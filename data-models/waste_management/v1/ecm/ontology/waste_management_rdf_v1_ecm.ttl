# --- Attribute Properties ---
ind:acquisitionId rdf:type rdf:Property ;
    rdfs:label 'Acquisition Id' ;
    rdfs:comment 'Unique identifier for the asset acquisition event. Primary key for the acquisition record.' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:acquisitionFixedAssetId rdf:type rdf:Property ;
    rdfs:label 'Acquisition Fixed Asset Id' ;
    rdfs:comment 'Reference to the fixed asset master record that was acquired through this acquisition event. Links to the asset master upon capitalization.' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FixedAsset .

ind:acquisitionTradeInAssetFixedAssetId rdf:type rdf:Property ;
    rdfs:label 'Acquisition Trade In Asset Fixed Asset Id' ;
    rdfs:comment 'Reference to the existing asset that was traded in as part of this acquisition. Links to the disposed asset record for gain/loss calculation.' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FixedAsset .

ind:capitalProjectId rdf:type rdf:Property ;
    rdfs:label 'Capital Project Id' ;
    rdfs:comment 'Reference to the capital project or CapEx initiative under which this asset was acquired. Links to capital planning and budget tracking systems.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CapitalProject .

ind:classId rdf:type rdf:Property ;
    rdfs:label 'Class Id' ;
    rdfs:comment 'Foreign key linking to asset.asset_class. Business justification: Acquisition has asset_class STRING indicating the class of the asset being acquired, but asset_class table exists with capitalization thresholds, depreciation rules, and GL accounts. Adding asset_clas' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Class .

ind:vendorId rdf:type rdf:Property ;
    rdfs:label 'Vendor Id' ;
    rdfs:comment 'Reference to the vendor or supplier from whom the asset was purchased. Links to vendor master in SAP MM.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:acquisitionDate rdf:type rdf:Property ;
    rdfs:label 'Acquisition Date' ;
    rdfs:comment 'Date the asset was acquired and placed into service. Used as the start date for depreciation calculation and asset lifecycle tracking.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:acquisitionMethod rdf:type rdf:Property ;
    rdfs:label 'Acquisition Method' ;
    rdfs:comment 'Method by which the asset was acquired. Determines capitalization treatment and accounting entries per GAAP/IFRS standards.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acquisitionNumber rdf:type rdf:Property ;
    rdfs:label 'Acquisition Number' ;
    rdfs:comment 'Business identifier for the acquisition transaction. Externally-known reference number used in procurement and accounting documentation.' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acquisitionStatus rdf:type rdf:Property ;
    rdfs:label 'Acquisition Status' ;
    rdfs:comment 'Current status of the acquisition transaction in its lifecycle. Tracks progression from approval through capitalization or cancellation. [ENUM-REF-CANDIDATE: pending|approved|in_transit|received|installed|capitalized|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalAuthority rdf:type rdf:Property ;
    rdfs:label 'Approval Authority' ;
    rdfs:comment 'Name or title of the individual or committee that approved the asset acquisition. Supports SOX compliance and capital expenditure governance.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalDate rdf:type rdf:Property ;
    rdfs:label 'Approval Date' ;
    rdfs:comment 'Date the asset acquisition was formally approved by the designated authority. Part of the audit trail for capital expenditure controls.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:budgetLineItem rdf:type rdf:Property ;
    rdfs:label 'Budget Line Item' ;
    rdfs:comment 'Specific budget line item or cost center code against which the acquisition was charged. Used for budget variance analysis and financial control.' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capitalizationDate rdf:type rdf:Property ;
    rdfs:label 'Capitalization Date' ;
    rdfs:comment 'Date the asset was capitalized in the general ledger and added to the fixed asset register. May differ from acquisition date for constructed assets.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cost rdf:type rdf:Property ;
    rdfs:label 'Cost' ;
    rdfs:comment 'Base purchase price of the asset before additional costs. Represents the invoice amount paid to the vendor excluding freight, installation, and other capitalizable costs.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:createdTimestamp rdf:type rdf:Property ;
    rdfs:label 'Created Timestamp' ;
    rdfs:comment 'Timestamp when the acquisition record was first created in the system. Part of the audit trail for data lineage and compliance.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:currencyCode rdf:type rdf:Property ;
    rdfs:label 'Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the acquisition transaction. Primarily USD for domestic operations, with CAD and MXN for North American facilities.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depreciationMethod rdf:type rdf:Property ;
    rdfs:label 'Depreciation Method' ;
    rdfs:comment 'Depreciation method applied to the asset for financial reporting. Straight-line is most common for waste management fixed assets per GAAP.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightCost rdf:type rdf:Property ;
    rdfs:label 'Freight Cost' ;
    rdfs:comment 'Transportation and shipping costs incurred to deliver the asset to its installation location. Capitalized as part of total asset cost per GAAP.' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fundingSource rdf:type rdf:Property ;
    rdfs:label 'Funding Source' ;
    rdfs:comment 'Source of funds used to finance the asset acquisition. Tracks whether the asset was funded through operating budget, capital expenditure budget, grants, or financing arrangements.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:installationCost rdf:type rdf:Property ;
    rdfs:label 'Installation Cost' ;
    rdfs:comment 'Costs incurred to install, configure, and prepare the asset for its intended use. Includes labor, materials, and contractor fees. Capitalized per GAAP.' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceDate rdf:type rdf:Property ;
    rdfs:label 'Invoice Date' ;
    rdfs:comment 'Date of the vendor invoice for the asset purchase. Used for payment terms calculation and financial period assignment.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:invoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Invoice Number' ;
    rdfs:comment 'Vendor invoice number associated with the asset purchase. Used for accounts payable reconciliation and audit verification.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedBy rdf:type rdf:Property ;
    rdfs:label 'Modified By' ;
    rdfs:comment 'User ID or name of the individual who last modified the acquisition record. Supports audit trail and change management.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Modified Timestamp' ;
    rdfs:comment 'Timestamp when the acquisition record was last modified. Tracks changes for audit and data quality purposes.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:notes rdf:type rdf:Property ;
    rdfs:label 'Notes' ;
    rdfs:comment 'Free-text notes capturing additional context about the acquisition, such as special terms, conditions, or justification for the purchase.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otherCapitalizableCosts rdf:type rdf:Property ;
    rdfs:label 'Other Capitalizable Costs' ;
    rdfs:comment 'Additional costs that are capitalized as part of the asset value, such as site preparation, testing, training, or legal fees directly attributable to the acquisition.' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:purchaseOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Number' ;
    rdfs:comment 'Purchase order number issued to procure the asset. Links to SAP MM purchasing documents for procurement audit trail.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salvageValue rdf:type rdf:Property ;
    rdfs:label 'Salvage Value' ;
    rdfs:comment 'Estimated residual value of the asset at the end of its useful life. Used in depreciation calculation to determine depreciable basis.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sapAssetDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Asset Document Number' ;
    rdfs:comment 'SAP asset acquisition document number generated when the asset was capitalized in SAP FI-AA. Links to SAP fixed asset master and depreciation runs.' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCapitalizedCost rdf:type rdf:Property ;
    rdfs:label 'Total Capitalized Cost' ;
    rdfs:comment 'Total cost capitalized for the asset, including acquisition cost, freight, installation, and other capitalizable costs. This is the depreciable basis for the asset.' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tradeInValue rdf:type rdf:Property ;
    rdfs:label 'Trade In Value' ;
    rdfs:comment 'Credit or allowance received for the trade-in asset, reducing the net acquisition cost. Used in gain/loss calculation on asset disposal.' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usefulLifeYears rdf:type rdf:Property ;
    rdfs:label 'Useful Life Years' ;
    rdfs:comment 'Expected useful life of the asset in years, used for depreciation calculation. Determined by asset class and company depreciation policy.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyEndDate rdf:type rdf:Property ;
    rdfs:label 'Warranty End Date' ;
    rdfs:comment 'Date the manufacturer or vendor warranty coverage expires. Triggers transition to internal maintenance or extended warranty consideration.' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:warrantyStartDate rdf:type rdf:Property ;
    rdfs:label 'Warranty Start Date' ;
    rdfs:comment 'Date the manufacturer or vendor warranty coverage begins for the acquired asset. Used for maintenance planning and warranty claim tracking.' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:warrantyTerms rdf:type rdf:Property ;
    rdfs:label 'Warranty Terms' ;
    rdfs:comment 'Description of warranty coverage terms, including what is covered, exclusions, and claim procedures. Supports warranty management and cost avoidance.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdBy rdf:type rdf:Property ;
    rdfs:label 'Created By' ;
    rdfs:comment 'User ID or name of the individual who created the acquisition record. Supports audit trail and accountability for data entry.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentAssetClassId rdf:type rdf:Property ;
    rdfs:label 'Parent Asset Class Id' ;
    rdfs:comment 'Reference to the parent asset class in the classification hierarchy, enabling multi-level asset categorization (e.g., Containers > Roll-Off Containers > 20-Yard Roll-Offs).' ;
    rdfs:domain ind:Class ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Class .

ind:assetCategory rdf:type rdf:Property ;
    rdfs:label 'Asset Category' ;
    rdfs:comment 'High-level categorization of the asset class aligned with Waste Management operational divisions. Containers include dumpsters, roll-offs, carts; stationary equipment includes compactors, balers, scales; infrastructure includes landfill cells, liners, caps, leachate systems. [ENUM-REF-CANDIDATE: container|stationary_equipment|landfill_infrastructure|mrf_equipment|wte_equipment|transfer_station_equipment|building|land|vehicle_attachment|other — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetClassCode rdf:type rdf:Property ;
    rdfs:label 'Asset Class Code' ;
    rdfs:comment 'External business identifier for the asset class used in SAP and financial reporting. Typically a 4-12 character alphanumeric code aligned with chart of accounts structure.' ;
    rdfs:domain ind:Class ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetClassDescription rdf:type rdf:Property ;
    rdfs:label 'Asset Class Description' ;
    rdfs:comment 'Detailed description of the asset class including scope, typical assets included, and business purpose.' ;
    rdfs:domain ind:Class ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetClassName rdf:type rdf:Property ;
    rdfs:label 'Asset Class Name' ;
    rdfs:comment 'Full descriptive name of the asset class (e.g., Roll-Off Containers, Front-End Loaders, Compactors, Landfill Infrastructure, MRF Equipment).' ;
    rdfs:domain ind:Class ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetType rdf:type rdf:Property ;
    rdfs:label 'Asset Type' ;
    rdfs:comment 'Specific type within the asset category providing granular classification (e.g., Front-End Loader, Rear-End Loader, Automated Side Loader, Stationary Compactor, Baler, Weighbridge, Landfill Cell, MRF Sorting Line).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capitalizationThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Capitalization Threshold Amount' ;
    rdfs:comment 'Minimum acquisition cost required for an asset in this class to be capitalized rather than expensed, aligned with GAAP/IFRS policies and company materiality thresholds.' ;
    rdfs:domain ind:Class ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capitalizationThresholdCurrency rdf:type rdf:Property ;
    rdfs:label 'Capitalization Threshold Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the capitalization threshold amount (e.g., USD, CAD, MXN).' ;
    rdfs:domain ind:Class ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classStatus rdf:type rdf:Property ;
    rdfs:label 'Class Status' ;
    rdfs:comment 'Current lifecycle status of the asset class in the master data system. Active classes are available for new asset creation; deprecated classes are retained for historical assets only.' ;
    rdfs:domain ind:Class ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterDefault rdf:type rdf:Property ;
    rdfs:label 'Cost Center Default' ;
    rdfs:comment 'Default cost center code for assets in this class, used for management accounting and operational expense allocation in SAP CO.' ;
    rdfs:domain ind:Class ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalityRating rdf:type rdf:Property ;
    rdfs:label 'Criticality Rating' ;
    rdfs:comment 'Business criticality classification for assets in this class based on operational impact of failure. Critical assets require immediate response; low criticality assets can tolerate longer downtime.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveEndDate rdf:type rdf:Property ;
    rdfs:label 'Effective End Date' ;
    rdfs:comment 'Date after which this asset class configuration is no longer valid for new asset creation. Null for currently active configurations.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveStartDate rdf:type rdf:Property ;
    rdfs:label 'Effective Start Date' ;
    rdfs:comment 'Date from which this asset class configuration becomes effective for new asset creation and depreciation calculation.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:energyConsumptionTracked rdf:type rdf:Property ;
    rdfs:label 'Energy Consumption Tracked' ;
    rdfs:comment 'Indicates whether energy consumption (electricity, natural gas, diesel) is tracked at the asset class level for sustainability reporting and cost allocation.' ;
    rdfs:domain ind:Class ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:environmentalImpactCategory rdf:type rdf:Property ;
    rdfs:label 'Environmental Impact Category' ;
    rdfs:comment 'Classification of potential environmental impact from failure or improper operation of assets in this class. High for landfill liners and leachate systems; medium for compactors and balers; low for administrative assets.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epaReportingRequired rdf:type rdf:Property ;
    rdfs:label 'Epa Reporting Required' ;
    rdfs:comment 'Indicates whether assets in this class must be included in EPA regulatory reporting (e.g., landfill gas collection systems, leachate treatment equipment, air emission control devices).' ;
    rdfs:domain ind:Class ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ghgEmissionSource rdf:type rdf:Property ;
    rdfs:label 'Ghg Emission Source' ;
    rdfs:comment 'Indicates whether assets in this class are direct sources of greenhouse gas emissions requiring monitoring and reporting (e.g., landfill gas collection systems, WTE combustion equipment, stationary engines).' ;
    rdfs:domain ind:Class ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:glAccumulatedDepreciationAccount rdf:type rdf:Property ;
    rdfs:label 'Gl Accumulated Depreciation Account' ;
    rdfs:comment 'General Ledger contra-asset account number for accumulated depreciation of assets in this class. Maps to SAP FI chart of accounts.' ;
    rdfs:domain ind:Class ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAssetAccount rdf:type rdf:Property ;
    rdfs:label 'Gl Asset Account' ;
    rdfs:comment 'General Ledger account number for capitalizing assets in this class on the balance sheet. Maps to SAP FI chart of accounts.' ;
    rdfs:domain ind:Class ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glDepreciationAccount rdf:type rdf:Property ;
    rdfs:label 'Gl Depreciation Account' ;
    rdfs:comment 'General Ledger account number for recording depreciation expense for assets in this class. Maps to SAP FI chart of accounts.' ;
    rdfs:domain ind:Class ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glGainLossAccount rdf:type rdf:Property ;
    rdfs:label 'Gl Gain Loss Account' ;
    rdfs:comment 'General Ledger account number for recording gains or losses on disposal or retirement of assets in this class.' ;
    rdfs:domain ind:Class ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Inspection Frequency Days' ;
    rdfs:comment 'Standard interval in days between required inspections for assets in this class. Null if periodic inspection is not required.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:insuranceRequired rdf:type rdf:Property ;
    rdfs:label 'Insurance Required' ;
    rdfs:comment 'Indicates whether assets in this class must carry specific insurance coverage beyond general property insurance (e.g., environmental liability insurance for landfill cells, equipment breakdown insurance for WTE plants).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insuranceType rdf:type rdf:Property ;
    rdfs:label 'Insurance Type' ;
    rdfs:comment 'Type of insurance coverage required for assets in this class (e.g., Environmental Liability, Equipment Breakdown, Pollution Legal Liability, Property and Casualty). Null if no specific insurance required.' ;
    rdfs:domain ind:Class ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceStrategy rdf:type rdf:Property ;
    rdfs:label 'Maintenance Strategy' ;
    rdfs:comment 'Default maintenance approach for assets in this class. Preventive for scheduled maintenance; predictive for sensor-monitored equipment; reactive for low-criticality items; condition-based for inspection-driven maintenance.' ;
    rdfs:domain ind:Class ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturerWarrantyMonths rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Warranty Months' ;
    rdfs:comment 'Typical manufacturer warranty period in months for new assets in this class. Used for warranty tracking and maintenance planning during warranty period.' ;
    rdfs:domain ind:Class ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rcraRegulated rdf:type rdf:Property ;
    rdfs:label 'Rcra Regulated' ;
    rdfs:comment 'Indicates whether assets in this class are subject to RCRA hazardous waste management regulations (e.g., hazardous waste storage containers, treatment equipment, TSDF infrastructure).' ;
    rdfs:domain ind:Class ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresGpsTracking rdf:type rdf:Property ;
    rdfs:label 'Requires Gps Tracking' ;
    rdfs:comment 'Indicates whether assets in this class require GPS tracking devices for location monitoring. May apply to mobile equipment and high-value portable assets.' ;
    rdfs:domain ind:Class ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresPeriodicInspection rdf:type rdf:Property ;
    rdfs:label 'Requires Periodic Inspection' ;
    rdfs:comment 'Indicates whether assets in this class are subject to mandatory periodic safety or compliance inspections (e.g., pressure vessels, lifting equipment, hazardous waste storage units).' ;
    rdfs:domain ind:Class ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresRfidTracking rdf:type rdf:Property ;
    rdfs:label 'Requires Rfid Tracking' ;
    rdfs:comment 'Indicates whether assets in this class must be equipped with RFID tags for automated tracking and inventory management. Typically true for containers (CID tracking), false for fixed infrastructure.' ;
    rdfs:domain ind:Class ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:salvageValuePercentage rdf:type rdf:Property ;
    rdfs:label 'Salvage Value Percentage' ;
    rdfs:comment 'Expected residual value as a percentage of original cost at end of useful life. Containers and equipment may have 5-15% salvage value; buildings typically higher; landfill cells near zero.' ;
    rdfs:domain ind:Class ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serializedTrackingRequired rdf:type rdf:Property ;
    rdfs:label 'Serialized Tracking Required' ;
    rdfs:comment 'Indicates whether individual assets in this class must be tracked by unique serial number in addition to asset ID. True for high-value equipment and containers; false for bulk infrastructure.' ;
    rdfs:domain ind:Class ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:usefulLifeYearsDefault rdf:type rdf:Property ;
    rdfs:label 'Useful Life Years Default' ;
    rdfs:comment 'Standard useful life in years applied by default when creating new assets in this class, typically the midpoint or most common value within the min-max range.' ;
    rdfs:domain ind:Class ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:usefulLifeYearsMax rdf:type rdf:Property ;
    rdfs:label 'Useful Life Years Max' ;
    rdfs:comment 'Maximum expected useful life in years for assets in this class, providing a range for depreciation planning based on usage intensity and maintenance quality.' ;
    rdfs:domain ind:Class ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:usefulLifeYearsMin rdf:type rdf:Property ;
    rdfs:label 'Useful Life Years Min' ;
    rdfs:comment 'Minimum expected useful life in years for assets in this class, used for depreciation calculation and asset lifecycle planning.' ;
    rdfs:domain ind:Class ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:conditionHistoryId rdf:type rdf:Property ;
    rdfs:label 'Condition History Id' ;
    rdfs:comment 'Unique identifier for each asset condition history record. Primary key for the asset condition history log.' ;
    rdfs:domain ind:ConditionHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fixedAssetId rdf:type rdf:Property ;
    rdfs:label 'Fixed Asset Id' ;
    rdfs:comment 'Reference to the fixed asset whose condition is being tracked. Links to the asset master record in SAP PM or Infor EAM.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FixedAsset .

ind:inspectionWorkOrderId rdf:type rdf:Property ;
    rdfs:label 'Inspection Work Order Id' ;
    rdfs:comment 'Reference to the work order under which this condition assessment was performed. Links to Infor EAM or SAP PM work order records.' ;
    rdfs:domain ind:ConditionHistory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkOrder .

ind:inspectorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Inspector Employee Id' ;
    rdfs:comment 'Reference to the employee or technician who performed the condition assessment. Links to Workday HCM employee master data.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assessmentMethod rdf:type rdf:Property ;
    rdfs:label 'Assessment Method' ;
    rdfs:comment 'The method or technique used to assess the asset condition. Distinguishes between manual inspections, automated sensor data, and predictive analytics.' ;
    rdfs:domain ind:ConditionHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentNotes rdf:type rdf:Property ;
    rdfs:label 'Assessment Notes' ;
    rdfs:comment 'Free-text notes and observations from the condition assessment. Provides detailed context for condition changes and recommended actions.' ;
    rdfs:domain ind:ConditionHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assessment Timestamp' ;
    rdfs:comment 'Date and time when the condition assessment was performed or recorded. Principal business event timestamp for this log entry.' ;
    rdfs:domain ind:ConditionHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assessmentType rdf:type rdf:Property ;
    rdfs:label 'Assessment Type' ;
    rdfs:comment 'Classification of the assessment based on its business purpose. Supports compliance tracking and maintenance strategy analysis.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceInspectionFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Inspection Flag' ;
    rdfs:comment 'Indicates whether this assessment was performed to satisfy regulatory compliance requirements (EPA, OSHA, DOT, state environmental agencies).' ;
    rdfs:domain ind:ConditionHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conditionChangeReason rdf:type rdf:Property ;
    rdfs:label 'Condition Change Reason' ;
    rdfs:comment 'Explanation or root cause for the change in asset condition. Captures factors such as wear and tear, environmental exposure, accident damage, or maintenance improvements.' ;
    rdfs:domain ind:ConditionHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionScore rdf:type rdf:Property ;
    rdfs:label 'Condition Score' ;
    rdfs:comment 'Numeric condition score on a standardized scale (typically 0-100) representing asset health. Enables quantitative trend analysis and predictive maintenance modeling.' ;
    rdfs:domain ind:ConditionHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:criticalDefectFlag rdf:type rdf:Property ;
    rdfs:label 'Critical Defect Flag' ;
    rdfs:comment 'Indicates whether any critical or safety-related defects were identified during this assessment. Triggers immediate corrective action workflows.' ;
    rdfs:domain ind:ConditionHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:currentConditionGrade rdf:type rdf:Property ;
    rdfs:label 'Current Condition Grade' ;
    rdfs:comment 'The new condition rating assigned during this assessment. Used for asset health monitoring and replacement prioritization.' ;
    rdfs:domain ind:ConditionHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectCount rdf:type rdf:Property ;
    rdfs:label 'Defect Count' ;
    rdfs:comment 'Number of defects or issues identified during this condition assessment. Quantifies asset health problems for prioritization and trend analysis.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:documentAttachmentCount rdf:type rdf:Property ;
    rdfs:label 'Document Attachment Count' ;
    rdfs:comment 'Number of supporting documents (inspection reports, test results, certifications) attached to this condition assessment.' ;
    rdfs:domain ind:ConditionHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:environmentalRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Environmental Risk Level' ;
    rdfs:comment 'Assessment of environmental risk posed by the asset in its current condition. Critical for landfill liners, leachate systems, and hazardous waste containers.' ;
    rdfs:domain ind:ConditionHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedRemainingLifeYears rdf:type rdf:Property ;
    rdfs:label 'Estimated Remaining Life Years' ;
    rdfs:comment 'Estimated number of years the asset can continue to operate in its current condition before replacement is required. Supports capital planning and budgeting.' ;
    rdfs:domain ind:ConditionHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedRepairCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Repair Cost' ;
    rdfs:comment 'Estimated cost to repair or remediate the identified condition issues. Supports maintenance budgeting and repair-versus-replace analysis.' ;
    rdfs:domain ind:ConditionHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gpsLatitude rdf:type rdf:Property ;
    rdfs:label 'Gps Latitude' ;
    rdfs:comment 'Latitude coordinate where the condition assessment was performed. Supports field inspection verification and mobile workforce tracking.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gpsLongitude rdf:type rdf:Property ;
    rdfs:label 'Gps Longitude' ;
    rdfs:comment 'Longitude coordinate where the condition assessment was performed. Supports field inspection verification and mobile workforce tracking.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inspectionReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Inspection Reference Number' ;
    rdfs:comment 'External reference number or document identifier for the inspection report or assessment record. Supports traceability to source documentation.' ;
    rdfs:domain ind:ConditionHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectorName rdf:type rdf:Property ;
    rdfs:label 'Inspector Name' ;
    rdfs:comment 'Full name of the technician or inspector who recorded the condition change. Provides human-readable reference for audit and accountability.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextAssessmentDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Assessment Due Date' ;
    rdfs:comment 'Scheduled date for the next condition assessment based on inspection frequency requirements and asset criticality. Drives preventive maintenance scheduling.' ;
    rdfs:domain ind:ConditionHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operationalImpact rdf:type rdf:Property ;
    rdfs:label 'Operational Impact' ;
    rdfs:comment 'Assessment of how the current asset condition affects operational performance and service delivery. Supports asset replacement prioritization.' ;
    rdfs:domain ind:ConditionHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:photoAttachmentCount rdf:type rdf:Property ;
    rdfs:label 'Photo Attachment Count' ;
    rdfs:comment 'Number of photos or images attached to this condition assessment record. Supports visual documentation of asset condition.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:previousConditionGrade rdf:type rdf:Property ;
    rdfs:label 'Previous Condition Grade' ;
    rdfs:comment 'The condition rating of the asset immediately before this assessment. Enables tracking of condition degradation or improvement over time.' ;
    rdfs:domain ind:ConditionHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendedAction rdf:type rdf:Property ;
    rdfs:label 'Recommended Action' ;
    rdfs:comment 'The recommended maintenance or lifecycle action based on this condition assessment. Drives work order generation and capital planning decisions.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendedActionPriority rdf:type rdf:Property ;
    rdfs:label 'Recommended Action Priority' ;
    rdfs:comment 'Priority level for the recommended action. Determines scheduling and resource allocation for corrective maintenance.' ;
    rdfs:domain ind:ConditionHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAgency rdf:type rdf:Property ;
    rdfs:label 'Regulatory Agency' ;
    rdfs:comment 'Name of the regulatory agency or authority for which this compliance inspection was performed (e.g., EPA, OSHA, state environmental department).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Safety Risk Level' ;
    rdfs:comment 'Assessment of safety risk posed by the asset in its current condition. Aligns with OSHA and EPA safety compliance requirements.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sensorDeviceCode rdf:type rdf:Property ;
    rdfs:label 'Sensor Device Code' ;
    rdfs:comment 'Identifier of the IoT sensor or monitoring device that captured automated condition data. Applicable for sensor-based assessments on compactors, scales, and facility equipment.' ;
    rdfs:domain ind:ConditionHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:systemSource rdf:type rdf:Property ;
    rdfs:label 'System Source' ;
    rdfs:comment 'Source system or application that recorded this condition assessment. Supports data lineage and integration troubleshooting.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impairmentId rdf:type rdf:Property ;
    rdfs:label 'Impairment Id' ;
    rdfs:comment 'Unique identifier for the asset impairment assessment record. Primary key.' ;
    rdfs:domain ind:Impairment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:facilityId rdf:type rdf:Property ;
    rdfs:label 'Facility Id' ;
    rdfs:comment 'Reference to the facility where the impaired asset is located. Particularly relevant for landfill sites approaching capacity limits or WTE plants subject to regulatory changes.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WasteManagement .

ind:appraisalReportReference rdf:type rdf:Property ;
    rdfs:label 'Appraisal Report Reference' ;
    rdfs:comment 'Reference number or document identifier for the external appraisal report supporting the impairment assessment.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appraiserName rdf:type rdf:Property ;
    rdfs:label 'Appraiser Name' ;
    rdfs:comment 'Name of the independent appraiser or valuation firm that performed the asset valuation, if an external appraisal was obtained.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvingAuthority rdf:type rdf:Property ;
    rdfs:label 'Approving Authority' ;
    rdfs:comment 'Name or title of the executive or authority who approved the impairment assessment and write-down. Typically CFO or Controller for material impairments.' ;
    rdfs:domain ind:Impairment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditTrailReference rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Reference' ;
    rdfs:comment 'Reference to supporting documentation, work papers, and audit trail materials that substantiate the impairment assessment for internal and external audit purposes.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carryingAmount rdf:type rdf:Property ;
    rdfs:label 'Carrying Amount' ;
    rdfs:comment 'The net book value of the asset immediately before the impairment loss is recognized, calculated as acquisition cost less accumulated depreciation.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:companyCode rdf:type rdf:Property ;
    rdfs:label 'Company Code' ;
    rdfs:comment 'The legal entity or company code in the ERP system (SAP S/4HANA) to which this impairment belongs.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenter rdf:type rdf:Property ;
    rdfs:label 'Cost Center' ;
    rdfs:comment 'The cost center responsible for the impaired asset, used for management accounting and cost allocation.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountRatePercent rdf:type rdf:Property ;
    rdfs:label 'Discount Rate Percent' ;
    rdfs:comment 'The discount rate applied in calculating the present value of future cash flows for value-in-use calculations, expressed as a percentage.' ;
    rdfs:domain ind:Impairment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalIncidentFlag rdf:type rdf:Property ;
    rdfs:label 'Environmental Incident Flag' ;
    rdfs:comment 'Indicates whether an environmental incident (e.g., leachate release, air quality violation, groundwater contamination) contributed to the impairment assessment.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fairValueLessCostsToSell rdf:type rdf:Property ;
    rdfs:label 'Fair Value Less Costs To Sell' ;
    rdfs:comment 'The estimated market value of the asset less the costs that would be incurred to dispose of it. Used in determining recoverable amount under IFRS.' ;
    rdfs:domain ind:Impairment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fiscalPeriod rdf:type rdf:Property ;
    rdfs:label 'Fiscal Period' ;
    rdfs:comment 'The fiscal period (month or quarter) within the fiscal year in which the impairment loss is recognized.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalYear rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year' ;
    rdfs:comment 'The fiscal year in which the impairment loss is recognized for financial reporting purposes.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:glPostingDate rdf:type rdf:Property ;
    rdfs:label 'Gl Posting Date' ;
    rdfs:comment 'The effective date on which the impairment loss was posted to the general ledger for financial reporting purposes.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:glPostingDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Gl Posting Document Number' ;
    rdfs:comment 'The document number in the general ledger system (SAP FI) that records the impairment loss journal entry.' ;
    rdfs:domain ind:Impairment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impairmentNumber rdf:type rdf:Property ;
    rdfs:label 'Impairment Number' ;
    rdfs:comment 'Business identifier for the impairment assessment, typically generated by the financial system for tracking and audit purposes.' ;
    rdfs:domain ind:Impairment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impairmentStatus rdf:type rdf:Property ;
    rdfs:label 'Impairment Status' ;
    rdfs:comment 'Current lifecycle status of the impairment assessment in the approval and posting workflow.' ;
    rdfs:domain ind:Impairment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impairmentType rdf:type rdf:Property ;
    rdfs:label 'Impairment Type' ;
    rdfs:comment 'Classification of whether the impairment is permanent (not reversible) or potentially reversible under future conditions. GAAP generally prohibits reversal; IFRS allows reversal under certain conditions.' ;
    rdfs:domain ind:Impairment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:landfillRemainingCapacityTons rdf:type rdf:Property ;
    rdfs:label 'Landfill Remaining Capacity Tons' ;
    rdfs:comment 'For landfill assets, the remaining permitted capacity in tons at the time of impairment assessment. Approaching capacity limits is a common impairment trigger for landfill infrastructure.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lossAmount rdf:type rdf:Property ;
    rdfs:label 'Loss Amount' ;
    rdfs:comment 'The amount by which the carrying amount exceeds the recoverable amount. This is the write-down amount recognized in the financial statements.' ;
    rdfs:domain ind:Impairment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recoverableAmount rdf:type rdf:Property ;
    rdfs:label 'Recoverable Amount' ;
    rdfs:comment 'The higher of the asset\'s fair value less costs to sell or its value in use. This is the amount the asset is expected to recover through use or sale.' ;
    rdfs:domain ind:Impairment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reference' ;
    rdfs:comment 'Reference to specific regulatory changes, permit modifications, or compliance requirements that triggered or contributed to the impairment (e.g., EPA permit restrictions, RCRA changes, state environmental regulations).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalAmount rdf:type rdf:Property ;
    rdfs:label 'Reversal Amount' ;
    rdfs:comment 'The amount of impairment loss reversed, if applicable under IFRS. Limited to the amount that would restore the asset to its depreciated historical cost.' ;
    rdfs:domain ind:Impairment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reversalDate rdf:type rdf:Property ;
    rdfs:label 'Reversal Date' ;
    rdfs:comment 'The date on which the impairment loss was reversed, if applicable under IFRS. Null if no reversal has occurred.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reversalIndicator rdf:type rdf:Property ;
    rdfs:label 'Reversal Indicator' ;
    rdfs:comment 'Flag indicating whether this impairment has been subsequently reversed. Applicable under IFRS IAS 36; not permitted under GAAP ASC 360.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:soxMaterialFlag rdf:type rdf:Property ;
    rdfs:label 'Sox Material Flag' ;
    rdfs:comment 'Indicates whether the impairment loss is material for SOX financial reporting and internal control purposes, requiring enhanced documentation and executive certification.' ;
    rdfs:domain ind:Impairment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:testDate rdf:type rdf:Property ;
    rdfs:label 'Test Date' ;
    rdfs:comment 'The date on which the impairment assessment was performed. This is the principal business event timestamp for the impairment evaluation.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:triggeringEvent rdf:type rdf:Property ;
    rdfs:label 'Triggering Event' ;
    rdfs:comment 'The business event or condition that triggered the impairment assessment. Common triggers include market decline, physical damage, regulatory changes, technology obsolescence, landfill capacity limits, or environmental incidents. [ENUM-REF-CANDIDATE: market_decline|physical_damage|regulatory_change|technology_obsolescence|capacity_limit|operational_closure|environmental_incident — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Impairment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggeringEventDescription rdf:type rdf:Property ;
    rdfs:label 'Triggering Event Description' ;
    rdfs:comment 'Detailed narrative describing the specific circumstances that triggered the impairment assessment, including relevant facts, dates, and business context.' ;
    rdfs:domain ind:Impairment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationMethod rdf:type rdf:Property ;
    rdfs:label 'Valuation Method' ;
    rdfs:comment 'The methodology used to determine the recoverable amount or fair value of the asset for impairment testing purposes.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valueInUse rdf:type rdf:Property ;
    rdfs:label 'Value In Use' ;
    rdfs:comment 'The present value of future cash flows expected to be derived from the asset through continued use and eventual disposal. Used in determining recoverable amount under IFRS.' ;
    rdfs:domain ind:Impairment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assetInspectionId rdf:type rdf:Property ;
    rdfs:label 'Asset Inspection Id' ;
    rdfs:comment 'Unique identifier for the asset inspection record. Primary key.' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:checklistId rdf:type rdf:Property ;
    rdfs:label 'Checklist Id' ;
    rdfs:comment 'Identifier of the standardized inspection checklist or template used for this inspection, ensuring consistency and completeness of inspection procedures.' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InspectionChecklist .

ind:primaryAssetEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Asset Employee Id' ;
    rdfs:comment 'Identifier of the employee or contractor who performed the inspection.' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:workOrderId rdf:type rdf:Property ;
    rdfs:label 'Work Order Id' ;
    rdfs:comment 'Identifier of the work order generated as a result of this inspection, if corrective action was required. Links inspection findings to maintenance execution.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkOrder .

ind:assetOutOfServiceFlag rdf:type rdf:Property ;
    rdfs:label 'Asset Out Of Service Flag' ;
    rdfs:comment 'Boolean indicator (True/False) specifying whether the asset was taken out of service as a result of this inspection due to safety concerns, regulatory non-compliance, or critical defects. Triggers asset status update in Infor EAM.' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:correctiveActionDescription rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Description' ;
    rdfs:comment 'Detailed description of the corrective actions recommended or required, including repair scope, parts needed, estimated labor hours, and priority level. Used to generate work orders and allocate maintenance resources.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionPriority rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Priority' ;
    rdfs:comment 'Priority level for corrective action: critical (immediate safety or regulatory risk), high (significant operational impact), medium (scheduled repair), or low (cosmetic or deferred maintenance).' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Required Flag' ;
    rdfs:comment 'Boolean indicator (True/False) specifying whether corrective action (repair, replacement, or remediation) is required as a result of this inspection. Triggers work order generation in Infor EAM.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:defectFindings rdf:type rdf:Property ;
    rdfs:label 'Defect Findings' ;
    rdfs:comment 'Free-text or structured description of specific defects identified during inspection, such as dents, cracks, leaks, rust, graffiti, missing lids, broken hinges, worn seals, hydraulic leaks, structural damage, or electrical faults. Supports root cause analysis and maintenance planning.' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationMinutes rdf:type rdf:Property ;
    rdfs:label 'Duration Minutes' ;
    rdfs:comment 'Total time in minutes required to complete the inspection, used for labor cost allocation, productivity analysis, and scheduling optimization.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inspectionDate rdf:type rdf:Property ;
    rdfs:label 'Inspection Date' ;
    rdfs:comment 'Date on which the physical inspection was performed.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inspectionMethod rdf:type rdf:Property ;
    rdfs:label 'Inspection Method' ;
    rdfs:comment 'Method or technique used to perform the inspection: visual (walk-around observation), manual (hands-on testing), automated (RFID scan, IoT sensor), sensor_based (remote monitoring), or third_party (external contractor or certification body).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionNumber rdf:type rdf:Property ;
    rdfs:label 'Inspection Number' ;
    rdfs:comment 'Business-facing unique inspection number or code used for tracking and reference in work orders and compliance documentation.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Inspection Status' ;
    rdfs:comment 'Current lifecycle status of the inspection: scheduled (planned but not started), in_progress (underway), completed (finished and recorded), cancelled (not performed), or failed (inspection could not be completed due to access or safety issues).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Inspection Timestamp' ;
    rdfs:comment 'Precise date and time when the inspection was completed, supporting shift-level and real-time tracking.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:inspectionType rdf:type rdf:Property ;
    rdfs:label 'Inspection Type' ;
    rdfs:comment 'Category of inspection performed: routine (scheduled periodic), pre-deployment (before asset is placed in service), post-incident (after damage or accident), regulatory (mandated by EPA, OSHA, DOT), preventive maintenance (PM-driven), safety (OSHA compliance), or quality assurance. [ENUM-REF-CANDIDATE: routine|pre_deployment|post_incident|regulatory|preventive_maintenance|safety|quality_assurance — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectorCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Inspector Certification Number' ;
    rdfs:comment 'Certification or license number of the inspector, if required by regulation (e.g., DOT inspector certification, OSHA competent person designation, EPA-certified technician). Validates inspector qualifications.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:location rdf:type rdf:Property ;
    rdfs:label 'Location' ;
    rdfs:comment 'Physical location where the inspection was performed, such as facility name, yard, maintenance shop, customer site, or field location. Supports geographic analysis and compliance documentation.' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextScheduledInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Inspection Date' ;
    rdfs:comment 'Date on which the next inspection of this asset is scheduled, based on regulatory requirements, preventive maintenance schedules, or asset condition. Supports compliance tracking and proactive maintenance planning.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:overallConditionGrade rdf:type rdf:Property ;
    rdfs:label 'Overall Condition Grade' ;
    rdfs:comment 'Numeric condition rating on a 1-5 scale where 1=Excellent (no defects), 2=Good (minor wear), 3=Fair (moderate wear, functional), 4=Poor (significant defects, repair needed), 5=Critical (unsafe, immediate action required). Used for asset lifecycle and replacement planning.' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:passFailDetermination rdf:type rdf:Property ;
    rdfs:label 'Pass Fail Determination' ;
    rdfs:comment 'Binary or conditional outcome of the inspection: pass (asset meets all criteria), fail (asset does not meet criteria and cannot be used), or conditional_pass (asset can be used with restrictions or minor repairs).' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:photoDocumentationFlag rdf:type rdf:Property ;
    rdfs:label 'Photo Documentation Flag' ;
    rdfs:comment 'Boolean indicator (True/False) specifying whether photographic evidence was captured during the inspection. Photos are typically stored in a separate document management system and linked via inspection_id.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recordCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Created Timestamp' ;
    rdfs:comment 'Timestamp when this inspection record was first created in the system, supporting audit trail and data lineage.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Updated Timestamp' ;
    rdfs:comment 'Timestamp when this inspection record was last modified, supporting audit trail and change tracking.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:regulatoryComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Flag' ;
    rdfs:comment 'Boolean indicator (True/False) specifying whether this inspection was performed to satisfy a regulatory requirement from EPA, OSHA, DOT, or local enforcement agencies. Used for audit trail and compliance reporting.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reference Number' ;
    rdfs:comment 'Reference number or citation for the specific regulatory requirement that mandated this inspection, such as EPA permit condition, OSHA standard section, or DOT inspection code. Supports audit documentation.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyIncidentFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Incident Flag' ;
    rdfs:comment 'Boolean indicator (True/False) specifying whether a safety incident or near-miss occurred during the inspection. Triggers incident reporting workflow in Enviance EHS.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:weatherConditions rdf:type rdf:Property ;
    rdfs:label 'Weather Conditions' ;
    rdfs:comment 'Weather conditions at the time of inspection (e.g., clear, rain, snow, extreme heat), relevant for outdoor asset inspections where environmental factors may affect inspection quality or asset condition assessment.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetInsuranceId rdf:type rdf:Property ;
    rdfs:label 'Asset Insurance Id' ;
    rdfs:comment 'Unique identifier for the asset insurance coverage record. Primary key.' ;
    rdfs:domain ind:AssetInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:additionalInsuredParties rdf:type rdf:Property ;
    rdfs:label 'Additional Insured Parties' ;
    rdfs:comment 'Comma-separated list of additional parties named as insured under this policy. May include lessors, contractors, or municipalities requiring coverage.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brokerContactEmail rdf:type rdf:Property ;
    rdfs:label 'Broker Contact Email' ;
    rdfs:comment 'Primary email address for the insurance broker. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brokerContactPhone rdf:type rdf:Property ;
    rdfs:label 'Broker Contact Phone' ;
    rdfs:comment 'Primary phone number for the insurance broker. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brokerName rdf:type rdf:Property ;
    rdfs:label 'Broker Name' ;
    rdfs:comment 'The name of the insurance broker or agent who arranged this coverage. Used for policy servicing and renewal negotiations.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessInterruptionCoverageFlag rdf:type rdf:Property ;
    rdfs:label 'Business Interruption Coverage Flag' ;
    rdfs:comment 'Indicates whether the policy includes business interruption coverage for lost revenue if the asset is damaged and operations are disrupted. Critical for WTE plants, MRF facilities, and landfill operations.' ;
    rdfs:domain ind:AssetInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificateOfInsuranceIssuedDate rdf:type rdf:Property ;
    rdfs:label 'Certificate Of Insurance Issued Date' ;
    rdfs:comment 'The date when the certificate of insurance was issued. Used to verify current coverage for contract compliance and vendor requirements.' ;
    rdfs:domain ind:AssetInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:claimsCount rdf:type rdf:Property ;
    rdfs:label 'Claims Count' ;
    rdfs:comment 'The total number of insurance claims filed against this policy for this asset. Used for loss history analysis and premium negotiation.' ;
    rdfs:domain ind:AssetInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:coinsurancePercentage rdf:type rdf:Property ;
    rdfs:label 'Coinsurance Percentage' ;
    rdfs:comment 'The percentage of loss that the insured must bear if the asset is underinsured. Typically 80% or 90% coinsurance clause requiring asset to be insured to that percentage of value.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coverageEndDate rdf:type rdf:Property ;
    rdfs:label 'Coverage End Date' ;
    rdfs:comment 'The date when insurance coverage expires for this asset. Triggers renewal workflows and coverage gap alerts.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:coverageLimit rdf:type rdf:Property ;
    rdfs:label 'Coverage Limit' ;
    rdfs:comment 'The maximum amount the insurance policy will pay for a covered loss. May differ from insured value due to policy caps or sub-limits.' ;
    rdfs:domain ind:AssetInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coverageStartDate rdf:type rdf:Property ;
    rdfs:label 'Coverage Start Date' ;
    rdfs:comment 'The date when insurance coverage becomes effective for this asset. Used to determine coverage eligibility for claims.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:coverageStatus rdf:type rdf:Property ;
    rdfs:label 'Coverage Status' ;
    rdfs:comment 'Current status of the insurance coverage. Active indicates coverage is in force; expired indicates coverage has lapsed; cancelled indicates policy was terminated; pending renewal indicates coverage is up for renewal; suspended indicates temporary hold.' ;
    rdfs:domain ind:AssetInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageType rdf:type rdf:Property ;
    rdfs:label 'Coverage Type' ;
    rdfs:comment 'The type of insurance coverage provided. Property covers physical damage to assets; equipment breakdown covers mechanical/electrical failure; inland marine covers mobile equipment and goods in transit; general liability covers third-party claims; environmental liability covers pollution incidents; business interruption covers lost revenue.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deductibleAmount rdf:type rdf:Property ;
    rdfs:label 'Deductible Amount' ;
    rdfs:comment 'The deductible amount that must be paid out-of-pocket before insurance coverage applies. Used in claims processing and financial planning.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalCoverageFlag rdf:type rdf:Property ;
    rdfs:label 'Environmental Coverage Flag' ;
    rdfs:comment 'Indicates whether the policy includes environmental liability coverage for pollution incidents, contamination, or remediation costs. Essential for landfills, hazardous waste facilities, and transfer stations.' ;
    rdfs:domain ind:AssetInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insuredValue rdf:type rdf:Property ;
    rdfs:label 'Insured Value' ;
    rdfs:comment 'The declared value of the asset covered under the insurance policy. Used to determine coverage limits and premium calculations. Represents replacement cost or agreed value.' ;
    rdfs:domain ind:AssetInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insurerContactName rdf:type rdf:Property ;
    rdfs:label 'Insurer Contact Name' ;
    rdfs:comment 'Primary contact person at the insurance carrier for policy inquiries and claims.' ;
    rdfs:domain ind:AssetInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insurerEmail rdf:type rdf:Property ;
    rdfs:label 'Insurer Email' ;
    rdfs:comment 'Primary email address for the insurance carrier contact. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:AssetInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insurerName rdf:type rdf:Property ;
    rdfs:label 'Insurer Name' ;
    rdfs:comment 'The legal name of the insurance company providing coverage for this asset.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insurerPhone rdf:type rdf:Property ;
    rdfs:label 'Insurer Phone' ;
    rdfs:comment 'Primary phone number for the insurance carrier contact. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:AssetInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAppraisalDate rdf:type rdf:Property ;
    rdfs:label 'Last Appraisal Date' ;
    rdfs:comment 'The date when the asset was last appraised to determine insured value. Used to track valuation currency and trigger reappraisal workflows.' ;
    rdfs:domain ind:AssetInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lossPayeeName rdf:type rdf:Property ;
    rdfs:label 'Loss Payee Name' ;
    rdfs:comment 'The name of the entity designated to receive insurance proceeds in the event of a loss. Typically the asset owner or lender with a security interest.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextAppraisalDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Appraisal Due Date' ;
    rdfs:comment 'The date when the next asset appraisal is due. Ensures insured values remain current and aligned with replacement costs.' ;
    rdfs:domain ind:AssetInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:policyNumber rdf:type rdf:Property ;
    rdfs:label 'Policy Number' ;
    rdfs:comment 'The unique policy number assigned by the insurance carrier. Used for claims processing and policy lookup.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyRenewalDate rdf:type rdf:Property ;
    rdfs:label 'Policy Renewal Date' ;
    rdfs:comment 'The date when the insurance policy is scheduled for renewal. Triggers renewal workflows and premium renegotiation processes.' ;
    rdfs:domain ind:AssetInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:premiumAllocationMethod rdf:type rdf:Property ;
    rdfs:label 'Premium Allocation Method' ;
    rdfs:comment 'The method used to allocate premium costs to this specific asset. Direct assigns full premium to one asset; proportional allocates based on insured value; usage-based allocates by utilization; blanket covers multiple assets under one policy.' ;
    rdfs:domain ind:AssetInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:premiumAmount rdf:type rdf:Property ;
    rdfs:label 'Premium Amount' ;
    rdfs:comment 'The total premium amount paid for this insurance coverage. May be annual, semi-annual, or allocated portion for this specific asset.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:premiumFrequency rdf:type rdf:Property ;
    rdfs:label 'Premium Frequency' ;
    rdfs:comment 'The frequency at which insurance premiums are paid. Used for cash flow planning and accounts payable scheduling.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalNoticeSentDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Notice Sent Date' ;
    rdfs:comment 'The date when renewal notice was sent to stakeholders. Used to track renewal workflow progress and ensure timely policy continuation.' ;
    rdfs:domain ind:AssetInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:replacementCostCoverageFlag rdf:type rdf:Property ;
    rdfs:label 'Replacement Cost Coverage Flag' ;
    rdfs:comment 'Indicates whether the policy provides replacement cost coverage (true) or actual cash value coverage (false). Replacement cost pays to replace with new; actual cash value deducts depreciation.' ;
    rdfs:domain ind:AssetInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:riskAssessmentRating rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Rating' ;
    rdfs:comment 'The risk rating assigned to this asset by the insurer or internal risk management. Influences premium rates and coverage terms. High-risk assets include WTE boilers, hazardous waste equipment, and landfill gas systems.' ;
    rdfs:domain ind:AssetInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalClaimsPaid rdf:type rdf:Property ;
    rdfs:label 'Total Claims Paid' ;
    rdfs:comment 'The cumulative amount paid by the insurer for all claims on this asset. Used for loss ratio analysis and risk assessment.' ;
    rdfs:domain ind:AssetInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lifecycleStageId rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Stage Id' ;
    rdfs:comment 'Unique identifier for the asset lifecycle stage reference record. Primary key for the asset lifecycle stage table.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LifecycleStage .

ind:allowedSourceStages rdf:type rdf:Property ;
    rdfs:label 'Allowed Source Stages' ;
    rdfs:comment 'Comma-separated list of lifecycle stage codes from which an asset can transition INTO this stage. Defines valid state machine transitions. Empty for initial stage (Ordered). Used for lifecycle transition validation.' ;
    rdfs:domain ind:LifecycleStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allowedTargetStages rdf:type rdf:Property ;
    rdfs:label 'Allowed Target Stages' ;
    rdfs:comment 'Comma-separated list of lifecycle stage codes to which an asset can transition FROM this stage. Defines valid state machine transitions. Empty for terminal stage (Retired). Used for lifecycle transition validation.' ;
    rdfs:domain ind:LifecycleStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amcsDeploymentStatus rdf:type rdf:Property ;
    rdfs:label 'Amcs Deployment Status' ;
    rdfs:comment 'Corresponding container deployment status in AMCS Platform for container assets (dumpsters, roll-offs, carts). Maps lifecycle stage to AMCS container tracking status. Null for non-container assets.' ;
    rdfs:domain ind:LifecycleStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalRequired rdf:type rdf:Property ;
    rdfs:label 'Approval Required' ;
    rdfs:comment 'Indicates whether management approval is required before an asset can transition into this lifecycle stage. True for Condemned and Retired stages due to financial impact; False for routine operational transitions.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:displayOrder rdf:type rdf:Property ;
    rdfs:label 'Display Order' ;
    rdfs:comment 'Numeric value controlling the display order of lifecycle stages in user interface dropdowns, reports, and dashboards. Lower numbers appear first. Allows custom ordering independent of stage_sequence.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:disposalMethodApplicable rdf:type rdf:Property ;
    rdfs:label 'Disposal Method Applicable' ;
    rdfs:comment 'Indicates the typical disposal method applicable when assets reach this lifecycle stage. Only populated for terminal stages (Condemned, Retired). Used to guide asset disposition process and environmental compliance. [ENUM-REF-CANDIDATE: sale|scrap|donation|landfill|recycle|transfer|not_applicable — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LifecycleStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eamStatusMapping rdf:type rdf:Property ;
    rdfs:label 'Eam Status Mapping' ;
    rdfs:comment 'Corresponding asset status code in Infor EAM system. Enables synchronization of lifecycle stage between Waste Management\'s enterprise data model and Infor EAM operational system. Used for bidirectional integration.' ;
    rdfs:domain ind:LifecycleStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalComplianceRequired rdf:type rdf:Property ;
    rdfs:label 'Environmental Compliance Required' ;
    rdfs:comment 'Indicates whether assets in this lifecycle stage are subject to active environmental compliance monitoring and reporting requirements (EPA, RCRA, air/water permits). True for In-Service stage at regulated facilities; False for non-operational stages.' ;
    rdfs:domain ind:LifecycleStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:glImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Gl Impact Flag' ;
    rdfs:comment 'Indicates whether transitions into or out of this lifecycle stage trigger General Ledger postings in SAP FI. True for capitalization (Received), disposal (Retired), and impairment (Condemned) stages; False for operational transitions.' ;
    rdfs:domain ind:LifecycleStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isActive rdf:type rdf:Property ;
    rdfs:label 'Is Active' ;
    rdfs:comment 'Indicates whether this lifecycle stage definition is currently active and available for assignment to assets. False for deprecated or retired stage definitions. Used for reference data filtering.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isActiveStatus rdf:type rdf:Property ;
    rdfs:label 'Is Active Status' ;
    rdfs:comment 'Indicates whether this lifecycle stage represents an active operational state where the asset is available for use or deployment. True for In-Service and Idle stages; False for all others.' ;
    rdfs:domain ind:LifecycleStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isBillable rdf:type rdf:Property ;
    rdfs:label 'Is Billable' ;
    rdfs:comment 'Indicates whether assets in this lifecycle stage can be billed to customers for service. True for In-Service stage when asset is deployed at customer location; False for all other stages including maintenance, transit, and disposal.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDepreciable rdf:type rdf:Property ;
    rdfs:label 'Is Depreciable' ;
    rdfs:comment 'Indicates whether assets in this lifecycle stage are subject to depreciation calculations. True for capitalized stages (Received, In-Service, Idle, Under-Repair); False for pre-capitalization (Ordered, In-Transit) and post-disposal (Condemned, Retired) stages.' ;
    rdfs:domain ind:LifecycleStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isInsurable rdf:type rdf:Property ;
    rdfs:label 'Is Insurable' ;
    rdfs:comment 'Indicates whether assets in this lifecycle stage require active insurance coverage. True for stages where asset has value and risk exposure (In-Transit, Received, In-Service, Idle, Under-Repair); False for pre-acquisition and post-disposal stages.' ;
    rdfs:domain ind:LifecycleStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTerminalStage rdf:type rdf:Property ;
    rdfs:label 'Is Terminal Stage' ;
    rdfs:comment 'Indicates whether this is a terminal lifecycle stage from which no further transitions are allowed. True only for Retired stage; False for all others. Used for lifecycle completion validation.' ;
    rdfs:domain ind:LifecycleStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maintenanceStrategyApplicable rdf:type rdf:Property ;
    rdfs:label 'Maintenance Strategy Applicable' ;
    rdfs:comment 'Indicates whether preventive maintenance (PM) strategies and work orders should be active for assets in this lifecycle stage. True for In-Service and Idle stages; False for all others. Drives PM scheduling in Infor EAM.' ;
    rdfs:domain ind:LifecycleStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationRequired rdf:type rdf:Property ;
    rdfs:label 'Notification Required' ;
    rdfs:comment 'Indicates whether automated notifications should be sent to stakeholders when an asset transitions into this lifecycle stage. True for exception stages (Under-Repair, Condemned) and terminal stages (Retired); False for routine operational transitions.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresInspection rdf:type rdf:Property ;
    rdfs:label 'Requires Inspection' ;
    rdfs:comment 'Indicates whether assets in this lifecycle stage require periodic safety and compliance inspections. True for In-Service and Idle stages; False for non-operational stages. Drives inspection scheduling in Infor EAM.' ;
    rdfs:domain ind:LifecycleStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresLocationTracking rdf:type rdf:Property ;
    rdfs:label 'Requires Location Tracking' ;
    rdfs:comment 'Indicates whether assets in this lifecycle stage require active GPS or RFID location tracking. True for In-Service, Idle, and In-Transit stages; False for stationary stages (Received, Under-Repair) and disposal stages.' ;
    rdfs:domain ind:LifecycleStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sapSystemStatus rdf:type rdf:Property ;
    rdfs:label 'Sap System Status' ;
    rdfs:comment 'Corresponding system status code in SAP Asset Accounting (FI-AA) module. Maps lifecycle stage to SAP\'s asset master status field. Used for SAP integration and financial reporting alignment.' ;
    rdfs:domain ind:LifecycleStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaDurationDays rdf:type rdf:Property ;
    rdfs:label 'Sla Duration Days' ;
    rdfs:comment 'Target maximum number of days an asset should remain in this lifecycle stage before transitioning to the next stage. Used for lifecycle aging analysis and exception reporting. Null for stages without time constraints (e.g., In-Service).' ;
    rdfs:domain ind:LifecycleStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaWarningThresholdDays rdf:type rdf:Property ;
    rdfs:label 'Sla Warning Threshold Days' ;
    rdfs:comment 'Number of days before SLA breach when warning alerts should be triggered for assets remaining in this stage. Typically 70-80% of sla_duration_days. Used for proactive lifecycle management.' ;
    rdfs:domain ind:LifecycleStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stageCategory rdf:type rdf:Property ;
    rdfs:label 'Stage Category' ;
    rdfs:comment 'High-level grouping of lifecycle stages into major phases: acquisition (ordered, in-transit, received), operational (in-service, idle), maintenance (under-repair), disposal (condemned, retired). Used for lifecycle analytics and reporting.' ;
    rdfs:domain ind:LifecycleStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stageCode rdf:type rdf:Property ;
    rdfs:label 'Stage Code' ;
    rdfs:comment 'Short alphanumeric code representing the lifecycle stage (e.g., ORD, INTRANS, RECV, INSVC, IDLE, REPAIR, COND, RET). Used as a business key for system integration across SAP FI-AA, Infor EAM, and AMCS Platform.' ;
    rdfs:domain ind:LifecycleStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stageDescription rdf:type rdf:Property ;
    rdfs:label 'Stage Description' ;
    rdfs:comment 'Detailed description of the lifecycle stage, including business meaning, typical duration, and operational implications. Provides context for asset managers and system users.' ;
    rdfs:domain ind:LifecycleStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stageName rdf:type rdf:Property ;
    rdfs:label 'Stage Name' ;
    rdfs:comment 'Human-readable name of the lifecycle stage (e.g., Ordered, In-Transit, Received, In-Service, Idle, Under-Repair, Condemned, Retired). Primary display label for user interfaces and reports.' ;
    rdfs:domain ind:LifecycleStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stageOwnerRole rdf:type rdf:Property ;
    rdfs:label 'Stage Owner Role' ;
    rdfs:comment 'Business role or department responsible for managing assets in this lifecycle stage (e.g., Procurement for Ordered, Operations for In-Service, Maintenance for Under-Repair, Finance for Retired). Used for workflow routing and accountability.' ;
    rdfs:domain ind:LifecycleStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stageSequence rdf:type rdf:Property ;
    rdfs:label 'Stage Sequence' ;
    rdfs:comment 'Numeric ordering of lifecycle stages representing typical progression through asset lifecycle. Lower numbers indicate earlier stages. Used for lifecycle progression reporting and validation.' ;
    rdfs:domain ind:LifecycleStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:updatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Updated Timestamp' ;
    rdfs:comment 'Timestamp when this lifecycle stage reference record was last modified. Used for audit trail, change tracking, and data synchronization.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:utilizationTrackingEnabled rdf:type rdf:Property ;
    rdfs:label 'Utilization Tracking Enabled' ;
    rdfs:comment 'Indicates whether asset utilization metrics (hours operated, cycles completed, tonnage processed) should be tracked for assets in this lifecycle stage. True for In-Service stage; False for all others. Drives utilization reporting and ROI analysis.' ;
    rdfs:domain ind:LifecycleStage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:locationId rdf:type rdf:Property ;
    rdfs:label 'Location Id' ;
    rdfs:comment 'Unique identifier for the asset location record. Primary key.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:customerAccountId rdf:type rdf:Property ;
    rdfs:label 'Customer Account Id' ;
    rdfs:comment 'Identifier of the customer account associated with this asset location. Applicable when the asset is placed at a customer site for service delivery.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerAccount .

ind:districtId rdf:type rdf:Property ;
    rdfs:label 'District Id' ;
    rdfs:comment 'Identifier of the operational district or service area where the asset is located. Used for regional management and reporting.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:District .

ind:placementDriverId rdf:type rdf:Property ;
    rdfs:label 'Placement Driver Id' ;
    rdfs:comment 'Identifier of the driver who placed or delivered the asset to this location. Links to driver master for accountability and audit trail.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Driver .

ind:placementVehicleId rdf:type rdf:Property ;
    rdfs:label 'Placement Vehicle Id' ;
    rdfs:comment 'Identifier of the vehicle used to transport and place the asset at this location. Links to fleet vehicle master.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vehicle .

ind:placementWorkOrderId rdf:type rdf:Property ;
    rdfs:label 'Placement Work Order Id' ;
    rdfs:comment 'Identifier of the work order that authorized or executed the asset placement at this location. Links to field service work order system.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkOrder .

ind:routeId rdf:type rdf:Property ;
    rdfs:label 'Route Id' ;
    rdfs:comment 'Identifier of the collection route that services this asset location. Links to route master for operational planning and optimization.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Route .

ind:serviceAddressId rdf:type rdf:Property ;
    rdfs:label 'Service Address Id' ;
    rdfs:comment 'Identifier of the customer service address where the asset is located. Applicable for containers placed at customer sites. Links to customer service address master.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceAddress .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line 1' ;
    rdfs:comment 'Primary street address line of the asset location. Includes street number and street name.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line 2' ;
    rdfs:comment 'Secondary address line for additional location details such as suite, unit, or building number.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentReason rdf:type rdf:Property ;
    rdfs:label 'Assignment Reason' ;
    rdfs:comment 'Business reason for assigning the asset to this location. Supports root cause analysis for location changes and utilization patterns. [ENUM-REF-CANDIDATE: new_service|service_change|replacement|maintenance|temporary_placement|customer_request|route_optimization|lost_recovery|seasonal — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bayOrPadNumber rdf:type rdf:Property ;
    rdfs:label 'Bay Or Pad Number' ;
    rdfs:comment 'Specific bay, pad, or designated area within a building or facility where the asset is positioned. Used for precise location tracking of stationary equipment like compactors, balers, and scales.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buildingCode rdf:type rdf:Property ;
    rdfs:label 'Building Code' ;
    rdfs:comment 'Code identifying the specific building or structure within a facility where the asset is located. Used for maintenance shops, administrative buildings, and multi-building facilities.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cid rdf:type rdf:Property ;
    rdfs:label 'Cid' ;
    rdfs:comment 'Container Identification number - unique alphanumeric identifier assigned to containers (dumpsters, roll-offs, carts) for tracking and service management. Industry-standard identifier used across AMCS and Waste Logics platforms.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:city rdf:type rdf:Property ;
    rdfs:label 'City' ;
    rdfs:comment 'City or municipality where the asset is located.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryCode rdf:type rdf:Property ;
    rdfs:label 'Country Code' ;
    rdfs:comment 'Three-letter ISO country code where the asset is located. Primary operations in USA and CAN.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geofenceZoneCode rdf:type rdf:Property ;
    rdfs:label 'Geofence Zone Code' ;
    rdfs:comment 'Identifier of the geofence zone that encompasses this asset location. Used for automated location alerts and compliance monitoring.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gpsAccuracyMeters rdf:type rdf:Property ;
    rdfs:label 'Gps Accuracy Meters' ;
    rdfs:comment 'Accuracy of the GPS coordinates in meters. Indicates the precision of the location data captured from telemetry systems.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isBillableLocation rdf:type rdf:Property ;
    rdfs:label 'Is Billable Location' ;
    rdfs:comment 'Flag indicating whether the asset placement at this location is billable to a customer. True for customer sites with active service; false for internal facility locations.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimaryLocation rdf:type rdf:Property ;
    rdfs:label 'Is Primary Location' ;
    rdfs:comment 'Flag indicating whether this is the primary or home location for the asset. True for the main assigned location; false for temporary or secondary locations.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Modified Timestamp' ;
    rdfs:comment 'Date and time when this asset location record was last updated. Audit trail for record changes.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastServiceDate rdf:type rdf:Property ;
    rdfs:label 'Last Service Date' ;
    rdfs:comment 'Date when the asset at this location was last serviced (e.g., container emptied, equipment maintained). Used for service frequency analysis.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastVerifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Verified Timestamp' ;
    rdfs:comment 'Date and time when the asset location was last verified or confirmed. Updated by RFID scans, GPS pings, or manual audits.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:locationStatus rdf:type rdf:Property ;
    rdfs:label 'Location Status' ;
    rdfs:comment 'Current status of the asset at this location. Indicates whether the asset is actively in service, temporarily placed, awaiting pickup, or lost/missing.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationType rdf:type rdf:Property ;
    rdfs:label 'Location Type' ;
    rdfs:comment 'Classification of the location where the asset is currently positioned. Distinguishes between customer sites, internal facilities, and transit states. [ENUM-REF-CANDIDATE: customer_site|facility|yard|transfer_station|landfill|mrf|wte_plant|maintenance_shop|in_transit|storage — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextScheduledServiceDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Service Date' ;
    rdfs:comment 'Date when the asset at this location is next scheduled for service. Supports route planning and customer service level agreement (SLA) compliance.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:placementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Placement Timestamp' ;
    rdfs:comment 'Precise date and time when the asset was placed at this location. Captured from driver mobile app, RFID scan, or GPS telemetry.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:postalCode rdf:type rdf:Property ;
    rdfs:label 'Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the asset location. US format supports 5-digit or 9-digit ZIP codes.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfidTag rdf:type rdf:Property ;
    rdfs:label 'Rfid Tag' ;
    rdfs:comment 'RFID tag identifier attached to the asset for automated tracking and scanning during collection operations. Hexadecimal format.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystem rdf:type rdf:Property ;
    rdfs:label 'Source System' ;
    rdfs:comment 'System or method that captured or recorded this asset location. Indicates data lineage and reliability of location information. [ENUM-REF-CANDIDATE: amcs|geotab|waste_logics|infor_eam|manual_entry|rfid_scan|gps_telemetry — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateProvince rdf:type rdf:Property ;
    rdfs:label 'State Province' ;
    rdfs:comment 'Two-letter state or province code where the asset is located. US state codes follow USPS standard.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utilizationStatus rdf:type rdf:Property ;
    rdfs:label 'Utilization Status' ;
    rdfs:comment 'Current utilization state of the asset at this location. Indicates whether the asset is actively being used, idle, or available for redeployment.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retirementId rdf:type rdf:Property ;
    rdfs:label 'Retirement Id' ;
    rdfs:comment 'Unique identifier for the asset retirement record. Primary key for the asset retirement transaction.' ;
    rdfs:domain ind:Retirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:retirementApprovingAuthorityEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Retirement Approving Authority Employee Id' ;
    rdfs:comment 'The employee identifier of the approving authority in Workday HCM. Provides audit trail and segregation of duties verification.' ;
    rdfs:domain ind:Retirement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:retirementFixedAssetId rdf:type rdf:Property ;
    rdfs:label 'Retirement Fixed Asset Id' ;
    rdfs:comment 'Reference to the fixed asset being retired from the asset register. Links to the master asset record in the asset management system.' ;
    rdfs:domain ind:Retirement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FixedAsset .

ind:retirementInitiatedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Retirement Initiated By Employee Id' ;
    rdfs:comment 'The employee identifier of the person who initiated the retirement request in Infor EAM or SAP PM. Used for accountability and process tracking.' ;
    rdfs:domain ind:Retirement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:retirementProcessedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Retirement Processed By Employee Id' ;
    rdfs:comment 'The employee identifier of the finance or asset management specialist who processed the retirement transaction in SAP FI-AA. Used for audit trail and quality control.' ;
    rdfs:domain ind:Retirement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:retirementReplacementAssetFixedAssetId rdf:type rdf:Property ;
    rdfs:label 'Retirement Replacement Asset Fixed Asset Id' ;
    rdfs:comment 'Reference to the new asset that replaced the retired asset, if applicable. Used for asset lifecycle planning, capacity management, and capital expenditure tracking.' ;
    rdfs:domain ind:Retirement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FixedAsset .

ind:rfidTagId rdf:type rdf:Property ;
    rdfs:label 'Rfid Tag Id' ;
    rdfs:comment 'The RFID tag identifier assigned to the retired asset for automated tracking and inventory management. Tag should be deactivated or recovered upon retirement.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RfidTag .

ind:accumulatedDepreciation rdf:type rdf:Property ;
    rdfs:label 'Accumulated Depreciation' ;
    rdfs:comment 'The total depreciation expense recognized on the asset from acquisition date through retirement date. Used to calculate net book value at retirement.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvingAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Approving Authority Name' ;
    rdfs:comment 'The name of the manager or executive who authorized the asset retirement. Required for governance and internal control compliance.' ;
    rdfs:domain ind:Retirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetSubcategory rdf:type rdf:Property ;
    rdfs:label 'Asset Subcategory' ;
    rdfs:comment 'Detailed classification within the asset category (e.g., Front End Loader (FEL) container, stationary compactor, Materials Recovery Facility (MRF), Automated Side Loader (ASL) truck). Provides granular asset type for reporting and analysis.' ;
    rdfs:domain ind:Retirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buyerContactInformation rdf:type rdf:Property ;
    rdfs:label 'Buyer Contact Information' ;
    rdfs:comment 'Contact details (phone, email, address) for the buyer of the retired asset. Used for transaction documentation and warranty transfer. Business-confidential organizational contact data.' ;
    rdfs:domain ind:Retirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buyerName rdf:type rdf:Property ;
    rdfs:label 'Buyer Name' ;
    rdfs:comment 'The name of the individual or organization that purchased the retired asset. Applicable when retirement reason is SALE. Used for Bill of Lading (BOL) and transfer documentation.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterCode rdf:type rdf:Property ;
    rdfs:label 'Cost Center Code' ;
    rdfs:comment 'The cost center responsible for the retired asset. Used for management accounting, budget tracking, and departmental performance analysis.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalCostAmount rdf:type rdf:Property ;
    rdfs:label 'Disposal Cost Amount' ;
    rdfs:comment 'The cost incurred to dispose of the retired asset, including transportation, environmental remediation, hazardous waste handling fees, and TSDF tipping fees. Reduces net proceeds in gain/loss calculation.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disposalMethod rdf:type rdf:Property ;
    rdfs:label 'Disposal Method' ;
    rdfs:comment 'The method used to dispose of the retired asset: AUCTION (public/private auction), TRADE_IN (traded for new equipment), DONATION (donated to charity/municipality), LANDFILL (disposed in company landfill), RECYCLING (sent to MRF for material recovery), HAZMAT_DISPOSAL (sent to TSDF for hazardous waste disposal), SALVAGE (sold for parts/scrap value). [ENUM-REF-CANDIDATE: AUCTION|TRADE_IN|DONATION|LANDFILL|RECYCLING|HAZMAT_DISPOSAL|SALVAGE — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentNumber rdf:type rdf:Property ;
    rdfs:label 'Document Number' ;
    rdfs:comment 'The official document number generated in SAP FI-AA (Fixed Asset Accounting) module for the asset retirement transaction. Used for audit trail and financial reconciliation.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalDisposalCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Environmental Disposal Certification Number' ;
    rdfs:comment 'The certification or manifest number issued by the EPA, state environmental agency, or TSDF confirming compliant disposal of assets containing hazardous materials (e.g., compactors with hydraulic fluid, equipment with refrigerants). Required for RCRA and CERCLA compliance.' ;
    rdfs:domain ind:Retirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gainLossAmount rdf:type rdf:Property ;
    rdfs:label 'Gain Loss Amount' ;
    rdfs:comment 'The financial gain (positive) or loss (negative) recognized on asset retirement, calculated as (sale proceeds - disposal costs - net book value). Posted to the General Ledger (GL) for financial reporting.' ;
    rdfs:domain ind:Retirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:glAccountCode rdf:type rdf:Property ;
    rdfs:label 'Gl Account Code' ;
    rdfs:comment 'The General Ledger account code in SAP FI where the gain or loss on disposal is posted. Ensures proper financial statement classification and audit trail.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardousMaterialIndicator rdf:type rdf:Property ;
    rdfs:label 'Hazardous Material Indicator' ;
    rdfs:comment 'Boolean flag indicating whether the retired asset contained or was contaminated with hazardous materials requiring special disposal procedures under RCRA or OSHA regulations. True if hazardous, False otherwise.' ;
    rdfs:domain ind:Retirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazardousMaterialType rdf:type rdf:Property ;
    rdfs:label 'Hazardous Material Type' ;
    rdfs:comment 'Description of the type of hazardous material contained in the retired asset (e.g., hydraulic fluid, refrigerant, lead-acid battery, PCB-containing transformer). Required for EPA manifest and TSDF acceptance.' ;
    rdfs:domain ind:Retirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceClaimNumber rdf:type rdf:Property ;
    rdfs:label 'Insurance Claim Number' ;
    rdfs:comment 'The insurance claim number if the asset retirement was due to theft, damage, or casualty loss covered by insurance. Links to insurance recovery and subrogation processes.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceRecoveryAmount rdf:type rdf:Property ;
    rdfs:label 'Insurance Recovery Amount' ;
    rdfs:comment 'The amount recovered from insurance for the retired asset. Offsets the loss on disposal in financial reporting and may affect gain/loss calculation.' ;
    rdfs:domain ind:Retirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netBookValue rdf:type rdf:Property ;
    rdfs:label 'Net Book Value' ;
    rdfs:comment 'The carrying value of the asset at retirement date, calculated as original acquisition cost minus accumulated depreciation. Represents the undepreciated balance being removed from the books.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalAcquisitionCost rdf:type rdf:Property ;
    rdfs:label 'Original Acquisition Cost' ;
    rdfs:comment 'The original purchase price or capitalized cost of the asset when it was first acquired and placed in service. Used to calculate gain or loss on disposal.' ;
    rdfs:domain ind:Retirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:physicalLocationAtRetirement rdf:type rdf:Property ;
    rdfs:label 'Physical Location At Retirement' ;
    rdfs:comment 'The physical site, facility, or yard where the asset was located at the time of retirement. Used for asset tracking, inventory reconciliation, and logistics planning.' ;
    rdfs:domain ind:Retirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonCode rdf:type rdf:Property ;
    rdfs:label 'Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for asset retirement: SALE (sold to third party), SCRAP (scrapped/disposed), THEFT (stolen/lost), DAMAGE (irreparable damage), EOL (end of useful life), OBSOLETE (technologically obsolete).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonDescription rdf:type rdf:Property ;
    rdfs:label 'Reason Description' ;
    rdfs:comment 'Detailed narrative explanation of the circumstances and business justification for retiring the asset. Provides context beyond the standardized reason code.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retirementDate rdf:type rdf:Property ;
    rdfs:label 'Retirement Date' ;
    rdfs:comment 'The effective date when the asset was officially retired from service and removed from the active asset register. Used for depreciation calculation cutoff and financial reporting.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:retirementStatus rdf:type rdf:Property ;
    rdfs:label 'Retirement Status' ;
    rdfs:comment 'Current workflow status of the retirement transaction: PENDING (awaiting approval), APPROVED (authorized but not yet processed), COMPLETED (fully processed and posted to GL), CANCELLED (retirement request withdrawn).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:saleInvoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Sale Invoice Number' ;
    rdfs:comment 'The invoice number issued to the buyer for the sale of the retired asset. Links to Oracle Revenue Management for Accounts Receivable (AR) tracking and revenue recognition.' ;
    rdfs:domain ind:Retirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:saleProceedsAmount rdf:type rdf:Property ;
    rdfs:label 'Sale Proceeds Amount' ;
    rdfs:comment 'The cash or fair market value received from the sale or disposal of the retired asset. Null if asset was scrapped with no salvage value. Used to calculate gain or loss on disposal.' ;
    rdfs:domain ind:Retirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serialNumber rdf:type rdf:Property ;
    rdfs:label 'Serial Number' ;
    rdfs:comment 'The manufacturer serial number or Container Identification (CID) number of the retired asset. Used for warranty claims, recall tracking, and disposal documentation.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferId rdf:type rdf:Property ;
    rdfs:label 'Transfer Id' ;
    rdfs:comment 'Unique identifier for the asset transfer transaction. Primary key for the asset transfer record.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maintenanceWorkOrderId rdf:type rdf:Property ;
    rdfs:label 'Maintenance Work Order Id' ;
    rdfs:comment 'Reference to the work order created in Infor EAM for post-transfer maintenance or inspection. Links transfer event to maintenance execution.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkOrder .

ind:receivingFacilityId rdf:type rdf:Property ;
    rdfs:label 'Receiving Facility Id' ;
    rdfs:comment 'Reference to the facility, plant, yard, or customer site to which the asset is being transferred. Destination location in the transfer transaction.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:sendingFacilityId rdf:type rdf:Property ;
    rdfs:label 'Sending Facility Id' ;
    rdfs:comment 'Reference to the facility, plant, yard, or customer site from which the asset is being transferred. Source location in the transfer transaction.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:transferApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Transfer Approved By Employee Id' ;
    rdfs:comment 'Reference to the employee who authorized the asset transfer. Typically a regional director, asset manager, or finance controller depending on transfer type and value.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:transferRequestedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Transfer Requested By Employee Id' ;
    rdfs:comment 'Reference to the employee who initiated the asset transfer request. Typically a district manager, operations supervisor, or asset coordinator.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualTransferTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Transfer Timestamp' ;
    rdfs:comment 'Precise date and time when the asset physically arrived at the receiving facility and custody was transferred. Captured from RFID scan, GPS telematics, or manual confirmation.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assetBookValueAtTransfer rdf:type rdf:Property ;
    rdfs:label 'Asset Book Value At Transfer' ;
    rdfs:comment 'Net book value (acquisition cost minus accumulated depreciation) of the asset at the transfer date. Used for intercompany accounting entries and financial reporting.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assetConditionAtTransfer rdf:type rdf:Property ;
    rdfs:label 'Asset Condition At Transfer' ;
    rdfs:comment 'Physical and operational condition assessment of the asset at the time of transfer. Used to determine maintenance requirements at receiving location and validate transfer appropriateness.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierName rdf:type rdf:Property ;
    rdfs:label 'Carrier Name' ;
    rdfs:comment 'Name of the transportation company or internal fleet unit responsible for moving the asset. Applicable when shipping method involves a carrier.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerCid rdf:type rdf:Property ;
    rdfs:label 'Container Cid' ;
    rdfs:comment 'Container Identification number for waste containers (dumpsters, roll-offs, carts). Applicable when the transferred asset is a container. Links to RFID tracking systems.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Amount' ;
    rdfs:comment 'Total cost incurred to execute the asset transfer, including transportation, labor, inspection, and administrative expenses. Allocated to receiving cost center.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Cost Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the transfer cost amount. Typically USD for Waste Management domestic operations.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gpsLatitudeAtTransfer rdf:type rdf:Property ;
    rdfs:label 'Gps Latitude At Transfer' ;
    rdfs:comment 'GPS latitude coordinate where the asset transfer was physically executed. Captured from Geotab telematics or AMCS platform for location verification.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gpsLongitudeAtTransfer rdf:type rdf:Property ;
    rdfs:label 'Gps Longitude At Transfer' ;
    rdfs:comment 'GPS longitude coordinate where the asset transfer was physically executed. Captured from Geotab telematics or AMCS platform for location verification.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:intercompanyAccountingDocument rdf:type rdf:Property ;
    rdfs:label 'Intercompany Accounting Document' ;
    rdfs:comment 'SAP FI-AA document number for the intercompany accounting entry generated by the asset transfer. Used for financial reconciliation and audit trail.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingCompanyCode rdf:type rdf:Property ;
    rdfs:label 'Receiving Company Code' ;
    rdfs:comment 'SAP company code of the legal entity assuming asset ownership. Required for intercompany transfers to generate proper accounting entries.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingCostCenter rdf:type rdf:Property ;
    rdfs:label 'Receiving Cost Center' ;
    rdfs:comment 'SAP FI-CO cost center code of the receiving organizational unit. Used for intercompany accounting entries and depreciation allocation after transfer.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresMaintenanceFlag rdf:type rdf:Property ;
    rdfs:label 'Requires Maintenance Flag' ;
    rdfs:comment 'Indicator whether the asset requires preventive maintenance (PM) or repair work order (WO) upon arrival at receiving facility. Triggers work order creation in Infor EAM.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduledTransferDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Transfer Date' ;
    rdfs:comment 'Planned date for the physical movement and custody change of the asset. May differ from actual transfer date due to logistics or operational constraints.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sendingCompanyCode rdf:type rdf:Property ;
    rdfs:label 'Sending Company Code' ;
    rdfs:comment 'SAP company code of the legal entity relinquishing asset ownership. Required for intercompany transfers to generate proper accounting entries.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sendingCostCenter rdf:type rdf:Property ;
    rdfs:label 'Sending Cost Center' ;
    rdfs:comment 'SAP FI-CO cost center code of the sending organizational unit. Used for intercompany accounting entries and depreciation allocation prior to transfer.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingMethod rdf:type rdf:Property ;
    rdfs:label 'Shipping Method' ;
    rdfs:comment 'Mode of transportation used to physically move the asset from sending to receiving location. Impacts transit time and cost allocation.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemRecordReference rdf:type rdf:Property ;
    rdfs:label 'Source System Record Reference' ;
    rdfs:comment 'Primary key or unique identifier of this asset transfer record in the source operational system. Enables traceability and reconciliation back to source.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trackingNumber rdf:type rdf:Property ;
    rdfs:label 'Tracking Number' ;
    rdfs:comment 'Shipment tracking identifier provided by carrier or logistics system. Enables real-time visibility of asset location during transit.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferDate rdf:type rdf:Property ;
    rdfs:label 'Transfer Date' ;
    rdfs:comment 'The business date when the asset transfer was executed and ownership/custody changed from sending to receiving facility. Used for financial period assignment and depreciation calculation cutoff in SAP FI-AA.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transferStatus rdf:type rdf:Property ;
    rdfs:label 'Transfer Status' ;
    rdfs:comment 'Current lifecycle status of the asset transfer transaction. Tracks workflow progression from initiation through completion or cancellation. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|in_transit|completed|cancelled|rejected — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferType rdf:type rdf:Property ;
    rdfs:label 'Transfer Type' ;
    rdfs:comment 'Classification of the transfer transaction based on organizational scope and business purpose. Determines accounting treatment and approval workflow. [ENUM-REF-CANDIDATE: intercompany|interplant|interlocation|redeployment|consolidation|disposal_routing|customer_site_swap — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valueCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Value Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the asset book value at transfer. Typically USD for Waste Management domestic operations.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utilizationId rdf:type rdf:Property ;
    rdfs:label 'Utilization Id' ;
    rdfs:comment 'Unique identifier for the asset utilization measurement record.' ;
    rdfs:domain ind:Utilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:businessUnitId rdf:type rdf:Property ;
    rdfs:label 'Business Unit Id' ;
    rdfs:comment 'Reference to the business unit that owns or operates the asset. Used for organizational reporting and asset portfolio analysis across divisions.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:actualThroughputUnit rdf:type rdf:Property ;
    rdfs:label 'Actual Throughput Unit' ;
    rdfs:comment 'The unit of measure for the actual throughput value. Must be compatible with the rated capacity unit for utilization rate calculation.' ;
    rdfs:domain ind:Utilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualThroughputValue rdf:type rdf:Property ;
    rdfs:label 'Actual Throughput Value' ;
    rdfs:comment 'The actual measured throughput or usage during the measurement period. For containers, this is average fill level. For compactors and balers, this is actual tons processed. For scales, this is actual weighing transactions completed.' ;
    rdfs:domain ind:Utilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageFillLevelPercent rdf:type rdf:Property ;
    rdfs:label 'Average Fill Level Percent' ;
    rdfs:comment 'Average fill level percentage for containers during the measurement period. Calculated from RFID sensor readings or visual inspection data. Used to optimize service frequency and identify oversized or undersized containers.' ;
    rdfs:domain ind:Utilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cyclesCompleted rdf:type rdf:Property ;
    rdfs:label 'Cycles Completed' ;
    rdfs:comment 'Total number of operational cycles completed during the measurement period. Applicable to compactors (compaction cycles) and balers (baling cycles). Captured from equipment control systems or manual logs.' ;
    rdfs:domain ind:Utilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataSource rdf:type rdf:Property ;
    rdfs:label 'Data Source' ;
    rdfs:comment 'The system or method used to capture the utilization measurement. Identifies whether data came from automated sensors (RFID, GPS), manual entry, or integrated systems (AMCS, Infor EAM, SAP PM). Critical for data quality assessment. [ENUM-REF-CANDIDATE: rfid_sensor|gps_telematics|manual_entry|amcs_platform|infor_eam|sap_pm|scale_system|equipment_controller — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:idleDays rdf:type rdf:Property ;
    rdfs:label 'Idle Days' ;
    rdfs:comment 'Number of calendar days the asset was idle (not used or serviced) during the measurement period. Critical metric for container rationalization and redeployment decisions.' ;
    rdfs:domain ind:Utilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:idleHours rdf:type rdf:Property ;
    rdfs:label 'Idle Hours' ;
    rdfs:comment 'Total idle hours (non-operating time) during the measurement period. For containers, this represents days without service. For equipment, this is available hours minus operating hours. Used to identify underutilized assets for redeployment.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementMethod rdf:type rdf:Property ;
    rdfs:label 'Measurement Method' ;
    rdfs:comment 'The method used to obtain the utilization measurement. Automated sensor indicates RFID or IoT device readings, manual inspection indicates visual assessment, system calculated indicates derived metrics from operational systems.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Measurement Period End Date' ;
    rdfs:comment 'The end date of the utilization measurement period. Defines the conclusion of the observation window for calculating utilization metrics.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measurementPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Measurement Period Start Date' ;
    rdfs:comment 'The start date of the utilization measurement period. Defines the beginning of the observation window for calculating utilization metrics.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measurementQualityScore rdf:type rdf:Property ;
    rdfs:label 'Measurement Quality Score' ;
    rdfs:comment 'Data quality score for the utilization measurement, ranging from 0.00 to 1.00. Higher scores indicate more reliable data. Factors include data source reliability, completeness, and timeliness. Used to weight measurements in analytics.' ;
    rdfs:domain ind:Utilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Measurement Timestamp' ;
    rdfs:comment 'The precise date and time when the utilization measurement was captured or recorded. For sensor-based measurements, this is the sensor reading timestamp. For manual entries, this is the data entry timestamp.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:operatingHours rdf:type rdf:Property ;
    rdfs:label 'Operating Hours' ;
    rdfs:comment 'Total operating hours recorded for the asset during the measurement period. Applicable to compactors, balers, and other powered equipment. Captured from equipment hour meters or telematics systems.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:peakFillLevelPercent rdf:type rdf:Property ;
    rdfs:label 'Peak Fill Level Percent' ;
    rdfs:comment 'Maximum fill level percentage recorded during the measurement period. Indicates whether the container size is adequate for the customer\'s waste generation rate.' ;
    rdfs:domain ind:Utilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ratePercent rdf:type rdf:Property ;
    rdfs:label 'Rate Percent' ;
    rdfs:comment 'The calculated utilization rate expressed as a percentage of rated capacity. For containers, this is average fill level percentage. For equipment, this is operating hours divided by available hours. Used for asset rationalization and redeployment decisions.' ;
    rdfs:domain ind:Utilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ratedCapacityUnit rdf:type rdf:Property ;
    rdfs:label 'Rated Capacity Unit' ;
    rdfs:comment 'The unit of measure for the rated capacity value. Varies by asset type: cubic yards for containers, tons per day for processing equipment, transactions per day for scales, operating hours for machinery.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratedCapacityValue rdf:type rdf:Property ;
    rdfs:label 'Rated Capacity Value' ;
    rdfs:comment 'The maximum rated capacity of the asset during the measurement period. For containers, this is volume in cubic yards. For compactors and balers, this is throughput in tons per day (TPD). For scales, this is maximum weighing transactions per day.' ;
    rdfs:domain ind:Utilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:redeploymentCandidateFlag rdf:type rdf:Property ;
    rdfs:label 'Redeployment Candidate Flag' ;
    rdfs:comment 'Indicates whether the asset is a candidate for redeployment based on utilization metrics. True if asset is underutilized at current location and could be more effectively deployed elsewhere.' ;
    rdfs:domain ind:Utilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:roiImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Roi Impact Flag' ;
    rdfs:comment 'Indicates whether this utilization measurement has significant impact on asset ROI analysis. True if utilization is outside acceptable thresholds and requires management attention for redeployment or disposal decisions.' ;
    rdfs:domain ind:Utilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceFrequencyCount rdf:type rdf:Property ;
    rdfs:label 'Service Frequency Count' ;
    rdfs:comment 'Number of times the asset was serviced during the measurement period. For containers, this is the number of pickups. For equipment, this is the number of maintenance or operational service events.' ;
    rdfs:domain ind:Utilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalWeightProcessedTons rdf:type rdf:Property ;
    rdfs:label 'Total Weight Processed Tons' ;
    rdfs:comment 'Total weight in tons processed through the asset during the measurement period. Applicable to compactors, balers, scales, and processing equipment. Sourced from weight tickets and equipment logs.' ;
    rdfs:domain ind:Utilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weighingTransactionsCount rdf:type rdf:Property ;
    rdfs:label 'Weighing Transactions Count' ;
    rdfs:comment 'Total number of weighing transactions processed by a scale during the measurement period. Key utilization metric for landfill scales, transfer station scales, and MRF scales.' ;
    rdfs:domain ind:Utilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:valuationId rdf:type rdf:Property ;
    rdfs:label 'Valuation Id' ;
    rdfs:comment 'Unique identifier for the asset valuation record. Primary key.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:appraisedValue rdf:type rdf:Property ;
    rdfs:label 'Appraised Value' ;
    rdfs:comment 'The monetary value assigned to the asset by the appraiser or valuation methodology at the valuation date, expressed in the reporting currency.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:appraiserCertification rdf:type rdf:Property ;
    rdfs:label 'Appraiser Certification' ;
    rdfs:comment 'Professional certification or credential of the appraiser (e.g., ASA, MAI, CPA, internal certification reference).' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appraiserFirm rdf:type rdf:Property ;
    rdfs:label 'Appraiser Firm' ;
    rdfs:comment 'Name of the external appraisal firm or internal department that conducted the valuation.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedBy rdf:type rdf:Property ;
    rdfs:label 'Approved By' ;
    rdfs:comment 'Name or identifier of the individual who approved the valuation (e.g., CFO, Controller, Asset Manager).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depreciationMethodUsed rdf:type rdf:Property ;
    rdfs:label 'Depreciation Method Used' ;
    rdfs:comment 'The depreciation method applied in the valuation calculation: straight line, declining balance, units of production, sum of years digits, or none (for land or non-depreciable assets).' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:economicObsolescenceFlag rdf:type rdf:Property ;
    rdfs:label 'Economic Obsolescence Flag' ;
    rdfs:comment 'Boolean flag indicating whether the asset exhibits economic obsolescence (loss of value due to external market or regulatory factors beyond the assets control).' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:functionalObsolescenceFlag rdf:type rdf:Property ;
    rdfs:label 'Functional Obsolescence Flag' ;
    rdfs:comment 'Boolean flag indicating whether the asset exhibits functional obsolescence (outdated design, inefficiency, or inability to meet current operational requirements).' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:impairmentIndicatorFlag rdf:type rdf:Property ;
    rdfs:label 'Impairment Indicator Flag' ;
    rdfs:comment 'Boolean flag indicating whether this valuation identified an impairment condition (appraised value below carrying amount) requiring a write-down per GAAP ASC 360.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:impairmentLossAmount rdf:type rdf:Property ;
    rdfs:label 'Impairment Loss Amount' ;
    rdfs:comment 'The calculated impairment loss amount if an impairment was identified (carrying amount minus fair value). Null if no impairment.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceCoverageAmount rdf:type rdf:Property ;
    rdfs:label 'Insurance Coverage Amount' ;
    rdfs:comment 'The insurance coverage amount recommended or established based on this valuation, used for property and casualty insurance policy limits.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marketValueAdjustmentPct rdf:type rdf:Property ;
    rdfs:label 'Market Value Adjustment Pct' ;
    rdfs:comment 'Percentage adjustment applied to the base valuation to reflect current market conditions, expressed as a percentage (e.g., 5.00 for 5% increase, -10.00 for 10% decrease).' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:methodology rdf:type rdf:Property ;
    rdfs:label 'Methodology' ;
    rdfs:comment 'The technical approach used to determine the appraised value: cost approach (replacement cost less depreciation), market approach (comparable sales), income approach (discounted cash flow), or other industry-standard methodology.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextValuationDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Valuation Due Date' ;
    rdfs:comment 'The scheduled date for the next valuation of this asset, based on policy requirements (e.g., annual insurance appraisals, quarterly impairment testing).' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:physicalConditionRating rdf:type rdf:Property ;
    rdfs:label 'Physical Condition Rating' ;
    rdfs:comment 'Appraiser assessment of the physical condition of the asset at the valuation date: excellent (like new), good (minor wear), fair (moderate wear), poor (significant deterioration), critical (near end of life).' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purpose rdf:type rdf:Property ;
    rdfs:label 'Purpose' ;
    rdfs:comment 'Free-text description of the business purpose for this valuation (e.g., annual insurance renewal, quarterly impairment testing, pre-disposal assessment, merger and acquisition due diligence).' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replacementCostNew rdf:type rdf:Property ;
    rdfs:label 'Replacement Cost New' ;
    rdfs:comment 'The estimated cost to replace the asset with a new equivalent asset at current market prices, used for insurance and capital planning.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportReference rdf:type rdf:Property ;
    rdfs:label 'Report Reference' ;
    rdfs:comment 'Document reference number or file path to the detailed valuation report supporting this valuation record.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usefulLifeRemainingYears rdf:type rdf:Property ;
    rdfs:label 'Useful Life Remaining Years' ;
    rdfs:comment 'The estimated remaining useful life of the asset in years at the valuation date, as assessed by the appraiser.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valuationDate rdf:type rdf:Property ;
    rdfs:label 'Valuation Date' ;
    rdfs:comment 'The date on which the asset valuation was performed or effective.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:valuationNumber rdf:type rdf:Property ;
    rdfs:label 'Valuation Number' ;
    rdfs:comment 'Business identifier for the valuation event, often assigned by appraiser or internal valuation team.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationStatus rdf:type rdf:Property ;
    rdfs:label 'Valuation Status' ;
    rdfs:comment 'Current lifecycle status of the valuation record: draft (in progress), pending review (submitted for approval), approved (finalized and accepted), rejected (not accepted), superseded (replaced by a newer valuation).' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationType rdf:type rdf:Property ;
    rdfs:label 'Valuation Type' ;
    rdfs:comment 'The purpose or methodology category of the valuation: insurance appraisal for coverage renewal, fair market value for financial reporting, impairment test per ASC 360, replacement cost for capital planning, liquidation value for disposal scenarios, or book value reconciliation.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyId rdf:type rdf:Property ;
    rdfs:label 'Warranty Id' ;
    rdfs:comment 'Unique identifier for the asset warranty record. Primary key.' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:claimLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Claim Limit Amount' ;
    rdfs:comment 'Maximum total dollar amount that can be claimed under this warranty over its lifetime. Null indicates unlimited coverage. Critical for high-value equipment like MRF sorting systems and WTE boilers.' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:claimLimitCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Claim Limit Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the claim limit amount (e.g., USD, CAD, EUR).' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimsApprovedCount rdf:type rdf:Property ;
    rdfs:label 'Claims Approved Count' ;
    rdfs:comment 'Total number of warranty claims that were approved and paid by the warranty provider. Used to calculate claim approval rate and assess warranty provider responsiveness.' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:claimsFiledCount rdf:type rdf:Property ;
    rdfs:label 'Claims Filed Count' ;
    rdfs:comment 'Total number of warranty claims filed against this warranty to date. Used for warranty utilization tracking and vendor performance assessment.' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contactEmail rdf:type rdf:Property ;
    rdfs:label 'Contact Email' ;
    rdfs:comment 'Primary email address for warranty claim submission and service coordination.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactName rdf:type rdf:Property ;
    rdfs:label 'Contact Name' ;
    rdfs:comment 'Name of the primary contact person at the warranty provider for claim submission and service coordination.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPhone rdf:type rdf:Property ;
    rdfs:label 'Contact Phone' ;
    rdfs:comment 'Primary phone number for warranty claim submission and service requests. Critical for emergency equipment failures at MRF and WTE facilities.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Contract Document Reference' ;
    rdfs:comment 'Reference to the warranty contract document stored in the document management system. May be a file path, document ID, or URL to the warranty certificate and terms.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageDurationMonths rdf:type rdf:Property ;
    rdfs:label 'Coverage Duration Months' ;
    rdfs:comment 'Total duration of warranty coverage expressed in months. Standard manufacturer warranties are typically 12-36 months; extended warranties may range from 12-120 months for high-value equipment.' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deductibleCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Deductible Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the deductible amount (e.g., USD, CAD, EUR).' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusions rdf:type rdf:Property ;
    rdfs:label 'Exclusions' ;
    rdfs:comment 'Specific items, conditions, or circumstances not covered by the warranty. Common exclusions include consumables, normal wear and tear, misuse, unauthorized modifications, and environmental damage from landfill leachate or corrosive waste.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laborCoverageFlag rdf:type rdf:Property ;
    rdfs:label 'Labor Coverage Flag' ;
    rdfs:comment 'Indicates whether the warranty covers labor costs for repairs and service. True means labor is covered; false means labor must be paid separately.' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:partsCoverageFlag rdf:type rdf:Property ;
    rdfs:label 'Parts Coverage Flag' ;
    rdfs:comment 'Indicates whether the warranty covers replacement parts costs. True means parts are covered; false means parts must be purchased separately.' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:providerName rdf:type rdf:Property ;
    rdfs:label 'Provider Name' ;
    rdfs:comment 'Name of the company or organization providing the warranty coverage. May be the original equipment manufacturer (OEM), third-party warranty provider, or service contractor.' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Renewal Eligible Flag' ;
    rdfs:comment 'Indicates whether this warranty is eligible for renewal upon expiration. True means renewal option is available; false means warranty cannot be renewed.' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Notification Date' ;
    rdfs:comment 'Date when Waste Management should be notified about warranty renewal options. Typically 60-90 days before coverage end date to allow procurement lead time.' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:serviceResponseTimeHours rdf:type rdf:Property ;
    rdfs:label 'Service Response Time Hours' ;
    rdfs:comment 'Guaranteed maximum time in hours for warranty provider to respond to a service request. Part of warranty Service Level Agreement (SLA). Critical for high-availability equipment like MRF sorting lines and WTE boilers.' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:termsAndConditions rdf:type rdf:Property ;
    rdfs:label 'Terms And Conditions' ;
    rdfs:comment 'Full text or summary of warranty terms, conditions, exclusions, and limitations. Includes coverage scope, maintenance requirements, claim procedures, and exclusions (e.g., misuse, environmental damage, normal wear).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalClaimsCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Total Claims Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the total claims value (e.g., USD, CAD, EUR).' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalClaimsValue rdf:type rdf:Property ;
    rdfs:label 'Total Claims Value' ;
    rdfs:comment 'Cumulative dollar value of all approved warranty claims paid under this warranty. Used for warranty ROI calculation and vendor performance assessment.' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transferableFlag rdf:type rdf:Property ;
    rdfs:label 'Transferable Flag' ;
    rdfs:comment 'Indicates whether the warranty can be transferred to a new owner if the asset is sold or relocated. True means warranty transfers with the asset; false means warranty is non-transferable.' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:travelCoverageFlag rdf:type rdf:Property ;
    rdfs:label 'Travel Coverage Flag' ;
    rdfs:comment 'Indicates whether the warranty covers technician travel and trip charges for on-site service. Particularly relevant for remote landfill sites, transfer stations, and MRF facilities.' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:warrantyNumber rdf:type rdf:Property ;
    rdfs:label 'Warranty Number' ;
    rdfs:comment 'Unique warranty certificate or policy number issued by the warranty provider. Used for warranty claim reference and tracking.' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyStatus rdf:type rdf:Property ;
    rdfs:label 'Warranty Status' ;
    rdfs:comment 'Current lifecycle status of the warranty. Active indicates coverage is in effect; expired indicates coverage period has ended; cancelled indicates warranty was terminated early; suspended indicates temporary hold; pending activation indicates warranty purchased but not yet effective.' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyType rdf:type rdf:Property ;
    rdfs:label 'Warranty Type' ;
    rdfs:comment 'Classification of warranty coverage. Manufacturer warranty is included with asset purchase; extended warranty is purchased separately; comprehensive covers parts and labor; parts-only covers replacement parts; labor-only covers service labor; service contract is ongoing maintenance agreement.' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomId rdf:type rdf:Property ;
    rdfs:label 'Bom Id' ;
    rdfs:comment 'Unique identifier for the bill of materials record.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bomLevel rdf:type rdf:Property ;
    rdfs:label 'Bom Level' ;
    rdfs:comment 'Hierarchical level of the component within the BOM structure. Level 0 is the parent asset; level 1 is a direct child assembly; level 2 is a sub-assembly of level 1, etc. Supports multi-level BOM explosion.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bomStatus rdf:type rdf:Property ;
    rdfs:label 'Bom Status' ;
    rdfs:comment 'Current lifecycle status of the BOM line item: active (in use), inactive (temporarily disabled), obsolete (superseded by newer component), or pending approval (engineering change pending).' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentDescription rdf:type rdf:Property ;
    rdfs:label 'Component Description' ;
    rdfs:comment 'Detailed textual description of the component part, including specifications, model information, and functional purpose within the parent asset.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentPartNumber rdf:type rdf:Property ;
    rdfs:label 'Component Part Number' ;
    rdfs:comment 'Internal part number or SKU identifying the component part or sub-assembly within the BOM structure. Used for inventory lookup and procurement.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentType rdf:type rdf:Property ;
    rdfs:label 'Component Type' ;
    rdfs:comment 'Classification of the component within the BOM hierarchy: assembly (major sub-system), sub-assembly (grouped parts), part (individual component), consumable (regularly replaced item), fluid (lubricant, hydraulic fluid), or fastener (bolt, nut, washer).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ehsNotes rdf:type rdf:Property ;
    rdfs:label 'Ehs Notes' ;
    rdfs:comment 'Free-text field capturing environmental, health, and safety considerations for the component, including PPE requirements, disposal instructions, and regulatory compliance notes.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatIndicator rdf:type rdf:Property ;
    rdfs:label 'Hazmat Indicator' ;
    rdfs:comment 'Indicates whether the component is classified as hazardous material under RCRA, DOT, or OSHA regulations (e.g., batteries, hydraulic fluids, refrigerants). Requires special handling, storage, and disposal procedures.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interchangeablePartNumbers rdf:type rdf:Property ;
    rdfs:label 'Interchangeable Part Numbers' ;
    rdfs:comment 'Comma-separated list of alternative or equivalent part numbers that can substitute for this component. Supports flexible sourcing and reduces downtime when primary part is unavailable.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCapitalSpare rdf:type rdf:Property ;
    rdfs:label 'Is Capital Spare' ;
    rdfs:comment 'Indicates whether the component is classified as a capital spare (high-value, long-lead-time item stocked for emergency replacement) versus a consumable or routine spare. Capital spares are capitalized on the balance sheet.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isConsumable rdf:type rdf:Property ;
    rdfs:label 'Is Consumable' ;
    rdfs:comment 'Indicates whether the component is a consumable item (regularly replaced during preventive maintenance, such as filters, belts, fluids) versus a durable part. Consumables are expensed immediately.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastModifiedBy rdf:type rdf:Property ;
    rdfs:label 'Last Modified By' ;
    rdfs:comment 'Username or employee identifier of the person who last modified this BOM record. Tracks engineering change ownership.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Lead Time Days' ;
    rdfs:comment 'Average number of days required to procure and receive the component from the supplier. Used for preventive maintenance planning and spare parts inventory optimization.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:manufacturerName rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Name' ;
    rdfs:comment 'Name of the manufacturer or supplier of the component part.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturerPartNumber rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Part Number' ;
    rdfs:comment 'Original equipment manufacturer (OEM) part number for the component. Used for sourcing genuine replacement parts and warranty claims.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meanTimeBetweenFailuresHours rdf:type rdf:Property ;
    rdfs:label 'Mean Time Between Failures Hours' ;
    rdfs:comment 'Average operating hours between failures for this component, based on historical maintenance data. Used for predictive maintenance scheduling and reliability analysis.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentComponentPartNumber rdf:type rdf:Property ;
    rdfs:label 'Parent Component Part Number' ;
    rdfs:comment 'Part number of the immediate parent component in a multi-level BOM. Null for level-1 components that report directly to the parent asset. Enables hierarchical BOM navigation.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionReference rdf:type rdf:Property ;
    rdfs:label 'Position Reference' ;
    rdfs:comment 'Physical location or position identifier of the component within the parent asset (e.g., \'Front Left Wheel\', \'Hydraulic Pump #2\', \'Conveyor Belt Section A\'). Aids field technicians during maintenance.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityRequired rdf:type rdf:Property ;
    rdfs:label 'Quantity Required' ;
    rdfs:comment 'Number of units of this component required to assemble or maintain one unit of the parent asset. Supports fractional quantities for consumables.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recommendedReplacementIntervalHours rdf:type rdf:Property ;
    rdfs:label 'Recommended Replacement Interval Hours' ;
    rdfs:comment 'Manufacturer-recommended or company-standard operating hours between scheduled replacements for this component. Drives preventive maintenance (PM) work order generation.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceSystemCode rdf:type rdf:Property ;
    rdfs:label 'Source System Code' ;
    rdfs:comment 'Unique identifier of this BOM record in the source operational system. Enables traceability and reconciliation with upstream systems.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitCost rdf:type rdf:Property ;
    rdfs:label 'Unit Cost' ;
    rdfs:comment 'Standard cost per unit of the component in US dollars. Used for total cost of ownership analysis, maintenance budgeting, and spare parts valuation.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Unit Of Measure' ;
    rdfs:comment 'Standard unit of measure for the component quantity (e.g., each, gallon, kilogram). Aligns with inventory and procurement systems. [ENUM-REF-CANDIDATE: each|set|pair|gallon|liter|pound|kilogram|meter|foot|box|roll|sheet — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyMonths rdf:type rdf:Property ;
    rdfs:label 'Warranty Months' ;
    rdfs:comment 'Duration of manufacturer warranty coverage for the component in months from date of installation. Used for warranty claim tracking and cost recovery.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:carbonInitiativeId rdf:type rdf:Property ;
    rdfs:label 'Carbon Initiative Id' ;
    rdfs:comment 'Foreign key linking to sustainability.carbon_initiative. Business justification: Capital projects implementing carbon reduction initiatives (LFG-to-RNG systems, solar installations, fleet electrification, energy efficiency upgrades) must link to carbon_initiative to track capital ' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CarbonInitiative .

ind:contractorVendorId rdf:type rdf:Property ;
    rdfs:label 'Contractor Vendor Id' ;
    rdfs:comment 'Vendor master identifier for the primary contractor executing the capital project.' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:projectManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Project Manager Employee Id' ;
    rdfs:comment 'Employee identifier for the project manager assigned to this capital project.' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:strategicInitiativeId rdf:type rdf:Property ;
    rdfs:label 'Strategic Initiative Id' ;
    rdfs:comment 'Reference to the corporate strategic initiative or program that this capital project supports (e.g., sustainability program, fleet modernization, digital transformation).' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StrategicInitiative .

ind:actualCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Date' ;
    rdfs:comment 'Actual date when the project was completed and ready for capitalization or operational handover.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Spend Amount' ;
    rdfs:comment 'Cumulative actual expenditure incurred to date on the capital project, including committed and posted costs.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualStartDate rdf:type rdf:Property ;
    rdfs:label 'Actual Start Date' ;
    rdfs:comment 'Actual date when project execution commenced (first work order issued or first cost posted).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvedBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Approved Budget Amount' ;
    rdfs:comment 'Total capital expenditure budget approved for the project by the investment committee or board. Represents the authorized spending limit.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:committedAmount rdf:type rdf:Property ;
    rdfs:label 'Committed Amount' ;
    rdfs:comment 'Total amount committed via purchase orders and contracts but not yet invoiced or paid.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Number' ;
    rdfs:comment 'Contract or purchase order number governing the terms and conditions of the capital project execution with the contractor.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalPermitRequired rdf:type rdf:Property ;
    rdfs:label 'Environmental Permit Required' ;
    rdfs:comment 'Indicates whether the capital project requires environmental permits from EPA, state, or local authorities (e.g., air quality permit, water discharge permit, solid waste permit).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:permitNumber rdf:type rdf:Property ;
    rdfs:label 'Permit Number' ;
    rdfs:comment 'Official permit number issued by the regulatory authority for environmental or construction permits required for the project.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitStatus rdf:type rdf:Property ;
    rdfs:label 'Permit Status' ;
    rdfs:comment 'Current status of required environmental or construction permits: not required, pending (application submitted), approved (permit issued), denied (application rejected), expired (permit lapsed).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Planned Completion Date' ;
    rdfs:comment 'Target date for project completion as defined in the approved project schedule.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedStartDate rdf:type rdf:Property ;
    rdfs:label 'Planned Start Date' ;
    rdfs:comment 'Scheduled date for project execution to begin, as defined in the project plan.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:projectName rdf:type rdf:Property ;
    rdfs:label 'Project Name' ;
    rdfs:comment 'Descriptive name of the capital project (e.g., \'Landfill Cell 7 Construction\', \'MRF Baler Upgrade\').' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectNotes rdf:type rdf:Property ;
    rdfs:label 'Project Notes' ;
    rdfs:comment 'Free-form notes capturing important project milestones, issues, decisions, or other relevant information for audit and knowledge management.' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectNumber rdf:type rdf:Property ;
    rdfs:label 'Project Number' ;
    rdfs:comment 'Business-facing unique project number or code assigned to the capital project for external reference and tracking.' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectPriority rdf:type rdf:Property ;
    rdfs:label 'Project Priority' ;
    rdfs:comment 'Business priority ranking of the capital project: critical (regulatory/safety), high (strategic), medium (operational improvement), low (discretionary).' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectScopeDescription rdf:type rdf:Property ;
    rdfs:label 'Project Scope Description' ;
    rdfs:comment 'Detailed narrative description of the capital project scope, objectives, deliverables, and expected business outcomes.' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectStatus rdf:type rdf:Property ;
    rdfs:label 'Project Status' ;
    rdfs:comment 'Current lifecycle status of the capital project: planning (pre-approval), approved (budget authorized), in_progress (active execution), on_hold (temporarily suspended), completed (construction finished), cancelled (terminated before completion), closed (financially settled and capitalized). [ENUM-REF-CANDIDATE: planning|approved|in_progress|on_hold|completed|cancelled|closed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectType rdf:type rdf:Property ;
    rdfs:label 'Project Type' ;
    rdfs:comment 'Classification of the capital project by nature of work: new construction (greenfield facility), expansion (capacity increase), rehabilitation (major repair/refurbishment), technology upgrade (system modernization), equipment replacement (asset renewal), or environmental compliance (regulatory-driven improvements).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskLevel rdf:type rdf:Property ;
    rdfs:label 'Risk Level' ;
    rdfs:comment 'Overall risk assessment of the capital project considering technical complexity, regulatory exposure, schedule constraints, and financial impact.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapInternalOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Internal Order Number' ;
    rdfs:comment 'SAP internal order number used for cost collection and tracking for smaller capital projects not requiring full WBS structure.' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapWbsElement rdf:type rdf:Property ;
    rdfs:label 'Sap Wbs Element' ;
    rdfs:comment 'SAP WBS element identifier for complex capital projects structured with hierarchical work breakdown for cost and schedule control.' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleVarianceDays rdf:type rdf:Property ;
    rdfs:label 'Schedule Variance Days' ;
    rdfs:comment 'Schedule variance in days calculated as actual completion date minus planned completion date. Positive values indicate delay, negative values indicate early completion.' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:varianceAmount rdf:type rdf:Property ;
    rdfs:label 'Variance Amount' ;
    rdfs:comment 'Budget variance calculated as actual spend minus approved budget. Positive values indicate over-budget, negative values indicate under-budget.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:variancePercentage rdf:type rdf:Property ;
    rdfs:label 'Variance Percentage' ;
    rdfs:comment 'Budget variance expressed as a percentage of approved budget: (actual spend / approved budget - 1) * 100.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capitalProjectExpenditureId rdf:type rdf:Property ;
    rdfs:label 'Capital Project Expenditure Id' ;
    rdfs:comment 'Unique identifier for the capital project expenditure line item. Primary key.' ;
    rdfs:domain ind:CapitalProjectExpenditure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:budgetLineItemId rdf:type rdf:Property ;
    rdfs:label 'Budget Line Item Id' ;
    rdfs:comment 'Foreign key reference to the capital budget line item against which this expenditure is tracked. Enables budget vs. actual variance analysis and commitment tracking.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BudgetLineItem .

ind:costCenterId rdf:type rdf:Property ;
    rdfs:label 'Cost Center Id' ;
    rdfs:comment 'The internal cost center code that originated this expenditure for internal labor, overhead, or allocated costs. Used when the expenditure is not vendor-sourced but represents internal resource consumption charged to the capital project.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCenter .

ind:assetClass rdf:type rdf:Property ;
    rdfs:label 'Asset Class' ;
    rdfs:comment 'The asset class or category to which the capitalized expenditure will be assigned upon asset creation. Determines depreciation method, useful life, and general ledger account assignment (e.g., Buildings, Machinery, Vehicles, Landfill Infrastructure, MRF Equipment).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetVarianceAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Variance Amount' ;
    rdfs:comment 'The variance between this expenditure and the budgeted amount for the associated budget line item. Positive values indicate over-budget spending; negative values indicate under-budget. Supports project cost control and variance reporting.' ;
    rdfs:domain ind:CapitalProjectExpenditure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capitalizationEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Capitalization Eligible Flag' ;
    rdfs:comment 'Boolean indicator (True/False) denoting whether this expenditure is eligible for capitalization as part of the fixed asset cost basis. True indicates the cost will be capitalized; False indicates it will be expensed. Drives the asset acquisition cost calculation and financial statement treatment.' ;
    rdfs:domain ind:CapitalProjectExpenditure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capitalizationReasonCode rdf:type rdf:Property ;
    rdfs:label 'Capitalization Reason Code' ;
    rdfs:comment 'Code indicating the reason for the capitalization eligibility determination. Values include: direct_material (materials incorporated into the asset), direct_labor (labor directly attributable to asset construction), freight_delivery (transportation costs), installation (installation and commissioning), site_preparation (site work required for asset placement), engineering_design (design and engineering services), permits_fees (regulatory permits and fees), interest_during_construction (financing costs during construction period), overhead_allocation (allocated indirect costs), non_capitalizable_expense (operating expense not eligible for capitalization), maintenance_repair (routine maintenance or repair costs). [ENUM-REF-CANDIDATE: direct_material|direct_labor|freight_delivery|installation|site_preparation|engineering_design|permits_fees|interest_during_construction|overhead_allocation|non_capitalizable_expense|maintenance_repair — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CapitalProjectExpenditure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Commitment Document Number' ;
    rdfs:comment 'The document number representing the financial commitment (purchase requisition, purchase order, or contract) that reserved budget for this expenditure. Supports commitment accounting and funds reservation tracking.' ;
    rdfs:domain ind:CapitalProjectExpenditure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costElement rdf:type rdf:Property ;
    rdfs:label 'Cost Element' ;
    rdfs:comment 'The cost element or general ledger account code to which this expenditure is classified. Represents the nature of the cost (e.g., materials, labor, equipment rental, professional services, freight). Aligns with the chart of accounts and cost accounting structure.' ;
    rdfs:domain ind:CapitalProjectExpenditure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costElementDescription rdf:type rdf:Property ;
    rdfs:label 'Cost Element Description' ;
    rdfs:comment 'Human-readable description of the cost element, providing business context for the type of expenditure (e.g., Construction Materials, Engineering Services, Equipment Purchase, Site Preparation).' ;
    rdfs:domain ind:CapitalProjectExpenditure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentDate rdf:type rdf:Property ;
    rdfs:label 'Document Date' ;
    rdfs:comment 'The date of the originating source document (invoice date, goods receipt date, timesheet date) that triggered this expenditure posting. Used for audit trail and variance analysis between document and posting dates.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expenditureAmount rdf:type rdf:Property ;
    rdfs:label 'Expenditure Amount' ;
    rdfs:comment 'The monetary value of this expenditure line item in the transaction currency. Represents the gross cost posted to the capital project before any adjustments, taxes, or allocations.' ;
    rdfs:domain ind:CapitalProjectExpenditure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expenditureDate rdf:type rdf:Property ;
    rdfs:label 'Expenditure Date' ;
    rdfs:comment 'The date on which this expenditure was posted to the capital project in the financial system. Represents the accounting date for cost recognition, distinct from the document date or goods receipt date.' ;
    rdfs:domain ind:CapitalProjectExpenditure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expenditureNumber rdf:type rdf:Property ;
    rdfs:label 'Expenditure Number' ;
    rdfs:comment 'Business-readable identifier or line number for this expenditure transaction within the project accounting system. May correspond to a journal entry line, goods receipt line, or invoice line.' ;
    rdfs:domain ind:CapitalProjectExpenditure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsReceiptNumber rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Number' ;
    rdfs:comment 'The goods receipt document number that confirmed physical receipt of materials or completion of services. Links expenditure to the three-way match process (PO, GR, Invoice) and inventory movements.' ;
    rdfs:domain ind:CapitalProjectExpenditure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentDate rdf:type rdf:Property ;
    rdfs:label 'Payment Date' ;
    rdfs:comment 'The date on which payment was made to the vendor for this expenditure. Supports cash flow analysis and working capital management for capital projects.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Document Number' ;
    rdfs:comment 'The financial document number for the payment that settled this expenditure. Links to accounts payable payment run and cash management.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingStatus rdf:type rdf:Property ;
    rdfs:label 'Posting Status' ;
    rdfs:comment 'The current posting status of this expenditure in the financial system. Values: posted (successfully posted to GL and project), pending (awaiting approval or posting), reversed (posting has been reversed), cancelled (transaction cancelled before posting), parked (saved as draft, not yet posted).' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseOrderLineItem rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Line Item' ;
    rdfs:comment 'The specific line item number within the purchase order that this expenditure relates to. Provides granular linkage to the ordered material or service specification.' ;
    rdfs:domain ind:CapitalProjectExpenditure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantity rdf:type rdf:Property ;
    rdfs:label 'Quantity' ;
    rdfs:comment 'The quantity of goods or services received for this expenditure line item. Used in conjunction with unit_of_measure for materials management and unit cost analysis.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversedDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reversed Document Number' ;
    rdfs:comment 'The document number of the reversal transaction if this expenditure has been reversed. Provides audit trail linkage between original and reversal postings.' ;
    rdfs:domain ind:CapitalProjectExpenditure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Amount' ;
    rdfs:comment 'The total tax amount (sales tax, VAT, GST) associated with this expenditure. Supports tax accounting, compliance reporting, and determination of capitalizable vs. expensed tax costs.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxCode rdf:type rdf:Property ;
    rdfs:label 'Tax Code' ;
    rdfs:comment 'The tax jurisdiction or tax code applied to this expenditure. Determines tax rate, tax type, and tax account assignment.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workBreakdownStructureElement rdf:type rdf:Property ;
    rdfs:label 'Work Breakdown Structure Element' ;
    rdfs:comment 'The WBS element code within the project hierarchy to which this expenditure is assigned. Provides granular project phase or deliverable-level cost tracking (e.g., Design Phase, Site Preparation, Equipment Installation, Commissioning).' ;
    rdfs:domain ind:CapitalProjectExpenditure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetContainerId rdf:type rdf:Property ;
    rdfs:label 'Asset Container Id' ;
    rdfs:comment 'Unique identifier for the waste container. Primary key. This is the system-generated surrogate key that uniquely identifies each container record in the enterprise data warehouse.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssetContainer .

ind:approvedWasteProfileId rdf:type rdf:Property ;
    rdfs:label 'Approved Waste Profile Id' ;
    rdfs:comment 'Foreign key linking to hazmat.waste_profile. Business justification: Containers must be approved for specific waste profiles based on material compatibility, DOT ratings, and waste characteristics. Links containers to approved waste profiles for safe deployment, regula' ;
    rdfs:domain ind:AssetContainer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WasteProfile .

ind:lastMaintenanceWorkOrderId rdf:type rdf:Property ;
    rdfs:label 'Last Maintenance Work Order Id' ;
    rdfs:comment 'Foreign key linking to maintenance.work_order. Business justification: Container maintenance history tracking requires linking to the actual work order that performed the last maintenance. This supports container lifecycle management, warranty tracking, and regulatory co' ;
    rdfs:domain ind:AssetContainer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkOrder .

ind:serviceVehicleId rdf:type rdf:Property ;
    rdfs:label 'Service Vehicle Id' ;
    rdfs:comment 'Foreign key linking to fleet.vehicle. Business justification: Containers are serviced by specific vehicles on routes. While route_id exists, direct vehicle linkage enables container-to-vehicle assignment validation, RFID read reconciliation for billing disputes,' ;
    rdfs:domain ind:AssetContainer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vehicle .

ind:acquisitionCost rdf:type rdf:Property ;
    rdfs:label 'Acquisition Cost' ;
    rdfs:comment 'The original purchase price or capitalized cost of the container in USD. Used for depreciation calculations, asset valuation, and financial reporting. Confidential business financial data.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amcsContainerReference rdf:type rdf:Property ;
    rdfs:label 'Amcs Container Reference' ;
    rdfs:comment 'The external identifier for this container in the AMCS Platform system. Used for integration and cross-system reconciliation between the enterprise data warehouse and the operational AMCS system.' ;
    rdfs:domain ind:AssetContainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityCubicYards rdf:type rdf:Property ;
    rdfs:label 'Capacity Cubic Yards' ;
    rdfs:comment 'The volumetric capacity of the container measured in cubic yards. Standard sizes include 2, 4, 6, 8 cubic yards for front/rear-load dumpsters; 10, 20, 30, 40 cubic yards for roll-off boxes; and 32, 64, 96 gallons (converted to cubic yards) for residential carts. This is the principal quantitative measurement for the container resource.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:color rdf:type rdf:Property ;
    rdfs:label 'Color' ;
    rdfs:comment 'The exterior color of the container, often used to designate waste stream type (e.g., blue for recycling, green for organics, black for MSW). Color coding helps drivers and customers identify the correct container for each waste stream. [ENUM-REF-CANDIDATE: green|blue|black|gray|brown|yellow|red — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AssetContainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compactionRatio rdf:type rdf:Property ;
    rdfs:label 'Compaction Ratio' ;
    rdfs:comment 'The volume reduction ratio achieved by compactor units. For example, a ratio of 4.0 means the compactor reduces waste volume by 4:1. Only applicable to compactor_unit container types. Used to calculate effective capacity and optimize service frequency.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conditionGrade rdf:type rdf:Property ;
    rdfs:label 'Condition Grade' ;
    rdfs:comment 'Assessment of the physical condition of the container based on inspection findings. Excellent means like-new; good means minor wear; fair means functional with visible wear; poor means needs repair soon; critical means unsafe or non-functional.' ;
    rdfs:domain ind:AssetContainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerType rdf:type rdf:Property ;
    rdfs:label 'Container Type' ;
    rdfs:comment 'Classification of the container by its operational design and collection method. Front-load dumpsters are serviced by Front End Loader (FEL) trucks, rear-load by Rear End Loader (REL) trucks, roll-offs by specialized roll-off trucks, residential carts by Automated Side Loader (ASL) trucks, and compactor units are stationary compression equipment.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deploymentDate rdf:type rdf:Property ;
    rdfs:label 'Deployment Date' ;
    rdfs:comment 'The date this container was most recently deployed to a customer service address. Used to track deployment history and calculate time-in-service metrics.' ;
    rdfs:domain ind:AssetContainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gpsDeviceCode rdf:type rdf:Property ;
    rdfs:label 'Gps Device Code' ;
    rdfs:comment 'Identifier for the GPS tracking device installed on high-value containers (typically roll-offs and compactors) for real-time location monitoring via Geotab Fleet Telematics or similar systems.' ;
    rdfs:domain ind:AssetContainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inforEamAssetReference rdf:type rdf:Property ;
    rdfs:label 'Infor Eam Asset Reference' ;
    rdfs:comment 'The asset identifier for this container in the Infor EAM system. Used for maintenance work order management, preventive maintenance scheduling, and parts inventory tracking.' ;
    rdfs:domain ind:AssetContainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isGpsEnabled rdf:type rdf:Property ;
    rdfs:label 'Is Gps Enabled' ;
    rdfs:comment 'Boolean flag indicating whether this container is equipped with an active GPS tracking device. True means GPS device is installed and transmitting; false means no GPS tracking.' ;
    rdfs:domain ind:AssetContainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRfidEnabled rdf:type rdf:Property ;
    rdfs:label 'Is Rfid Enabled' ;
    rdfs:comment 'Boolean flag indicating whether this container is equipped with an active RFID tag for automated scanning. True means RFID tag is attached and functional; false means no RFID capability.' ;
    rdfs:domain ind:AssetContainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Last Inspection Date' ;
    rdfs:comment 'The date of the most recent physical inspection of the container. Regular inspections are required for safety, compliance, and preventive maintenance. Inspection frequency varies by container type and regulatory requirements.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lidType rdf:type rdf:Property ;
    rdfs:label 'Lid Type' ;
    rdfs:comment 'The type of lid or cover on the container. Lids help control odor, prevent unauthorized dumping, and keep out rain. Locking lids provide security for customer-specific waste. Some roll-offs have no lids.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturer rdf:type rdf:Property ;
    rdfs:label 'Manufacturer' ;
    rdfs:comment 'The name of the company that manufactured the container. Used for warranty tracking, parts sourcing, and quality analysis.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:material rdf:type rdf:Property ;
    rdfs:label 'Material' ;
    rdfs:comment 'The primary construction material of the container body. Steel is common for commercial dumpsters and roll-offs; plastic (high-density polyethylene) for residential carts; fiberglass for specialized applications; aluminum for lightweight applications.' ;
    rdfs:domain ind:AssetContainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelNumber rdf:type rdf:Property ;
    rdfs:label 'Model Number' ;
    rdfs:comment 'The manufacturer\'s model or part number for this container design. Used for parts compatibility, warranty claims, and standardization.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextInspectionDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Inspection Due Date' ;
    rdfs:comment 'The scheduled date for the next required inspection of the container. Used for preventive maintenance scheduling and compliance tracking.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ownershipStatus rdf:type rdf:Property ;
    rdfs:label 'Ownership Status' ;
    rdfs:comment 'Indicates whether the container is owned by Waste Management, leased from a third party, or owned by the customer. Owned containers are capitalized assets; leased containers have associated lease obligations; customer-owned containers are tracked for service purposes but not capitalized.' ;
    rdfs:domain ind:AssetContainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retrievalDate rdf:type rdf:Property ;
    rdfs:label 'Retrieval Date' ;
    rdfs:comment 'The date this container was retrieved from a customer service address and returned to inventory or maintenance. Null if container is currently deployed.' ;
    rdfs:domain ind:AssetContainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sapAssetNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Asset Number' ;
    rdfs:comment 'The asset number assigned to this container in the SAP S/4HANA Fixed Assets (FI-AA) module. Used for financial asset tracking, depreciation runs, and general ledger integration.' ;
    rdfs:domain ind:AssetContainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceFrequency rdf:type rdf:Property ;
    rdfs:label 'Service Frequency' ;
    rdfs:comment 'The scheduled frequency at which this container is serviced (emptied). Daily is common for high-volume commercial accounts; weekly/biweekly for residential; on-demand for roll-offs.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tareWeightLbs rdf:type rdf:Property ;
    rdfs:label 'Tare Weight Lbs' ;
    rdfs:comment 'The empty weight of the container in pounds. Used to calculate net waste weight by subtracting tare weight from gross weight measured at scales. Critical for accurate tonnage reporting and billing.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wasteStreamType rdf:type rdf:Property ;
    rdfs:label 'Waste Stream Type' ;
    rdfs:comment 'The type of waste this container is designated to hold. MSW is Municipal Solid Waste (general trash); recycling for recyclable materials; organics for compostable waste; C&D for Construction and Demolition debris; hazardous for RCRA-regulated waste; universal waste for batteries, electronics, etc.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerInventoryId rdf:type rdf:Property ;
    rdfs:label 'Container Inventory Id' ;
    rdfs:comment 'Unique identifier for the container inventory snapshot record.' ;
    rdfs:domain ind:ContainerInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supplierVendorId rdf:type rdf:Property ;
    rdfs:label 'Supplier Vendor Id' ;
    rdfs:comment 'Identifier of the primary vendor or supplier for this container type and size.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:yardFacilityId rdf:type rdf:Property ;
    rdfs:label 'Yard Facility Id' ;
    rdfs:comment 'Identifier of the yard, maintenance shop, or staging area where the container inventory is held.' ;
    rdfs:domain ind:ContainerInventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:averageDailyDeployment rdf:type rdf:Property ;
    rdfs:label 'Average Daily Deployment' ;
    rdfs:comment 'The average number of containers of this type and size deployed per day over the last 30 days.' ;
    rdfs:domain ind:ContainerInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:containerSize rdf:type rdf:Property ;
    rdfs:label 'Container Size' ;
    rdfs:comment 'The size or capacity of the container (e.g., 2-yard, 4-yard, 6-yard, 8-yard, 10-yard, 20-yard, 30-yard, 40-yard, 64-gallon, 96-gallon).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleCountFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Cycle Count Frequency Days' ;
    rdfs:comment 'The number of days between scheduled cycle counts for this container type and size.' ;
    rdfs:domain ind:ContainerInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:daysOfSupply rdf:type rdf:Property ;
    rdfs:label 'Days Of Supply' ;
    rdfs:comment 'The number of days the current available inventory can support based on average daily deployment rate.' ;
    rdfs:domain ind:ContainerInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inventoryDate rdf:type rdf:Property ;
    rdfs:label 'Inventory Date' ;
    rdfs:comment 'The date for which this inventory snapshot was recorded.' ;
    rdfs:domain ind:ContainerInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inventoryStatus rdf:type rdf:Property ;
    rdfs:label 'Inventory Status' ;
    rdfs:comment 'The current status of this inventory record (active, inactive, frozen, under review).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastPhysicalCountBy rdf:type rdf:Property ;
    rdfs:label 'Last Physical Count By' ;
    rdfs:comment 'Name or identifier of the employee who performed the last physical inventory count.' ;
    rdfs:domain ind:ContainerInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastPhysicalCountDate rdf:type rdf:Property ;
    rdfs:label 'Last Physical Count Date' ;
    rdfs:comment 'The date when the last physical inventory count was performed for this container type and size at this location.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:materialNumber rdf:type rdf:Property ;
    rdfs:label 'Material Number' ;
    rdfs:comment 'The SAP material master number or SKU for this container type and size.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextScheduledCountDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Count Date' ;
    rdfs:comment 'The date when the next physical inventory count is scheduled for this container type and size.' ;
    rdfs:domain ind:ContainerInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quantityAvailable rdf:type rdf:Property ;
    rdfs:label 'Quantity Available' ;
    rdfs:comment 'Number of containers available for immediate deployment to customer sites.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityCondemned rdf:type rdf:Property ;
    rdfs:label 'Quantity Condemned' ;
    rdfs:comment 'Number of containers marked as condemned or awaiting disposal due to irreparable damage or end of useful life.' ;
    rdfs:domain ind:ContainerInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantityInRepair rdf:type rdf:Property ;
    rdfs:label 'Quantity In Repair' ;
    rdfs:comment 'Number of containers currently undergoing maintenance or repair.' ;
    rdfs:domain ind:ContainerInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantityInTransit rdf:type rdf:Property ;
    rdfs:label 'Quantity In Transit' ;
    rdfs:comment 'Number of containers in transit between facilities or being relocated.' ;
    rdfs:domain ind:ContainerInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantityOnHand rdf:type rdf:Property ;
    rdfs:label 'Quantity On Hand' ;
    rdfs:comment 'Total number of containers of this type and size currently in stock at the yard location.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityReserved rdf:type rdf:Property ;
    rdfs:label 'Quantity Reserved' ;
    rdfs:comment 'Number of containers reserved for scheduled deployment or customer orders.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reorderPoint rdf:type rdf:Property ;
    rdfs:label 'Reorder Point' ;
    rdfs:comment 'The minimum inventory level that triggers a reorder or procurement action for this container type and size.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reorderQuantity rdf:type rdf:Property ;
    rdfs:label 'Reorder Quantity' ;
    rdfs:comment 'The standard quantity to order when inventory falls below the reorder point.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageLocationCode rdf:type rdf:Property ;
    rdfs:label 'Storage Location Code' ;
    rdfs:comment 'The specific storage location or bin code within the yard facility where containers are stored.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalInventoryValue rdf:type rdf:Property ;
    rdfs:label 'Total Inventory Value' ;
    rdfs:comment 'The total value of the inventory on hand (quantity_on_hand multiplied by unit_cost).' ;
    rdfs:domain ind:ContainerInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceQuantity rdf:type rdf:Property ;
    rdfs:label 'Variance Quantity' ;
    rdfs:comment 'The difference between the system inventory count and the last physical count (positive or negative).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depreciationPostingId rdf:type rdf:Property ;
    rdfs:label 'Depreciation Posting Id' ;
    rdfs:comment 'Unique identifier for the depreciation posting record. Primary key for this entity.' ;
    rdfs:domain ind:DepreciationPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:depreciationRunId rdf:type rdf:Property ;
    rdfs:label 'Depreciation Run Id' ;
    rdfs:comment 'Reference to the depreciation run batch that generated this posting. Multiple postings are created by a single depreciation run execution.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DepreciationRun .

ind:employeeId rdf:type rdf:Property ;
    rdfs:label 'Employee Id' ;
    rdfs:comment 'The system user ID or service account that executed the depreciation run and created this posting. Required for SOX audit trail.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:reversedPostingDepreciationPostingId rdf:type rdf:Property ;
    rdfs:label 'Reversed Posting Depreciation Posting Id' ;
    rdfs:comment 'Reference to the original depreciation_posting_id that this posting reverses. Null if this is not a reversal transaction.' ;
    rdfs:domain ind:DepreciationPosting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DepreciationPosting .

ind:acquisitionValue rdf:type rdf:Property ;
    rdfs:label 'Acquisition Value' ;
    rdfs:comment 'The original acquisition or capitalized cost of the asset. Denormalized from asset master for reporting and audit trail purposes.' ;
    rdfs:domain ind:DepreciationPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assetDescription rdf:type rdf:Property ;
    rdfs:label 'Asset Description' ;
    rdfs:comment 'Short text description of the asset. Denormalized from asset master for reporting convenience and audit trail.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetNumber rdf:type rdf:Property ;
    rdfs:label 'Asset Number' ;
    rdfs:comment 'The business identifier (asset tag or asset number) of the fixed asset. Denormalized from asset master for reporting convenience and audit trail.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetSubNumber rdf:type rdf:Property ;
    rdfs:label 'Asset Sub Number' ;
    rdfs:comment 'Sub-asset identifier for assets with multiple components or sub-assets tracked separately (e.g., landfill cells within a landfill site, or equipment modules within a MRF facility).' ;
    rdfs:domain ind:DepreciationPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessArea rdf:type rdf:Property ;
    rdfs:label 'Business Area' ;
    rdfs:comment 'Business area or segment (e.g., Residential Collection, Commercial Collection, Recycling, Landfill, Hazmat) for segment reporting and profitability analysis.' ;
    rdfs:domain ind:DepreciationPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depreciationArea rdf:type rdf:Property ;
    rdfs:label 'Depreciation Area' ;
    rdfs:comment 'Depreciation area code representing the valuation view (e.g., 01=Book Depreciation, 10=Tax Depreciation, 15=IFRS, 20=Cost Accounting, 30=Consolidated, 40=Investment Support). Allows parallel depreciation calculations for different reporting purposes.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depreciationKey rdf:type rdf:Property ;
    rdfs:label 'Depreciation Key' ;
    rdfs:comment 'The depreciation method key or code (e.g., straight-line, declining balance, units of production) used to calculate depreciation for this asset. Denormalized for audit and reporting.' ;
    rdfs:domain ind:DepreciationPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccountAccumulatedDepreciation rdf:type rdf:Property ;
    rdfs:label 'Gl Account Accumulated Depreciation' ;
    rdfs:comment 'The GL account number to which the accumulated depreciation is credited (contra-asset account on the balance sheet).' ;
    rdfs:domain ind:DepreciationPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccountDepreciationExpense rdf:type rdf:Property ;
    rdfs:label 'Gl Account Depreciation Expense' ;
    rdfs:comment 'The GL account number to which the depreciation expense is debited (income statement account).' ;
    rdfs:domain ind:DepreciationPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glDocumentLineItem rdf:type rdf:Property ;
    rdfs:label 'Gl Document Line Item' ;
    rdfs:comment 'The line item number within the GL document for this specific depreciation posting entry.' ;
    rdfs:domain ind:DepreciationPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:glDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Gl Document Number' ;
    rdfs:comment 'The GL document number generated by the depreciation posting. Provides the audit trail link to the financial accounting document.' ;
    rdfs:domain ind:DepreciationPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedDepreciationAmount rdf:type rdf:Property ;
    rdfs:label 'Planned Depreciation Amount' ;
    rdfs:comment 'The planned or calculated depreciation amount for the asset in this period, based on the depreciation key and useful life. Expressed in the company currency.' ;
    rdfs:domain ind:DepreciationPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postedDepreciationAmount rdf:type rdf:Property ;
    rdfs:label 'Posted Depreciation Amount' ;
    rdfs:comment 'The actual depreciation amount posted to the General Ledger (GL) for this period. May differ from planned amount due to manual adjustments, partial period depreciation, or asset retirement.' ;
    rdfs:domain ind:DepreciationPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postingDate rdf:type rdf:Property ;
    rdfs:label 'Posting Date' ;
    rdfs:comment 'The date on which the depreciation posting was made to the General Ledger (GL). Typically the last day of the posting period.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:postingPeriod rdf:type rdf:Property ;
    rdfs:label 'Posting Period' ;
    rdfs:comment 'The fiscal posting period (1-12 for monthly, or 1-13 if special period is used) within the fiscal year for which depreciation is posted.' ;
    rdfs:domain ind:DepreciationPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:postingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Posting Timestamp' ;
    rdfs:comment 'The exact date and time when the depreciation posting was created and posted to the GL. Required for audit trail and SOX compliance.' ;
    rdfs:domain ind:DepreciationPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sourceDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Source Document Reference' ;
    rdfs:comment 'Reference to the source document or transaction in the originating system. Provides traceability back to the source system for audit purposes.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionType rdf:type rdf:Property ;
    rdfs:label 'Transaction Type' ;
    rdfs:comment 'The type of depreciation transaction: planned (normal periodic depreciation), unplanned (extraordinary depreciation), manual_adjustment (manual correction), reversal (correction of prior posting), catch_up (retroactive depreciation for missed periods).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usefulLifePeriods rdf:type rdf:Property ;
    rdfs:label 'Useful Life Periods' ;
    rdfs:comment 'The useful life of the asset expressed in posting periods (e.g., months). Used when depreciation is calculated on a period basis rather than annual.' ;
    rdfs:domain ind:DepreciationPosting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reversedRunDepreciationRunId rdf:type rdf:Property ;
    rdfs:label 'Reversed Run Depreciation Run Id' ;
    rdfs:comment 'Foreign key reference to the original depreciation_run_id that this run reverses. Populated only when reversal_indicator is True. Provides audit trail for corrections.' ;
    rdfs:domain ind:DepreciationRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DepreciationRun .

ind:approvalStatus rdf:type rdf:Property ;
    rdfs:label 'Approval Status' ;
    rdfs:comment 'Indicates whether the depreciation run results have been reviewed and approved by the accounting team before GL posting. Used in organizations with segregation of duties and SOX controls.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approved Timestamp' ;
    rdfs:comment 'The date and time when the depreciation run was approved for GL posting. Part of the SOX-compliant audit trail for financial close processes.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assetCount rdf:type rdf:Property ;
    rdfs:label 'Asset Count' ;
    rdfs:comment 'The total number of fixed assets processed and included in this depreciation calculation run. Used for reconciliation and audit trail purposes.' ;
    rdfs:domain ind:DepreciationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:endTimestamp rdf:type rdf:Property ;
    rdfs:label 'End Timestamp' ;
    rdfs:comment 'The precise date and time when the depreciation calculation run completed (successfully or with errors). Used for performance monitoring and SLA tracking.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:errorCount rdf:type rdf:Property ;
    rdfs:label 'Error Count' ;
    rdfs:comment 'The number of errors encountered during the depreciation run, such as assets with incomplete master data, invalid depreciation keys, or calculation failures. Zero indicates a clean run.' ;
    rdfs:domain ind:DepreciationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:executionDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Execution Duration Seconds' ;
    rdfs:comment 'The total elapsed time in seconds for the depreciation run to complete, calculated as the difference between start_timestamp and end_timestamp. Used for performance analysis and optimization.' ;
    rdfs:domain ind:DepreciationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:postingDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Posting Document Number' ;
    rdfs:comment 'The SAP FI General Ledger (GL) document number generated when the depreciation expense is posted to the financial ledger. This provides the audit trail linking the depreciation run to the GL entries for SOX compliance.' ;
    rdfs:domain ind:DepreciationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runDate rdf:type rdf:Property ;
    rdfs:label 'Run Date' ;
    rdfs:comment 'The date on which the depreciation calculation run was executed. This is the principal business event timestamp for the run.' ;
    rdfs:domain ind:DepreciationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:runMode rdf:type rdf:Property ;
    rdfs:label 'Run Mode' ;
    rdfs:comment 'Indicates whether the depreciation run was executed in test mode (for validation and review without GL posting) or production mode (with actual GL posting). Test runs are used during month-end close preparation.' ;
    rdfs:domain ind:DepreciationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runNumber rdf:type rdf:Property ;
    rdfs:label 'Run Number' ;
    rdfs:comment 'Business identifier for the depreciation run, typically generated by the financial system (SAP FI-AA) to uniquely identify each periodic depreciation calculation cycle.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runStatus rdf:type rdf:Property ;
    rdfs:label 'Run Status' ;
    rdfs:comment 'Current lifecycle status of the depreciation run indicating whether the calculation is scheduled, executing, completed successfully, failed, cancelled, or posted to the General Ledger (GL).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runType rdf:type rdf:Property ;
    rdfs:label 'Run Type' ;
    rdfs:comment 'Classification of the depreciation run indicating whether it is a standard planned periodic run, an unplanned ad-hoc run, a repeat run to correct errors, an adjustment run for asset changes, or a special year-end closing run.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:startTimestamp rdf:type rdf:Property ;
    rdfs:label 'Start Timestamp' ;
    rdfs:comment 'The precise date and time when the depreciation calculation run was initiated. Used for performance monitoring and audit trail.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:totalDepreciationAmount rdf:type rdf:Property ;
    rdfs:label 'Total Depreciation Amount' ;
    rdfs:comment 'The aggregate depreciation expense calculated and posted across all assets processed in this run, expressed in the company\'s reporting currency (USD). This amount flows to the General Ledger (GL) as a period expense.' ;
    rdfs:domain ind:DepreciationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warningCount rdf:type rdf:Property ;
    rdfs:label 'Warning Count' ;
    rdfs:comment 'The number of warnings generated during the depreciation run, such as assets nearing full depreciation or assets with unusual depreciation patterns. Warnings do not prevent posting but require review.' ;
    rdfs:domain ind:DepreciationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:airPermitNumber rdf:type rdf:Property ;
    rdfs:label 'Air Permit Number' ;
    rdfs:comment 'Permit number issued under the Clean Air Act (CAA) for facilities with air emissions (e.g., landfills with LFG flares, WTE plants).' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissioningDate rdf:type rdf:Property ;
    rdfs:label 'Commissioning Date' ;
    rdfs:comment 'Date when the facility became fully operational and began accepting waste or providing services.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:decommissioningDate rdf:type rdf:Property ;
    rdfs:label 'Decommissioning Date' ;
    rdfs:comment 'Date when the facility was permanently closed and decommissioned. Null for active facilities.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:emailAddress rdf:type rdf:Property ;
    rdfs:label 'Email Address' ;
    rdfs:comment 'Primary email address for facility correspondence and notifications.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epaFacilityNumber rdf:type rdf:Property ;
    rdfs:label 'Epa Facility Number' ;
    rdfs:comment 'Unique identifier assigned by the U.S. EPA for tracking environmental compliance and reporting (e.g., FRS Registry ID).' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityCode rdf:type rdf:Property ;
    rdfs:label 'Facility Code' ;
    rdfs:comment 'Short alphanumeric code used for internal identification and reporting (e.g., \'LF-001\', \'MRF-023\').' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityName rdf:type rdf:Property ;
    rdfs:label 'Facility Name' ;
    rdfs:comment 'Official business name of the facility (e.g., \'Metro East Landfill\', \'Riverside MRF\').' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityType rdf:type rdf:Property ;
    rdfs:label 'Facility Type' ;
    rdfs:comment 'Classification of the facility by operational purpose: landfill (Municipal Solid Waste disposal site), MRF (Materials Recovery Facility for recycling), WTE (Waste-to-Energy conversion plant), transfer_station (intermediate collection point), TSDF (Treatment Storage and Disposal Facility for hazardous waste), maintenance_shop (fleet and equipment repair), administrative_office (corporate/regional office). [ENUM-REF-CANDIDATE: landfill|mrf|wte|transfer_station|tsdf|maintenance_shop|administrative_office — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:faxNumber rdf:type rdf:Property ;
    rdfs:label 'Fax Number' ;
    rdfs:comment 'Fax number for the facility, if applicable.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatFacilityFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Facility Flag' ;
    rdfs:comment 'Indicates whether the facility is authorized to handle, store, or treat hazardous waste under RCRA Subtitle C (True/False).' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iso14001Certified rdf:type rdf:Property ;
    rdfs:label 'Iso 14001 Certified' ;
    rdfs:comment 'Indicates whether the facility holds ISO 14001 certification for environmental management systems (True/False).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iso45001Certified rdf:type rdf:Property ;
    rdfs:label 'Iso 45001 Certified' ;
    rdfs:comment 'Indicates whether the facility holds ISO 45001 certification for occupational health and safety management (True/False).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:landfillClosureDate rdf:type rdf:Property ;
    rdfs:label 'Landfill Closure Date' ;
    rdfs:comment 'Projected or actual date when the landfill will reach capacity and cease accepting waste. Null for non-landfill facilities.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:latitude rdf:type rdf:Property ;
    rdfs:label 'Latitude' ;
    rdfs:comment 'Geographic latitude coordinate of the facility in decimal degrees (WGS84 datum).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leaJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Lea Jurisdiction' ;
    rdfs:comment 'Name of the Local Enforcement Agency (LEA) or county environmental health department with regulatory oversight of the facility.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:longitude rdf:type rdf:Property ;
    rdfs:label 'Longitude' ;
    rdfs:comment 'Geographic longitude coordinate of the facility in decimal degrees (WGS84 datum).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:managerName rdf:type rdf:Property ;
    rdfs:label 'Manager Name' ;
    rdfs:comment 'Full name of the facility manager or site superintendent responsible for day-to-day operations.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipType rdf:type rdf:Property ;
    rdfs:label 'Ownership Type' ;
    rdfs:comment 'Legal ownership structure of the facility: owned (company-owned asset), leased (leased from third party), operated_under_contract (operated on behalf of municipality or other entity), joint_venture (co-owned with partner).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permittedCapacityTpd rdf:type rdf:Property ;
    rdfs:label 'Permitted Capacity Tpd' ;
    rdfs:comment 'Maximum daily waste processing or disposal capacity in tons per day (TPD) as authorized by regulatory permits. Applicable to landfills, MRFs, WTE plants, and transfer stations.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:phoneNumber rdf:type rdf:Property ;
    rdfs:label 'Phone Number' ;
    rdfs:comment 'Primary contact phone number for the facility.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteAreaAcres rdf:type rdf:Property ;
    rdfs:label 'Site Area Acres' ;
    rdfs:comment 'Total land area of the facility site in acres, including operational areas, buffer zones, and administrative buildings.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:solidWastePermitNumber rdf:type rdf:Property ;
    rdfs:label 'Solid Waste Permit Number' ;
    rdfs:comment 'Primary operating permit number issued by state or local authority under RCRA Subtitle D (non-hazardous) or Subtitle C (hazardous) for waste management operations.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:swisNumber rdf:type rdf:Property ;
    rdfs:label 'Swis Number' ;
    rdfs:comment 'State-issued identifier for solid waste facilities used for regulatory tracking and reporting (varies by state).' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waterPermitNumber rdf:type rdf:Property ;
    rdfs:label 'Water Permit Number' ;
    rdfs:comment 'Permit number issued under the Clean Water Act (CWA) for facilities that discharge wastewater or manage leachate (e.g., NPDES permit).' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Responsible Employee Id' ;
    rdfs:comment 'Identifier of the employee responsible for the asset. Used for accountability, maintenance coordination, and asset custody tracking.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:capacityUnit rdf:type rdf:Property ;
    rdfs:label 'Capacity Unit' ;
    rdfs:comment 'Unit of measure for the capacity value. Must align with industry standards and operational reporting requirements.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityValue rdf:type rdf:Property ;
    rdfs:label 'Capacity Value' ;
    rdfs:comment 'Rated capacity or size of the asset in appropriate units. Examples: cubic yards for containers, tons per day for processing equipment, square feet for buildings.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conditionRating rdf:type rdf:Property ;
    rdfs:label 'Condition Rating' ;
    rdfs:comment 'Current physical condition assessment of the asset based on inspection and maintenance history. Used for replacement planning and risk assessment.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentBookValue rdf:type rdf:Property ;
    rdfs:label 'Current Book Value' ;
    rdfs:comment 'Current net book value of the asset after accumulated depreciation. Calculated as acquisition cost minus accumulated depreciation. Updated with each depreciation run.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disposalDate rdf:type rdf:Property ;
    rdfs:label 'Disposal Date' ;
    rdfs:comment 'Date the asset was retired, sold, scrapped, or otherwise disposed of. Marks the end of the assets lifecycle and triggers final accounting entries.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disposalProceeds rdf:type rdf:Property ;
    rdfs:label 'Disposal Proceeds' ;
    rdfs:comment 'Amount received from sale or disposal of the asset. Used to calculate gain or loss on disposal for financial reporting.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Environmental Compliance Flag' ;
    rdfs:comment 'Indicates whether the asset requires environmental compliance monitoring per EPA, RCRA, or state regulations. Used for regulatory reporting and inspection scheduling.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insurancePolicyNumber rdf:type rdf:Property ;
    rdfs:label 'Insurance Policy Number' ;
    rdfs:comment 'Insurance policy number covering the asset. Used for risk management, claims processing, and insurance compliance tracking.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaseContractNumber rdf:type rdf:Property ;
    rdfs:label 'Lease Contract Number' ;
    rdfs:comment 'Contract number for leased assets. Links to lease agreement master data for payment tracking and lease accounting compliance.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationDescription rdf:type rdf:Property ;
    rdfs:label 'Location Description' ;
    rdfs:comment 'Detailed physical location description of where the asset is deployed or stored. Examples: customer site address, facility name, yard location, route assignment.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Warranty Expiration Date' ;
    rdfs:comment 'Date when manufacturer or vendor warranty coverage expires. Used for maintenance cost planning and warranty claim eligibility.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gpsTelemetryId rdf:type rdf:Property ;
    rdfs:label 'Gps Telemetry Id' ;
    rdfs:comment 'Unique identifier for the GPS telemetry record. Primary key for time-series GPS position and telemetry data from GPS-equipped stationary assets and containers.' ;
    rdfs:domain ind:GpsTelemetry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accuracyMeters rdf:type rdf:Property ;
    rdfs:label 'Accuracy Meters' ;
    rdfs:comment 'Estimated accuracy radius of the GPS position reading in meters. Represents the confidence interval within which the true position lies. Lower values indicate higher precision.' ;
    rdfs:domain ind:GpsTelemetry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:altitudeMeters rdf:type rdf:Property ;
    rdfs:label 'Altitude Meters' ;
    rdfs:comment 'Elevation above sea level in meters at the time of GPS reading. Used for terrain analysis and asset placement verification in landfill cells or hilly terrain.' ;
    rdfs:domain ind:GpsTelemetry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batteryLevelPercent rdf:type rdf:Property ;
    rdfs:label 'Battery Level Percent' ;
    rdfs:comment 'Remaining battery charge level of the GPS device as a percentage (0.00 to 100.00). Used for proactive device maintenance and battery replacement scheduling.' ;
    rdfs:domain ind:GpsTelemetry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deviceCode rdf:type rdf:Property ;
    rdfs:label 'Device Code' ;
    rdfs:comment 'Unique identifier of the GPS tracking device hardware unit. Used to identify the specific GPS tracker installed on the asset, distinct from the asset itself.' ;
    rdfs:domain ind:GpsTelemetry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceStatus rdf:type rdf:Property ;
    rdfs:label 'Device Status' ;
    rdfs:comment 'Operational status of the GPS tracking device. Active = functioning normally, Inactive = powered off or not transmitting, Maintenance = undergoing service, Fault = malfunction detected, Decommissioned = removed from service.' ;
    rdfs:domain ind:GpsTelemetry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventTimestamp rdf:type rdf:Property ;
    rdfs:label 'Event Timestamp' ;
    rdfs:comment 'Date and time when the GPS position and telemetry data was captured by the device. Represents the real-world observation time in ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:firmwareVersion rdf:type rdf:Property ;
    rdfs:label 'Firmware Version' ;
    rdfs:comment 'Version number of the GPS device firmware at the time of transmission. Used for device management, compatibility tracking, and firmware update planning.' ;
    rdfs:domain ind:GpsTelemetry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geofenceStatus rdf:type rdf:Property ;
    rdfs:label 'Geofence Status' ;
    rdfs:comment 'Current status of the asset relative to its assigned geofence zone. Inside = within authorized zone, Outside = beyond authorized zone, Entering = crossing into zone, Exiting = crossing out of zone.' ;
    rdfs:domain ind:GpsTelemetry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hdop rdf:type rdf:Property ;
    rdfs:label 'Hdop' ;
    rdfs:comment 'Measure of GPS position accuracy. Lower values indicate better precision. <1 = Ideal, 1-2 = Excellent, 2-5 = Good, 5-10 = Moderate, 10-20 = Fair, >20 = Poor.' ;
    rdfs:domain ind:GpsTelemetry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:headingDegrees rdf:type rdf:Property ;
    rdfs:label 'Heading Degrees' ;
    rdfs:comment 'Compass direction of asset movement in degrees (0-360). 0/360 = North, 90 = East, 180 = South, 270 = West. Null if asset is stationary.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:installationDate rdf:type rdf:Property ;
    rdfs:label 'Installation Date' ;
    rdfs:comment 'Date when the GPS device was installed on the asset. Used for device age tracking, warranty management, and replacement planning.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastMaintenanceDate rdf:type rdf:Property ;
    rdfs:label 'Last Maintenance Date' ;
    rdfs:comment 'Date when the GPS device last underwent maintenance, battery replacement, or firmware update. Used for preventive maintenance scheduling and device lifecycle tracking.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:movementAlertFlag rdf:type rdf:Property ;
    rdfs:label 'Movement Alert Flag' ;
    rdfs:comment 'Boolean indicator of whether unauthorized movement was detected for a stationary asset. True = unexpected movement detected, False = asset stationary or movement authorized. Used for theft detection.' ;
    rdfs:domain ind:GpsTelemetry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:networkType rdf:type rdf:Property ;
    rdfs:label 'Network Type' ;
    rdfs:comment 'Communication network used to transmit the telemetry data. Cellular = 3G/4G/5G mobile network, Satellite = satellite communication, WiFi = wireless local area network, LoRa = long-range low-power network.' ;
    rdfs:domain ind:GpsTelemetry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:satelliteCount rdf:type rdf:Property ;
    rdfs:label 'Satellite Count' ;
    rdfs:comment 'Number of GPS satellites the device was connected to at the time of reading. Higher count indicates better position accuracy. Minimum 3 required for 2D fix, 4 for 3D fix.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:signalQuality rdf:type rdf:Property ;
    rdfs:label 'Signal Quality' ;
    rdfs:comment 'Quality of the GPS satellite signal at the time of reading. Excellent = 4+ satellites with strong signal, Good = 3-4 satellites, Fair = 2-3 satellites, Poor = 1-2 satellites, No Signal = 0 satellites.' ;
    rdfs:domain ind:GpsTelemetry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:speedKmh rdf:type rdf:Property ;
    rdfs:label 'Speed Kmh' ;
    rdfs:comment 'Instantaneous speed of the asset in kilometers per hour. For stationary assets, non-zero values indicate unauthorized movement or theft. Used for tamper detection and movement alerts.' ;
    rdfs:domain ind:GpsTelemetry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tamperAlertFlag rdf:type rdf:Property ;
    rdfs:label 'Tamper Alert Flag' ;
    rdfs:comment 'Boolean indicator of whether the GPS device detected tampering or unauthorized removal attempt. True = tamper detected, False = no tamper. Triggers security alerts and theft investigation.' ;
    rdfs:domain ind:GpsTelemetry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:temperatureCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Celsius' ;
    rdfs:comment 'Ambient temperature reading from the GPS device sensor in degrees Celsius. Used for device health monitoring and environmental condition tracking. Null if device does not have temperature sensor.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transmissionType rdf:type rdf:Property ;
    rdfs:label 'Transmission Type' ;
    rdfs:comment 'Classification of what triggered this telemetry transmission. Scheduled = routine periodic update, Event Triggered = geofence breach or movement alert, On Demand = manual query, Emergency = tamper or critical alert.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaseId rdf:type rdf:Property ;
    rdfs:label 'Lease Id' ;
    rdfs:comment 'Unique identifier for the lease contract record. Primary key.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lessorVendorId rdf:type rdf:Property ;
    rdfs:label 'Lessor Vendor Id' ;
    rdfs:comment 'Vendor master record identifier for the lessor in the SAP S/4HANA MM module. Links lease contract to vendor master for procurement and accounts payable processing.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:classificationDate rdf:type rdf:Property ;
    rdfs:label 'Classification Date' ;
    rdfs:comment 'Date on which the lease was classified as operating or finance lease per ASC 842/IFRS 16 criteria. Typically the lease commencement date or the date of initial recognition.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:documentUrl rdf:type rdf:Property ;
    rdfs:label 'Document Url' ;
    rdfs:comment 'URL or file path to the scanned lease contract document stored in the enterprise document management system. Provides access to the original signed lease agreement for audit and reference purposes.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endDate rdf:type rdf:Property ;
    rdfs:label 'End Date' ;
    rdfs:comment 'Scheduled end date of the lease contract term. May be extended if renewal options are exercised. Null for perpetual or indefinite leases.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:implicitInterestRate rdf:type rdf:Property ;
    rdfs:label 'Implicit Interest Rate' ;
    rdfs:comment 'Implicit interest rate in the lease contract, if determinable. Used to discount lease payments to present value for ROU asset and lease liability calculation. If not determinable, the lessee\'s incremental borrowing rate is used instead.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incrementalBorrowingRate rdf:type rdf:Property ;
    rdfs:label 'Incremental Borrowing Rate' ;
    rdfs:comment 'The rate of interest that the lessee would have to pay to borrow funds on a collateralized basis over a similar term to obtain an asset of similar value. Used as the discount rate when the implicit rate is not readily determinable.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leaseStatus rdf:type rdf:Property ;
    rdfs:label 'Lease Status' ;
    rdfs:comment 'Current lifecycle status of the lease contract. Active indicates the lease is in force; terminated indicates early termination; expired indicates natural end of term; renewed indicates transition to a new lease term.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaseType rdf:type rdf:Property ;
    rdfs:label 'Lease Type' ;
    rdfs:comment 'Classification of the lease as operating lease, finance lease, or capital lease per ASC 842 (US GAAP) and IFRS 16 accounting standards. Determines accounting treatment for right-of-use asset and lease liability recognition.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leasedAssetDescription rdf:type rdf:Property ;
    rdfs:label 'Leased Asset Description' ;
    rdfs:comment 'Detailed description of the asset(s) covered by this lease contract. May include containers (dumpsters, roll-offs, carts), compactors, balers, scales, or other equipment used in waste collection and processing operations.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liabilityBalance rdf:type rdf:Property ;
    rdfs:label 'Liability Balance' ;
    rdfs:comment 'Current outstanding lease liability balance on the balance sheet. Represents the present value of remaining lease payments. Reduced by principal portion of each lease payment and increased by interest accretion.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modificationDate rdf:type rdf:Property ;
    rdfs:label 'Modification Date' ;
    rdfs:comment 'Date of the most recent lease modification that changed the scope or consideration of the lease. Lease modifications require remeasurement of the lease liability and ROU asset per ASC 842/IFRS 16.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:modificationDescription rdf:type rdf:Property ;
    rdfs:label 'Modification Description' ;
    rdfs:comment 'Description of the most recent lease modification, including changes to lease term, payment amounts, or scope of leased assets. Null if no modifications have occurred.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monthlyLeasePayment rdf:type rdf:Property ;
    rdfs:label 'Monthly Lease Payment' ;
    rdfs:comment 'Fixed monthly payment amount due to the lessor under the lease contract. Excludes variable payments based on usage or performance. Denominated in the currency specified in payment_currency_code.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Payment Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for lease payment amounts (e.g., USD, CAD, EUR). All monetary fields in this lease record are denominated in this currency.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentFrequency rdf:type rdf:Property ;
    rdfs:label 'Payment Frequency' ;
    rdfs:comment 'Frequency of lease payment obligations. Most leases are monthly; some may be quarterly or annually depending on contract terms.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseOptionFlag rdf:type rdf:Property ;
    rdfs:label 'Purchase Option Flag' ;
    rdfs:comment 'Indicates whether the lease contract includes an option for the lessee to purchase the leased asset at the end of the lease term or during the lease period. True if purchase option exists; False otherwise.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:purchaseOptionPrice rdf:type rdf:Property ;
    rdfs:label 'Purchase Option Price' ;
    rdfs:comment 'Fixed purchase price or formula for calculating the purchase price if the lessee exercises the purchase option. Null if no purchase option exists or price is not predetermined.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewalOptionFlag rdf:type rdf:Property ;
    rdfs:label 'Renewal Option Flag' ;
    rdfs:comment 'Indicates whether the lease contract includes an option for the lessee to renew the lease term beyond the initial end date. True if renewal option exists; False otherwise.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalOptionTerms rdf:type rdf:Property ;
    rdfs:label 'Renewal Option Terms' ;
    rdfs:comment 'Detailed description of renewal option terms, including renewal period duration, payment adjustments, and conditions for exercising the renewal. Null if no renewal option exists.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rouAssetValue rdf:type rdf:Property ;
    rdfs:label 'Rou Asset Value' ;
    rdfs:comment 'Initial right-of-use asset value recognized on the balance sheet at lease commencement per ASC 842/IFRS 16. Calculated as the present value of lease payments plus initial direct costs. Amortized over the lease term.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sapLeaseContractReference rdf:type rdf:Property ;
    rdfs:label 'Sap Lease Contract Reference' ;
    rdfs:comment 'Reference number or document ID for the lease contract in SAP S/4HANA lease accounting module. Used for integration and reconciliation between lakehouse and SAP system of record.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:startDate rdf:type rdf:Property ;
    rdfs:label 'Start Date' ;
    rdfs:comment 'Effective start date of the lease contract. Marks the commencement of the lease term and the beginning of lease payment obligations and right-of-use asset recognition per ASC 842/IFRS 16.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:termMonths rdf:type rdf:Property ;
    rdfs:label 'Term Months' ;
    rdfs:comment 'Total duration of the lease contract in months from start date to end date. Used for lease accounting calculations and amortization schedules.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:terminationOptionFlag rdf:type rdf:Property ;
    rdfs:label 'Termination Option Flag' ;
    rdfs:comment 'Indicates whether the lessee has the right to terminate the lease before the scheduled end date. True if early termination option exists; False otherwise.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:terminationPenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Termination Penalty Amount' ;
    rdfs:comment 'Financial penalty or fee payable by the lessee if the lease is terminated early. Null if no termination penalty applies or if termination is not permitted.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rfidReadEventId rdf:type rdf:Property ;
    rdfs:label 'Rfid Read Event Id' ;
    rdfs:comment 'Unique identifier for each RFID tag read event captured during container service operations or facility gate transactions.' ;
    rdfs:domain ind:RfidReadEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:collectionStopId rdf:type rdf:Property ;
    rdfs:label 'Collection Stop Id' ;
    rdfs:comment 'Reference to the specific route stop where the RFID read occurred. Null for non-route events such as facility gate scans.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CollectionStop .

ind:driverId rdf:type rdf:Property ;
    rdfs:label 'Driver Id' ;
    rdfs:comment 'Reference to the driver operating the vehicle at the time of the RFID read. Null for stationary facility readers. Used for driver performance tracking and service accountability.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Driver .

ind:vehicleId rdf:type rdf:Property ;
    rdfs:label 'Vehicle Id' ;
    rdfs:comment 'Reference to the collection vehicle on which the RFID reader was mounted at the time of the read event. Null for stationary readers at facilities.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vehicle .

ind:antennaCode rdf:type rdf:Property ;
    rdfs:label 'Antenna Code' ;
    rdfs:comment 'Identifier of the specific antenna on the reader device that captured the tag read. Multi-antenna readers use this to determine read direction and position.' ;
    rdfs:domain ind:RfidReadEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Billing Eligible Flag' ;
    rdfs:comment 'Indicates whether this read event qualifies for billing confirmation based on read quality, location accuracy, and business rules. True if eligible, False if not.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:duplicateReadFlag rdf:type rdf:Property ;
    rdfs:label 'Duplicate Read Flag' ;
    rdfs:comment 'Indicates whether this read event is a duplicate of a previous read within a defined time window (typically 60 seconds). True if duplicate, False if unique read.' ;
    rdfs:domain ind:RfidReadEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eventType rdf:type rdf:Property ;
    rdfs:label 'Event Type' ;
    rdfs:comment 'Classification of the RFID read event indicating the business context: service confirmation during collection, yard inventory scan, facility gate entry/exit, manual handheld scan, or exception handling scan.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionCode rdf:type rdf:Property ;
    rdfs:label 'Exception Code' ;
    rdfs:comment 'Code indicating any exception or anomaly detected during the read event. Empty string if no exception. Used for quality control and dispute resolution.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionDescription rdf:type rdf:Property ;
    rdfs:label 'Exception Description' ;
    rdfs:comment 'Human-readable description of the exception or anomaly, if any. Null if no exception occurred. Provides context for operational review and customer service.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Processed Timestamp' ;
    rdfs:comment 'Date and time when the raw RFID read event was processed and loaded into the lakehouse silver layer. Used for data lineage and latency monitoring.' ;
    rdfs:domain ind:RfidReadEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:readDirection rdf:type rdf:Property ;
    rdfs:label 'Read Direction' ;
    rdfs:comment 'Direction of vehicle or container movement at the time of read: inbound (entering facility), outbound (exiting facility), stationary (no movement), or unknown (direction not determinable).' ;
    rdfs:domain ind:RfidReadEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:readLatitude rdf:type rdf:Property ;
    rdfs:label 'Read Latitude' ;
    rdfs:comment 'Geographic latitude coordinate (decimal degrees) captured by GPS at the time of the RFID read. Used for service verification and geospatial analytics.' ;
    rdfs:domain ind:RfidReadEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:readLongitude rdf:type rdf:Property ;
    rdfs:label 'Read Longitude' ;
    rdfs:comment 'Geographic longitude coordinate (decimal degrees) captured by GPS at the time of the RFID read. Used for service verification and geospatial analytics.' ;
    rdfs:domain ind:RfidReadEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:readQualityScore rdf:type rdf:Property ;
    rdfs:label 'Read Quality Score' ;
    rdfs:comment 'Normalized quality score (0-100) calculated from signal strength, GPS accuracy, and reader diagnostics. Higher scores indicate more reliable reads suitable for billing confirmation.' ;
    rdfs:domain ind:RfidReadEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:readSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Read Sequence Number' ;
    rdfs:comment 'Sequential number of this read within the route execution or facility session. Used to reconstruct the chronological order of service events and detect duplicate reads.' ;
    rdfs:domain ind:RfidReadEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:readTimestamp rdf:type rdf:Property ;
    rdfs:label 'Read Timestamp' ;
    rdfs:comment 'Precise date and time when the RFID tag was read by the reader device. Captured in UTC and converted to local time zone for reporting.' ;
    rdfs:domain ind:RfidReadEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:readerDeviceCode rdf:type rdf:Property ;
    rdfs:label 'Reader Device Code' ;
    rdfs:comment 'Unique identifier of the RFID reader device that captured the tag read. Typically mounted on collection trucks, facility gates, or yard scanners.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:readerFirmwareVersion rdf:type rdf:Property ;
    rdfs:label 'Reader Firmware Version' ;
    rdfs:comment 'Version number of the firmware running on the RFID reader device at the time of the read. Used for troubleshooting and ensuring device compliance with operational standards.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceDate rdf:type rdf:Property ;
    rdfs:label 'Service Date' ;
    rdfs:comment 'Business date (local time zone) on which the service event occurred. Used for partitioning, billing cycle alignment, and operational reporting. Derived from read_timestamp.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:signalStrengthDbm rdf:type rdf:Property ;
    rdfs:label 'Signal Strength Dbm' ;
    rdfs:comment 'Received signal strength indicator (RSSI) of the RFID tag read measured in dBm. Higher values (closer to zero) indicate stronger signal. Used for read quality assessment and troubleshooting.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceRecordReference rdf:type rdf:Property ;
    rdfs:label 'Source Record Reference' ;
    rdfs:comment 'Unique identifier of the read event record in the source operational system. Used for traceability and reconciliation with upstream systems.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tagMemoryBank rdf:type rdf:Property ;
    rdfs:label 'Tag Memory Bank' ;
    rdfs:comment 'RFID tag memory bank from which the data was read: EPC (Electronic Product Code), TID (Tag Identifier), USER (user-defined data), or RESERVED (access/kill passwords).' ;
    rdfs:domain ind:RfidReadEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedAssetId rdf:type rdf:Property ;
    rdfs:label 'Assigned Asset Id' ;
    rdfs:comment 'Foreign key reference to the asset (container, equipment, or other trackable item) to which this RFID tag is currently attached. Null if the tag is in inventory and not yet assigned.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FixedAsset .

ind:primaryRfidInstalledByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Rfid Installed By Employee Id' ;
    rdfs:comment 'Foreign key reference to the employee who physically installed the RFID tag on the asset. Used for quality control, training assessment, and accountability.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:replacedByTagId rdf:type rdf:Property ;
    rdfs:label 'Replaced By Tag Id' ;
    rdfs:comment 'Foreign key reference to the new RFID tag that replaced this tag. Creates a chain of custody for container tracking history. Null if the tag is still active or was retired without replacement.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RfidTag .

ind:assignedAssetType rdf:type rdf:Property ;
    rdfs:label 'Assigned Asset Type' ;
    rdfs:comment 'The category of asset to which this RFID tag is attached. Container is most common for waste management operations. Equipment includes compactors, balers, and scales. Vehicle tags are used for non-fleet tracking (fleet has separate DOT-compliant systems).' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentDate rdf:type rdf:Property ;
    rdfs:label 'Assignment Date' ;
    rdfs:comment 'The date when this RFID tag was assigned to a specific asset (container, equipment, or other trackable item). Marks the beginning of the tag-asset relationship for tracking and billing purposes.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:batchNumber rdf:type rdf:Property ;
    rdfs:label 'Batch Number' ;
    rdfs:comment 'The manufacturer batch or lot number for this RFID tag. Used for quality control, recall management, and performance analysis by production batch. If a batch shows high failure rates, all tags from that batch can be identified and replaced proactively.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:encryptionEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Encryption Enabled Flag' ;
    rdfs:comment 'Indicates whether the RFID tag uses encrypted communication protocols. True for tags with built-in encryption capabilities. Encryption enhances security for sensitive applications and prevents unauthorized tag cloning.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:environmentalRating rdf:type rdf:Property ;
    rdfs:label 'Environmental Rating' ;
    rdfs:comment 'The IP (Ingress Protection) rating indicating the tags resistance to dust and water. Waste container RFID tags typically require IP67 or higher for outdoor exposure, pressure washing, and harsh environmental conditions.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epcCode rdf:type rdf:Property ;
    rdfs:label 'Epc Code' ;
    rdfs:comment 'The unique EPC identifier encoded in the RFID tag, typically a 96-bit or 128-bit hexadecimal value conforming to GS1 EPC standards. This is the actual data read from the tag during scanning operations.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedLifespanYears rdf:type rdf:Property ;
    rdfs:label 'Expected Lifespan Years' ;
    rdfs:comment 'The manufacturer-specified expected operational lifespan of the RFID tag in years under normal operating conditions. Passive tags typically last 10-20 years; active tags with batteries last 3-7 years. Used for replacement forecasting and total cost of ownership calculations.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:frequencyBand rdf:type rdf:Property ;
    rdfs:label 'Frequency Band' ;
    rdfs:comment 'The radio frequency band on which the tag operates. UHF (860-960 MHz) is standard for waste container tracking due to long read range and fast read rates. Frequency band determines reader compatibility and regulatory compliance.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:installationLocation rdf:type rdf:Property ;
    rdfs:label 'Installation Location' ;
    rdfs:comment 'Describes where on the asset the RFID tag is physically mounted (e.g., front panel, lid interior, side wall, handle). Important for troubleshooting read failures and ensuring consistent tag placement across the fleet.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReadLocationLatitude rdf:type rdf:Property ;
    rdfs:label 'Last Read Location Latitude' ;
    rdfs:comment 'The geographic latitude coordinate where the RFID tag was last successfully read. Captured from GPS-enabled mobile readers on collection vehicles or fixed readers at facilities.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastReadLocationLongitude rdf:type rdf:Property ;
    rdfs:label 'Last Read Location Longitude' ;
    rdfs:comment 'The geographic longitude coordinate where the RFID tag was last successfully read. Used in conjunction with latitude for geospatial analysis and container location tracking.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastReadReaderCode rdf:type rdf:Property ;
    rdfs:label 'Last Read Reader Code' ;
    rdfs:comment 'Identifier of the RFID reader device that performed the last successful read. May be a vehicle-mounted reader, handheld scanner, or fixed portal reader. Used for reader performance analysis and troubleshooting.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReadTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Read Timestamp' ;
    rdfs:comment 'The most recent date and time when this RFID tag was successfully read by an RFID reader during a collection event, yard inventory scan, or other tracking operation. Used to identify potentially damaged or lost tags.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:memoryCapacityBytes rdf:type rdf:Property ;
    rdfs:label 'Memory Capacity Bytes' ;
    rdfs:comment 'The total memory capacity of the RFID tag in bytes. Typical passive UHF tags have 96-512 bits (12-64 bytes). Larger memory allows storage of additional data such as service history, container specifications, or maintenance records directly on the tag.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operatingTemperatureMaxC rdf:type rdf:Property ;
    rdfs:label 'Operating Temperature Max C' ;
    rdfs:comment 'The maximum ambient temperature in Celsius at which the RFID tag is rated to operate reliably. Important for tags on containers exposed to direct sunlight, hot climates, or high-temperature waste streams.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatingTemperatureMinC rdf:type rdf:Property ;
    rdfs:label 'Operating Temperature Min C' ;
    rdfs:comment 'The minimum ambient temperature in Celsius at which the RFID tag is rated to operate reliably. Critical for tags deployed in extreme cold climates or refrigerated waste applications.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:readFailureCount rdf:type rdf:Property ;
    rdfs:label 'Read Failure Count' ;
    rdfs:comment 'The total number of attempted reads that failed for this RFID tag. High failure counts indicate potential tag damage, environmental interference, or reader issues requiring investigation.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:readSuccessCount rdf:type rdf:Property ;
    rdfs:label 'Read Success Count' ;
    rdfs:comment 'The total number of successful reads recorded for this RFID tag since installation. Used to assess tag performance, durability, and expected remaining lifespan.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:replacementDate rdf:type rdf:Property ;
    rdfs:label 'Replacement Date' ;
    rdfs:comment 'The date when this RFID tag was replaced with a new tag. Marks the end of the tags active service life. Used in conjunction with installation_date to calculate actual tag lifespan for performance analysis.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:replacementReason rdf:type rdf:Property ;
    rdfs:label 'Replacement Reason' ;
    rdfs:comment 'Free-text description of why the RFID tag was replaced or retired. Common reasons include physical damage, read failures, container disposal, tag upgrade, or end of service life. Used for root cause analysis and tag durability improvement.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tagManufacturer rdf:type rdf:Property ;
    rdfs:label 'Tag Manufacturer' ;
    rdfs:comment 'The name of the company that manufactured the RFID tag hardware (e.g., Alien Technology, Impinj, Avery Dennison, Confidex). Important for warranty tracking, performance characteristics, and replacement sourcing.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tagModel rdf:type rdf:Property ;
    rdfs:label 'Tag Model' ;
    rdfs:comment 'The specific model or part number of the RFID tag. Different models have varying read ranges, durability ratings, and environmental tolerances critical for outdoor waste container applications.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tagStatus rdf:type rdf:Property ;
    rdfs:label 'Tag Status' ;
    rdfs:comment 'Current operational status of the RFID tag. Active tags are in service and readable. Damaged tags have been identified as non-functional during read attempts. Replaced tags have been swapped out. Retired tags are decommissioned. Lost tags cannot be located. Quarantined tags are temporarily suspended pending investigation.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tagType rdf:type rdf:Property ;
    rdfs:label 'Tag Type' ;
    rdfs:comment 'The technology type of the RFID tag. Passive UHF tags are most common for container tracking in waste management, offering long read ranges (up to 40 feet) without battery power. Active tags include battery for extended range and sensor capabilities.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitCostUsd rdf:type rdf:Property ;
    rdfs:label 'Unit Cost Usd' ;
    rdfs:comment 'The purchase cost of the individual RFID tag in USD. Used for asset valuation, inventory accounting, and cost-benefit analysis of RFID tracking programs. Passive UHF tags typically cost $0.10-$2.00; active tags cost $10-$50.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:writeProtectedFlag rdf:type rdf:Property ;
    rdfs:label 'Write Protected Flag' ;
    rdfs:comment 'Indicates whether the RFID tag memory is write-protected (locked). True means the tag is read-only and cannot be reprogrammed. False means the tag can be rewritten. Write protection prevents accidental or malicious data modification.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:adjustmentId rdf:type rdf:Property ;
    rdfs:label 'Adjustment Id' ;
    rdfs:comment 'Unique identifier for the billing adjustment record. Primary key.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Adjustment .

ind:adjustmentCreatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Adjustment Created By User Employee Id' ;
    rdfs:comment 'Reference to the user who initiated the adjustment. Supports audit trail and accountability requirements.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:adjustmentEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Adjustment Employee Id' ;
    rdfs:comment 'Reference to the employee or manager who approved the adjustment. Required for adjustments exceeding automated approval thresholds. Supports SOX audit trail requirements.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:arAccountId rdf:type rdf:Property ;
    rdfs:label 'Ar Account Id' ;
    rdfs:comment 'Foreign key linking to billing.ar_account. Business justification: Adjustments (credits, debits, write-offs) directly impact AR account balances. While adjustment.invoice_id and adjustment.billing_account_id exist, a direct FK to ar_account is essential for AR sub-le' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ArAccount .

ind:billingAccountId rdf:type rdf:Property ;
    rdfs:label 'Billing Account Id' ;
    rdfs:comment 'Reference to the customer account receiving the adjustment. Links to the billing account impacted by this adjustment.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BillingAccount .

ind:contaminationEventId rdf:type rdf:Property ;
    rdfs:label 'Contamination Event Id' ;
    rdfs:comment 'Foreign key linking to recycling.contamination_event. Business justification: Contamination events trigger billing adjustments (surcharges when contamination exceeds contract thresholds, or credits for processing issues). Real-world process requires linking adjustments to conta' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContaminationEvent .

ind:contractId rdf:type rdf:Property ;
    rdfs:label 'Contract Id' ;
    rdfs:comment 'Foreign key linking to contract.contract. Business justification: Billing adjustments stem from contract disputes, SLA breaches, or rate corrections. Audit trail requires linking adjustment back to governing agreement for regulatory compliance, revenue recognition c' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contract .

ind:disputeId rdf:type rdf:Property ;
    rdfs:label 'Dispute Id' ;
    rdfs:comment 'Reference to the billing dispute case that triggered this adjustment. Links adjustments to customer dispute resolution workflows.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Dispute .

ind:ghgEmissionId rdf:type rdf:Property ;
    rdfs:label 'Ghg Emission Id' ;
    rdfs:comment 'Foreign key linking to sustainability.ghg_emission. Business justification: Credit memos for service failures require corresponding emission allocation adjustments for accurate carbon accounting. Links billing adjustments to emission records, ensuring regulatory reporting acc' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GhgEmission .

ind:incidentId rdf:type rdf:Property ;
    rdfs:label 'Incident Id' ;
    rdfs:comment 'Foreign key linking to safety.incident. Business justification: Safety incidents frequently trigger billing adjustments for service interruptions, equipment damage, liability claims, or route delays. Waste Management operations require tracking which adjustments s' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Incident .

ind:invoiceId rdf:type rdf:Property ;
    rdfs:label 'Invoice Id' ;
    rdfs:comment 'Reference to the original invoice being adjusted. Links to the invoice that this adjustment modifies or corrects.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:offeringId rdf:type rdf:Property ;
    rdfs:label 'Offering Id' ;
    rdfs:comment 'Foreign key linking to service.offering. Business justification: Service-related adjustments (missed pickup credits, contamination charges, SLA breach credits) must reference the offering to categorize revenue impact, track service quality costs, and analyze adjust' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Offering .

ind:reversedAdjustmentId rdf:type rdf:Property ;
    rdfs:label 'Reversed Adjustment Id' ;
    rdfs:comment 'Reference to the original adjustment being reversed by this adjustment. Maintains bidirectional linkage for audit trail and correction tracking.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Adjustment .

ind:serviceExceptionId rdf:type rdf:Property ;
    rdfs:label 'Service Exception Id' ;
    rdfs:comment 'Foreign key linking to collection.service_exception. Business justification: Billing adjustments for missed pickups, contamination, access issues, or service failures require linking to the documented service exception with root cause and resolution notes.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceException .

ind:serviceRequestId rdf:type rdf:Property ;
    rdfs:label 'Service Request Id' ;
    rdfs:comment 'Foreign key linking to customer.service_request. Business justification: Credits and adjustments frequently originate from service requests (missed pickups, service failures, complaint resolutions). Tracking this relationship enables root cause analysis of revenue leakage,' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceRequest .

ind:violationNoticeId rdf:type rdf:Property ;
    rdfs:label 'Violation Notice Id' ;
    rdfs:comment 'Foreign key linking to compliance.violation_notice. Business justification: Billing adjustments frequently result from violation notices: credits for service interruptions due to compliance shutdowns, charge corrections for non-permitted waste acceptance, or penalty-related b' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ViolationNotice .

ind:adjustmentNumber rdf:type rdf:Property ;
    rdfs:label 'Adjustment Number' ;
    rdfs:comment 'Externally visible unique business identifier for the adjustment. Used for customer communication, dispute tracking, and audit trails.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentStatus rdf:type rdf:Property ;
    rdfs:label 'Adjustment Status' ;
    rdfs:comment 'Current lifecycle state of the adjustment in the approval and posting workflow. Determines whether the adjustment has impacted financial statements and customer balances. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|rejected|posted|reversed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentType rdf:type rdf:Property ;
    rdfs:label 'Adjustment Type' ;
    rdfs:comment 'Classification of the adjustment indicating the nature of the correction or modification. Determines accounting treatment and approval workflow requirements. [ENUM-REF-CANDIDATE: credit_memo|debit_memo|service_credit|write_off|bad_debt|rate_correction|small_balance_write_off|promotional_discount|dispute_settlement|billing_error_correction — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amount rdf:type rdf:Property ;
    rdfs:label 'Amount' ;
    rdfs:comment 'Monetary value of the adjustment. Positive values represent debits (charges to customer), negative values represent credits (refunds or reductions). Expressed in the account\'s billing currency.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approval Timestamp' ;
    rdfs:comment 'Date and time when the adjustment was approved by authorized personnel. Critical for SOX compliance and audit trail documentation.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:badDebtFlag rdf:type rdf:Property ;
    rdfs:label 'Bad Debt Flag' ;
    rdfs:comment 'Indicates whether this adjustment represents a bad debt write-off or uncollectible balance. Used for bad debt reserve calculations per ASC 326 Current Expected Credit Loss (CECL) standard.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:correctedChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Corrected Charge Amount' ;
    rdfs:comment 'Corrected invoice line item amount after adjustment. Used for billing error analysis and process improvement initiatives.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Date' ;
    rdfs:comment 'Date on which the customer was notified of the adjustment. Tracks communication timeliness and customer service performance.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customerNotificationFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Flag' ;
    rdfs:comment 'Indicates whether the customer has been notified of this adjustment. Supports customer communication tracking and service quality management.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:effectiveDate rdf:type rdf:Property ;
    rdfs:label 'Effective Date' ;
    rdfs:comment 'Business date on which the adjustment becomes effective for revenue recognition and customer billing purposes. May differ from posting date for backdated corrections.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:externalReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'External Reference Number' ;
    rdfs:comment 'External reference identifier from the source system or third-party system. Supports cross-system reconciliation and audit trail linkage.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Original Charge Amount' ;
    rdfs:comment 'Original invoice line item amount before adjustment. Provides context for variance analysis and billing accuracy metrics.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Posted Timestamp' ;
    rdfs:comment 'Date and time when the adjustment was posted to the general ledger and customer account balance. Marks the point at which the adjustment impacts financial statements.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recoveryAmount rdf:type rdf:Property ;
    rdfs:label 'Recovery Amount' ;
    rdfs:comment 'Amount recovered from a previously written-off balance. Tracks bad debt recoveries for financial reporting and collections performance metrics.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recoveryDate rdf:type rdf:Property ;
    rdfs:label 'Recovery Date' ;
    rdfs:comment 'Date on which a previously written-off amount was recovered. Used for bad debt recovery reporting and collections analytics.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recoveryEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Recovery Eligible Flag' ;
    rdfs:comment 'Indicates whether a written-off balance is eligible for future recovery attempts. Used by collections teams to prioritize recovery efforts.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revenueImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Revenue Impact Amount' ;
    rdfs:comment 'Amount by which this adjustment impacts recognized revenue in the current accounting period. Used for revenue recognition reporting per ASC 606 and IFRS 15.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reversalFlag rdf:type rdf:Property ;
    rdfs:label 'Reversal Flag' ;
    rdfs:comment 'Indicates whether this adjustment reverses a previous adjustment. Used to track adjustment corrections and maintain audit trail integrity.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:servicePeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Service Period End Date' ;
    rdfs:comment 'End date of the service period to which this adjustment applies. Supports revenue recognition and period-specific billing corrections.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:servicePeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Service Period Start Date' ;
    rdfs:comment 'Start date of the service period to which this adjustment applies. Used for revenue recognition timing and period-specific adjustments.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:writeOffFlag rdf:type rdf:Property ;
    rdfs:label 'Write Off Flag' ;
    rdfs:comment 'Indicates whether this adjustment represents a write-off of an uncollectible or immaterial balance. Supports accounts receivable aging and collections management.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentPlanId rdf:type rdf:Property ;
    rdfs:label 'Payment Plan Id' ;
    rdfs:comment 'Reference to the active payment plan agreement if the customer is on a payment plan. Null if no payment plan exists.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentPlan .

ind:accountClosedDate rdf:type rdf:Property ;
    rdfs:label 'Account Closed Date' ;
    rdfs:comment 'Date when the AR account was closed or terminated. Null for active accounts. Used for churn analysis and account lifecycle tracking.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accountOpenedDate rdf:type rdf:Property ;
    rdfs:label 'Account Opened Date' ;
    rdfs:comment 'Date when the AR account was first established for the customer. Used to calculate customer tenure and lifetime value.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accountStatus rdf:type rdf:Property ;
    rdfs:label 'Account Status' ;
    rdfs:comment 'Current lifecycle status of the AR account. Active accounts are in good standing; suspended accounts have service holds; closed accounts are no longer active; write-off accounts have been deemed uncollectible; bankruptcy accounts are in legal proceedings.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agingBucket030Days rdf:type rdf:Property ;
    rdfs:label 'Aging Bucket 0 30 Days' ;
    rdfs:comment 'Outstanding balance for invoices aged 0 to 30 days past due date. Current receivables within normal payment terms. Expressed in USD.' ;
    rdfs:domain ind:ArAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:agingBucket3160Days rdf:type rdf:Property ;
    rdfs:label 'Aging Bucket 31 60 Days' ;
    rdfs:comment 'Outstanding balance for invoices aged 31 to 60 days past due date. Moderately overdue receivables requiring follow-up. Expressed in USD.' ;
    rdfs:domain ind:ArAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:agingBucket6190Days rdf:type rdf:Property ;
    rdfs:label 'Aging Bucket 61 90 Days' ;
    rdfs:comment 'Outstanding balance for invoices aged 61 to 90 days past due date. Significantly overdue receivables requiring escalated collection efforts. Expressed in USD.' ;
    rdfs:domain ind:ArAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:agingBucketOver90Days rdf:type rdf:Property ;
    rdfs:label 'Aging Bucket Over 90 Days' ;
    rdfs:comment 'Outstanding balance for invoices aged more than 90 days past due date. Severely overdue receivables at high risk of uncollectibility, may require legal action or write-off consideration. Expressed in USD.' ;
    rdfs:domain ind:ArAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:arAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Ar Account Number' ;
    rdfs:comment 'Business identifier for the AR account, typically the customer account number used in billing and collections. May align with SAP FI AR account number or Oracle Revenue Management customer account number.' ;
    rdfs:domain ind:ArAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoPayEnrolledFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Pay Enrolled Flag' ;
    rdfs:comment 'Indicates whether the customer is enrolled in automatic payment processing. True means payments are automatically processed on due date; false means manual payment required.' ;
    rdfs:domain ind:ArAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:availableCredit rdf:type rdf:Property ;
    rdfs:label 'Available Credit' ;
    rdfs:comment 'Remaining credit available to the customer, calculated as credit limit minus current balance. Expressed in USD.' ;
    rdfs:domain ind:ArAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:badDebtReserve rdf:type rdf:Property ;
    rdfs:label 'Bad Debt Reserve' ;
    rdfs:comment 'Amount reserved for potential uncollectible receivables based on aging analysis and credit risk assessment. Used for allowance for doubtful accounts calculation. Expressed in USD.' ;
    rdfs:domain ind:ArAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingCurrency rdf:type rdf:Property ;
    rdfs:label 'Billing Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for invoicing and payments. Typically USD for US operations but may vary for international customers.' ;
    rdfs:domain ind:ArAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCycle rdf:type rdf:Property ;
    rdfs:label 'Billing Cycle' ;
    rdfs:comment 'Frequency at which the customer is billed for services. Monthly is standard residential; quarterly/annual are common for commercial; on-demand is for transactional services; custom is negotiated frequency.' ;
    rdfs:domain ind:ArAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionStatus rdf:type rdf:Property ;
    rdfs:label 'Collection Status' ;
    rdfs:comment 'Current stage in the collections process. Current indicates no collection activity; reminder/notices indicate escalating communication; collections-agency indicates third-party involvement; legal-action indicates court proceedings; payment-plan indicates negotiated repayment; settled indicates resolved. [ENUM-REF-CANDIDATE: current|reminder_sent|first_notice|second_notice|final_notice|collections_agency|legal_action|payment_plan|settled — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ArAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Credit Hold Flag' ;
    rdfs:comment 'Indicates whether the account is on credit hold. True means services are suspended due to credit issues; false means account is in good standing.' ;
    rdfs:domain ind:ArAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditHoldReason rdf:type rdf:Property ;
    rdfs:label 'Credit Hold Reason' ;
    rdfs:comment 'Reason code for why the account is on credit hold. Over-limit indicates balance exceeds credit limit; past-due indicates overdue invoices; bankruptcy indicates legal proceedings; fraud indicates suspected fraudulent activity; dispute indicates billing dispute; manual-hold indicates administrative hold; none indicates no hold. [ENUM-REF-CANDIDATE: over_limit|past_due|bankruptcy|fraud|dispute|manual_hold|none — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ArAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimit rdf:type rdf:Property ;
    rdfs:label 'Credit Limit' ;
    rdfs:comment 'Maximum amount of credit extended to the customer. Services may be suspended if current balance exceeds this limit. Expressed in USD.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditStatus rdf:type rdf:Property ;
    rdfs:label 'Credit Status' ;
    rdfs:comment 'Current credit standing of the account. Approved accounts can receive services; on-hold accounts have credit restrictions; under-review accounts are being evaluated; restricted accounts have limited credit; revoked accounts have no credit privileges.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentBalance rdf:type rdf:Property ;
    rdfs:label 'Current Balance' ;
    rdfs:comment 'Total outstanding balance owed by the customer across all invoices. Represents the sum of all unpaid charges, fees, and adjustments. Expressed in USD.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daysSalesOutstanding rdf:type rdf:Property ;
    rdfs:label 'Days Sales Outstanding' ;
    rdfs:comment 'Average number of days it takes the customer to pay invoices. Key metric for assessing payment behavior and credit risk. Calculated as (current balance / average daily sales).' ;
    rdfs:domain ind:ArAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:disputeFlag rdf:type rdf:Property ;
    rdfs:label 'Dispute Flag' ;
    rdfs:comment 'Indicates whether there are active billing disputes on the account. True means one or more invoices are disputed; false means no disputes.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disputedAmount rdf:type rdf:Property ;
    rdfs:label 'Disputed Amount' ;
    rdfs:comment 'Total amount of charges currently under dispute by the customer. Expressed in USD.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dunningLevel rdf:type rdf:Property ;
    rdfs:label 'Dunning Level' ;
    rdfs:comment 'Current collection escalation level for overdue accounts. 0 indicates no dunning; 1-3 indicate progressive collection notice levels; higher numbers indicate more aggressive collection actions including legal proceedings.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastInvoiceAmount rdf:type rdf:Property ;
    rdfs:label 'Last Invoice Amount' ;
    rdfs:comment 'Amount of the most recent invoice issued to the customer. Expressed in USD.' ;
    rdfs:domain ind:ArAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastInvoiceDate rdf:type rdf:Property ;
    rdfs:label 'Last Invoice Date' ;
    rdfs:comment 'Date of the most recent invoice issued to the customer. Used to track billing activity and calculate days since last invoice.' ;
    rdfs:domain ind:ArAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Last Payment Amount' ;
    rdfs:comment 'Amount of the most recent payment received from the customer. Expressed in USD.' ;
    rdfs:domain ind:ArAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Last Payment Date' ;
    rdfs:comment 'Date of the most recent payment received from the customer. Used to track payment history and calculate days since last payment.' ;
    rdfs:domain ind:ArAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paperlessBillingFlag rdf:type rdf:Property ;
    rdfs:label 'Paperless Billing Flag' ;
    rdfs:comment 'Indicates whether the customer has opted for electronic invoicing instead of paper statements. True means electronic delivery only; false means paper statements are sent.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentMethod rdf:type rdf:Property ;
    rdfs:label 'Payment Method' ;
    rdfs:comment 'Primary payment method used by the customer. ACH is Automated Clearing House electronic transfer; credit-card is card payment; check is paper check; wire-transfer is bank wire; cash is physical currency; auto-pay is automatic recurring payment; other is alternative methods. [ENUM-REF-CANDIDATE: ach|credit_card|check|wire_transfer|cash|auto_pay|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentPlanFlag rdf:type rdf:Property ;
    rdfs:label 'Payment Plan Flag' ;
    rdfs:comment 'Indicates whether the customer is on a negotiated payment plan for overdue balances. True means payment plan is active; false means no payment plan.' ;
    rdfs:domain ind:ArAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentTerms rdf:type rdf:Property ;
    rdfs:label 'Payment Terms' ;
    rdfs:comment 'Standard payment terms for this AR account. Net-15/30/45/60 indicates number of days from invoice date; due-on-receipt requires immediate payment; prepaid requires payment before service; custom indicates negotiated terms. [ENUM-REF-CANDIDATE: net_15|net_30|net_45|net_60|due_on_receipt|prepaid|custom — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapFiArAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Fi Ar Account Number' ;
    rdfs:comment 'The SAP FI customer account number in the accounts receivable sub-ledger. Used for integration and reconciliation with the SAP S/4HANA FI module.' ;
    rdfs:domain ind:ArAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExemptCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Exempt Certificate Number' ;
    rdfs:comment 'Government-issued tax exemption certificate number for tax-exempt customers. Required for audit compliance when tax-exempt flag is true.' ;
    rdfs:domain ind:ArAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExemptFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Exempt Flag' ;
    rdfs:comment 'Indicates whether the customer is exempt from sales tax on waste management services. True means tax-exempt status verified; false means standard tax applies.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalAdjustmentsYtd rdf:type rdf:Property ;
    rdfs:label 'Total Adjustments Ytd' ;
    rdfs:comment 'Total amount of billing adjustments (credits, write-offs, discounts) applied to the customer account in the current fiscal year. Expressed in USD.' ;
    rdfs:domain ind:ArAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalInvoicedYtd rdf:type rdf:Property ;
    rdfs:label 'Total Invoiced Ytd' ;
    rdfs:comment 'Total amount invoiced to the customer in the current fiscal year. Used for revenue analysis and customer value assessment. Expressed in USD.' ;
    rdfs:domain ind:ArAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPaymentsYtd rdf:type rdf:Property ;
    rdfs:label 'Total Payments Ytd' ;
    rdfs:comment 'Total amount of payments received from the customer in the current fiscal year. Used for cash flow analysis and payment behavior assessment. Expressed in USD.' ;
    rdfs:domain ind:ArAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:writeOffAmountYtd rdf:type rdf:Property ;
    rdfs:label 'Write Off Amount Ytd' ;
    rdfs:comment 'Total amount of receivables written off as uncollectible in the current fiscal year. Used for bad debt expense tracking and financial reporting. Expressed in USD.' ;
    rdfs:domain ind:ArAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:areaId rdf:type rdf:Property ;
    rdfs:label 'Area Id' ;
    rdfs:comment 'Foreign key linking to service.service_area. Business justification: Billing accounts are domiciled in service areas for franchise compliance, tax jurisdiction determination, service territory management, and regulatory reporting. Essential for municipal contract compl' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Area .

ind:cycleId rdf:type rdf:Property ;
    rdfs:label 'Cycle Id' ;
    rdfs:comment 'FK to billing.billing_cycle' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Cycle .

ind:accountName rdf:type rdf:Property ;
    rdfs:label 'Account Name' ;
    rdfs:comment 'Descriptive name for the billing account, often matching the customer legal name or a business unit designation.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountNumber rdf:type rdf:Property ;
    rdfs:label 'Account Number' ;
    rdfs:comment 'Human-readable billing account number displayed on invoices and customer communications. Externally visible identifier.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountType rdf:type rdf:Property ;
    rdfs:label 'Account Type' ;
    rdfs:comment 'Classification of the billing account based on customer segment and service model.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autopayEnrolledFlag rdf:type rdf:Property ;
    rdfs:label 'Autopay Enrolled Flag' ;
    rdfs:comment 'Indicates whether the account is enrolled in automatic payment processing on invoice due date.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:autopayEnrollmentDate rdf:type rdf:Property ;
    rdfs:label 'Autopay Enrollment Date' ;
    rdfs:comment 'Date when the customer enrolled in automatic payment processing.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Billing Address Line1' ;
    rdfs:comment 'Primary street address line for billing correspondence and invoice delivery.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Billing Address Line2' ;
    rdfs:comment 'Secondary address line for suite, apartment, or unit number for billing correspondence.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCity rdf:type rdf:Property ;
    rdfs:label 'Billing City' ;
    rdfs:comment 'City name for the billing address.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingContactEmail rdf:type rdf:Property ;
    rdfs:label 'Billing Contact Email' ;
    rdfs:comment 'Primary email address for billing contact to receive invoices and payment notifications.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingContactName rdf:type rdf:Property ;
    rdfs:label 'Billing Contact Name' ;
    rdfs:comment 'Full name of the primary billing contact person responsible for invoice receipt and payment coordination.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingContactPhone rdf:type rdf:Property ;
    rdfs:label 'Billing Contact Phone' ;
    rdfs:comment 'Primary phone number for billing contact for payment inquiries and dispute resolution.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Billing Country Code' ;
    rdfs:comment 'Three-letter ISO country code for the billing address.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingPostalCode rdf:type rdf:Property ;
    rdfs:label 'Billing Postal Code' ;
    rdfs:comment 'ZIP or postal code for the billing address.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingStateProvince rdf:type rdf:Property ;
    rdfs:label 'Billing State Province' ;
    rdfs:comment 'Two-letter state or province code for the billing address.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessUnitCode rdf:type rdf:Property ;
    rdfs:label 'Business Unit Code' ;
    rdfs:comment 'Business unit or division code for organizational hierarchy and reporting segmentation.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closeDate rdf:type rdf:Property ;
    rdfs:label 'Close Date' ;
    rdfs:comment 'Date when the billing account was closed and billing operations ceased.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:closeReasonCode rdf:type rdf:Property ;
    rdfs:label 'Close Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for account closure (e.g., customer request, non-payment, service termination).' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Amount' ;
    rdfs:comment 'Maximum outstanding balance allowed for the account before service suspension or payment requirement.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditRating rdf:type rdf:Property ;
    rdfs:label 'Credit Rating' ;
    rdfs:comment 'Internal or external credit assessment classification used for credit limit determination and collections risk management.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastDunningDate rdf:type rdf:Property ;
    rdfs:label 'Last Dunning Date' ;
    rdfs:comment 'Most recent date when a dunning notice or collection communication was sent to the customer.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:openDate rdf:type rdf:Property ;
    rdfs:label 'Open Date' ;
    rdfs:comment 'Date when the billing account was first established and activated for billing operations.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:oracleAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Oracle Account Number' ;
    rdfs:comment 'External account identifier in Oracle Revenue Management system used for billing and invoicing integration.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paperlessEnrollmentDate rdf:type rdf:Property ;
    rdfs:label 'Paperless Enrollment Date' ;
    rdfs:comment 'Date when the customer enrolled in paperless billing.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentTermsDays rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Days' ;
    rdfs:comment 'Number of days from invoice date until payment is due, defining the standard payment window.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preferredPaymentMethod rdf:type rdf:Property ;
    rdfs:label 'Preferred Payment Method' ;
    rdfs:comment 'Default payment instrument type preferred by the customer for invoice settlement.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterCode rdf:type rdf:Property ;
    rdfs:label 'Profit Center Code' ;
    rdfs:comment 'Profit center code for segment reporting and business unit performance tracking.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExemptionCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Exemption Certificate Number' ;
    rdfs:comment 'Government-issued certificate number validating the tax-exempt status of the account.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExemptionExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Tax Exemption Expiration Date' ;
    rdfs:comment 'Date when the tax exemption certificate expires and requires renewal.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cycleEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Cycle Employee Id' ;
    rdfs:comment 'User ID of the system user or administrator who created this billing cycle configuration. Audit trail for accountability and change tracking.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:cycleLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Cycle Last Modified By User Employee Id' ;
    rdfs:comment 'User ID of the system user or administrator who last modified this billing cycle configuration. Audit trail for change accountability.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:dunningSequenceId rdf:type rdf:Property ;
    rdfs:label 'Dunning Sequence Id' ;
    rdfs:comment 'Reference to the dunning sequence configuration that defines the escalation schedule and actions for overdue accounts in this billing cycle (e.g., reminder at 5 days, notice at 15 days, suspension at 30 days).' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DunningSequence .

ind:advanceBillingEnabled rdf:type rdf:Property ;
    rdfs:label 'Advance Billing Enabled' ;
    rdfs:comment 'Indicates whether invoices are generated in advance of the service period (prepaid model) or after service delivery (arrears model). True for advance billing (invoice before service), False for arrears billing (invoice after service).' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:arAgingBucketDays rdf:type rdf:Property ;
    rdfs:label 'Ar Aging Bucket Days' ;
    rdfs:comment 'Comma-separated list of day thresholds for AR aging bucket calculations (e.g., 30,60,90,120 for standard 30-day buckets). Used to categorize outstanding receivables by age for collections prioritization and financial reporting.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoRenewalEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Enabled' ;
    rdfs:comment 'Indicates whether accounts in this billing cycle automatically renew at the end of each period without requiring manual intervention. True for ongoing subscription services, False for term-limited contracts requiring explicit renewal.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:billingModel rdf:type rdf:Property ;
    rdfs:label 'Billing Model' ;
    rdfs:comment 'Revenue model applied in this billing cycle. Subscription for fixed recurring fees (monthly container rental), transactional for per-event charges (per-haul roll-off), usage-based for metered consumption (tonnage-based tipping fees), hybrid for combination of fixed and variable charges.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingPeriodDay rdf:type rdf:Property ;
    rdfs:label 'Billing Period Day' ;
    rdfs:comment 'Day of the month when the billing period closes and invoices are generated (1-31). For monthly cycles, this is the cutoff day. For bi-monthly or quarterly, this represents the anchor day.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:consolidationLevel rdf:type rdf:Property ;
    rdfs:label 'Consolidation Level' ;
    rdfs:comment 'Defines how invoices are consolidated for multi-site or hierarchical accounts. Account-level generates one invoice per account, site-level generates separate invoices per service location, parent-account rolls up all child accounts, consolidated combines all services into single invoice.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerSegment rdf:type rdf:Property ;
    rdfs:label 'Customer Segment' ;
    rdfs:comment 'Primary customer segment this billing cycle serves. Residential for household waste collection, commercial for business accounts, industrial for manufacturing facilities, municipal for government contracts, roll-off for temporary container services, special-waste for hazardous or regulated waste handling.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleCode rdf:type rdf:Property ;
    rdfs:label 'Cycle Code' ;
    rdfs:comment 'Short alphanumeric code identifying the billing cycle (e.g., MC01 for Monthly Cycle 01, BC15 for Bi-Monthly Cycle 15). Used as business identifier in Oracle Revenue Management.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleDescription rdf:type rdf:Property ;
    rdfs:label 'Cycle Description' ;
    rdfs:comment 'Detailed description of the billing cycle purpose, scope, and applicable customer segments.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleName rdf:type rdf:Property ;
    rdfs:label 'Cycle Name' ;
    rdfs:comment 'Descriptive name of the billing cycle for business user identification (e.g., Monthly Residential East, Quarterly Commercial West).' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleStatus rdf:type rdf:Property ;
    rdfs:label 'Cycle Status' ;
    rdfs:comment 'Current operational status of the billing cycle. Active for cycles currently in use, inactive for cycles not yet activated, suspended for temporarily disabled cycles, archived for historical cycles no longer in use but retained for audit purposes.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountEligibilityEnabled rdf:type rdf:Property ;
    rdfs:label 'Discount Eligibility Enabled' ;
    rdfs:comment 'Indicates whether accounts in this billing cycle are eligible for early payment discounts, volume discounts, or promotional pricing. True enables discount application rules, False excludes cycle from discount programs.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dunningProcessEnabled rdf:type rdf:Property ;
    rdfs:label 'Dunning Process Enabled' ;
    rdfs:comment 'Indicates whether automated dunning (collections reminder) process is enabled for overdue accounts in this billing cycle. True triggers escalating reminder notices and collection actions, False requires manual collections management.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:earlyPaymentDiscountDays rdf:type rdf:Property ;
    rdfs:label 'Early Payment Discount Days' ;
    rdfs:comment 'Number of days from invoice date within which payment must be received to qualify for early payment discount. Typically 10 days for 2/10 net-30 terms.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:earlyPaymentDiscountPercentage rdf:type rdf:Property ;
    rdfs:label 'Early Payment Discount Percentage' ;
    rdfs:comment 'Percentage discount offered for payment within specified early payment window (e.g., 2% discount if paid within 10 days). Common for commercial accounts to incentivize faster payment and improve cash flow.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:frequency rdf:type rdf:Property ;
    rdfs:label 'Frequency' ;
    rdfs:comment 'Recurrence pattern for invoice generation. Monthly for standard residential/commercial, bi-monthly for certain municipal contracts, quarterly for large commercial accounts, annual for prepaid contracts, per-haul for roll-off containers, on-demand for special services.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glArAccountCode rdf:type rdf:Property ;
    rdfs:label 'Gl Ar Account Code' ;
    rdfs:comment 'Default GL account code for posting accounts receivable from invoices in this billing cycle. Maps to SAP FI/CO chart of accounts for balance sheet reporting.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glRevenueAccountCode rdf:type rdf:Property ;
    rdfs:label 'Gl Revenue Account Code' ;
    rdfs:comment 'Default GL account code for posting revenue from invoices in this billing cycle. Maps to SAP FI/CO chart of accounts for financial reporting and revenue recognition.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gracePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Grace Period Days' ;
    rdfs:comment 'Number of days after payment due date before late fees are assessed or collection actions begin. Typically 5-10 days to accommodate payment processing delays.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:invoiceDeliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Invoice Delivery Method' ;
    rdfs:comment 'Primary method for delivering invoices to customers in this billing cycle. Email for electronic delivery, postal-mail for paper invoices, portal for customer self-service access, EDI for electronic data interchange with large commercial accounts, both for dual delivery.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceGenerationDate rdf:type rdf:Property ;
    rdfs:label 'Invoice Generation Date' ;
    rdfs:comment 'The date when invoices for this billing cycle are generated and made available to customers. Typically 1-3 days after billing period closes.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lateFeeFlatAmount rdf:type rdf:Property ;
    rdfs:label 'Late Fee Flat Amount' ;
    rdfs:comment 'Fixed dollar amount charged as late fee regardless of balance, used as alternative or supplement to percentage-based late fees. Common for residential accounts ($5-$25 flat fee).' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lateFeePercentage rdf:type rdf:Property ;
    rdfs:label 'Late Fee Percentage' ;
    rdfs:comment 'Percentage of outstanding balance charged as late fee when payment is overdue beyond grace period. Typically 1.5% to 3% per month, subject to state usury laws.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lateFeeTriggerEnabled rdf:type rdf:Property ;
    rdfs:label 'Late Fee Trigger Enabled' ;
    rdfs:comment 'Indicates whether late fees are automatically triggered for overdue invoices in this billing cycle. True enables automatic late fee assessment, False requires manual review.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentDueDateOffsetDays rdf:type rdf:Property ;
    rdfs:label 'Payment Due Date Offset Days' ;
    rdfs:comment 'Number of days after invoice generation date when payment is due. Typically 15, 30, or 45 days representing net-15, net-30, or net-45 payment terms.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:prorationEnabled rdf:type rdf:Property ;
    rdfs:label 'Proration Enabled' ;
    rdfs:comment 'Indicates whether charges are prorated for partial billing periods when accounts are activated or terminated mid-cycle. True enables daily proration calculations, False bills full period regardless of start/end dates.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revenueRecognitionMethod rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Method' ;
    rdfs:comment 'Accounting method for recognizing revenue from invoices in this billing cycle per GAAP/IFRS standards. Point-in-time for transactional services (per-haul), over-time for subscription services (monthly collection), milestone-based for project-based contracts.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceType rdf:type rdf:Property ;
    rdfs:label 'Service Type' ;
    rdfs:comment 'Primary service type billed under this cycle. Collection for regular pickup services, disposal for landfill tipping fees, recycling for material recovery facility processing, hauling for transportation services, rental for container/equipment rental, processing for waste-to-energy or treatment services.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statementGenerationEnabled rdf:type rdf:Property ;
    rdfs:label 'Statement Generation Enabled' ;
    rdfs:comment 'Indicates whether monthly account statements are generated in addition to individual invoices. True for accounts requiring consolidated statements showing all activity, False for invoice-only delivery.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Tax Calculation Method' ;
    rdfs:comment 'Method for calculating sales tax or VAT on invoices in this billing cycle. Standard applies jurisdiction-based tax rates, exempt for tax-exempt customers (municipalities, non-profits), reverse-charge for certain B2B transactions, mixed for accounts with both taxable and exempt services.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:writeOffThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Write Off Threshold Amount' ;
    rdfs:comment 'Maximum dollar amount that can be written off as bad debt without requiring executive approval. Balances below this threshold can be written off by collections team, amounts above require CFO or controller authorization per SOX controls.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingRateScheduleId rdf:type rdf:Property ;
    rdfs:label 'Billing Rate Schedule Id' ;
    rdfs:comment 'Unique identifier for the billing rate schedule. Primary key.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BillingRateSchedule .

ind:baseRateAmount rdf:type rdf:Property ;
    rdfs:label 'Base Rate Amount' ;
    rdfs:comment 'Primary charge amount for the service before surcharges, fees, or adjustments. Unit of measure depends on billing model.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:containerRentalFee rdf:type rdf:Property ;
    rdfs:label 'Container Rental Fee' ;
    rdfs:comment 'Monthly or periodic charge for rental of waste containers, dumpsters, or roll-off boxes. Separate from service pickup charges.' ;
    rdfs:domain ind:BillingRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractType rdf:type rdf:Property ;
    rdfs:label 'Contract Type' ;
    rdfs:comment 'Classification of contract or agreement type that this rate schedule supports. Determines pricing flexibility and approval requirements.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalSurcharge rdf:type rdf:Property ;
    rdfs:label 'Disposal Surcharge' ;
    rdfs:comment 'Additional charge applied for disposal at landfill or processing facility. May vary by waste type or facility capacity.' ;
    rdfs:domain ind:BillingRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalFee rdf:type rdf:Property ;
    rdfs:label 'Environmental Fee' ;
    rdfs:comment 'Regulatory or operational fee charged to cover environmental compliance, remediation, or sustainability program costs.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelSurchargeRate rdf:type rdf:Property ;
    rdfs:label 'Fuel Surcharge Rate' ;
    rdfs:comment 'Percentage or fixed amount added to base rate to recover fuel costs. May be indexed to diesel fuel price benchmarks.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geographicZone rdf:type rdf:Property ;
    rdfs:label 'Geographic Zone' ;
    rdfs:comment 'Geographic service area or zone identifier where this rate schedule is applicable. May reference district, county, or custom service territory.' ;
    rdfs:domain ind:BillingRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glCostCenter rdf:type rdf:Property ;
    rdfs:label 'Gl Cost Center' ;
    rdfs:comment 'Cost center code for internal cost allocation and profitability analysis. Used for transfer pricing and divisional reporting.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glRevenueAccount rdf:type rdf:Property ;
    rdfs:label 'Gl Revenue Account' ;
    rdfs:comment 'General ledger account code where revenue from this rate schedule is recognized. Supports financial reporting and SOX compliance.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indexationFormula rdf:type rdf:Property ;
    rdfs:label 'Indexation Formula' ;
    rdfs:comment 'Formula or reference index used for automatic rate adjustments. May reference CPI, fuel price index, or commodity pricing.' ;
    rdfs:domain ind:BillingRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumCharge rdf:type rdf:Property ;
    rdfs:label 'Maximum Charge' ;
    rdfs:comment 'Ceiling amount for billing to cap customer exposure. Null indicates no maximum limit.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumCharge rdf:type rdf:Property ;
    rdfs:label 'Minimum Charge' ;
    rdfs:comment 'Floor amount for billing regardless of usage or quantity. Ensures minimum revenue per transaction or billing period.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overageRate rdf:type rdf:Property ;
    rdfs:label 'Overage Rate' ;
    rdfs:comment 'Rate charged for usage exceeding contracted or included quantities. Applies to weight, volume, or pickup frequency overages.' ;
    rdfs:domain ind:BillingRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricingTier rdf:type rdf:Property ;
    rdfs:label 'Pricing Tier' ;
    rdfs:comment 'Tiered pricing level or bracket identifier for volume-based or loyalty-based rate differentiation.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Rate Calculation Method' ;
    rdfs:comment 'Methodology used to compute the final charge. Defines whether rate is static, variable, or formula-driven.' ;
    rdfs:domain ind:BillingRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Rate Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the base rate amount. Defines the quantity basis for billing calculations. [ENUM-REF-CANDIDATE: ton|cubic_yard|pickup|month|gallon|container|pound — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BillingRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleCode rdf:type rdf:Property ;
    rdfs:label 'Schedule Code' ;
    rdfs:comment 'Unique alphanumeric code used to reference this rate schedule in billing systems and customer contracts.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleName rdf:type rdf:Property ;
    rdfs:label 'Schedule Name' ;
    rdfs:comment 'Business name of the rate schedule for identification and reporting purposes.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runId rdf:type rdf:Property ;
    rdfs:label 'Run Id' ;
    rdfs:comment 'Unique identifier for the billing run batch execution. Primary key.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Run .

ind:runApprovedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Run Approved By User Employee Id' ;
    rdfs:comment 'Reference to the manager or supervisor who approved this billing run for invoice release. Null if approval not required or not yet approved.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:runEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Run Employee Id' ;
    rdfs:comment 'Reference to the system user or automated process that initiated the billing run. Used for audit trail and accountability.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accountsOnHold rdf:type rdf:Property ;
    rdfs:label 'Accounts On Hold' ;
    rdfs:comment 'Count of customer accounts excluded from billing due to hold status (e.g., payment dispute, account under review, service suspension).' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountsWithErrors rdf:type rdf:Property ;
    rdfs:label 'Accounts With Errors' ;
    rdfs:comment 'Count of customer accounts that encountered errors during billing run processing. Requires manual review and correction.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Approval Required Flag' ;
    rdfs:comment 'Indicates whether this billing run requires managerial approval before invoice release. True for correction and manual runs; false for scheduled runs.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:arPostingStatus rdf:type rdf:Property ;
    rdfs:label 'Ar Posting Status' ;
    rdfs:comment 'Status of the accounts receivable posting for this billing run. Pending indicates awaiting posting; posted indicates successfully recorded in AR; failed indicates posting error; reversed indicates posting was reversed due to correction.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Billing Period End Date' ;
    rdfs:comment 'Last date of the billing period covered by this run. Defines the inclusive end boundary for usage and service charges.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Billing Period Start Date' ;
    rdfs:comment 'First date of the billing period covered by this run. Defines the inclusive start boundary for usage and service charges.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:durationSeconds rdf:type rdf:Property ;
    rdfs:label 'Duration Seconds' ;
    rdfs:comment 'Total elapsed time in seconds from run start to run end. Used for performance analysis and capacity planning.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:errorLogSummary rdf:type rdf:Property ;
    rdfs:label 'Error Log Summary' ;
    rdfs:comment 'High-level summary of errors encountered during billing run execution. Detailed error records are stored in separate error log tables.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glBatchNumber rdf:type rdf:Property ;
    rdfs:label 'Gl Batch Number' ;
    rdfs:comment 'SAP FI/CO batch identifier for the general ledger posting of this billing run revenue. Used for financial reconciliation and audit trail.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Invoice Release Date' ;
    rdfs:comment 'Date when invoices from this billing run were released to customers. May differ from run completion date if approval or review was required.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalAccountsProcessed rdf:type rdf:Property ;
    rdfs:label 'Total Accounts Processed' ;
    rdfs:comment 'Count of distinct customer accounts included in this billing run. Used for reconciliation and completeness validation.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalAdjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Total Adjustment Amount' ;
    rdfs:comment 'Sum of all billing adjustments (credits, discounts, dispute resolutions) applied in this run, in USD. Negative values represent credits to customers.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalBilledAmount rdf:type rdf:Property ;
    rdfs:label 'Total Billed Amount' ;
    rdfs:comment 'Sum of all invoice amounts generated by this billing run, in USD. Represents gross revenue recognized for the billing period before payments and adjustments.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalInvoicesGenerated rdf:type rdf:Property ;
    rdfs:label 'Total Invoices Generated' ;
    rdfs:comment 'Count of invoices created by this billing run. May differ from accounts processed if some accounts have zero balance or are on hold.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalServiceChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Total Service Charge Amount' ;
    rdfs:comment 'Sum of all recurring service charges (container rentals, subscription fees) included in this run, in USD. Excludes usage-based charges and taxes.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Total Tax Amount' ;
    rdfs:comment 'Sum of all tax charges included in the invoices generated by this run, in USD. Includes sales tax, environmental fees, and regulatory surcharges.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalUsageChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Total Usage Charge Amount' ;
    rdfs:comment 'Sum of all usage-based charges (tonnage, pickups, tipping fees) included in this run, in USD. Excludes recurring service charges and taxes.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:zeroBalanceAccounts rdf:type rdf:Property ;
    rdfs:label 'Zero Balance Accounts' ;
    rdfs:comment 'Count of customer accounts processed that resulted in zero invoice amount due to no usage or offsetting credits.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:billingTippingFeeScheduleId rdf:type rdf:Property ;
    rdfs:label 'Billing Tipping Fee Schedule Id' ;
    rdfs:comment 'Unique identifier for the tipping fee schedule record. Primary key.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BillingTippingFeeSchedule .

ind:mrfFacilityId rdf:type rdf:Property ;
    rdfs:label 'Mrf Facility Id' ;
    rdfs:comment 'Foreign key linking to recycling.mrf_facility. Business justification: Tipping fee schedules are facility-specific, varying by MRF operational costs, market conditions, and capacity. Each facility maintains its own fee schedule. Core pricing configuration for MRF tipping' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MrfFacility .

ind:transferStationId rdf:type rdf:Property ;
    rdfs:label 'Transfer Station Id' ;
    rdfs:comment 'Foreign key linking to collection.transfer_station. Business justification: Tipping fee schedules are facility-specific; direct link enables rate lookup, contract enforcement, and automated billing for inbound loads at each transfer station.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TransferStation .

ind:wasteStreamId rdf:type rdf:Property ;
    rdfs:label 'Waste Stream Id' ;
    rdfs:comment 'Foreign key linking to service.service_waste_stream. Business justification: Tipping fees are priced by waste stream classification (MSW, C&D, hazardous, recyclables). Disposal facilities require this link for regulatory compliance, cost recovery calculations, and accurate inv' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WasteStream .

ind:customerTier rdf:type rdf:Property ;
    rdfs:label 'Customer Tier' ;
    rdfs:comment 'Customer segment or tier to which this tipping fee schedule applies, enabling tiered pricing strategies.' ;
    rdfs:domain ind:BillingTippingFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalSurcharge rdf:type rdf:Property ;
    rdfs:label 'Environmental Surcharge' ;
    rdfs:comment 'Additional regulatory or environmental surcharge per ton, covering compliance costs such as landfill gas monitoring, leachate treatment, or closure reserves.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feePerTon rdf:type rdf:Property ;
    rdfs:label 'Fee Per Ton' ;
    rdfs:comment 'Base tipping fee charged per ton of waste disposed. Primary pricing component for tonnage-based billing.' ;
    rdfs:domain ind:BillingTippingFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hostCommunityFee rdf:type rdf:Property ;
    rdfs:label 'Host Community Fee' ;
    rdfs:comment 'Fee per ton paid to the host municipality or community as part of landfill operating agreements.' ;
    rdfs:domain ind:BillingTippingFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:internalTransferPricingFlag rdf:type rdf:Property ;
    rdfs:label 'Internal Transfer Pricing Flag' ;
    rdfs:comment 'Indicates whether this schedule is used for internal transfer pricing between operational units (True) or external customer billing (False).' ;
    rdfs:domain ind:BillingTippingFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:localTaxRate rdf:type rdf:Property ;
    rdfs:label 'Local Tax Rate' ;
    rdfs:comment 'Local jurisdiction tax rate applied to tipping fees, expressed as a decimal.' ;
    rdfs:domain ind:BillingTippingFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumLoadFee rdf:type rdf:Property ;
    rdfs:label 'Minimum Load Fee' ;
    rdfs:comment 'Minimum charge applied per load regardless of tonnage, ensuring cost recovery for small loads.' ;
    rdfs:domain ind:BillingTippingFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricingModel rdf:type rdf:Property ;
    rdfs:label 'Pricing Model' ;
    rdfs:comment 'Pricing methodology applied by this schedule (flat rate per ton, tiered pricing based on volume thresholds, time-of-day pricing).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleStatus rdf:type rdf:Property ;
    rdfs:label 'Schedule Status' ;
    rdfs:comment 'Current lifecycle status of the tipping fee schedule. Controls whether the schedule is available for billing transactions.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateTaxRate rdf:type rdf:Property ;
    rdfs:label 'State Tax Rate' ;
    rdfs:comment 'State-level tax rate applied to tipping fees, expressed as a decimal (e.g., 0.0650 for 6.5%).' ;
    rdfs:domain ind:BillingTippingFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:collectionActionId rdf:type rdf:Property ;
    rdfs:label 'Collection Action Id' ;
    rdfs:comment 'Unique identifier for the collection action record. Primary key.' ;
    rdfs:domain ind:CollectionAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actionDate rdf:type rdf:Property ;
    rdfs:label 'Action Date' ;
    rdfs:comment 'Date on which the collection action was executed or initiated.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actionNumber rdf:type rdf:Property ;
    rdfs:label 'Action Number' ;
    rdfs:comment 'Business identifier for the collection action, used for tracking and reference in communications and workflows.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionOutcome rdf:type rdf:Property ;
    rdfs:label 'Action Outcome' ;
    rdfs:comment 'Result or outcome of the collection action, capturing whether payment was received, a plan was established, or further escalation is required. [ENUM-REF-CANDIDATE: payment_received|payment_plan_established|promise_to_pay|no_contact|dispute_raised|account_escalated|service_suspended|legal_action_initiated|account_written_off|no_response — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CollectionAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionStatus rdf:type rdf:Property ;
    rdfs:label 'Action Status' ;
    rdfs:comment 'Current status of the collection action in its lifecycle.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Action Timestamp' ;
    rdfs:comment 'Precise date and time when the collection action was executed, supporting audit trail and compliance requirements.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actionType rdf:type rdf:Property ;
    rdfs:label 'Action Type' ;
    rdfs:comment 'Type of collection activity performed. Includes dunning notices, collection calls, service suspension warnings, lien filings, and third-party collections referrals. [ENUM-REF-CANDIDATE: dunning_notice|collection_call|email_reminder|service_suspension_warning|payment_plan_offer|lien_filing|legal_notice|third_party_referral|account_review|settlement_offer — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Call Duration Seconds' ;
    rdfs:comment 'Duration of the collection call in seconds, if the action type was a phone call.' ;
    rdfs:domain ind:CollectionAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:callRecordingReference rdf:type rdf:Property ;
    rdfs:label 'Call Recording Reference' ;
    rdfs:comment 'Reference identifier or URI to the call recording, if the collection call was recorded for quality and compliance purposes.' ;
    rdfs:domain ind:CollectionAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communicationNotes rdf:type rdf:Property ;
    rdfs:label 'Communication Notes' ;
    rdfs:comment 'Free-text notes documenting the details of the communication or action taken, including customer responses and commitments.' ;
    rdfs:domain ind:CollectionAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceVerifiedBy rdf:type rdf:Property ;
    rdfs:label 'Compliance Verified By' ;
    rdfs:comment 'Reference to the employee who verified compliance for this collection action.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceVerifiedDate rdf:type rdf:Property ;
    rdfs:label 'Compliance Verified Date' ;
    rdfs:comment 'Date on which compliance verification was completed for this collection action.' ;
    rdfs:domain ind:CollectionAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Verified Flag' ;
    rdfs:comment 'Indicates whether this collection action was reviewed and verified for compliance with FDCPA and internal policies.' ;
    rdfs:domain ind:CollectionAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contactEmailAddress rdf:type rdf:Property ;
    rdfs:label 'Contact Email Address' ;
    rdfs:comment 'Email address used to contact the customer during this collection action, if applicable.' ;
    rdfs:domain ind:CollectionAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactMethod rdf:type rdf:Property ;
    rdfs:label 'Contact Method' ;
    rdfs:comment 'Method used to contact the customer for this collection action.' ;
    rdfs:domain ind:CollectionAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPhoneNumber rdf:type rdf:Property ;
    rdfs:label 'Contact Phone Number' ;
    rdfs:comment 'Phone number used to contact the customer during this collection action, if applicable.' ;
    rdfs:domain ind:CollectionAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daysPastDue rdf:type rdf:Property ;
    rdfs:label 'Days Past Due' ;
    rdfs:comment 'Number of days the account was past due at the time of the collection action.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:delinquencyAmount rdf:type rdf:Property ;
    rdfs:label 'Delinquency Amount' ;
    rdfs:comment 'Total amount of accounts receivable that was delinquent at the time this collection action was taken, in USD.' ;
    rdfs:domain ind:CollectionAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeRaisedFlag rdf:type rdf:Property ;
    rdfs:label 'Dispute Raised Flag' ;
    rdfs:comment 'Indicates whether the customer raised a billing dispute during this collection action.' ;
    rdfs:domain ind:CollectionAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disputeReason rdf:type rdf:Property ;
    rdfs:label 'Dispute Reason' ;
    rdfs:comment 'Description of the reason for the dispute raised by the customer, if applicable.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dunningLetterSentFlag rdf:type rdf:Property ;
    rdfs:label 'Dunning Letter Sent Flag' ;
    rdfs:comment 'Indicates whether a formal dunning letter was sent to the customer as part of this action.' ;
    rdfs:domain ind:CollectionAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dunningLetterTemplateCode rdf:type rdf:Property ;
    rdfs:label 'Dunning Letter Template Code' ;
    rdfs:comment 'Identifier of the dunning letter template used for this action, supporting compliance and audit requirements.' ;
    rdfs:domain ind:CollectionAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationLevel rdf:type rdf:Property ;
    rdfs:label 'Escalation Level' ;
    rdfs:comment 'Numeric indicator of the escalation stage in the collections process (e.g., 1=first notice, 2=second notice, 3=final notice, 4=legal action).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalActionFlag rdf:type rdf:Property ;
    rdfs:label 'Legal Action Flag' ;
    rdfs:comment 'Indicates whether legal action (lien filing, lawsuit) was initiated or threatened as part of this collection action.' ;
    rdfs:domain ind:CollectionAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextFollowUpDate rdf:type rdf:Property ;
    rdfs:label 'Next Follow Up Date' ;
    rdfs:comment 'Scheduled date for the next follow-up action or contact with the customer.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:promiseToPayAmount rdf:type rdf:Property ;
    rdfs:label 'Promise To Pay Amount' ;
    rdfs:comment 'Amount the customer promised to pay, if a promise to pay was obtained during this action.' ;
    rdfs:domain ind:CollectionAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promiseToPayDate rdf:type rdf:Property ;
    rdfs:label 'Promise To Pay Date' ;
    rdfs:comment 'Date on which the customer promised to make payment, if a promise to pay was obtained during this action.' ;
    rdfs:domain ind:CollectionAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:serviceSuspensionFlag rdf:type rdf:Property ;
    rdfs:label 'Service Suspension Flag' ;
    rdfs:comment 'Indicates whether service suspension was initiated or threatened as part of this collection action.' ;
    rdfs:domain ind:CollectionAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complaintId rdf:type rdf:Property ;
    rdfs:label 'Complaint Id' ;
    rdfs:comment 'Reference to the Salesforce CRM case record associated with this dispute for tracking and resolution workflow.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Complaint .

ind:complianceInspectionId rdf:type rdf:Property ;
    rdfs:label 'Compliance Inspection Id' ;
    rdfs:comment 'Foreign key linking to compliance.compliance_inspection. Business justification: Customer disputes often stem from inspection findings: contamination charges, service denials due to non-compliance, or disputed fees for regulatory violations. Linking disputes to triggering inspecti' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ComplianceInspection .

ind:disputeApprovedByManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Dispute Approved By Manager Employee Id' ;
    rdfs:comment 'Reference to the manager who approved the dispute resolution and associated financial adjustment.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:disputeEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Dispute Employee Id' ;
    rdfs:comment 'Reference to the billing analyst or customer service representative assigned to investigate and resolve the dispute.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:disputeEscalatedToManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Dispute Escalated To Manager Employee Id' ;
    rdfs:comment 'Reference to the manager or supervisor to whom the dispute was escalated for review and decision.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:invoiceLineId rdf:type rdf:Property ;
    rdfs:label 'Invoice Line Id' ;
    rdfs:comment 'Reference to the specific invoice line item being disputed, if the dispute is line-item specific rather than invoice-level.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InvoiceLine .

ind:pickupEventId rdf:type rdf:Property ;
    rdfs:label 'Pickup Event Id' ;
    rdfs:comment 'Foreign key linking to collection.pickup_event. Business justification: Service disputes often reference specific pickup events; direct link enables investigation of RFID scans, timestamps, GPS coordinates, driver notes, and contamination flags for resolution.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PickupEvent .

ind:weightTicketId rdf:type rdf:Property ;
    rdfs:label 'Weight Ticket Id' ;
    rdfs:comment 'Foreign key linking to collection.weight_ticket. Business justification: Tonnage and tipping fee disputes require direct access to the weight ticket with certified gross/tare/net weights, scale calibration date, and weighmaster certification for validation.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WeightTicket .

ind:closedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Closed Timestamp' ;
    rdfs:comment 'The date and time when the dispute was formally closed in the system.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:creditAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Amount' ;
    rdfs:comment 'The monetary amount credited to the customer account as a result of the dispute resolution, in USD.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditMemoId rdf:type rdf:Property ;
    rdfs:label 'Credit Memo Id' ;
    rdfs:comment 'Reference to the credit memo issued as part of the dispute resolution, if applicable.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:customerContactEmail rdf:type rdf:Property ;
    rdfs:label 'Customer Contact Email' ;
    rdfs:comment 'Email address of the customer contact for dispute correspondence and resolution communication.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerContactName rdf:type rdf:Property ;
    rdfs:label 'Customer Contact Name' ;
    rdfs:comment 'Name of the individual customer contact who initiated or is associated with the dispute.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerContactPhone rdf:type rdf:Property ;
    rdfs:label 'Customer Contact Phone' ;
    rdfs:comment 'Phone number of the customer contact for dispute follow-up and resolution discussions.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerSatisfactionRating rdf:type rdf:Property ;
    rdfs:label 'Customer Satisfaction Rating' ;
    rdfs:comment 'Post-resolution customer satisfaction score (1-5 scale) collected via survey to measure dispute handling quality.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:disputeDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Date' ;
    rdfs:comment 'The date the customer formally raised the billing dispute.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disputeNumber rdf:type rdf:Property ;
    rdfs:label 'Dispute Number' ;
    rdfs:comment 'Human-readable business identifier for the dispute, used in customer communications and internal tracking.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeStatus rdf:type rdf:Property ;
    rdfs:label 'Dispute Status' ;
    rdfs:comment 'Current lifecycle status of the dispute in the resolution workflow.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationDate rdf:type rdf:Property ;
    rdfs:label 'Escalation Date' ;
    rdfs:comment 'The date the dispute was escalated to a higher authority for resolution.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:financialImpactCategory rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Category' ;
    rdfs:comment 'Classification of the financial impact of the dispute and its resolution on the business.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priority rdf:type rdf:Property ;
    rdfs:label 'Priority' ;
    rdfs:comment 'Priority level assigned to the dispute based on amount, customer tier, or business impact.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundAmount rdf:type rdf:Property ;
    rdfs:label 'Refund Amount' ;
    rdfs:comment 'The monetary amount refunded to the customer via payment reversal as a result of the dispute resolution, in USD.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resolutionDate rdf:type rdf:Property ;
    rdfs:label 'Resolution Date' ;
    rdfs:comment 'The date the dispute was formally resolved and closed.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:resolutionNotes rdf:type rdf:Property ;
    rdfs:label 'Resolution Notes' ;
    rdfs:comment 'Detailed notes documenting the investigation findings, actions taken, and rationale for the resolution decision.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionType rdf:type rdf:Property ;
    rdfs:label 'Resolution Type' ;
    rdfs:comment 'The outcome classification of the dispute resolution indicating how the dispute was settled. [ENUM-REF-CANDIDATE: credit issued|charge upheld|partial credit|invoice corrected|waived|refund issued|adjustment applied — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseCategory rdf:type rdf:Property ;
    rdfs:label 'Root Cause Category' ;
    rdfs:comment 'Classification of the underlying root cause identified during dispute investigation, used for process improvement and trend analysis. [ENUM-REF-CANDIDATE: billing system error|rate table error|service delivery failure|data entry error|customer misunderstanding|policy exception|system integration issue — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaBreachFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Flag' ;
    rdfs:comment 'Indicator of whether the dispute resolution exceeded the SLA target resolution timeframe.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaTargetResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Sla Target Resolution Date' ;
    rdfs:comment 'The target date by which the dispute should be resolved per service level agreement commitments.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:soxComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Sox Compliance Flag' ;
    rdfs:comment 'Indicator of whether the dispute resolution followed SOX-compliant approval and documentation procedures for financial adjustments.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commoditySaleId rdf:type rdf:Property ;
    rdfs:label 'Commodity Sale Id' ;
    rdfs:comment 'Foreign key linking to recycling.commodity_sale. Business justification: Commodity sales to buyers generate AR invoices for payment collection. Every sale transaction must be invoiced. Core accounts receivable process in recycling operations requires linking invoices to or' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CommoditySale .

ind:permitId rdf:type rdf:Property ;
    rdfs:label 'Permit Id' ;
    rdfs:comment 'Foreign key linking to compliance.permit. Business justification: Invoices for permitted facility services (landfill tipping, transfer station fees) must reference the authorizing operating permit for regulatory audit trails and compliance verification. Permit-based' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Permit .

ind:reportPeriodId rdf:type rdf:Property ;
    rdfs:label 'Report Period Id' ;
    rdfs:comment 'Foreign key linking to sustainability.report_period. Business justification: ESG disclosures and EPA GHGRP reporting require billing revenue aligned with sustainability reporting periods. CFO and sustainability teams must reconcile financial performance with environmental metr' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReportPeriod .

ind:adjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Adjustment Amount' ;
    rdfs:comment 'Net adjustments applied to the invoice for credits, billing corrections, dispute resolutions, or service exceptions.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingModelType rdf:type rdf:Property ;
    rdfs:label 'Billing Model Type' ;
    rdfs:comment 'Classification of the billing approach used for this invoice: subscription (fixed recurring), transactional (per-pickup), tipping fee (per-ton disposal), usage-based (metered), hybrid, or one-time charge.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerType rdf:type rdf:Property ;
    rdfs:label 'Customer Type' ;
    rdfs:comment 'Classification of the customer being billed: residential household, commercial business, industrial facility, municipal contract, or government entity.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Delivery Method' ;
    rdfs:comment 'Method by which the invoice was or will be delivered to the customer: email, postal mail, customer portal, or EDI.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountAmount rdf:type rdf:Property ;
    rdfs:label 'Discount Amount' ;
    rdfs:comment 'Total discounts applied to the invoice, including promotional discounts, volume discounts, or contractual rate reductions.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dueDate rdf:type rdf:Property ;
    rdfs:label 'Due Date' ;
    rdfs:comment 'Date by which payment is expected from the customer. Used for aging buckets and collections prioritization.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:invoiceStatus rdf:type rdf:Property ;
    rdfs:label 'Invoice Status' ;
    rdfs:comment 'Current lifecycle status of the invoice in the billing and collections workflow. [ENUM-REF-CANDIDATE: draft|issued|sent|paid|partially_paid|overdue|void|disputed|cancelled — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outstandingBalance rdf:type rdf:Property ;
    rdfs:label 'Outstanding Balance' ;
    rdfs:comment 'Remaining unpaid amount on the invoice (total_amount minus paid_amount). Used for accounts receivable aging and collections.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paidAmount rdf:type rdf:Property ;
    rdfs:label 'Paid Amount' ;
    rdfs:comment 'Total amount paid by the customer against this invoice to date. Used to calculate outstanding balance.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueRecognitionDate rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Date' ;
    rdfs:comment 'Date on which revenue from this invoice is recognized in the general ledger per GAAP/IFRS standards.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revenueRecognitionPeriod rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Period' ;
    rdfs:comment 'Fiscal period (YYYY-MM format) in which revenue from this invoice is recognized for financial reporting.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Service Address Line1' ;
    rdfs:comment 'Primary street address line where waste collection or environmental services were provided during the billing period.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Service Address Line2' ;
    rdfs:comment 'Secondary address line (suite, unit, building) for the service location.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceCity rdf:type rdf:Property ;
    rdfs:label 'Service City' ;
    rdfs:comment 'City where waste collection or environmental services were provided.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:servicePostalCode rdf:type rdf:Property ;
    rdfs:label 'Service Postal Code' ;
    rdfs:comment 'ZIP or postal code for the service address. Used for route assignment and tax jurisdiction.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceState rdf:type rdf:Property ;
    rdfs:label 'Service State' ;
    rdfs:comment 'Two-letter state code where services were provided. Used for tax jurisdiction determination.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemInvoiceReference rdf:type rdf:Property ;
    rdfs:label 'Source System Invoice Reference' ;
    rdfs:comment 'Original invoice identifier in the source system. Used for traceability and reconciliation.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subtotalAmount rdf:type rdf:Property ;
    rdfs:label 'Subtotal Amount' ;
    rdfs:comment 'Sum of all line item charges before taxes, fees, adjustments, and discounts.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalAmount rdf:type rdf:Property ;
    rdfs:label 'Total Amount' ;
    rdfs:comment 'Final amount due from the customer after applying subtotal, taxes, discounts, and adjustments. This is the amount the customer must pay.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baleId rdf:type rdf:Property ;
    rdfs:label 'Bale Id' ;
    rdfs:comment 'Foreign key linking to recycling.bale. Business justification: Individual bales sold to commodity buyers generate specific invoice line items. High-value commodity transactions require bale-level traceability to invoice lines for quality disputes, payment reconci' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Bale .

ind:containerPlacementId rdf:type rdf:Property ;
    rdfs:label 'Container Placement Id' ;
    rdfs:comment 'Foreign key linking to collection.container_placement. Business justification: Container rental charges are billed based on placement records that track deployment dates, removal dates, rental duration, and container condition for accurate billing and asset tracking.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContainerPlacement .

ind:diversionRecordId rdf:type rdf:Property ;
    rdfs:label 'Diversion Record Id' ;
    rdfs:comment 'Foreign key linking to sustainability.diversion_record. Business justification: Performance-based contracts with diversion rate guarantees require billing-to-performance reconciliation. Links recycling service charges to actual diversion outcomes for verification, customer sustai' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DiversionRecord .

ind:frequencyPlanId rdf:type rdf:Property ;
    rdfs:label 'Frequency Plan Id' ;
    rdfs:comment 'Foreign key linking to service.frequency_plan. Business justification: Invoice lines for recurring collection services must reference the frequency plan (weekly, bi-weekly, on-call) to validate billing periods, prorate charges for partial periods, and reconcile billed se' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FrequencyPlan .

ind:haulManifestId rdf:type rdf:Property ;
    rdfs:label 'Haul Manifest Id' ;
    rdfs:comment 'Foreign key linking to collection.haul_manifest. Business justification: Invoicing outbound haul services requires linking to the manifest that documents waste classification, tonnage, regulatory compliance, and destination facility for accurate billing and reporting.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HaulManifest .

ind:loadTicketId rdf:type rdf:Property ;
    rdfs:label 'Load Ticket Id' ;
    rdfs:comment 'Foreign key linking to collection.load_ticket. Business justification: Transfer station tipping fee invoicing requires linking to the load ticket that captured inbound tonnage, waste classification, and fee calculation for regulatory compliance and customer billing.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LoadTicket .

ind:onDemandRequestId rdf:type rdf:Property ;
    rdfs:label 'On Demand Request Id' ;
    rdfs:comment 'Foreign key linking to collection.on_demand_request. Business justification: One-time service charges for bulk pickups, extra collections, and special requests are billed directly from the on-demand request that authorized the service and captured pricing.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OnDemandRequest .

ind:outboundHaulId rdf:type rdf:Property ;
    rdfs:label 'Outbound Haul Id' ;
    rdfs:comment 'Foreign key linking to collection.outbound_haul. Business justification: Invoicing outbound transportation from transfer stations to disposal facilities requires linking to the haul record with actual tonnage, destination facility, and transportation costs for accurate bil' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OutboundHaul .

ind:residueDisposalId rdf:type rdf:Property ;
    rdfs:label 'Residue Disposal Id' ;
    rdfs:comment 'Foreign key linking to recycling.residue_disposal. Business justification: Residue disposal costs are rebilled to customers as pass-through charges on invoice lines. MRFs must link invoice line items to specific disposal events for cost recovery, margin analysis, and custome' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ResidueDisposal .

ind:rolloffOrderId rdf:type rdf:Property ;
    rdfs:label 'Rolloff Order Id' ;
    rdfs:comment 'Foreign key linking to collection.rolloff_order. Business justification: Rolloff rental and disposal invoicing requires direct link to the order defining container size, rental duration, actual weight, overage charges, and service dates for accurate billing.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RolloffOrder .

ind:scaleTransactionId rdf:type rdf:Property ;
    rdfs:label 'Scale Transaction Id' ;
    rdfs:comment 'Foreign key linking to collection.scale_transaction. Business justification: Tonnage-based charges require direct link to the scale transaction that captured certified weights, scale calibration date, and weighmaster certification for accurate billing and audit compliance.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ScaleTransaction .

ind:surchargeId rdf:type rdf:Property ;
    rdfs:label 'Surcharge Id' ;
    rdfs:comment 'Foreign key linking to billing.surcharge. Business justification: Invoice line items can include surcharges (fuel surcharge, environmental fees, disposal surcharges) beyond base service charges. The surcharge master table defines available surcharges with rates, app' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Surcharge .

ind:taxRuleId rdf:type rdf:Property ;
    rdfs:label 'Tax Rule Id' ;
    rdfs:comment 'Foreign key linking to billing.tax_rule. Business justification: Invoice line items currently have tax_code (STRING) and tax_amount but no FK to the tax_rule master. Tax rules define jurisdiction-specific tax rates, calculation methods, and applicability. Adding ta' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TaxRule .

ind:tippingFeeRateId rdf:type rdf:Property ;
    rdfs:label 'Tipping Fee Rate Id' ;
    rdfs:comment 'Reference to the tipping fee rate schedule applied to this disposal charge. Links to the rate card for landfill or disposal facility charges.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TippingFeeRate .

ind:adjustmentReasonCode rdf:type rdf:Property ;
    rdfs:label 'Adjustment Reason Code' ;
    rdfs:comment 'Code indicating the reason for any billing adjustment on this line (e.g., service credit, billing correction, dispute resolution, promotional discount). Used for audit trail and dispute management.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargeCategory rdf:type rdf:Property ;
    rdfs:label 'Charge Category' ;
    rdfs:comment 'Revenue category classification for this line item. Used for financial reporting and revenue recognition (e.g., service charge, rental fee, disposal fee, fuel surcharge, environmental levy, late fee).' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceLineDescription rdf:type rdf:Property ;
    rdfs:label 'Invoice Line Description' ;
    rdfs:comment 'Detailed textual description of the charge appearing on the customer invoice. Provides human-readable explanation of what is being billed.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDisputed rdf:type rdf:Property ;
    rdfs:label 'Is Disputed' ;
    rdfs:comment 'Boolean flag indicating whether this line item is under dispute by the customer. Used for accounts receivable management and dispute resolution tracking.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineAmount rdf:type rdf:Property ;
    rdfs:label 'Line Amount' ;
    rdfs:comment 'Extended amount for this line item before taxes and adjustments. Calculated as quantity multiplied by unit rate, representing the base charge.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineNumber rdf:type rdf:Property ;
    rdfs:label 'Line Number' ;
    rdfs:comment 'Sequential line number within the invoice, used for ordering and referencing specific charges on the invoice document.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:materialType rdf:type rdf:Property ;
    rdfs:label 'Material Type' ;
    rdfs:comment 'Type of waste material being serviced or disposed. Categorizes the waste stream for regulatory reporting and pricing (e.g., MSW, recycling, organic, C&D, hazardous, medical, e-waste). [ENUM-REF-CANDIDATE: msw|recycling|organic|construction_debris|hazardous|medical|electronic — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netAmount rdf:type rdf:Property ;
    rdfs:label 'Net Amount' ;
    rdfs:comment 'Final net amount for this line item after applying discounts and adding taxes. Represents the total charge to the customer for this line.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueRecognitionRule rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Rule' ;
    rdfs:comment 'Rule governing when and how revenue from this line item is recognized. Supports GAAP/IFRS compliance (e.g., immediate, deferred, prorated over service period, milestone-based).' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRecognizedDate rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognized Date' ;
    rdfs:comment 'Date when revenue from this line item was recognized in the general ledger. Used for GAAP/IFRS compliance and financial period closing.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tonnage rdf:type rdf:Property ;
    rdfs:label 'Tonnage' ;
    rdfs:comment 'Weight of waste in tons for this line item. Used for tonnage-based billing at landfills, transfer stations, and disposal facilities. Measured in short tons (US) or metric tonnes.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitRate rdf:type rdf:Property ;
    rdfs:label 'Unit Rate' ;
    rdfs:comment 'Price per unit of measure for this line item. The rate charged per pickup, per ton, per day, etc., before applying quantity.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentId rdf:type rdf:Property ;
    rdfs:label 'Payment Id' ;
    rdfs:comment 'Unique identifier for the payment transaction. Primary key.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Payment .

ind:paymentMethodId rdf:type rdf:Property ;
    rdfs:label 'Payment Method Id' ;
    rdfs:comment 'Foreign key linking to billing.payment_method. Business justification: Normalize payment.payment_method from STRING to FK. Current implementation stores payment method as free-text string, leading to data quality issues (inconsistent values, typos, no referential integri' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentMethod .

ind:appliedAmount rdf:type rdf:Property ;
    rdfs:label 'Applied Amount' ;
    rdfs:comment 'Portion of the payment amount that has been applied to one or more invoices.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:arBatchReference rdf:type rdf:Property ;
    rdfs:label 'Ar Batch Reference' ;
    rdfs:comment 'Identifier of the accounts receivable batch in which this payment was processed, used for AR reconciliation and audit.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Bank Account Number' ;
    rdfs:comment 'Bank account number from which the payment was drawn (for ACH, EFT, wire transfers). Masked or tokenized for security.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankDepositBatchReference rdf:type rdf:Property ;
    rdfs:label 'Bank Deposit Batch Reference' ;
    rdfs:comment 'Identifier of the bank deposit batch in which this payment was deposited, used for cash management and reconciliation.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankRoutingNumber rdf:type rdf:Property ;
    rdfs:label 'Bank Routing Number' ;
    rdfs:comment 'Bank routing number (ABA number) for ACH, EFT, or wire transfer payments.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channel rdf:type rdf:Property ;
    rdfs:label 'Channel' ;
    rdfs:comment 'The interface or channel through which the payment was submitted (customer portal, mail, phone, in-person, bank transfer, auto-pay, third-party processor). [ENUM-REF-CANDIDATE: customer_portal|mail|phone|in_person|bank_transfer|auto_pay|third_party — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearedDate rdf:type rdf:Property ;
    rdfs:label 'Cleared Date' ;
    rdfs:comment 'The date the payment cleared the bank and funds became available.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditCardLastFour rdf:type rdf:Property ;
    rdfs:label 'Credit Card Last Four' ;
    rdfs:comment 'Last four digits of the credit or debit card used for payment, for reference and reconciliation purposes.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditCardType rdf:type rdf:Property ;
    rdfs:label 'Credit Card Type' ;
    rdfs:comment 'Type of credit or debit card used for payment (Visa, MasterCard, American Express, Discover, other).' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depositDate rdf:type rdf:Property ;
    rdfs:label 'Deposit Date' ;
    rdfs:comment 'The date the payment was deposited into the company bank account.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:glDate rdf:type rdf:Property ;
    rdfs:label 'Gl Date' ;
    rdfs:comment 'The accounting date on which the payment was posted to the general ledger for financial reporting purposes.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:glPeriod rdf:type rdf:Property ;
    rdfs:label 'Gl Period' ;
    rdfs:comment 'The accounting period (e.g., 2024-01, Q1-2024) in which the payment was posted to the general ledger.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lockboxBatchReference rdf:type rdf:Property ;
    rdfs:label 'Lockbox Batch Reference' ;
    rdfs:comment 'Identifier of the lockbox batch for payments received via bank lockbox service, used for automated payment processing and reconciliation.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nsfFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Nsf Fee Amount' ;
    rdfs:comment 'Fee charged to the customer for a returned payment due to non-sufficient funds.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Number' ;
    rdfs:comment 'Business-facing unique reference number for the payment transaction, used for customer communication and reconciliation.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Status' ;
    rdfs:comment 'Current lifecycle status of the payment: received, cleared, applied to invoice, unapplied, returned (NSF), reversed, held for review, or voided. [ENUM-REF-CANDIDATE: received|cleared|applied|unapplied|returned|reversed|held|voided — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentType rdf:type rdf:Property ;
    rdfs:label 'Payment Type' ;
    rdfs:comment 'Classification of the payment transaction: standard payment against invoice, prepayment, advance deposit, retainer, refund, or credit memo application.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prepaymentExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Prepayment Expiry Date' ;
    rdfs:comment 'Expiration date for prepayments or advance deposits, after which the unapplied amount may be refunded or forfeited per contract terms.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:processor rdf:type rdf:Property ;
    rdfs:label 'Processor' ;
    rdfs:comment 'Name of the third-party payment processor or gateway used to process the payment (e.g., Stripe, PayPal, Authorize.Net).' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processorTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Processor Transaction Reference' ;
    rdfs:comment 'Unique transaction identifier assigned by the payment processor or gateway for tracking and reconciliation.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reference rdf:type rdf:Property ;
    rdfs:label 'Reference' ;
    rdfs:comment 'External reference number provided by the customer or payment processor (check number, transaction ID, confirmation code).' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundDate rdf:type rdf:Property ;
    rdfs:label 'Refund Date' ;
    rdfs:comment 'The date the refund was issued to the customer.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:refundStatus rdf:type rdf:Property ;
    rdfs:label 'Refund Status' ;
    rdfs:comment 'Status of any refund associated with this payment: not refunded, refund requested, refund approved, refund issued, or refund rejected.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalReason rdf:type rdf:Property ;
    rdfs:label 'Reversal Reason' ;
    rdfs:comment 'Reason code or description for payment reversal (NSF, stop payment, customer dispute, processing error, fraud).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unappliedAmount rdf:type rdf:Property ;
    rdfs:label 'Unapplied Amount' ;
    rdfs:comment 'Portion of the payment amount that remains unapplied and available for future invoice application or refund.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentApplicationId rdf:type rdf:Property ;
    rdfs:label 'Payment Application Id' ;
    rdfs:comment 'Unique identifier for the payment application record. Primary key.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:prepaymentId rdf:type rdf:Property ;
    rdfs:label 'Prepayment Id' ;
    rdfs:comment 'Foreign key linking to billing.prepayment. Business justification: Payment_application currently links payment_id to invoice_id, capturing how payment funds are allocated. However, prepayments (customer deposits, advance payments) are held in the prepayment table and' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Prepayment .

ind:primaryPaymentEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Payment Employee Id' ;
    rdfs:comment 'Identifier of the system user or automated process that created this payment application. Used for audit trail and accountability in AR operations.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryPaymentLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Payment Last Modified By User Employee Id' ;
    rdfs:comment 'Identifier of the user who last modified this payment application record. Used for accountability and audit trail.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accountingPeriod rdf:type rdf:Property ;
    rdfs:label 'Accounting Period' ;
    rdfs:comment 'The fiscal period identifier (e.g., 2024-Q1, 2024-01) to which this payment application is assigned for financial reporting and period close processes.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationDate rdf:type rdf:Property ;
    rdfs:label 'Application Date' ;
    rdfs:comment 'The date when the payment was applied to the invoice. This is the business event date used for accounting period assignment and Accounts Receivable (AR) aging calculations.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:applicationNumber rdf:type rdf:Property ;
    rdfs:label 'Application Number' ;
    rdfs:comment 'Business identifier for the payment application transaction. Used for tracking and reference in customer service and accounting operations.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationSource rdf:type rdf:Property ;
    rdfs:label 'Application Source' ;
    rdfs:comment 'The system or process that originated this payment application. Manual applications are entered by AR staff; automatic applications are system-matched; lockbox applications come from bank lockbox processing; customer portal applications are self-service; batch imports are from external systems; API applications are from integrated systems.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationStatus rdf:type rdf:Property ;
    rdfs:label 'Application Status' ;
    rdfs:comment 'Current lifecycle status of the payment application. Pending applications are awaiting approval; applied applications are finalized; reversed applications have been undone; voided applications are cancelled; adjusted applications have been modified post-application.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Application Timestamp' ;
    rdfs:comment 'Precise date and time when the payment application was processed in the system. Used for audit trail and transaction sequencing.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:applicationType rdf:type rdf:Property ;
    rdfs:label 'Application Type' ;
    rdfs:comment 'Classification of how the payment is being applied. Standard applications reduce open AR balance; prepayments are applied to future invoices; credit memo offsets apply credits; dispute settlements resolve billing disputes; overpayment allocations handle excess payments; refund reversals correct previously issued refunds.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:comments rdf:type rdf:Property ;
    rdfs:label 'Comments' ;
    rdfs:comment 'Free-text notes or comments about this payment application. Used to document special circumstances, customer requests, dispute resolutions, or manual intervention reasons.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountDate rdf:type rdf:Property ;
    rdfs:label 'Discount Date' ;
    rdfs:comment 'The date by which payment must be received to qualify for early payment discount. Used to validate discount eligibility at application time.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exchangeRate rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate' ;
    rdfs:comment 'The currency exchange rate used to convert payment amount to invoice currency, if cross-currency application. Null for same-currency applications.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exchangeRateDate rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate Date' ;
    rdfs:comment 'The date for which the exchange rate was determined. Used for foreign exchange gain/loss calculations and audit trail.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exchangeRateType rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate Type' ;
    rdfs:comment 'The type of exchange rate used for cross-currency applications. Spot rates are market rates at transaction time; corporate rates are company-defined standard rates; user-defined rates are manually entered.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceBalanceAfter rdf:type rdf:Property ;
    rdfs:label 'Invoice Balance After' ;
    rdfs:comment 'The outstanding balance of the invoice immediately after this payment application was processed. Used for audit trail and to determine if invoice is fully paid.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceBalanceBefore rdf:type rdf:Property ;
    rdfs:label 'Invoice Balance Before' ;
    rdfs:comment 'The outstanding balance of the invoice immediately before this payment application was processed. Used for audit trail and reconciliation.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isCrossCurrency rdf:type rdf:Property ;
    rdfs:label 'Is Cross Currency' ;
    rdfs:comment 'Indicates whether this payment application involves currency conversion (payment currency differs from invoice currency). Used for foreign exchange gain/loss tracking.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOnAccount rdf:type rdf:Property ;
    rdfs:label 'Is On Account' ;
    rdfs:comment 'Indicates whether this payment application represents an on-account credit (payment received without a specific invoice to apply to). True for prepayments and overpayments held for future application.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:matchingRuleCode rdf:type rdf:Property ;
    rdfs:label 'Matching Rule Code' ;
    rdfs:comment 'The automated matching rule that was used to apply this payment to the invoice (e.g., exact amount match, invoice number match, customer account match). Used for automatic cash application processes.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalAppliedAmount rdf:type rdf:Property ;
    rdfs:label 'Original Applied Amount' ;
    rdfs:comment 'The initial applied amount before any subsequent adjustments or reversals. Used to track the history of changes to the payment application.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentMethodCode rdf:type rdf:Property ;
    rdfs:label 'Payment Method Code' ;
    rdfs:comment 'The payment instrument used for this payment (e.g., check, ACH, credit card, wire transfer, cash). Denormalized from payment record for application-level reporting.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Reference Number' ;
    rdfs:comment 'External reference number from the payment transaction (e.g., check number, ACH trace number, credit card authorization code). Denormalized for reconciliation and customer service.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remainingUnappliedAmount rdf:type rdf:Property ;
    rdfs:label 'Remaining Unapplied Amount' ;
    rdfs:comment 'The portion of the original payment that remains unapplied after this application. Used for tracking partial payment scenarios and multi-invoice applications.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reversalReasonCode rdf:type rdf:Property ;
    rdfs:label 'Reversal Reason Code' ;
    rdfs:comment 'Standardized code indicating why the payment application was reversed. Examples include payment error, incorrect invoice, customer dispute, NSF (Non-Sufficient Funds), or administrative correction.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Reversal Reason Description' ;
    rdfs:comment 'Detailed explanation of why the payment application was reversed. Provides context for audit and customer service inquiries.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:writeoffAmount rdf:type rdf:Property ;
    rdfs:label 'Writeoff Amount' ;
    rdfs:comment 'The amount of invoice balance written off as uncollectible at the time of this payment application. Used in partial payment scenarios where remaining balance is deemed uncollectible.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quaternaryPaymentModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Payment Modified By User Employee Id' ;
    rdfs:comment 'Reference to the user who last modified this payment plan record.' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryPaymentCreatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Payment Created By User Employee Id' ;
    rdfs:comment 'Reference to the user (customer service representative, collections agent, or system process) who created this payment plan record.' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:autoPayEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Pay Enabled Flag' ;
    rdfs:comment 'Indicates whether automatic payment processing is enabled for this plan. When true, installments are automatically charged to the customers payment method on file on each due date.' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bankruptcyCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Bankruptcy Case Number' ;
    rdfs:comment 'Court-assigned bankruptcy case number if this payment plan is part of a bankruptcy arrangement. Null for non-bankruptcy plans.' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankruptcyChapter rdf:type rdf:Property ;
    rdfs:label 'Bankruptcy Chapter' ;
    rdfs:comment 'Type of bankruptcy filing if this payment plan is part of a bankruptcy arrangement. Chapter 7 is liquidation; Chapter 11 is business reorganization; Chapter 13 is individual debt adjustment. Null for non-bankruptcy plans.' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultThresholdCount rdf:type rdf:Property ;
    rdfs:label 'Default Threshold Count' ;
    rdfs:comment 'Number of missed installments allowed before the plan is automatically moved to defaulted status. Typically 2 for standard plans, may be higher for hardship programs.' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:downPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Down Payment Amount' ;
    rdfs:comment 'Initial payment required at plan setup before installment schedule begins. May be zero for certain hardship programs.' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:downPaymentReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Down Payment Received Date' ;
    rdfs:comment 'Date the down payment was received and processed. Null if no down payment was required or if down payment is still outstanding.' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enrolledBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Enrolled Balance Amount' ;
    rdfs:comment 'The portion of the original balance that was enrolled into this payment plan. May be less than original balance if customer made partial payment or if certain charges were excluded from the plan.' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:finalInstallmentDueDate rdf:type rdf:Property ;
    rdfs:label 'Final Installment Due Date' ;
    rdfs:comment 'Scheduled due date for the last installment payment. Represents the planned completion date of the payment plan.' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:firstInstallmentDueDate rdf:type rdf:Property ;
    rdfs:label 'First Installment Due Date' ;
    rdfs:comment 'Scheduled due date for the first installment payment. Subsequent installments are calculated based on this date and the installment frequency.' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:installmentAmount rdf:type rdf:Property ;
    rdfs:label 'Installment Amount' ;
    rdfs:comment 'Standard amount due for each installment payment. Calculated as (enrolled_balance_amount - down_payment_amount) / total_installment_count. Final installment may differ to account for rounding.' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:installmentFrequency rdf:type rdf:Property ;
    rdfs:label 'Installment Frequency' ;
    rdfs:comment 'Cadence at which installment payments are scheduled. Monthly is most common; weekly and biweekly are used for residential hardship programs; quarterly may be used for large commercial accounts.' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interestAccruedAmount rdf:type rdf:Property ;
    rdfs:label 'Interest Accrued Amount' ;
    rdfs:comment 'Total interest charges accrued on this payment plan to date. Zero for interest-free plans.' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interestRatePercent rdf:type rdf:Property ;
    rdfs:label 'Interest Rate Percent' ;
    rdfs:comment 'Annual interest rate applied to the enrolled balance, if any. Most residential hardship plans have zero interest; commercial workout agreements may include interest. Expressed as percentage (e.g., 5.00 for 5%).' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lateFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Late Fee Amount' ;
    rdfs:comment 'Standard late fee charged for each missed installment payment. May be waived for hardship programs.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:missedInstallmentCount rdf:type rdf:Property ;
    rdfs:label 'Missed Installment Count' ;
    rdfs:comment 'Number of scheduled installments that were not paid by their due date. Used to determine default status and trigger collections escalation.' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Original Balance Amount' ;
    rdfs:comment 'Total outstanding accounts receivable (AR) balance at the time the payment plan was established. Represents the full amount owed before any plan payments were made.' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planEndDate rdf:type rdf:Property ;
    rdfs:label 'Plan End Date' ;
    rdfs:comment 'Actual date the payment plan was completed, defaulted, or cancelled. Null for active or suspended plans. For completed plans, this is the date the final payment was received; for defaulted or cancelled plans, this is the date the plan was terminated.' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planNumber rdf:type rdf:Property ;
    rdfs:label 'Plan Number' ;
    rdfs:comment 'Externally visible unique business identifier for the payment plan, formatted as PP-NNNNNNNN.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planStartDate rdf:type rdf:Property ;
    rdfs:label 'Plan Start Date' ;
    rdfs:comment 'Effective date when the payment plan became active and the installment schedule began. Typically the date the plan was approved and down payment (if required) was received.' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planStatus rdf:type rdf:Property ;
    rdfs:label 'Plan Status' ;
    rdfs:comment 'Current lifecycle state of the payment plan. Draft indicates plan is being set up but not yet active; active means plan is in effect and installments are being processed; completed indicates all installments paid successfully; defaulted means customer missed installments per default criteria; cancelled indicates plan was terminated before completion; suspended means plan is temporarily on hold pending resolution of dispute or other issue.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planType rdf:type rdf:Property ;
    rdfs:label 'Plan Type' ;
    rdfs:comment 'Classification of the payment plan based on the business program and customer segment. Residential hardship programs support customers facing temporary financial difficulty; commercial workout agreements are negotiated arrangements for business accounts; standard installment plans are routine payment schedules; seasonal deferral plans accommodate seasonal business fluctuations; bankruptcy arrangements comply with court-ordered payment terms; settlement plans represent negotiated reduced-balance agreements.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remainingBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Remaining Balance Amount' ;
    rdfs:comment 'Current outstanding balance remaining on the payment plan after all payments received to date. Calculated as enrolled_balance_amount minus sum of all installment payments received.' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementDiscountAmount rdf:type rdf:Property ;
    rdfs:label 'Settlement Discount Amount' ;
    rdfs:comment 'Dollar amount of discount applied to the original balance as part of a settlement agreement. Zero for standard payment plans.' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementDiscountPercent rdf:type rdf:Property ;
    rdfs:label 'Settlement Discount Percent' ;
    rdfs:comment 'Percentage discount applied to the original balance as part of a settlement agreement. Zero for standard payment plans. Expressed as percentage (e.g., 20.00 for 20% discount).' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalInstallmentCount rdf:type rdf:Property ;
    rdfs:label 'Total Installment Count' ;
    rdfs:comment 'Total number of scheduled installment payments in this plan. Typically ranges from 3 to 24 installments depending on plan type and balance amount.' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalLateFeesAssessed rdf:type rdf:Property ;
    rdfs:label 'Total Late Fees Assessed' ;
    rdfs:comment 'Cumulative sum of all late fees assessed on this payment plan due to missed installments.' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPaidAmount rdf:type rdf:Property ;
    rdfs:label 'Total Paid Amount' ;
    rdfs:comment 'Cumulative sum of all payments received against this payment plan, including down payment and all installment payments to date.' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentPlanInstallmentId rdf:type rdf:Property ;
    rdfs:label 'Payment Plan Installment Id' ;
    rdfs:comment 'Unique identifier for the payment plan installment record. Primary key.' ;
    rdfs:domain ind:PaymentPlanInstallment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:appliedToInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Applied To Invoice Id' ;
    rdfs:comment 'Reference to the specific invoice that this installment payment was applied against in the accounts receivable (AR) system. Used for revenue recognition and reconciliation.' ;
    rdfs:domain ind:PaymentPlanInstallment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:actualAmountPaid rdf:type rdf:Property ;
    rdfs:label 'Actual Amount Paid' ;
    rdfs:comment 'The actual amount paid by the customer for this installment in USD. May differ from scheduled amount due to partial payments or overpayments. Null if not yet paid.' ;
    rdfs:domain ind:PaymentPlanInstallment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Actual Payment Date' ;
    rdfs:comment 'The date on which the customer actually made the payment for this installment. Null if not yet paid.' ;
    rdfs:domain ind:PaymentPlanInstallment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:installmentNumber rdf:type rdf:Property ;
    rdfs:label 'Installment Number' ;
    rdfs:comment 'Sequential number of this installment within the payment plan (e.g., 1, 2, 3). Determines the order of scheduled payments.' ;
    rdfs:domain ind:PaymentPlanInstallment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:installmentStatus rdf:type rdf:Property ;
    rdfs:label 'Installment Status' ;
    rdfs:comment 'Current lifecycle status of this installment: scheduled (not yet due or paid), paid (fully paid), partial (partially paid), missed (past due and unpaid), waived (forgiven by collections), cancelled (plan terminated).' ;
    rdfs:domain ind:PaymentPlanInstallment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lateFeeWaivedFlag rdf:type rdf:Property ;
    rdfs:label 'Late Fee Waived Flag' ;
    rdfs:comment 'Indicates whether the late fee for this installment was waived as a customer service gesture or due to billing error. True if waived, False otherwise.' ;
    rdfs:domain ind:PaymentPlanInstallment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentChannel rdf:type rdf:Property ;
    rdfs:label 'Payment Channel' ;
    rdfs:comment 'The channel or interface through which the customer submitted this installment payment (e.g., online portal, mobile app, phone). Null if not yet paid.' ;
    rdfs:domain ind:PaymentPlanInstallment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledAmount rdf:type rdf:Property ;
    rdfs:label 'Scheduled Amount' ;
    rdfs:comment 'The contractually agreed amount due for this installment in USD. Represents the planned payment obligation.' ;
    rdfs:domain ind:PaymentPlanInstallment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduledDueDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Due Date' ;
    rdfs:comment 'The date on which this installment payment is contractually due from the customer.' ;
    rdfs:domain ind:PaymentPlanInstallment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:waiverApprovedBy rdf:type rdf:Property ;
    rdfs:label 'Waiver Approved By' ;
    rdfs:comment 'Name or identifier of the manager or system user who approved the waiver of this installment. Required for SOX audit trail when waivers are granted.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverDate rdf:type rdf:Property ;
    rdfs:label 'Waiver Date' ;
    rdfs:comment 'Date on which the waiver for this installment was approved and applied. Null if not waived.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:waiverReasonCode rdf:type rdf:Property ;
    rdfs:label 'Waiver Reason Code' ;
    rdfs:comment 'Reason code explaining why this installment was waived or forgiven by collections or management. Null if not waived. [ENUM-REF-CANDIDATE: financial_hardship|service_failure|billing_error|customer_retention|bankruptcy|deceased|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PaymentPlanInstallment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prepaymentApprovedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Prepayment Approved By User Employee Id' ;
    rdfs:comment 'Reference to the supervisor or manager who approved the prepayment for posting, required for SOX (Sarbanes-Oxley Act) segregation of duties controls.' ;
    rdfs:domain ind:Prepayment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:prepaymentEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Prepayment Employee Id' ;
    rdfs:comment 'Reference to the employee or system user who recorded the prepayment receipt in the system.' ;
    rdfs:domain ind:Prepayment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:prepaymentLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Prepayment Last Modified By User Employee Id' ;
    rdfs:comment 'Reference to the user who last modified the prepayment record, supporting SOX audit trail requirements.' ;
    rdfs:domain ind:Prepayment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:applicationPriority rdf:type rdf:Property ;
    rdfs:label 'Application Priority' ;
    rdfs:comment 'Numeric priority order for automatic application of this prepayment against invoices when multiple prepayments exist for the same customer account. Lower numbers indicate higher priority.' ;
    rdfs:domain ind:Prepayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:autoApplyFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Apply Flag' ;
    rdfs:comment 'Indicates whether this prepayment should be automatically applied to new invoices (true) or requires manual application by AR staff (false).' ;
    rdfs:domain ind:Prepayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bankAccountReference rdf:type rdf:Property ;
    rdfs:label 'Bank Account Reference' ;
    rdfs:comment 'Reference to the company bank account where the prepayment funds were deposited.' ;
    rdfs:domain ind:Prepayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expiryDate rdf:type rdf:Property ;
    rdfs:label 'Expiry Date' ;
    rdfs:comment 'Date after which the prepayment is no longer valid for application and may be subject to refund or forfeiture per contract terms. Null for prepayments with no expiration.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:externalReferenceCode rdf:type rdf:Property ;
    rdfs:label 'External Reference Code' ;
    rdfs:comment 'Unique identifier from the source system for cross-system reconciliation and traceability.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forfeitureDate rdf:type rdf:Property ;
    rdfs:label 'Forfeiture Date' ;
    rdfs:comment 'Date when the prepayment was forfeited and recognized as revenue per contract terms (e.g., non-refundable deposit after service cancellation). Null if not forfeited.' ;
    rdfs:domain ind:Prepayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:forfeitureReason rdf:type rdf:Property ;
    rdfs:label 'Forfeiture Reason' ;
    rdfs:comment 'Business reason or contract clause justifying the forfeiture of the prepayment (e.g., customer cancellation, breach of contract, expiration). Null if not forfeited.' ;
    rdfs:domain ind:Prepayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prepaymentNumber rdf:type rdf:Property ;
    rdfs:label 'Prepayment Number' ;
    rdfs:comment 'Business-facing unique identifier for the prepayment transaction, typically system-generated or manually assigned for tracking and reference purposes.' ;
    rdfs:domain ind:Prepayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prepaymentStatus rdf:type rdf:Property ;
    rdfs:label 'Prepayment Status' ;
    rdfs:comment 'Current lifecycle status of the prepayment: active (available for application), partially applied (some balance used), fully applied (entire amount consumed), refunded (returned to customer), expired (past validity period), or forfeited (retained per contract terms).' ;
    rdfs:domain ind:Prepayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prepaymentType rdf:type rdf:Property ;
    rdfs:label 'Prepayment Type' ;
    rdfs:comment 'Classification of the prepayment purpose: deposit (refundable security), advance payment (applied to future invoices), retainer (ongoing service commitment), mobilization fee (municipal contract startup), security deposit (credit risk mitigation), or container deposit (roll-off equipment).' ;
    rdfs:domain ind:Prepayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptDate rdf:type rdf:Property ;
    rdfs:label 'Receipt Date' ;
    rdfs:comment 'Date when the prepayment was received from the customer. This is the business event date for the cash receipt.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:receiptTimestamp rdf:type rdf:Property ;
    rdfs:label 'Receipt Timestamp' ;
    rdfs:comment 'Precise timestamp when the prepayment was received, including time zone information for multi-region operations.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:refundEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Refund Eligible Flag' ;
    rdfs:comment 'Indicates whether the prepayment is eligible for refund to the customer (true) or is non-refundable per contract terms (false).' ;
    rdfs:domain ind:Prepayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:refundMethod rdf:type rdf:Property ;
    rdfs:label 'Refund Method' ;
    rdfs:comment 'Method used to return funds to the customer: check, wire transfer, ACH, credit card reversal, or account credit. Null if no refund has been processed.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Refund Reference Number' ;
    rdfs:comment 'External reference identifier for the refund transaction (check number, wire confirmation, ACH trace) for reconciliation purposes. Null if no refund has been processed.' ;
    rdfs:domain ind:Prepayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remainingBalance rdf:type rdf:Property ;
    rdfs:label 'Remaining Balance' ;
    rdfs:comment 'Current unapplied balance available for future invoice applications. Calculated as prepayment_amount minus applied_amount minus any refunds or adjustments.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceStartDate rdf:type rdf:Property ;
    rdfs:label 'Service Start Date' ;
    rdfs:comment 'Expected or actual start date of services for which this prepayment was collected, relevant for advance payments and mobilization fees.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rateComponentId rdf:type rdf:Property ;
    rdfs:label 'Rate Component Id' ;
    rdfs:comment 'Unique identifier for the rate component. Primary key.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RateComponent .

ind:supersededByComponentRateComponentId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Component Rate Component Id' ;
    rdfs:comment 'Reference to the rate component that replaces this one when a new version is created. Null if this is the current version.' ;
    rdfs:domain ind:RateComponent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RateComponent .

ind:appliesToContainerType rdf:type rdf:Property ;
    rdfs:label 'Applies To Container Type' ;
    rdfs:comment 'Container type(s) to which this component applies (e.g., 96-gallon cart, 2-yard dumpster, 40-yard rolloff). Pipe-separated list for multiple types. [ENUM-REF-CANDIDATE: 32_gal_cart|64_gal_cart|96_gal_cart|1_yard_dumpster|2_yard_dumpster|4_yard_dumpster|6_yard_dumpster|8_yard_dumpster|10_yard_rolloff|20_yard_rolloff|30_yard_rolloff|40_yard_rolloff|compactor — promote to reference product]' ;
    rdfs:domain ind:RateComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appliesToServiceType rdf:type rdf:Property ;
    rdfs:label 'Applies To Service Type' ;
    rdfs:comment 'Service type(s) to which this component applies (e.g., residential collection, commercial hauling, recycling). Pipe-separated list for multiple types. [ENUM-REF-CANDIDATE: residential_collection|commercial_collection|recycling|landfill_disposal|hazardous_waste|rolloff|compactor_rental|transfer_station — promote to reference product]' ;
    rdfs:domain ind:RateComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculationMethod rdf:type rdf:Property ;
    rdfs:label 'Calculation Method' ;
    rdfs:comment 'Method used to calculate the charge: fixed amount, percentage of base, per-unit rate, tiered pricing, or custom formula.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentCode rdf:type rdf:Property ;
    rdfs:label 'Component Code' ;
    rdfs:comment 'Unique business identifier code for the rate component (e.g., BASE_FEE, FUEL_SRCHG, ENV_FEE).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentName rdf:type rdf:Property ;
    rdfs:label 'Component Name' ;
    rdfs:comment 'Human-readable name of the rate component (e.g., Base Service Fee, Fuel Surcharge, Environmental Fee).' ;
    rdfs:domain ind:RateComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentStatus rdf:type rdf:Property ;
    rdfs:label 'Component Status' ;
    rdfs:comment 'Current lifecycle status of the rate component.' ;
    rdfs:domain ind:RateComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deferralPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Deferral Period Months' ;
    rdfs:comment 'Number of months over which revenue should be deferred when revenue_recognition_rule is deferred or over_service_period.' ;
    rdfs:domain ind:RateComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:formulaExpression rdf:type rdf:Property ;
    rdfs:label 'Formula Expression' ;
    rdfs:comment 'Custom calculation formula expression when calculation_method is formula. Uses Oracle Revenue Management formula syntax.' ;
    rdfs:domain ind:RateComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceLabel rdf:type rdf:Property ;
    rdfs:label 'Invoice Label' ;
    rdfs:comment 'Customer-facing label text to display on invoices when print_on_invoice_flag is true.' ;
    rdfs:domain ind:RateComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passThroughFlag rdf:type rdf:Property ;
    rdfs:label 'Pass Through Flag' ;
    rdfs:comment 'Indicates whether this component is a pass-through charge (collected from customer and remitted to third party) versus company revenue.' ;
    rdfs:domain ind:RateComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:printOnInvoiceFlag rdf:type rdf:Property ;
    rdfs:label 'Print On Invoice Flag' ;
    rdfs:comment 'Indicates whether this component should be displayed as a separate line item on customer invoices.' ;
    rdfs:domain ind:RateComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:profitCenter rdf:type rdf:Property ;
    rdfs:label 'Profit Center' ;
    rdfs:comment 'Profit center code for segment reporting and profitability analysis.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prorationMethod rdf:type rdf:Property ;
    rdfs:label 'Proration Method' ;
    rdfs:comment 'Method for prorating charges when service period is partial (e.g., mid-month start/stop).' ;
    rdfs:domain ind:RateComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateValue rdf:type rdf:Property ;
    rdfs:label 'Rate Value' ;
    rdfs:comment 'Numeric value of the rate component. Interpretation depends on calculation_method (e.g., dollar amount for fixed, percentage for percentage-based, rate per unit for per-unit).' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryFeeFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Fee Flag' ;
    rdfs:comment 'Indicates whether this component represents a government-mandated or regulatory fee that must be separately tracked for compliance reporting.' ;
    rdfs:domain ind:RateComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:roundingRule rdf:type rdf:Property ;
    rdfs:label 'Rounding Rule' ;
    rdfs:comment 'Rounding rule applied to calculated component amount.' ;
    rdfs:domain ind:RateComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Sequence Number' ;
    rdfs:comment 'Order in which this component is calculated and displayed within the rate schedule. Lower numbers are processed first.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:taxCategory rdf:type rdf:Property ;
    rdfs:label 'Tax Category' ;
    rdfs:comment 'Tax treatment category for this component when taxable_flag is true.' ;
    rdfs:domain ind:RateComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxableFlag rdf:type rdf:Property ;
    rdfs:label 'Taxable Flag' ;
    rdfs:comment 'Indicates whether this rate component is subject to sales tax or other applicable taxes.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:versionNumber rdf:type rdf:Property ;
    rdfs:label 'Version Number' ;
    rdfs:comment 'Version number of this rate component for tracking changes over time. Incremented with each modification.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratedUsageId rdf:type rdf:Property ;
    rdfs:label 'Rated Usage Id' ;
    rdfs:comment 'Unique identifier for the rated usage record. Primary key for the rated usage entity.' ;
    rdfs:domain ind:RatedUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:appliedSurchargeId rdf:type rdf:Property ;
    rdfs:label 'Applied Surcharge Id' ;
    rdfs:comment 'Foreign key linking to billing.surcharge. Business justification: Rated usage records capture priced usage events with fuel_surcharge_amount, environmental_fee_amount, and other_surcharge_amount. Adding applied_surcharge_id FK links to the surcharge master definitio' ;
    rdfs:domain ind:RatedUsage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Surcharge .

ind:contractServiceCommitmentId rdf:type rdf:Property ;
    rdfs:label 'Contract Service Commitment Id' ;
    rdfs:comment 'Foreign key linking to contract.service_commitment. Business justification: Rated usage must reference the service commitment that defines rate schedule, service frequency, and overage thresholds. Critical for tiered pricing application, minimum commitment true-ups, variance ' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContractServiceCommitment .

ind:primaryRatedEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Rated Employee Id' ;
    rdfs:comment 'User ID of the billing analyst who performed the manual override. Null for non-overridden records. Supports SOX compliance and audit requirements.' ;
    rdfs:domain ind:RatedUsage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:usageEventId rdf:type rdf:Property ;
    rdfs:label 'Usage Event Id' ;
    rdfs:comment 'Reference to the raw usage event that was rated. Links this rated record back to the originating operational usage event (pickup, tonnage, container rental day, etc.).' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UsageEvent .

ind:baseChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Base Charge Amount' ;
    rdfs:comment 'Calculated charge amount before surcharges, fees, and taxes. Computed as usage_quantity multiplied by unit_rate.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Environmental Fee Amount' ;
    rdfs:comment 'Regulatory or operational environmental fee applied to the usage. May include host community fees, state environmental fees, or landfill closure fees.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelSurchargeAmount rdf:type rdf:Property ;
    rdfs:label 'Fuel Surcharge Amount' ;
    rdfs:comment 'Additional charge applied to cover fuel cost fluctuations. Calculated based on fuel surcharge rate schedule and usage quantity.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceLineNumber rdf:type rdf:Property ;
    rdfs:label 'Invoice Line Number' ;
    rdfs:comment 'Line number on the invoice where this rated usage appears. Null if not yet invoiced. Enables traceability from invoice back to rated usage.' ;
    rdfs:domain ind:RatedUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:otherSurchargeAmount rdf:type rdf:Property ;
    rdfs:label 'Other Surcharge Amount' ;
    rdfs:comment 'Additional surcharges not categorized as fuel or environmental. May include administrative fees, special handling charges, or regulatory compliance fees.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overrideFlag rdf:type rdf:Property ;
    rdfs:label 'Override Flag' ;
    rdfs:comment 'Indicates whether this rated usage was manually overridden by a billing analyst. True if rates or amounts were manually adjusted, false for standard rating engine output.' ;
    rdfs:domain ind:RatedUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overrideReasonCode rdf:type rdf:Property ;
    rdfs:label 'Override Reason Code' ;
    rdfs:comment 'Reason code for manual override if override_flag is true. Null for non-overridden records. Supports audit trail and dispute resolution.' ;
    rdfs:domain ind:RatedUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideTimestamp rdf:type rdf:Property ;
    rdfs:label 'Override Timestamp' ;
    rdfs:comment 'Date and time when the manual override was performed. Null for non-overridden records.' ;
    rdfs:domain ind:RatedUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ratedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Rated Timestamp' ;
    rdfs:comment 'Date and time when the rating engine processed and priced this usage event. Represents the rating execution time, not the usage occurrence time.' ;
    rdfs:domain ind:RatedUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ratingBatchReference rdf:type rdf:Property ;
    rdfs:label 'Rating Batch Reference' ;
    rdfs:comment 'Identifier for the rating engine batch run that processed this usage event. Supports reprocessing and audit trail.' ;
    rdfs:domain ind:RatedUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingErrorCode rdf:type rdf:Property ;
    rdfs:label 'Rating Error Code' ;
    rdfs:comment 'Error code if rating failed or encountered issues. Null for successfully rated records. Used for troubleshooting and reprocessing.' ;
    rdfs:domain ind:RatedUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingErrorMessage rdf:type rdf:Property ;
    rdfs:label 'Rating Error Message' ;
    rdfs:comment 'Detailed error message describing why rating failed or what issue was encountered. Null for successfully rated records.' ;
    rdfs:domain ind:RatedUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingStatus rdf:type rdf:Property ;
    rdfs:label 'Rating Status' ;
    rdfs:comment 'Current status of the rating process for this usage event. Indicates whether rating completed successfully or requires intervention.' ;
    rdfs:domain ind:RatedUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceTypeCode rdf:type rdf:Property ;
    rdfs:label 'Service Type Code' ;
    rdfs:comment 'Type of waste management service for which usage was rated. Categorizes the billable service line.' ;
    rdfs:domain ind:RatedUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Total Charge Amount' ;
    rdfs:comment 'Final billable amount for this rated usage event. Sum of subtotal_amount and tax_amount. This is the amount that will appear on the customer invoice.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usageDate rdf:type rdf:Property ;
    rdfs:label 'Usage Date' ;
    rdfs:comment 'Date when the actual usage event occurred (pickup date, disposal date, rental day). Business event date for revenue recognition and reporting.' ;
    rdfs:domain ind:RatedUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:usageQuantity rdf:type rdf:Property ;
    rdfs:label 'Usage Quantity' ;
    rdfs:comment 'Measured quantity of usage that was rated. Value depends on usage type: number of pickups, tons of waste, days of container rental, etc.' ;
    rdfs:domain ind:RatedUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usageTypeCode rdf:type rdf:Property ;
    rdfs:label 'Usage Type Code' ;
    rdfs:comment 'Classification of the usage event being rated. Distinguishes between different billable usage categories (pickups, weight-based, time-based, fees).' ;
    rdfs:domain ind:RatedUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRecognitionId rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Id' ;
    rdfs:comment 'Primary key for revenue_recognition' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalRecognitionEventRevenueRecognitionId rdf:type rdf:Property ;
    rdfs:label 'Original Recognition Event Revenue Recognition Id' ;
    rdfs:comment 'Reference to the original revenue recognition event if this record is a reversal or adjustment. Null for original recognition events.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RevenueRecognition .

ind:performanceObligationId rdf:type rdf:Property ;
    rdfs:label 'Performance Obligation Id' ;
    rdfs:comment 'Reference to the specific performance obligation within the contract that this revenue recognition satisfies.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PerformanceObligation .

ind:accountingDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Accounting Document Number' ;
    rdfs:comment 'The SAP FI accounting document number generated for this revenue recognition posting.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessUnit rdf:type rdf:Property ;
    rdfs:label 'Business Unit' ;
    rdfs:comment 'The business unit or division generating this revenue (e.g., Residential Services, Commercial Services, Recycling Operations).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionPercentage rdf:type rdf:Property ;
    rdfs:label 'Completion Percentage' ;
    rdfs:comment 'The percentage of performance obligation completion for percentage-of-completion recognition method. Value between 0.00 and 100.00.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deferredAmount rdf:type rdf:Property ;
    rdfs:label 'Deferred Amount' ;
    rdfs:comment 'The amount of revenue deferred to future periods because performance obligations have not yet been satisfied. Represents unearned revenue liability.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recognitionDate rdf:type rdf:Property ;
    rdfs:label 'Recognition Date' ;
    rdfs:comment 'The date on which revenue is recognized in the general ledger according to GAAP/IFRS standards.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recognitionMethod rdf:type rdf:Property ;
    rdfs:label 'Recognition Method' ;
    rdfs:comment 'The method used to recognize revenue according to ASC 606 / IFRS 15 standards. Point-in-time for single service events, over-time for ongoing services, percentage-of-completion for long-term contracts.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognitionPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Recognition Period End Date' ;
    rdfs:comment 'The end date of the period over which revenue is recognized for over-time recognition methods.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recognitionPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Recognition Period Start Date' ;
    rdfs:comment 'The start date of the period over which revenue is recognized for over-time recognition methods.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recognitionStatus rdf:type rdf:Property ;
    rdfs:label 'Recognition Status' ;
    rdfs:comment 'Current status of the revenue recognition event in the revenue lifecycle: pending approval, recognized and posted, deferred to future period, reversed, or adjusted.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognizedAmount rdf:type rdf:Property ;
    rdfs:label 'Recognized Amount' ;
    rdfs:comment 'The amount of revenue recognized in this event, posted to the general ledger. Represents earned revenue per GAAP/IFRS standards.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueCategory rdf:type rdf:Property ;
    rdfs:label 'Revenue Category' ;
    rdfs:comment 'The category of waste service revenue being recognized: collection (pickup services), disposal (landfill fees), recycling (MRF processing), rental (container leases), tipping fees, or hauling (transportation).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueStreamType rdf:type rdf:Property ;
    rdfs:label 'Revenue Stream Type' ;
    rdfs:comment 'The billing model driving this revenue: subscription (recurring monthly), transactional (per-event), usage-based (tonnage/pickups), fixed fee, or variable fee.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Service Delivery Date' ;
    rdfs:comment 'The date on which the underlying waste service was delivered or performed, triggering revenue recognition eligibility.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:serviceLine rdf:type rdf:Property ;
    rdfs:label 'Service Line' ;
    rdfs:comment 'The business service line generating the revenue: residential waste collection, commercial services, industrial accounts, municipal contracts, or hazardous waste handling.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxControlFlag rdf:type rdf:Property ;
    rdfs:label 'Sox Control Flag' ;
    rdfs:comment 'Flag indicating whether this revenue recognition event is subject to SOX internal control testing and audit requirements.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transactionPrice rdf:type rdf:Property ;
    rdfs:label 'Transaction Price' ;
    rdfs:comment 'The total consideration allocated to this performance obligation under the contract, representing the expected payment amount.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unbilledAmount rdf:type rdf:Property ;
    rdfs:label 'Unbilled Amount' ;
    rdfs:comment 'The amount of revenue recognized but not yet invoiced to the customer. Represents contract asset or accrued revenue.' ;
    rdfs:domain ind:RevenueRecognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emissionFactorId rdf:type rdf:Property ;
    rdfs:label 'Emission Factor Id' ;
    rdfs:comment 'Foreign key linking to sustainability.emission_factor. Business justification: Fuel and environmental surcharges must be calculated using documented emission factors for regulatory compliance and customer transparency. Links surcharge rates to emission factor methodology, enabli' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EmissionFactor .

ind:surchargeCreatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Surcharge Created By User Employee Id' ;
    rdfs:comment 'Identifier of the user who created this surcharge definition record. Part of audit trail.' ;
    rdfs:domain ind:Surcharge ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:surchargeEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Surcharge Employee Id' ;
    rdfs:comment 'Identifier of the user who approved this surcharge definition for use in billing. Populated when approval_required is True and surcharge has been approved.' ;
    rdfs:domain ind:Surcharge ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:surchargeLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Surcharge Last Modified By User Employee Id' ;
    rdfs:comment 'Identifier of the user who last modified this surcharge definition record. Part of audit trail.' ;
    rdfs:domain ind:Surcharge ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:applicabilityCustomerType rdf:type rdf:Property ;
    rdfs:label 'Applicability Customer Type' ;
    rdfs:comment 'Pipe-separated list of customer types to which this surcharge applies (e.g., residential|commercial|industrial|municipal). Empty if applicable to all customer types. [ENUM-REF-CANDIDATE: residential|commercial|industrial|municipal|government|non_profit|construction — promote to reference product]' ;
    rdfs:domain ind:Surcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicabilityGeography rdf:type rdf:Property ;
    rdfs:label 'Applicability Geography' ;
    rdfs:comment 'Geographic scope where this surcharge applies. Can be state code, county name, city name, ZIP code range, or service district code. Empty if applicable to all geographies.' ;
    rdfs:domain ind:Surcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicabilityServiceType rdf:type rdf:Property ;
    rdfs:label 'Applicability Service Type' ;
    rdfs:comment 'Pipe-separated list of service types to which this surcharge applies (e.g., collection|disposal|recycling|hazardous_waste|roll_off). Empty if applicable to all service types. [ENUM-REF-CANDIDATE: collection|disposal|recycling|hazardous_waste|roll_off|compactor|special_waste|medical_waste — promote to reference product]' ;
    rdfs:domain ind:Surcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicabilityWasteType rdf:type rdf:Property ;
    rdfs:label 'Applicability Waste Type' ;
    rdfs:comment 'Pipe-separated list of waste types to which this surcharge applies (e.g., MSW|C&D|hazardous|medical|e_waste). Empty if applicable to all waste types. MSW = Municipal Solid Waste, C&D = Construction and Demolition Waste.' ;
    rdfs:domain ind:Surcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculationBasis rdf:type rdf:Property ;
    rdfs:label 'Calculation Basis' ;
    rdfs:comment 'Method used to calculate the surcharge amount: percentage_of_base (percentage of base service charge), flat_fee (fixed dollar amount), per_ton (rate per ton of waste), per_yard (rate per cubic yard), per_pickup (rate per pickup event), per_container (rate per container), tiered (tiered rate structure), formula (custom formula-based calculation). [ENUM-REF-CANDIDATE: percentage_of_base|flat_fee|per_ton|per_yard|per_pickup|per_container|tiered|formula — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Surcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceDescription rdf:type rdf:Property ;
    rdfs:label 'Invoice Description' ;
    rdfs:comment 'Customer-facing description of the surcharge as it appears on invoices. May differ from internal surcharge_name to provide clearer customer communication.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceDisplayOrder rdf:type rdf:Property ;
    rdfs:label 'Invoice Display Order' ;
    rdfs:comment 'Numeric sequence order in which this surcharge should appear on customer invoices. Lower numbers appear first. Used to control invoice line item presentation.' ;
    rdfs:domain ind:Surcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isProrated rdf:type rdf:Property ;
    rdfs:label 'Is Prorated' ;
    rdfs:comment 'Indicates whether this surcharge should be prorated for partial billing periods (e.g., mid-month service start/stop). True if prorated, False if charged in full regardless of period.' ;
    rdfs:domain ind:Surcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRecurring rdf:type rdf:Property ;
    rdfs:label 'Is Recurring' ;
    rdfs:comment 'Indicates whether this surcharge is applied on a recurring basis (e.g., monthly fuel surcharge) or is a one-time charge. True if recurring, False if one-time.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRegulatoryMandated rdf:type rdf:Property ;
    rdfs:label 'Is Regulatory Mandated' ;
    rdfs:comment 'Indicates whether this surcharge is mandated by regulatory authority (EPA, state environmental agency, local solid waste authority) or is a discretionary business charge. True if regulatory-mandated, False if discretionary.' ;
    rdfs:domain ind:Surcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTaxable rdf:type rdf:Property ;
    rdfs:label 'Is Taxable' ;
    rdfs:comment 'Indicates whether this surcharge is subject to sales tax or other applicable taxes. True if taxable, False if tax-exempt.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recurrenceFrequency rdf:type rdf:Property ;
    rdfs:label 'Recurrence Frequency' ;
    rdfs:comment 'Frequency at which this surcharge recurs: monthly (every month), quarterly (every quarter), annually (every year), per_service (each service event), one_time (single occurrence). Populated only when is_recurring is True.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAuthority rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority' ;
    rdfs:comment 'Name of the regulatory body or authority that mandates this surcharge (e.g., EPA, California Department of Resources Recycling and Recovery, Local Enforcement Agency). Populated only when is_regulatory_mandated is True.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surchargeCode rdf:type rdf:Property ;
    rdfs:label 'Surcharge Code' ;
    rdfs:comment 'Unique business identifier code for the surcharge (e.g., FUEL_SUR, ENV_FEE, REG_REC, ADMIN_FEE, LATE_PAY). Used in billing systems and customer communications.' ;
    rdfs:domain ind:Surcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surchargeName rdf:type rdf:Property ;
    rdfs:label 'Surcharge Name' ;
    rdfs:comment 'Full descriptive name of the surcharge as it appears on customer invoices (e.g., Fuel Surcharge, Environmental Fee, Regulatory Recovery Fee, Administrative Fee, Late Payment Fee).' ;
    rdfs:domain ind:Surcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surchargeStatus rdf:type rdf:Property ;
    rdfs:label 'Surcharge Status' ;
    rdfs:comment 'Current lifecycle status of the surcharge definition: active (currently in use), inactive (not in use), pending (approved but not yet effective), expired (past effective end date), suspended (temporarily disabled).' ;
    rdfs:domain ind:Surcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surchargeType rdf:type rdf:Property ;
    rdfs:label 'Surcharge Type' ;
    rdfs:comment 'Classification of the surcharge by business purpose: fuel (fuel cost recovery), environmental (environmental compliance fees), regulatory (regulatory recovery fees), administrative (administrative processing fees), late_payment (late payment penalties), disposal (special disposal fees), contamination (contamination processing fees), distance (distance-based fees), special_handling (special handling fees), other (miscellaneous surcharges). [ENUM-REF-CANDIDATE: fuel|environmental|regulatory|administrative|late_payment|disposal|contamination|distance|special_handling|other — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Surcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryTaxEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Tax Employee Id' ;
    rdfs:comment 'Identifier of the user who approved this tax rule configuration for production use.' ;
    rdfs:domain ind:TaxRule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:supersededByRuleTaxRuleId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Rule Tax Rule Id' ;
    rdfs:comment 'Identifier of the tax rule that replaces this rule when it expires or is updated, maintaining audit trail of rule changes.' ;
    rdfs:domain ind:TaxRule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TaxRule .

ind:applicableServiceTypes rdf:type rdf:Property ;
    rdfs:label 'Applicable Service Types' ;
    rdfs:comment 'Comma-separated list of waste management service types to which this tax rule applies (e.g., residential collection, commercial hauling, landfill disposal, recycling, hazardous waste). [ENUM-REF-CANDIDATE: residential_collection|commercial_collection|landfill_disposal|recycling|hazardous_waste|transfer_station|waste_to_energy|rolloff_service — promote to reference product]' ;
    rdfs:domain ind:TaxRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compoundingSequence rdf:type rdf:Property ;
    rdfs:label 'Compounding Sequence' ;
    rdfs:comment 'Order in which this tax is applied when multiple taxes compound on each other. Lower numbers are applied first.' ;
    rdfs:domain ind:TaxRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:customerTypeApplicability rdf:type rdf:Property ;
    rdfs:label 'Customer Type Applicability' ;
    rdfs:comment 'Customer segments to which this tax rule applies (all, residential, commercial, industrial, municipal, government).' ;
    rdfs:domain ind:TaxRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exemptionCategories rdf:type rdf:Property ;
    rdfs:label 'Exemption Categories' ;
    rdfs:comment 'Comma-separated list of exemption categories that exclude customers or transactions from this tax (e.g., nonprofit, government, recycling-only, tax-exempt certificate holders).' ;
    rdfs:domain ind:TaxRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exemptionCertificateRequired rdf:type rdf:Property ;
    rdfs:label 'Exemption Certificate Required' ;
    rdfs:comment 'Indicates whether a valid tax exemption certificate must be on file to apply the exemption (True/False).' ;
    rdfs:domain ind:TaxRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:flatFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Flat Fee Amount' ;
    rdfs:comment 'Fixed dollar amount charged per transaction or unit when tax is assessed as a flat fee rather than a percentage rate.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:jurisdictionCounty rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction County' ;
    rdfs:comment 'County name where the tax rule applies, if applicable to county-level taxation.' ;
    rdfs:domain ind:TaxRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionMunicipality rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Municipality' ;
    rdfs:comment 'City or municipality name where the tax rule applies, if applicable to municipal-level taxation.' ;
    rdfs:domain ind:TaxRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionPostalCode rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Postal Code' ;
    rdfs:comment 'ZIP or ZIP+4 postal code defining the geographic boundary for tax applicability, used for address-based tax determination.' ;
    rdfs:domain ind:TaxRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionState rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction State' ;
    rdfs:comment 'Two-letter state code where the tax rule applies (ISO 3166-2:US format).' ;
    rdfs:domain ind:TaxRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Tax Amount' ;
    rdfs:comment 'Maximum tax amount cap per transaction or billing period, limiting tax liability for high-value transactions.' ;
    rdfs:domain ind:TaxRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Tax Amount' ;
    rdfs:comment 'Minimum tax amount to be charged regardless of calculated tax, ensuring a floor for tax collection.' ;
    rdfs:domain ind:TaxRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remittanceDueDay rdf:type rdf:Property ;
    rdfs:label 'Remittance Due Day' ;
    rdfs:comment 'Day of the month (1-31) or days after period end when tax remittance payment is due to the authority.' ;
    rdfs:domain ind:TaxRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:remittanceFrequency rdf:type rdf:Property ;
    rdfs:label 'Remittance Frequency' ;
    rdfs:comment 'Frequency at which collected taxes must be remitted to the tax authority: monthly, quarterly, annually, or on-demand.' ;
    rdfs:domain ind:TaxRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingCode rdf:type rdf:Property ;
    rdfs:label 'Reporting Code' ;
    rdfs:comment 'Code used for regulatory tax reporting and filing with state or local authorities (e.g., sales tax jurisdiction code, waste tax category code).' ;
    rdfs:domain ind:TaxRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleCode rdf:type rdf:Property ;
    rdfs:label 'Rule Code' ;
    rdfs:comment 'Business identifier code for the tax rule, used for external reference and system integration.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleDescription rdf:type rdf:Property ;
    rdfs:label 'Rule Description' ;
    rdfs:comment 'Detailed description of the tax rule including applicability conditions, exemptions, and business context.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleName rdf:type rdf:Property ;
    rdfs:label 'Rule Name' ;
    rdfs:comment 'Descriptive name of the tax rule for business user identification and reporting purposes.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleStatus rdf:type rdf:Property ;
    rdfs:label 'Rule Status' ;
    rdfs:comment 'Current lifecycle status of the tax rule: draft, pending approval, active, suspended, expired, or superseded.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxAuthorityCode rdf:type rdf:Property ;
    rdfs:label 'Tax Authority Code' ;
    rdfs:comment 'Standardized code identifying the tax authority (e.g., state FIPS code, county code, municipality tax ID).' ;
    rdfs:domain ind:TaxRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Tax Authority Name' ;
    rdfs:comment 'Name of the governmental entity or tax authority imposing the tax (e.g., State of California, Cook County, City of Houston).' ;
    rdfs:domain ind:TaxRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxAuthorityType rdf:type rdf:Property ;
    rdfs:label 'Tax Authority Type' ;
    rdfs:comment 'Level of government or jurisdiction imposing the tax (state, county, municipality, special district, federal, tribal).' ;
    rdfs:domain ind:TaxRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxBase rdf:type rdf:Property ;
    rdfs:label 'Tax Base' ;
    rdfs:comment 'The base amount or unit upon which the tax is calculated: gross invoice amount, net amount after discounts, tonnage disposed, number of pickups, container count, or service days.' ;
    rdfs:domain ind:TaxRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxRate rdf:type rdf:Property ;
    rdfs:label 'Tax Rate' ;
    rdfs:comment 'Tax rate expressed as a decimal (e.g., 0.0825 for 8.25% tax rate). Supports up to six decimal places for precision.' ;
    rdfs:domain ind:TaxRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Tax Rate Percentage' ;
    rdfs:comment 'Tax rate expressed as a percentage (e.g., 8.25 for 8.25% tax). Used for display and reporting purposes.' ;
    rdfs:domain ind:TaxRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxType rdf:type rdf:Property ;
    rdfs:label 'Tax Type' ;
    rdfs:comment 'Category of tax being applied: sales tax, excise tax, solid waste tax, environmental surcharge, tipping fee tax, or franchise fee.' ;
    rdfs:domain ind:TaxRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteStreamApplicability rdf:type rdf:Property ;
    rdfs:label 'Waste Stream Applicability' ;
    rdfs:comment 'Types of waste streams subject to this tax rule (e.g., MSW, C&D, hazardous, recyclable materials). Municipal Solid Waste (MSW), Construction and Demolition (C&D) waste classification.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerRfidScanId rdf:type rdf:Property ;
    rdfs:label 'Container Rfid Scan Id' ;
    rdfs:comment 'Foreign key linking to collection.container_rfid_scan. Business justification: RFID-based billing systems generate usage events from container scans; direct link provides proof-of-service, timestamp validation, and lift confirmation for automated billing and dispute resolution.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContainerRfidScan .

ind:inboundLoadId rdf:type rdf:Property ;
    rdfs:label 'Inbound Load Id' ;
    rdfs:comment 'Foreign key linking to recycling.inbound_load. Business justification: Inbound loads at MRFs generate billable tipping fee usage events. Real-world MRF operations require linking usage events to source loads for revenue reconciliation, dispute resolution, and contaminati' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InboundLoad .

ind:billableQuantity rdf:type rdf:Property ;
    rdfs:label 'Billable Quantity' ;
    rdfs:comment 'Normalized quantity used for rating and billing, expressed in the unit_of_measure. May differ from raw measurement due to rounding, minimums, or contractual adjustments.' ;
    rdfs:domain ind:UsageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingStatus rdf:type rdf:Property ;
    rdfs:label 'Billing Status' ;
    rdfs:comment 'Current lifecycle status of the usage event in the billing workflow: unbilled (captured but not yet rated), rated (charge calculated), billed (included in invoice), excluded (non-billable), disputed (under review), reversed (charge reversed).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventDate rdf:type rdf:Property ;
    rdfs:label 'Event Date' ;
    rdfs:comment 'Calendar date of the service event, used for daily billing aggregation and reporting. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eventNumber rdf:type rdf:Property ;
    rdfs:label 'Event Number' ;
    rdfs:comment 'Externally-visible unique business identifier for the usage event, often printed on scale tickets or BOL documents.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityPickups rdf:type rdf:Property ;
    rdfs:label 'Quantity Pickups' ;
    rdfs:comment 'Number of discrete pickup actions performed during this event (typically 1 for standard collection, may be higher for multi-container stops).' ;
    rdfs:domain ind:UsageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ratingExceptionCode rdf:type rdf:Property ;
    rdfs:label 'Rating Exception Code' ;
    rdfs:comment 'Code indicating any exception or issue encountered during the rating process (e.g., MISSING_RATE, INVALID_QUANTITY, MANUAL_OVERRIDE). Empty if rating was successful.' ;
    rdfs:domain ind:UsageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingExceptionDescription rdf:type rdf:Property ;
    rdfs:label 'Rating Exception Description' ;
    rdfs:comment 'Human-readable description of the rating exception, if any occurred during charge calculation.' ;
    rdfs:domain ind:UsageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Rating Timestamp' ;
    rdfs:comment 'Date and time when the usage event was rated and charges were calculated. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:UsageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:revenueRecognitionStatus rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Status' ;
    rdfs:comment 'Status of revenue recognition for this usage event under GAAP/IFRS standards: pending (not yet recognized), recognized (posted to GL), deferred (recognition delayed), reversed (recognition reversed).' ;
    rdfs:domain ind:UsageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfidTagNumber rdf:type rdf:Property ;
    rdfs:label 'Rfid Tag Number' ;
    rdfs:comment 'RFID tag identifier read from the container at time of service, used for automated container tracking.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ticketNumber rdf:type rdf:Property ;
    rdfs:label 'Ticket Number' ;
    rdfs:comment 'Scale ticket number, BOL (Bill of Lading) number, or field service ticket number associated with this usage event.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeCubicYards rdf:type rdf:Property ;
    rdfs:label 'Volume Cubic Yards' ;
    rdfs:comment 'Volume of material collected, measured in cubic yards. Used for roll-off containers and volumetric billing.' ;
    rdfs:domain ind:UsageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightTons rdf:type rdf:Property ;
    rdfs:label 'Weight Tons' ;
    rdfs:comment 'Weight of material collected or disposed, measured in tons. Captured from scale systems at landfills, transfer stations, or onboard truck scales.' ;
    rdfs:domain ind:UsageEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:writeOffId rdf:type rdf:Property ;
    rdfs:label 'Write Off Id' ;
    rdfs:comment 'Unique identifier for the accounts receivable write-off record. Primary key.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:finalCollectionActionId rdf:type rdf:Property ;
    rdfs:label 'Final Collection Action Id' ;
    rdfs:comment 'Foreign key linking to billing.collection_action. Business justification: Write-offs occur after collection efforts are exhausted. Write_off table has collection_attempts_count and last_collection_action_date but no FK to the actual collection_action records. Adding final_c' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CollectionAction .

ind:primaryWriteEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Write Employee Id' ;
    rdfs:comment 'Reference to the user who approved the write-off. Required for SOX segregation of duties compliance. Links to the user/employee who has write-off approval authority.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryWriteLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Write Last Modified By User Employee Id' ;
    rdfs:comment 'Reference to the user who last modified this write-off record. Used for change accountability and SOX compliance.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:approvalAuthorityLevel rdf:type rdf:Property ;
    rdfs:label 'Approval Authority Level' ;
    rdfs:comment 'The organizational level of the approver. Values: supervisor (up to $1K), manager (up to $10K), director (up to $50K), vp (up to $250K), cfo (over $250K). Ensures write-offs are approved at appropriate authority level per dollar thresholds.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionAttemptsCount rdf:type rdf:Property ;
    rdfs:label 'Collection Attempts Count' ;
    rdfs:comment 'Total number of collection attempts made before the write-off decision. Demonstrates due diligence for SOX compliance.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:daysPastDueAtWriteOff rdf:type rdf:Property ;
    rdfs:label 'Days Past Due At Write Off' ;
    rdfs:comment 'Number of days the invoice was past due at the time of write-off. Used for aging analysis and collection effectiveness metrics.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:glArContraAccount rdf:type rdf:Property ;
    rdfs:label 'Gl Ar Contra Account' ;
    rdfs:comment 'The GL contra account code used to reduce the AR balance. Paired with bad debt expense account for double-entry accounting.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glBadDebtExpenseAccount rdf:type rdf:Property ;
    rdfs:label 'Gl Bad Debt Expense Account' ;
    rdfs:comment 'The GL account code to which the bad debt expense is posted. Used for financial statement reporting and GAAP compliance.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalInvoiceAmount rdf:type rdf:Property ;
    rdfs:label 'Original Invoice Amount' ;
    rdfs:comment 'The original total amount of the invoice(s) before any payments or adjustments. Provides context for the write-off magnitude.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outstandingBalanceBeforeWriteOff rdf:type rdf:Property ;
    rdfs:label 'Outstanding Balance Before Write Off' ;
    rdfs:comment 'The AR balance outstanding immediately before the write-off was applied. Used for reconciliation and audit purposes.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:writeOffDate rdf:type rdf:Property ;
    rdfs:label 'Write Off Date' ;
    rdfs:comment 'The date on which the AR balance was officially written off as uncollectible bad debt. Used for financial reporting and GAAP revenue recognition.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:writeOffNumber rdf:type rdf:Property ;
    rdfs:label 'Write Off Number' ;
    rdfs:comment 'Business-facing unique identifier for the write-off transaction. Format: WO-NNNNNNNN. Used for audit trails and external references.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:writeOffStatus rdf:type rdf:Property ;
    rdfs:label 'Write Off Status' ;
    rdfs:comment 'Current status of the write-off record. Values: written_off (initial write-off recorded), partially_recovered (some amount recovered post-write-off), fully_recovered (entire amount recovered), reversed (write-off reversed due to error or policy change).' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:writeOffTimestamp rdf:type rdf:Property ;
    rdfs:label 'Write Off Timestamp' ;
    rdfs:comment 'Precise timestamp when the write-off transaction was recorded in the system. Used for audit trails and SOX compliance.' ;
    rdfs:domain ind:WriteOff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:compactionMeasurementId rdf:type rdf:Property ;
    rdfs:label 'Compaction Measurement Id' ;
    rdfs:comment 'Primary key for compaction_measurement' ;
    rdfs:domain ind:CompactionMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:routeExecutionId rdf:type rdf:Property ;
    rdfs:label 'Route Execution Id' ;
    rdfs:comment 'Reference to the specific route execution during which this compaction measurement was captured.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RouteExecution .

ind:shiftLogId rdf:type rdf:Property ;
    rdfs:label 'Shift Log Id' ;
    rdfs:comment 'Identifier of the operational shift during which this measurement was recorded.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ShiftLog .

ind:ambientTemperatureFahrenheit rdf:type rdf:Property ;
    rdfs:label 'Ambient Temperature Fahrenheit' ;
    rdfs:comment 'Ambient air temperature at measurement time in Fahrenheit, which can affect waste density and compaction efficiency.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:anomalyReason rdf:type rdf:Property ;
    rdfs:label 'Anomaly Reason' ;
    rdfs:comment 'Explanation of why this measurement was flagged as an anomaly, if applicable. Null for valid measurements.' ;
    rdfs:domain ind:CompactionMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compactionCyclesCount rdf:type rdf:Property ;
    rdfs:label 'Compaction Cycles Count' ;
    rdfs:comment 'Number of compaction cycles performed by the truck mechanism up to this measurement point during the route.' ;
    rdfs:domain ind:CompactionMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Data Source System' ;
    rdfs:comment 'Source system that captured and transmitted this compaction measurement record.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedVolumeCubicYards rdf:type rdf:Property ;
    rdfs:label 'Estimated Volume Cubic Yards' ;
    rdfs:comment 'Estimated volume of waste material in the truck at measurement time, expressed in cubic yards. Used to calculate compaction ratio.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossWeightTons rdf:type rdf:Property ;
    rdfs:label 'Gross Weight Tons' ;
    rdfs:comment 'Total combined weight of truck and payload in tons at measurement time.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hydraulicPressurePsi rdf:type rdf:Property ;
    rdfs:label 'Hydraulic Pressure Psi' ;
    rdfs:comment 'Hydraulic system pressure in pounds per square inch at measurement time, indicating compaction mechanism performance.' ;
    rdfs:domain ind:CompactionMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:loadWeightTons rdf:type rdf:Property ;
    rdfs:label 'Load Weight Tons' ;
    rdfs:comment 'Total weight of waste material loaded in the truck at the time of measurement, expressed in tons. Critical for Tons Per Day (TPD) reporting and payload optimization.' ;
    rdfs:domain ind:CompactionMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementAccuracyGrade rdf:type rdf:Property ;
    rdfs:label 'Measurement Accuracy Grade' ;
    rdfs:comment 'Quality grade of the measurement indicating reliability level. Certified measurements meet regulatory standards, calibrated are from maintained equipment, estimated use algorithms, approximate are visual assessments.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementLocationLatitude rdf:type rdf:Property ;
    rdfs:label 'Measurement Location Latitude' ;
    rdfs:comment 'Geographic latitude coordinate where the compaction measurement was captured, sourced from GPS telemetry.' ;
    rdfs:domain ind:CompactionMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementLocationLongitude rdf:type rdf:Property ;
    rdfs:label 'Measurement Location Longitude' ;
    rdfs:comment 'Geographic longitude coordinate where the compaction measurement was captured, sourced from GPS telemetry.' ;
    rdfs:domain ind:CompactionMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementNotes rdf:type rdf:Property ;
    rdfs:label 'Measurement Notes' ;
    rdfs:comment 'Free-text notes or comments about this compaction measurement, typically used to document unusual conditions or manual adjustments.' ;
    rdfs:domain ind:CompactionMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementStatus rdf:type rdf:Property ;
    rdfs:label 'Measurement Status' ;
    rdfs:comment 'Quality status of the measurement record. Valid measurements pass all validation rules, flagged require review, anomaly indicates outlier values, under review is being investigated, rejected are excluded from reporting.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netPayloadTons rdf:type rdf:Property ;
    rdfs:label 'Net Payload Tons' ;
    rdfs:comment 'Calculated net weight of waste payload only, derived by subtracting tare weight from gross weight.' ;
    rdfs:domain ind:CompactionMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payloadCapacityPercentage rdf:type rdf:Property ;
    rdfs:label 'Payload Capacity Percentage' ;
    rdfs:comment 'Percentage of the truck\'s maximum payload capacity currently utilized at measurement time. Enables truck utilization analysis and route optimization.' ;
    rdfs:domain ind:CompactionMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:routeSegmentSequence rdf:type rdf:Property ;
    rdfs:label 'Route Segment Sequence' ;
    rdfs:comment 'Sequential position of this measurement within the route execution, indicating progression through the collection route.' ;
    rdfs:domain ind:CompactionMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scaleCalibrationDate rdf:type rdf:Property ;
    rdfs:label 'Scale Calibration Date' ;
    rdfs:comment 'Date when the onboard scale used for this measurement was last calibrated, ensuring measurement accuracy and regulatory compliance.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tareWeightTons rdf:type rdf:Property ;
    rdfs:label 'Tare Weight Tons' ;
    rdfs:comment 'Empty weight of the truck in tons, used to calculate net payload weight by subtracting from gross weight.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:truckCapacityCubicYards rdf:type rdf:Property ;
    rdfs:label 'Truck Capacity Cubic Yards' ;
    rdfs:comment 'Maximum volumetric capacity of the truck body in cubic yards. Used for volume-based utilization calculations.' ;
    rdfs:domain ind:CompactionMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:truckCapacityTons rdf:type rdf:Property ;
    rdfs:label 'Truck Capacity Tons' ;
    rdfs:comment 'Maximum rated payload capacity of the collection truck in tons. Used as denominator for payload percentage calculation.' ;
    rdfs:domain ind:CompactionMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:truckType rdf:type rdf:Property ;
    rdfs:label 'Truck Type' ;
    rdfs:comment 'Type of collection vehicle. ASL is Automated Side Loader, FEL is Front End Loader, REL is Rear End Loader.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationFlag rdf:type rdf:Property ;
    rdfs:label 'Validation Flag' ;
    rdfs:comment 'Boolean indicator whether this measurement passed automated validation rules for accuracy and completeness.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:wasteType rdf:type rdf:Property ;
    rdfs:label 'Waste Type' ;
    rdfs:comment 'Type of waste material being collected and compacted. MSW is Municipal Solid Waste, C&D is Construction and Demolition waste.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerDriverId rdf:type rdf:Property ;
    rdfs:label 'Container Driver Id' ;
    rdfs:comment 'Reference to the driver who performed the container placement. Links to the workforce employee record.' ;
    rdfs:domain ind:ContainerPlacement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Driver .

ind:containerVehicleId rdf:type rdf:Property ;
    rdfs:label 'Container Vehicle Id' ;
    rdfs:comment 'Reference to the fleet vehicle used to deliver and place the container. Links to the fleet asset master record.' ;
    rdfs:domain ind:ContainerPlacement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vehicle .

ind:containerWorkOrderId rdf:type rdf:Property ;
    rdfs:label 'Container Work Order Id' ;
    rdfs:comment 'Reference to the work order that authorized and tracked the container placement activity. Links to the work order management system.' ;
    rdfs:domain ind:ContainerPlacement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkOrder .

ind:primaryContainerRemovalDriverId rdf:type rdf:Property ;
    rdfs:label 'Primary Container Removal Driver Id' ;
    rdfs:comment 'Reference to the driver who performed the container removal. Links to the workforce employee record.' ;
    rdfs:domain ind:ContainerPlacement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Driver .

ind:primaryContainerRemovalVehicleId rdf:type rdf:Property ;
    rdfs:label 'Primary Container Removal Vehicle Id' ;
    rdfs:comment 'Reference to the fleet vehicle used to remove the container. Links to the fleet asset master record.' ;
    rdfs:domain ind:ContainerPlacement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vehicle .

ind:primaryContainerRemovalWorkOrderId rdf:type rdf:Property ;
    rdfs:label 'Primary Container Removal Work Order Id' ;
    rdfs:comment 'Reference to the work order that authorized and tracked the container removal activity. Links to the work order management system.' ;
    rdfs:domain ind:ContainerPlacement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkOrder .

ind:purchaseOrderId rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Id' ;
    rdfs:comment 'Foreign key linking to procurement.purchase_order. Business justification: Container placements may be fulfilled via purchase orders for container rental or delivery services from third-party vendors. Operations reconciles placement_work_order_id against POs for billing vali' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseOrder .

ind:supervisorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Supervisor Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Container placements/removals requiring site assessment, customer coordination, or permit verification need supervisor authorization for asset accountability and customer billing accuracy.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:wasteProfileId rdf:type rdf:Property ;
    rdfs:label 'Waste Profile Id' ;
    rdfs:comment 'Foreign key linking to hazmat.waste_profile. Business justification: Hazmat container placements must match approved waste profiles to ensure proper container type, labeling, and compatibility. Prevents unauthorized waste accumulation and ensures RCRA compliance.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WasteProfile .

ind:actualRemovalDate rdf:type rdf:Property ;
    rdfs:label 'Actual Removal Date' ;
    rdfs:comment 'Actual date when the container was physically removed from the service location. Marks the end of the container assignment lifecycle.' ;
    rdfs:domain ind:ContainerPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:containerConditionAtPlacement rdf:type rdf:Property ;
    rdfs:label 'Container Condition At Placement' ;
    rdfs:comment 'Physical condition assessment of the container at the time of placement. Used for asset lifecycle tracking and maintenance planning.' ;
    rdfs:domain ind:ContainerPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerConditionAtRemoval rdf:type rdf:Property ;
    rdfs:label 'Container Condition At Removal' ;
    rdfs:comment 'Physical condition assessment of the container at the time of removal. Used for asset lifecycle tracking, maintenance planning, and loss tracking.' ;
    rdfs:domain ind:ContainerPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isTemporaryPlacement rdf:type rdf:Property ;
    rdfs:label 'Is Temporary Placement' ;
    rdfs:comment 'Flag indicating whether this is a temporary container placement (e.g., roll-off for construction project, event-based service) versus a permanent ongoing service.' ;
    rdfs:domain ind:ContainerPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:placementAccuracyMeters rdf:type rdf:Property ;
    rdfs:label 'Placement Accuracy Meters' ;
    rdfs:comment 'GPS accuracy radius in meters for the placement coordinates. Indicates the precision of the recorded location.' ;
    rdfs:domain ind:ContainerPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:placementDate rdf:type rdf:Property ;
    rdfs:label 'Placement Date' ;
    rdfs:comment 'Date when the container was physically placed at the service location. Marks the start of the container assignment lifecycle.' ;
    rdfs:domain ind:ContainerPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:placementLatitude rdf:type rdf:Property ;
    rdfs:label 'Placement Latitude' ;
    rdfs:comment 'GPS latitude coordinate of the container placement location. Used for route optimization, asset tracking, and geospatial analytics.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:placementLongitude rdf:type rdf:Property ;
    rdfs:label 'Placement Longitude' ;
    rdfs:comment 'GPS longitude coordinate of the container placement location. Used for route optimization, asset tracking, and geospatial analytics.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:placementNotes rdf:type rdf:Property ;
    rdfs:label 'Placement Notes' ;
    rdfs:comment 'Free-text notes recorded by the driver or dispatcher at the time of placement. Captures special instructions, access issues, or site-specific details.' ;
    rdfs:domain ind:ContainerPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:placementReason rdf:type rdf:Property ;
    rdfs:label 'Placement Reason' ;
    rdfs:comment 'Business reason for the container placement. Indicates whether this is a new service, replacement, additional container, temporary placement, seasonal service, or event-based service.' ;
    rdfs:domain ind:ContainerPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:placementStatus rdf:type rdf:Property ;
    rdfs:label 'Placement Status' ;
    rdfs:comment 'Current lifecycle status of the container placement. Tracks whether the container is actively in service, pending placement, pending removal, removed, relocated, damaged, or under repair. [ENUM-REF-CANDIDATE: active|pending-placement|pending-removal|removed|relocated|damaged|under-repair — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ContainerPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:removalNotes rdf:type rdf:Property ;
    rdfs:label 'Removal Notes' ;
    rdfs:comment 'Free-text notes recorded by the driver or dispatcher at the time of removal. Captures condition issues, access problems, or other relevant observations.' ;
    rdfs:domain ind:ContainerPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:removalReason rdf:type rdf:Property ;
    rdfs:label 'Removal Reason' ;
    rdfs:comment 'Business reason for the container removal. Indicates whether this is due to service termination, replacement, relocation, end of temporary service, seasonal end, customer request, non-payment, or damage. [ENUM-REF-CANDIDATE: service-termination|replacement|relocation|temporary-end|seasonal-end|customer-request|non-payment|damaged — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ContainerPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:removalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Removal Timestamp' ;
    rdfs:comment 'Precise date and time when the container was removed from the service location. Captured from GPS-enabled fleet telematics or driver mobile application.' ;
    rdfs:domain ind:ContainerPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledRemovalDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Removal Date' ;
    rdfs:comment 'Planned date for container removal from the service location. Used for temporary placements such as roll-off boxes or event-based service.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:containerSizeGallons rdf:type rdf:Property ;
    rdfs:label 'Container Size Gallons' ;
    rdfs:comment 'The volumetric capacity of the scanned container measured in gallons. Captured to support service billing verification and capacity planning.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataQualityScore rdf:type rdf:Property ;
    rdfs:label 'Data Quality Score' ;
    rdfs:comment 'A calculated score from 0.00 to 1.00 representing the overall quality and completeness of this scan record based on signal strength, GPS accuracy, and data completeness. Higher scores indicate higher quality data.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exceptionNotes rdf:type rdf:Property ;
    rdfs:label 'Exception Notes' ;
    rdfs:comment 'Free-text field for driver or system to record additional details about service exceptions, scan issues, or operational notes related to this scan event.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liftConfirmedFlag rdf:type rdf:Property ;
    rdfs:label 'Lift Confirmed Flag' ;
    rdfs:comment 'Boolean indicator confirming whether the container was physically lifted and emptied based on PTO (Power Take-Off) sensor data correlated with the RFID scan event. True indicates confirmed service completion.' ;
    rdfs:domain ind:ContainerRfidScan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:proofOfServiceFlag rdf:type rdf:Property ;
    rdfs:label 'Proof Of Service Flag' ;
    rdfs:comment 'Boolean indicator confirming this scan event serves as valid proof of service delivery for customer SLA and dispute resolution purposes. True indicates verified service completion.' ;
    rdfs:domain ind:ContainerRfidScan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ptoActivationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pto Activation Timestamp' ;
    rdfs:comment 'The timestamp when the vehicle PTO system was activated to lift and empty the container. Used to correlate RFID scan with physical service completion.' ;
    rdfs:domain ind:ContainerRfidScan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scanDate rdf:type rdf:Property ;
    rdfs:label 'Scan Date' ;
    rdfs:comment 'The calendar date of the RFID scan event, derived from scan_timestamp for simplified date-based reporting and partitioning.' ;
    rdfs:domain ind:ContainerRfidScan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scanResultStatus rdf:type rdf:Property ;
    rdfs:label 'Scan Result Status' ;
    rdfs:comment 'The outcome status of the RFID scan attempt indicating whether the tag was successfully read or if any issues occurred during the scan operation.' ;
    rdfs:domain ind:ContainerRfidScan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scanSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Scan Source System' ;
    rdfs:comment 'The operational system that originated and transmitted this RFID scan record. Identifies the data lineage and integration source.' ;
    rdfs:domain ind:ContainerRfidScan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scanTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scan Timestamp' ;
    rdfs:comment 'The precise date and time when the RFID tag was scanned by the collection vehicle reader. Represents the proof-of-service event time for this container.' ;
    rdfs:domain ind:ContainerRfidScan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledServiceTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Service Time' ;
    rdfs:comment 'The planned timestamp for servicing this container based on the route schedule. Used to calculate service timeliness and SLA compliance.' ;
    rdfs:domain ind:ContainerRfidScan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:serviceVarianceMinutes rdf:type rdf:Property ;
    rdfs:label 'Service Variance Minutes' ;
    rdfs:comment 'The difference in minutes between the scheduled service time and actual scan timestamp. Positive values indicate late service, negative values indicate early service.' ;
    rdfs:domain ind:ContainerRfidScan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:signalStrength rdf:type rdf:Property ;
    rdfs:label 'Signal Strength' ;
    rdfs:comment 'The radio frequency signal strength measured in decibels-milliwatts (dBm) at the time of the scan. Indicates the quality of the RFID tag read and can help diagnose tag or reader issues.' ;
    rdfs:domain ind:ContainerRfidScan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Compliance Flag' ;
    rdfs:comment 'Boolean indicator showing whether this scan event occurred within the contracted service window defined in the customer SLA. True indicates on-time service delivery.' ;
    rdfs:domain ind:ContainerRfidScan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceSystemTimestamp rdf:type rdf:Property ;
    rdfs:label 'Source System Timestamp' ;
    rdfs:comment 'The timestamp when this scan record was created in the originating operational system (AMCS or Geotab). Used to measure data latency and support data reconciliation.' ;
    rdfs:domain ind:ContainerRfidScan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:truckNumber rdf:type rdf:Property ;
    rdfs:label 'Truck Number' ;
    rdfs:comment 'The human-readable fleet identification number of the collection vehicle that performed the scan. Used for operational reporting and driver communication.' ;
    rdfs:domain ind:ContainerRfidScan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationFacilityId rdf:type rdf:Property ;
    rdfs:label 'Destination Facility Id' ;
    rdfs:comment 'Unique identifier for the destination facility record. Primary key.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WasteManagement .

ind:regulatedFacilityId rdf:type rdf:Property ;
    rdfs:label 'Regulated Facility Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulated_facility. Business justification: Destination facilities receiving waste from transfer stations are regulated facilities with permits and compliance obligations. Links outbound haul destinations to regulatory compliance tracking.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatedFacility .

ind:relationshipManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Relationship Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Disposal destination facilities have relationship managers for contract negotiation, rate management, service coordination, and dispute resolution—replaces denormalized facility_contact_name/phone/ema' ;
    rdfs:domain ind:DestinationFacility ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:wteFacilityId rdf:type rdf:Property ;
    rdfs:label 'Wte Facility Id' ;
    rdfs:comment 'Foreign key linking to energy.wte_facility. Business justification: Collection destination_facility lookup table lists disposal destinations including WTE plants. This link identifies which destinations are energy recovery facilities vs landfills, enabling route optim' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WteFacility .

ind:acceptedWasteStreams rdf:type rdf:Property ;
    rdfs:label 'Accepted Waste Streams' ;
    rdfs:comment 'Comma-separated list of waste stream types accepted at this destination facility (e.g., MSW, C&D, recyclables, organics, hazardous). MSW = Municipal Solid Waste, C&D = Construction and Demolition Waste.' ;
    rdfs:domain ind:DestinationFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Reference Number' ;
    rdfs:comment 'Reference number for the disposal services contract or Service Level Agreement (SLA) governing the relationship with this destination facility.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalFeePerTon rdf:type rdf:Property ;
    rdfs:label 'Environmental Fee Per Ton' ;
    rdfs:comment 'Additional environmental surcharge per ton assessed by the destination facility for regulatory compliance and environmental programs.' ;
    rdfs:domain ind:DestinationFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedTravelTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Estimated Travel Time Minutes' ;
    rdfs:comment 'Average travel time in minutes from the primary transfer station to this destination facility under normal traffic conditions.' ;
    rdfs:domain ind:DestinationFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:facilityStatus rdf:type rdf:Property ;
    rdfs:label 'Facility Status' ;
    rdfs:comment 'Current operational status of the destination facility indicating availability for receiving waste hauls.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelSurchargeApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Fuel Surcharge Applicable Flag' ;
    rdfs:comment 'Indicates whether the destination facility applies a fuel surcharge to tipping fees. True if surcharge applies, False otherwise.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:haulDistanceMiles rdf:type rdf:Property ;
    rdfs:label 'Haul Distance Miles' ;
    rdfs:comment 'Estimated road distance in miles from the primary transfer station to this destination facility, used for route optimization and cost planning.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatingHoursWeekday rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Weekday' ;
    rdfs:comment 'Standard operating hours for the destination facility on weekdays (Monday-Friday), formatted as start-end time range.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingHoursWeekend rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Weekend' ;
    rdfs:comment 'Standard operating hours for the destination facility on weekends (Saturday-Sunday), formatted as start-end time range.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Permit Expiration Date' ;
    rdfs:comment 'Date when the current operating permit expires and requires renewal to continue receiving waste.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preferredFacilityFlag rdf:type rdf:Property ;
    rdfs:label 'Preferred Facility Flag' ;
    rdfs:comment 'Indicates whether this destination facility is designated as a preferred routing target for cost or operational efficiency. True if preferred, False otherwise.' ;
    rdfs:domain ind:DestinationFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Regulatory Jurisdiction' ;
    rdfs:comment 'Name of the regulatory authority or Local Enforcement Agency (LEA) with oversight of this destination facility.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresManifestFlag rdf:type rdf:Property ;
    rdfs:label 'Requires Manifest Flag' ;
    rdfs:comment 'Indicates whether the destination facility requires hazardous waste manifests or Bills of Lading (BOL) for incoming loads. True if manifests required, False otherwise.' ;
    rdfs:domain ind:DestinationFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scaleAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Scale Available Flag' ;
    rdfs:comment 'Indicates whether the destination facility has certified scales for weighing incoming loads. True if scales are available, False otherwise.' ;
    rdfs:domain ind:DestinationFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tippingFeePerTon rdf:type rdf:Property ;
    rdfs:label 'Tipping Fee Per Ton' ;
    rdfs:comment 'Standard disposal charge per ton of waste received at the destination facility. Business-sensitive pricing information.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:districtEmployeeId rdf:type rdf:Property ;
    rdfs:label 'District Employee Id' ;
    rdfs:comment 'Unique identifier of the operations manager assigned to this district. References employee master data.' ;
    rdfs:domain ind:District ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:districtOperationsManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'District Operations Manager Employee Id' ;
    rdfs:comment 'FK to workforce.employee' ;
    rdfs:domain ind:District ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:reductionTargetId rdf:type rdf:Property ;
    rdfs:label 'Reduction Target Id' ;
    rdfs:comment 'Foreign key linking to sustainability.reduction_target. Business justification: Collection districts are operational units for carbon reduction target setting. District-level targets (e.g., 20% emission reduction by 2030) require linking to corporate sustainability targets for ca' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReductionTarget .

ind:areaSquareMiles rdf:type rdf:Property ;
    rdfs:label 'Area Square Miles' ;
    rdfs:comment 'Geographic area of the district in square miles. Used for route density analysis and operational efficiency metrics.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:collectionFrequency rdf:type rdf:Property ;
    rdfs:label 'Collection Frequency' ;
    rdfs:comment 'Standard collection frequency for this district. Values: daily, weekly, biweekly, monthly, on_demand.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commercialAccountCount rdf:type rdf:Property ;
    rdfs:label 'Commercial Account Count' ;
    rdfs:comment 'Number of commercial customer accounts served in this district. Used for route planning and revenue forecasting.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:containerTypeSupported rdf:type rdf:Property ;
    rdfs:label 'Container Type Supported' ;
    rdfs:comment 'Types of waste containers supported in this district (e.g., \'96-gallon cart, 2-yard dumpster, 8-yard compactor\'). Comma-separated list.' ;
    rdfs:domain ind:District ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depotLocation rdf:type rdf:Property ;
    rdfs:label 'Depot Location' ;
    rdfs:comment 'Name or identifier of the primary depot or yard location that services this district.' ;
    rdfs:domain ind:District ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:districtCode rdf:type rdf:Property ;
    rdfs:label 'District Code' ;
    rdfs:comment 'Business identifier code for the collection district used in operational systems and reporting. Typically alphanumeric, 2-10 characters.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:districtName rdf:type rdf:Property ;
    rdfs:label 'District Name' ;
    rdfs:comment 'Human-readable name of the collection district (e.g., \'North Metro District\', \'Downtown Commercial Zone\').' ;
    rdfs:domain ind:District ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:districtStatus rdf:type rdf:Property ;
    rdfs:label 'District Status' ;
    rdfs:comment 'Current operational status of the district. Values: active (currently serviced), inactive (no longer serviced), planned (future service area), suspended (temporarily not serviced).' ;
    rdfs:domain ind:District ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diversionRateTarget rdf:type rdf:Property ;
    rdfs:label 'Diversion Rate Target' ;
    rdfs:comment 'Target percentage of waste diverted from landfill through recycling, composting, and other programs. Expressed as a percentage (0.00 to 100.00).' ;
    rdfs:domain ind:District ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:endTime rdf:type rdf:Property ;
    rdfs:label 'End Time' ;
    rdfs:comment 'Standard end time for collection operations in this district (HH:MM format, 24-hour clock).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:expirationDate rdf:type rdf:Property ;
    rdfs:label 'Expiration Date' ;
    rdfs:comment 'Date when this district configuration expires or is scheduled to be deactivated. Null if no expiration is planned.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fuelType rdf:type rdf:Property ;
    rdfs:label 'Fuel Type' ;
    rdfs:comment 'Primary fuel type used by collection vehicles in this district. Values: diesel, compressed_natural_gas (CNG), renewable_natural_gas (RNG), electric, hybrid.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicBoundaryDescription rdf:type rdf:Property ;
    rdfs:label 'Geographic Boundary Description' ;
    rdfs:comment 'Textual description of the geographic boundaries of the district (e.g., \'Bounded by Main St to the north, Highway 101 to the south\').' ;
    rdfs:domain ind:District ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatCollectionAllowed rdf:type rdf:Property ;
    rdfs:label 'Hazmat Collection Allowed' ;
    rdfs:comment 'Indicates whether hazardous waste collection is permitted in this district. True if allowed, False if not. Subject to RCRA and DOT regulations.' ;
    rdfs:domain ind:District ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:householdCount rdf:type rdf:Property ;
    rdfs:label 'Household Count' ;
    rdfs:comment 'Number of residential households served in this district. Used for route planning and service level analysis.' ;
    rdfs:domain ind:District ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:jurisdiction rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction' ;
    rdfs:comment 'Regulatory jurisdiction or local enforcement agency governing this district (e.g., county, regional authority).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:municipality rdf:type rdf:Property ;
    rdfs:label 'Municipality' ;
    rdfs:comment 'Name of the municipality, city, or township that this district serves. Used for regulatory jurisdiction alignment.' ;
    rdfs:domain ind:District ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organicsProgramActive rdf:type rdf:Property ;
    rdfs:label 'Organics Program Active' ;
    rdfs:comment 'Indicates whether an organics/composting collection program is active in this district. True if active, False if not.' ;
    rdfs:domain ind:District ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:populationServed rdf:type rdf:Property ;
    rdfs:label 'Population Served' ;
    rdfs:comment 'Estimated population count served by this collection district. Used for capacity planning and regulatory reporting.' ;
    rdfs:domain ind:District ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recyclingProgramActive rdf:type rdf:Property ;
    rdfs:label 'Recycling Program Active' ;
    rdfs:comment 'Indicates whether a recycling collection program is active in this district. True if active, False if not.' ;
    rdfs:domain ind:District ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:routeCount rdf:type rdf:Property ;
    rdfs:label 'Route Count' ;
    rdfs:comment 'Number of active collection routes operating within this district. Used for resource allocation and performance tracking.' ;
    rdfs:domain ind:District ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceDays rdf:type rdf:Property ;
    rdfs:label 'Service Days' ;
    rdfs:comment 'Days of the week when collection service is provided in this district (e.g., \'Monday, Wednesday, Friday\').' ;
    rdfs:domain ind:District ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:startTime rdf:type rdf:Property ;
    rdfs:label 'Start Time' ;
    rdfs:comment 'Standard start time for collection operations in this district (HH:MM format, 24-hour clock).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:vehicleTypeRequired rdf:type rdf:Property ;
    rdfs:label 'Vehicle Type Required' ;
    rdfs:comment 'Primary type of collection vehicle required for this district. Values: automated_side_loader (ASL), front_end_loader (FEL), rear_end_loader (REL), roll_off, mixed.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zoneCode rdf:type rdf:Property ;
    rdfs:label 'Zone Code' ;
    rdfs:comment 'Sub-district zone code used for finer geographic segmentation within the district. Alphanumeric, 1-6 characters.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:driverAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Driver Assignment Id' ;
    rdfs:comment 'Unique identifier for the driver assignment record. Primary key for this transactional entity capturing the assignment of a CDL-licensed driver to a specific route execution.' ;
    rdfs:domain ind:DriverAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hazwoperTrainingId rdf:type rdf:Property ;
    rdfs:label 'Hazwoper Training Id' ;
    rdfs:comment 'Foreign key linking to hazmat.hazwoper_training. Business justification: Drivers assigned to hazmat collection routes must have current HAZWOPER certification per OSHA 1910.120. Links assignment to training verification for regulatory compliance and safety qualification.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HazwoperTraining .

ind:observationId rdf:type rdf:Property ;
    rdfs:label 'Observation Id' ;
    rdfs:comment 'Foreign key linking to safety.safety_observation. Business justification: Safety observations are made on specific driver assignments during their shift. Observers need to link observations to the assignment context (route type, vehicle, shift conditions) for meaningful beh' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Observation .

ind:primaryDriverEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Driver Employee Id' ;
    rdfs:comment 'Identifier of the helper (second crew member) assigned to assist the driver on this route execution. Links to the workforce employee master record. Null if no helper assigned.' ;
    rdfs:domain ind:DriverAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryDriverId rdf:type rdf:Property ;
    rdfs:label 'Primary Driver Id' ;
    rdfs:comment 'Identifier of the Commercial Driver License (CDL) licensed driver assigned to execute the route. Links to the driver master record in Workday HCM.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Driver .

ind:absenceReasonCode rdf:type rdf:Property ;
    rdfs:label 'Absence Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for driver absence if assignment status is absent. Sick for illness, vacation for planned time off, personal for personal leave, injury for work-related injury, no_show for unexcused absence, other for miscellaneous reasons. Null if driver reported for duty.' ;
    rdfs:domain ind:DriverAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualEndTime rdf:type rdf:Property ;
    rdfs:label 'Actual End Time' ;
    rdfs:comment 'The actual timestamp when the driver completed their shift and returned to the depot. Captured from Geotab Fleet Telematics GPS tracking or driver mobile app check-out. Used for performance analysis and variance reporting against scheduled end time.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualStartTime rdf:type rdf:Property ;
    rdfs:label 'Actual Start Time' ;
    rdfs:comment 'The actual timestamp when the driver began their shift and commenced route execution. Captured from Geotab Fleet Telematics GPS tracking or driver mobile app check-in. Used for performance analysis and variance reporting against scheduled start time.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assignmentCreatedBy rdf:type rdf:Property ;
    rdfs:label 'Assignment Created By' ;
    rdfs:comment 'Username or identifier of the dispatcher or system user who created this driver assignment record. Used for accountability and audit trail.' ;
    rdfs:domain ind:DriverAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assignment Created Timestamp' ;
    rdfs:comment 'The timestamp when this driver assignment record was first created in the Locus Dispatch system. Used for audit trail and assignment lead time analysis.' ;
    rdfs:domain ind:DriverAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assignmentModifiedBy rdf:type rdf:Property ;
    rdfs:label 'Assignment Modified By' ;
    rdfs:comment 'Username or identifier of the dispatcher or system user who last modified this driver assignment record. Used for accountability and audit trail.' ;
    rdfs:domain ind:DriverAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assignment Modified Timestamp' ;
    rdfs:comment 'The timestamp when this driver assignment record was last modified in the Locus Dispatch system. Used for audit trail and change tracking.' ;
    rdfs:domain ind:DriverAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assignmentNotes rdf:type rdf:Property ;
    rdfs:label 'Assignment Notes' ;
    rdfs:comment 'Free-text operational notes and special instructions for the driver assignment. May include route-specific guidance, customer alerts, safety warnings, or equipment requirements.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentNumber rdf:type rdf:Property ;
    rdfs:label 'Assignment Number' ;
    rdfs:comment 'Human-readable business identifier for the driver assignment, formatted as DA- followed by 10 digits. Used for operational tracking and communication.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentPriority rdf:type rdf:Property ;
    rdfs:label 'Assignment Priority' ;
    rdfs:comment 'Priority classification of the driver assignment indicating urgency and importance. Critical for time-sensitive routes or service level agreement (SLA) commitments, high for premium customers, normal for standard service, low for flexible/deferred routes.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentStatus rdf:type rdf:Property ;
    rdfs:label 'Assignment Status' ;
    rdfs:comment 'Current lifecycle status of the driver assignment. Scheduled indicates future planned assignment, active indicates driver is currently executing the route, completed indicates route execution finished, absent indicates driver did not report, cancelled indicates assignment was voided before execution.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentType rdf:type rdf:Property ;
    rdfs:label 'Assignment Type' ;
    rdfs:comment 'Classification of the driver assignment indicating the role and responsibility level. Primary indicates regular assigned driver, relief indicates substitute coverage, trainee indicates driver under training supervision, backup indicates standby assignment, temporary indicates short-term fill-in.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdlClassRequired rdf:type rdf:Property ;
    rdfs:label 'Cdl Class Required' ;
    rdfs:comment 'The minimum Commercial Driver License (CDL) class required to operate the assigned truck and execute the route. Class A for combination vehicles over 26,001 lbs, Class B for single vehicles over 26,001 lbs, Class C for vehicles designed to transport 16+ passengers or hazardous materials.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdlEndorsementsRequired rdf:type rdf:Property ;
    rdfs:label 'Cdl Endorsements Required' ;
    rdfs:comment 'Comma-separated list of CDL endorsements required for the assignment. Common endorsements include H (Hazardous Materials), N (Tank Vehicle), P (Passenger), S (School Bus), T (Double/Triple Trailers). Empty if no special endorsements required.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatchSequence rdf:type rdf:Property ;
    rdfs:label 'Dispatch Sequence' ;
    rdfs:comment 'The sequential order in which this driver assignment was dispatched from the depot on the service date. Used for operational tracking and first-out/last-in analysis.' ;
    rdfs:domain ind:DriverAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dotHosCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Dot Hos Compliant Flag' ;
    rdfs:comment 'Boolean indicator of whether the driver assignment complies with DOT hours-of-service regulations at the time of assignment. True indicates the driver has sufficient available hours and rest periods to legally execute the route, false indicates a compliance violation or risk.' ;
    rdfs:domain ind:DriverAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedRouteDurationHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Route Duration Hours' ;
    rdfs:comment 'The estimated total duration in hours required to complete the assigned route execution, including driving time, service stops, and breaks. Used for scheduling and DOT hours-of-service compliance planning.' ;
    rdfs:domain ind:DriverAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:helperAssignedFlag rdf:type rdf:Property ;
    rdfs:label 'Helper Assigned Flag' ;
    rdfs:comment 'Boolean indicator of whether a helper (second crew member) is assigned to assist the driver on this route execution. True indicates a two-person crew, false indicates solo driver operation. Common for residential rear-loader routes and heavy commercial pickups.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hosAvailableDriveHours rdf:type rdf:Property ;
    rdfs:label 'Hos Available Drive Hours' ;
    rdfs:comment 'The number of driving hours available to the driver under DOT hours-of-service regulations at the time of assignment. Calculated from the drivers electronic logging device (ELD) data and used to ensure compliance with the 11-hour driving limit.' ;
    rdfs:domain ind:DriverAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hosAvailableDutyHours rdf:type rdf:Property ;
    rdfs:label 'Hos Available Duty Hours' ;
    rdfs:comment 'The number of on-duty hours available to the driver under DOT hours-of-service regulations at the time of assignment. Calculated from the drivers electronic logging device (ELD) data and used to ensure compliance with the 14-hour on-duty limit.' ;
    rdfs:domain ind:DriverAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preTripInspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Pre Trip Inspection Status' ;
    rdfs:comment 'Status of the mandatory pre-trip vehicle inspection conducted by the driver before route execution. Passed indicates inspection completed with no defects, failed indicates defects found requiring maintenance, pending indicates inspection not yet completed, not_required indicates inspection waived for specific assignment type, waived indicates management override.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preTripInspectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pre Trip Inspection Timestamp' ;
    rdfs:comment 'The timestamp when the pre-trip vehicle inspection was completed and recorded by the driver. Used for DOT compliance documentation and audit trail.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:routeType rdf:type rdf:Property ;
    rdfs:label 'Route Type' ;
    rdfs:comment 'Classification of the route type that the driver is assigned to execute. Residential for curbside household collection, commercial for business waste pickup, roll_off for large container haul, recycling for materials recovery collection, hazardous for special waste handling.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceAreaCode rdf:type rdf:Property ;
    rdfs:label 'Service Area Code' ;
    rdfs:comment 'Geographic service area code where the route is executed. Formatted as 2-3 letter region code followed by 3-digit zone number (e.g., NE-001, SW-042). Used for territory management and performance reporting.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftEndTime rdf:type rdf:Property ;
    rdfs:label 'Shift End Time' ;
    rdfs:comment 'The scheduled timestamp when the driver is expected to complete their shift and return to the depot. Used for workforce scheduling and DOT hours-of-service compliance tracking.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shiftStartTime rdf:type rdf:Property ;
    rdfs:label 'Shift Start Time' ;
    rdfs:comment 'The scheduled timestamp when the driver is expected to begin their shift and commence route execution. Used for workforce scheduling and Department of Transportation (DOT) hours-of-service compliance tracking.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sourceSystemRecordCode rdf:type rdf:Property ;
    rdfs:label 'Source System Record Code' ;
    rdfs:comment 'The unique record identifier from the source operational system (Locus Dispatch or Workday HCM). Used for data lineage tracking and reconciliation with source systems.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionEnvironmentalMonitoringId rdf:type rdf:Property ;
    rdfs:label 'Collection Environmental Monitoring Id' ;
    rdfs:comment 'Unique identifier for the environmental monitoring record. Primary key for this entity.' ;
    rdfs:domain ind:CollectionEnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceEnvironmentalMonitoringId rdf:type rdf:Property ;
    rdfs:label 'Compliance Environmental Monitoring Id' ;
    rdfs:comment 'Foreign key linking to compliance.compliance_environmental_monitoring. Business justification: Collection-side environmental monitoring at transfer stations feeds compliance monitoring programs required by permits. Links operational monitoring data to regulatory compliance tracking for air, wat' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ComplianceEnvironmentalMonitoring .

ind:sampleId rdf:type rdf:Property ;
    rdfs:label 'Sample Id' ;
    rdfs:comment 'Unique identifier assigned to the environmental sample collected for laboratory analysis, enabling chain of custody tracking.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WasteManagement .

ind:agencyReportDate rdf:type rdf:Property ;
    rdfs:label 'Agency Report Date' ;
    rdfs:comment 'Date when the monitoring result was submitted to the regulatory agency in compliance with reporting requirements.' ;
    rdfs:domain ind:CollectionEnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:agencyReportReference rdf:type rdf:Property ;
    rdfs:label 'Agency Report Reference' ;
    rdfs:comment 'Reference number or tracking identifier assigned by the regulatory agency upon receipt of the monitoring report.' ;
    rdfs:domain ind:CollectionEnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifiedLabReference rdf:type rdf:Property ;
    rdfs:label 'Certified Lab Reference' ;
    rdfs:comment 'Reference number or identifier for the certified environmental laboratory that performed the analysis, if applicable. Required for regulatory reporting of laboratory-analyzed samples.' ;
    rdfs:domain ind:CollectionEnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceedanceFlag rdf:type rdf:Property ;
    rdfs:label 'Exceedance Flag' ;
    rdfs:comment 'Indicates whether the measured value exceeded the regulatory threshold, triggering potential compliance action or corrective measures.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:labCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Lab Certification Number' ;
    rdfs:comment 'State or federal certification number of the environmental laboratory that conducted the analysis, demonstrating compliance with quality assurance requirements.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measuredParameter rdf:type rdf:Property ;
    rdfs:label 'Measured Parameter' ;
    rdfs:comment 'Specific environmental parameter being measured, such as pH, total suspended solids, particulate matter PM10, hydrogen sulfide concentration, decibel level, or biochemical oxygen demand.' ;
    rdfs:domain ind:CollectionEnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measuredValue rdf:type rdf:Property ;
    rdfs:label 'Measured Value' ;
    rdfs:comment 'Numeric value of the environmental parameter measurement as recorded by the monitoring equipment or certified laboratory analysis.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:monitoringDate rdf:type rdf:Property ;
    rdfs:label 'Monitoring Date' ;
    rdfs:comment 'Calendar date when the environmental monitoring measurement or observation was taken.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:monitoringEquipmentCode rdf:type rdf:Property ;
    rdfs:label 'Monitoring Equipment Code' ;
    rdfs:comment 'Identifier for the monitoring equipment or instrument used to collect the measurement, enabling traceability and calibration verification.' ;
    rdfs:domain ind:CollectionEnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringFrequencyRequired rdf:type rdf:Property ;
    rdfs:label 'Monitoring Frequency Required' ;
    rdfs:comment 'Frequency at which this type of environmental monitoring is required to be conducted per permit conditions or regulatory requirements. [ENUM-REF-CANDIDATE: daily|weekly|monthly|quarterly|annual|event_based|continuous — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CollectionEnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringLocation rdf:type rdf:Property ;
    rdfs:label 'Monitoring Location' ;
    rdfs:comment 'Specific location on the transfer station site where the environmental monitoring was conducted, such as perimeter fence line, tipping floor, stormwater outfall, or property boundary.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringLocationLatitude rdf:type rdf:Property ;
    rdfs:label 'Monitoring Location Latitude' ;
    rdfs:comment 'Geographic latitude coordinate of the monitoring location in decimal degrees format.' ;
    rdfs:domain ind:CollectionEnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:monitoringLocationLongitude rdf:type rdf:Property ;
    rdfs:label 'Monitoring Location Longitude' ;
    rdfs:comment 'Geographic longitude coordinate of the monitoring location in decimal degrees format.' ;
    rdfs:domain ind:CollectionEnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:monitoringMethod rdf:type rdf:Property ;
    rdfs:label 'Monitoring Method' ;
    rdfs:comment 'Standardized method or protocol used to conduct the environmental monitoring, such as EPA Method 9040B for pH or EPA Method 1664A for oil and grease.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringStatus rdf:type rdf:Property ;
    rdfs:label 'Monitoring Status' ;
    rdfs:comment 'Current status of the environmental monitoring record in its lifecycle, from scheduling through completion and regulatory reporting.' ;
    rdfs:domain ind:CollectionEnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringTechnicianCertification rdf:type rdf:Property ;
    rdfs:label 'Monitoring Technician Certification' ;
    rdfs:comment 'Professional certification or qualification held by the monitoring technician, such as Certified Environmental Professional (CEP) or state-specific certifications.' ;
    rdfs:domain ind:CollectionEnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringTechnicianName rdf:type rdf:Property ;
    rdfs:label 'Monitoring Technician Name' ;
    rdfs:comment 'Name of the technician or environmental specialist who conducted the monitoring or collected the sample.' ;
    rdfs:domain ind:CollectionEnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringTimestamp rdf:type rdf:Property ;
    rdfs:label 'Monitoring Timestamp' ;
    rdfs:comment 'Precise date and time when the environmental monitoring measurement was recorded, including time zone information for regulatory compliance.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:monitoringType rdf:type rdf:Property ;
    rdfs:label 'Monitoring Type' ;
    rdfs:comment 'Category of environmental monitoring being performed at the transfer station. Determines the regulatory framework and compliance requirements applicable to this record. [ENUM-REF-CANDIDATE: stormwater_runoff|air_emissions|odor_complaint|noise_level|leachate|dust|vector_control — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitConditionReference rdf:type rdf:Property ;
    rdfs:label 'Permit Condition Reference' ;
    rdfs:comment 'Specific permit condition, section, or requirement that mandates this environmental monitoring activity, linking the record to regulatory obligations.' ;
    rdfs:domain ind:CollectionEnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordNumber rdf:type rdf:Property ;
    rdfs:label 'Record Number' ;
    rdfs:comment 'Business identifier for the environmental monitoring record, typically used for external reporting and permit compliance documentation.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryThreshold rdf:type rdf:Property ;
    rdfs:label 'Regulatory Threshold' ;
    rdfs:comment 'Maximum allowable value or regulatory limit for the measured parameter as defined by the applicable environmental permit or regulatory standard.' ;
    rdfs:domain ind:CollectionEnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportedToAgencyFlag rdf:type rdf:Property ;
    rdfs:label 'Reported To Agency Flag' ;
    rdfs:comment 'Indicates whether this monitoring result has been reported to the regulatory authority as required by permit conditions or compliance obligations.' ;
    rdfs:domain ind:CollectionEnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:windDirection rdf:type rdf:Property ;
    rdfs:label 'Wind Direction' ;
    rdfs:comment 'Cardinal or intercardinal direction from which the wind is blowing at the time of monitoring, relevant for odor complaint investigations and air quality assessments.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:windSpeedMph rdf:type rdf:Property ;
    rdfs:label 'Wind Speed Mph' ;
    rdfs:comment 'Wind speed in miles per hour at the time of monitoring, relevant for air quality and odor dispersion assessments.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:facilityCapacityId rdf:type rdf:Property ;
    rdfs:label 'Facility Capacity Id' ;
    rdfs:comment 'Unique identifier for the facility capacity tracking record. Primary key for daily and period-level capacity and throughput tracking at transfer stations.' ;
    rdfs:domain ind:FacilityCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualInboundTonnage rdf:type rdf:Property ;
    rdfs:label 'Actual Inbound Tonnage' ;
    rdfs:comment 'Total tonnage of waste received at the transfer station during the record date or period. Represents all incoming waste streams before sorting or processing.' ;
    rdfs:domain ind:FacilityCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualOutboundTonnage rdf:type rdf:Property ;
    rdfs:label 'Actual Outbound Tonnage' ;
    rdfs:comment 'Total tonnage of waste dispatched from the transfer station to disposal or processing facilities during the record date or period.' ;
    rdfs:domain ind:FacilityCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageDailyTonnage rdf:type rdf:Property ;
    rdfs:label 'Average Daily Tonnage' ;
    rdfs:comment 'Average daily tonnage processed during the record period. For daily records, equals actual_inbound_tonnage. For period records, represents the mean daily throughput.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityStatus rdf:type rdf:Property ;
    rdfs:label 'Capacity Status' ;
    rdfs:comment 'Operational status of the transfer station capacity. Normal indicates utilization within acceptable range, near_capacity indicates approaching permit limits, over_capacity indicates permit exceedance, under_capacity indicates significantly below normal throughput.' ;
    rdfs:domain ind:FacilityCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityUtilizationPercentage rdf:type rdf:Property ;
    rdfs:label 'Capacity Utilization Percentage' ;
    rdfs:comment 'Percentage of permitted daily capacity utilized, calculated as (actual_inbound_tonnage / permitted_daily_capacity_tpd) * 100. Key performance indicator for capacity management.' ;
    rdfs:domain ind:FacilityCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:correctiveActionTaken rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Taken' ;
    rdfs:comment 'Description of corrective actions implemented in response to capacity exceedance or operational issues. Documents compliance response for regulatory reporting.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diversionRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Diversion Rate Percentage' ;
    rdfs:comment 'Percentage of waste diverted from landfill disposal through recycling, composting, or waste-to-energy. Calculated as ((outbound_mrf_tonnage + outbound_wte_tonnage + outbound_organics_tonnage) / actual_inbound_tonnage) * 100. Key sustainability metric.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exceedanceReason rdf:type rdf:Property ;
    rdfs:label 'Exceedance Reason' ;
    rdfs:comment 'Explanation for why the permitted capacity was exceeded, if applicable. Includes operational circumstances, emergency conditions, or unplanned events that led to the exceedance.' ;
    rdfs:domain ind:FacilityCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceedanceTonnage rdf:type rdf:Property ;
    rdfs:label 'Exceedance Tonnage' ;
    rdfs:comment 'Tonnage by which the actual inbound tonnage exceeded the permitted daily capacity. Null if no exceedance occurred. Used for regulatory violation reporting and corrective action planning.' ;
    rdfs:domain ind:FacilityCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:floorStorageTonnage rdf:type rdf:Property ;
    rdfs:label 'Floor Storage Tonnage' ;
    rdfs:comment 'Tonnage of waste remaining on the transfer station floor at the end of the record date. Represents inventory not yet dispatched for disposal or processing.' ;
    rdfs:domain ind:FacilityCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inboundCdTonnage rdf:type rdf:Property ;
    rdfs:label 'Inbound Cd Tonnage' ;
    rdfs:comment 'Tonnage of construction and demolition (C&D) waste received during the record date or period. C&D includes debris from building, renovation, and demolition activities.' ;
    rdfs:domain ind:FacilityCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inboundLoadCount rdf:type rdf:Property ;
    rdfs:label 'Inbound Load Count' ;
    rdfs:comment 'Total count of inbound collection vehicles or loads received at the transfer station during the record date or period. Used for operational throughput analysis.' ;
    rdfs:domain ind:FacilityCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inboundMswTonnage rdf:type rdf:Property ;
    rdfs:label 'Inbound Msw Tonnage' ;
    rdfs:comment 'Tonnage of municipal solid waste (MSW) received during the record date or period. MSW includes residential and commercial non-hazardous waste.' ;
    rdfs:domain ind:FacilityCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inboundOrganicsTonnage rdf:type rdf:Property ;
    rdfs:label 'Inbound Organics Tonnage' ;
    rdfs:comment 'Tonnage of organic waste (food waste, yard waste, compostables) received during the record date or period. Tracked separately for diversion rate calculation.' ;
    rdfs:domain ind:FacilityCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inboundRecyclableTonnage rdf:type rdf:Property ;
    rdfs:label 'Inbound Recyclable Tonnage' ;
    rdfs:comment 'Tonnage of recyclable materials received during the record date or period. Includes materials destined for Materials Recovery Facility (MRF) processing.' ;
    rdfs:domain ind:FacilityCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operationalNotes rdf:type rdf:Property ;
    rdfs:label 'Operational Notes' ;
    rdfs:comment 'Free-text notes documenting operational conditions, equipment issues, weather impacts, or other factors affecting capacity and throughput during the record date or period.' ;
    rdfs:domain ind:FacilityCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outboundHaulCount rdf:type rdf:Property ;
    rdfs:label 'Outbound Haul Count' ;
    rdfs:comment 'Total count of outbound haul trucks dispatched from the transfer station to disposal or processing facilities during the record date or period.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:outboundLandfillTonnage rdf:type rdf:Property ;
    rdfs:label 'Outbound Landfill Tonnage' ;
    rdfs:comment 'Tonnage of waste hauled to landfill disposal facilities during the record date or period. Used for diversion rate calculation.' ;
    rdfs:domain ind:FacilityCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outboundMrfTonnage rdf:type rdf:Property ;
    rdfs:label 'Outbound Mrf Tonnage' ;
    rdfs:comment 'Tonnage of recyclable materials sent to Materials Recovery Facility (MRF) for processing during the record date or period. Contributes to diversion rate.' ;
    rdfs:domain ind:FacilityCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outboundWteTonnage rdf:type rdf:Property ;
    rdfs:label 'Outbound Wte Tonnage' ;
    rdfs:comment 'Tonnage of waste sent to waste-to-energy (WTE) facilities for energy recovery during the record date or period. Contributes to diversion rate.' ;
    rdfs:domain ind:FacilityCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:peakHourThroughputTons rdf:type rdf:Property ;
    rdfs:label 'Peak Hour Throughput Tons' ;
    rdfs:comment 'Maximum tonnage processed during any single hour of the record date. Used to identify operational bottlenecks and peak demand periods.' ;
    rdfs:domain ind:FacilityCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:peakHourTimestamp rdf:type rdf:Property ;
    rdfs:label 'Peak Hour Timestamp' ;
    rdfs:comment 'Timestamp indicating when the peak hour throughput occurred during the record date. Supports operational planning and resource allocation.' ;
    rdfs:domain ind:FacilityCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:permitExceedanceFlag rdf:type rdf:Property ;
    rdfs:label 'Permit Exceedance Flag' ;
    rdfs:comment 'Boolean flag indicating whether the actual inbound tonnage exceeded the permitted daily capacity. True indicates a regulatory compliance issue requiring immediate attention and reporting.' ;
    rdfs:domain ind:FacilityCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:permittedDailyCapacityTpd rdf:type rdf:Property ;
    rdfs:label 'Permitted Daily Capacity Tpd' ;
    rdfs:comment 'The maximum daily throughput capacity in tons per day (TPD) as authorized by the facility\'s operating permit. This is the regulatory limit that cannot be exceeded without permit violation.' ;
    rdfs:domain ind:FacilityCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recordDate rdf:type rdf:Property ;
    rdfs:label 'Record Date' ;
    rdfs:comment 'The specific date for which this capacity record applies. Used for daily capacity tracking and regulatory reporting.' ;
    rdfs:domain ind:FacilityCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recordPeriod rdf:type rdf:Property ;
    rdfs:label 'Record Period' ;
    rdfs:comment 'The reporting period for aggregated capacity tracking (e.g., 2024-Q1, 2024-03). Supports both monthly and quarterly period-level reporting.' ;
    rdfs:domain ind:FacilityCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordStatus rdf:type rdf:Property ;
    rdfs:label 'Record Status' ;
    rdfs:comment 'Current status of the capacity record in the reporting workflow. Draft indicates preliminary data, validated indicates quality checks passed, submitted indicates included in regulatory reporting, archived indicates historical record.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Reference' ;
    rdfs:comment 'Reference number or identifier for the regulatory report submission that includes this capacity data. Links capacity records to state SWIS reporting, EPA reporting, or local enforcement agency submissions.' ;
    rdfs:domain ind:FacilityCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Report Submission Date' ;
    rdfs:comment 'Date when the regulatory report containing this capacity data was submitted to the governing authority. Used for compliance tracking and audit trail.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Validation Timestamp' ;
    rdfs:comment 'Timestamp when the capacity record was validated and approved for regulatory reporting. Part of the audit trail for compliance documentation.' ;
    rdfs:domain ind:FacilityCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:disposalLandfillSiteId rdf:type rdf:Property ;
    rdfs:label 'Disposal Landfill Site Id' ;
    rdfs:comment 'Foreign key linking to landfill.site. Business justification: Haul manifests for waste transported to landfills require landfill site reference for regulatory compliance, manifest-based waste tracking, and chain-of-custody documentation. Core regulatory and oper' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Site .

ind:disposalPurchaseOrderId rdf:type rdf:Property ;
    rdfs:label 'Disposal Purchase Order Id' ;
    rdfs:comment 'Foreign key linking to procurement.disposal_purchase_order. Business justification: Haul manifests provide regulatory documentation for waste shipments under disposal purchase orders. EPA RCRA regulations require linking manifests to disposal contracts for hazardous waste. Compliance' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DisposalPurchaseOrder .

ind:haulingAgreementId rdf:type rdf:Property ;
    rdfs:label 'Hauling Agreement Id' ;
    rdfs:comment 'Foreign key linking to contract.hauling_agreement. Business justification: Haul manifests document waste transport under hauling agreements, including BOL terms and carrier obligations. Regulatory compliance, carrier liability verification, and hauling agreement audit trails' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HaulingAgreement .

ind:hazmatManifestId rdf:type rdf:Property ;
    rdfs:label 'Hazmat Manifest Id' ;
    rdfs:comment 'Foreign key linking to hazmat.manifest. Business justification: Links operational haul tracking to authoritative regulatory manifest system. Role-prefixed to distinguish from local manifest_number field; removes denormalized manifest_tracking_number for 3NF.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Manifest .

ind:originTransferStationId rdf:type rdf:Property ;
    rdfs:label 'Origin Transfer Station Id' ;
    rdfs:comment 'Transfer station facility from which this haul originated. Starting point of the outbound shipment.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TransferStation .

ind:actualArrivalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Arrival Timestamp' ;
    rdfs:comment 'Actual date and time when the haul arrived at the destination facility. Used for transit time tracking and SLA compliance.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:bolReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Bol Reference Number' ;
    rdfs:comment 'Bill of Lading reference number accompanying this haul manifest. Links manifest to shipping documentation.' ;
    rdfs:domain ind:HaulManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierDotNumber rdf:type rdf:Property ;
    rdfs:label 'Carrier Dot Number' ;
    rdfs:comment 'DOT registration number of the carrier company responsible for transporting this haul. Required for interstate commerce compliance.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerCount rdf:type rdf:Property ;
    rdfs:label 'Container Count' ;
    rdfs:comment 'Number of containers or trailers included in this haul shipment.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:departureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Departure Timestamp' ;
    rdfs:comment 'Date and time when the haul departed from the origin transfer station. Marks the beginning of the transport chain-of-custody.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:destinationSignatureName rdf:type rdf:Property ;
    rdfs:label 'Destination Signature Name' ;
    rdfs:comment 'Name of the destination facility representative who signed the manifest upon receipt, confirming delivery and acceptance.' ;
    rdfs:domain ind:HaulManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationSignatureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Destination Signature Timestamp' ;
    rdfs:comment 'Date and time when the destination facility representative signed the manifest acknowledging receipt.' ;
    rdfs:domain ind:HaulManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:driverSignatureCapturedFlag rdf:type rdf:Property ;
    rdfs:label 'Driver Signature Captured Flag' ;
    rdfs:comment 'Indicates whether the driver signature was captured on the manifest document. Required for DOT compliance.' ;
    rdfs:domain ind:HaulManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:driverSignatureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Driver Signature Timestamp' ;
    rdfs:comment 'Date and time when the driver signed the manifest document acknowledging receipt and transport responsibility.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:emergencyContactName rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Name' ;
    rdfs:comment 'Name of the emergency response contact person or organization for incidents involving this haul. Required for hazardous waste shipments.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyContactPhone rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Phone' ;
    rdfs:comment '24-hour emergency response phone number for incidents involving this haul. Required for hazardous waste shipments.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epaWasteCode rdf:type rdf:Property ;
    rdfs:label 'Epa Waste Code' ;
    rdfs:comment 'EPA hazardous waste code(s) applicable to this shipment. Multiple codes may be comma-separated. Required for RCRA manifest compliance.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedArrivalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Estimated Arrival Timestamp' ;
    rdfs:comment 'Planned date and time when the haul is expected to arrive at the destination facility.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:hazmatFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Flag' ;
    rdfs:comment 'Indicates whether this haul contains hazardous materials requiring special handling and RCRA manifest compliance.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:manifestIssuedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Manifest Issued Timestamp' ;
    rdfs:comment 'Date and time when the manifest document was officially issued and became active for this haul.' ;
    rdfs:domain ind:HaulManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:manifestNumber rdf:type rdf:Property ;
    rdfs:label 'Manifest Number' ;
    rdfs:comment 'Externally-known unique manifest tracking number assigned to this outbound haul shipment. Required for DOT compliance and chain-of-custody documentation.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manifestStatus rdf:type rdf:Property ;
    rdfs:label 'Manifest Status' ;
    rdfs:comment 'Current lifecycle status of the haul manifest in the shipping and tracking workflow.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originSignatureName rdf:type rdf:Property ;
    rdfs:label 'Origin Signature Name' ;
    rdfs:comment 'Name of the transfer station representative who signed the manifest at origin, certifying the shipment details.' ;
    rdfs:domain ind:HaulManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originSignatureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Origin Signature Timestamp' ;
    rdfs:comment 'Date and time when the origin facility representative signed the manifest.' ;
    rdfs:domain ind:HaulManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rcraManifestRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Rcra Manifest Required Flag' ;
    rdfs:comment 'Indicates whether this haul requires a formal RCRA hazardous waste manifest under federal regulations.' ;
    rdfs:domain ind:HaulManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rejectionFlag rdf:type rdf:Property ;
    rdfs:label 'Rejection Flag' ;
    rdfs:comment 'Indicates whether this haul was rejected at the destination facility due to contamination, incorrect classification, or other non-compliance issues.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rejectionReason rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason' ;
    rdfs:comment 'Detailed explanation of why the haul was rejected at the destination facility. Populated only when rejection_flag is true.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sealNumbers rdf:type rdf:Property ;
    rdfs:label 'Seal Numbers' ;
    rdfs:comment 'Security seal identification numbers applied to containers or trailer doors. Multiple seals may be comma-separated. Required for chain-of-custody integrity.' ;
    rdfs:domain ind:HaulManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialHandlingInstructions rdf:type rdf:Property ;
    rdfs:label 'Special Handling Instructions' ;
    rdfs:comment 'Additional instructions for handling, transporting, or unloading this haul. May include safety precautions, equipment requirements, or facility-specific procedures.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalNetWeightTons rdf:type rdf:Property ;
    rdfs:label 'Total Net Weight Tons' ;
    rdfs:comment 'Total net weight of waste material in this haul measured in tons. Calculated as gross weight minus tare weight.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:haulRateId rdf:type rdf:Property ;
    rdfs:label 'Haul Rate Id' ;
    rdfs:comment 'Unique identifier for the haul rate record. Primary key.' ;
    rdfs:domain ind:HaulRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:haulerAccountId rdf:type rdf:Property ;
    rdfs:label 'Hauler Account Id' ;
    rdfs:comment 'Reference to the third-party hauling contractor or internal fleet division responsible for outbound transportation. Used for invoice validation and cost allocation.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HaulerAccount .

ind:primaryHaulEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Haul Employee Id' ;
    rdfs:comment 'Reference to the user who approved this haul rate. Provides audit trail for rate authorization.' ;
    rdfs:domain ind:HaulRate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:supersededByRateHaulRateId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Rate Haul Rate Id' ;
    rdfs:comment 'Reference to the newer haul rate record that replaces this rate. Used to maintain rate history and version control. Null for current active rates.' ;
    rdfs:domain ind:HaulRate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HaulRate .

ind:tertiaryHaulLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Haul Last Modified By User Employee Id' ;
    rdfs:comment 'Reference to the user who last modified this haul rate record. Part of audit trail for rate changes.' ;
    rdfs:domain ind:HaulRate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:distanceMiles rdf:type rdf:Property ;
    rdfs:label 'Distance Miles' ;
    rdfs:comment 'Standard route distance in miles between origin transfer station and destination facility. Used for per-mile rate calculations and route planning.' ;
    rdfs:domain ind:HaulRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedTransitTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Estimated Transit Time Minutes' ;
    rdfs:comment 'Expected travel time in minutes for haul route under normal traffic conditions. Used for scheduling and per-hour rate calculations.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fuelSurchargeFormula rdf:type rdf:Property ;
    rdfs:label 'Fuel Surcharge Formula' ;
    rdfs:comment 'Mathematical formula or reference to fuel surcharge calculation method applied to base rate. May reference DOT fuel price index or fixed percentage. Used to adjust transportation costs based on fuel price volatility.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelSurchargePercentage rdf:type rdf:Property ;
    rdfs:label 'Fuel Surcharge Percentage' ;
    rdfs:comment 'Fixed percentage fuel surcharge applied to base rate if using percentage-based surcharge method. Null if formula-based surcharge is used.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Charge Amount' ;
    rdfs:comment 'Maximum transportation charge cap per haul. May be imposed by municipal contracts or regulatory rate caps.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Charge Amount' ;
    rdfs:comment 'Minimum transportation charge per haul regardless of calculated rate. Ensures cost recovery for small loads or short hauls.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:permitRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Permit Required Flag' ;
    rdfs:comment 'Indicates whether special hauling permits are required for this route. True for hazardous waste, overweight loads, or restricted routes.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rateAdjustmentPercentage rdf:type rdf:Property ;
    rdfs:label 'Rate Adjustment Percentage' ;
    rdfs:comment 'Annual or periodic percentage adjustment applied to base rate for inflation or cost escalation per contract terms. Null if no automatic adjustment applies.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateAmount rdf:type rdf:Property ;
    rdfs:label 'Rate Amount' ;
    rdfs:comment 'Base transportation rate amount per unit as defined by rate basis. Expressed in currency per ton, per load, per mile, or other unit. Excludes fuel surcharges and additional fees.' ;
    rdfs:domain ind:HaulRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateBasis rdf:type rdf:Property ;
    rdfs:label 'Rate Basis' ;
    rdfs:comment 'Unit of measure on which the haul rate is calculated. Determines how transportation costs are computed for invoicing and cost accounting.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCode rdf:type rdf:Property ;
    rdfs:label 'Rate Code' ;
    rdfs:comment 'Business identifier code for the haul rate used in contracts and invoicing. Unique alphanumeric code assigned to each rate schedule.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateName rdf:type rdf:Property ;
    rdfs:label 'Rate Name' ;
    rdfs:comment 'Descriptive name for the haul rate schedule for business user identification and reporting purposes.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateNotes rdf:type rdf:Property ;
    rdfs:label 'Rate Notes' ;
    rdfs:comment 'Free-text field for additional rate information, special conditions, or business context not captured in structured fields.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateStatus rdf:type rdf:Property ;
    rdfs:label 'Rate Status' ;
    rdfs:comment 'Current lifecycle status of the haul rate. Controls whether rate is available for use in cost calculations and invoicing.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateTier rdf:type rdf:Property ;
    rdfs:label 'Rate Tier' ;
    rdfs:comment 'Classification of rate type based on contract structure. Spot = one-time market rate, Contracted = long-term agreement rate, Municipal = government contract rate, Emergency = premium rate for urgent hauls, Seasonal = time-period specific rate.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryRateCap rdf:type rdf:Property ;
    rdfs:label 'Regulatory Rate Cap' ;
    rdfs:comment 'Maximum rate amount imposed by regulatory authority or municipal contract. Null if no regulatory cap applies.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tollChargesIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Toll Charges Included Flag' ;
    rdfs:comment 'Indicates whether toll road charges are included in the base rate or billed separately. True if tolls are included in rate amount.' ;
    rdfs:domain ind:HaulRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:volumeDiscountRate rdf:type rdf:Property ;
    rdfs:label 'Volume Discount Rate' ;
    rdfs:comment 'Discounted rate amount applied when volume threshold is met. Null if no volume discount applies.' ;
    rdfs:domain ind:HaulRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeDiscountThresholdTons rdf:type rdf:Property ;
    rdfs:label 'Volume Discount Threshold Tons' ;
    rdfs:comment 'Minimum tonnage threshold per period to qualify for volume-based rate discount. Null if no volume discount applies.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightLimitTons rdf:type rdf:Property ;
    rdfs:label 'Weight Limit Tons' ;
    rdfs:comment 'Maximum payload weight in tons allowed for this haul route based on DOT regulations, vehicle capacity, and facility restrictions.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accountManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Account Manager Employee Id' ;
    rdfs:comment 'FK to workforce.employee' ;
    rdfs:domain ind:HaulerAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:epaGeneratorId rdf:type rdf:Property ;
    rdfs:label 'Epa Generator Id' ;
    rdfs:comment 'EPA-issued identification number for hazardous waste generators, required for haulers delivering hazardous waste streams under RCRA regulations.' ;
    rdfs:domain ind:HaulerAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HazardousWasteGenerator .

ind:approvedWasteStreams rdf:type rdf:Property ;
    rdfs:label 'Approved Waste Streams' ;
    rdfs:comment 'Comma-separated list of waste stream types the hauler is authorized to deliver (e.g., MSW, C&D, recyclables, organics, hazardous). Determines acceptance at transfer station gates.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoRenewalFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Flag' ;
    rdfs:comment 'Indicates whether the hauler contract automatically renews upon expiration without requiring explicit re-negotiation.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:businessAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Business Address Line1' ;
    rdfs:comment 'Primary street address line for the hauler business location.' ;
    rdfs:domain ind:HaulerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Business Address Line2' ;
    rdfs:comment 'Secondary address line for suite, unit, or building information.' ;
    rdfs:domain ind:HaulerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessCity rdf:type rdf:Property ;
    rdfs:label 'Business City' ;
    rdfs:comment 'City name for the hauler business address.' ;
    rdfs:domain ind:HaulerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessCountryCode rdf:type rdf:Property ;
    rdfs:label 'Business Country Code' ;
    rdfs:comment 'Three-letter ISO country code for the hauler business address.' ;
    rdfs:domain ind:HaulerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessPostalCode rdf:type rdf:Property ;
    rdfs:label 'Business Postal Code' ;
    rdfs:comment 'ZIP or postal code for the hauler business address.' ;
    rdfs:domain ind:HaulerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessState rdf:type rdf:Property ;
    rdfs:label 'Business State' ;
    rdfs:comment 'Two-letter state or province code for the hauler business address.' ;
    rdfs:domain ind:HaulerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Contract Effective Date' ;
    rdfs:comment 'Start date of the current contract or service agreement with the hauler.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Contract Expiration Date' ;
    rdfs:comment 'End date of the current contract or service agreement. Null indicates an evergreen or month-to-month arrangement.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditTerms rdf:type rdf:Property ;
    rdfs:label 'Credit Terms' ;
    rdfs:comment 'Payment terms extended to the hauler account. Net_15/30/45/60: payment due within specified days. Prepay: payment required before service. COD: cash on delivery.' ;
    rdfs:domain ind:HaulerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dotCarrierNumber rdf:type rdf:Property ;
    rdfs:label 'Dot Carrier Number' ;
    rdfs:comment 'USDOT carrier identification number issued by the Federal Motor Carrier Safety Administration for commercial haulers operating interstate.' ;
    rdfs:domain ind:HaulerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originatingJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Originating Jurisdiction' ;
    rdfs:comment 'Primary municipality, county, or jurisdiction where the hauler collects waste, used for regulatory reporting and flow control compliance.' ;
    rdfs:domain ind:HaulerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfidTagRequired rdf:type rdf:Property ;
    rdfs:label 'Rfid Tag Required' ;
    rdfs:comment 'Indicates whether hauler vehicles must have RFID tags for automated gate entry and tracking at transfer stations.' ;
    rdfs:domain ind:HaulerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:suspensionReason rdf:type rdf:Property ;
    rdfs:label 'Suspension Reason' ;
    rdfs:comment 'Reason code or description if account status is suspended (e.g., insurance lapse, payment delinquency, contamination violations, safety incident).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxIdentifier rdf:type rdf:Property ;
    rdfs:label 'Tax Identifier' ;
    rdfs:comment 'Federal Employer Identification Number (EIN) or Tax ID for the hauler entity, used for billing and tax reporting.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationReason rdf:type rdf:Property ;
    rdfs:label 'Termination Reason' ;
    rdfs:comment 'Reason code or description if account status is terminated (e.g., contract expiration, business closure, regulatory violation, mutual agreement).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tippingFeeRateTier rdf:type rdf:Property ;
    rdfs:label 'Tipping Fee Rate Tier' ;
    rdfs:comment 'Rate tier classification determining the per-ton tipping fee charged to this hauler. Standard: published rate. Contracted: negotiated rate. Municipal: government rate. Volume discount: high-volume rate. Spot: one-time rate.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehiclePreAuthorizationRequired rdf:type rdf:Property ;
    rdfs:label 'Vehicle Pre Authorization Required' ;
    rdfs:comment 'Indicates whether hauler vehicles must be pre-registered in AMCS before being allowed entry to transfer stations. True for contracted haulers, typically false for self-haul.' ;
    rdfs:domain ind:HaulerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disposalAgreementId rdf:type rdf:Property ;
    rdfs:label 'Disposal Agreement Id' ;
    rdfs:comment 'Foreign key linking to contract.disposal_agreement. Business justification: Load tickets track tonnage delivered under disposal agreements with landfills/WTE facilities. Contracted capacity utilization, tipping fee reconciliation, and disposal agreement compliance reporting r' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DisposalAgreement .

ind:outboundHaulFacilityId rdf:type rdf:Property ;
    rdfs:label 'Outbound Haul Facility Id' ;
    rdfs:comment 'Reference to the final disposal facility (landfill, WTE plant, MRF) where this load will be hauled after transfer station consolidation.' ;
    rdfs:domain ind:LoadTicket ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:scaleEquipmentId rdf:type rdf:Property ;
    rdfs:label 'Scale Equipment Id' ;
    rdfs:comment 'Reference to the specific weighing scale used to measure this load. Required for calibration tracking and measurement accuracy audits.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ScaleEquipment .

ind:acceptanceDecision rdf:type rdf:Property ;
    rdfs:label 'Acceptance Decision' ;
    rdfs:comment 'Final decision on whether the load was accepted for disposal, rejected, or conditionally accepted with restrictions or additional fees.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billableFlag rdf:type rdf:Property ;
    rdfs:label 'Billable Flag' ;
    rdfs:comment 'Indicates whether this load ticket is eligible for customer billing. False for rejected loads, voided tickets, or internal transfers.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contaminationLevel rdf:type rdf:Property ;
    rdfs:label 'Contamination Level' ;
    rdfs:comment 'Assessment of contamination or prohibited materials in the load. High contamination may trigger rejection or additional processing fees.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contaminationType rdf:type rdf:Property ;
    rdfs:label 'Contamination Type' ;
    rdfs:comment 'Description of specific contaminants identified in the load (e.g., hazardous materials in MSW, non-recyclables in recycling stream, liquids in C&D).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalAuthorizationNumber rdf:type rdf:Property ;
    rdfs:label 'Disposal Authorization Number' ;
    rdfs:comment 'Pre-authorization or permit number authorizing disposal of this specific load. Required for certain waste streams or customer contracts.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:driverCdlNumber rdf:type rdf:Property ;
    rdfs:label 'Driver Cdl Number' ;
    rdfs:comment 'The driver\'s Commercial Driver License number verified at gate entry. Required for DOT compliance and hazardous waste handling authorization.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateEntryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Gate Entry Timestamp' ;
    rdfs:comment 'Date and time when the vehicle entered the transfer station gate. Used for queue time analysis and facility throughput metrics.' ;
    rdfs:domain ind:LoadTicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:gateExitTimestamp rdf:type rdf:Property ;
    rdfs:label 'Gate Exit Timestamp' ;
    rdfs:comment 'Date and time when the vehicle exited the transfer station gate. Used for total facility dwell time calculation.' ;
    rdfs:domain ind:LoadTicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:haulerType rdf:type rdf:Property ;
    rdfs:label 'Hauler Type' ;
    rdfs:comment 'Classification of the entity that delivered this load: company-owned fleet, third-party contractor, municipal vehicle, or customer self-haul.' ;
    rdfs:domain ind:LoadTicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netWeightTons rdf:type rdf:Property ;
    rdfs:label 'Net Weight Tons' ;
    rdfs:comment 'Calculated net payload weight (gross minus tare) expressed in tons. Primary basis for tipping fee calculation and tonnage reporting.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preEntryInspectionResult rdf:type rdf:Property ;
    rdfs:label 'Pre Entry Inspection Result' ;
    rdfs:comment 'Result of the pre-entry safety and load inspection conducted at the gate before allowing vehicle entry. Failed inspections may result in rejection.' ;
    rdfs:domain ind:LoadTicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionDispositionInstructions rdf:type rdf:Property ;
    rdfs:label 'Rejection Disposition Instructions' ;
    rdfs:comment 'Instructions provided to the driver for proper disposal of rejected loads, including alternative facility recommendations or remediation requirements.' ;
    rdfs:domain ind:LoadTicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionReasonCode rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for load rejection (e.g., prohibited materials, excessive contamination, unauthorized waste stream, permit violation).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfidTransponderScan rdf:type rdf:Property ;
    rdfs:label 'Rfid Transponder Scan' ;
    rdfs:comment 'RFID tag or transponder identifier scanned from the vehicle at gate entry. Used for automated vehicle identification and access control.' ;
    rdfs:domain ind:LoadTicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ticketStatus rdf:type rdf:Property ;
    rdfs:label 'Ticket Status' ;
    rdfs:comment 'Current lifecycle status of this load ticket record. Completed tickets are eligible for billing; voided tickets are excluded from revenue reporting.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tippingFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Tipping Fee Amount' ;
    rdfs:comment 'Total tipping fee charged for this load (net weight multiplied by tipping fee rate). Primary revenue component for transfer station operations.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tippingFeeRate rdf:type rdf:Property ;
    rdfs:label 'Tipping Fee Rate' ;
    rdfs:comment 'Per-ton disposal fee rate applied to this load based on waste stream type, customer contract, and jurisdiction. Expressed in currency per ton.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wasteCharacterizationMethod rdf:type rdf:Property ;
    rdfs:label 'Waste Characterization Method' ;
    rdfs:comment 'Method used to determine the waste stream type and material composition: visual inspection, manifest declaration, physical sampling, customer declaration, or default profile.' ;
    rdfs:domain ind:LoadTicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteOriginJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Waste Origin Jurisdiction' ;
    rdfs:comment 'Municipality, county, or jurisdiction where the waste was collected. Required for regulatory reporting and flow control compliance.' ;
    rdfs:domain ind:LoadTicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weighInTimestamp rdf:type rdf:Property ;
    rdfs:label 'Weigh In Timestamp' ;
    rdfs:comment 'Date and time when the loaded vehicle was weighed at the inbound scale. Primary transaction timestamp for this load ticket.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:weighOutTimestamp rdf:type rdf:Property ;
    rdfs:label 'Weigh Out Timestamp' ;
    rdfs:comment 'Date and time when the empty vehicle was weighed at the outbound scale after unloading. Used to calculate tare weight and cycle time.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assignedDriverId rdf:type rdf:Property ;
    rdfs:label 'Assigned Driver Id' ;
    rdfs:comment 'Reference to the driver assigned to fulfill this on-demand request. Links to workforce management system for labor tracking and performance metrics.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Driver .

ind:assignedRouteId rdf:type rdf:Property ;
    rdfs:label 'Assigned Route Id' ;
    rdfs:comment 'Reference to the collection route to which this on-demand request has been assigned for fulfillment. Used for driver dispatch and operational tracking.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Route .

ind:assignedVehicleId rdf:type rdf:Property ;
    rdfs:label 'Assigned Vehicle Id' ;
    rdfs:comment 'Reference to the collection vehicle assigned to fulfill this request. Used for fleet utilization tracking and capacity validation.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vehicle .

ind:actualWeightTons rdf:type rdf:Property ;
    rdfs:label 'Actual Weight Tons' ;
    rdfs:comment 'Actual weight of material collected in tons, measured at disposal facility or transfer station. Used for final billing calculation and operational reporting.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:additionalFeesAmount rdf:type rdf:Property ;
    rdfs:label 'Additional Fees Amount' ;
    rdfs:comment 'Sum of any additional charges such as fuel surcharge, environmental fees, special handling fees, or expedited service premiums in USD.' ;
    rdfs:domain ind:OnDemandRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cancellationReason rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason' ;
    rdfs:comment 'Free-text explanation for why the on-demand request was cancelled or rejected. Populated when request_status is cancelled or rejected. Used for customer service analysis and process improvement.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cancellation Timestamp' ;
    rdfs:comment 'Date and time when the request was cancelled or rejected. Used for SLA tracking and operational metrics.' ;
    rdfs:domain ind:OnDemandRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:completionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Completion Timestamp' ;
    rdfs:comment 'Date and time when the on-demand collection service was completed by the driver. Captured from mobile device or telematics system at point of service.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:containerQuantity rdf:type rdf:Property ;
    rdfs:label 'Container Quantity' ;
    rdfs:comment 'Number of containers or items to be collected for this on-demand request. Used for capacity planning and pricing.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:customerSignatureCapturedFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Signature Captured Flag' ;
    rdfs:comment 'Indicates whether customer signature was captured at time of service. Used for proof of delivery and billing validation.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerSignatureRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Signature Required Flag' ;
    rdfs:comment 'Indicates whether customer signature is required to confirm service completion. True for high-value services or contractual requirements.' ;
    rdfs:domain ind:OnDemandRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disposalFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Disposal Fee Amount' ;
    rdfs:comment 'Tipping fee or disposal cost charged for processing the collected material at landfill or transfer station in USD. Weight-based or flat fee depending on waste stream and facility.' ;
    rdfs:domain ind:OnDemandRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedWeightTons rdf:type rdf:Property ;
    rdfs:label 'Estimated Weight Tons' ;
    rdfs:comment 'Estimated weight of material to be collected in tons. Used for vehicle capacity planning and preliminary billing calculation. Actual weight captured separately at disposal facility.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:photoCapturedFlag rdf:type rdf:Property ;
    rdfs:label 'Photo Captured Flag' ;
    rdfs:comment 'Indicates whether driver captured photo documentation at time of service. Used for quality assurance and dispute resolution.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:photoRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Photo Required Flag' ;
    rdfs:comment 'Indicates whether photographic documentation is required for this request. True for high-value items, disputed services, or compliance documentation needs.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorityLevel rdf:type rdf:Property ;
    rdfs:label 'Priority Level' ;
    rdfs:comment 'Service priority classification. Standard for normal scheduling, high for expedited service within 48 hours, urgent for same-day or next-day service, emergency for immediate health or safety hazards requiring rapid response.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestNumber rdf:type rdf:Property ;
    rdfs:label 'Request Number' ;
    rdfs:comment 'Externally visible unique business identifier for the on-demand request, formatted as ODR-NNNNNNNN. Used for customer communication and tracking.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestStatus rdf:type rdf:Property ;
    rdfs:label 'Request Status' ;
    rdfs:comment 'Current lifecycle status of the on-demand request. Pending indicates awaiting review, scheduled means assigned to a route, dispatched means driver notified, in_progress means driver en route or on site, completed means service fulfilled, cancelled means customer or system cancelled, rejected means request denied due to service constraints or policy. [ENUM-REF-CANDIDATE: pending|scheduled|dispatched|in_progress|completed|cancelled|rejected — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedServiceDate rdf:type rdf:Property ;
    rdfs:label 'Requested Service Date' ;
    rdfs:comment 'Date requested by the customer for the on-demand collection service. May differ from actual scheduled date based on route availability and operational constraints.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledServiceDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Service Date' ;
    rdfs:comment 'Actual date scheduled for the collection service after route optimization and capacity planning. Confirmed date communicated to customer.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledTimeWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Scheduled Time Window End' ;
    rdfs:comment 'End of the time window when the collection service is scheduled to occur. Defines customer expectation window for service completion.' ;
    rdfs:domain ind:OnDemandRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledTimeWindowStart rdf:type rdf:Property ;
    rdfs:label 'Scheduled Time Window Start' ;
    rdfs:comment 'Beginning of the time window when the collection service is scheduled to occur. Provides customer with expected arrival timeframe.' ;
    rdfs:domain ind:OnDemandRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:serviceChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Service Charge Amount' ;
    rdfs:comment 'Base service charge for the on-demand collection in USD. Calculated based on request type, container quantity, and rate schedule. Excludes taxes and additional fees.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Service Duration Minutes' ;
    rdfs:comment 'Actual time spent by driver at service location in minutes, from arrival to departure. Used for labor costing, route optimization, and productivity analysis.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaMetFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Met Flag' ;
    rdfs:comment 'Indicates whether the service was completed within the SLA target timeframe. True if completion_timestamp minus created_timestamp is less than or equal to sla_target_hours. Used for performance reporting and customer satisfaction tracking.' ;
    rdfs:domain ind:OnDemandRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaTargetHours rdf:type rdf:Property ;
    rdfs:label 'Sla Target Hours' ;
    rdfs:comment 'Service level agreement target for request fulfillment in hours from request creation. Based on priority level and customer contract terms.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceChannel rdf:type rdf:Property ;
    rdfs:label 'Source Channel' ;
    rdfs:comment 'Channel through which the on-demand request was initiated. Customer portal for self-service web, mobile app for customer mobile application, call center for phone requests, email for email submissions, field sales for in-person requests, CRM for internal service team entries.' ;
    rdfs:domain ind:OnDemandRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialInstructions rdf:type rdf:Property ;
    rdfs:label 'Special Instructions' ;
    rdfs:comment 'Customer-provided or dispatcher-added instructions for the collection crew. May include access codes, placement details, safety notes, or material descriptions.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingPermitId rdf:type rdf:Property ;
    rdfs:label 'Operating Permit Id' ;
    rdfs:comment 'Unique identifier for the operating permit record. Primary key for the operating permit entity.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Permit .

ind:franchiseAgreementId rdf:type rdf:Property ;
    rdfs:label 'Franchise Agreement Id' ;
    rdfs:comment 'Foreign key linking to contract.franchise_agreement. Business justification: Operating permits implement permit conditions mandated by franchise agreements with municipalities. Franchise compliance verification, permit-to-contract reconciliation, and municipal audit support re' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FranchiseAgreement .

ind:supersededPermitOperatingPermitId rdf:type rdf:Property ;
    rdfs:label 'Superseded Permit Operating Permit Id' ;
    rdfs:comment 'Reference to the previous operating permit that this permit replaces or supersedes, if applicable. Used for tracking permit lineage.' ;
    rdfs:domain ind:OperatingPermit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OperatingPermit .

ind:appealStatus rdf:type rdf:Property ;
    rdfs:label 'Appeal Status' ;
    rdfs:comment 'Status of any appeals or challenges to permit conditions or denial. Tracks legal or administrative proceedings related to the permit.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalMonitoringRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Environmental Monitoring Required Flag' ;
    rdfs:comment 'Indicates whether the permit requires ongoing environmental monitoring such as air quality, water quality, or noise level monitoring.' ;
    rdfs:domain ind:OperatingPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:financialAssuranceAmount rdf:type rdf:Property ;
    rdfs:label 'Financial Assurance Amount' ;
    rdfs:comment 'Required amount of financial assurance in US dollars to be maintained as a condition of the permit. Covers potential closure, remediation, and post-closure costs.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financialAssuranceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Financial Assurance Required Flag' ;
    rdfs:comment 'Indicates whether the permit requires financial assurance instruments such as bonds, letters of credit, or insurance to cover closure and post-closure costs.' ;
    rdfs:domain ind:OperatingPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issueDate rdf:type rdf:Property ;
    rdfs:label 'Issue Date' ;
    rdfs:comment 'The date on which the permit was officially issued by the regulatory authority. Marks the beginning of permit validity.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:issuingAgency rdf:type rdf:Property ;
    rdfs:label 'Issuing Agency' ;
    rdfs:comment 'Name of the regulatory authority that issued the permit. May include EPA, state environmental agencies, or Local Enforcement Agency (LEA).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingAgencyCode rdf:type rdf:Property ;
    rdfs:label 'Issuing Agency Code' ;
    rdfs:comment 'Standardized code or abbreviation for the issuing regulatory agency for system integration and reporting purposes.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastInspectionResult rdf:type rdf:Property ;
    rdfs:label 'Last Inspection Result' ;
    rdfs:comment 'Outcome of the most recent regulatory inspection. Indicates whether the facility was found to be in compliance with permit conditions.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModificationDate rdf:type rdf:Property ;
    rdfs:label 'Last Modification Date' ;
    rdfs:comment 'Date of the most recent modification or amendment to the permit terms or conditions.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:modificationCount rdf:type rdf:Property ;
    rdfs:label 'Modification Count' ;
    rdfs:comment 'Total number of modifications or amendments made to the permit since original issuance. Used for tracking permit change history.' ;
    rdfs:domain ind:OperatingPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:monitoringFrequency rdf:type rdf:Property ;
    rdfs:label 'Monitoring Frequency' ;
    rdfs:comment 'Required frequency of environmental monitoring and compliance reporting as specified in the permit conditions.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingHoursRestriction rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Restriction' ;
    rdfs:comment 'Specific operating hours or time-of-day restrictions imposed by the permit. May limit facility operations to certain days or hours to minimize community impact.' ;
    rdfs:domain ind:OperatingPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitConditions rdf:type rdf:Property ;
    rdfs:label 'Permit Conditions' ;
    rdfs:comment 'Detailed text description of specific conditions, restrictions, and operational requirements imposed by the regulatory authority as part of the permit. May include operating hours, noise limits, traffic restrictions, or environmental monitoring requirements.' ;
    rdfs:domain ind:OperatingPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitDocumentStoragePath rdf:type rdf:Property ;
    rdfs:label 'Permit Document Storage Path' ;
    rdfs:comment 'File system path or document management system reference to the official permit document and supporting materials.' ;
    rdfs:domain ind:OperatingPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permittedAnnualTonnageLimit rdf:type rdf:Property ;
    rdfs:label 'Permitted Annual Tonnage Limit' ;
    rdfs:comment 'Maximum annual tonnage of waste authorized for processing or transfer at the facility under this permit. Used for long-term capacity planning and annual compliance reporting.' ;
    rdfs:domain ind:OperatingPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:permittedDailyTonnageLimit rdf:type rdf:Property ;
    rdfs:label 'Permitted Daily Tonnage Limit' ;
    rdfs:comment 'Maximum daily tonnage of waste authorized for processing or transfer at the facility under this permit, measured in Tons Per Day (TPD). Critical operational constraint for capacity planning and compliance.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:permittedWasteTypes rdf:type rdf:Property ;
    rdfs:label 'Permitted Waste Types' ;
    rdfs:comment 'Comma-separated list or description of waste types authorized for handling under this permit. May include Municipal Solid Waste (MSW), Construction and Demolition (C&D), recyclables, or other specific waste streams.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicNoticeRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Public Notice Required Flag' ;
    rdfs:comment 'Indicates whether the permit requires public notice or community notification for certain operational changes or permit modifications.' ;
    rdfs:domain ind:OperatingPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalDueDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Due Date' ;
    rdfs:comment 'The date by which the permit renewal application must be submitted to the regulatory authority to avoid lapse in coverage.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalStatus rdf:type rdf:Property ;
    rdfs:label 'Renewal Status' ;
    rdfs:comment 'Current status of the permit renewal process. Tracks whether renewal is required and the stage of the renewal application.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingFrequency rdf:type rdf:Property ;
    rdfs:label 'Reporting Frequency' ;
    rdfs:comment 'Required frequency for submitting compliance reports to the regulatory authority as specified in the permit.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsiblePartyContactEmail rdf:type rdf:Property ;
    rdfs:label 'Responsible Party Contact Email' ;
    rdfs:comment 'Primary email address for the responsible party or permit holder for regulatory correspondence and compliance notifications.' ;
    rdfs:domain ind:OperatingPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsiblePartyContactPhone rdf:type rdf:Property ;
    rdfs:label 'Responsible Party Contact Phone' ;
    rdfs:comment 'Primary phone number for the responsible party or permit holder for regulatory correspondence and emergency notifications.' ;
    rdfs:domain ind:OperatingPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsiblePartyName rdf:type rdf:Property ;
    rdfs:label 'Responsible Party Name' ;
    rdfs:comment 'Name of the individual or organization legally responsible for compliance with this permit. Typically the facility operator or permit holder.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationCount rdf:type rdf:Property ;
    rdfs:label 'Violation Count' ;
    rdfs:comment 'Total number of permit violations recorded against this permit since issuance. Used for compliance tracking and risk assessment.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualDepartureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Departure Timestamp' ;
    rdfs:comment 'Actual date and time when the vehicle departed the transfer station. Used for on-time performance tracking and DOT compliance.' ;
    rdfs:domain ind:OutboundHaul ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualTonnage rdf:type rdf:Property ;
    rdfs:label 'Actual Tonnage' ;
    rdfs:comment 'Actual weight of the waste load in tons as measured at the destination facility scale. Used for billing and disposal fee calculation.' ;
    rdfs:domain ind:OutboundHaul ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bolNumber rdf:type rdf:Property ;
    rdfs:label 'Bol Number' ;
    rdfs:comment 'Bill of Lading document number for the outbound haul shipment. Required for DOT compliance and chain-of-custody tracking.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contaminationFlag rdf:type rdf:Property ;
    rdfs:label 'Contamination Flag' ;
    rdfs:comment 'Indicates whether the load was identified as contaminated with prohibited materials or improperly sorted waste streams.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:destinationFacilityType rdf:type rdf:Property ;
    rdfs:label 'Destination Facility Type' ;
    rdfs:comment 'Classification of the destination facility type. MRF = Materials Recovery Facility, WTE = Waste-to-Energy, TSDF = Treatment Storage and Disposal Facility.' ;
    rdfs:domain ind:OutboundHaul ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatchNotes rdf:type rdf:Property ;
    rdfs:label 'Dispatch Notes' ;
    rdfs:comment 'Operational notes from dispatch personnel regarding special handling instructions, route conditions, or coordination requirements.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:driverNotes rdf:type rdf:Property ;
    rdfs:label 'Driver Notes' ;
    rdfs:comment 'Notes entered by the driver regarding delivery conditions, facility operations, delays, or issues encountered during the haul.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedFuelConsumptionGallons rdf:type rdf:Property ;
    rdfs:label 'Estimated Fuel Consumption Gallons' ;
    rdfs:comment 'Estimated fuel consumption in gallons for the outbound haul based on vehicle type, load weight, and route distance.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedTonnage rdf:type rdf:Property ;
    rdfs:label 'Estimated Tonnage' ;
    rdfs:comment 'Estimated weight of the consolidated waste load in tons based on transfer station scale readings or volume calculations.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:generatorSignatureCapturedFlag rdf:type rdf:Property ;
    rdfs:label 'Generator Signature Captured Flag' ;
    rdfs:comment 'Indicates whether the waste generator signature was captured on the manifest or BOL for chain-of-custody compliance.' ;
    rdfs:domain ind:OutboundHaul ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:haulNumber rdf:type rdf:Property ;
    rdfs:label 'Haul Number' ;
    rdfs:comment 'Externally-known business identifier for the outbound haul assignment. Used for operational tracking and communication with drivers, facilities, and regulatory agencies.' ;
    rdfs:domain ind:OutboundHaul ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:haulStatus rdf:type rdf:Property ;
    rdfs:label 'Haul Status' ;
    rdfs:comment 'Current lifecycle status of the outbound haul assignment in the dispatch and delivery workflow.' ;
    rdfs:domain ind:OutboundHaul ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadRejectionFlag rdf:type rdf:Property ;
    rdfs:label 'Load Rejection Flag' ;
    rdfs:comment 'Indicates whether the destination facility rejected the load due to contamination, improper classification, or facility capacity constraints.' ;
    rdfs:domain ind:OutboundHaul ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rcraClassification rdf:type rdf:Property ;
    rdfs:label 'Rcra Classification' ;
    rdfs:comment 'Resource Conservation and Recovery Act classification for the waste load. Determines regulatory handling and disposal requirements.' ;
    rdfs:domain ind:OutboundHaul ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiverSignatureCapturedFlag rdf:type rdf:Property ;
    rdfs:label 'Receiver Signature Captured Flag' ;
    rdfs:comment 'Indicates whether the destination facility receiver signature was captured on the manifest or BOL for chain-of-custody completion.' ;
    rdfs:domain ind:OutboundHaul ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:routeDistanceMiles rdf:type rdf:Property ;
    rdfs:label 'Route Distance Miles' ;
    rdfs:comment 'Total distance in miles from transfer station origin to destination facility. Used for fuel cost allocation and route optimization.' ;
    rdfs:domain ind:OutboundHaul ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduledDepartureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Departure Timestamp' ;
    rdfs:comment 'Planned date and time for the vehicle to depart the transfer station with the consolidated load.' ;
    rdfs:domain ind:OutboundHaul ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sealNumber rdf:type rdf:Property ;
    rdfs:label 'Seal Number' ;
    rdfs:comment 'Tamper-evident seal identifier applied to the trailer or container. Used for security and chain-of-custody verification, especially for hazardous waste.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transporterSignatureCapturedFlag rdf:type rdf:Property ;
    rdfs:label 'Transporter Signature Captured Flag' ;
    rdfs:comment 'Indicates whether the transporter (driver) signature was captured on the manifest or BOL for chain-of-custody compliance.' ;
    rdfs:domain ind:OutboundHaul ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:manifestId rdf:type rdf:Property ;
    rdfs:label 'Manifest Id' ;
    rdfs:comment 'Foreign key linking to hazmat.manifest. Business justification: Individual hazmat pickup events require manifest documentation per RCRA regulations. Links proof-of-service at container level to regulatory chain-of-custody for hazardous waste generators.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Manifest .

ind:arrivalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Arrival Timestamp' ;
    rdfs:comment 'Timestamp when the collection vehicle arrived at the service stop, captured from GPS telemetry.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:estimatedWeightLbs rdf:type rdf:Property ;
    rdfs:label 'Estimated Weight Lbs' ;
    rdfs:comment 'Estimated weight of waste collected in pounds, derived from onboard scale sensors or volumetric calculations.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:liftConfirmationFlag rdf:type rdf:Property ;
    rdfs:label 'Lift Confirmation Flag' ;
    rdfs:comment 'Boolean flag indicating whether the Power Take-Off (PTO) sensor confirmed that the container was physically lifted and emptied.' ;
    rdfs:domain ind:PickupEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:liftCount rdf:type rdf:Property ;
    rdfs:label 'Lift Count' ;
    rdfs:comment 'Number of container lifts performed during this pickup event. Typically 1, but may be higher for multiple containers at a single stop.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overageChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Overage Charge Amount' ;
    rdfs:comment 'Additional charge amount in USD for overage conditions such as excess weight or extra containers, applied per contract terms.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:photoStorageUrl rdf:type rdf:Property ;
    rdfs:label 'Photo Storage Url' ;
    rdfs:comment 'URL reference to the stored photo image in the document management system, if a photo was captured.' ;
    rdfs:domain ind:PickupEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfidScanStatus rdf:type rdf:Property ;
    rdfs:label 'Rfid Scan Status' ;
    rdfs:comment 'Status of the RFID scan attempt indicating whether the container tag was successfully read, failed to read, or encountered other issues.' ;
    rdfs:domain ind:PickupEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledPickupTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Pickup Time' ;
    rdfs:comment 'The originally scheduled time for this pickup as planned in the route optimization system.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:serviceCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Service Completion Timestamp' ;
    rdfs:comment 'Timestamp when the pickup service was completed and the vehicle departed the stop.' ;
    rdfs:domain ind:PickupEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:serviceDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Service Duration Seconds' ;
    rdfs:comment 'Total time in seconds spent at the stop from arrival to departure, used for route efficiency analysis.' ;
    rdfs:domain ind:PickupEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceOutcome rdf:type rdf:Property ;
    rdfs:label 'Service Outcome' ;
    rdfs:comment 'Final outcome of the pickup attempt indicating whether service was completed successfully or the reason for non-completion.' ;
    rdfs:domain ind:PickupEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stopSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Stop Sequence Number' ;
    rdfs:comment 'Sequential order of this stop within the route execution, used for route optimization and performance analysis.' ;
    rdfs:domain ind:PickupEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:truckLoaderType rdf:type rdf:Property ;
    rdfs:label 'Truck Loader Type' ;
    rdfs:comment 'Type of loading mechanism on the collection vehicle. ASL (Automated Side Loader), FEL (Front End Loader), REL (Rear End Loader), Roll-Off, or Side-Load.' ;
    rdfs:domain ind:PickupEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weatherCondition rdf:type rdf:Property ;
    rdfs:label 'Weather Condition' ;
    rdfs:comment 'Weather condition at the time of service, captured for safety analysis and route performance evaluation.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalFacilityId rdf:type rdf:Property ;
    rdfs:label 'Disposal Facility Id' ;
    rdfs:comment 'Reference to the landfill, transfer station, or Materials Recovery Facility (MRF) where the waste was disposed or processed.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:baseRentalCharge rdf:type rdf:Property ;
    rdfs:label 'Base Rental Charge' ;
    rdfs:comment 'Base rental fee in USD for the roll-off container for the authorized rental duration.' ;
    rdfs:domain ind:RolloffOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:containerSizeYards rdf:type rdf:Property ;
    rdfs:label 'Container Size Yards' ;
    rdfs:comment 'Size of the roll-off container in cubic yards. Common sizes: 10, 20, 30, 40 yards.' ;
    rdfs:domain ind:RolloffOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryActualTimestamp rdf:type rdf:Property ;
    rdfs:label 'Delivery Actual Timestamp' ;
    rdfs:comment 'Actual date and time when the roll-off container was delivered to the service address. Captured via driver mobile app or GPS telematics.' ;
    rdfs:domain ind:RolloffOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deliveryScheduledDate rdf:type rdf:Property ;
    rdfs:label 'Delivery Scheduled Date' ;
    rdfs:comment 'Scheduled date for initial delivery of the roll-off container to the service address.' ;
    rdfs:domain ind:RolloffOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disposalCharge rdf:type rdf:Property ;
    rdfs:label 'Disposal Charge' ;
    rdfs:comment 'Charge in USD for disposal of the waste at the landfill or transfer station, based on actual weight and tipping fee schedule.' ;
    rdfs:domain ind:RolloffOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderNumber rdf:type rdf:Property ;
    rdfs:label 'Order Number' ;
    rdfs:comment 'Externally-visible business identifier for the roll-off order. Used on customer communications, work orders, and invoices.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderPlacedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Order Placed Timestamp' ;
    rdfs:comment 'Date and time when the customer placed the roll-off order. Principal business event timestamp for this transaction.' ;
    rdfs:domain ind:RolloffOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:orderStatus rdf:type rdf:Property ;
    rdfs:label 'Order Status' ;
    rdfs:comment 'Current lifecycle status of the roll-off order. Tracks progression from order placement through delivery, service, pull, and invoicing. [ENUM-REF-CANDIDATE: pending|scheduled|delivered|on_site|swapped|pulled|invoiced|cancelled — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overageWeightTons rdf:type rdf:Property ;
    rdfs:label 'Overage Weight Tons' ;
    rdfs:comment 'Weight in tons exceeding the authorized weight limit. Used to calculate overage charges.' ;
    rdfs:domain ind:RolloffOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pullActualTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pull Actual Timestamp' ;
    rdfs:comment 'Actual date and time when the roll-off container was pulled from the service address. Captured via driver mobile app or GPS telematics.' ;
    rdfs:domain ind:RolloffOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pullScheduledDate rdf:type rdf:Property ;
    rdfs:label 'Pull Scheduled Date' ;
    rdfs:comment 'Scheduled date for final pull (removal) of the roll-off container from the service address.' ;
    rdfs:domain ind:RolloffOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rentalDurationDays rdf:type rdf:Property ;
    rdfs:label 'Rental Duration Days' ;
    rdfs:comment 'Number of days the roll-off container is authorized to remain on-site before additional rental charges apply.' ;
    rdfs:domain ind:RolloffOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:swapCount rdf:type rdf:Property ;
    rdfs:label 'Swap Count' ;
    rdfs:comment 'Number of times the roll-off container was swapped (full container pulled and empty container delivered) during the rental period.' ;
    rdfs:domain ind:RolloffOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:weightTicketNumber rdf:type rdf:Property ;
    rdfs:label 'Weight Ticket Number' ;
    rdfs:comment 'Unique identifier for the weight ticket issued at the disposal facility scale. Used for weight verification and billing reconciliation.' ;
    rdfs:domain ind:RolloffOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelPurchaseId rdf:type rdf:Property ;
    rdfs:label 'Fuel Purchase Id' ;
    rdfs:comment 'Foreign key linking to procurement.fuel_purchase. Business justification: Routes plan fuel consumption; operations reconcile planned vs. actual fuel purchases for cost allocation and efficiency analysis. Fleet managers use this to validate fuel budgets per route and detect ' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FuelPurchase .

ind:lineId rdf:type rdf:Property ;
    rdfs:label 'Line Id' ;
    rdfs:comment 'Foreign key linking to service.service_line. Business justification: Routes are organized by service line (residential, commercial, industrial) for operational planning, fleet assignment, and pricing model selection. Essential for route optimization and resource alloca' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Line .

ind:capacityConstraintTons rdf:type rdf:Property ;
    rdfs:label 'Capacity Constraint Tons' ;
    rdfs:comment 'Maximum tonnage capacity for this route based on truck payload limits and disposal facility constraints.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:containerTypePrimary rdf:type rdf:Property ;
    rdfs:label 'Container Type Primary' ;
    rdfs:comment 'Primary type of waste container serviced on this route: cart (residential curbside), bin (small commercial), dumpster (large commercial), compactor, or roll-off container.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endLocationLatitude rdf:type rdf:Property ;
    rdfs:label 'End Location Latitude' ;
    rdfs:comment 'Latitude coordinate of the route end location (typically a disposal facility, transfer station, or return depot).' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:endLocationLongitude rdf:type rdf:Property ;
    rdfs:label 'End Location Longitude' ;
    rdfs:comment 'Longitude coordinate of the route end location (typically a disposal facility, transfer station, or return depot).' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Estimated Duration Minutes' ;
    rdfs:comment 'Planned duration in minutes to complete the entire route under normal conditions, including drive time and service time.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedGhgEmissionsCo2eKg rdf:type rdf:Property ;
    rdfs:label 'Estimated Ghg Emissions Co2e Kg' ;
    rdfs:comment 'Estimated greenhouse gas emissions in kilograms of Carbon Dioxide Equivalent (CO2e) for a typical execution of this route, supporting sustainability and EPA reporting.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelTypeRequired rdf:type rdf:Property ;
    rdfs:label 'Fuel Type Required' ;
    rdfs:comment 'Type of fuel required for vehicles assigned to this route: diesel, Compressed Natural Gas (CNG), Renewable Natural Gas (RNG), electric, or hybrid.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optimizationScore rdf:type rdf:Property ;
    rdfs:label 'Optimization Score' ;
    rdfs:comment 'Efficiency score (0-100) assigned by route optimization algorithms, reflecting factors such as mileage efficiency, stop density, and time utilization.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requiresCdl rdf:type rdf:Property ;
    rdfs:label 'Requires Cdl' ;
    rdfs:comment 'Indicates whether a Commercial Driver License (CDL) is required to operate the vehicle type assigned to this route.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresHazmatCertification rdf:type rdf:Property ;
    rdfs:label 'Requires Hazmat Certification' ;
    rdfs:comment 'Indicates whether hazardous materials handling certification is required for drivers on this route due to the nature of waste collected.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:routeCode rdf:type rdf:Property ;
    rdfs:label 'Route Code' ;
    rdfs:comment 'Business identifier for the route, used in operational systems and driver communications. Typically alphanumeric code assigned by dispatch.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeName rdf:type rdf:Property ;
    rdfs:label 'Route Name' ;
    rdfs:comment 'Human-readable name or description of the route, often including geographic area or customer segment (e.g., \'Downtown Commercial MSW Monday\').' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeStatus rdf:type rdf:Property ;
    rdfs:label 'Route Status' ;
    rdfs:comment 'Current lifecycle status of the route: active (in regular operation), inactive (temporarily not scheduled), suspended (on hold), planned (designed but not yet operational), or retired (permanently discontinued).' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledDayOfWeek rdf:type rdf:Property ;
    rdfs:label 'Scheduled Day Of Week' ;
    rdfs:comment 'Primary day of the week this route is scheduled to run (for weekly/biweekly routes). Multiple days may result in multiple route records or a separate schedule table.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaOnTimeTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Sla On Time Target Percent' ;
    rdfs:comment 'Target percentage of stops that must be serviced within the scheduled time window to meet Service Level Agreement (SLA) commitments.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:startLocationLatitude rdf:type rdf:Property ;
    rdfs:label 'Start Location Latitude' ;
    rdfs:comment 'Latitude coordinate of the route start location (typically a depot or transfer station).' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:startLocationLongitude rdf:type rdf:Property ;
    rdfs:label 'Start Location Longitude' ;
    rdfs:comment 'Longitude coordinate of the route start location (typically a depot or transfer station).' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalMileage rdf:type rdf:Property ;
    rdfs:label 'Total Mileage' ;
    rdfs:comment 'Total planned mileage for the route in miles, including travel to first stop, between stops, and return to facility.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalStops rdf:type rdf:Property ;
    rdfs:label 'Total Stops' ;
    rdfs:comment 'Total number of scheduled service stops (customer pickup points) on this route.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:truckTypeRequired rdf:type rdf:Property ;
    rdfs:label 'Truck Type Required' ;
    rdfs:comment 'Type of collection vehicle required for this route: Automated Side Loader (ASL), Front End Loader (FEL), Rear End Loader (REL), roll-off truck, or compactor truck.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:airEmissionEventId rdf:type rdf:Property ;
    rdfs:label 'Air Emission Event Id' ;
    rdfs:comment 'Foreign key linking to compliance.air_emission_event. Business justification: Route executions generate emissions events when vehicles experience mechanical failures, fuel spills, or exhaust system malfunctions requiring regulatory notification and emissions reporting.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AirEmissionEvent .

ind:auditId rdf:type rdf:Property ;
    rdfs:label 'Audit Id' ;
    rdfs:comment 'Foreign key linking to safety.safety_audit. Business justification: Safety audits are conducted on active route executions to verify driver behavior, vehicle condition, and operational compliance. Real-world safety programs audit routes in progress for behavioral obse' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Audit .

ind:customerComplaintFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Complaint Flag' ;
    rdfs:comment 'Indicates whether any customer complaints were logged against this route execution. True if service quality issues were reported.' ;
    rdfs:domain ind:RouteExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:distanceTraveledMiles rdf:type rdf:Property ;
    rdfs:label 'Distance Traveled Miles' ;
    rdfs:comment 'Total distance traveled during route execution measured in miles. Captured from GPS telematics.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:executionStatus rdf:type rdf:Property ;
    rdfs:label 'Execution Status' ;
    rdfs:comment 'Current lifecycle status of the route execution. Tracks progression from scheduled through completion or cancellation.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelConsumedGallons rdf:type rdf:Property ;
    rdfs:label 'Fuel Consumed Gallons' ;
    rdfs:comment 'Total fuel consumed by the vehicle during this route execution measured in gallons. Sourced from telematics or fuel card data.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:numberOfDumps rdf:type rdf:Property ;
    rdfs:label 'Number Of Dumps' ;
    rdfs:comment 'Count of times the vehicle dumped its load at a disposal or transfer facility during this route execution.' ;
    rdfs:domain ind:RouteExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overtimeFlag rdf:type rdf:Property ;
    rdfs:label 'Overtime Flag' ;
    rdfs:comment 'Indicates whether the route execution resulted in driver overtime hours. True if actual duration exceeded standard shift length.' ;
    rdfs:domain ind:RouteExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plannedEndTime rdf:type rdf:Property ;
    rdfs:label 'Planned End Time' ;
    rdfs:comment 'Scheduled completion time for the route execution as defined in the dispatch plan.' ;
    rdfs:domain ind:RouteExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedStartTime rdf:type rdf:Property ;
    rdfs:label 'Planned Start Time' ;
    rdfs:comment 'Scheduled start time for the route execution as defined in the dispatch plan.' ;
    rdfs:domain ind:RouteExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:routeDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Route Duration Minutes' ;
    rdfs:comment 'Total elapsed time from actual start to actual end of route execution measured in minutes.' ;
    rdfs:domain ind:RouteExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalStopsCompleted rdf:type rdf:Property ;
    rdfs:label 'Total Stops Completed' ;
    rdfs:comment 'Number of collection stops successfully serviced during this route execution.' ;
    rdfs:domain ind:RouteExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalStopsMissed rdf:type rdf:Property ;
    rdfs:label 'Total Stops Missed' ;
    rdfs:comment 'Number of planned stops that were not serviced during this route execution. Includes skipped, inaccessible, and cancelled stops.' ;
    rdfs:domain ind:RouteExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalStopsPlanned rdf:type rdf:Property ;
    rdfs:label 'Total Stops Planned' ;
    rdfs:comment 'Number of collection stops scheduled for this route execution based on the route definition and service calendar.' ;
    rdfs:domain ind:RouteExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalTonnageCollected rdf:type rdf:Property ;
    rdfs:label 'Total Tonnage Collected' ;
    rdfs:comment 'Total weight of waste collected during this route execution measured in tons. Key operational metric for capacity planning and billing.' ;
    rdfs:domain ind:RouteExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalVolumeCollectedCubicYards rdf:type rdf:Property ;
    rdfs:label 'Total Volume Collected Cubic Yards' ;
    rdfs:comment 'Total volume of waste collected during this route execution measured in cubic yards. Used for capacity utilization analysis.' ;
    rdfs:domain ind:RouteExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:routeOptimizationRunId rdf:type rdf:Property ;
    rdfs:label 'Route Optimization Run Id' ;
    rdfs:comment 'Unique identifier for each execution of the route optimization algorithm. Primary key.' ;
    rdfs:domain ind:RouteOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryRouteEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Route Employee Id' ;
    rdfs:comment 'Reference to the user (operations manager or dispatcher) who made the acceptance decision. Nullable if decision is still pending.' ;
    rdfs:domain ind:RouteOptimizationRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:acceptanceDecisionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Acceptance Decision Timestamp' ;
    rdfs:comment 'The date and time when the acceptance decision was made. Nullable if decision is still pending.' ;
    rdfs:domain ind:RouteOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:algorithmVersion rdf:type rdf:Property ;
    rdfs:label 'Algorithm Version' ;
    rdfs:comment 'Version number of the route optimization algorithm used for this run, formatted as major.minor.patch (e.g., 3.2.1).' ;
    rdfs:domain ind:RouteOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselineTotalMiles rdf:type rdf:Property ;
    rdfs:label 'Baseline Total Miles' ;
    rdfs:comment 'Total route miles from the previous or baseline plan, used for comparison to measure optimization improvement. Nullable if no baseline exists.' ;
    rdfs:domain ind:RouteOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:configurationProfileCode rdf:type rdf:Property ;
    rdfs:label 'Configuration Profile Code' ;
    rdfs:comment 'Reference to the optimization configuration profile (parameter set) used for this run, defining weights, constraints, and objectives.' ;
    rdfs:domain ind:RouteOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:errorMessage rdf:type rdf:Property ;
    rdfs:label 'Error Message' ;
    rdfs:comment 'Detailed error or exception message if the optimization run failed or encountered issues. Nullable if run completed successfully.' ;
    rdfs:domain ind:RouteOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionMode rdf:type rdf:Property ;
    rdfs:label 'Execution Mode' ;
    rdfs:comment 'Indicates how the optimization run was initiated: manual (user-triggered), scheduled (automated on schedule), automatic (event-driven), or api_triggered (external system integration).' ;
    rdfs:domain ind:RouteOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inputDriverCount rdf:type rdf:Property ;
    rdfs:label 'Input Driver Count' ;
    rdfs:comment 'Total number of drivers available and included as input to the optimization algorithm.' ;
    rdfs:domain ind:RouteOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inputStopCount rdf:type rdf:Property ;
    rdfs:label 'Input Stop Count' ;
    rdfs:comment 'Total number of customer stops (service locations) included as input to the optimization algorithm.' ;
    rdfs:domain ind:RouteOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inputTruckCount rdf:type rdf:Property ;
    rdfs:label 'Input Truck Count' ;
    rdfs:comment 'Total number of collection vehicles (trucks) available and included as input to the optimization algorithm.' ;
    rdfs:domain ind:RouteOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:milesImprovementPercentage rdf:type rdf:Property ;
    rdfs:label 'Miles Improvement Percentage' ;
    rdfs:comment 'Percentage reduction in total route miles compared to the baseline plan. Positive values indicate improvement (fewer miles). Nullable if no baseline exists.' ;
    rdfs:domain ind:RouteOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:optimizationDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Optimization Duration Seconds' ;
    rdfs:comment 'Total elapsed time in seconds for the optimization algorithm to complete execution.' ;
    rdfs:domain ind:RouteOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:optimizationEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Optimization End Timestamp' ;
    rdfs:comment 'The date and time when the optimization algorithm execution completed or terminated.' ;
    rdfs:domain ind:RouteOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:optimizationQualityScore rdf:type rdf:Property ;
    rdfs:label 'Optimization Quality Score' ;
    rdfs:comment 'Algorithm-generated quality score (0-100) indicating how well the optimized solution meets the defined objectives and constraints. Higher scores indicate better optimization results.' ;
    rdfs:domain ind:RouteOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:optimizationRunNumber rdf:type rdf:Property ;
    rdfs:label 'Optimization Run Number' ;
    rdfs:comment 'Business-friendly identifier for the optimization run, typically formatted as OPT-YYYYMMDD-HHMMSS for traceability.' ;
    rdfs:domain ind:RouteOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optimizationScenarioType rdf:type rdf:Property ;
    rdfs:label 'Optimization Scenario Type' ;
    rdfs:comment 'The business scenario or trigger that initiated this optimization run, such as daily re-optimization, seasonal rebalancing, new customer onboarding, emergency reroute, capacity expansion, or service area change.' ;
    rdfs:domain ind:RouteOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optimizationStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Optimization Start Timestamp' ;
    rdfs:comment 'The date and time when the optimization algorithm execution began.' ;
    rdfs:domain ind:RouteOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:optimizationStatus rdf:type rdf:Property ;
    rdfs:label 'Optimization Status' ;
    rdfs:comment 'Current lifecycle status of the optimization run: queued (awaiting execution), running (in progress), completed (successfully finished), failed (encountered errors), cancelled (manually stopped), or partially_accepted (some routes accepted, others rejected).' ;
    rdfs:domain ind:RouteOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outputAverageHoursPerRoute rdf:type rdf:Property ;
    rdfs:label 'Output Average Hours Per Route' ;
    rdfs:comment 'Average estimated time in hours per route in the optimized plan.' ;
    rdfs:domain ind:RouteOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outputAverageMilesPerRoute rdf:type rdf:Property ;
    rdfs:label 'Output Average Miles Per Route' ;
    rdfs:comment 'Average distance in miles per route in the optimized plan.' ;
    rdfs:domain ind:RouteOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outputAverageStopsPerRoute rdf:type rdf:Property ;
    rdfs:label 'Output Average Stops Per Route' ;
    rdfs:comment 'Average number of customer stops per route in the optimized plan.' ;
    rdfs:domain ind:RouteOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outputRouteCount rdf:type rdf:Property ;
    rdfs:label 'Output Route Count' ;
    rdfs:comment 'Total number of optimized routes generated by the algorithm as output.' ;
    rdfs:domain ind:RouteOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:outputTotalRouteHours rdf:type rdf:Property ;
    rdfs:label 'Output Total Route Hours' ;
    rdfs:comment 'Total estimated time in hours across all optimized routes, including drive time, service time, and breaks.' ;
    rdfs:domain ind:RouteOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outputTotalRouteMiles rdf:type rdf:Property ;
    rdfs:label 'Output Total Route Miles' ;
    rdfs:comment 'Total distance in miles across all optimized routes generated by the algorithm.' ;
    rdfs:domain ind:RouteOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outputUnassignedStopCount rdf:type rdf:Property ;
    rdfs:label 'Output Unassigned Stop Count' ;
    rdfs:comment 'Number of customer stops that could not be assigned to any route due to constraints (capacity, time windows, or other limitations).' ;
    rdfs:domain ind:RouteOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryOptimizationObjective rdf:type rdf:Property ;
    rdfs:label 'Primary Optimization Objective' ;
    rdfs:comment 'The primary business objective the optimization algorithm was configured to achieve: minimize total route miles, minimize total route time, maximize compaction efficiency, balance workload across drivers, minimize operational cost, or maximize service quality.' ;
    rdfs:domain ind:RouteOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryOptimizationObjective rdf:type rdf:Property ;
    rdfs:label 'Secondary Optimization Objective' ;
    rdfs:comment 'The secondary business objective applied as a tie-breaker or secondary goal when the primary objective is met. Nullable if only one objective was used.' ;
    rdfs:domain ind:RouteOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeWindowEnforcementFlag rdf:type rdf:Property ;
    rdfs:label 'Time Window Enforcement Flag' ;
    rdfs:comment 'Indicates whether customer-specific time window constraints were enforced during optimization (True) or relaxed (False).' ;
    rdfs:domain ind:RouteOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vehicleCapacityConstraintFlag rdf:type rdf:Property ;
    rdfs:label 'Vehicle Capacity Constraint Flag' ;
    rdfs:comment 'Indicates whether vehicle capacity constraints (weight and volume limits) were enforced during optimization (True) or relaxed (False).' ;
    rdfs:domain ind:RouteOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lockoutTagoutProcedureId rdf:type rdf:Property ;
    rdfs:label 'Lockout Tagout Procedure Id' ;
    rdfs:comment 'Foreign key linking to safety.lockout_tagout_procedure. Business justification: Scale equipment requires LOTO procedures for maintenance and calibration. This is a regulatory requirement under OSHA 1910.147 for servicing equipment with electrical, hydraulic, and mechanical energy' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LockoutTagoutProcedure .

ind:lotoExecutionId rdf:type rdf:Property ;
    rdfs:label 'Loto Execution Id' ;
    rdfs:comment 'Foreign key linking to safety.loto_execution. Business justification: When scale equipment undergoes maintenance, the actual LOTO execution must be tracked for compliance verification, audit trail, and incident investigation if equipment-related injuries occur during or' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LotoExecution .

ind:pmScheduleId rdf:type rdf:Property ;
    rdfs:label 'Pm Schedule Id' ;
    rdfs:comment 'Foreign key linking to maintenance.pm_schedule. Business justification: Scales require scheduled preventive maintenance (calibration every 90 days, annual certification inspections) per state weights-and-measures regulations. Linking scale_equipment to its PM schedule ena' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PmSchedule .

ind:accuracyClass rdf:type rdf:Property ;
    rdfs:label 'Accuracy Class' ;
    rdfs:comment 'NIST accuracy classification for the scale equipment. Class I (precision laboratory), Class II (precision commercial), Class III (commercial/vehicle scales - most common for waste operations), Class IIII (wheel-load weighers). Determines acceptable tolerance and verification requirements.' ;
    rdfs:domain ind:ScaleEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acquisitionCostAmount rdf:type rdf:Property ;
    rdfs:label 'Acquisition Cost Amount' ;
    rdfs:comment 'Total capital cost of acquiring and installing the scale equipment, including hardware, foundation, installation labor, and initial calibration. Used for asset valuation and depreciation calculations.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calibrationAuthority rdf:type rdf:Property ;
    rdfs:label 'Calibration Authority' ;
    rdfs:comment 'Name of the organization or agency that performed the most recent calibration. Typically a state weights and measures department or certified third-party calibration service provider.' ;
    rdfs:domain ind:ScaleEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Calibration Certificate Number' ;
    rdfs:comment 'Unique identifier for the most recent calibration certificate issued by the authorized calibration service provider or weights and measures authority. Required for audit and compliance verification.' ;
    rdfs:domain ind:ScaleEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cameraSystemInstalledFlag rdf:type rdf:Property ;
    rdfs:label 'Camera System Installed Flag' ;
    rdfs:comment 'Indicates whether the scale is equipped with camera systems for license plate recognition, load verification, or security monitoring. True if cameras are installed, false otherwise.' ;
    rdfs:domain ind:ScaleEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capacityTons rdf:type rdf:Property ;
    rdfs:label 'Capacity Tons' ;
    rdfs:comment 'Maximum weight capacity of the scale equipment measured in tons. Represents the upper limit for safe and accurate weighing operations. Critical for operational planning and load management.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:divisionSizeLbs rdf:type rdf:Property ;
    rdfs:label 'Division Size Lbs' ;
    rdfs:comment 'The smallest unit of weight that the scale can display and measure, expressed in pounds. Also known as scale increment or readability. Determines the precision of weight measurements.' ;
    rdfs:domain ind:ScaleEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalProtectionRating rdf:type rdf:Property ;
    rdfs:label 'Environmental Protection Rating' ;
    rdfs:comment 'IP (Ingress Protection) rating or equivalent environmental protection classification for the scale electronics and load cells. Indicates resistance to dust, moisture, and harsh conditions typical in waste operations.' ;
    rdfs:domain ind:ScaleEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:foundationType rdf:type rdf:Property ;
    rdfs:label 'Foundation Type' ;
    rdfs:comment 'Type of foundation construction for the scale installation. Concrete pit is below-grade installation, above ground is surface-mounted, shallow pit is partially recessed, modular is prefabricated foundation system. Affects maintenance access and drainage requirements.' ;
    rdfs:domain ind:ScaleEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inboundOutboundDesignation rdf:type rdf:Property ;
    rdfs:label 'Inbound Outbound Designation' ;
    rdfs:comment 'Indicates whether the scale is designated for inbound collection vehicles, outbound transfer haul vehicles, or bidirectional use for both traffic flows. Critical for operational flow management and weight ticket routing.' ;
    rdfs:domain ind:ScaleEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indicatorModel rdf:type rdf:Property ;
    rdfs:label 'Indicator Model' ;
    rdfs:comment 'Model designation of the digital weight indicator (display and processing unit) connected to the scale. The indicator converts load cell signals to weight readings and interfaces with ticketing systems.' ;
    rdfs:domain ind:ScaleEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indicatorSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Indicator Serial Number' ;
    rdfs:comment 'Unique serial number of the weight indicator unit. Required for NTEP certification tracking and service documentation.' ;
    rdfs:domain ind:ScaleEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastCalibrationDate rdf:type rdf:Property ;
    rdfs:label 'Last Calibration Date' ;
    rdfs:comment 'Date of the most recent calibration performed on the scale equipment. Calibration ensures measurement accuracy and is required for regulatory compliance with state weights and measures authorities.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:loadCellCount rdf:type rdf:Property ;
    rdfs:label 'Load Cell Count' ;
    rdfs:comment 'Number of load cells (weight sensors) installed in the scale system. Typical configurations range from 4 to 12 load cells depending on platform size and capacity. Critical for maintenance planning and troubleshooting.' ;
    rdfs:domain ind:ScaleEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maintenanceContractNumber rdf:type rdf:Property ;
    rdfs:label 'Maintenance Contract Number' ;
    rdfs:comment 'Reference number for the active preventive maintenance or service contract covering this scale equipment. Links to vendor service agreements and scheduled maintenance activities.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextCalibrationDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Calibration Due Date' ;
    rdfs:comment 'Scheduled date for the next required calibration of the scale equipment. Used for preventive maintenance planning and regulatory compliance tracking. Typically annual or semi-annual based on jurisdiction requirements.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ntepCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Ntep Certificate Number' ;
    rdfs:comment 'Certificate number issued by the National Conference on Weights and Measures (NCWM) National Type Evaluation Program, certifying that the scale design meets NIST Handbook 44 requirements. Required for commercial weighing applications in most U.S. jurisdictions.' ;
    rdfs:domain ind:ScaleEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationalStatus rdf:type rdf:Property ;
    rdfs:label 'Operational Status' ;
    rdfs:comment 'Current operational state of the scale equipment. Active indicates in-service and available for weighing operations, inactive for temporarily offline, maintenance for scheduled service, out_of_service for equipment failures, decommissioned for permanently retired units.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformLengthFeet rdf:type rdf:Property ;
    rdfs:label 'Platform Length Feet' ;
    rdfs:comment 'Length of the scale weighing platform measured in feet. Determines the maximum vehicle length that can be accommodated for single-draft weighing. Typical truck scales range from 40 to 100 feet.' ;
    rdfs:domain ind:ScaleEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:platformWidthFeet rdf:type rdf:Property ;
    rdfs:label 'Platform Width Feet' ;
    rdfs:comment 'Width of the scale weighing platform measured in feet. Standard truck scale widths are typically 10 to 12 feet to accommodate commercial vehicle axle spacing.' ;
    rdfs:domain ind:ScaleEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:printerIntegrationType rdf:type rdf:Property ;
    rdfs:label 'Printer Integration Type' ;
    rdfs:comment 'Method by which weight ticket printers are connected to the scale system. Direct serial for RS-232 connection, network for TCP/IP, USB for local connection, none if no printer is integrated.' ;
    rdfs:domain ind:ScaleEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remoteDisplayEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Remote Display Enabled Flag' ;
    rdfs:comment 'Indicates whether the scale is equipped with remote weight displays visible to drivers. True if remote displays are installed and operational, false otherwise. Enhances transparency and reduces disputes.' ;
    rdfs:domain ind:ScaleEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rfidReaderInstalledFlag rdf:type rdf:Property ;
    rdfs:label 'Rfid Reader Installed Flag' ;
    rdfs:comment 'Indicates whether the scale is equipped with RFID readers for automated vehicle or container identification. True if RFID capability is installed, false otherwise. Enables touchless weighing workflows.' ;
    rdfs:domain ind:ScaleEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scaleHouseLocation rdf:type rdf:Property ;
    rdfs:label 'Scale House Location' ;
    rdfs:comment 'Physical location description of the scale house or weighing station within the transfer station facility. Used for operational routing and driver instructions.' ;
    rdfs:domain ind:ScaleEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scaleNumber rdf:type rdf:Property ;
    rdfs:label 'Scale Number' ;
    rdfs:comment 'Business identifier for the scale equipment, used for operational reference and reporting. Externally visible scale designation.' ;
    rdfs:domain ind:ScaleEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scaleType rdf:type rdf:Property ;
    rdfs:label 'Scale Type' ;
    rdfs:comment 'Classification of the scale equipment based on its design and intended use. Truck scales are for full vehicle weighing, axle scales for individual axle measurement, floor scales for smaller loads, platform scales for container weighing, portable scales for temporary installations, and rail scales for rail car weighing.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:softwareSystemIntegration rdf:type rdf:Property ;
    rdfs:label 'Software System Integration' ;
    rdfs:comment 'Name of the enterprise software system that the scale is integrated with for automated weight ticket generation and data capture. Typically ERP, billing, or waste management platform.' ;
    rdfs:domain ind:ScaleEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unattendedOperationEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Unattended Operation Enabled Flag' ;
    rdfs:comment 'Indicates whether the scale is configured for unattended self-service operation by drivers. True if kiosk or automated systems allow operation without scale house attendant, false for attended-only operation.' ;
    rdfs:domain ind:ScaleEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:weighmasterCertificationStatus rdf:type rdf:Property ;
    rdfs:label 'Weighmaster Certification Status' ;
    rdfs:comment 'Indicates whether the scale location has current weighmaster certification as required by state regulations. Certified means valid certification is in place, expired means renewal is needed, not_required for jurisdictions without this requirement, pending for applications in process.' ;
    rdfs:domain ind:ScaleEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingDate rdf:type rdf:Property ;
    rdfs:label 'Billing Date' ;
    rdfs:comment 'Date when the scale transaction was included in customer billing. Used for revenue recognition and accounts receivable tracking.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:grossWeightLbs rdf:type rdf:Property ;
    rdfs:label 'Gross Weight Lbs' ;
    rdfs:comment 'Total weight of the vehicle and load combined, measured in pounds. Captured during the first weighing event.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:loadType rdf:type rdf:Property ;
    rdfs:label 'Load Type' ;
    rdfs:comment 'Classification of the load source. Indicates whether the load originated from collection routes, transfer operations, commercial customers, residential service, rolloff containers, or special waste handling.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netWeightLbs rdf:type rdf:Property ;
    rdfs:label 'Net Weight Lbs' ;
    rdfs:comment 'Net weight of the load only, calculated as gross weight minus tare weight, measured in pounds.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scaleCalibrationRecordNumber rdf:type rdf:Property ;
    rdfs:label 'Scale Calibration Record Number' ;
    rdfs:comment 'Reference to the most recent scale calibration record at the time of transaction. Ensures measurement accuracy and regulatory compliance.' ;
    rdfs:domain ind:ScaleTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionDate rdf:type rdf:Property ;
    rdfs:label 'Transaction Date' ;
    rdfs:comment 'Business date of the scale transaction. Used for daily reporting, billing cycles, and operational analytics.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transactionStatus rdf:type rdf:Property ;
    rdfs:label 'Transaction Status' ;
    rdfs:comment 'Current lifecycle status of the scale transaction. Tracks whether the transaction is completed, pending validation, voided, under dispute, corrected, or rejected.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transaction Timestamp' ;
    rdfs:comment 'Date and time when the scale transaction was recorded. Primary business event timestamp for the weighing event.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:validationNotes rdf:type rdf:Property ;
    rdfs:label 'Validation Notes' ;
    rdfs:comment 'Notes recorded during the validation process. Captures reasons for rejection, corrections made, or special circumstances requiring review.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehiclePlateNumber rdf:type rdf:Property ;
    rdfs:label 'Vehicle Plate Number' ;
    rdfs:comment 'License plate number of the vehicle being weighed. Used for manual verification and cross-reference.' ;
    rdfs:domain ind:ScaleTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteStreamCode rdf:type rdf:Property ;
    rdfs:label 'Waste Stream Code' ;
    rdfs:comment 'Code identifying the type of waste material being weighed. Examples include MSW (Municipal Solid Waste), C&D (Construction and Demolition), recyclables, organics, hazardous waste.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weighmasterCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Weighmaster Certification Number' ;
    rdfs:comment 'Certification number of the licensed weighmaster who validated the transaction. Required for regulatory compliance in jurisdictions with weighmaster certification requirements.' ;
    rdfs:domain ind:ScaleTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyResponseIncidentId rdf:type rdf:Property ;
    rdfs:label 'Emergency Response Incident Id' ;
    rdfs:comment 'Foreign key linking to hazmat.emergency_response_incident. Business justification: Service exceptions involving hazmat spills or releases trigger emergency response incidents requiring NRC notification. Links operational exception tracking to regulatory incident reporting and remedi' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EmergencyResponseIncident .

ind:primaryServiceRouteId rdf:type rdf:Property ;
    rdfs:label 'Primary Service Route Id' ;
    rdfs:comment 'Reference to the collection route where the exception occurred.' ;
    rdfs:domain ind:ServiceException ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Route .

ind:spillReleaseId rdf:type rdf:Property ;
    rdfs:label 'Spill Release Id' ;
    rdfs:comment 'Foreign key linking to compliance.spill_release. Business justification: Service exceptions involving spills or releases of hazardous materials trigger spill_release incident reporting and regulatory notification to environmental agencies per CERCLA and state requirements.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SpillRelease .

ind:contaminationSeverity rdf:type rdf:Property ;
    rdfs:label 'Contamination Severity' ;
    rdfs:comment 'Severity level of contamination requiring different handling or customer education responses.' ;
    rdfs:domain ind:ServiceException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditIssuedFlag rdf:type rdf:Property ;
    rdfs:label 'Credit Issued Flag' ;
    rdfs:comment 'Indicates whether a billing credit was issued to the customer as a result of this exception.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerNotificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Timestamp' ;
    rdfs:comment 'Date and time when the customer was notified about the service exception.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:customerNotifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Notified Flag' ;
    rdfs:comment 'Indicates whether the customer has been notified about the service exception.' ;
    rdfs:domain ind:ServiceException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exceptionNumber rdf:type rdf:Property ;
    rdfs:label 'Exception Number' ;
    rdfs:comment 'Business-facing unique exception tracking number displayed to customers and service personnel.' ;
    rdfs:domain ind:ServiceException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionStatus rdf:type rdf:Property ;
    rdfs:label 'Exception Status' ;
    rdfs:comment 'Current lifecycle status of the service exception indicating resolution progress.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Exception Timestamp' ;
    rdfs:comment 'Date and time when the service exception was encountered or reported by the driver in the field.' ;
    rdfs:domain ind:ServiceException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:exceptionTypeCode rdf:type rdf:Property ;
    rdfs:label 'Exception Type Code' ;
    rdfs:comment 'Standardized code categorizing the type of service exception encountered during collection operations. [ENUM-REF-CANDIDATE: MISSED_PICKUP|CONTAMINATION|BLOCKED_ACCESS|OVERWEIGHT|OVERFILLED|WRONG_MATERIAL|NO_CONTAINER|DAMAGED_CONTAINER|SAFETY_HAZARD|WEATHER_DELAY|EQUIPMENT_FAILURE|CUSTOMER_NOT_READY — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ServiceException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpScheduledDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Scheduled Date' ;
    rdfs:comment 'Scheduled date for follow-up service or resolution action related to this exception.' ;
    rdfs:domain ind:ServiceException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:photoStoragePath rdf:type rdf:Property ;
    rdfs:label 'Photo Storage Path' ;
    rdfs:comment 'File system or cloud storage path reference to exception documentation photos.' ;
    rdfs:domain ind:ServiceException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preventableFlag rdf:type rdf:Property ;
    rdfs:label 'Preventable Flag' ;
    rdfs:comment 'Indicates whether the exception was preventable through operational improvements or customer education.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:repeatExceptionFlag rdf:type rdf:Property ;
    rdfs:label 'Repeat Exception Flag' ;
    rdfs:comment 'Indicates whether this is a recurring exception at the same service address or for the same customer.' ;
    rdfs:domain ind:ServiceException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportedBySource rdf:type rdf:Property ;
    rdfs:label 'Reported By Source' ;
    rdfs:comment 'Indicates the source or channel through which the exception was initially reported.' ;
    rdfs:domain ind:ServiceException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresFollowUpFlag rdf:type rdf:Property ;
    rdfs:label 'Requires Follow Up Flag' ;
    rdfs:comment 'Indicates whether this exception requires additional follow-up action or customer contact.' ;
    rdfs:domain ind:ServiceException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rescheduleRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Reschedule Required Flag' ;
    rdfs:comment 'Indicates whether the missed or incomplete service requires rescheduling on a future route.' ;
    rdfs:domain ind:ServiceException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resolutionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Resolution Timestamp' ;
    rdfs:comment 'Date and time when the service exception was marked as resolved or closed.' ;
    rdfs:domain ind:ServiceException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:serviceScheduleId rdf:type rdf:Property ;
    rdfs:label 'Service Schedule Id' ;
    rdfs:comment 'Unique identifier for the service schedule record. Primary key.' ;
    rdfs:domain ind:ServiceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:createdByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Created By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Service schedules track which employee created them for audit trail, training assessment, and accountability in customer service setup—complements modified_by_user for change tracking.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:slaTermId rdf:type rdf:Property ;
    rdfs:label 'Sla Term Id' ;
    rdfs:comment 'Reference to the SLA governing this service schedule. Defines performance commitments, response times, and service guarantees.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SlaTerm .

ind:accessRequirements rdf:type rdf:Property ;
    rdfs:label 'Access Requirements' ;
    rdfs:comment 'Special access conditions required to service this stop. Used for driver preparation and route planning.' ;
    rdfs:domain ind:ServiceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoRenewFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Renew Flag' ;
    rdfs:comment 'Indicates whether this schedule automatically renews at the end of its term. True if the schedule continues indefinitely unless cancelled.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:billingFrequency rdf:type rdf:Property ;
    rdfs:label 'Billing Frequency' ;
    rdfs:comment 'Frequency at which the customer is billed for this scheduled service. May differ from service frequency.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerSizeUnit rdf:type rdf:Property ;
    rdfs:label 'Container Size Unit' ;
    rdfs:comment 'Unit of measure for the container size. Standardizes capacity reporting across different container types.' ;
    rdfs:domain ind:ServiceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalScheduleCode rdf:type rdf:Property ;
    rdfs:label 'External Schedule Code' ;
    rdfs:comment 'Unique identifier from the source operational system. Used for cross-system reconciliation and integration.' ;
    rdfs:domain ind:ServiceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fridayFlag rdf:type rdf:Property ;
    rdfs:label 'Friday Flag' ;
    rdfs:comment 'Indicates whether service is scheduled on Fridays. True if Friday is a scheduled service day.' ;
    rdfs:domain ind:ServiceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:holidayHandlingRule rdf:type rdf:Property ;
    rdfs:label 'Holiday Handling Rule' ;
    rdfs:comment 'Defines how service is adjusted when a scheduled day falls on a recognized holiday. Determines whether service is skipped, rescheduled, or delivered as normal.' ;
    rdfs:domain ind:ServiceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mondayFlag rdf:type rdf:Property ;
    rdfs:label 'Monday Flag' ;
    rdfs:comment 'Indicates whether service is scheduled on Mondays. True if Monday is a scheduled service day.' ;
    rdfs:domain ind:ServiceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:routeAssignmentMethod rdf:type rdf:Property ;
    rdfs:label 'Route Assignment Method' ;
    rdfs:comment 'Method used to assign this schedule to collection routes. Fixed schedules are always on the same route; dynamic schedules are optimized daily.' ;
    rdfs:domain ind:ServiceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:saturdayFlag rdf:type rdf:Property ;
    rdfs:label 'Saturday Flag' ;
    rdfs:comment 'Indicates whether service is scheduled on Saturdays. True if Saturday is a scheduled service day.' ;
    rdfs:domain ind:ServiceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceWindowEndTime rdf:type rdf:Property ;
    rdfs:label 'Service Window End Time' ;
    rdfs:comment 'Latest time of day when service can be performed at this stop. Format HH:MM in 24-hour notation. Used for route optimization and customer expectations.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:serviceWindowStartTime rdf:type rdf:Property ;
    rdfs:label 'Service Window Start Time' ;
    rdfs:comment 'Earliest time of day when service can be performed at this stop. Format HH:MM in 24-hour notation. Used for route optimization and customer expectations.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sundayFlag rdf:type rdf:Property ;
    rdfs:label 'Sunday Flag' ;
    rdfs:comment 'Indicates whether service is scheduled on Sundays. True if Sunday is a scheduled service day.' ;
    rdfs:domain ind:ServiceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:thursdayFlag rdf:type rdf:Property ;
    rdfs:label 'Thursday Flag' ;
    rdfs:comment 'Indicates whether service is scheduled on Thursdays. True if Thursday is a scheduled service day.' ;
    rdfs:domain ind:ServiceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tuesdayFlag rdf:type rdf:Property ;
    rdfs:label 'Tuesday Flag' ;
    rdfs:comment 'Indicates whether service is scheduled on Tuesdays. True if Tuesday is a scheduled service day.' ;
    rdfs:domain ind:ServiceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:wasteStream rdf:type rdf:Property ;
    rdfs:label 'Waste Stream' ;
    rdfs:comment 'Classification of the waste material being collected. Determines disposal routing, processing requirements, and regulatory compliance obligations. MSW = Municipal Solid Waste, C&D = Construction and Demolition. [ENUM-REF-CANDIDATE: msw|recycling|organics|yard_waste|construction_demolition|hazardous|special — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ServiceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wednesdayFlag rdf:type rdf:Property ;
    rdfs:label 'Wednesday Flag' ;
    rdfs:comment 'Indicates whether service is scheduled on Wednesdays. True if Wednesday is a scheduled service day.' ;
    rdfs:domain ind:ServiceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryShiftEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Shift Employee Id' ;
    rdfs:comment 'Reference to the supervisor responsible for overseeing operations during this shift.' ;
    rdfs:domain ind:ShiftLog ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:contaminationIncidentCount rdf:type rdf:Property ;
    rdfs:label 'Contamination Incident Count' ;
    rdfs:comment 'Number of contamination incidents identified during the shift where prohibited materials were detected in waste streams.' ;
    rdfs:domain ind:ShiftLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contaminationIncidentSummary rdf:type rdf:Property ;
    rdfs:label 'Contamination Incident Summary' ;
    rdfs:comment 'Description of contamination incidents including material types, sources, and corrective actions taken to address the contamination.' ;
    rdfs:domain ind:ShiftLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentDeployed rdf:type rdf:Property ;
    rdfs:label 'Equipment Deployed' ;
    rdfs:comment 'Comma-separated list of equipment units deployed during the shift, including loaders, compactors, and other machinery with asset identifiers.' ;
    rdfs:domain ind:ShiftLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentIssuesNoted rdf:type rdf:Property ;
    rdfs:label 'Equipment Issues Noted' ;
    rdfs:comment 'Narrative description of any equipment malfunctions, breakdowns, or performance issues observed during the shift requiring maintenance attention.' ;
    rdfs:domain ind:ShiftLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:floorClearanceTimestamp rdf:type rdf:Property ;
    rdfs:label 'Floor Clearance Timestamp' ;
    rdfs:comment 'Timestamp when the tipping floor was cleared of all waste material and ready for the next shift or end-of-day closure.' ;
    rdfs:domain ind:ShiftLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:logNumber rdf:type rdf:Property ;
    rdfs:label 'Log Number' ;
    rdfs:comment 'Human-readable business identifier for the shift log, typically formatted as station code, date, and shift sequence.' ;
    rdfs:domain ind:ShiftLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationalAnomalyDescription rdf:type rdf:Property ;
    rdfs:label 'Operational Anomaly Description' ;
    rdfs:comment 'Detailed narrative of operational anomalies, unusual events, or deviations from standard operating procedures encountered during the shift.' ;
    rdfs:domain ind:ShiftLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationalAnomalyFlag rdf:type rdf:Property ;
    rdfs:label 'Operational Anomaly Flag' ;
    rdfs:comment 'Boolean indicator of whether any operational anomalies or deviations from normal procedures occurred during the shift.' ;
    rdfs:domain ind:ShiftLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operationalHoldDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Operational Hold Duration Minutes' ;
    rdfs:comment 'Total duration in minutes that operations were on hold or stopped during the shift.' ;
    rdfs:domain ind:ShiftLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operationalHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Operational Hold Flag' ;
    rdfs:comment 'Boolean indicator of whether operations were placed on hold or stopped during the shift due to safety, equipment, or regulatory reasons.' ;
    rdfs:domain ind:ShiftLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operationalHoldReason rdf:type rdf:Property ;
    rdfs:label 'Operational Hold Reason' ;
    rdfs:comment 'Explanation of why operations were placed on hold, including safety concerns, equipment failure, regulatory inspection, or other causes.' ;
    rdfs:domain ind:ShiftLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryInspectionSummary rdf:type rdf:Property ;
    rdfs:label 'Regulatory Inspection Summary' ;
    rdfs:comment 'Summary of the regulatory inspection including areas reviewed, findings, citations issued, and follow-up actions required.' ;
    rdfs:domain ind:ShiftLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryInspectorAgency rdf:type rdf:Property ;
    rdfs:label 'Regulatory Inspector Agency' ;
    rdfs:comment 'Name of the regulatory agency or local enforcement authority whose inspector visited the facility during the shift.' ;
    rdfs:domain ind:ShiftLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryInspectorVisitFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Inspector Visit Flag' ;
    rdfs:comment 'Boolean indicator of whether a regulatory inspector from EPA, state environmental agency, or local enforcement authority visited the facility during the shift.' ;
    rdfs:domain ind:ShiftLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:safetyIncidentCount rdf:type rdf:Property ;
    rdfs:label 'Safety Incident Count' ;
    rdfs:comment 'Number of safety incidents reported during the shift, including injuries, near-misses, and hazardous conditions.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:safetyIncidentSummary rdf:type rdf:Property ;
    rdfs:label 'Safety Incident Summary' ;
    rdfs:comment 'Brief summary of safety incidents that occurred during the shift, including nature, location, and immediate response actions taken.' ;
    rdfs:domain ind:ShiftLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftDate rdf:type rdf:Property ;
    rdfs:label 'Shift Date' ;
    rdfs:comment 'Calendar date on which the shift occurred.' ;
    rdfs:domain ind:ShiftLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shiftHandoverNotes rdf:type rdf:Property ;
    rdfs:label 'Shift Handover Notes' ;
    rdfs:comment 'Narrative notes provided by the shift supervisor to the incoming shift, documenting ongoing issues, pending tasks, and operational status for continuity.' ;
    rdfs:domain ind:ShiftLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftStatus rdf:type rdf:Property ;
    rdfs:label 'Shift Status' ;
    rdfs:comment 'Current lifecycle status of the shift log record indicating whether it is in draft, active, completed, under review, or approved state.' ;
    rdfs:domain ind:ShiftLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftType rdf:type rdf:Property ;
    rdfs:label 'Shift Type' ;
    rdfs:comment 'Classification of the shift period: day shift, evening shift, night shift, weekend shift, or holiday shift.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:staffingHeadcount rdf:type rdf:Property ;
    rdfs:label 'Staffing Headcount' ;
    rdfs:comment 'Total number of personnel assigned and present during the shift, including operators, spotters, and support staff.' ;
    rdfs:domain ind:ShiftLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tippingFloorUtilizationPercent rdf:type rdf:Property ;
    rdfs:label 'Tipping Floor Utilization Percent' ;
    rdfs:comment 'Percentage of tipping floor capacity utilized during the shift, calculated as occupied area divided by total available area.' ;
    rdfs:domain ind:ShiftLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalLoadsReceived rdf:type rdf:Property ;
    rdfs:label 'Total Loads Received' ;
    rdfs:comment 'Total count of waste loads received at the transfer station during this shift from collection vehicles and other sources.' ;
    rdfs:domain ind:ShiftLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalTonnageProcessed rdf:type rdf:Property ;
    rdfs:label 'Total Tonnage Processed' ;
    rdfs:comment 'Total weight in tons of waste material processed through the transfer station during this shift, measured via scale tickets.' ;
    rdfs:domain ind:ShiftLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:generatorEpaIdRegistrationId rdf:type rdf:Property ;
    rdfs:label 'Generator Epa Id Registration Id' ;
    rdfs:comment 'Foreign key linking to hazmat.epa_id_registration. Business justification: Stops at hazmat generator sites reference EPA ID for regulatory tracking and service authorization. Required for verifying generator permit status at point of service.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EpaIdRegistration .

ind:accessInstructions rdf:type rdf:Property ;
    rdfs:label 'Access Instructions' ;
    rdfs:comment 'Special instructions for accessing the service location, such as gate codes, key locations, or entry procedures.' ;
    rdfs:domain ind:CollectionStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualArrivalTime rdf:type rdf:Property ;
    rdfs:label 'Actual Arrival Time' ;
    rdfs:comment 'Actual timestamp when the collection vehicle arrived at this stop, captured via GPS telematics or driver input.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualServiceEndTime rdf:type rdf:Property ;
    rdfs:label 'Actual Service End Time' ;
    rdfs:comment 'Timestamp when service activity was completed at this stop.' ;
    rdfs:domain ind:CollectionStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualServiceStartTime rdf:type rdf:Property ;
    rdfs:label 'Actual Service Start Time' ;
    rdfs:comment 'Timestamp when service activity began at this stop.' ;
    rdfs:domain ind:CollectionStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cidTagIdentifiers rdf:type rdf:Property ;
    rdfs:label 'Cid Tag Identifiers' ;
    rdfs:comment 'Comma-separated list of CID or RFID tag identifiers for containers at this stop, used for automated container tracking.' ;
    rdfs:domain ind:CollectionStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedServiceDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Estimated Service Duration Minutes' ;
    rdfs:comment 'Expected time in minutes required to complete service at this stop, used for route time calculations.' ;
    rdfs:domain ind:CollectionStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:geofenceRadiusMeters rdf:type rdf:Property ;
    rdfs:label 'Geofence Radius Meters' ;
    rdfs:comment 'Radius in meters defining the geofence boundary around the stop location, used to trigger automated arrival/departure events.' ;
    rdfs:domain ind:CollectionStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedArrivalTime rdf:type rdf:Property ;
    rdfs:label 'Planned Arrival Time' ;
    rdfs:comment 'Scheduled timestamp when the collection vehicle is expected to arrive at this stop, based on route optimization.' ;
    rdfs:domain ind:CollectionStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedServiceWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Planned Service Window End' ;
    rdfs:comment 'End of the time window during which service is scheduled to occur.' ;
    rdfs:domain ind:CollectionStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedServiceWindowStart rdf:type rdf:Property ;
    rdfs:label 'Planned Service Window Start' ;
    rdfs:comment 'Beginning of the time window during which service is scheduled to occur, often used for commercial SLA commitments.' ;
    rdfs:domain ind:CollectionStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requiresBackup rdf:type rdf:Property ;
    rdfs:label 'Requires Backup' ;
    rdfs:comment 'Flag indicating whether the collection vehicle must back up to access this stop, relevant for safety and route planning.' ;
    rdfs:domain ind:CollectionStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresPpe rdf:type rdf:Property ;
    rdfs:label 'Requires Ppe' ;
    rdfs:comment 'Flag indicating whether specialized personal protective equipment is required for service at this stop due to hazardous materials or safety concerns.' ;
    rdfs:domain ind:CollectionStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceDayOfWeek rdf:type rdf:Property ;
    rdfs:label 'Service Day Of Week' ;
    rdfs:comment 'Designated day of the week when this stop is scheduled for service. [ENUM-REF-CANDIDATE: monday|tuesday|wednesday|thursday|friday|saturday|sunday — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skipReasonCode rdf:type rdf:Property ;
    rdfs:label 'Skip Reason Code' ;
    rdfs:comment 'Standardized code indicating why service was not completed at this stop, if applicable. [ENUM-REF-CANDIDATE: no_access|blocked|weather|customer_request|equipment_failure|safety_concern|no_waste_out — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CollectionStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skipReasonNotes rdf:type rdf:Property ;
    rdfs:label 'Skip Reason Notes' ;
    rdfs:comment 'Free-text explanation providing additional context for why service was skipped.' ;
    rdfs:domain ind:CollectionStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialHandlingNotes rdf:type rdf:Property ;
    rdfs:label 'Special Handling Notes' ;
    rdfs:comment 'Additional instructions for service delivery, such as backup required, hazardous materials present, or customer preferences.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stopNumber rdf:type rdf:Property ;
    rdfs:label 'Stop Number' ;
    rdfs:comment 'Business identifier for the stop, often used in driver manifests and dispatch communications.' ;
    rdfs:domain ind:CollectionStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stopStatus rdf:type rdf:Property ;
    rdfs:label 'Stop Status' ;
    rdfs:comment 'Current operational status of the stop within its service lifecycle.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stopType rdf:type rdf:Property ;
    rdfs:label 'Stop Type' ;
    rdfs:comment 'Classification of the stop based on customer segment and service characteristics.' ;
    rdfs:domain ind:CollectionStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeCollectedCubicYards rdf:type rdf:Property ;
    rdfs:label 'Volume Collected Cubic Yards' ;
    rdfs:comment 'Estimated volume in cubic yards of waste collected at this stop.' ;
    rdfs:domain ind:CollectionStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightCollectedLbs rdf:type rdf:Property ;
    rdfs:label 'Weight Collected Lbs' ;
    rdfs:comment 'Total weight in pounds of waste collected at this stop, captured via onboard scales or estimated.' ;
    rdfs:domain ind:CollectionStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryTippingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Tipping Employee Id' ;
    rdfs:comment 'Identifier of the user who approved this tipping fee rate. Nullable if not yet approved.' ;
    rdfs:domain ind:TippingFeeRate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:supersededByRateTippingFeeRateId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Rate Tipping Fee Rate Id' ;
    rdfs:comment 'Reference to the new rate that replaces this rate when status is superseded. Nullable for active rates. Maintains rate version history.' ;
    rdfs:domain ind:TippingFeeRate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TippingFeeRate .

ind:tertiaryTippingLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Tipping Last Modified By User Employee Id' ;
    rdfs:comment 'Identifier of the user who last modified this tipping fee rate record. Used for audit trail and accountability.' ;
    rdfs:domain ind:TippingFeeRate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:contaminationPenaltyRate rdf:type rdf:Property ;
    rdfs:label 'Contamination Penalty Rate' ;
    rdfs:comment 'Additional fee per ton charged for contaminated loads that do not meet material stream specifications. Nullable if no contamination penalty applies.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ratePerTon rdf:type rdf:Property ;
    rdfs:label 'Rate Per Ton' ;
    rdfs:comment 'Tipping fee charged per ton of waste disposed. Primary pricing metric for tonnage-based billing. Expressed in local currency.' ;
    rdfs:domain ind:TippingFeeRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:seasonalRateFlag rdf:type rdf:Property ;
    rdfs:label 'Seasonal Rate Flag' ;
    rdfs:comment 'Indicates whether this is a seasonal rate with time-limited applicability. True for seasonal rates, False for year-round rates.' ;
    rdfs:domain ind:TippingFeeRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:volumeDiscountRatePerTon rdf:type rdf:Property ;
    rdfs:label 'Volume Discount Rate Per Ton' ;
    rdfs:comment 'Discounted rate per ton applied when volume threshold is exceeded. Nullable if no volume discount applies.' ;
    rdfs:domain ind:TippingFeeRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emissionSourceId rdf:type rdf:Property ;
    rdfs:label 'Emission Source Id' ;
    rdfs:comment 'Foreign key linking to sustainability.emission_source. Business justification: Transfer stations are stationary emission sources with equipment, flares, and fugitive emissions. EPA GHGRP Subpart HH requires facility-level emission source registration and continuous monitoring.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EmissionSource .

ind:operatorVendorId rdf:type rdf:Property ;
    rdfs:label 'Operator Vendor Id' ;
    rdfs:comment 'Foreign key linking to procurement.vendor. Business justification: Transfer stations may be operated by third-party vendors under service contracts. Asset management and procurement teams track which stations are vendor-operated for contract management, performance m' ;
    rdfs:domain ind:TransferStation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:safetyProgramId rdf:type rdf:Property ;
    rdfs:label 'Safety Program Id' ;
    rdfs:comment 'Foreign key linking to safety.safety_program. Business justification: Each transfer station implements specific safety programs based on operational characteristics, waste streams handled, and regulatory requirements. Essential for OSHA compliance, program auditing, and' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SafetyProgram .

ind:transferFacilityId rdf:type rdf:Property ;
    rdfs:label 'Transfer Facility Id' ;
    rdfs:comment 'FK to asset.facility.facility_id — Transfer stations are physical facilities tracked in the asset domain. This FK enables joining transfer operations to facility maintenance, inspections, and capital planning.' ;
    rdfs:domain ind:TransferStation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:transferOutboundDisposalFacilityId rdf:type rdf:Property ;
    rdfs:label 'Transfer Outbound Disposal Facility Id' ;
    rdfs:comment 'Identifier of the primary landfill or disposal facility where waste is hauled from this transfer station.' ;
    rdfs:domain ind:TransferStation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:acceptsCommercialWaste rdf:type rdf:Property ;
    rdfs:label 'Accepts Commercial Waste' ;
    rdfs:comment 'Indicates whether the transfer station accepts commercial waste from business and industrial customers.' ;
    rdfs:domain ind:TransferStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:acceptsConstructionDebris rdf:type rdf:Property ;
    rdfs:label 'Accepts Construction Debris' ;
    rdfs:comment 'Indicates whether the transfer station accepts construction and demolition waste materials.' ;
    rdfs:domain ind:TransferStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:acceptsHazardousWaste rdf:type rdf:Property ;
    rdfs:label 'Accepts Hazardous Waste' ;
    rdfs:comment 'Indicates whether the transfer station is permitted and equipped to handle hazardous waste materials under RCRA regulations.' ;
    rdfs:domain ind:TransferStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:acceptsRecyclables rdf:type rdf:Property ;
    rdfs:label 'Accepts Recyclables' ;
    rdfs:comment 'Indicates whether the transfer station accepts recyclable materials for processing or transfer to MRF facilities.' ;
    rdfs:domain ind:TransferStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:acceptsResidentialWaste rdf:type rdf:Property ;
    rdfs:label 'Accepts Residential Waste' ;
    rdfs:comment 'Indicates whether the transfer station accepts residential MSW from collection routes.' ;
    rdfs:domain ind:TransferStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:closureDate rdf:type rdf:Property ;
    rdfs:label 'Closure Date' ;
    rdfs:comment 'Date when the transfer station ceased operations or was decommissioned. Null for active facilities.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:environmentalComplianceOfficer rdf:type rdf:Property ;
    rdfs:label 'Environmental Compliance Officer' ;
    rdfs:comment 'Name of the environmental compliance officer responsible for regulatory compliance at this transfer station.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationalCapacityTpd rdf:type rdf:Property ;
    rdfs:label 'Operational Capacity Tpd' ;
    rdfs:comment 'Actual operational throughput capacity in tons per day based on equipment, staffing, and facility configuration.' ;
    rdfs:domain ind:TransferStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scaleCount rdf:type rdf:Property ;
    rdfs:label 'Scale Count' ;
    rdfs:comment 'Number of truck scales installed at the transfer station for weighing incoming and outgoing vehicles.' ;
    rdfs:domain ind:TransferStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stationCode rdf:type rdf:Property ;
    rdfs:label 'Station Code' ;
    rdfs:comment 'Business identifier code for the transfer station facility used in operational systems and reporting. Externally-known unique code for the facility.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stationName rdf:type rdf:Property ;
    rdfs:label 'Station Name' ;
    rdfs:comment 'Official business name of the transfer station facility as registered with regulatory authorities and used in customer communications.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tippingFloorAreaSqft rdf:type rdf:Property ;
    rdfs:label 'Tipping Floor Area Sqft' ;
    rdfs:comment 'Total area of the tipping floor in square feet where incoming waste is unloaded and staged for processing.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transferTrailerId rdf:type rdf:Property ;
    rdfs:label 'Transfer Trailer Id' ;
    rdfs:comment 'Unique identifier for the transfer trailer. Primary key for this entity.' ;
    rdfs:domain ind:TransferTrailer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignedTransferStationId rdf:type rdf:Property ;
    rdfs:label 'Assigned Transfer Station Id' ;
    rdfs:comment 'Identifier of the transfer station to which this trailer is currently assigned or based.' ;
    rdfs:domain ind:TransferTrailer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TransferStation .

ind:axleCount rdf:type rdf:Property ;
    rdfs:label 'Axle Count' ;
    rdfs:comment 'Number of axles on the trailer, relevant for weight distribution and DOT compliance.' ;
    rdfs:domain ind:TransferTrailer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:currentLocationLatitude rdf:type rdf:Property ;
    rdfs:label 'Current Location Latitude' ;
    rdfs:comment 'Most recent GPS latitude coordinate of the trailer\'s location.' ;
    rdfs:domain ind:TransferTrailer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentLocationLongitude rdf:type rdf:Property ;
    rdfs:label 'Current Location Longitude' ;
    rdfs:comment 'Most recent GPS longitude coordinate of the trailer\'s location.' ;
    rdfs:domain ind:TransferTrailer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dotRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Dot Registration Number' ;
    rdfs:comment 'DOT registration number required for interstate commercial hauling operations.' ;
    rdfs:domain ind:TransferTrailer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gpsTrackingEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Gps Tracking Enabled Flag' ;
    rdfs:comment 'Indicates whether the trailer is equipped with active GPS tracking for real-time location monitoring.' ;
    rdfs:domain ind:TransferTrailer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inServiceDate rdf:type rdf:Property ;
    rdfs:label 'In Service Date' ;
    rdfs:comment 'Date the trailer was placed into active operational service.' ;
    rdfs:domain ind:TransferTrailer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:insuranceExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Insurance Expiration Date' ;
    rdfs:comment 'Date when the current insurance policy for the trailer expires.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastLocationUpdateTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Location Update Timestamp' ;
    rdfs:comment 'Timestamp of the most recent GPS location update received from the trailer.' ;
    rdfs:domain ind:TransferTrailer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:licensePlate rdf:type rdf:Property ;
    rdfs:label 'License Plate' ;
    rdfs:comment 'State-issued license plate number for the transfer trailer.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelName rdf:type rdf:Property ;
    rdfs:label 'Model Name' ;
    rdfs:comment 'Manufacturer\'s model designation for the trailer.' ;
    rdfs:domain ind:TransferTrailer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelYear rdf:type rdf:Property ;
    rdfs:label 'Model Year' ;
    rdfs:comment 'Year the trailer was manufactured, used for depreciation and compliance tracking.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextDotInspectionDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Dot Inspection Due Date' ;
    rdfs:comment 'Scheduled date for the next required DOT annual inspection to maintain compliance.' ;
    rdfs:domain ind:TransferTrailer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextMaintenanceDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Maintenance Due Date' ;
    rdfs:comment 'Scheduled date for the next preventive maintenance service based on time or usage intervals.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:odometerMiles rdf:type rdf:Property ;
    rdfs:label 'Odometer Miles' ;
    rdfs:comment 'Current odometer reading in miles, used for maintenance scheduling and utilization tracking.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payloadCapacityTons rdf:type rdf:Property ;
    rdfs:label 'Payload Capacity Tons' ;
    rdfs:comment 'Maximum allowable payload weight in tons that the trailer can legally and safely carry.' ;
    rdfs:domain ind:TransferTrailer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:registrationExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Registration Expiration Date' ;
    rdfs:comment 'Date when the current state registration for the trailer expires.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:registrationState rdf:type rdf:Property ;
    rdfs:label 'Registration State' ;
    rdfs:comment 'Two-letter state code where the trailer is registered for operation.' ;
    rdfs:domain ind:TransferTrailer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retirementReason rdf:type rdf:Property ;
    rdfs:label 'Retirement Reason' ;
    rdfs:comment 'Reason the trailer was retired from service (e.g., end of useful life, accident damage, sold, lease termination).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tireSize rdf:type rdf:Property ;
    rdfs:label 'Tire Size' ;
    rdfs:comment 'Standard tire size specification for the trailer, used for maintenance and replacement planning.' ;
    rdfs:domain ind:TransferTrailer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trailerNumber rdf:type rdf:Property ;
    rdfs:label 'Trailer Number' ;
    rdfs:comment 'Externally-known unique identifier or asset tag for the transfer trailer, used for operational tracking and dispatch.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trailerStatus rdf:type rdf:Property ;
    rdfs:label 'Trailer Status' ;
    rdfs:comment 'Current operational status of the transfer trailer indicating availability and location state.' ;
    rdfs:domain ind:TransferTrailer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trailerType rdf:type rdf:Property ;
    rdfs:label 'Trailer Type' ;
    rdfs:comment 'Classification of the transfer trailer by its unloading mechanism and design (e.g., walking floor, end-dump, live-bottom, compactor trailer).' ;
    rdfs:domain ind:TransferTrailer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vin rdf:type rdf:Property ;
    rdfs:label 'Vin' ;
    rdfs:comment '17-character Vehicle Identification Number assigned by the manufacturer, used for registration and compliance tracking.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeCapacityCubicYards rdf:type rdf:Property ;
    rdfs:label 'Volume Capacity Cubic Yards' ;
    rdfs:comment 'Maximum volume capacity of the trailer in cubic yards, relevant for low-density waste streams.' ;
    rdfs:domain ind:TransferTrailer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:truckAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Truck Assignment Id' ;
    rdfs:comment 'Unique identifier for the truck assignment record. Primary key for this transactional entity capturing the assignment of a collection vehicle to a route execution on a specific service date.' ;
    rdfs:domain ind:TruckAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryTruckDispatchFacilityId rdf:type rdf:Property ;
    rdfs:label 'Primary Truck Dispatch Facility Id' ;
    rdfs:comment 'Reference to the facility or yard from which the truck was dispatched for this route execution. Typically a collection operations center, transfer station, or regional depot.' ;
    rdfs:domain ind:TruckAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:assignmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assignment Timestamp' ;
    rdfs:comment 'Date and time when the truck was assigned to the route execution. Represents the business event time when dispatch confirmed the vehicle-to-route pairing.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:gpsTrackingEnabled rdf:type rdf:Property ;
    rdfs:label 'Gps Tracking Enabled' ;
    rdfs:comment 'Indicates whether real-time GPS tracking was active for this truck assignment. True if Geotab telematics was operational and transmitting location data during route execution.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:odometerEnd rdf:type rdf:Property ;
    rdfs:label 'Odometer End' ;
    rdfs:comment 'Odometer reading in miles at the time the truck completed the route execution and returned. Used to calculate route mileage and update vehicle lifecycle metrics.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:odometerStart rdf:type rdf:Property ;
    rdfs:label 'Odometer Start' ;
    rdfs:comment 'Odometer reading in miles at the time the truck was assigned and departed for route execution. Used for mileage tracking, fuel efficiency analysis, and preventive maintenance scheduling.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postTripInspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Post Trip Inspection Status' ;
    rdfs:comment 'Result of the post-trip vehicle inspection performed after route completion. Identifies any defects or maintenance needs discovered during route execution.' ;
    rdfs:domain ind:TruckAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postTripInspectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Post Trip Inspection Timestamp' ;
    rdfs:comment 'Date and time when the post-trip inspection was completed. Used for maintenance work order generation and fleet safety tracking.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reassignmentReason rdf:type rdf:Property ;
    rdfs:label 'Reassignment Reason' ;
    rdfs:comment 'Free-text explanation for why the truck was reassigned during route execution. Captures operational context for vehicle breakdowns, driver changes, route adjustments, or emergency redeployment.' ;
    rdfs:domain ind:TruckAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeDeviationFlag rdf:type rdf:Property ;
    rdfs:label 'Route Deviation Flag' ;
    rdfs:comment 'Indicates whether the truck deviated from the planned route during execution. True if GPS tracking detected significant off-route travel, triggering operational review or customer service follow-up.' ;
    rdfs:domain ind:TruckAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduledStartTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Time' ;
    rdfs:comment 'Planned date and time when the truck is scheduled to begin the route execution. Used for dispatch planning and driver coordination.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:disposalSiteId rdf:type rdf:Property ;
    rdfs:label 'Disposal Site Id' ;
    rdfs:comment 'Foreign key linking to landfill.site. Business justification: Weight tickets from collection routes disposing at landfills require landfill site reference for disposal tracking, regulatory reporting, tipping fee reconciliation, and landfill capacity management. ' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Site .

ind:modifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Modified By User Employee Id' ;
    rdfs:comment 'User ID of the person who last modified this weight ticket record. Used for accountability and audit purposes.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:regulatorySubmissionId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_submission. Business justification: Weight tickets provide source data for regulatory submissions including tonnage reports, waste characterization reports, and capacity utilization filings required by environmental agencies.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatorySubmission .

ind:originType rdf:type rdf:Property ;
    rdfs:label 'Origin Type' ;
    rdfs:comment 'Source classification of the waste collected. Used for waste characterization studies and regulatory reporting.' ;
    rdfs:domain ind:WeightTicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Detected By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Tracking which employee detected emission events supports training effectiveness analysis, incident response performance evaluation, and recognition programs for proactive environmental monitoring in ' ;
    rdfs:domain ind:AirEmissionEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:emergencyActionPlanId rdf:type rdf:Property ;
    rdfs:label 'Emergency Action Plan Id' ;
    rdfs:comment 'Foreign key linking to safety.emergency_action_plan. Business justification: Air emission events trigger emergency response procedures. This link documents which emergency plan was activated and ensures regulatory reporting includes emergency response actions. Required for Tit' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EmergencyActionPlan .

ind:regulatoryCorrectiveActionId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Corrective Action Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_corrective_action. Business justification: Emission events that exceed permit limits or regulatory thresholds trigger corrective actions. This FK links emission events to the corrective actions taken to address the deviation, enabling tracking' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryCorrectiveAction .

ind:responsibleVendorId rdf:type rdf:Property ;
    rdfs:label 'Responsible Vendor Id' ;
    rdfs:comment 'Foreign key linking to procurement.vendor. Business justification: Emission events result from vendor equipment failure or service issues (control equipment malfunction, contractor error). Essential for vendor accountability, warranty claims, and performance evaluati' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:agencyContactName rdf:type rdf:Property ;
    rdfs:label 'Agency Contact Name' ;
    rdfs:comment 'Name of the regulatory agency representative or inspector who was contacted regarding the emission event.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyName rdf:type rdf:Property ;
    rdfs:label 'Agency Name' ;
    rdfs:comment 'Name of the regulatory agency notified (e.g., U.S. Environmental Protection Agency, State Department of Environmental Quality, Local Air Quality Management District).' ;
    rdfs:domain ind:AirEmissionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyNotifiedDate rdf:type rdf:Property ;
    rdfs:label 'Agency Notified Date' ;
    rdfs:comment 'Actual date when the regulatory agency (EPA, state air quality agency, or local enforcement agency) was notified of the emission event. Used to verify compliance with notification deadlines.' ;
    rdfs:domain ind:AirEmissionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:airEmissionEventStatus rdf:type rdf:Property ;
    rdfs:label 'Air Emission Event Status' ;
    rdfs:comment 'Current status of the emission event record in the EHS management system. Open indicates active event; under investigation means root cause analysis in progress; corrective action pending means actions identified but not completed; reported means regulatory notification submitted; closed means all actions complete and event resolved.' ;
    rdfs:domain ind:AirEmissionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:causeDescription rdf:type rdf:Property ;
    rdfs:label 'Cause Description' ;
    rdfs:comment 'Detailed narrative describing the root cause of the emission event. Includes equipment failure details, operational upset conditions, weather events, human error, or other contributing factors. Required for regulatory deviation reports.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communityImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Community Impact Flag' ;
    rdfs:comment 'Indicates whether the emission event resulted in off-site impacts, odor complaints, or community concerns. True if complaints were received or visible plume extended beyond facility boundary.' ;
    rdfs:domain ind:AirEmissionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complaintCount rdf:type rdf:Property ;
    rdfs:label 'Complaint Count' ;
    rdfs:comment 'Number of community complaints received related to this emission event. Includes odor complaints, visible emission concerns, and health-related inquiries.' ;
    rdfs:domain ind:AirEmissionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:detectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Detection Timestamp' ;
    rdfs:comment 'Date and time when the emission event was first detected or identified. May differ from event start time if detection was delayed.' ;
    rdfs:domain ind:AirEmissionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deviationFlag rdf:type rdf:Property ;
    rdfs:label 'Deviation Flag' ;
    rdfs:comment 'Indicates whether the emission event constitutes a deviation from permit requirements under Clean Air Act Title V. True if permit limits were exceeded or monitoring/recordkeeping requirements were not met.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:emissionQuantityUnit rdf:type rdf:Property ;
    rdfs:label 'Emission Quantity Unit' ;
    rdfs:comment 'Unit of measure for the estimated emission quantity. Typically pounds or tons for mass-based pollutants, cubic feet or cubic meters for volumetric measurements.' ;
    rdfs:domain ind:AirEmissionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enforcementActionFlag rdf:type rdf:Property ;
    rdfs:label 'Enforcement Action Flag' ;
    rdfs:comment 'Indicates whether the emission event resulted in regulatory enforcement action such as Notice of Violation (NOV), penalty assessment, consent order, or compliance schedule. True if formal enforcement was initiated.' ;
    rdfs:domain ind:AirEmissionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedEmissionQuantity rdf:type rdf:Property ;
    rdfs:label 'Estimated Emission Quantity' ;
    rdfs:comment 'Estimated quantity of pollutant released during the event. Calculated using emission factors, continuous emission monitoring system (CEMS) data, or engineering estimates. Reported in units specified by emission_quantity_unit.' ;
    rdfs:domain ind:AirEmissionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eventDurationHours rdf:type rdf:Property ;
    rdfs:label 'Event Duration Hours' ;
    rdfs:comment 'Total duration of the emission event in hours. Calculated from start and end timestamps. Used for regulatory reporting and compliance assessment.' ;
    rdfs:domain ind:AirEmissionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eventEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Event End Timestamp' ;
    rdfs:comment 'Date and time when the air emission event concluded or was brought under control. Used to calculate total event duration and emission quantity.' ;
    rdfs:domain ind:AirEmissionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eventStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Event Start Timestamp' ;
    rdfs:comment 'Date and time when the air emission event began. Critical for calculating duration and determining regulatory notification deadlines.' ;
    rdfs:domain ind:AirEmissionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:notificationDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Notification Deadline Date' ;
    rdfs:comment 'Date by which regulatory notification or deviation report must be submitted to the appropriate agency. Calculated based on event type and applicable regulations (typically 24 hours for emergencies, 30 days for deviations).' ;
    rdfs:domain ind:AirEmissionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:notificationMethod rdf:type rdf:Property ;
    rdfs:label 'Notification Method' ;
    rdfs:comment 'Method used to notify the regulatory agency of the emission event (phone call, email, written report, electronic submission portal, in-person notification).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Notification Required Flag' ;
    rdfs:comment 'Indicates whether the emission event triggered a regulatory notification requirement to EPA, state air quality agency, or local enforcement agency. True if immediate notification (within 24 hours) or deviation reporting is required.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:penaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Penalty Amount' ;
    rdfs:comment 'Monetary penalty assessed by regulatory agency for the emission event violation, if applicable. Reported in U.S. dollars.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:permitLimitUnit rdf:type rdf:Property ;
    rdfs:label 'Permit Limit Unit' ;
    rdfs:comment 'Unit of measure for the permit limit (e.g., pounds per hour, tons per year, parts per million, percent opacity, grains per dry standard cubic foot).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitLimitValue rdf:type rdf:Property ;
    rdfs:label 'Permit Limit Value' ;
    rdfs:comment 'The regulatory permit limit for the pollutant and emission unit that was exceeded or approached during this event. Used to determine if event constitutes a deviation or violation.' ;
    rdfs:domain ind:AirEmissionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pollutantCode rdf:type rdf:Property ;
    rdfs:label 'Pollutant Code' ;
    rdfs:comment 'EPA-standardized code for the primary air pollutant involved in the emission event (e.g., PM10, PM2.5, SO2, NOx, VOC, CO, CO2e, CH4, H2S). May reference multiple pollutants for complex events.' ;
    rdfs:domain ind:AirEmissionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pollutantName rdf:type rdf:Property ;
    rdfs:label 'Pollutant Name' ;
    rdfs:comment 'Full name of the air pollutant released during the event (e.g., Particulate Matter 10 micrometers, Sulfur Dioxide, Nitrogen Oxides, Volatile Organic Compounds, Carbon Monoxide, Methane, Hydrogen Sulfide).' ;
    rdfs:domain ind:AirEmissionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preventiveActionPlanned rdf:type rdf:Property ;
    rdfs:label 'Preventive Action Planned' ;
    rdfs:comment 'Description of planned preventive measures to avoid similar emission events in the future. May include capital improvements, enhanced training, revised procedures, or increased inspection frequency.' ;
    rdfs:domain ind:AirEmissionEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Report Reference Number' ;
    rdfs:comment 'Reference number or tracking identifier assigned by the regulatory agency or internal EHS system for the deviation report or notification associated with this emission event.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severityLevel rdf:type rdf:Property ;
    rdfs:label 'Severity Level' ;
    rdfs:comment 'Internal classification of emission event severity based on magnitude of exceedance, duration, community impact, and regulatory significance. Minor events have minimal impact; critical events pose significant environmental or health risks.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditProgramId rdf:type rdf:Property ;
    rdfs:label 'Audit Program Id' ;
    rdfs:comment 'Unique identifier for the audit program record. Primary key.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AuditProgram .

ind:auditEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Audit Employee Id' ;
    rdfs:comment 'FK to workforce.employee' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:ownerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Owner Employee Id' ;
    rdfs:comment 'Identifier of the corporate or regional EHS manager who owns and oversees this audit program. References workforce or employee master data.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryLeadAuditorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Lead Auditor Employee Id' ;
    rdfs:comment 'FK to workforce.employee' ;
    rdfs:domain ind:AuditProgram ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:applicableFacilities rdf:type rdf:Property ;
    rdfs:label 'Applicable Facilities' ;
    rdfs:comment 'Comma-separated list or description of facilities covered by this audit program (e.g., \'All MRF facilities\', \'Landfill sites in Region 3\', \'TSDF facilities\').' ;
    rdfs:domain ind:AuditProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditFrequency rdf:type rdf:Property ;
    rdfs:label 'Audit Frequency' ;
    rdfs:comment 'Scheduled frequency at which audits under this program are conducted (Annual, Semi-Annual, Quarterly, Monthly, Biennial, Ad-Hoc).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditMethodology rdf:type rdf:Property ;
    rdfs:label 'Audit Methodology' ;
    rdfs:comment 'Description of the audit methodology and approach used in this program (e.g., \'Process-based audit\', \'Risk-based audit\', \'Compliance checklist audit\').' ;
    rdfs:domain ind:AuditProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditTeamMembers rdf:type rdf:Property ;
    rdfs:label 'Audit Team Members' ;
    rdfs:comment 'Comma-separated list of names or identifiers of additional audit team members assigned to this program.' ;
    rdfs:domain ind:AuditProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditType rdf:type rdf:Property ;
    rdfs:label 'Audit Type' ;
    rdfs:comment 'Classification of the audit program by its primary focus and regulatory or standards framework (ISO 14001 internal audit, RCRA compliance audit, OSHA VPP audit, operational compliance review, ISO 45001 internal audit, integrated EHS audit).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetAllocatedAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Allocated Amount' ;
    rdfs:comment 'Total budget amount allocated for this audit program, covering auditor time, travel, training, and related expenses.' ;
    rdfs:domain ind:AuditProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Budget Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the budget allocated amount (e.g., USD, EUR, CAD).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationBody rdf:type rdf:Property ;
    rdfs:label 'Certification Body' ;
    rdfs:comment 'Name of the external certification or accreditation body associated with this audit program, if applicable (e.g., \'BSI\', \'DNV\', \'UL\').' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionList rdf:type rdf:Property ;
    rdfs:label 'Distribution List' ;
    rdfs:comment 'Comma-separated list of roles, departments, or individuals who receive audit reports and findings from this program.' ;
    rdfs:domain ind:AuditProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentationRequirements rdf:type rdf:Property ;
    rdfs:label 'Documentation Requirements' ;
    rdfs:comment 'Description of documentation and records required to be reviewed or produced as part of audits under this program.' ;
    rdfs:domain ind:AuditProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalCertificationFlag rdf:type rdf:Property ;
    rdfs:label 'External Certification Flag' ;
    rdfs:comment 'Indicates whether this audit program supports external certification or accreditation (e.g., ISO 14001, ISO 45001 certification) (True/False).' ;
    rdfs:domain ind:AuditProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:followUpAuditRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Follow Up Audit Required Flag' ;
    rdfs:comment 'Indicates whether follow-up audits are required to verify closure of corrective actions (True/False).' ;
    rdfs:domain ind:AuditProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isoClauses rdf:type rdf:Property ;
    rdfs:label 'Iso Clauses' ;
    rdfs:comment 'Specific ISO standard clauses addressed by this audit program (e.g., \'ISO 14001:2015 Clause 9.2\', \'ISO 45001:2018 Clause 9.2\').' ;
    rdfs:domain ind:AuditProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Review Date' ;
    rdfs:comment 'Date of the most recent management review of the audit program.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Review Date' ;
    rdfs:comment 'Scheduled date for the next management review of the audit program to assess effectiveness and make adjustments.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:programCode rdf:type rdf:Property ;
    rdfs:label 'Program Code' ;
    rdfs:comment 'Unique business identifier code for the audit program, used for external reference and reporting. Typically follows organizational coding standards.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programName rdf:type rdf:Property ;
    rdfs:label 'Program Name' ;
    rdfs:comment 'Descriptive name of the audit program (e.g., \'ISO 14001 Internal Audit Program FY2024\', \'RCRA Compliance Audit Program\').' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programObjectives rdf:type rdf:Property ;
    rdfs:label 'Program Objectives' ;
    rdfs:comment 'Stated objectives and goals of the audit program, including compliance verification, process improvement, risk mitigation, and certification maintenance.' ;
    rdfs:domain ind:AuditProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programStatus rdf:type rdf:Property ;
    rdfs:label 'Program Status' ;
    rdfs:comment 'Current lifecycle status of the audit program (Active, Inactive, Suspended, Under Review, Archived).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryStandards rdf:type rdf:Property ;
    rdfs:label 'Regulatory Standards' ;
    rdfs:comment 'List of applicable regulatory standards, frameworks, and requirements covered by this audit program (e.g., \'RCRA 40 CFR Part 264\', \'ISO 14001:2015\', \'OSHA 29 CFR 1910\', \'Clean Air Act Title V\').' ;
    rdfs:domain ind:AuditProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingTemplate rdf:type rdf:Property ;
    rdfs:label 'Reporting Template' ;
    rdfs:comment 'Name or reference to the standard reporting template or format used for audit reports generated under this program.' ;
    rdfs:domain ind:AuditProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeDescription rdf:type rdf:Property ;
    rdfs:label 'Scope Description' ;
    rdfs:comment 'Detailed description of the audit program scope, including applicable facilities, operations, processes, and regulatory or standards requirements covered.' ;
    rdfs:domain ind:AuditProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chemicalInventoryId rdf:type rdf:Property ;
    rdfs:label 'Chemical Inventory Id' ;
    rdfs:comment 'Unique identifier for the chemical inventory record. Primary key for the chemical inventory product.' ;
    rdfs:domain ind:ChemicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hazardRegisterId rdf:type rdf:Property ;
    rdfs:label 'Hazard Register Id' ;
    rdfs:comment 'Foreign key linking to safety.hazard_register. Business justification: Chemicals in inventory represent hazards that must be in the hazard register. This link ensures all chemical hazards (flammability, toxicity, reactivity) are captured for risk management. Required for' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HazardRegister .

ind:averageDailyQuantity rdf:type rdf:Property ;
    rdfs:label 'Average Daily Quantity' ;
    rdfs:comment 'Average amount of the chemical present at the facility on a daily basis during the reporting year. Used for EPCRA Tier II reporting.' ;
    rdfs:domain ind:ChemicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:casNumber rdf:type rdf:Property ;
    rdfs:label 'Cas Number' ;
    rdfs:comment 'Unique numerical identifier assigned by the Chemical Abstracts Service to every chemical substance. Used for precise identification in regulatory reporting.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cerclaReportableQuantity rdf:type rdf:Property ;
    rdfs:label 'Cercla Reportable Quantity' ;
    rdfs:comment 'CERCLA reportable quantity in pounds. Releases of this amount or more within a 24-hour period must be reported to the National Response Center. Null if no RQ established.' ;
    rdfs:domain ind:ChemicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confidentialLocationFlag rdf:type rdf:Property ;
    rdfs:label 'Confidential Location Flag' ;
    rdfs:comment 'Indicates whether the specific storage location is withheld from public disclosure in Tier II reporting due to trade secret or security concerns. Requires substantiation to state authority.' ;
    rdfs:domain ind:ChemicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ehsFlag rdf:type rdf:Property ;
    rdfs:label 'Ehs Flag' ;
    rdfs:comment 'Indicates whether the chemical is listed as an Extremely Hazardous Substance under EPCRA Section 302. EHS chemicals trigger emergency planning and release reporting requirements.' ;
    rdfs:domain ind:ChemicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ehsThresholdPlanningQuantity rdf:type rdf:Property ;
    rdfs:label 'Ehs Threshold Planning Quantity' ;
    rdfs:comment 'EPCRA Section 302 threshold planning quantity for the EHS chemical in pounds. Facilities storing amounts at or above the TPQ must notify the SERC and LEPC. Null if not an EHS.' ;
    rdfs:domain ind:ChemicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:epcraSection313Flag rdf:type rdf:Property ;
    rdfs:label 'Epcra Section 313 Flag' ;
    rdfs:comment 'Indicates whether the chemical is a listed toxic chemical under EPCRA Section 313 requiring annual TRI reporting if threshold quantities are manufactured, processed, or otherwise used.' ;
    rdfs:domain ind:ChemicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ghsEnvironmentalHazardClass rdf:type rdf:Property ;
    rdfs:label 'Ghs Environmental Hazard Class' ;
    rdfs:comment 'GHS environmental hazard classification (e.g., hazardous to the aquatic environment acute category 1, chronic category 2). Derived from Section 2 of the SDS.' ;
    rdfs:domain ind:ChemicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ghsHealthHazardClass rdf:type rdf:Property ;
    rdfs:label 'Ghs Health Hazard Class' ;
    rdfs:comment 'GHS health hazard classification (e.g., acute toxicity category 3, carcinogenicity category 1A, skin corrosion category 1B). Derived from Section 2 of the SDS.' ;
    rdfs:domain ind:ChemicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ghsPhysicalHazardClass rdf:type rdf:Property ;
    rdfs:label 'Ghs Physical Hazard Class' ;
    rdfs:comment 'GHS physical hazard classification (e.g., flammable liquid category 2, oxidizing solid category 1, explosive division 1.1). Derived from Section 2 of the SDS.' ;
    rdfs:domain ind:ChemicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hmisRating rdf:type rdf:Property ;
    rdfs:label 'Hmis Rating' ;
    rdfs:comment 'HMIS rating in format Health-Flammability-Physical-PPE (e.g., 2-3-1-B). Used for workplace labeling and employee right-to-know programs.' ;
    rdfs:domain ind:ChemicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastInventoryDate rdf:type rdf:Property ;
    rdfs:label 'Last Inventory Date' ;
    rdfs:comment 'Date of the most recent physical inventory verification for this chemical. EPCRA Tier II requires annual inventory updates; more frequent verification may be required for PSM-covered chemicals.' ;
    rdfs:domain ind:ChemicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maximumQuantityStored rdf:type rdf:Property ;
    rdfs:label 'Maximum Quantity Stored' ;
    rdfs:comment 'Maximum amount of the chemical present at the facility at any time during the reporting year. Used for EPCRA Tier II threshold determination.' ;
    rdfs:domain ind:ChemicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nfpaRating rdf:type rdf:Property ;
    rdfs:label 'Nfpa Rating' ;
    rdfs:comment 'NFPA 704 diamond rating in format Health-Flammability-Instability-Special (e.g., 2-3-1-OX). Used for emergency response and facility placarding.' ;
    rdfs:domain ind:ChemicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:physicalState rdf:type rdf:Property ;
    rdfs:label 'Physical State' ;
    rdfs:comment 'Physical form of the chemical at ambient conditions (solid, liquid, gas, sludge, or compressed gas). Determines storage and handling requirements.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productIdentifier rdf:type rdf:Property ;
    rdfs:label 'Product Identifier' ;
    rdfs:comment 'Manufacturer\'s product code, catalog number, or SKU for the specific chemical product. Used for procurement and inventory tracking.' ;
    rdfs:domain ind:ChemicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:psmCoveredFlag rdf:type rdf:Property ;
    rdfs:label 'Psm Covered Flag' ;
    rdfs:comment 'Indicates whether the chemical is present in quantities that trigger OSHA Process Safety Management requirements (10,000 lbs threshold for most flammables, specific thresholds for listed chemicals).' ;
    rdfs:domain ind:ChemicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:psmThresholdQuantity rdf:type rdf:Property ;
    rdfs:label 'Psm Threshold Quantity' ;
    rdfs:comment 'OSHA PSM threshold quantity for the chemical in pounds. Facilities with amounts at or above this threshold must implement PSM program elements. Null if not a PSM-covered chemical.' ;
    rdfs:domain ind:ChemicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityUnit rdf:type rdf:Property ;
    rdfs:label 'Quantity Unit' ;
    rdfs:comment 'Unit of measure for maximum and average daily quantities (pounds, kilograms, gallons, liters, cubic feet, cubic meters). Must be consistent with EPCRA reporting requirements.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rcraGeneratorStatusImpact rdf:type rdf:Property ;
    rdfs:label 'Rcra Generator Status Impact' ;
    rdfs:comment 'Impact of this chemical on the facility\'s RCRA hazardous waste generator status classification (none, conditionally exempt, small quantity, large quantity). Based on monthly generation quantities.' ;
    rdfs:domain ind:ChemicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingYear rdf:type rdf:Property ;
    rdfs:label 'Reporting Year' ;
    rdfs:comment 'Calendar year for which this inventory record applies. EPCRA Tier II reports are due by March 1 for the previous calendar year.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sdsDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Sds Document Url' ;
    rdfs:comment 'URL or file path to the electronic copy of the Safety Data Sheet in the Enviance EHS document management system. SDS must be readily accessible to employees.' ;
    rdfs:domain ind:ChemicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdsRevisionDate rdf:type rdf:Property ;
    rdfs:label 'Sds Revision Date' ;
    rdfs:comment 'Date of the most recent revision of the Safety Data Sheet for this chemical. SDS must be updated within three months of new hazard information becoming available.' ;
    rdfs:domain ind:ChemicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:storageCondition rdf:type rdf:Property ;
    rdfs:label 'Storage Condition' ;
    rdfs:comment 'Special storage conditions required for the chemical (ambient, refrigerated, heated, pressurized, inert atmosphere). Derived from Section 7 of the SDS.' ;
    rdfs:domain ind:ChemicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageLocation rdf:type rdf:Property ;
    rdfs:label 'Storage Location' ;
    rdfs:comment 'Specific location within the facility where the chemical is stored (e.g., building number, room, tank ID, outdoor storage area). Used for emergency response planning.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageType rdf:type rdf:Property ;
    rdfs:label 'Storage Type' ;
    rdfs:comment 'Type of container or storage system used for the chemical (tank, drum, tote, cylinder, bag, bulk storage, other). Determines inspection and containment requirements. [ENUM-REF-CANDIDATE: tank|drum|tote|cylinder|bag|bulk_storage|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ChemicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierIiReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Tier Ii Reporting Flag' ;
    rdfs:comment 'Indicates whether this chemical must be included in the annual EPCRA Tier II inventory report submitted to SERC, LEPC, and local fire department (threshold: 10,000 lbs or EHS TPQ).' ;
    rdfs:domain ind:ChemicalInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unNaNumber rdf:type rdf:Property ;
    rdfs:label 'Un Na Number' ;
    rdfs:comment 'Four-digit identification number assigned by the United Nations or Department of Transportation for hazardous materials transport. Used on shipping papers and placards.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionId rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Id' ;
    rdfs:comment 'Reference to the corrective action record initiated in response to this monitoring result, if applicable.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CorrectiveAction .

ind:laboratoryVendorId rdf:type rdf:Property ;
    rdfs:label 'Laboratory Vendor Id' ;
    rdfs:comment 'Foreign key linking to procurement.vendor. Business justification: Monitoring programs use contracted laboratories and sampling services. Links lab certification verification, chain-of-custody, performance evaluation, and payment processing. Laboratory_name is denorm' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:monitoringProgramId rdf:type rdf:Property ;
    rdfs:label 'Monitoring Program Id' ;
    rdfs:comment 'Reference to the environmental monitoring program under which this measurement was collected.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MonitoringProgram .

ind:monitoringStationId rdf:type rdf:Property ;
    rdfs:label 'Monitoring Station Id' ;
    rdfs:comment 'Foreign key linking to compliance.monitoring_station. Business justification: Environmental monitoring records are collected at fixed monitoring stations (groundwater wells, air monitoring stations, leachate sampling points). This FK replaces the denormalized monitoring_locatio' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MonitoringStation .

ind:regulatoryRequirementId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Requirement Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_requirement. Business justification: Environmental monitoring is conducted to satisfy regulatory requirements (Clean Water Act discharge monitoring, landfill groundwater monitoring under Subtitle D). This FK links monitoring records to t' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryRequirement .

ind:analysisCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Analysis Completion Date' ;
    rdfs:comment 'Date when the laboratory analysis was completed and results were finalized.' ;
    rdfs:domain ind:ComplianceEnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionRequired rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Required' ;
    rdfs:comment 'Indicates whether the monitoring result triggered the need for corrective action due to exceedance, trend analysis, or other compliance concern.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataQualifier rdf:type rdf:Property ;
    rdfs:label 'Data Qualifier' ;
    rdfs:comment 'Code or flag indicating special conditions affecting the measurement result, such as J (estimated value), U (non-detect), B (blank contamination), or other EPA-standard qualifiers.' ;
    rdfs:domain ind:ComplianceEnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionLimit rdf:type rdf:Property ;
    rdfs:label 'Detection Limit' ;
    rdfs:comment 'The minimum concentration or value that the analytical method can reliably detect for this parameter. Values below this threshold may be reported as non-detect or below detection limit.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laboratoryCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Laboratory Certification Number' ;
    rdfs:comment 'The certification or accreditation number of the laboratory that performed the analysis, demonstrating compliance with quality assurance requirements.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringEventNumber rdf:type rdf:Property ;
    rdfs:label 'Monitoring Event Number' ;
    rdfs:comment 'Business identifier for the monitoring event, used for tracking and reporting purposes.' ;
    rdfs:domain ind:ComplianceEnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringProgramType rdf:type rdf:Property ;
    rdfs:label 'Monitoring Program Type' ;
    rdfs:comment 'Type of environmental monitoring program. Ambient air monitors outdoor air quality, stack emissions track facility discharge, NPDES (National Pollutant Discharge Elimination System) effluent monitors wastewater discharge, groundwater well tracks subsurface water quality, LFG (Landfill Gas) LEL (Lower Explosive Limit) methane monitors landfill gas concentrations, leachate monitors liquid drainage from landfills, soil monitors ground contamination, surface water tracks nearby water bodies, and stormwater monitors runoff quality. [ENUM-REF-CANDIDATE: ambient_air|stack_emissions|npdes_effluent|groundwater_well|lfg_lel_methane|leachate|soil|surface_water|stormwater — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parameterMeasured rdf:type rdf:Property ;
    rdfs:label 'Parameter Measured' ;
    rdfs:comment 'The specific environmental parameter or pollutant measured in this monitoring event. Examples include CO2e (Carbon Dioxide Equivalent), methane, BOD (Biochemical Oxygen Demand), pH, VOCs (Volatile Organic Compounds), TSS (Total Suspended Solids), heavy metals, nitrogen oxides, sulfur dioxide, particulate matter, and other regulated substances.' ;
    rdfs:domain ind:ComplianceEnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityAssuranceFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Assurance Flag' ;
    rdfs:comment 'Indicates whether the measurement passed quality assurance and quality control (QA/QC) checks including calibration verification, blank analysis, duplicate samples, and spike recoveries.' ;
    rdfs:domain ind:ComplianceEnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryLimit rdf:type rdf:Property ;
    rdfs:label 'Regulatory Limit' ;
    rdfs:comment 'The maximum allowable concentration or value for this parameter as specified by the applicable environmental permit, regulation, or standard. Used for compliance comparison.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryReportingRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Required' ;
    rdfs:comment 'Indicates whether this monitoring result must be included in regulatory reports submitted to EPA, state agencies, or local authorities (e.g., SWIS, air quality reports, discharge monitoring reports).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportingPeriod rdf:type rdf:Property ;
    rdfs:label 'Reporting Period' ;
    rdfs:comment 'The regulatory reporting period to which this monitoring result applies, typically expressed as a month, quarter, or year (e.g., 2024-Q1, January 2024).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleCollectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sample Collection Timestamp' ;
    rdfs:comment 'Date and time when the environmental sample was collected or the measurement was taken in the field.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:samplerName rdf:type rdf:Property ;
    rdfs:label 'Sampler Name' ;
    rdfs:comment 'Name of the individual or team who collected the environmental sample or performed the field measurement.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplingMethod rdf:type rdf:Property ;
    rdfs:label 'Sampling Method' ;
    rdfs:comment 'The EPA-approved or industry-standard method used to collect and analyze the environmental sample. Examples include EPA Method 8260 for VOCs, EPA Method 25 for stack emissions, Standard Methods for water quality, and ASTM methods for soil analysis.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ghgInventoryId rdf:type rdf:Property ;
    rdfs:label 'Ghg Inventory Id' ;
    rdfs:comment 'Foreign key linking to sustainability.ghg_inventory. Business justification: EPA GHGRP compliance inspections verify GHG inventory data quality, calculation methods, and supporting documentation. Inspectors review the facility\'s inventory to ensure regulatory compliance. Links' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GhgInventory .

ind:inspectedVendorId rdf:type rdf:Property ;
    rdfs:label 'Inspected Vendor Id' ;
    rdfs:comment 'Foreign key linking to procurement.vendor. Business justification: Inspections evaluate vendor-provided services (waste hauler performance, TSDF compliance). Findings feed vendor performance ratings and re-qualification decisions. Critical for vendor management and c' ;
    rdfs:domain ind:ComplianceInspection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:actualInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Inspection Date' ;
    rdfs:comment 'Date on which the inspection was actually conducted. This is the primary business event date for the inspection.' ;
    rdfs:domain ind:ComplianceInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:checklistUsed rdf:type rdf:Property ;
    rdfs:label 'Checklist Used' ;
    rdfs:comment 'Name or identifier of the standardized inspection checklist or audit protocol used during the inspection. Ensures consistency and completeness of inspection coverage.' ;
    rdfs:domain ind:ComplianceInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Critical Findings Count' ;
    rdfs:comment 'Number of findings classified as critical or high-severity, requiring immediate corrective action. Subset of total findings.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:facilityEpaNumber rdf:type rdf:Property ;
    rdfs:label 'Facility Epa Number' ;
    rdfs:comment 'EPA-assigned unique 12-character identifier for the facility, required for RCRA-regulated facilities. Format: 2-letter state code + 9-digit number.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpDueDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Due Date' ;
    rdfs:comment 'Date by which corrective actions must be completed and documented, or by which a follow-up inspection is required. Null if no follow-up is needed.' ;
    rdfs:domain ind:ComplianceInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:frequencyRequirement rdf:type rdf:Property ;
    rdfs:label 'Frequency Requirement' ;
    rdfs:comment 'Required frequency for this type of inspection based on regulatory requirements or internal policy. Supports compliance calendar planning.' ;
    rdfs:domain ind:ComplianceInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectingAuthority rdf:type rdf:Property ;
    rdfs:label 'Inspecting Authority' ;
    rdfs:comment 'Name of the regulatory agency, local enforcement body, or designation of internal audit team conducting the inspection (e.g., U.S. EPA Region 5, California DTSC, Internal EHS Audit Team).' ;
    rdfs:domain ind:ComplianceInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionResult rdf:type rdf:Property ;
    rdfs:label 'Inspection Result' ;
    rdfs:comment 'Overall outcome of the inspection. Indicates whether the facility passed, failed, or requires follow-up action based on findings.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionScope rdf:type rdf:Property ;
    rdfs:label 'Inspection Scope' ;
    rdfs:comment 'Detailed description of the areas, processes, permits, or compliance requirements covered during the inspection. Defines the boundaries and focus areas of the inspection activity.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectorBadgeNumber rdf:type rdf:Property ;
    rdfs:label 'Inspector Badge Number' ;
    rdfs:comment 'Official badge or credential number of the external regulatory inspector. Applicable only to government agency inspections; null for internal audits.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iso14001Audit rdf:type rdf:Property ;
    rdfs:label 'Iso 14001 Audit' ;
    rdfs:comment 'Indicates whether this inspection was conducted as part of an ISO 14001 Environmental Management System audit or certification process.' ;
    rdfs:domain ind:ComplianceInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iso45001Audit rdf:type rdf:Property ;
    rdfs:label 'Iso 45001 Audit' ;
    rdfs:comment 'Indicates whether this inspection was conducted as part of an ISO 45001 Occupational Health and Safety Management System audit or certification process.' ;
    rdfs:domain ind:ComplianceInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:majorFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Major Findings Count' ;
    rdfs:comment 'Number of findings classified as major or medium-severity, requiring corrective action within a defined timeframe. Subset of total findings.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minorFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Minor Findings Count' ;
    rdfs:comment 'Number of findings classified as minor or low-severity, requiring corrective action but not posing immediate risk. Subset of total findings.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:noticeOfViolationIssued rdf:type rdf:Property ;
    rdfs:label 'Notice Of Violation Issued' ;
    rdfs:comment 'Indicates whether a formal Notice of Violation was issued by the regulatory authority as a result of the inspection findings.' ;
    rdfs:domain ind:ComplianceInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:numberOfFindings rdf:type rdf:Property ;
    rdfs:label 'Number Of Findings' ;
    rdfs:comment 'Total count of deficiencies, violations, observations, or non-conformances identified during the inspection. Zero indicates no issues found.' ;
    rdfs:domain ind:ComplianceInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryProgram rdf:type rdf:Property ;
    rdfs:label 'Regulatory Program' ;
    rdfs:comment 'Primary federal, state, or local regulatory program under which the inspection was conducted. Determines applicable compliance requirements and enforcement authority. [ENUM-REF-CANDIDATE: RCRA|Clean Air Act|Clean Water Act|CERCLA|TSCA|EPCRA|OSHA|DOT|State Solid Waste|Local Ordinance — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportUrl rdf:type rdf:Property ;
    rdfs:label 'Report Url' ;
    rdfs:comment 'URL or file path to the official inspection report document stored in the document management system. Provides access to the full inspection findings and recommendations.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Date' ;
    rdfs:comment 'Date on which the inspection was originally scheduled to occur. May differ from actual inspection date if rescheduled.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:violationsCited rdf:type rdf:Property ;
    rdfs:label 'Violations Cited' ;
    rdfs:comment 'Comma-separated list or detailed description of specific regulatory violations, permit conditions, or standards cited during the inspection. References specific CFR sections, permit conditions, or internal policy violations.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ehsIncidentId rdf:type rdf:Property ;
    rdfs:label 'Ehs Incident Id' ;
    rdfs:comment 'Unique identifier for the EHS incident record. Primary key.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EhsIncident .

ind:involvedVendorId rdf:type rdf:Property ;
    rdfs:label 'Involved Vendor Id' ;
    rdfs:comment 'Foreign key linking to procurement.vendor. Business justification: Incidents frequently involve vendor personnel or equipment (contractor injury, vendor vehicle accident). Essential for vendor safety performance tracking, insurance claims, and vendor qualification de' ;
    rdfs:domain ind:EhsIncident ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:jhaId rdf:type rdf:Property ;
    rdfs:label 'Jha Id' ;
    rdfs:comment 'Foreign key linking to safety.jha. Business justification: When incidents occur during tasks with JHAs, linking enables root cause analysis of whether JHA controls were adequate or followed. Essential for JHA effectiveness review and continuous improvement. R' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Jha .

ind:bodyPartAffected rdf:type rdf:Property ;
    rdfs:label 'Body Part Affected' ;
    rdfs:comment 'Specific body part(s) injured in the incident (e.g., left hand, lower back, eyes). Null if no personal injury occurred.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Completed Date' ;
    rdfs:comment 'Actual date on which all corrective actions were verified as complete. Null if actions not yet complete.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionDueDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Due Date' ;
    rdfs:comment 'Target date by which corrective actions must be completed. Null if no corrective action required.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:daysAwayFromWork rdf:type rdf:Property ;
    rdfs:label 'Days Away From Work' ;
    rdfs:comment 'Number of calendar days the injured employee was unable to work as a result of the incident. Zero if no time lost. Used for OSHA DART rate calculation.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:daysOfJobTransfer rdf:type rdf:Property ;
    rdfs:label 'Days Of Job Transfer' ;
    rdfs:comment 'Number of calendar days the injured employee was transferred to another job as a result of the incident. Zero if no transfer occurred.' ;
    rdfs:domain ind:EhsIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:daysOfRestrictedWork rdf:type rdf:Property ;
    rdfs:label 'Days Of Restricted Work' ;
    rdfs:comment 'Number of calendar days the injured employee was on restricted or light duty as a result of the incident. Zero if no restriction. Used for OSHA DART rate calculation.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:environmentalMediaAffected rdf:type rdf:Property ;
    rdfs:label 'Environmental Media Affected' ;
    rdfs:comment 'The environmental medium impacted by a release or spill incident. Applicable only to environmental release incidents.' ;
    rdfs:domain ind:EhsIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:immediateCause rdf:type rdf:Property ;
    rdfs:label 'Immediate Cause' ;
    rdfs:comment 'The direct, proximate cause of the incident as observed at the time of occurrence (e.g., equipment failure, slip and fall, vehicle collision).' ;
    rdfs:domain ind:EhsIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentDate rdf:type rdf:Property ;
    rdfs:label 'Incident Date' ;
    rdfs:comment 'The calendar date on which the incident occurred.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:incidentDescription rdf:type rdf:Property ;
    rdfs:label 'Incident Description' ;
    rdfs:comment 'Comprehensive narrative description of what happened during the incident, including sequence of events, conditions, and immediate observations.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentNumber rdf:type rdf:Property ;
    rdfs:label 'Incident Number' ;
    rdfs:comment 'Business-facing unique incident tracking number assigned by the EHS system for external reference and reporting.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentStatus rdf:type rdf:Property ;
    rdfs:label 'Incident Status' ;
    rdfs:comment 'Current lifecycle status of the incident record. Open indicates initial reporting; under investigation means root cause analysis in progress; corrective action pending means investigation complete but actions not yet implemented; closed means all actions complete and incident resolved.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentTime rdf:type rdf:Property ;
    rdfs:label 'Incident Time' ;
    rdfs:comment 'The precise date and time when the incident occurred, including timezone information.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:incidentType rdf:type rdf:Property ;
    rdfs:label 'Incident Type' ;
    rdfs:comment 'Classification of the incident based on severity and regulatory reporting requirements. OSHA recordable requires formal logging; first aid is minor treatment; near-miss had potential but no actual harm; environmental release involves spills or emissions; property damage affects assets; vehicle accident involves fleet collision.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:injuredPartyName rdf:type rdf:Property ;
    rdfs:label 'Injured Party Name' ;
    rdfs:comment 'Full name of the person injured or affected by the incident. Null if incident did not involve personal injury.' ;
    rdfs:domain ind:EhsIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:injuryType rdf:type rdf:Property ;
    rdfs:label 'Injury Type' ;
    rdfs:comment 'Classification of the physical injury sustained. Null if incident did not result in personal injury. [ENUM-REF-CANDIDATE: laceration|fracture|sprain|burn|contusion|amputation|respiratory|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Investigation Completed Date' ;
    rdfs:comment 'Date on which the formal incident investigation was completed and root cause analysis finalized. Null if investigation not yet complete.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:investigatorName rdf:type rdf:Property ;
    rdfs:label 'Investigator Name' ;
    rdfs:comment 'Name of the EHS professional or manager who led the incident investigation.' ;
    rdfs:domain ind:EhsIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialReleased rdf:type rdf:Property ;
    rdfs:label 'Material Released' ;
    rdfs:comment 'Description of the hazardous or non-hazardous material released during an environmental incident (e.g., diesel fuel, leachate, hydraulic fluid). Null if not an environmental release.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationDate rdf:type rdf:Property ;
    rdfs:label 'Notification Date' ;
    rdfs:comment 'Date on which the regulatory agency was notified of the incident. Null if no notification required.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:oshaRecordableFlag rdf:type rdf:Property ;
    rdfs:label 'Osha Recordable Flag' ;
    rdfs:comment 'Indicates whether the incident meets OSHA criteria for recordability on the OSHA 300 log (death, days away from work, restricted work, medical treatment beyond first aid, loss of consciousness, or significant injury/illness diagnosed by healthcare professional).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ppeInUseFlag rdf:type rdf:Property ;
    rdfs:label 'Ppe In Use Flag' ;
    rdfs:comment 'Indicates whether the injured party was wearing required personal protective equipment at the time of the incident. Null if not applicable.' ;
    rdfs:domain ind:EhsIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ppeType rdf:type rdf:Property ;
    rdfs:label 'Ppe Type' ;
    rdfs:comment 'Description of the PPE that was (or should have been) in use at the time of the incident (e.g., hard hat, safety glasses, gloves, respirator, steel-toed boots). Null if not applicable.' ;
    rdfs:domain ind:EhsIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:propertyDamageAmount rdf:type rdf:Property ;
    rdfs:label 'Property Damage Amount' ;
    rdfs:comment 'Estimated monetary value of property damage resulting from the incident in USD. Null if no property damage occurred.' ;
    rdfs:domain ind:EhsIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryAgencyNotified rdf:type rdf:Property ;
    rdfs:label 'Regulatory Agency Notified' ;
    rdfs:comment 'Name of the regulatory agency (EPA, OSHA, DOT, state environmental agency, local fire department) that was notified of the incident. Null if no notification required.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Required Flag' ;
    rdfs:comment 'Indicates whether the incident triggers a mandatory regulatory reporting obligation to EPA, OSHA, DOT, or state/local agencies.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:releaseQuantity rdf:type rdf:Property ;
    rdfs:label 'Release Quantity' ;
    rdfs:comment 'Estimated quantity of material released during an environmental incident. Null if not an environmental release.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:releaseQuantityUnit rdf:type rdf:Property ;
    rdfs:label 'Release Quantity Unit' ;
    rdfs:comment 'Unit of measure for the release quantity (gallons, liters, pounds, kilograms, cubic yards, tons).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportedByName rdf:type rdf:Property ;
    rdfs:label 'Reported By Name' ;
    rdfs:comment 'Name of the individual who initially reported the incident to the EHS department or management.' ;
    rdfs:domain ind:EhsIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reported Timestamp' ;
    rdfs:comment 'Date and time when the incident was first reported to the EHS system or management.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rootCauseClassification rdf:type rdf:Property ;
    rdfs:label 'Root Cause Classification' ;
    rdfs:comment 'High-level classification of the underlying root cause determined through incident investigation. Human error includes training gaps or procedural non-compliance; equipment failure is mechanical breakdown; process deficiency is inadequate procedure; environmental condition is weather or site hazard; management system is organizational control weakness.' ;
    rdfs:domain ind:EhsIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseDescription rdf:type rdf:Property ;
    rdfs:label 'Root Cause Description' ;
    rdfs:comment 'Detailed narrative of the root cause analysis findings, including contributing factors and systemic issues identified.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:witnessNames rdf:type rdf:Property ;
    rdfs:label 'Witness Names' ;
    rdfs:comment 'Comma-separated list of names of individuals who witnessed the incident. Used for investigation purposes. Null if no witnesses.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ghgRegulatorySubmissionId rdf:type rdf:Property ;
    rdfs:label 'Ghg Regulatory Submission Id' ;
    rdfs:comment 'Unique identifier for the greenhouse gas regulatory submission record.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GhgRegulatorySubmission .

ind:responsiblePartyEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Responsible Party Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: GHG submissions require employee ownership for data quality and regulatory accountability. Linking supports audit trails, workload management for sustainability staff, and performance tracking for cli' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:activityDataInput rdf:type rdf:Property ;
    rdfs:label 'Activity Data Input' ;
    rdfs:comment 'Description of the activity data inputs used in the emission calculation (e.g., waste in place tonnage, fuel consumption volume, vehicle miles traveled).' ;
    rdfs:domain ind:GhgRegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activityDataUnit rdf:type rdf:Property ;
    rdfs:label 'Activity Data Unit' ;
    rdfs:comment 'Unit of measure for the activity data (e.g., metric tons, gallons, cubic feet, vehicle miles).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activityDataValue rdf:type rdf:Property ;
    rdfs:label 'Activity Data Value' ;
    rdfs:comment 'Numeric value of the activity data used in the emission calculation.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calculatedCo2eQuantity rdf:type rdf:Property ;
    rdfs:label 'Calculated Co2e Quantity' ;
    rdfs:comment 'Total greenhouse gas emissions calculated and expressed in metric tons of carbon dioxide equivalent (CO2e) using EPA-specified global warming potentials.' ;
    rdfs:domain ind:GhgRegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calculationMethodology rdf:type rdf:Property ;
    rdfs:label 'Calculation Methodology' ;
    rdfs:comment 'EPA-approved calculation methodology tier used to quantify GHG emissions (Tier 1-4, direct measurement, mass balance, or continuous emissions monitoring system). [ENUM-REF-CANDIDATE: tier_1|tier_2|tier_3|tier_4|direct_measurement|mass_balance|cems — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculationNotes rdf:type rdf:Property ;
    rdfs:label 'Calculation Notes' ;
    rdfs:comment 'Additional notes, assumptions, or explanations regarding the GHG emission calculation methodology and data sources.' ;
    rdfs:domain ind:GhgRegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:co2eUnit rdf:type rdf:Property ;
    rdfs:label 'Co2e Unit' ;
    rdfs:comment 'Unit of measure for the calculated CO2e quantity, standardized as metric tons CO2e per EPA requirements.' ;
    rdfs:domain ind:GhgRegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:corporateSustainabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Corporate Sustainability Flag' ;
    rdfs:comment 'Indicates whether this submission is also used for corporate sustainability GHG inventory and ESG reporting purposes.' ;
    rdfs:domain ind:GhgRegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataQualityRating rdf:type rdf:Property ;
    rdfs:label 'Data Quality Rating' ;
    rdfs:comment 'Assessment of the quality and reliability of the activity data and emission factors used in the calculation.' ;
    rdfs:domain ind:GhgRegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emissionFactorApplied rdf:type rdf:Property ;
    rdfs:label 'Emission Factor Applied' ;
    rdfs:comment 'EPA-approved emission factor applied in the GHG calculation (e.g., methane generation rate constant, CO2 emission factor per fuel type).' ;
    rdfs:domain ind:GhgRegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emissionFactorUnit rdf:type rdf:Property ;
    rdfs:label 'Emission Factor Unit' ;
    rdfs:comment 'Unit of measure for the emission factor (e.g., kg CO2e per gallon, metric tons CH4 per metric ton waste).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emissionSourceType rdf:type rdf:Property ;
    rdfs:label 'Emission Source Type' ;
    rdfs:comment 'Category of emission source being reported: landfill gas methane (Subpart HH), waste-to-energy combustion (Subpart C), stationary combustion, mobile fleet sources, or fugitive emissions.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epaConfirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Epa Confirmation Number' ;
    rdfs:comment 'Confirmation number issued by EPA e-GGRT portal upon successful submission of the GHG report.' ;
    rdfs:domain ind:GhgRegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epaSubpart rdf:type rdf:Property ;
    rdfs:label 'Epa Subpart' ;
    rdfs:comment 'Specific EPA 40 CFR Part 98 subpart under which the emissions are being reported (e.g., Subpart HH for landfills, Subpart C for stationary combustion).' ;
    rdfs:domain ind:GhgRegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ghgPollutant rdf:type rdf:Property ;
    rdfs:label 'Ghg Pollutant' ;
    rdfs:comment 'Specific greenhouse gas pollutant being reported: methane (CH4), carbon dioxide (CO2), nitrous oxide (N2O), hydrofluorocarbons (HFC), perfluorocarbons (PFC), sulfur hexafluoride (SF6), or nitrogen trifluoride (NF3). [ENUM-REF-CANDIDATE: CH4|CO2|N2O|HFC|PFC|SF6|NF3 — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GhgRegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:globalWarmingPotential rdf:type rdf:Property ;
    rdfs:label 'Global Warming Potential' ;
    rdfs:comment 'EPA-specified global warming potential factor used to convert the GHG pollutant to CO2 equivalent (e.g., CH4 = 25, N2O = 298).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportingThresholdMetFlag rdf:type rdf:Property ;
    rdfs:label 'Reporting Threshold Met Flag' ;
    rdfs:comment 'Indicates whether the facility met the EPA reporting threshold for mandatory GHG reporting (typically 25,000 metric tons CO2e per year).' ;
    rdfs:domain ind:GhgRegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revisionNumber rdf:type rdf:Property ;
    rdfs:label 'Revision Number' ;
    rdfs:comment 'Version number of the GHG submission if the report has been revised or resubmitted after initial filing.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionReason rdf:type rdf:Property ;
    rdfs:label 'Revision Reason' ;
    rdfs:comment 'Explanation for why the GHG submission was revised or resubmitted after the initial filing.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionDate rdf:type rdf:Property ;
    rdfs:label 'Submission Date' ;
    rdfs:comment 'Date when the GHG emission report was submitted to EPA e-GGRT portal.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:submissionDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Submission Deadline Date' ;
    rdfs:comment 'Regulatory deadline date by which the GHG report must be submitted to EPA (typically March 31 following the reporting year).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:submissionNumber rdf:type rdf:Property ;
    rdfs:label 'Submission Number' ;
    rdfs:comment 'Unique business identifier for the GHG regulatory submission assigned by the reporting system or EPA e-GGRT portal.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionStatus rdf:type rdf:Property ;
    rdfs:label 'Submission Status' ;
    rdfs:comment 'Current lifecycle status of the GHG regulatory submission in the EPA e-GGRT workflow.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationDate rdf:type rdf:Property ;
    rdfs:label 'Verification Date' ;
    rdfs:comment 'Date when the GHG emission calculation and submission were verified or quality-assured.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verificationStatus rdf:type rdf:Property ;
    rdfs:label 'Verification Status' ;
    rdfs:comment 'Status of third-party verification or internal quality assurance review of the GHG emission calculation and submission.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verifierName rdf:type rdf:Property ;
    rdfs:label 'Verifier Name' ;
    rdfs:comment 'Name of the third-party verifier or internal auditor who verified the GHG emission calculation.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionFindingId rdf:type rdf:Property ;
    rdfs:label 'Inspection Finding Id' ;
    rdfs:comment 'Unique identifier for the inspection finding record. Primary key.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InspectionFinding .

ind:permitConditionId rdf:type rdf:Property ;
    rdfs:label 'Permit Condition Id' ;
    rdfs:comment 'Foreign key linking to compliance.permit_condition. Business justification: Findings cite specific permit conditions that were violated (e.g., exceeded emission limit, missed monitoring deadline). This FK links findings to the specific permit condition, enabling condition-lev' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PermitCondition .

ind:previousFindingInspectionFindingId rdf:type rdf:Property ;
    rdfs:label 'Previous Finding Inspection Finding Id' ;
    rdfs:comment 'Reference to the prior finding record if this is a repeat finding. Enables tracking of recurrence patterns and corrective action effectiveness.' ;
    rdfs:domain ind:InspectionFinding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InspectionFinding .

ind:environmentalImpact rdf:type rdf:Property ;
    rdfs:label 'Environmental Impact' ;
    rdfs:comment 'Assessment of the actual or potential environmental impact of the condition identified in the finding. None indicates no environmental consequence; low indicates minimal impact; medium indicates localized impact; high indicates significant impact; severe indicates widespread or long-term environmental harm.' ;
    rdfs:domain ind:InspectionFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityArea rdf:type rdf:Property ;
    rdfs:label 'Facility Area' ;
    rdfs:comment 'Specific location, department, or operational area within the facility where the finding was identified (e.g., Landfill Cell 3, MRF Sorting Line, Fleet Maintenance Bay, Leachate Collection System). Enables spatial tracking and accountability.' ;
    rdfs:domain ind:InspectionFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingNumber rdf:type rdf:Property ;
    rdfs:label 'Finding Number' ;
    rdfs:comment 'Business identifier for the finding, typically a sequential or hierarchical number within the parent inspection (e.g., F-001, 1.1, 2.3). Used for external reference and reporting.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingType rdf:type rdf:Property ;
    rdfs:label 'Finding Type' ;
    rdfs:comment 'Classification of the finding based on its regulatory or operational significance. Violation indicates a regulatory breach; observation is a noted condition without immediate compliance impact; recommendation suggests improvement; non-conformance indicates deviation from internal standards; opportunity for improvement highlights process enhancement areas; best practice recognizes exemplary performance.' ;
    rdfs:domain ind:InspectionFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:healthSafetyImpact rdf:type rdf:Property ;
    rdfs:label 'Health Safety Impact' ;
    rdfs:comment 'Assessment of the actual or potential health and safety impact of the condition identified in the finding. None indicates no health/safety consequence; low indicates minimal risk; medium indicates manageable risk; high indicates significant risk; severe indicates imminent danger.' ;
    rdfs:domain ind:InspectionFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionFindingDescription rdf:type rdf:Property ;
    rdfs:label 'Inspection Finding Description' ;
    rdfs:comment 'Detailed narrative description of the deficiency, observation, or condition identified during the inspection. Includes context, evidence observed, and specific circumstances. Critical for understanding the nature and scope of the finding.' ;
    rdfs:domain ind:InspectionFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionFindingStatus rdf:type rdf:Property ;
    rdfs:label 'Inspection Finding Status' ;
    rdfs:comment 'Current lifecycle status of the finding. Open indicates newly identified and not yet addressed; in progress indicates corrective action underway; pending verification indicates action completed awaiting validation; closed indicates verified resolution; deferred indicates postponed resolution with documented justification.' ;
    rdfs:domain ind:InspectionFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectorOrganization rdf:type rdf:Property ;
    rdfs:label 'Inspector Organization' ;
    rdfs:comment 'Organization or agency the inspector represents (e.g., EPA Region 5, State DEQ, Internal EHS Team, Third-Party Auditor). Provides context for the findings authority and follow-up requirements.' ;
    rdfs:domain ind:InspectionFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationSent rdf:type rdf:Property ;
    rdfs:label 'Notification Sent' ;
    rdfs:comment 'Indicates whether formal notification of this finding has been sent to responsible parties, management, or regulatory authorities as required.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:penaltyCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Penalty Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the potential penalty amount. Waste Management primarily operates in USD.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:photographicEvidenceUrl rdf:type rdf:Property ;
    rdfs:label 'Photographic Evidence Url' ;
    rdfs:comment 'Reference URL or file path to photographic or video evidence documenting the finding. Supports objective verification and audit trail.' ;
    rdfs:domain ind:InspectionFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:potentialPenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Potential Penalty Amount' ;
    rdfs:comment 'Estimated or assessed monetary penalty associated with this finding if it results in a regulatory violation. Used for financial risk assessment and reserve planning.' ;
    rdfs:domain ind:InspectionFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulationCategory rdf:type rdf:Property ;
    rdfs:label 'Regulation Category' ;
    rdfs:comment 'High-level categorization of the regulatory domain to which this finding pertains. Enables grouping and analysis of findings by compliance area. [ENUM-REF-CANDIDATE: air_quality|water_quality|waste_management|hazardous_materials|occupational_safety|environmental_monitoring|permit_compliance|reporting|other — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:InspectionFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryCitation rdf:type rdf:Property ;
    rdfs:label 'Regulatory Citation' ;
    rdfs:comment 'Specific regulatory code, statute, or standard section violated or referenced by this finding (e.g., 40 CFR 258.21, OSHA 1910.134, RCRA Subtitle D). Provides legal traceability and compliance context.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repeatFinding rdf:type rdf:Property ;
    rdfs:label 'Repeat Finding' ;
    rdfs:comment 'Indicates whether this finding is a recurrence of a previously identified and closed issue. Repeat findings may trigger escalated enforcement or management review.' ;
    rdfs:domain ind:InspectionFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rootCause rdf:type rdf:Property ;
    rdfs:label 'Root Cause' ;
    rdfs:comment 'Documented root cause of the finding as determined through root cause analysis. Identifies underlying systemic issues rather than symptoms.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseAnalysisCompleted rdf:type rdf:Property ;
    rdfs:label 'Root Cause Analysis Completed' ;
    rdfs:comment 'Indicates whether a formal root cause analysis has been conducted for this finding. Typically required for major or critical findings to prevent recurrence.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:severity rdf:type rdf:Property ;
    rdfs:label 'Severity' ;
    rdfs:comment 'Severity classification of the finding. Critical indicates immediate threat to health, safety, or environment requiring urgent action; major indicates significant regulatory or operational risk; moderate indicates manageable risk with defined timeline; minor indicates low-impact issue; informational indicates no immediate action required.' ;
    rdfs:domain ind:InspectionFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationMethod rdf:type rdf:Property ;
    rdfs:label 'Verification Method' ;
    rdfs:comment 'Method used to verify closure of the finding (e.g., follow-up inspection, document review, photographic evidence, testing results). Documents the evidence basis for closure.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verifiedBy rdf:type rdf:Property ;
    rdfs:label 'Verified By' ;
    rdfs:comment 'Name or identifier of the individual who verified the closure of the finding. Provides accountability for closure decisions.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentVendorId rdf:type rdf:Property ;
    rdfs:label 'Equipment Vendor Id' ;
    rdfs:comment 'Foreign key linking to procurement.vendor. Business justification: Monitoring equipment is vendor-supplied with maintenance contracts. Tracks equipment warranty, calibration service scheduling, and vendor performance for critical compliance infrastructure.' ;
    rdfs:domain ind:MonitoringStation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:accessRestrictions rdf:type rdf:Property ;
    rdfs:label 'Access Restrictions' ;
    rdfs:comment 'Description of any physical access restrictions, safety requirements, or special procedures needed to reach or service this monitoring station (e.g., \'Requires confined space entry permit\', \'Active landfill area - escort required\', \'Locked enclosure\').' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activationDate rdf:type rdf:Property ;
    rdfs:label 'Activation Date' ;
    rdfs:comment 'Date when the monitoring station was activated and began collecting compliance data. May differ from installation date if there was a commissioning period.' ;
    rdfs:domain ind:MonitoringStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:analyteList rdf:type rdf:Property ;
    rdfs:label 'Analyte List' ;
    rdfs:comment 'Comma-separated list or reference to the suite of parameters, chemicals, or constituents monitored at this station (e.g., \'Appendix I VOCs\', \'Appendix II metals\', \'LFG composition\', \'pH, conductivity, turbidity\'). Defines the scope of environmental monitoring.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:casingDiameterInches rdf:type rdf:Property ;
    rdfs:label 'Casing Diameter Inches' ;
    rdfs:comment 'Inner diameter of the well casing in inches. Determines sampling equipment compatibility and flow capacity. Applicable to wells only.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:casingMaterial rdf:type rdf:Property ;
    rdfs:label 'Casing Material' ;
    rdfs:comment 'Material composition of the well casing. Affects chemical compatibility and longevity. Applicable to wells and probes.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communicationMethod rdf:type rdf:Property ;
    rdfs:label 'Communication Method' ;
    rdfs:comment 'Method by which monitoring data is transmitted from the station to central systems (cellular modem, satellite uplink, radio telemetry, hardwired connection, or manual collection).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataLoggerCode rdf:type rdf:Property ;
    rdfs:label 'Data Logger Code' ;
    rdfs:comment 'Identifier for the electronic data logger or telemetry device that collects and transmits measurements from this station. Used for data integration and troubleshooting.' ;
    rdfs:domain ind:MonitoringStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deactivationDate rdf:type rdf:Property ;
    rdfs:label 'Deactivation Date' ;
    rdfs:comment 'Date when the monitoring station was deactivated, abandoned, or decommissioned. Null for active stations. Marks the end of the station\'s operational lifecycle.' ;
    rdfs:domain ind:MonitoringStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deactivationReason rdf:type rdf:Property ;
    rdfs:label 'Deactivation Reason' ;
    rdfs:comment 'Explanation for why the monitoring station was deactivated (e.g., \'Permit requirement ended\', \'Well damaged beyond repair\', \'Facility closure\', \'Replaced by new station\'). Null for active stations.' ;
    rdfs:domain ind:MonitoringStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:elevationFt rdf:type rdf:Property ;
    rdfs:label 'Elevation Ft' ;
    rdfs:comment 'Elevation of the monitoring station above mean sea level in feet. Critical for groundwater flow analysis and air quality modeling.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:equipmentSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Equipment Serial Number' ;
    rdfs:comment 'Manufacturer serial number of the primary monitoring equipment at this station. Used for warranty tracking, calibration records, and maintenance history.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentType rdf:type rdf:Property ;
    rdfs:label 'Equipment Type' ;
    rdfs:comment 'Type or model of monitoring equipment or instrumentation installed at the station (e.g., \'Continuous Air Monitor Model XYZ\', \'Submersible Pump\', \'Flow Meter\'). Used for maintenance planning and calibration tracking.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:installationContractor rdf:type rdf:Property ;
    rdfs:label 'Installation Contractor' ;
    rdfs:comment 'Name of the contractor or vendor who installed the monitoring station. Used for warranty tracking and quality assurance.' ;
    rdfs:domain ind:MonitoringStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringPurpose rdf:type rdf:Property ;
    rdfs:label 'Monitoring Purpose' ;
    rdfs:comment 'Primary purpose or phase of the monitoring program this station supports (detection monitoring, assessment monitoring, corrective action, etc.). Determines sampling frequency and analyte list.' ;
    rdfs:domain ind:MonitoringStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringStationStatus rdf:type rdf:Property ;
    rdfs:label 'Monitoring Station Status' ;
    rdfs:comment 'Current operational status of the monitoring station. Determines whether the station is included in active monitoring schedules and compliance reporting.' ;
    rdfs:domain ind:MonitoringStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringZone rdf:type rdf:Property ;
    rdfs:label 'Monitoring Zone' ;
    rdfs:comment 'Designated monitoring zone or area within the facility (e.g., \'Upgradient\', \'Downgradient\', \'Cell 3 Perimeter\', \'North Boundary\'). Used for spatial grouping and compliance zone tracking.' ;
    rdfs:domain ind:MonitoringStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryDesignation rdf:type rdf:Property ;
    rdfs:label 'Regulatory Designation' ;
    rdfs:comment 'Official regulatory identifier or designation assigned by permitting authority (e.g., NPDES outfall number, well ID per state permit, EPA monitoring point ID). Used in compliance reporting and permit tracking.' ;
    rdfs:domain ind:MonitoringStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleParty rdf:type rdf:Property ;
    rdfs:label 'Responsible Party' ;
    rdfs:comment 'Name or role of the person, team, or contractor responsible for maintaining and sampling this monitoring station. Used for accountability and work assignment.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplingFrequency rdf:type rdf:Property ;
    rdfs:label 'Sampling Frequency' ;
    rdfs:comment 'Required or planned frequency for collecting samples or measurements at this station, as specified by permit or monitoring plan. [ENUM-REF-CANDIDATE: continuous|hourly|daily|weekly|biweekly|monthly|quarterly|semiannual|annual|event_based — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screenIntervalBottomFt rdf:type rdf:Property ;
    rdfs:label 'Screen Interval Bottom Ft' ;
    rdfs:comment 'Depth to the bottom of the well screen interval from ground surface in feet. Defines the lower boundary of the monitored zone. Applicable to wells only.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:screenIntervalTopFt rdf:type rdf:Property ;
    rdfs:label 'Screen Interval Top Ft' ;
    rdfs:comment 'Depth to the top of the well screen interval from ground surface in feet. Defines the upper boundary of the monitored zone. Applicable to wells only.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stationType rdf:type rdf:Property ;
    rdfs:label 'Station Type' ;
    rdfs:comment 'Classification of the monitoring station based on the environmental medium and purpose. Determines the types of measurements collected and regulatory requirements applicable. [ENUM-REF-CANDIDATE: groundwater_well|lfg_extraction_well|lfg_monitoring_probe|air_quality_station|stormwater_outfall|leachate_collection_point|npdes_discharge_point|surface_water_monitoring|soil_gas_probe|meteorological_station — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wellDepthFt rdf:type rdf:Property ;
    rdfs:label 'Well Depth Ft' ;
    rdfs:comment 'Total depth of the monitoring well from ground surface to bottom in feet. Applicable only to groundwater wells and LFG extraction wells. Null for other station types.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedVendorId rdf:type rdf:Property ;
    rdfs:label 'Approved Vendor Id' ;
    rdfs:comment 'Foreign key linking to procurement.vendor. Business justification: Permits often specify approved vendors for permitted activities (hazmat disposal, monitoring equipment). Procurement must verify vendor is permit-approved before issuing POs. Essential for regulatory ' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:complianceOfficerEmail rdf:type rdf:Property ;
    rdfs:label 'Compliance Officer Email' ;
    rdfs:comment 'Email address of the compliance officer responsible for this permit. Used for regulatory correspondence and internal compliance tracking.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceOfficerName rdf:type rdf:Property ;
    rdfs:label 'Compliance Officer Name' ;
    rdfs:comment 'Name of the Waste Management employee responsible for ensuring compliance with this permit. Primary point of contact for regulatory agency communications.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceOfficerPhone rdf:type rdf:Property ;
    rdfs:label 'Compliance Officer Phone' ;
    rdfs:comment 'Phone number of the compliance officer responsible for this permit. Enables direct communication with the regulatory agency and internal stakeholders.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditions rdf:type rdf:Property ;
    rdfs:label 'Conditions' ;
    rdfs:comment 'Specific conditions, limitations, and operational requirements imposed by the regulatory agency as part of the permit. Includes monitoring frequencies, reporting obligations, and operational constraints.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epaIdNumber rdf:type rdf:Property ;
    rdfs:label 'Epa Id Number' ;
    rdfs:comment 'Unique EPA identification number assigned to the facility for tracking purposes under federal environmental programs. Required for RCRA hazardous waste facilities and other federally regulated sites.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialAssuranceRequired rdf:type rdf:Property ;
    rdfs:label 'Financial Assurance Required' ;
    rdfs:comment 'Indicates whether the permit requires financial assurance instruments (bonds, letters of credit, trust funds) to ensure closure and post-closure care funding. Common for landfill and TSDF permits.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:financialAssuranceType rdf:type rdf:Property ;
    rdfs:label 'Financial Assurance Type' ;
    rdfs:comment 'Type of financial assurance instrument used to meet the permit requirement. Determines the mechanism by which closure and post-closure funds are secured.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionFrequency rdf:type rdf:Property ;
    rdfs:label 'Inspection Frequency' ;
    rdfs:comment 'Frequency at which the regulatory agency conducts inspections of the permitted facility. Determines the cadence of regulatory oversight and compliance verification.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingAgencyJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Issuing Agency Jurisdiction' ;
    rdfs:comment 'Jurisdictional level of the issuing regulatory agency. Determines the hierarchy of regulatory oversight and appeal processes.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastViolationDate rdf:type rdf:Property ;
    rdfs:label 'Last Violation Date' ;
    rdfs:comment 'Date of the most recent violation or notice of non-compliance issued against this permit. Nullable if no violations have occurred.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:monitoringRequirements rdf:type rdf:Property ;
    rdfs:label 'Monitoring Requirements' ;
    rdfs:comment 'Description of the environmental monitoring and testing requirements mandated by the permit. Includes parameters to be monitored, sampling frequencies, and analytical methods.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Next Inspection Date' ;
    rdfs:comment 'Anticipated date of the next regulatory inspection. May be scheduled by the agency or estimated based on historical inspection frequency.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:permitTier rdf:type rdf:Property ;
    rdfs:label 'Permit Tier' ;
    rdfs:comment 'Regulatory classification of the permit based on the scale and environmental impact of the permitted activities. Major permits typically require more stringent monitoring and reporting.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitType rdf:type rdf:Property ;
    rdfs:label 'Permit Type' ;
    rdfs:comment 'Classification of the permit based on the environmental or operational domain it regulates. Determines applicable regulatory framework and compliance requirements.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permittedActivities rdf:type rdf:Property ;
    rdfs:label 'Permitted Activities' ;
    rdfs:comment 'Detailed description of the activities authorized under this permit. May include waste acceptance types, treatment processes, discharge points, emission sources, or operational constraints.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permittedCapacity rdf:type rdf:Property ;
    rdfs:label 'Permitted Capacity' ;
    rdfs:comment 'Maximum operational capacity authorized by the permit. Units vary by permit type: TPD (Tons Per Day) for waste facilities, gallons per day for water discharge, tons per year for air emissions.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:publicNoticeDate rdf:type rdf:Property ;
    rdfs:label 'Public Notice Date' ;
    rdfs:comment 'Date on which public notice of the permit action was published. Marks the start of the public comment period.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:publicNoticeRequired rdf:type rdf:Property ;
    rdfs:label 'Public Notice Required' ;
    rdfs:comment 'Indicates whether the permit issuance, renewal, or modification requires public notice and comment period. Common for major permits and significant permit modifications.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:statePermitNumber rdf:type rdf:Property ;
    rdfs:label 'State Permit Number' ;
    rdfs:comment 'State-specific permit identifier assigned by the state environmental quality department. Used for state-level tracking and reporting in addition to the primary permit number.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subtype rdf:type rdf:Property ;
    rdfs:label 'Subtype' ;
    rdfs:comment 'Detailed classification within the permit type. Examples include Title V Operating Permit, NSR (New Source Review), NPDES (National Pollutant Discharge Elimination System), TSDF (Treatment Storage and Disposal Facility), or municipal solid waste landfill permit.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatedMaterialId rdf:type rdf:Property ;
    rdfs:label 'Regulated Material Id' ;
    rdfs:comment 'Foreign key linking to procurement.material. Business justification: Permit conditions frequently reference specific materials with usage limits (e.g., \'max 500 gallons solvent X/month\'). Procurement must check permit limits before ordering regulated materials to preve' ;
    rdfs:domain ind:PermitCondition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Material .

ind:averagingPeriod rdf:type rdf:Property ;
    rdfs:label 'Averaging Period' ;
    rdfs:comment 'The time period over which the limit is calculated or averaged (e.g., hourly, daily, monthly, annual, 30-day rolling). Null for instantaneous limits.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceSchedule rdf:type rdf:Property ;
    rdfs:label 'Compliance Schedule' ;
    rdfs:comment 'Description of any phased compliance schedule or milestone dates specified in the condition (e.g., interim limits, construction deadlines, operational milestones).' ;
    rdfs:domain ind:PermitCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Status' ;
    rdfs:comment 'Current compliance status of this condition based on the most recent monitoring or inspection. Updated as monitoring data is received.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionCategory rdf:type rdf:Property ;
    rdfs:label 'Condition Category' ;
    rdfs:comment 'Broad environmental or operational category to which the condition applies. Used for grouping and reporting. [ENUM-REF-CANDIDATE: air_quality|water_quality|waste_management|hazardous_materials|noise|odor|safety|operational|administrative — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PermitCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionDescription rdf:type rdf:Property ;
    rdfs:label 'Condition Description' ;
    rdfs:comment 'Full text description of the permit condition as written in the permit document. Specifies the enforceable requirement in detail.' ;
    rdfs:domain ind:PermitCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionNumber rdf:type rdf:Property ;
    rdfs:label 'Condition Number' ;
    rdfs:comment 'The official condition number or identifier as specified in the permit document. Used for regulatory citation and tracking.' ;
    rdfs:domain ind:PermitCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionType rdf:type rdf:Property ;
    rdfs:label 'Condition Type' ;
    rdfs:comment 'Classification of the permit condition by regulatory purpose. Determines the nature of the enforceable requirement. [ENUM-REF-CANDIDATE: emission_limit|discharge_limit|operational_restriction|monitoring_requirement|reporting_requirement|compliance_schedule|record_keeping|best_management_practice — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PermitCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviationThreshold rdf:type rdf:Property ;
    rdfs:label 'Deviation Threshold' ;
    rdfs:comment 'The numeric threshold at which a deviation or exceedance must be reported or triggers corrective action. May differ from the limit_value.' ;
    rdfs:domain ind:PermitCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deviationThresholdUnit rdf:type rdf:Property ;
    rdfs:label 'Deviation Threshold Unit' ;
    rdfs:comment 'Unit of measure for the deviation threshold. Required when deviation_threshold is populated.' ;
    rdfs:domain ind:PermitCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enforcementPriority rdf:type rdf:Property ;
    rdfs:label 'Enforcement Priority' ;
    rdfs:comment 'The regulatory enforcement priority level assigned to this condition. High-priority conditions receive heightened scrutiny and faster enforcement response.' ;
    rdfs:domain ind:PermitCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCritical rdf:type rdf:Property ;
    rdfs:label 'Is Critical' ;
    rdfs:comment 'Indicates whether this condition is designated as critical or high-priority for compliance tracking. Violations of critical conditions may trigger immediate enforcement action.' ;
    rdfs:domain ind:PermitCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastComplianceCheckDate rdf:type rdf:Property ;
    rdfs:label 'Last Compliance Check Date' ;
    rdfs:comment 'The date of the most recent compliance verification, monitoring event, or inspection for this condition.' ;
    rdfs:domain ind:PermitCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:limitType rdf:type rdf:Property ;
    rdfs:label 'Limit Type' ;
    rdfs:comment 'Specifies whether the limit is a maximum allowable value, minimum required value, range, or time-averaged value. Defines how compliance is measured.' ;
    rdfs:domain ind:PermitCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limitUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Limit Unit Of Measure' ;
    rdfs:comment 'The unit of measure for the limit value (e.g., ppm, mg/L, tons per day, decibels, cubic meters per hour). Required when limit_value is populated.' ;
    rdfs:domain ind:PermitCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limitValue rdf:type rdf:Property ;
    rdfs:label 'Limit Value' ;
    rdfs:comment 'The numeric threshold, limit, or target value specified in the condition (e.g., emission rate, discharge concentration, operational parameter). Null if the condition is qualitative.' ;
    rdfs:domain ind:PermitCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextComplianceCheckDate rdf:type rdf:Property ;
    rdfs:label 'Next Compliance Check Date' ;
    rdfs:comment 'The scheduled date for the next compliance verification, monitoring event, or inspection for this condition. Used for proactive compliance management.' ;
    rdfs:domain ind:PermitCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingDeadlineDays rdf:type rdf:Property ;
    rdfs:label 'Reporting Deadline Days' ;
    rdfs:comment 'Number of days after the monitoring period or event by which the report must be submitted. Null if no specific deadline is defined.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryRegulatedEpaFacilityId rdf:type rdf:Property ;
    rdfs:label 'Primary Regulated Epa Facility Id' ;
    rdfs:comment 'EPA Facility Registry Service (FRS) identifier. Unique federal identifier assigned by EPA for tracking environmental compliance across all federal programs.' ;
    rdfs:domain ind:RegulatedFacility ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:activeViolationsCount rdf:type rdf:Property ;
    rdfs:label 'Active Violations Count' ;
    rdfs:comment 'Current number of unresolved regulatory violations at this facility. Calculated from violation_notice records with status = open or pending. Used for compliance risk assessment.' ;
    rdfs:domain ind:RegulatedFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicableRegulatoryPrograms rdf:type rdf:Property ;
    rdfs:label 'Applicable Regulatory Programs' ;
    rdfs:comment 'Comma-separated list of federal and state environmental programs applicable to this facility. Examples: RCRA Subtitle D, Title V Air, NPDES Water, SPCC, EPCRA Tier II, SWIS. Determines compliance obligations and reporting requirements.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Capacity Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the design capacity value. TPD = Tons Per Day (common for landfills and WTE), cubic yards (transfer stations), tons per hour (MRFs).' ;
    rdfs:domain ind:RegulatedFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Compliance Risk Level' ;
    rdfs:comment 'Overall compliance risk assessment for the facility. Low = no violations, good compliance history; Medium = minor violations or aging permits; High = multiple violations or major non-compliance; Critical = enforcement action pending or operations at risk. Used for prioritizing compliance resources.' ;
    rdfs:domain ind:RegulatedFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designCapacity rdf:type rdf:Property ;
    rdfs:label 'Design Capacity' ;
    rdfs:comment 'Maximum permitted operational capacity of the facility. Units vary by facility type: TPD (Tons Per Day) for landfills and WTE plants, cubic yards for transfer stations, tons per hour for MRFs. Used for permit compliance and capacity planning.' ;
    rdfs:domain ind:RegulatedFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:facilityClosureDate rdf:type rdf:Property ;
    rdfs:label 'Facility Closure Date' ;
    rdfs:comment 'Date the facility permanently ceased operations. Null for active facilities. Used for post-closure monitoring and long-term stewardship tracking.' ;
    rdfs:domain ind:RegulatedFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:facilityOpenedDate rdf:type rdf:Property ;
    rdfs:label 'Facility Opened Date' ;
    rdfs:comment 'Date the facility first began operations. Used for facility age analysis, permit history tracking, and closure planning.' ;
    rdfs:domain ind:RegulatedFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:naicsCode rdf:type rdf:Property ;
    rdfs:label 'Naics Code' ;
    rdfs:comment 'Six-digit NAICS code classifying the facility\'s primary business activity. Used for regulatory applicability determination and industry benchmarking. Common codes: 562111 (Solid Waste Collection), 562212 (Solid Waste Landfill), 562213 (Solid Waste Combustors and Incinerators), 562920 (Materials Recovery Facilities).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingPermitNumber rdf:type rdf:Property ;
    rdfs:label 'Operating Permit Number' ;
    rdfs:comment 'Primary operating permit number issued by the state or local regulatory agency. Required for legal operation of the facility. Links to detailed permit records in Enviance EHS.' ;
    rdfs:domain ind:RegulatedFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postClosureMonitoringEndDate rdf:type rdf:Property ;
    rdfs:label 'Post Closure Monitoring End Date' ;
    rdfs:comment 'Date when post-closure monitoring obligations end. Typically 30 years after closure for landfills. Null if monitoring not required or facility still active.' ;
    rdfs:domain ind:RegulatedFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:postClosureMonitoringRequired rdf:type rdf:Property ;
    rdfs:label 'Post Closure Monitoring Required' ;
    rdfs:comment 'Indicates whether the facility requires post-closure environmental monitoring after operations cease. True = monitoring required (typical for landfills), False = no monitoring required. Determines long-term compliance obligations.' ;
    rdfs:domain ind:RegulatedFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryRegulatoryContactEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Regulatory Contact Email' ;
    rdfs:comment 'Email address of the primary regulatory contact. Used for regulatory correspondence, inspection notifications, and compliance alerts.' ;
    rdfs:domain ind:RegulatedFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryRegulatoryContactName rdf:type rdf:Property ;
    rdfs:label 'Primary Regulatory Contact Name' ;
    rdfs:comment 'Full name of the primary internal contact responsible for regulatory compliance at this facility. Typically the facility manager, EHS manager, or compliance officer.' ;
    rdfs:domain ind:RegulatedFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryRegulatoryContactPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Regulatory Contact Phone' ;
    rdfs:comment 'Phone number of the primary regulatory contact. Used for urgent regulatory communications and emergency response coordination.' ;
    rdfs:domain ind:RegulatedFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rcraGeneratorStatus rdf:type rdf:Property ;
    rdfs:label 'Rcra Generator Status' ;
    rdfs:comment 'RCRA hazardous waste generator classification. LQG = Large Quantity Generator (≥1000 kg/month), SQG = Small Quantity Generator (100-1000 kg/month), VSQG = Very Small Quantity Generator (<100 kg/month). Determines hazardous waste management requirements.' ;
    rdfs:domain ind:RegulatedFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionalEpaOffice rdf:type rdf:Property ;
    rdfs:label 'Regional Epa Office' ;
    rdfs:comment 'EPA regional office with jurisdiction over this facility. Determines which EPA regional office handles permits, inspections, and enforcement actions. [ENUM-REF-CANDIDATE: region_1|region_2|region_3|region_4|region_5|region_6|region_7|region_8|region_9|region_10 — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RegulatedFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Status' ;
    rdfs:comment 'Current regulatory compliance status of the facility. Active = operational and compliant, Inactive = temporarily non-operational, Pending closure = in closure process, Closed = permanently closed, Suspended = operations halted due to violations, Under review = regulatory investigation in progress.' ;
    rdfs:domain ind:RegulatedFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sicCode rdf:type rdf:Property ;
    rdfs:label 'Sic Code' ;
    rdfs:comment 'Four-digit SIC code for legacy regulatory reporting. Still required by some state agencies and EPA programs. Common codes: 4953 (Refuse Systems), 4212 (Local Trucking Without Storage).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:titleVDesignation rdf:type rdf:Property ;
    rdfs:label 'Title V Designation' ;
    rdfs:comment 'Clean Air Act Title V operating permit classification. Major source = emissions exceed threshold limits, Minor source = below thresholds, Synthetic minor = voluntarily limited emissions. Determines air quality monitoring and reporting requirements.' ;
    rdfs:domain ind:RegulatedFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procurementPurchaseOrderId rdf:type rdf:Property ;
    rdfs:label 'Procurement Purchase Order Id' ;
    rdfs:comment 'Foreign key linking to procurement.purchase_order. Business justification: Corrective actions require procurement of equipment, services, materials (install scrubber, engage remediation consultant). Tracks compliance-driven capital/operational spend and links regulatory obli' ;
    rdfs:domain ind:RegulatoryCorrectiveAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseOrder .

ind:actionDescription rdf:type rdf:Property ;
    rdfs:label 'Action Description' ;
    rdfs:comment 'Detailed description of the corrective or preventive action required, including specific steps, procedures, or changes to be implemented.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionTitle rdf:type rdf:Property ;
    rdfs:label 'Action Title' ;
    rdfs:comment 'Brief, descriptive title summarizing the corrective or preventive action.' ;
    rdfs:domain ind:RegulatoryCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualCost rdf:type rdf:Property ;
    rdfs:label 'Actual Cost' ;
    rdfs:comment 'Actual cost in US dollars incurred to implement the corrective or preventive action. Null if action is not yet completed or costs have not been finalized.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:closureNotes rdf:type rdf:Property ;
    rdfs:label 'Closure Notes' ;
    rdfs:comment 'Notes or comments documenting the closure of the action, including any final observations, lessons learned, or follow-up recommendations.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Cost' ;
    rdfs:comment 'Estimated cost in US dollars to implement the corrective or preventive action, including labor, materials, equipment, and contractor costs.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:managementReviewDate rdf:type rdf:Property ;
    rdfs:label 'Management Review Date' ;
    rdfs:comment 'Date when the corrective or preventive action was reviewed by management. Null if management review has not occurred or is not required.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:managementReviewRequired rdf:type rdf:Property ;
    rdfs:label 'Management Review Required' ;
    rdfs:comment 'Indicates whether the corrective or preventive action requires formal management review before closure, typically for high-priority or high-cost actions.' ;
    rdfs:domain ind:RegulatoryCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recurrenceRisk rdf:type rdf:Property ;
    rdfs:label 'Recurrence Risk' ;
    rdfs:comment 'Assessment of the risk that the nonconformity or incident will recur after the corrective or preventive action is implemented.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleDepartment rdf:type rdf:Property ;
    rdfs:label 'Responsible Department' ;
    rdfs:comment 'Department or functional area responsible for implementing the action (e.g., Operations, Maintenance, EHS, Fleet, Engineering).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseAnalysis rdf:type rdf:Property ;
    rdfs:label 'Root Cause Analysis' ;
    rdfs:comment 'Summary of the root cause analysis performed to identify the underlying cause of the nonconformity or potential nonconformity. May reference methodologies such as 5 Whys, Fishbone Diagram, or Fault Tree Analysis.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyImpactCategory rdf:type rdf:Property ;
    rdfs:label 'Safety Impact Category' ;
    rdfs:comment 'Category of occupational health and safety impact addressed by the action (e.g., hazardous waste exposure, equipment safety, PPE compliance, confined space, fall protection, vehicle safety).' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Target Completion Date' ;
    rdfs:comment 'Planned or required date by which the corrective or preventive action must be completed. May be driven by regulatory deadlines or internal commitments.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:triggeringEventReference rdf:type rdf:Property ;
    rdfs:label 'Triggering Event Reference' ;
    rdfs:comment 'Reference identifier to the source event that triggered this action (e.g., inspection ID, incident ID, audit finding ID, violation notice number). Enables traceability to the root cause.' ;
    rdfs:domain ind:RegulatoryCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggeringEventType rdf:type rdf:Property ;
    rdfs:label 'Triggering Event Type' ;
    rdfs:comment 'The type of event that initiated this corrective or preventive action (e.g., regulatory inspection, violation notice, environmental incident, internal audit finding, customer complaint, or proactive self-identification).' ;
    rdfs:domain ind:RegulatoryCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verifiedByName rdf:type rdf:Property ;
    rdfs:label 'Verified By Name' ;
    rdfs:comment 'Name of the individual who verified the effectiveness of the corrective or preventive action.' ;
    rdfs:domain ind:RegulatoryCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicabilityScope rdf:type rdf:Property ;
    rdfs:label 'Applicability Scope' ;
    rdfs:comment 'Describes the scope of operations, facility types, waste streams, or activities to which this regulatory requirement applies (e.g., \'All MSW landfills\', \'Hazardous waste TSDFs\', \'Commercial vehicle operators with CDL\', \'MRF operations handling recyclables\').' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:citationNumber rdf:type rdf:Property ;
    rdfs:label 'Citation Number' ;
    rdfs:comment 'The official citation or reference number of the regulation (e.g., 40 CFR 258.40, 29 CFR 1910.120, 49 CFR 172.101). This is the externally-known unique identifier for the regulatory requirement.' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceFrequency rdf:type rdf:Property ;
    rdfs:label 'Compliance Frequency' ;
    rdfs:comment 'The frequency at which compliance with this requirement must be demonstrated or reported (e.g., Annual, Quarterly, Continuous, Event-Driven). [ENUM-REF-CANDIDATE: One-Time|Daily|Weekly|Monthly|Quarterly|Semi-Annual|Annual|Biennial|Event-Driven|Continuous — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceObligationSummary rdf:type rdf:Property ;
    rdfs:label 'Compliance Obligation Summary' ;
    rdfs:comment 'A concise summary of the key compliance obligations imposed by this requirement, written for operational and compliance teams.' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentationRequired rdf:type rdf:Property ;
    rdfs:label 'Documentation Required' ;
    rdfs:comment 'Indicates whether this requirement mandates the creation and retention of specific documentation or records (True/False).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityTypeApplicability rdf:type rdf:Property ;
    rdfs:label 'Facility Type Applicability' ;
    rdfs:comment 'The specific facility types to which this requirement applies (e.g., Landfill, MRF, Transfer Station, WTE Facility, TSDF, Fleet Maintenance Facility). Pipe-separated list if multiple types apply.' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionRequired rdf:type rdf:Property ;
    rdfs:label 'Inspection Required' ;
    rdfs:comment 'Indicates whether this requirement mandates periodic inspections by regulatory authorities or third parties (True/False).' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:internalPolicyReference rdf:type rdf:Property ;
    rdfs:label 'Internal Policy Reference' ;
    rdfs:comment 'Reference to the internal company policy, procedure, or standard operating procedure (SOP) that implements this regulatory requirement.' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isoClauseReference rdf:type rdf:Property ;
    rdfs:label 'Iso Clause Reference' ;
    rdfs:comment 'The specific ISO 14001 or ISO 45001 clause or requirement that this regulatory requirement supports or maps to, if applicable.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionGeography rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Geography' ;
    rdfs:comment 'The specific geographic area or political subdivision where this requirement applies (e.g., USA, California, Harris County). Uses 3-letter country codes for national jurisdictions.' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumPenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Penalty Amount' ;
    rdfs:comment 'The maximum monetary penalty amount (in USD) that can be assessed for a single violation of this requirement, if defined by the regulation.' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:monitoringRequired rdf:type rdf:Property ;
    rdfs:label 'Monitoring Required' ;
    rdfs:comment 'Indicates whether this requirement mandates ongoing environmental or operational monitoring (e.g., air quality, groundwater, LFG, LEL) (True/False).' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operationTypeApplicability rdf:type rdf:Property ;
    rdfs:label 'Operation Type Applicability' ;
    rdfs:comment 'The operational activities to which this requirement applies (e.g., Collection, Hauling, Processing, Disposal, Treatment, Storage, Transport). Pipe-separated list if multiple operations apply.' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltySeverity rdf:type rdf:Property ;
    rdfs:label 'Penalty Severity' ;
    rdfs:comment 'The severity classification of penalties or enforcement actions associated with non-compliance with this requirement (Low, Medium, High, Critical).' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitRequired rdf:type rdf:Property ;
    rdfs:label 'Permit Required' ;
    rdfs:comment 'Indicates whether this requirement mandates obtaining a specific permit or authorization (e.g., air permit, water discharge permit, waste handling permit) (True/False).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulationTitle rdf:type rdf:Property ;
    rdfs:label 'Regulation Title' ;
    rdfs:comment 'The full official title or name of the regulation or regulatory requirement.' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryBody rdf:type rdf:Property ;
    rdfs:label 'Regulatory Body' ;
    rdfs:comment 'The governing body or agency that issued and enforces this regulatory requirement (e.g., EPA, OSHA, DOT, State Environmental Quality Department, Local Solid Waste Authority). [ENUM-REF-CANDIDATE: EPA|OSHA|DOT|State Environmental Agency|Local Enforcement Agency|SWANA|NWRA|ISO — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryFramework rdf:type rdf:Property ;
    rdfs:label 'Regulatory Framework' ;
    rdfs:comment 'The overarching regulatory framework or act under which this requirement falls (e.g., RCRA, CERCLA, Clean Air Act, Clean Water Act, ISO 14001, ISO 45001). [ENUM-REF-CANDIDATE: RCRA|CERCLA|CAA|CWA|TSCA|OSHA|DOT HAZMAT|ISO 14001|ISO 45001|State Solid Waste Code — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryRequirementDescription rdf:type rdf:Property ;
    rdfs:label 'Regulatory Requirement Description' ;
    rdfs:comment 'A detailed textual description of the regulatory requirement, including the specific obligations, standards, or actions mandated by the regulation.' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryRequirementStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Requirement Status' ;
    rdfs:comment 'The current lifecycle status of this regulatory requirement (Active, Proposed, Superseded, Repealed, Under Review, Pending).' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingRequired rdf:type rdf:Property ;
    rdfs:label 'Reporting Required' ;
    rdfs:comment 'Indicates whether this requirement mandates periodic or event-driven reporting to regulatory authorities (e.g., SWIS submissions, CERCLA notifications, incident reports) (True/False).' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requirementType rdf:type rdf:Property ;
    rdfs:label 'Requirement Type' ;
    rdfs:comment 'The category or type of compliance obligation imposed by this requirement (e.g., Permit, Inspection, Monitoring, Reporting, Training, Record Keeping, Operational Standard, Emission Limit). [ENUM-REF-CANDIDATE: Permit|Inspection|Monitoring|Reporting|Training|Record Keeping|Operational Standard|Design Standard|Emission Limit|Discharge Limit — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionDate rdf:type rdf:Property ;
    rdfs:label 'Revision Date' ;
    rdfs:comment 'The date of the most recent revision or amendment to this regulatory requirement.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Source Document Url' ;
    rdfs:comment 'The web URL or hyperlink to the official source document or regulatory text (e.g., Federal Register, EPA website, state regulatory portal).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingRequired rdf:type rdf:Property ;
    rdfs:label 'Training Required' ;
    rdfs:comment 'Indicates whether this requirement mandates specific training or certification for personnel (e.g., CDL, HAZWOPER, OSHA 40-hour) (True/False).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataProviderVendorId rdf:type rdf:Property ;
    rdfs:label 'Data Provider Vendor Id' ;
    rdfs:comment 'Foreign key linking to procurement.vendor. Business justification: Submissions require vendor data (Tier II reports use vendor SDS, disposal reports need TSDF certifications). Tracks vendor data quality and timeliness for regulatory deadlines and audit trails.' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:originalSubmissionRegulatorySubmissionId rdf:type rdf:Property ;
    rdfs:label 'Original Submission Regulatory Submission Id' ;
    rdfs:comment 'Identifier of the original regulatory submission that this record amends, if applicable. Links amended submissions to their original filing.' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatorySubmission .

ind:primaryRegulatoryPreparedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Regulatory Prepared By Employee Id' ;
    rdfs:comment 'Identifier of the employee who prepared the regulatory submission. Tracks accountability for report preparation.' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:scheduledObligationId rdf:type rdf:Property ;
    rdfs:label 'Scheduled Obligation Id' ;
    rdfs:comment 'Foreign key linking to compliance.scheduled_obligation. Business justification: Regulatory submissions fulfill scheduled compliance obligations. This FK links submissions to the scheduled obligation that triggered them, enabling obligation fulfillment tracking and deadline compli' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ScheduledObligation .

ind:tertiaryRegulatorySubmittedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Regulatory Submitted By Employee Id' ;
    rdfs:comment 'Identifier of the employee who executed the submission to the regulatory agency. Tracks final submission action.' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:agencyComments rdf:type rdf:Property ;
    rdfs:label 'Agency Comments' ;
    rdfs:comment 'Comments or feedback provided by the regulatory agency regarding the submission. Captures agency instructions, deficiency notices, or acceptance notes.' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Agency Jurisdiction' ;
    rdfs:comment 'Level of government jurisdiction for the filing agency (federal, state, local, or regional).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyResponseDate rdf:type rdf:Property ;
    rdfs:label 'Agency Response Date' ;
    rdfs:comment 'Date on which the regulatory agency provided a formal response to the submission (acceptance, rejection, or request for additional information).' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:agencyResponseStatus rdf:type rdf:Property ;
    rdfs:label 'Agency Response Status' ;
    rdfs:comment 'Status of the regulatory agency\'s response to the submission. Tracks whether the filing was accepted, rejected, or requires follow-up.' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentFlag rdf:type rdf:Property ;
    rdfs:label 'Amendment Flag' ;
    rdfs:comment 'Indicates whether this submission is an amendment to a previously filed report. True if this is an amended submission, false if original.' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:amendmentReason rdf:type rdf:Property ;
    rdfs:label 'Amendment Reason' ;
    rdfs:comment 'Explanation of why the original submission was amended. Documents the business justification for the corrected filing.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationDate rdf:type rdf:Property ;
    rdfs:label 'Certification Date' ;
    rdfs:comment 'Date on which the authorized official certified the regulatory submission. Establishes legal accountability for the report contents.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationStatement rdf:type rdf:Property ;
    rdfs:label 'Certification Statement' ;
    rdfs:comment 'Text of the certification statement signed by the authorized representative, attesting to the accuracy and completeness of the submission under penalty of law.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifyingOfficialName rdf:type rdf:Property ;
    rdfs:label 'Certifying Official Name' ;
    rdfs:comment 'Name of the authorized company official who certified the regulatory submission. Typically a facility manager, environmental manager, or corporate officer.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifyingOfficialTitle rdf:type rdf:Property ;
    rdfs:label 'Certifying Official Title' ;
    rdfs:comment 'Job title of the authorized official who certified the submission (e.g., Environmental Manager, Facility Manager, Vice President of EHS).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceYear rdf:type rdf:Property ;
    rdfs:label 'Compliance Year' ;
    rdfs:comment 'Calendar year for which compliance is being reported. Facilitates year-over-year compliance tracking and trend analysis.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:confirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Confirmation Number' ;
    rdfs:comment 'Confirmation or tracking number issued by the regulatory agency upon receipt of the submission. Serves as proof of filing.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentFilePath rdf:type rdf:Property ;
    rdfs:label 'Document File Path' ;
    rdfs:comment 'File path or storage location of the submitted regulatory report document. Enables retrieval of the original submission for audit and reference.' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentFormat rdf:type rdf:Property ;
    rdfs:label 'Document Format' ;
    rdfs:comment 'File format of the submitted regulatory report (PDF, XML, Excel, etc.). Identifies the technical format used for submission.' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingAgency rdf:type rdf:Property ;
    rdfs:label 'Filing Agency' ;
    rdfs:comment 'Name of the government agency or regulatory body to which the report is submitted (e.g., EPA, state environmental quality department, local enforcement agency).' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lateSubmissionFlag rdf:type rdf:Property ;
    rdfs:label 'Late Submission Flag' ;
    rdfs:comment 'Indicates whether the submission was filed after the regulatory deadline. True if late, false if on time. Used to track compliance with filing timelines.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lateSubmissionReason rdf:type rdf:Property ;
    rdfs:label 'Late Submission Reason' ;
    rdfs:comment 'Explanation for why the submission was filed late, if applicable. Documents the circumstances that caused the delay.' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportType rdf:type rdf:Property ;
    rdfs:label 'Report Type' ;
    rdfs:comment 'Classification of the regulatory report being submitted. Identifies the specific regulatory program and reporting requirement. [ENUM-REF-CANDIDATE: RCRA Biennial Report|SWIS Report|NPDES DMR|Title V Certification|CERCLA Tier II|EPCRA Tier II|OSHA 300A Summary|GHG Emissions Report|State Environmental Report|Air Quality Report|Water Discharge Report|Hazardous Waste Manifest|LFG Monitoring Report|Leachate Analysis Report — promote to reference product]' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Reporting Period End' ;
    rdfs:comment 'End date of the period covered by this regulatory submission. Defines the close of the compliance reporting window.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Start' ;
    rdfs:comment 'Start date of the period covered by this regulatory submission. Defines the beginning of the compliance reporting window.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:submissionMethod rdf:type rdf:Property ;
    rdfs:label 'Submission Method' ;
    rdfs:comment 'Method by which the report was submitted to the regulatory agency (electronic portal, paper mail, email, etc.).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Id' ;
    rdfs:comment 'Unique identifier for the environmental, health, and safety risk assessment record.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assessedMaterialId rdf:type rdf:Property ;
    rdfs:label 'Assessed Material Id' ;
    rdfs:comment 'Foreign key linking to procurement.material. Business justification: Risk assessments evaluate hazards of specific materials. Procurement must consider findings when sourcing alternatives or approving new materials. Links risk management to procurement decisions for sa' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Material .

ind:conductedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Conducted By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Risk assessments require qualified employees. Linking enables competency verification, workload tracking for EHS staff, audit trails for ISO 14001/45001 compliance, and quality assurance of assessment' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assessmentDate rdf:type rdf:Property ;
    rdfs:label 'Assessment Date' ;
    rdfs:comment 'Date when the risk assessment was conducted or completed. Represents the principal business event timestamp for this assessment record.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assessmentNumber rdf:type rdf:Property ;
    rdfs:label 'Assessment Number' ;
    rdfs:comment 'Business-facing unique identifier or reference number for the risk assessment, used for tracking and reporting purposes.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentReviewedBy rdf:type rdf:Property ;
    rdfs:label 'Assessment Reviewed By' ;
    rdfs:comment 'Name or identifier of the individual who reviewed and approved the risk assessment. Typically a senior EHS manager or facility director.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentStatus rdf:type rdf:Property ;
    rdfs:label 'Assessment Status' ;
    rdfs:comment 'Current lifecycle status of the risk assessment. Draft indicates initial preparation, In Review indicates management or EHS review in progress, Approved indicates formal acceptance, Active indicates current operational use, Superseded indicates replaced by newer assessment, Archived indicates historical record retention.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:associatedRiskOrImpact rdf:type rdf:Property ;
    rdfs:label 'Associated Risk Or Impact' ;
    rdfs:comment 'Description of the potential consequence or impact if the identified hazard or environmental aspect is realized. For safety, examples include injury, illness, or fatality. For environmental, examples include air quality degradation, water contamination, soil pollution, or contribution to climate change (CO2e emissions).' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:existingControls rdf:type rdf:Property ;
    rdfs:label 'Existing Controls' ;
    rdfs:comment 'Description of current control measures, safeguards, or mitigation strategies already in place to manage the identified hazard or environmental aspect. Examples include engineering controls (guards, ventilation), administrative controls (procedures, training, permits), or Personal Protective Equipment (PPE) requirements.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardCategory rdf:type rdf:Property ;
    rdfs:label 'Hazard Category' ;
    rdfs:comment 'Classification of the identified hazard or environmental aspect. Physical hazards include struck-by, caught-in, fall hazards. Chemical hazards include exposure to hazardous substances. Biological hazards include exposure to pathogens. Ergonomic hazards include repetitive motion or lifting. Environmental aspects include emissions, discharges, waste generation. Operational hazards include equipment failure or process upset. Regulatory hazards include non-compliance risk. [ENUM-REF-CANDIDATE: physical|chemical|biological|ergonomic|environmental|operational|regulatory — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardIdentified rdf:type rdf:Property ;
    rdfs:label 'Hazard Identified' ;
    rdfs:comment 'Description of the specific hazard, environmental aspect, or risk factor identified during the assessment. For occupational safety, examples include struck-by hazards from moving vehicles, exposure to hazardous waste, ergonomic strain, or confined space entry risks. For environmental aspects, examples include air emissions, wastewater discharge, soil contamination, or greenhouse gas (GHG) emissions.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:likelihoodRating rdf:type rdf:Property ;
    rdfs:label 'Likelihood Rating' ;
    rdfs:comment 'Numerical rating representing the probability or frequency that the identified hazard or environmental aspect will occur. Typically scored on a scale of 1 to 5, where 1 is rare and 5 is almost certain. Used in conjunction with severity rating to calculate risk priority.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:managementReviewRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Management Review Required Flag' ;
    rdfs:comment 'Indicates whether this risk assessment requires formal management review due to high residual risk level or significant operational impact. True if management review is required, False otherwise.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextReviewDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Review Due Date' ;
    rdfs:comment 'Scheduled date for the next periodic review or reassessment of this risk assessment. ISO 14001 and ISO 45001 require periodic review of risk assessments to ensure continued relevance and accuracy.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operationScope rdf:type rdf:Property ;
    rdfs:label 'Operation Scope' ;
    rdfs:comment 'Description of the specific operation, process, activity, or work area covered by this risk assessment. Examples include residential collection route operations, landfill cell compaction, MRF sorting line operations, hazardous waste handling, fleet maintenance activities, or leachate management.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ppeRequired rdf:type rdf:Property ;
    rdfs:label 'Ppe Required' ;
    rdfs:comment 'Description of Personal Protective Equipment (PPE) required to manage the identified hazard. Examples include hard hats, safety glasses, gloves, respirators, hearing protection, high-visibility vests, or chemical-resistant suits.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendedAdditionalControls rdf:type rdf:Property ;
    rdfs:label 'Recommended Additional Controls' ;
    rdfs:comment 'Description of recommended additional control measures, safeguards, or mitigation strategies to further reduce residual risk to an acceptable level. May include engineering improvements, enhanced training, revised procedures, or additional PPE.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Residual Risk Level' ;
    rdfs:comment 'Classification of the remaining risk level after existing controls are applied. Low indicates acceptable risk with current controls. Medium indicates risk requiring monitoring. High indicates risk requiring additional controls. Very High indicates unacceptable risk requiring immediate action.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewDate rdf:type rdf:Property ;
    rdfs:label 'Review Date' ;
    rdfs:comment 'Date when the risk assessment was formally reviewed and approved by management or EHS leadership.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:riskPriorityNumber rdf:type rdf:Property ;
    rdfs:label 'Risk Priority Number' ;
    rdfs:comment 'Calculated risk priority score, typically the product of likelihood rating and severity rating. Used to rank and prioritize risks for control implementation. Higher RPN values indicate higher priority for risk mitigation.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:severityRating rdf:type rdf:Property ;
    rdfs:label 'Severity Rating' ;
    rdfs:comment 'Numerical rating representing the magnitude of harm or impact if the identified hazard or environmental aspect is realized. Typically scored on a scale of 1 to 5, where 1 is negligible and 5 is catastrophic. Used in conjunction with likelihood rating to calculate risk priority.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Training Required Flag' ;
    rdfs:comment 'Indicates whether this risk assessment has identified the need for specific training to manage the identified hazard or environmental aspect. True if training is required, False otherwise. Examples include HAZWOPER training, CDL training, confined space entry training, or equipment-specific training.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:actualEffortHours rdf:type rdf:Property ;
    rdfs:label 'Actual Effort Hours' ;
    rdfs:comment 'Actual number of labor hours spent completing this obligation. Used for performance tracking and future estimation refinement.' ;
    rdfs:domain ind:ScheduledObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:agencyContactEmail rdf:type rdf:Property ;
    rdfs:label 'Agency Contact Email' ;
    rdfs:comment 'Email address of the regulatory agency contact person. Organizational contact information classified as confidential.' ;
    rdfs:domain ind:ScheduledObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyContactPhone rdf:type rdf:Property ;
    rdfs:label 'Agency Contact Phone' ;
    rdfs:comment 'Phone number of the regulatory agency contact person. Organizational contact information classified as confidential.' ;
    rdfs:domain ind:ScheduledObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completedBy rdf:type rdf:Property ;
    rdfs:label 'Completed By' ;
    rdfs:comment 'Name or identifier of the individual who completed this obligation. May differ from the originally assigned responsible party.' ;
    rdfs:domain ind:ScheduledObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionDate rdf:type rdf:Property ;
    rdfs:label 'Completion Date' ;
    rdfs:comment 'The actual date when this obligation was completed. Null if the obligation is still pending or in progress.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:daysUntilDue rdf:type rdf:Property ;
    rdfs:label 'Days Until Due' ;
    rdfs:comment 'Calculated number of days remaining until the obligation due date. Negative values indicate overdue obligations. Used for prioritization and escalation.' ;
    rdfs:domain ind:ScheduledObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:escalationFlag rdf:type rdf:Property ;
    rdfs:label 'Escalation Flag' ;
    rdfs:comment 'Indicates whether this obligation has been escalated to management due to approaching deadline, complexity, or risk. True if escalated, false otherwise.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedEffortHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Effort Hours' ;
    rdfs:comment 'Estimated number of labor hours required to complete this obligation. Used for resource planning and workload management.' ;
    rdfs:domain ind:ScheduledObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextOccurrenceDate rdf:type rdf:Property ;
    rdfs:label 'Next Occurrence Date' ;
    rdfs:comment 'The due date of the next scheduled occurrence of this recurring obligation. Automatically calculated based on recurrence frequency and pattern.' ;
    rdfs:domain ind:ScheduledObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:obligationDescription rdf:type rdf:Property ;
    rdfs:label 'Obligation Description' ;
    rdfs:comment 'Detailed description of the scheduled compliance obligation, including specific requirements, deliverables, and any special instructions for completion.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationNumber rdf:type rdf:Property ;
    rdfs:label 'Obligation Number' ;
    rdfs:comment 'Business-facing unique identifier for the scheduled obligation, formatted as OBL- followed by 8 digits. Used for tracking and reference in compliance communications.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationStatus rdf:type rdf:Property ;
    rdfs:label 'Obligation Status' ;
    rdfs:comment 'Current lifecycle status of the scheduled obligation. Tracks whether the obligation is awaiting action, being worked on, completed, or past due.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationTitle rdf:type rdf:Property ;
    rdfs:label 'Obligation Title' ;
    rdfs:comment 'Short descriptive title of the scheduled compliance obligation. Provides a human-readable summary of the task.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationType rdf:type rdf:Property ;
    rdfs:label 'Obligation Type' ;
    rdfs:comment 'Classification of the scheduled compliance obligation. Defines the nature of the regulatory task that must be completed. [ENUM-REF-CANDIDATE: permit_renewal|monitoring_report|regulatory_filing|compliance_certification|inspection|sampling|training_certification — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recurrencePattern rdf:type rdf:Property ;
    rdfs:label 'Recurrence Pattern' ;
    rdfs:comment 'Detailed recurrence pattern specification for complex schedules. May include specific days of month, week numbers, or custom scheduling rules.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryDriver rdf:type rdf:Property ;
    rdfs:label 'Regulatory Driver' ;
    rdfs:comment 'The specific regulation, permit condition, or regulatory citation that mandates this obligation. May reference EPA regulations, RCRA requirements, state environmental codes, or specific permit conditions.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledStartDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Date' ;
    rdfs:comment 'The planned date when work on this obligation should begin. Used for proactive task planning and resource allocation.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:submissionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Submission Required Flag' ;
    rdfs:comment 'Indicates whether this obligation requires formal submission of documentation or reports to a regulatory agency. True if submission is required, false otherwise.' ;
    rdfs:domain ind:ScheduledObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:affectedMedia rdf:type rdf:Property ;
    rdfs:label 'Affected Media' ;
    rdfs:comment 'Environmental media impacted by the spill (e.g., soil, surface water, groundwater, air, pavement, multiple media).' ;
    rdfs:domain ind:SpillRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyNotified rdf:type rdf:Property ;
    rdfs:label 'Agency Notified' ;
    rdfs:comment 'Name of the regulatory agency or agencies notified of the spill (e.g., National Response Center, state environmental agency, local emergency response).' ;
    rdfs:domain ind:SpillRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:causeCategory rdf:type rdf:Property ;
    rdfs:label 'Cause Category' ;
    rdfs:comment 'High-level classification of the root cause of the spill (e.g., equipment failure, human error, natural event, third-party action, unknown).' ;
    rdfs:domain ind:SpillRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cleanupCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Cleanup Completion Date' ;
    rdfs:comment 'Date on which all cleanup and remediation activities were completed and the site was restored.' ;
    rdfs:domain ind:SpillRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cleanupStartDate rdf:type rdf:Property ;
    rdfs:label 'Cleanup Start Date' ;
    rdfs:comment 'Date on which cleanup and remediation activities commenced.' ;
    rdfs:domain ind:SpillRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:containmentActions rdf:type rdf:Property ;
    rdfs:label 'Containment Actions' ;
    rdfs:comment 'Description of immediate containment and response actions taken to control the spill (e.g., deployment of absorbent materials, berms, booms, or other containment measures).' ;
    rdfs:domain ind:SpillRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActions rdf:type rdf:Property ;
    rdfs:label 'Corrective Actions' ;
    rdfs:comment 'Description of corrective and preventive actions implemented to prevent recurrence of similar spill incidents.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discoveryDate rdf:type rdf:Property ;
    rdfs:label 'Discovery Date' ;
    rdfs:comment 'The date on which the spill or release was first discovered by personnel.' ;
    rdfs:domain ind:SpillRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disposalFacilityEpaNumber rdf:type rdf:Property ;
    rdfs:label 'Disposal Facility Epa Number' ;
    rdfs:comment 'EPA identification number of the disposal facility where contaminated waste was sent.' ;
    rdfs:domain ind:SpillRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalFacilityName rdf:type rdf:Property ;
    rdfs:label 'Disposal Facility Name' ;
    rdfs:comment 'Name of the Treatment, Storage, and Disposal Facility (TSDF) where contaminated waste was sent for final disposal.' ;
    rdfs:domain ind:SpillRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedQuantity rdf:type rdf:Property ;
    rdfs:label 'Estimated Quantity' ;
    rdfs:comment 'Estimated volume or mass of material released during the spill incident.' ;
    rdfs:domain ind:SpillRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:locationAddress rdf:type rdf:Property ;
    rdfs:label 'Location Address' ;
    rdfs:comment 'Street address or specific location description where the spill occurred.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationCity rdf:type rdf:Property ;
    rdfs:label 'Location City' ;
    rdfs:comment 'City where the spill occurred.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationState rdf:type rdf:Property ;
    rdfs:label 'Location State' ;
    rdfs:comment 'Two-letter state code where the spill occurred.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationZipCode rdf:type rdf:Property ;
    rdfs:label 'Location Zip Code' ;
    rdfs:comment 'ZIP code of the location where the spill occurred.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationConfirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Notification Confirmation Number' ;
    rdfs:comment 'Confirmation or reference number provided by the regulatory agency upon notification of the spill.' ;
    rdfs:domain ind:SpillRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportableFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reportable Flag' ;
    rdfs:comment 'Indicates whether the spill is reportable to regulatory agencies under federal, state, or local requirements.' ;
    rdfs:domain ind:SpillRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:releaseType rdf:type rdf:Property ;
    rdfs:label 'Release Type' ;
    rdfs:comment 'Classification of the material released during the spill incident (e.g., leachate, fuel, hazardous material, stormwater, chemical, oil).' ;
    rdfs:domain ind:SpillRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportableQuantityExceededFlag rdf:type rdf:Property ;
    rdfs:label 'Reportable Quantity Exceeded Flag' ;
    rdfs:comment 'Indicates whether the spill quantity exceeded the CERCLA Reportable Quantity threshold requiring federal notification.' ;
    rdfs:domain ind:SpillRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:spillDate rdf:type rdf:Property ;
    rdfs:label 'Spill Date' ;
    rdfs:comment 'The date on which the spill or release incident occurred.' ;
    rdfs:domain ind:SpillRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:spillStatus rdf:type rdf:Property ;
    rdfs:label 'Spill Status' ;
    rdfs:comment 'Current lifecycle status of the spill incident (e.g., reported, contained, cleanup in progress, cleanup complete, closed).' ;
    rdfs:domain ind:SpillRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spillTime rdf:type rdf:Property ;
    rdfs:label 'Spill Time' ;
    rdfs:comment 'The precise timestamp when the spill or release incident was discovered or occurred.' ;
    rdfs:domain ind:SpillRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:unNumber rdf:type rdf:Property ;
    rdfs:label 'Un Number' ;
    rdfs:comment 'Four-digit UN identification number for hazardous materials transported, if applicable.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteDisposedQuantity rdf:type rdf:Property ;
    rdfs:label 'Waste Disposed Quantity' ;
    rdfs:comment 'Quantity of contaminated material or waste generated and disposed of as a result of the cleanup activities.' ;
    rdfs:domain ind:SpillRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wasteDisposedUnit rdf:type rdf:Property ;
    rdfs:label 'Waste Disposed Unit' ;
    rdfs:comment 'Unit of measure for the quantity of waste disposed (e.g., gallons, liters, pounds, kilograms, tons, cubic yards).' ;
    rdfs:domain ind:SpillRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingCertificationId rdf:type rdf:Property ;
    rdfs:label 'Training Certification Id' ;
    rdfs:comment 'Unique identifier for the training certification record. Primary key.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TrainingCertification .

ind:trainingRequirementId rdf:type rdf:Property ;
    rdfs:label 'Training Requirement Id' ;
    rdfs:comment 'Foreign key linking to compliance.training_requirement. Business justification: Training certifications fulfill specific training requirements (HAZWOPER, CDL, OSHA 40-hour, DOT HazMat). This FK replaces the denormalized certification_type STRING field with a structured relationsh' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TrainingRequirement .

ind:trainingVendorId rdf:type rdf:Property ;
    rdfs:label 'Training Vendor Id' ;
    rdfs:comment 'Foreign key linking to procurement.vendor. Business justification: Certifications are vendor-provided (OSHA HAZWOPER training, equipment certifications). Links vendor qualification, training cost tracking, and regulatory compliance verification. Training_provider is ' ;
    rdfs:domain ind:TrainingCertification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:attachmentUrl rdf:type rdf:Property ;
    rdfs:label 'Attachment Url' ;
    rdfs:comment 'The file path or URL to the scanned copy of the certification document stored in the document management system. Used for audit and verification purposes.' ;
    rdfs:domain ind:TrainingCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdlClass rdf:type rdf:Property ;
    rdfs:label 'Cdl Class' ;
    rdfs:comment 'For CDL certifications, the license class indicating the type and weight of vehicle the driver is authorized to operate. Class A: combination vehicles over 26,001 lbs; Class B: heavy straight vehicles over 26,001 lbs; Class C: vehicles designed to transport 16+ passengers or hazmat.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationNumber rdf:type rdf:Property ;
    rdfs:label 'Certification Number' ;
    rdfs:comment 'The unique certificate or license number issued by the certifying body. Examples include CDL number, HAZWOPER certificate number, OSHA card number.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationStatus rdf:type rdf:Property ;
    rdfs:label 'Certification Status' ;
    rdfs:comment 'Current lifecycle status of the certification. Active indicates valid and in good standing; Expired indicates past expiration date; Suspended or Revoked indicates regulatory action; Pending Renewal indicates renewal process initiated.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationType rdf:type rdf:Property ;
    rdfs:label 'Certification Type' ;
    rdfs:comment 'The category of training or certification. Includes Commercial Driver License (CDL), Hazardous Waste Operations and Emergency Response (HAZWOPER) 40-hour initial and 8-hour refresher, Department of Transportation (DOT) hazmat transport, Occupational Safety and Health Administration (OSHA) 10-hour and 30-hour safety, confined space entry, forklift operator, Environmental Protection Agency (EPA) Risk Management Plan (RMP), and ISO 14001/45001 internal auditor certifications. [ENUM-REF-CANDIDATE: CDL|HAZWOPER_40HR|HAZWOPER_8HR_REFRESHER|DOT_HAZMAT|OSHA_10HR|OSHA_30HR|CONFINED_SPACE|FORKLIFT_OPERATOR|EPA_RMP|ISO_14001_AUDITOR|ISO_45001_AUDITOR|FIRST_AID_CPR — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Requirement Flag' ;
    rdfs:comment 'Indicates whether this certification is a mandatory regulatory or company compliance requirement for the employees role. True for required certifications (e.g., CDL for drivers, HAZWOPER for hazmat handlers); False for optional professional development.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:endorsementCodes rdf:type rdf:Property ;
    rdfs:label 'Endorsement Codes' ;
    rdfs:comment 'For CDL certifications, the endorsement codes indicating specialized vehicle or cargo authorization. Examples: H (Hazardous Materials), N (Tank Vehicle), T (Double/Triple Trailers), P (Passenger). Pipe-separated if multiple endorsements.' ;
    rdfs:domain ind:TrainingCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instructorName rdf:type rdf:Property ;
    rdfs:label 'Instructor Name' ;
    rdfs:comment 'The name of the instructor or trainer who conducted the training session, if applicable.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingBody rdf:type rdf:Property ;
    rdfs:label 'Issuing Body' ;
    rdfs:comment 'The organization or regulatory authority that issued the certification. Examples include state Department of Motor Vehicles (DMV), OSHA Training Institute Education Centers, EPA-approved training providers, ISO registrars.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingState rdf:type rdf:Property ;
    rdfs:label 'Issuing State' ;
    rdfs:comment 'For state-issued certifications (e.g., CDL), the two-letter state code of the issuing jurisdiction. Examples: TX, CA, IL, NY.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passFailStatus rdf:type rdf:Property ;
    rdfs:label 'Pass Fail Status' ;
    rdfs:comment 'Indicates whether the employee passed, failed, is currently in progress, or did not complete the certification assessment.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Renewal Frequency Months' ;
    rdfs:comment 'The number of months between required renewals. Examples: 12 months for HAZWOPER refresher, 24 months for First Aid/CPR, 60 months for CDL renewal. Null if no renewal required.' ;
    rdfs:domain ind:TrainingCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:renewalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Renewal Required Flag' ;
    rdfs:comment 'Indicates whether this certification requires periodic renewal. True for CDL, HAZWOPER refresher, DOT hazmat; False for one-time certifications.' ;
    rdfs:domain ind:TrainingCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:restrictionCodes rdf:type rdf:Property ;
    rdfs:label 'Restriction Codes' ;
    rdfs:comment 'For CDL certifications, the restriction codes limiting driving privileges. Examples: L (No Air Brake Equipped CMV), Z (No Full Air Brake Equipped CMV), E (No Manual Transmission). Pipe-separated if multiple restrictions.' ;
    rdfs:domain ind:TrainingCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:score rdf:type rdf:Property ;
    rdfs:label 'Score' ;
    rdfs:comment 'The numerical score or percentage achieved on the certification exam or assessment, if applicable. Null for certifications without scored assessments.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingDeliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Training Delivery Method' ;
    rdfs:comment 'The method by which the training was delivered. In-person classroom, online e-learning, blended (combination), or on-the-job practical training.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingHours rdf:type rdf:Property ;
    rdfs:label 'Training Hours' ;
    rdfs:comment 'The total number of instructional hours completed for this certification. Examples: 40 hours for HAZWOPER initial, 8 hours for HAZWOPER refresher, 10 or 30 hours for OSHA safety training.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingLocation rdf:type rdf:Property ;
    rdfs:label 'Training Location' ;
    rdfs:comment 'The physical location or facility where the training was conducted. May be a Waste Management facility, training center, or external provider location. Null for online training.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByRequirementTrainingRequirementId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Requirement Training Requirement Id' ;
    rdfs:comment 'Reference to the training_requirement_id that replaces this requirement when regulatory standards change or training programs are updated. Null if not superseded.' ;
    rdfs:domain ind:TrainingRequirement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TrainingRequirement .

ind:accreditationBody rdf:type rdf:Property ;
    rdfs:label 'Accreditation Body' ;
    rdfs:comment 'Name of the organization that must accredit the training provider (e.g., OSHA, EPA, State DMV, IACET, ANSI). Null if no specific accreditation required.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableFacilityTypes rdf:type rdf:Property ;
    rdfs:label 'Applicable Facility Types' ;
    rdfs:comment 'Comma-separated list or description of facility types where this training is mandatory (e.g., Landfill, MRF, TSDF, Transfer Station, WTE Facility, Fleet Maintenance Yard, Hazardous Waste Storage).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableJobRoles rdf:type rdf:Property ;
    rdfs:label 'Applicable Job Roles' ;
    rdfs:comment 'Comma-separated list or description of job roles/positions to which this training requirement applies (e.g., CDL Driver, Hazmat Handler, MRF Sorter, Landfill Operator, Maintenance Technician, Environmental Compliance Manager).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessJustification rdf:type rdf:Property ;
    rdfs:label 'Business Justification' ;
    rdfs:comment 'Narrative explanation of why this training is required, including regulatory mandate, risk mitigation, operational necessity, or industry best practice rationale.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Certification Required Flag' ;
    rdfs:comment 'Indicates whether successful completion must result in a formal certification or credential (True) or if attendance/completion record is sufficient (False).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:competencyAssessmentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Competency Assessment Required Flag' ;
    rdfs:comment 'Indicates whether a formal competency assessment (exam, practical demonstration, skills test) is required in addition to training attendance.' ;
    rdfs:domain ind:TrainingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costEstimateUsd rdf:type rdf:Property ;
    rdfs:label 'Cost Estimate Usd' ;
    rdfs:comment 'Estimated cost per employee to complete this training requirement, including tuition, materials, travel, and lost productivity. Used for compliance budget planning.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:createdByUser rdf:type rdf:Property ;
    rdfs:label 'Created By User' ;
    rdfs:comment 'Username or identifier of the person who created this training requirement record.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentationRetentionYears rdf:type rdf:Property ;
    rdfs:label 'Documentation Retention Years' ;
    rdfs:comment 'Minimum number of years training records must be retained to satisfy regulatory and audit requirements (e.g., OSHA requires 3 years for most training, EPA RCRA requires duration of employment plus 3 years).' ;
    rdfs:domain ind:TrainingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:frequencyIntervalMonths rdf:type rdf:Property ;
    rdfs:label 'Frequency Interval Months' ;
    rdfs:comment 'Number of months between required training completions for recurring requirements. Null for one-time or event-driven training.' ;
    rdfs:domain ind:TrainingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:frequencyType rdf:type rdf:Property ;
    rdfs:label 'Frequency Type' ;
    rdfs:comment 'Recurrence pattern for the training requirement (e.g., initial upon hire, annual refresher, triennial recertification, event-driven upon role change). [ENUM-REF-CANDIDATE: initial|annual|biennial|triennial|quinquennial|one_time|event_driven — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iso14001CompetenceFlag rdf:type rdf:Property ;
    rdfs:label 'Iso 14001 Competence Flag' ;
    rdfs:comment 'Indicates whether this training requirement is part of the ISO 14001 Environmental Management System competence framework.' ;
    rdfs:domain ind:TrainingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iso45001CompetenceFlag rdf:type rdf:Property ;
    rdfs:label 'Iso 45001 Competence Flag' ;
    rdfs:comment 'Indicates whether this training requirement is part of the ISO 45001 Occupational Health and Safety Management System competence framework.' ;
    rdfs:domain ind:TrainingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:languageRequirements rdf:type rdf:Property ;
    rdfs:label 'Language Requirements' ;
    rdfs:comment 'Languages in which training must be available to ensure comprehension by all applicable employees (e.g., English, Spanish). OSHA requires training in language understood by employee.' ;
    rdfs:domain ind:TrainingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Last Modified By User' ;
    rdfs:comment 'Username or identifier of the person who last modified this training requirement record.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumPassingScorePercent rdf:type rdf:Property ;
    rdfs:label 'Minimum Passing Score Percent' ;
    rdfs:comment 'Minimum percentage score required on competency assessment to satisfy the training requirement. Null if no assessment or no minimum score defined.' ;
    rdfs:domain ind:TrainingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumTrainingHours rdf:type rdf:Property ;
    rdfs:label 'Minimum Training Hours' ;
    rdfs:comment 'Minimum contact hours required to satisfy the training obligation (e.g., 40 hours for HAZWOPER initial, 8 hours for annual refresher, 10 hours for OSHA General Industry).' ;
    rdfs:domain ind:TrainingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prerequisiteTrainingCodes rdf:type rdf:Property ;
    rdfs:label 'Prerequisite Training Codes' ;
    rdfs:comment 'Comma-separated list of training_type_code values that must be completed before this training can be taken (e.g., HAZWOPER_40HR must precede HAZWOPER_SUPERVISOR).' ;
    rdfs:domain ind:TrainingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requirementStatus rdf:type rdf:Property ;
    rdfs:label 'Requirement Status' ;
    rdfs:comment 'Current lifecycle state of the training requirement. Active requirements are enforced in compliance gap analysis.' ;
    rdfs:domain ind:TrainingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPartyCertificationFlag rdf:type rdf:Property ;
    rdfs:label 'Third Party Certification Flag' ;
    rdfs:comment 'Indicates whether the certification must be issued by an external accredited body (True) or can be issued internally (False). Examples: CDL requires state DMV, HAZWOPER may require accredited training provider.' ;
    rdfs:domain ind:TrainingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trainingCategory rdf:type rdf:Property ;
    rdfs:label 'Training Category' ;
    rdfs:comment 'High-level classification of the training requirement domain.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingDeliveryMethods rdf:type rdf:Property ;
    rdfs:label 'Training Delivery Methods' ;
    rdfs:comment 'Comma-separated list of acceptable delivery formats (e.g., classroom, online, blended, hands-on, on-the-job, simulator). Some regulatory training may restrict delivery methods.' ;
    rdfs:domain ind:TrainingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingName rdf:type rdf:Property ;
    rdfs:label 'Training Name' ;
    rdfs:comment 'Full descriptive name of the training program (e.g., 40-Hour HAZWOPER Initial Training, Commercial Driver License Class A Certification, OSHA 10-Hour General Industry Safety).' ;
    rdfs:domain ind:TrainingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingProviderType rdf:type rdf:Property ;
    rdfs:label 'Training Provider Type' ;
    rdfs:comment 'Classification of acceptable training provider sources for this requirement.' ;
    rdfs:domain ind:TrainingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingTypeCode rdf:type rdf:Property ;
    rdfs:label 'Training Type Code' ;
    rdfs:comment 'Standardized code identifying the specific training program (e.g., HAZWOPER_40HR, CDL_CLASS_A, OSHA_10HR, DOT_HAZMAT, RCRA_HANDLER, CONFINED_SPACE, FORKLIFT_CERT).' ;
    rdfs:domain ind:TrainingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyOffice rdf:type rdf:Property ;
    rdfs:label 'Agency Office' ;
    rdfs:comment 'Specific office, region, or district within the issuing agency responsible for the enforcement action.' ;
    rdfs:domain ind:ViolationNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appealFiledDate rdf:type rdf:Property ;
    rdfs:label 'Appeal Filed Date' ;
    rdfs:comment 'Date on which the company filed a formal appeal or contest of the violation notice.' ;
    rdfs:domain ind:ViolationNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:appealFiledFlag rdf:type rdf:Property ;
    rdfs:label 'Appeal Filed Flag' ;
    rdfs:comment 'Indicates whether the company filed a formal appeal or contested the violation notice with the regulatory agency or administrative law body.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appealOutcome rdf:type rdf:Property ;
    rdfs:label 'Appeal Outcome' ;
    rdfs:comment 'Final outcome of the appeal process, if an appeal was filed.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalCounselAssigned rdf:type rdf:Property ;
    rdfs:label 'Legal Counsel Assigned' ;
    rdfs:comment 'Name of the internal or external legal counsel assigned to manage the violation notice and enforcement action.' ;
    rdfs:domain ind:ViolationNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noticeIssuedDate rdf:type rdf:Property ;
    rdfs:label 'Notice Issued Date' ;
    rdfs:comment 'Date on which the regulatory agency officially issued the notice of violation to the company.' ;
    rdfs:domain ind:ViolationNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:noticeNumber rdf:type rdf:Property ;
    rdfs:label 'Notice Number' ;
    rdfs:comment 'Official notice number assigned by the issuing regulatory agency. This is the externally-known identifier for the enforcement action.' ;
    rdfs:domain ind:ViolationNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noticeReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Notice Received Date' ;
    rdfs:comment 'Date on which the company received the violation notice from the regulatory agency.' ;
    rdfs:domain ind:ViolationNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:noticeType rdf:type rdf:Property ;
    rdfs:label 'Notice Type' ;
    rdfs:comment 'Classification of the enforcement action type issued by the regulatory agency.' ;
    rdfs:domain ind:ViolationNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyAssessedAmount rdf:type rdf:Property ;
    rdfs:label 'Penalty Assessed Amount' ;
    rdfs:comment 'Monetary penalty amount assessed by the regulatory agency for the violation, in USD.' ;
    rdfs:domain ind:ViolationNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyPaidAmount rdf:type rdf:Property ;
    rdfs:label 'Penalty Paid Amount' ;
    rdfs:comment 'Actual monetary penalty amount paid by the company to the regulatory agency, in USD. May differ from assessed amount due to settlement or negotiation.' ;
    rdfs:domain ind:ViolationNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Penalty Payment Date' ;
    rdfs:comment 'Date on which the penalty payment was made to the regulatory agency.' ;
    rdfs:domain ind:ViolationNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:publicDisclosureFlag rdf:type rdf:Property ;
    rdfs:label 'Public Disclosure Flag' ;
    rdfs:comment 'Indicates whether the violation notice is subject to public disclosure or has been publicly reported by the regulatory agency.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responseDueDate rdf:type rdf:Property ;
    rdfs:label 'Response Due Date' ;
    rdfs:comment 'Deadline by which the company must submit a formal response or corrective action plan to the regulatory agency.' ;
    rdfs:domain ind:ViolationNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responseSubmittedDate rdf:type rdf:Property ;
    rdfs:label 'Response Submitted Date' ;
    rdfs:comment 'Date on which the company submitted its formal response or corrective action plan to the regulatory agency.' ;
    rdfs:domain ind:ViolationNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:settlementAgreementFlag rdf:type rdf:Property ;
    rdfs:label 'Settlement Agreement Flag' ;
    rdfs:comment 'Indicates whether the violation was resolved through a formal settlement agreement or consent decree with the regulatory agency.' ;
    rdfs:domain ind:ViolationNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:settlementAgreementNumber rdf:type rdf:Property ;
    rdfs:label 'Settlement Agreement Number' ;
    rdfs:comment 'Official reference number or identifier for the settlement agreement or consent decree, if applicable.' ;
    rdfs:domain ind:ViolationNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationCategory rdf:type rdf:Property ;
    rdfs:label 'Violation Category' ;
    rdfs:comment 'High-level classification of the violation type based on the environmental, health, or safety domain. [ENUM-REF-CANDIDATE: air_quality|water_quality|waste_management|hazardous_materials|occupational_safety|transportation|permit_compliance|reporting — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationDate rdf:type rdf:Property ;
    rdfs:label 'Violation Date' ;
    rdfs:comment 'Date on which the violation or non-compliance event occurred as documented by the regulatory agency.' ;
    rdfs:domain ind:ViolationNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:violationDescription rdf:type rdf:Property ;
    rdfs:label 'Violation Description' ;
    rdfs:comment 'Detailed narrative description of the violation, non-compliance event, or deficiency as documented in the notice.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationSeverity rdf:type rdf:Property ;
    rdfs:label 'Violation Severity' ;
    rdfs:comment 'Severity level of the violation as assessed by the regulatory agency or internal EHS team.' ;
    rdfs:domain ind:ViolationNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationStatus rdf:type rdf:Property ;
    rdfs:label 'Violation Status' ;
    rdfs:comment 'Current lifecycle status of the violation notice and enforcement action. [ENUM-REF-CANDIDATE: open|under_review|response_submitted|resolved|settled|appealed|closed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ViolationNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementTypeId rdf:type rdf:Property ;
    rdfs:label 'Agreement Type Id' ;
    rdfs:comment 'Unique identifier for the agreement type reference record. Primary key.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AgreementType .

ind:activeFlag rdf:type rdf:Property ;
    rdfs:label 'Active Flag' ;
    rdfs:comment 'Indicates whether this agreement type is currently active and available for new contract creation. Inactive types are retained for historical reference but not used for new agreements.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:allowsEarlyTermination rdf:type rdf:Property ;
    rdfs:label 'Allows Early Termination' ;
    rdfs:comment 'Indicates whether agreements of this type permit early termination by either party, typically subject to notice periods and potential penalties.' ;
    rdfs:domain ind:AgreementType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:amendmentApprovalLevel rdf:type rdf:Property ;
    rdfs:label 'Amendment Approval Level' ;
    rdfs:comment 'Organizational approval authority level required to amend or modify agreements of this type. Drives contract workflow routing in Salesforce CRM.' ;
    rdfs:domain ind:AgreementType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoRenewalEligible rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Eligible' ;
    rdfs:comment 'Indicates whether agreements of this type are eligible for automatic renewal upon expiration, subject to notice periods and customer consent.' ;
    rdfs:domain ind:AgreementType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceFramework rdf:type rdf:Property ;
    rdfs:label 'Compliance Framework' ;
    rdfs:comment 'Primary regulatory compliance framework governing agreements of this type (e.g., RCRA for hazardous waste, local franchise ordinances for MSW, CERCLA for remediation contracts).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractDurationType rdf:type rdf:Property ;
    rdfs:label 'Contract Duration Type' ;
    rdfs:comment 'Typical duration classification for agreements of this type. Short-term (under 1 year), long-term (multi-year), evergreen (auto-renewing), project-based (tied to specific project completion), or indefinite (no fixed end date).' ;
    rdfs:domain ind:AgreementType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultBillingFrequency rdf:type rdf:Property ;
    rdfs:label 'Default Billing Frequency' ;
    rdfs:comment 'Standard billing cycle frequency for agreements of this type. Drives invoice generation scheduling in Oracle Revenue Management.' ;
    rdfs:domain ind:AgreementType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultTermMonths rdf:type rdf:Property ;
    rdfs:label 'Default Term Months' ;
    rdfs:comment 'Standard initial contract term length in months for agreements of this type. Null if term is project-based or indefinite.' ;
    rdfs:domain ind:AgreementType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hazmatClassificationRequired rdf:type rdf:Property ;
    rdfs:label 'Hazmat Classification Required' ;
    rdfs:comment 'Indicates whether agreements of this type require hazardous material classification and manifest tracking per Resource Conservation and Recovery Act (RCRA) and Department of Transportation (DOT) regulations.' ;
    rdfs:domain ind:AgreementType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresFranchiseApproval rdf:type rdf:Property ;
    rdfs:label 'Requires Franchise Approval' ;
    rdfs:comment 'Indicates whether agreements of this type require municipal or local government franchise approval before execution. Critical for Municipal Solid Waste (MSW) franchise agreements.' ;
    rdfs:domain ind:AgreementType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresInsuranceCertificate rdf:type rdf:Property ;
    rdfs:label 'Requires Insurance Certificate' ;
    rdfs:comment 'Indicates whether agreements of this type require the service provider to maintain and provide proof of general liability, environmental liability, and workers compensation insurance.' ;
    rdfs:domain ind:AgreementType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresPerformanceBond rdf:type rdf:Property ;
    rdfs:label 'Requires Performance Bond' ;
    rdfs:comment 'Indicates whether agreements of this type require the service provider to post a performance bond or financial guarantee to ensure contract obligations are met. Common for municipal franchise agreements.' ;
    rdfs:domain ind:AgreementType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresPermit rdf:type rdf:Property ;
    rdfs:label 'Requires Permit' ;
    rdfs:comment 'Indicates whether this agreement type requires an active operating permit (e.g., Resource Conservation and Recovery Act (RCRA) permit for hazardous waste, landfill operating permit, Treatment Storage and Disposal Facility (TSDF) permit).' ;
    rdfs:domain ind:AgreementType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceCategory rdf:type rdf:Property ;
    rdfs:label 'Service Category' ;
    rdfs:comment 'High-level service category that this agreement type supports. Aligns with core business process segmentation for routing, billing, and compliance workflows.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTemplateRequired rdf:type rdf:Property ;
    rdfs:label 'Sla Template Required' ;
    rdfs:comment 'Indicates whether agreements of this type must include a formal Service Level Agreement (SLA) defining performance obligations, response times, and service quality metrics.' ;
    rdfs:domain ind:AgreementType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsRateEscalation rdf:type rdf:Property ;
    rdfs:label 'Supports Rate Escalation' ;
    rdfs:comment 'Indicates whether agreements of this type typically include automatic rate escalation clauses tied to Consumer Price Index (CPI), fuel surcharges, or other economic indices.' ;
    rdfs:domain ind:AgreementType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:terminationNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Termination Notice Days' ;
    rdfs:comment 'Standard advance notice period in days required for either party to terminate agreements of this type without cause. Null if termination is not permitted or requires cause.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:typeCode rdf:type rdf:Property ;
    rdfs:label 'Type Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the agreement type (e.g., MSW_FRAN, COMM_HAUL, ROLLOFF, HAZ_DISP). Used as business key in operational systems and contract workflows.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:typeDescription rdf:type rdf:Property ;
    rdfs:label 'Type Description' ;
    rdfs:comment 'Detailed business description of the agreement type, including scope of services, typical customer segments, and operational characteristics.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:typeName rdf:type rdf:Property ;
    rdfs:label 'Type Name' ;
    rdfs:comment 'Full descriptive name of the agreement type (e.g., Municipal Solid Waste Franchise Agreement, Commercial Hauling Contract, Roll-Off Disposal Agreement, Hazardous Waste Treatment Storage and Disposal Facility Agreement).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentId rdf:type rdf:Property ;
    rdfs:label 'Amendment Id' ;
    rdfs:comment 'Unique identifier for the contract amendment record. Primary key.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Amendment .

ind:documentId rdf:type rdf:Property ;
    rdfs:label 'Document Id' ;
    rdfs:comment 'Foreign key linking to contract.document. Business justification: Amendments are formal contract modifications that generate legal documents tracked in the document product. Currently amendment.document_reference is a STRING field - this should be normalized to a pr' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Document .

ind:supersededByAmendmentId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Amendment Id' ;
    rdfs:comment 'Reference to a subsequent amendment that supersedes or replaces this amendment. Null if this is the current active amendment.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Amendment .

ind:amendmentDescription rdf:type rdf:Property ;
    rdfs:label 'Amendment Description' ;
    rdfs:comment 'Detailed narrative description of the changes being made to the contract, including business rationale and scope of modifications.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentNumber rdf:type rdf:Property ;
    rdfs:label 'Amendment Number' ;
    rdfs:comment 'Business identifier for the amendment, typically sequential or hierarchical (e.g., A-001, A-002). Used for external reference and tracking.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentStatus rdf:type rdf:Property ;
    rdfs:label 'Amendment Status' ;
    rdfs:comment 'Current lifecycle status of the amendment in the approval and execution workflow. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|rejected|executed|cancelled|superseded — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentType rdf:type rdf:Property ;
    rdfs:label 'Amendment Type' ;
    rdfs:comment 'Classification of the amendment based on the nature of the change being made to the contract. [ENUM-REF-CANDIDATE: scope_change|rate_adjustment|service_addition|service_removal|term_extension|sla_revision|pricing_structure_change|volume_adjustment|equipment_change|other — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedDate rdf:type rdf:Property ;
    rdfs:label 'Approved Date' ;
    rdfs:comment 'Date when the amendment received final approval and was authorized for execution.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customerSignatureRequired rdf:type rdf:Property ;
    rdfs:label 'Customer Signature Required' ;
    rdfs:comment 'Indicates whether customer signature is required for this amendment to be legally binding.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerSignedDate rdf:type rdf:Property ;
    rdfs:label 'Customer Signed Date' ;
    rdfs:comment 'Date when the customer signed the amendment, if customer signature was required.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:executedDate rdf:type rdf:Property ;
    rdfs:label 'Executed Date' ;
    rdfs:comment 'Date when the amendment was formally executed or signed by all parties.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:financialImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Amount' ;
    rdfs:comment 'Estimated total financial impact of the amendment over its effective period. Positive for revenue increases, negative for decreases.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:legalReviewRequired rdf:type rdf:Property ;
    rdfs:label 'Legal Review Required' ;
    rdfs:comment 'Indicates whether legal department review and approval is required for this amendment based on materiality thresholds.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalReviewedBy rdf:type rdf:Property ;
    rdfs:label 'Legal Reviewed By' ;
    rdfs:comment 'Name or identifier of the legal counsel who reviewed the amendment, if legal review was required.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalReviewedDate rdf:type rdf:Property ;
    rdfs:label 'Legal Reviewed Date' ;
    rdfs:comment 'Date when legal review was completed and the amendment was cleared by legal counsel.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rateChangeAmount rdf:type rdf:Property ;
    rdfs:label 'Rate Change Amount' ;
    rdfs:comment 'Monetary value of rate adjustment if the amendment involves pricing changes. Positive for increases, negative for decreases.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateChangePercentage rdf:type rdf:Property ;
    rdfs:label 'Rate Change Percentage' ;
    rdfs:comment 'Percentage change in rates if the amendment involves pricing adjustments. Expressed as a decimal (e.g., 5.00 for 5%).' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requestedBy rdf:type rdf:Property ;
    rdfs:label 'Requested By' ;
    rdfs:comment 'Name or identifier of the individual or department who initiated the amendment request.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedDate rdf:type rdf:Property ;
    rdfs:label 'Requested Date' ;
    rdfs:comment 'Date when the amendment was formally requested or initiated in the system.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scopeChangeDescription rdf:type rdf:Property ;
    rdfs:label 'Scope Change Description' ;
    rdfs:comment 'Detailed description of changes to the scope of services, including additions, removals, or modifications to service offerings.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceLevelChangeDescription rdf:type rdf:Property ;
    rdfs:label 'Service Level Change Description' ;
    rdfs:comment 'Detailed description of changes to service level commitments, performance obligations, or SLA metrics.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termExtensionMonths rdf:type rdf:Property ;
    rdfs:label 'Term Extension Months' ;
    rdfs:comment 'Number of months by which the contract term is extended, if applicable. Null if amendment does not affect contract duration.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:billingTermId rdf:type rdf:Property ;
    rdfs:label 'Billing Term Id' ;
    rdfs:comment 'Unique identifier for the billing term record. Primary key.' ;
    rdfs:domain ind:BillingTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:acceptedPaymentMethods rdf:type rdf:Property ;
    rdfs:label 'Accepted Payment Methods' ;
    rdfs:comment 'Comma-separated list of payment methods accepted under this billing term (e.g., \'check, ACH, credit_card, wire_transfer\'). Defines customer payment options.' ;
    rdfs:domain ind:BillingTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoPayEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Pay Enabled' ;
    rdfs:comment 'Indicates whether automatic payment processing is enabled for this billing term. True if customer has authorized automatic payment deduction.' ;
    rdfs:domain ind:BillingTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:billingCycleDay rdf:type rdf:Property ;
    rdfs:label 'Billing Cycle Day' ;
    rdfs:comment 'Day of the month when the billing cycle closes and invoice is generated (e.g., 1 for first of month, 15 for mid-month). Null for event-based billing.' ;
    rdfs:domain ind:BillingTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:billingTermStatus rdf:type rdf:Property ;
    rdfs:label 'Billing Term Status' ;
    rdfs:comment 'Current lifecycle status of the billing term configuration. Active terms are in use for billing operations.' ;
    rdfs:domain ind:BillingTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountTerms rdf:type rdf:Property ;
    rdfs:label 'Discount Terms' ;
    rdfs:comment 'Early payment discount terms (e.g., \'2/10 Net 30\' means 2% discount if paid within 10 days, otherwise net 30). Null if no early payment discount applies.' ;
    rdfs:domain ind:BillingTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dunningProcedure rdf:type rdf:Property ;
    rdfs:label 'Dunning Procedure' ;
    rdfs:comment 'Collections procedure applied for overdue invoices. Defines escalation steps and timing for collection actions.' ;
    rdfs:domain ind:BillingTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:electronicInvoiceFormat rdf:type rdf:Property ;
    rdfs:label 'Electronic Invoice Format' ;
    rdfs:comment 'File format for electronic invoice delivery. EDI 810 is the standard Electronic Data Interchange (EDI) invoice transaction set.' ;
    rdfs:domain ind:BillingTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceConsolidation rdf:type rdf:Property ;
    rdfs:label 'Invoice Consolidation' ;
    rdfs:comment 'Indicates whether multiple service charges should be consolidated into a single invoice. True for consolidated billing, False for separate invoices per service.' ;
    rdfs:domain ind:BillingTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:latePaymentPenaltyRate rdf:type rdf:Property ;
    rdfs:label 'Late Payment Penalty Rate' ;
    rdfs:comment 'Percentage rate applied to overdue balances as a late payment penalty. Expressed as annual percentage rate (APR). Null if no late fees apply.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumInvoiceAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Invoice Amount' ;
    rdfs:comment 'Minimum monetary amount required to generate an invoice. Charges below this threshold may be carried forward to next billing cycle. Null if no minimum applies.' ;
    rdfs:domain ind:BillingTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentDueDay rdf:type rdf:Property ;
    rdfs:label 'Payment Due Day' ;
    rdfs:comment 'Specific day of the month when payment is due, if applicable. Used for fixed-date payment schedules (e.g., payment always due on the 15th of the month).' ;
    rdfs:domain ind:BillingTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:prorationAllowed rdf:type rdf:Property ;
    rdfs:label 'Proration Allowed' ;
    rdfs:comment 'Indicates whether charges can be prorated for partial billing periods (e.g., mid-cycle service start or termination). True if proration is permitted.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:securityDepositAmount rdf:type rdf:Property ;
    rdfs:label 'Security Deposit Amount' ;
    rdfs:comment 'Monetary amount of the security deposit required, if applicable. Null if no deposit is required.' ;
    rdfs:domain ind:BillingTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:securityDepositRequired rdf:type rdf:Property ;
    rdfs:label 'Security Deposit Required' ;
    rdfs:comment 'Indicates whether a security deposit is required under this billing term. True if deposit is mandatory, False otherwise.' ;
    rdfs:domain ind:BillingTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:statementFrequency rdf:type rdf:Property ;
    rdfs:label 'Statement Frequency' ;
    rdfs:comment 'Frequency at which account statements are generated and sent to the customer. Separate from invoice frequency.' ;
    rdfs:domain ind:BillingTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExempt rdf:type rdf:Property ;
    rdfs:label 'Tax Exempt' ;
    rdfs:comment 'Indicates whether the customer is exempt from sales tax under this billing term. True if tax-exempt status applies.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:termCode rdf:type rdf:Property ;
    rdfs:label 'Term Code' ;
    rdfs:comment 'Unique business identifier code for the billing term configuration. Used for external reference and integration with Oracle Revenue Management.' ;
    rdfs:domain ind:BillingTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termName rdf:type rdf:Property ;
    rdfs:label 'Term Name' ;
    rdfs:comment 'Human-readable name describing the billing term arrangement (e.g., \'Monthly Net 30\', \'Quarterly Prepaid\', \'Per-Service Event\').' ;
    rdfs:domain ind:BillingTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceObligationId rdf:type rdf:Property ;
    rdfs:label 'Compliance Obligation Id' ;
    rdfs:comment 'Primary key for compliance_obligation' ;
    rdfs:domain ind:ComplianceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wasteGeneratorProfileId rdf:type rdf:Property ;
    rdfs:label 'Waste Generator Profile Id' ;
    rdfs:comment 'Foreign key linking to customer.waste_generator_profile. Business justification: Compliance obligations (manifest requirements, EPA biennial reports, RCRA notifications) are driven by generator profile classification (LQG/SQG/CESQG). Linking enables automated compliance tracking, ' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WasteGeneratorProfile .

ind:contractClauseReference rdf:type rdf:Property ;
    rdfs:label 'Contract Clause Reference' ;
    rdfs:comment 'Specific contract section, clause, or exhibit number that defines this obligation (e.g., Section 7.3, Exhibit B, Schedule 2).' ;
    rdfs:domain ind:ComplianceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationProcedure rdf:type rdf:Property ;
    rdfs:label 'Escalation Procedure' ;
    rdfs:comment 'Process for escalating non-compliance issues, including notification chain and remediation steps.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingRegulation rdf:type rdf:Property ;
    rdfs:label 'Governing Regulation' ;
    rdfs:comment 'The specific regulation, statute, or standard that mandates this obligation (e.g., RCRA Subtitle D, Clean Air Act Section 111, ISO 14001:2015, Municipal Code Section 8.40).' ;
    rdfs:domain ind:ComplianceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAuditDate rdf:type rdf:Property ;
    rdfs:label 'Last Audit Date' ;
    rdfs:comment 'Date of the most recent audit or compliance review for this obligation.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastAuditResult rdf:type rdf:Property ;
    rdfs:label 'Last Audit Result' ;
    rdfs:comment 'Outcome of the most recent audit: passed (compliant), failed (non-compliant), conditional (compliant with corrective actions), or not_audited.' ;
    rdfs:domain ind:ComplianceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastComplianceDate rdf:type rdf:Property ;
    rdfs:label 'Last Compliance Date' ;
    rdfs:comment 'Date when the obligation was last successfully fulfilled or reported.' ;
    rdfs:domain ind:ComplianceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measurementMethodology rdf:type rdf:Property ;
    rdfs:label 'Measurement Methodology' ;
    rdfs:comment 'Description of how compliance is measured and verified (e.g., monthly tonnage reports, third-party audit, GPS tracking data, manifest counts, emissions calculations per EPA Method 25).' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Due Date' ;
    rdfs:comment 'Next scheduled date by which the obligation must be fulfilled or reported.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:obligationCategory rdf:type rdf:Property ;
    rdfs:label 'Obligation Category' ;
    rdfs:comment 'Functional category of the obligation: reporting (periodic submissions), manifest submission (hazardous waste tracking), diversion rate (waste reduction targets), emissions (GHG/air quality), safety (OSHA standards), performance (SLA metrics), financial (bonding/insurance), or operational (service delivery standards). [ENUM-REF-CANDIDATE: reporting|manifest_submission|diversion_rate|emissions|safety|performance|financial|operational — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ComplianceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyForNonCompliance rdf:type rdf:Property ;
    rdfs:label 'Penalty For Non Compliance' ;
    rdfs:comment 'Description of penalties, fines, or consequences for failing to meet the obligation (e.g., monetary fine, contract termination, permit suspension, liquidated damages).' ;
    rdfs:domain ind:ComplianceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionRecipient rdf:type rdf:Property ;
    rdfs:label 'Submission Recipient' ;
    rdfs:comment 'Entity or system to which compliance documentation must be submitted (e.g., EPA Regional Office, State Environmental Agency, Customer Contract Manager, SWIS Portal).' ;
    rdfs:domain ind:ComplianceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetMetric rdf:type rdf:Property ;
    rdfs:label 'Target Metric' ;
    rdfs:comment 'Specific performance metric or KPI that must be achieved (e.g., 50% diversion rate, 95% on-time service, zero OSHA recordables, GHG reduction of 10%).' ;
    rdfs:domain ind:ComplianceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Target Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the target value (e.g., percentage, tons, days, incidents, CO2e metric tons).' ;
    rdfs:domain ind:ComplianceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetValue rdf:type rdf:Property ;
    rdfs:label 'Target Value' ;
    rdfs:comment 'Numeric target value for the performance metric (e.g., 50.00 for 50% diversion rate, 95.00 for 95% on-time).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waiverExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Waiver Expiration Date' ;
    rdfs:comment 'Date when the granted waiver expires and the obligation resumes, if applicable.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:waiverGranted rdf:type rdf:Property ;
    rdfs:label 'Waiver Granted' ;
    rdfs:comment 'Indicates whether a temporary waiver or exemption from this obligation has been granted.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waiverReason rdf:type rdf:Property ;
    rdfs:label 'Waiver Reason' ;
    rdfs:comment 'Justification or reason for granting the waiver (e.g., force majeure, regulatory change, operational constraints).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingRegulatoryRequirementId rdf:type rdf:Property ;
    rdfs:label 'Governing Regulatory Requirement Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_requirement. Business justification: Master service agreements reference applicable regulatory frameworks (RCRA, Clean Air Act, state environmental codes) governing service delivery. Links contracts to primary regulatory drivers, essenti' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryRequirement .

ind:parentAgreementContractId rdf:type rdf:Property ;
    rdfs:label 'Parent Agreement Contract Id' ;
    rdfs:comment 'Identifier of the master or umbrella agreement under which this contract is subordinated. Used for multi-site or multi-service contract hierarchies. Nullable for standalone contracts.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contract .

ind:amendmentCount rdf:type rdf:Property ;
    rdfs:label 'Amendment Count' ;
    rdfs:comment 'Number of formal amendments executed against this contract since origination. Used to track contract change history and version control.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:annualEscalationPercentage rdf:type rdf:Property ;
    rdfs:label 'Annual Escalation Percentage' ;
    rdfs:comment 'Fixed percentage rate increase applied annually to the base service rate. Expressed as a percentage (e.g., 3.00 for 3% annual increase). Nullable if escalation is CPI-based or not applicable.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseServiceRate rdf:type rdf:Property ;
    rdfs:label 'Base Service Rate' ;
    rdfs:comment 'Primary recurring charge amount for the contracted service. Currency is USD unless otherwise specified in contract terms. Excludes variable charges, surcharges, and taxes.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractStatus rdf:type rdf:Property ;
    rdfs:label 'Contract Status' ;
    rdfs:comment 'Current lifecycle state of the contract. Draft for contracts under negotiation, Pending for signed but not yet effective, Active for in-force agreements, Suspended for temporarily paused contracts, Amended for contracts with modifications, Terminated for ended agreements.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:earlyTerminationPenalty rdf:type rdf:Property ;
    rdfs:label 'Early Termination Penalty' ;
    rdfs:comment 'Financial penalty amount charged if the customer terminates the contract before the expiration date. May be a fixed amount or calculated as a percentage of remaining contract value.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalComplianceRequirement rdf:type rdf:Property ;
    rdfs:label 'Environmental Compliance Requirement' ;
    rdfs:comment 'Description of environmental regulations and compliance obligations specified in the contract. May reference Resource Conservation and Recovery Act (RCRA), Clean Air Act (CAA), or state-specific environmental requirements.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forceMajeureClause rdf:type rdf:Property ;
    rdfs:label 'Force Majeure Clause' ;
    rdfs:comment 'Description of the circumstances (natural disasters, pandemics, war, government action) that excuse non-performance of contract obligations without penalty.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Governing Jurisdiction' ;
    rdfs:comment 'Legal jurisdiction whose laws govern the contract interpretation and dispute resolution. Typically a state or province code (e.g., TX, CA, ON) or country code for international contracts.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indemnificationClause rdf:type rdf:Property ;
    rdfs:label 'Indemnification Clause' ;
    rdfs:comment 'Description of the indemnification obligations where one party agrees to protect the other from specified liabilities, claims, or damages arising from contract performance.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceRequirement rdf:type rdf:Property ;
    rdfs:label 'Insurance Requirement' ;
    rdfs:comment 'Description of the insurance coverage types and minimum limits required under the contract. Typically includes general liability, auto liability, workers compensation, and environmental impairment liability.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAmendmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Amendment Date' ;
    rdfs:comment 'Date of the most recent contract amendment execution. Nullable if no amendments have been executed.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maximumTonnageLimit rdf:type rdf:Property ;
    rdfs:label 'Maximum Tonnage Limit' ;
    rdfs:comment 'Maximum volume of waste in tons that the facility or service provider will accept under the contract. Common in landfill disposal agreements. Nullable for unlimited contracts.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumTonnageCommitment rdf:type rdf:Property ;
    rdfs:label 'Minimum Tonnage Commitment' ;
    rdfs:comment 'Minimum volume of waste in tons that the customer commits to deliver under the contract term. Common in disposal and hauling agreements. Nullable for contracts without volume commitments.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ownerName rdf:type rdf:Property ;
    rdfs:label 'Owner Name' ;
    rdfs:comment 'Name of the Waste Management employee responsible for managing this contract relationship. Typically a sales representative, account manager, or municipal services manager.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceBondAmount rdf:type rdf:Property ;
    rdfs:label 'Performance Bond Amount' ;
    rdfs:comment 'Dollar amount of the performance bond required under the contract. Nullable if no bond is required.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceBondRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Performance Bond Required Flag' ;
    rdfs:comment 'Indicates whether the contract requires the service provider to post a performance bond to guarantee service delivery. Common in municipal and franchise agreements.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rateEscalationClause rdf:type rdf:Property ;
    rdfs:label 'Rate Escalation Clause' ;
    rdfs:comment 'Description of the pricing adjustment mechanism over the contract term. May reference Consumer Price Index (CPI), fixed percentage increases, or fuel surcharge formulas.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Notice Days' ;
    rdfs:comment 'Number of days prior to expiration that either party must provide notice to prevent auto-renewal or initiate renewal discussions. Typically 30, 60, or 90 days.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:salesforceOpportunityCode rdf:type rdf:Property ;
    rdfs:label 'Salesforce Opportunity Code' ;
    rdfs:comment 'Salesforce CRM opportunity identifier that originated this contract. Links contract to the sales pipeline and opportunity record for revenue attribution and sales performance tracking.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapContractNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Contract Number' ;
    rdfs:comment 'SAP S/4HANA Sales and Distribution (SD) module contract document number. Used for integration with SAP billing, order management, and financial accounting.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceLevelAgreement rdf:type rdf:Property ;
    rdfs:label 'Service Level Agreement' ;
    rdfs:comment 'Description of the performance obligations and service commitments defined in the contract. May include pickup frequency, response times, container delivery standards, and quality metrics.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signedDate rdf:type rdf:Property ;
    rdfs:label 'Signed Date' ;
    rdfs:comment 'Date when all parties executed the contract. Used for legal enforceability and contract lifecycle tracking. May differ from effective date.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:terminationClause rdf:type rdf:Property ;
    rdfs:label 'Termination Clause' ;
    rdfs:comment 'Description of the conditions and procedures under which either party may terminate the contract prior to expiration. Includes notice requirements, cause provisions, and early termination penalties.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valueTotal rdf:type rdf:Property ;
    rdfs:label 'Value Total' ;
    rdfs:comment 'Total estimated revenue value of the contract over its full term. Calculated from base rates, estimated volumes, and contract duration. Used for revenue forecasting and sales performance metrics.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partyId rdf:type rdf:Property ;
    rdfs:label 'Party Id' ;
    rdfs:comment 'Unique identifier for the contract party record. Primary key.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line1' ;
    rdfs:comment 'Primary street address line for the party\'s legal or administrative office. Used for official correspondence and legal notices.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line2' ;
    rdfs:comment 'Secondary address line for suite, floor, building, or department information.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentReference rdf:type rdf:Property ;
    rdfs:label 'Amendment Reference' ;
    rdfs:comment 'Reference number of the contract amendment that added or modified this party\'s role. Links party changes to formal contract amendments.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorityLevel rdf:type rdf:Property ;
    rdfs:label 'Authority Level' ;
    rdfs:comment 'The level of authority this party holds in contract execution and administration. Signatory can execute amendments; approver can authorize changes; administrator manages day-to-day operations; observer receives notifications only; beneficiary receives services or payments.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dbaName rdf:type rdf:Property ;
    rdfs:label 'Dba Name' ;
    rdfs:comment 'The trade name or doing-business-as name if different from the legal name. Common for franchises and subsidiaries.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guaranteeAmount rdf:type rdf:Property ;
    rdfs:label 'Guarantee Amount' ;
    rdfs:comment 'Maximum financial liability or guarantee amount this party has committed to under the contract. Applicable when guarantor_flag is true.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:guaranteeCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Guarantee Currency Code' ;
    rdfs:comment 'Three-letter ISO currency code for the guarantee amount. Typically USD for US operations, CAD for Canada, MXN for Mexico.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guarantorFlag rdf:type rdf:Property ;
    rdfs:label 'Guarantor Flag' ;
    rdfs:comment 'Indicates whether this party serves as a financial or performance guarantor for the contract. True for guarantors who assume liability; false otherwise.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insuranceCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Insurance Certificate Number' ;
    rdfs:comment 'Certificate number for insurance coverage provided by or required from this party. Applicable for insurer parties or parties required to maintain insurance.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalName rdf:type rdf:Property ;
    rdfs:label 'Legal Name' ;
    rdfs:comment 'The full legal name of the party as it appears on official documents and contracts. Used for contract execution and legal correspondence.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partyStatus rdf:type rdf:Property ;
    rdfs:label 'Party Status' ;
    rdfs:comment 'Current lifecycle status of the party\'s participation in the contract. Active indicates the party is currently engaged; inactive indicates the party role has ended; suspended indicates temporary hold; pending_approval indicates awaiting authorization; terminated indicates formal removal from contract.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partyType rdf:type rdf:Property ;
    rdfs:label 'Party Type' ;
    rdfs:comment 'Legal classification of the party entity. Distinguishes between individual persons, corporations, partnerships, government entities, nonprofit organizations, trusts, and joint ventures. [ENUM-REF-CANDIDATE: individual|corporation|partnership|government|nonprofit|trust|joint_venture — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Email' ;
    rdfs:comment 'Email address of the primary contact for contract-related correspondence, notices, and amendments.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactName rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Name' ;
    rdfs:comment 'Full name of the primary contact person for contract administration and communication at this party organization.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Phone' ;
    rdfs:comment 'Primary telephone number for reaching the contract contact. Includes country code, area code, and extension if applicable.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactTitle rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Title' ;
    rdfs:comment 'Job title or position of the primary contact person (e.g., Procurement Manager, City Administrator, Operations Director).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceCode rdf:type rdf:Property ;
    rdfs:label 'Reference Code' ;
    rdfs:comment 'Foreign key reference to the master data record for this party. The target table is determined by party_reference_type (e.g., customer_id, vendor_id, municipality_id).' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:referenceType rdf:type rdf:Property ;
    rdfs:label 'Reference Type' ;
    rdfs:comment 'Indicates which master data domain this party references. Determines whether the party_reference_id points to customer master, vendor master, employee master, municipality registry, regulatory agency registry, or internal WM entity.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roleCode rdf:type rdf:Property ;
    rdfs:label 'Role Code' ;
    rdfs:comment 'The role this party plays in the contract relationship. Common roles include customer (service recipient), provider (WM contracting entity), guarantor (financial guarantor), regulator (municipal or environmental authority), subcontractor (third-party hauler or processor), insurer (insurance provider), municipal_authority (local government entity), franchise_authority (franchising body), hauler (transportation provider), disposal_facility (landfill or processing facility operator), broker (intermediary), consultant (advisory party). [ENUM-REF-CANDIDATE: customer|provider|guarantor|regulator|subcontractor|insurer|municipal_authority|franchise_authority|hauler|disposal_facility|broker|consultant — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryContactEmail rdf:type rdf:Property ;
    rdfs:label 'Secondary Contact Email' ;
    rdfs:comment 'Email address of the secondary contact for escalation and backup communication.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryContactName rdf:type rdf:Property ;
    rdfs:label 'Secondary Contact Name' ;
    rdfs:comment 'Full name of the secondary or backup contact person for contract administration.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryContactPhone rdf:type rdf:Property ;
    rdfs:label 'Secondary Contact Phone' ;
    rdfs:comment 'Telephone number for the secondary contact person.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatoryName rdf:type rdf:Property ;
    rdfs:label 'Signatory Name' ;
    rdfs:comment 'Full name of the individual who signed on behalf of this party. May differ from primary contact if an officer or authorized representative signed.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatoryTitle rdf:type rdf:Property ;
    rdfs:label 'Signatory Title' ;
    rdfs:comment 'Official title of the signatory (e.g., Chief Executive Officer, City Manager, Authorized Representative). Establishes legal authority to bind the party.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatureDate rdf:type rdf:Property ;
    rdfs:label 'Signature Date' ;
    rdfs:comment 'Date on which this party signed the contract or amendment. Used to establish binding agreement and effective dates.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:signatureRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Signature Required Flag' ;
    rdfs:comment 'Indicates whether this party\'s signature is required for contract execution and amendments. True for signatories and guarantors; false for observers and administrators.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxIdentificationNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Identification Number' ;
    rdfs:comment 'Federal tax identification number (EIN for entities, SSN for individuals) used for tax reporting and compliance. Required for payment processing and 1099 reporting.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationReasonCode rdf:type rdf:Property ;
    rdfs:label 'Termination Reason Code' ;
    rdfs:comment 'Reason code for why this party\'s participation ended. Applicable when effective_end_date is populated. Used for churn analysis and risk assessment. [ENUM-REF-CANDIDATE: contract_expiration|mutual_agreement|breach|bankruptcy|merger_acquisition|regulatory_change|non_performance — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingId rdf:type rdf:Property ;
    rdfs:label 'Pricing Id' ;
    rdfs:comment 'Unique identifier for the contract pricing record. Primary key for this entity.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:baseRate rdf:type rdf:Property ;
    rdfs:label 'Base Rate' ;
    rdfs:comment 'The primary unit rate charged for the service or material, expressed in the currency of the contract. Does not include surcharges or adjustments.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discountPercentage rdf:type rdf:Property ;
    rdfs:label 'Discount Percentage' ;
    rdfs:comment 'Percentage discount applied to the base rate for this pricing component. Used for volume discounts, promotional pricing, or negotiated contract terms.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalFeeApplicable rdf:type rdf:Property ;
    rdfs:label 'Environmental Fee Applicable' ;
    rdfs:comment 'Indicates whether environmental recovery fees are applied to recover costs of environmental compliance, recycling programs, or sustainability initiatives.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escalationFrequency rdf:type rdf:Property ;
    rdfs:label 'Escalation Frequency' ;
    rdfs:comment 'How often the rate escalation is applied (e.g., annually on contract anniversary, quarterly based on fuel index).' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationRate rdf:type rdf:Property ;
    rdfs:label 'Escalation Rate' ;
    rdfs:comment 'The percentage rate at which pricing increases during escalation events. Used for fixed-percentage escalation types.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:escalationType rdf:type rdf:Property ;
    rdfs:label 'Escalation Type' ;
    rdfs:comment 'Method by which the pricing rate increases over time. Supports automatic rate adjustments per contract terms (e.g., annual CPI adjustment, fixed 3% increase).' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelSurchargeApplicable rdf:type rdf:Property ;
    rdfs:label 'Fuel Surcharge Applicable' ;
    rdfs:comment 'Indicates whether a variable fuel surcharge is applied to this pricing component based on diesel fuel price indices.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextEscalationDate rdf:type rdf:Property ;
    rdfs:label 'Next Escalation Date' ;
    rdfs:comment 'The scheduled date for the next automatic rate increase. Used for proactive rate change notifications and billing system updates.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pricingCode rdf:type rdf:Property ;
    rdfs:label 'Pricing Code' ;
    rdfs:comment 'Business identifier for the pricing structure, used for external reference and reporting.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingStatus rdf:type rdf:Property ;
    rdfs:label 'Pricing Status' ;
    rdfs:comment 'Current lifecycle state of this pricing record. Controls whether the pricing is used in billing calculations.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingType rdf:type rdf:Property ;
    rdfs:label 'Pricing Type' ;
    rdfs:comment 'Category of pricing component. Defines the nature of the charge applied to the contract. [ENUM-REF-CANDIDATE: base_service_rate|tipping_fee|container_rental|fuel_surcharge|environmental_recovery_fee|regulatory_cost_recovery|disposal_fee|hauling_fee|processing_fee|administrative_fee — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryFeeApplicable rdf:type rdf:Property ;
    rdfs:label 'Regulatory Fee Applicable' ;
    rdfs:comment 'Indicates whether regulatory cost recovery charges are applied to recover costs of permits, compliance monitoring, or mandated reporting.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceRecordCode rdf:type rdf:Property ;
    rdfs:label 'Source Record Code' ;
    rdfs:comment 'The unique identifier of this pricing record in the source system. Enables traceability and cross-system reconciliation.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierLevel rdf:type rdf:Property ;
    rdfs:label 'Tier Level' ;
    rdfs:comment 'Sequence number for tiered pricing structures. Used when pricing varies by volume thresholds (e.g., tier 1 for 0-10 tons, tier 2 for 10-50 tons). Null for non-tiered pricing.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tierMaximumQuantity rdf:type rdf:Property ;
    rdfs:label 'Tier Maximum Quantity' ;
    rdfs:comment 'The maximum quantity threshold for this pricing tier. Nullable for the highest tier with no upper limit.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tierMinimumQuantity rdf:type rdf:Property ;
    rdfs:label 'Tier Minimum Quantity' ;
    rdfs:comment 'The minimum quantity threshold for this pricing tier. Used in volume-based pricing models to define tier breakpoints.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Contract Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Disposal agreements require employee ownership for vendor relationship management, performance monitoring, renewal negotiations, and escalation workflows. Current contract_owner free-text field should' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:designatedCellId rdf:type rdf:Property ;
    rdfs:label 'Designated Cell Id' ;
    rdfs:comment 'Foreign key linking to landfill.cell. Business justification: Some disposal agreements specify designated cells for particular waste streams (e.g., industrial waste, C&D). Supports cell-specific capacity allocation, waste stream segregation requirements, and per' ;
    rdfs:domain ind:DisposalAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Cell .

ind:facilityPermitId rdf:type rdf:Property ;
    rdfs:label 'Facility Permit Id' ;
    rdfs:comment 'Foreign key linking to compliance.permit. Business justification: Disposal agreements with landfills/transfer stations must reference facility operating permits to verify accepted waste streams, capacity limits, and regulatory authorization. Procurement teams valida' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Permit .

ind:facilitySafetyProgramId rdf:type rdf:Property ;
    rdfs:label 'Facility Safety Program Id' ;
    rdfs:comment 'Foreign key linking to safety.safety_program. Business justification: Disposal facility agreements require facility-specific safety programs (RCRA compliance, confined space entry, LOTO procedures). Necessary for contractor safety orientation, facility access authorizat' ;
    rdfs:domain ind:DisposalAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SafetyProgram .

ind:agreementName rdf:type rdf:Property ;
    rdfs:label 'Agreement Name' ;
    rdfs:comment 'Descriptive name of the disposal agreement for business reference and reporting.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementNumber rdf:type rdf:Property ;
    rdfs:label 'Agreement Number' ;
    rdfs:comment 'Externally-known business identifier for the disposal agreement, used in contracts and invoicing.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementStatus rdf:type rdf:Property ;
    rdfs:label 'Agreement Status' ;
    rdfs:comment 'Current lifecycle status of the disposal agreement indicating its operational state.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseTippingFeeRate rdf:type rdf:Property ;
    rdfs:label 'Base Tipping Fee Rate' ;
    rdfs:comment 'Base rate charged per ton for waste disposal at the facility, measured in currency per ton. Excludes surcharges and adjustments.' ;
    rdfs:domain ind:DisposalAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractedAnnualTonnage rdf:type rdf:Property ;
    rdfs:label 'Contracted Annual Tonnage' ;
    rdfs:comment 'Total tonnage volume contracted per year under this disposal agreement, measured in tons.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:escalationPercentage rdf:type rdf:Property ;
    rdfs:label 'Escalation Percentage' ;
    rdfs:comment 'Annual percentage rate for tipping fee escalation as specified in the contract. Nullable if escalation is index-based.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:facilityOperator rdf:type rdf:Property ;
    rdfs:label 'Facility Operator' ;
    rdfs:comment 'Name of the organization or entity that operates the disposal facility.' ;
    rdfs:domain ind:DisposalAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manifestRequired rdf:type rdf:Property ;
    rdfs:label 'Manifest Required' ;
    rdfs:comment 'Indicates whether a hazardous waste tracking manifest (Bill of Lading) is required for waste deliveries under this agreement.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minimumTonnageGuarantee rdf:type rdf:Property ;
    rdfs:label 'Minimum Tonnage Guarantee' ;
    rdfs:comment 'Minimum tonnage volume that must be delivered annually to meet contractual obligations, measured in tons. Nullable if no minimum is required.' ;
    rdfs:domain ind:DisposalAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performancePenaltyClause rdf:type rdf:Property ;
    rdfs:label 'Performance Penalty Clause' ;
    rdfs:comment 'Description of penalties or liquidated damages for failure to meet contracted tonnage, SLA, or other performance obligations.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rcraComplianceRequired rdf:type rdf:Property ;
    rdfs:label 'Rcra Compliance Required' ;
    rdfs:comment 'Indicates whether this disposal agreement requires compliance with RCRA regulations for hazardous waste handling and disposal.' ;
    rdfs:domain ind:DisposalAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaTurnaroundTimeHours rdf:type rdf:Property ;
    rdfs:label 'Sla Turnaround Time Hours' ;
    rdfs:comment 'Maximum turnaround time in hours for waste acceptance and processing as specified in the Service Level Agreement (SLA).' ;
    rdfs:domain ind:DisposalAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:terminationDate rdf:type rdf:Property ;
    rdfs:label 'Termination Date' ;
    rdfs:comment 'Actual date when the disposal agreement was terminated, if applicable. Nullable for active agreements.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tippingFeeCurrency rdf:type rdf:Property ;
    rdfs:label 'Tipping Fee Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for tipping fee rates (e.g., USD, CAD).' ;
    rdfs:domain ind:DisposalAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tpdCapacity rdf:type rdf:Property ;
    rdfs:label 'Tpd Capacity' ;
    rdfs:comment 'Daily tonnage capacity allocated under this disposal agreement, measured in Tons Per Day (TPD).' ;
    rdfs:domain ind:DisposalAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorContactEmail rdf:type rdf:Property ;
    rdfs:label 'Vendor Contact Email' ;
    rdfs:comment 'Email address for the vendor contact at the disposal facility.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorContactName rdf:type rdf:Property ;
    rdfs:label 'Vendor Contact Name' ;
    rdfs:comment 'Primary contact name at the disposal facility vendor for operational coordination.' ;
    rdfs:domain ind:DisposalAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorContactPhone rdf:type rdf:Property ;
    rdfs:label 'Vendor Contact Phone' ;
    rdfs:comment 'Primary phone number for the vendor contact at the disposal facility.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByDocumentId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Document Id' ;
    rdfs:comment 'Reference to the contract document that supersedes or replaces this document. Establishes version lineage and ensures users access the most current document.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Document .

ind:accessRestrictionNotes rdf:type rdf:Property ;
    rdfs:label 'Access Restriction Notes' ;
    rdfs:comment 'Free-text notes describing specific access restrictions, handling requirements, or distribution limitations for the document. Used for confidential or proprietary documents.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedByUser rdf:type rdf:Property ;
    rdfs:label 'Approved By User' ;
    rdfs:comment 'User identifier or name of the person who approved the document for execution or publication. Supports approval workflow tracking and accountability.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checksumVerifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Checksum Verified Timestamp' ;
    rdfs:comment 'Date and time when the document hash checksum was last verified against the stored file. Ensures ongoing document integrity and detects corruption or tampering.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:confidentialityLevel rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Level' ;
    rdfs:comment 'Data classification level indicating the sensitivity and access restrictions for the document. Aligns with enterprise information security policy.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentDescription rdf:type rdf:Property ;
    rdfs:label 'Document Description' ;
    rdfs:comment 'Detailed narrative description of the document content, purpose, and key provisions. Used for search and retrieval purposes.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentStatus rdf:type rdf:Property ;
    rdfs:label 'Document Status' ;
    rdfs:comment 'Current lifecycle status of the document indicating its state in the approval and execution workflow. Tracks progression from draft through execution to archival. [ENUM-REF-CANDIDATE: DRAFT|PENDING_REVIEW|PENDING_APPROVAL|APPROVED|EXECUTED|ACTIVE|SUPERSEDED|EXPIRED|TERMINATED|ARCHIVED — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibleForDestructionDate rdf:type rdf:Property ;
    rdfs:label 'Eligible For Destruction Date' ;
    rdfs:comment 'Calculated date on which the document becomes eligible for destruction per retention policy. Computed as retention_trigger_date plus retention_period_years.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:executionDate rdf:type rdf:Property ;
    rdfs:label 'Execution Date' ;
    rdfs:comment 'Date on which the document was formally executed or signed by all required parties. Establishes legal effectiveness date for binding documents.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:extractedTextAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Extracted Text Available Flag' ;
    rdfs:comment 'Boolean indicator of whether extracted text content is available for the document. Supports full-text search and content analysis capabilities.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fileSizeBytes rdf:type rdf:Property ;
    rdfs:label 'File Size Bytes' ;
    rdfs:comment 'Size of the document file measured in bytes. Used for storage management and transmission planning.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:format rdf:type rdf:Property ;
    rdfs:label 'Format' ;
    rdfs:comment 'File format or media type of the stored document. Common formats include Portable Document Format (PDF), Microsoft Word (DOCX), Microsoft Excel (XLSX), Tagged Image File Format (TIFF), and email formats (MSG, EML). [ENUM-REF-CANDIDATE: PDF|DOCX|DOC|XLSX|XLS|TIF|TIFF|JPG|JPEG|PNG|MSG|EML — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hash rdf:type rdf:Property ;
    rdfs:label 'Hash' ;
    rdfs:comment 'Cryptographic hash (SHA-256 or MD5) of the document file content. Ensures document integrity and detects unauthorized modifications for audit and compliance purposes.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indexedForSearchFlag rdf:type rdf:Property ;
    rdfs:label 'Indexed For Search Flag' ;
    rdfs:comment 'Boolean indicator of whether the document content has been indexed for full-text search. Enables rapid document discovery and retrieval.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalHoldCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Legal Hold Case Number' ;
    rdfs:comment 'Case or matter number associated with the legal hold. Links document to specific litigation, investigation, or regulatory proceeding requiring preservation.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Legal Hold Flag' ;
    rdfs:comment 'Boolean indicator of whether the document is subject to a legal hold or litigation hold order. When true, document must be preserved and cannot be destroyed regardless of retention schedule.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ocrProcessedFlag rdf:type rdf:Property ;
    rdfs:label 'Ocr Processed Flag' ;
    rdfs:comment 'Boolean indicator of whether the document has been processed through Optical Character Recognition (OCR) to extract text from scanned images. Enables searchability of scanned documents.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pageCount rdf:type rdf:Property ;
    rdfs:label 'Page Count' ;
    rdfs:comment 'Total number of pages in the document. Applicable to paginated document formats such as PDF and Word documents.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryFilingDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Date' ;
    rdfs:comment 'Date on which the document was filed with the applicable regulatory authority. Used for compliance tracking and audit trail purposes.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:relatedDocumentIds rdf:type rdf:Property ;
    rdfs:label 'Related Document Ids' ;
    rdfs:comment 'Comma-separated list of contract_document_id values for related or cross-referenced documents. Supports navigation between exhibits, addenda, and parent agreements.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresRegulatoryFiling rdf:type rdf:Property ;
    rdfs:label 'Requires Regulatory Filing' ;
    rdfs:comment 'Boolean indicator of whether this document must be filed with or submitted to a regulatory authority such as Environmental Protection Agency (EPA), state environmental quality department, or local solid waste authority.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:retentionPeriodYears rdf:type rdf:Property ;
    rdfs:label 'Retention Period Years' ;
    rdfs:comment 'Number of years the document must be retained per legal, regulatory, or internal policy requirements. Drives records retention schedule and archival processes.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:retentionTriggerDate rdf:type rdf:Property ;
    rdfs:label 'Retention Trigger Date' ;
    rdfs:comment 'Date from which the retention period begins counting. Typically the execution date, expiration date, or contract termination date depending on document type and retention policy.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:signatoryPartyNames rdf:type rdf:Property ;
    rdfs:label 'Signatory Party Names' ;
    rdfs:comment 'Comma-separated list of all parties who signed or are required to sign the document. Includes customer representatives, Waste Management authorized signatories, and third-party witnesses.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemDocumentCode rdf:type rdf:Property ;
    rdfs:label 'Source System Document Code' ;
    rdfs:comment 'Unique identifier for the document in the source system. Enables traceability and reconciliation between the lakehouse and operational systems.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storagePath rdf:type rdf:Property ;
    rdfs:label 'Storage Path' ;
    rdfs:comment 'Full file path or Uniform Resource Locator (URL) reference to the physical document location in the Document Management System (DMS), SharePoint, or cloud storage repository. Enables direct retrieval of the document file.' ;
    rdfs:domain ind:Document ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:title rdf:type rdf:Property ;
    rdfs:label 'Title' ;
    rdfs:comment 'Full descriptive title of the document as it appears on the document itself. Provides human-readable identification of document content and purpose.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationClauseId rdf:type rdf:Property ;
    rdfs:label 'Escalation Clause Id' ;
    rdfs:comment 'Unique identifier for the escalation clause record. Primary key.' ;
    rdfs:domain ind:EscalationClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:appliesToServiceTypes rdf:type rdf:Property ;
    rdfs:label 'Applies To Service Types' ;
    rdfs:comment 'Comma-separated list of service types to which this escalation clause applies (e.g., residential_collection, commercial_hauling, disposal_fees, recycling_processing). Allows selective application of escalation to specific contract line items.' ;
    rdfs:domain ind:EscalationClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseIndexDate rdf:type rdf:Property ;
    rdfs:label 'Base Index Date' ;
    rdfs:comment 'The date on which the base index value was established, typically the contract effective date or last escalation reset date.' ;
    rdfs:domain ind:EscalationClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:baseIndexValue rdf:type rdf:Property ;
    rdfs:label 'Base Index Value' ;
    rdfs:comment 'The baseline index value established at contract origination or last reset, against which future index values are compared to calculate escalation percentage.' ;
    rdfs:domain ind:EscalationClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clauseNumber rdf:type rdf:Property ;
    rdfs:label 'Clause Number' ;
    rdfs:comment 'Business identifier for the escalation clause within the contract (e.g., Section 4.2, Clause E-1).' ;
    rdfs:domain ind:EscalationClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compoundingMethod rdf:type rdf:Property ;
    rdfs:label 'Compounding Method' ;
    rdfs:comment 'How escalations are calculated over multiple periods. Simple = each escalation applies to original base rate; compound = each escalation applies to previously escalated rate; reset_to_base = rate resets to base and new escalation calculated from current index.' ;
    rdfs:domain ind:EscalationClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerApprovalRequired rdf:type rdf:Property ;
    rdfs:label 'Customer Approval Required' ;
    rdfs:comment 'Indicates whether customer approval or acceptance is required before escalated rates take effect. True for some municipal contracts with board approval requirements; false for automatic escalations.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disputePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Dispute Period Days' ;
    rdfs:comment 'Number of days after notification during which customer may dispute the escalation calculation or request review. Null if no dispute period is contractually defined.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:escalationCapPercentage rdf:type rdf:Property ;
    rdfs:label 'Escalation Cap Percentage' ;
    rdfs:comment 'Maximum allowable rate increase percentage in any single escalation period, protecting customers from excessive increases during high inflation periods (e.g., 5.00 represents 5% cap).' ;
    rdfs:domain ind:EscalationClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:escalationClauseStatus rdf:type rdf:Property ;
    rdfs:label 'Escalation Clause Status' ;
    rdfs:comment 'Current lifecycle status of the escalation clause. Active = currently in effect; suspended = temporarily not applied; expired = past expiration date; superseded = replaced by amendment; pending_approval = awaiting customer or internal approval.' ;
    rdfs:domain ind:EscalationClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationFloorPercentage rdf:type rdf:Property ;
    rdfs:label 'Escalation Floor Percentage' ;
    rdfs:comment 'Minimum rate increase percentage guaranteed in any escalation period, ensuring revenue growth even during deflationary periods (e.g., 1.00 represents 1% floor). Null if no floor applies.' ;
    rdfs:domain ind:EscalationClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fixedEscalationPercentage rdf:type rdf:Property ;
    rdfs:label 'Fixed Escalation Percentage' ;
    rdfs:comment 'The predetermined annual percentage increase applied to rates for fixed percentage escalation clauses (e.g., 3.00 represents 3% annual increase). Null for index-based escalations.' ;
    rdfs:domain ind:EscalationClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:indexReference rdf:type rdf:Property ;
    rdfs:label 'Index Reference' ;
    rdfs:comment 'Specific economic index or benchmark used for escalation calculation (e.g., CPI-U All Urban Consumers, PPI Waste Management Services, DOE Diesel Fuel Index, Regional CPI). Null for fixed percentage escalations.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastEscalationDate rdf:type rdf:Property ;
    rdfs:label 'Last Escalation Date' ;
    rdfs:comment 'The date when the most recent rate escalation was applied under this clause. Null if no escalation has occurred yet.' ;
    rdfs:domain ind:EscalationClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastEscalationPercentage rdf:type rdf:Property ;
    rdfs:label 'Last Escalation Percentage' ;
    rdfs:comment 'The actual percentage increase applied during the most recent escalation event (e.g., 2.75 represents 2.75% increase). Used for historical tracking and forecasting.' ;
    rdfs:domain ind:EscalationClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:notificationDaysAdvance rdf:type rdf:Property ;
    rdfs:label 'Notification Days Advance' ;
    rdfs:comment 'Number of days prior to rate change effective date that customer must be notified, as stipulated in contract terms (e.g., 30, 60, 90 days). Required for compliance with municipal contract notification requirements.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reviewFrequency rdf:type rdf:Property ;
    rdfs:label 'Review Frequency' ;
    rdfs:comment 'How often the escalation clause is reviewed and rates are adjusted (annual = once per year, semi-annual = twice per year, quarterly = four times per year, biennial = every two years, monthly = every month).' ;
    rdfs:domain ind:EscalationClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportingDocumentationRequired rdf:type rdf:Property ;
    rdfs:label 'Supporting Documentation Required' ;
    rdfs:comment 'Indicates whether supporting documentation (index reports, cost data, calculations) must be provided to customer with escalation notification. True for municipal contracts requiring transparency; false for standard commercial agreements.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:esgDisclosureId rdf:type rdf:Property ;
    rdfs:label 'Esg Disclosure Id' ;
    rdfs:comment 'Foreign key linking to sustainability.esg_disclosure. Business justification: Municipal franchise agreements require ESG disclosures (diversion rates, emissions, community investment) for franchise fee calculations and renewal evaluations. Direct link needed for regulatory repo' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EsgDisclosure .

ind:municipalityId rdf:type rdf:Property ;
    rdfs:label 'Municipality Id' ;
    rdfs:comment 'Reference to the municipal government entity that granted this franchise agreement.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Municipality .

ind:requiredSafetyProgramId rdf:type rdf:Property ;
    rdfs:label 'Required Safety Program Id' ;
    rdfs:comment 'Foreign key linking to safety.safety_program. Business justification: Municipal franchise agreements explicitly mandate safety program compliance (OSHA VPP, DOT safety ratings, environmental compliance programs). Critical for franchise renewal audits, regulatory reporti' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SafetyProgram .

ind:annualRateEscalationPercentage rdf:type rdf:Property ;
    rdfs:label 'Annual Rate Escalation Percentage' ;
    rdfs:comment 'Fixed annual percentage increase applied to service rates, if applicable under the rate adjustment mechanism.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cpiIndexReference rdf:type rdf:Property ;
    rdfs:label 'Cpi Index Reference' ;
    rdfs:comment 'Specific Consumer Price Index used for rate escalation calculations, such as CPI-U for All Urban Consumers or regional CPI.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeResolutionMethod rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Method' ;
    rdfs:comment 'Primary method for resolving disputes between Waste Management and the municipality under the franchise agreement.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diversionRateRequirement rdf:type rdf:Property ;
    rdfs:label 'Diversion Rate Requirement' ;
    rdfs:comment 'Minimum percentage of waste that must be diverted from landfill through recycling, composting, or waste-to-energy programs as mandated by the municipality.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalComplianceRequirements rdf:type rdf:Property ;
    rdfs:label 'Environmental Compliance Requirements' ;
    rdfs:comment 'Description of specific environmental compliance obligations under the franchise agreement, including EPA, RCRA, Clean Air Act, and state environmental regulations.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusivityType rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Type' ;
    rdfs:comment 'Indicates whether Waste Management has exclusive, non-exclusive, or semi-exclusive rights to provide waste collection services within the franchise territory.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fleetCompositionRequirements rdf:type rdf:Property ;
    rdfs:label 'Fleet Composition Requirements' ;
    rdfs:comment 'Requirements for fleet composition serving the franchise territory, including minimum percentages of CNG, RNG, electric, or other alternative fuel vehicles.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:franchiseFeeFixedAmount rdf:type rdf:Property ;
    rdfs:label 'Franchise Fee Fixed Amount' ;
    rdfs:comment 'Fixed annual franchise fee amount paid to the municipality, applicable when franchise_fee_type is fixed_annual or hybrid.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:franchiseFeePerTonRate rdf:type rdf:Property ;
    rdfs:label 'Franchise Fee Per Ton Rate' ;
    rdfs:comment 'Per-ton franchise fee rate charged for waste disposed within the franchise territory, applicable when franchise_fee_type is per_ton or hybrid.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:franchiseFeePercentage rdf:type rdf:Property ;
    rdfs:label 'Franchise Fee Percentage' ;
    rdfs:comment 'Percentage of gross revenue paid to the municipality as franchise fee, applicable when franchise_fee_type is percentage_of_revenue or hybrid.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:franchiseFeeType rdf:type rdf:Property ;
    rdfs:label 'Franchise Fee Type' ;
    rdfs:comment 'Structure of the franchise fee payment to the municipality: percentage of gross revenue, fixed annual amount, per-ton disposal fee, or hybrid model.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ghgReductionTargetPercentage rdf:type rdf:Property ;
    rdfs:label 'Ghg Reduction Target Percentage' ;
    rdfs:comment 'Target percentage reduction in greenhouse gas emissions required under the franchise agreement, typically measured in CO2e.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:governingLawJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Governing Law Jurisdiction' ;
    rdfs:comment 'State or jurisdiction whose laws govern the interpretation and enforcement of the franchise agreement.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initialTermYears rdf:type rdf:Property ;
    rdfs:label 'Initial Term Years' ;
    rdfs:comment 'Number of years in the initial term of the franchise agreement before any renewal options.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:insuranceRequirementDescription rdf:type rdf:Property ;
    rdfs:label 'Insurance Requirement Description' ;
    rdfs:comment 'Description of the insurance coverage types and minimum limits required under the franchise agreement, including general liability, auto liability, and environmental liability.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Lea Reference Number' ;
    rdfs:comment 'Reference number assigned by the Local Enforcement Agency responsible for solid waste regulatory oversight in the franchise territory.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceBondRequired rdf:type rdf:Property ;
    rdfs:label 'Performance Bond Required' ;
    rdfs:comment 'Indicates whether Waste Management is required to maintain a performance bond to guarantee service delivery under this franchise agreement.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rateAdjustmentMechanism rdf:type rdf:Property ;
    rdfs:label 'Rate Adjustment Mechanism' ;
    rdfs:comment 'Description of the methodology for adjusting service rates over the term of the franchise agreement, including CPI escalation, fuel surcharge formulas, or other adjustment triggers.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalOptionYears rdf:type rdf:Property ;
    rdfs:label 'Renewal Option Years' ;
    rdfs:comment 'Number of years in each renewal option period, if the franchise agreement includes renewal provisions.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceScope rdf:type rdf:Property ;
    rdfs:label 'Service Scope' ;
    rdfs:comment 'Detailed description of the waste collection and disposal services covered under this franchise agreement, including residential, commercial, recycling, and special waste streams.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaMissedPickupResolutionHours rdf:type rdf:Property ;
    rdfs:label 'Sla Missed Pickup Resolution Hours' ;
    rdfs:comment 'Maximum number of hours allowed to resolve a missed pickup complaint within the franchise territory.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaResponseTimeHours rdf:type rdf:Property ;
    rdfs:label 'Sla Response Time Hours' ;
    rdfs:comment 'Maximum number of hours allowed to respond to service requests or complaints from residents within the franchise territory.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:swisReportingRequired rdf:type rdf:Property ;
    rdfs:label 'Swis Reporting Required' ;
    rdfs:comment 'Indicates whether reporting to the state Solid Waste Information System is required under this franchise agreement.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:terminationForCauseAllowed rdf:type rdf:Property ;
    rdfs:label 'Termination For Cause Allowed' ;
    rdfs:comment 'Indicates whether the municipality has the right to terminate the franchise agreement for cause due to performance failures or regulatory violations.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:territoryGeojson rdf:type rdf:Property ;
    rdfs:label 'Territory Geojson' ;
    rdfs:comment 'GeoJSON representation of the franchise territory boundaries for mapping and spatial analysis.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:haulerVendorId rdf:type rdf:Property ;
    rdfs:label 'Hauler Vendor Id' ;
    rdfs:comment 'Foreign key linking to procurement.vendor. Business justification: Third-party haulers are vendors providing transportation services under contract. Critical for subcontractor invoice reconciliation, insurance certificate tracking, DOT compliance verification, and pa' ;
    rdfs:domain ind:HaulingAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:originFacilityId rdf:type rdf:Property ;
    rdfs:label 'Origin Facility Id' ;
    rdfs:comment 'Identifier for the facility or location where waste is collected or loaded for transport. May be collection point, transfer station, or customer site.' ;
    rdfs:domain ind:HaulingAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:transportPermitId rdf:type rdf:Property ;
    rdfs:label 'Transport Permit Id' ;
    rdfs:comment 'Foreign key linking to compliance.permit. Business justification: Hauling agreements for hazardous waste transport require DOT/EPA permits. Contract terms (waste types, routes, volumes) must align with permit conditions. Essential for third-party hauler qualificatio' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Permit .

ind:bolRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Bol Requirement Flag' ;
    rdfs:comment 'Indicates whether a BOL document is required for each haul under this agreement. True if BOL is mandatory.' ;
    rdfs:domain ind:HaulingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractedRate rdf:type rdf:Property ;
    rdfs:label 'Contracted Rate' ;
    rdfs:comment 'Base rate amount per unit as defined by rate structure type. Expressed in USD unless otherwise specified in currency code.' ;
    rdfs:domain ind:HaulingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dotComplianceRequirements rdf:type rdf:Property ;
    rdfs:label 'Dot Compliance Requirements' ;
    rdfs:comment 'Specific DOT regulatory obligations applicable to this hauling agreement including vehicle standards, driver qualifications, and hours of service.' ;
    rdfs:domain ind:HaulingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalComplianceCertifications rdf:type rdf:Property ;
    rdfs:label 'Environmental Compliance Certifications' ;
    rdfs:comment 'List of environmental certifications and permits held by the hauler relevant to this agreement (e.g., EPA ID, state permits, ISO 14001).' ;
    rdfs:domain ind:HaulingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manifestRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Manifest Requirement Flag' ;
    rdfs:comment 'Indicates whether hazardous waste manifest tracking is required per RCRA regulations. True for hazardous waste streams.' ;
    rdfs:domain ind:HaulingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maximumVolumeCapacityTons rdf:type rdf:Property ;
    rdfs:label 'Maximum Volume Capacity Tons' ;
    rdfs:comment 'Maximum tonnage the hauler commits to transport over the contract period. Defines capacity ceiling.' ;
    rdfs:domain ind:HaulingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumVolumeCommitmentTons rdf:type rdf:Property ;
    rdfs:label 'Minimum Volume Commitment Tons' ;
    rdfs:comment 'Minimum tonnage the customer commits to provide for hauling over the contract period. Nullable if no minimum applies.' ;
    rdfs:domain ind:HaulingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceSlaOnTimePct rdf:type rdf:Property ;
    rdfs:label 'Performance Sla On Time Pct' ;
    rdfs:comment 'Contractual service level target for on-time delivery performance expressed as a percentage. Used for performance monitoring and penalties.' ;
    rdfs:domain ind:HaulingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateStructureType rdf:type rdf:Property ;
    rdfs:label 'Rate Structure Type' ;
    rdfs:comment 'Pricing model used to calculate hauling charges. Defines the unit basis for rate application.' ;
    rdfs:domain ind:HaulingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalTerms rdf:type rdf:Property ;
    rdfs:label 'Renewal Terms' ;
    rdfs:comment 'Contractual provisions governing automatic renewal, renewal notice periods, and renegotiation requirements.' ;
    rdfs:domain ind:HaulingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeLaneDescription rdf:type rdf:Property ;
    rdfs:label 'Route Lane Description' ;
    rdfs:comment 'Textual description of the hauling route or lane including key waypoints, geographic coverage, and operational constraints.' ;
    rdfs:domain ind:HaulingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyRating rdf:type rdf:Property ;
    rdfs:label 'Safety Rating' ;
    rdfs:comment 'DOT safety rating assigned to the hauler based on compliance history and safety performance inspections.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationForCauseClause rdf:type rdf:Property ;
    rdfs:label 'Termination For Cause Clause' ;
    rdfs:comment 'Contractual terms defining conditions under which either party may terminate immediately for material breach or non-performance.' ;
    rdfs:domain ind:HaulingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lifecycleEventId rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Event Id' ;
    rdfs:comment 'Primary key for lifecycle_event' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approverUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Approver User Employee Id' ;
    rdfs:comment 'Identifier of the user who approved this lifecycle event. Null if no approval was required or if auto-approved by system.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryLifecycleEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Lifecycle Employee Id' ;
    rdfs:comment 'Identifier of the user who initiated or triggered this lifecycle event. May be a system identifier for automated events.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:amendmentDetail rdf:type rdf:Property ;
    rdfs:label 'Amendment Detail' ;
    rdfs:comment 'For AMENDMENT events, provides specific details about what was changed (e.g., service frequency increased from weekly to bi-weekly, rate adjusted from $150 to $175). Null for non-amendment events.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentTypeCode rdf:type rdf:Property ;
    rdfs:label 'Amendment Type Code' ;
    rdfs:comment 'For AMENDMENT events, specifies the nature of the contract modification. Null for non-amendment events. [ENUM-REF-CANDIDATE: SCOPE_CHANGE|RATE_ADJUSTMENT|SERVICE_ADDITION|SERVICE_REMOVAL|TERM_EXTENSION|ADDRESS_CHANGE|BILLING_CHANGE — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Approval Reference Number' ;
    rdfs:comment 'Reference number or identifier of the approval workflow or authorization that permitted this lifecycle event. Null if no approval was required.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceReviewCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Review Completed Flag' ;
    rdfs:comment 'Indicates whether required compliance review has been completed for this lifecycle event. True if completed, False if pending or not applicable.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceReviewRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Review Required Flag' ;
    rdfs:comment 'Indicates whether this lifecycle event requires regulatory or legal compliance review. True if review is required, False otherwise.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerNotificationSentFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Sent Flag' ;
    rdfs:comment 'Indicates whether the customer was notified about this lifecycle event. True if notification was sent, False otherwise.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eventDescription rdf:type rdf:Property ;
    rdfs:label 'Event Description' ;
    rdfs:comment 'Detailed narrative description of the lifecycle event, including business context, reason for change, and any relevant details specific to this event occurrence.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Event Sequence Number' ;
    rdfs:comment 'Sequential ordering number of this event within the contracts lifecycle history. Enables chronological reconstruction of contract state changes.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eventTypeCode rdf:type rdf:Property ;
    rdfs:label 'Event Type Code' ;
    rdfs:comment 'Classification code identifying the type of lifecycle event. Values: ORIGINATION (contract created), ACTIVATION (contract becomes active), FIRST_SERVICE (first service delivery), AMENDMENT (contract modified), RENEWAL (contract renewed), TERMINATION (contract ended), SUSPENSION (contract temporarily paused), REINSTATEMENT (contract reactivated after suspension). [ENUM-REF-CANDIDATE: ORIGINATION|ACTIVATION|FIRST_SERVICE|AMENDMENT|RENEWAL|TERMINATION|SUSPENSION|REINSTATEMENT — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newContractStatus rdf:type rdf:Property ;
    rdfs:label 'New Contract Status' ;
    rdfs:comment 'The contract status after this lifecycle event was applied. Represents the resulting state of the contract. [ENUM-REF-CANDIDATE: DRAFT|PENDING_APPROVAL|ACTIVE|SUSPENDED|TERMINATED|EXPIRED|RENEWED — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newMonthlyValue rdf:type rdf:Property ;
    rdfs:label 'New Monthly Value' ;
    rdfs:comment 'For AMENDMENT or RENEWAL events that change pricing, the monthly contract value after the event in USD. Null if pricing was not modified.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:newTermEndDate rdf:type rdf:Property ;
    rdfs:label 'New Term End Date' ;
    rdfs:comment 'For RENEWAL or AMENDMENT events that extend the contract term, the new end date of the contract. Null if term was not modified.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priorContractStatus rdf:type rdf:Property ;
    rdfs:label 'Prior Contract Status' ;
    rdfs:comment 'The contract status immediately before this lifecycle event occurred. Enables state transition tracking and audit trail reconstruction. [ENUM-REF-CANDIDATE: DRAFT|PENDING_APPROVAL|ACTIVE|SUSPENDED|TERMINATED|EXPIRED|RENEWED — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorMonthlyValue rdf:type rdf:Property ;
    rdfs:label 'Prior Monthly Value' ;
    rdfs:comment 'For AMENDMENT or RENEWAL events that change pricing, the monthly contract value before the event in USD. Null if pricing was not modified.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorTermEndDate rdf:type rdf:Property ;
    rdfs:label 'Prior Term End Date' ;
    rdfs:comment 'For RENEWAL events, the end date of the previous contract term. Null for non-renewal events.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rateEscalationPercentage rdf:type rdf:Property ;
    rdfs:label 'Rate Escalation Percentage' ;
    rdfs:comment 'For RENEWAL or AMENDMENT events involving rate escalation, the percentage increase applied to contract rates. Null if no escalation occurred.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewalOutcomeCode rdf:type rdf:Property ;
    rdfs:label 'Renewal Outcome Code' ;
    rdfs:comment 'For RENEWAL events, indicates how the renewal was executed. Null for non-renewal events.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceLevelAgreementChangeFlag rdf:type rdf:Property ;
    rdfs:label 'Service Level Agreement Change Flag' ;
    rdfs:comment 'Indicates whether this lifecycle event resulted in changes to the contracts Service Level Agreement terms. True if SLA was modified, False otherwise.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:triggeringSystemCode rdf:type rdf:Property ;
    rdfs:label 'Triggering System Code' ;
    rdfs:comment 'Identifies the source system or process that generated this lifecycle event. Enables traceability of event origin.' ;
    rdfs:domain ind:LifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Service Enrollment Id' ;
    rdfs:comment 'Foreign key linking to customer.service_enrollment. Business justification: ASC 606 revenue recognition requires performance obligations mapped to specific service enrollments. Linking enables accurate revenue allocation, satisfaction tracking, and contract asset/liability ca' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceEnrollment .

ind:allocatedTransactionPrice rdf:type rdf:Property ;
    rdfs:label 'Allocated Transaction Price' ;
    rdfs:comment 'Portion of the total contract transaction price allocated to this specific performance obligation based on relative standalone selling prices.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amendmentDate rdf:type rdf:Property ;
    rdfs:label 'Amendment Date' ;
    rdfs:comment 'Date when this performance obligation was amended or modified. Null if never amended.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:amendmentIndicator rdf:type rdf:Property ;
    rdfs:label 'Amendment Indicator' ;
    rdfs:comment 'Indicates whether this performance obligation was added or modified through a contract amendment.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:billingSchedule rdf:type rdf:Property ;
    rdfs:label 'Billing Schedule' ;
    rdfs:comment 'Billing frequency or schedule for this performance obligation (may differ from revenue recognition pattern).' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constraintApplied rdf:type rdf:Property ;
    rdfs:label 'Constraint Applied' ;
    rdfs:comment 'Indicates whether a constraint has been applied to variable consideration to prevent significant revenue reversal.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractAssetLiabilityIndicator rdf:type rdf:Property ;
    rdfs:label 'Contract Asset Liability Indicator' ;
    rdfs:comment 'Indicates whether this obligation creates a contract asset (revenue recognized before billing) or contract liability (billing before revenue recognition) on the balance sheet.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costOfService rdf:type rdf:Property ;
    rdfs:label 'Cost Of Service' ;
    rdfs:comment 'Estimated or actual cost to fulfill this performance obligation, used for profitability analysis.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isDistinct rdf:type rdf:Property ;
    rdfs:label 'Is Distinct' ;
    rdfs:comment 'Indicates whether this obligation is distinct and separately identifiable from other promises in the contract per ASC 606 criteria.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVariableConsideration rdf:type rdf:Property ;
    rdfs:label 'Is Variable Consideration' ;
    rdfs:comment 'Indicates whether this obligation includes variable consideration (e.g., usage-based pricing, performance bonuses, penalties) that may affect the transaction price.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:percentageComplete rdf:type rdf:Property ;
    rdfs:label 'Percentage Complete' ;
    rdfs:comment 'Percentage of completion for obligations satisfied over time, used to calculate revenue recognition (0.00 to 100.00).' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceMilestone rdf:type rdf:Property ;
    rdfs:label 'Performance Milestone' ;
    rdfs:comment 'Description of key milestone or deliverable that triggers satisfaction of this obligation (applicable for milestone-based recognition).' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remainingRevenue rdf:type rdf:Property ;
    rdfs:label 'Remaining Revenue' ;
    rdfs:comment 'Remaining revenue to be recognized for this performance obligation (allocated transaction price minus revenue recognized to date).' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueRecognitionPattern rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Pattern' ;
    rdfs:comment 'The pattern used to recognize revenue for this obligation (e.g., straight-line over contract term, usage-based per service event, milestone completion).' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRecognizedToDate rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognized To Date' ;
    rdfs:comment 'Cumulative revenue recognized for this performance obligation as of the current reporting period.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:satisfactionDate rdf:type rdf:Property ;
    rdfs:label 'Satisfaction Date' ;
    rdfs:comment 'Actual date when the performance obligation was fully satisfied. Null if not yet satisfied.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:satisfactionMethod rdf:type rdf:Property ;
    rdfs:label 'Satisfaction Method' ;
    rdfs:comment 'Indicates whether the performance obligation is satisfied over time (e.g., ongoing collection service) or at a point in time (e.g., one-time container delivery).' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceQuantity rdf:type rdf:Property ;
    rdfs:label 'Service Quantity' ;
    rdfs:comment 'Quantity of service units promised under this obligation (e.g., number of pickups, number of containers, tons of waste).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Service Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the service quantity (e.g., pickups, containers, tons, cubic yards). [ENUM-REF-CANDIDATE: pickup|container|ton|cubic_yard|gallon|service_event|month — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTarget rdf:type rdf:Property ;
    rdfs:label 'Sla Target' ;
    rdfs:comment 'Service level target or performance standard associated with this obligation (e.g., 99% on-time pickup rate, 24-hour response time).' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standaloneSellingPrice rdf:type rdf:Property ;
    rdfs:label 'Standalone Selling Price' ;
    rdfs:comment 'The price at which the entity would sell the promised good or service separately to a customer, used for transaction price allocation under ASC 606.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:variableConsiderationEstimate rdf:type rdf:Property ;
    rdfs:label 'Variable Consideration Estimate' ;
    rdfs:comment 'Estimated amount of variable consideration expected to be received for this obligation, subject to constraint requirements.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateLineId rdf:type rdf:Property ;
    rdfs:label 'Rate Line Id' ;
    rdfs:comment 'Unique identifier for the rate line item within the rate schedule. Primary key.' ;
    rdfs:domain ind:RateLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:arrearsAdvanceIndicator rdf:type rdf:Property ;
    rdfs:label 'Arrears Advance Indicator' ;
    rdfs:comment 'Indicates whether this rate line is billed in arrears (after service delivery) or in advance (before service delivery). Affects revenue recognition timing.' ;
    rdfs:domain ind:RateLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargeDescription rdf:type rdf:Property ;
    rdfs:label 'Charge Description' ;
    rdfs:comment 'Detailed business description of the charge component. Provides clarity on what this rate line represents for billing transparency and customer communication.' ;
    rdfs:domain ind:RateLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargeType rdf:type rdf:Property ;
    rdfs:label 'Charge Type' ;
    rdfs:comment 'Category of charge represented by this rate line. Defines the nature of the pricing component (e.g., base collection rate, tipping fee, fuel surcharge, environmental fee, container rental, overage charge, special handling fee).' ;
    rdfs:domain ind:RateLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationMethod rdf:type rdf:Property ;
    rdfs:label 'Escalation Method' ;
    rdfs:comment 'Method used for automatic rate escalation over time. Options include no escalation, fixed percentage increase, Consumer Price Index (CPI) adjustment, fuel index linkage, or custom formula.' ;
    rdfs:domain ind:RateLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isMandatory rdf:type rdf:Property ;
    rdfs:label 'Is Mandatory' ;
    rdfs:comment 'Boolean flag indicating whether this rate line is a mandatory charge that cannot be waived or removed from the contract. True means mandatory, false means optional.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Line Sequence Number' ;
    rdfs:comment 'Sequential ordering of this rate line within the parent rate schedule. Used for display and processing order.' ;
    rdfs:domain ind:RateLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:prorationRule rdf:type rdf:Property ;
    rdfs:label 'Proration Rule' ;
    rdfs:comment 'Rule for prorating charges when service starts or ends mid-period. Options include daily proration, monthly proration, no proration, or custom calculation method.' ;
    rdfs:domain ind:RateLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateLineStatus rdf:type rdf:Property ;
    rdfs:label 'Rate Line Status' ;
    rdfs:comment 'Current lifecycle status of this rate line. Active means currently in use for billing, inactive means not applied, pending means scheduled for future activation, superseded means replaced by a newer rate line.' ;
    rdfs:domain ind:RateLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierThresholdLower rdf:type rdf:Property ;
    rdfs:label 'Tier Threshold Lower' ;
    rdfs:comment 'Lower bound threshold for tiered pricing. Defines the minimum quantity or usage level at which this rate line applies. Used in conjunction with tiered rate structures.' ;
    rdfs:domain ind:RateLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tierThresholdUpper rdf:type rdf:Property ;
    rdfs:label 'Tier Threshold Upper' ;
    rdfs:comment 'Upper bound threshold for tiered pricing. Defines the maximum quantity or usage level at which this rate line applies. Null indicates no upper limit for the tier.' ;
    rdfs:domain ind:RateLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitPrice rdf:type rdf:Property ;
    rdfs:label 'Unit Price' ;
    rdfs:comment 'Price per unit of measure for this rate line. The base rate applied to calculate the charge amount based on quantity consumed or service frequency.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewalId rdf:type rdf:Property ;
    rdfs:label 'Renewal Id' ;
    rdfs:comment 'Unique identifier for the contract renewal event. Primary key.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:renewalApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Renewal Approved By Employee Id' ;
    rdfs:comment 'Reference to the manager or executive who approved the renewal terms. Links to employee master data in Workday HCM. Null if no approval was required.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:amendmentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Amendment Required Flag' ;
    rdfs:comment 'Indicates whether renewal resulted in formal contract amendment documentation due to material changes in terms, pricing, or service scope. True if amendment executed; False if renewal proceeded under existing contract framework.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:autoRenewalEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Eligible Flag' ;
    rdfs:comment 'Indicates whether the contract is eligible for automatic renewal based on original contract terms. True if auto-renewal clause exists and conditions are met; False if manual renewal process required.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:churnRiskScore rdf:type rdf:Property ;
    rdfs:label 'Churn Risk Score' ;
    rdfs:comment 'Predictive score (0.00 to 1.00) indicating likelihood of customer not renewing, calculated at renewal notice date. Higher scores indicate greater risk of churn. Derived from customer payment history, service complaints, competitive activity, and engagement metrics.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:competitorName rdf:type rdf:Property ;
    rdfs:label 'Competitor Name' ;
    rdfs:comment 'Name of competing waste management company that customer was considering during renewal, if disclosed. Used for competitive analysis and market intelligence.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitorThreatFlag rdf:type rdf:Property ;
    rdfs:label 'Competitor Threat Flag' ;
    rdfs:comment 'Indicates whether customer indicated they were considering or received offers from competing waste management providers during renewal process. True if competitive threat identified; False otherwise.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerResponseDate rdf:type rdf:Property ;
    rdfs:label 'Customer Response Date' ;
    rdfs:comment 'Date when the customer provided their decision on the renewal offer (accepted, declined, or requested renegotiation).' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:escalationBasis rdf:type rdf:Property ;
    rdfs:label 'Escalation Basis' ;
    rdfs:comment 'Method used to calculate rate increase at renewal. CPI: Consumer Price Index adjustment. Fixed Percentage: predetermined annual increase. Market Rate: adjustment to current market pricing. Negotiated: custom rate agreed during renewal discussion. None: no escalation applied.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noticeDate rdf:type rdf:Property ;
    rdfs:label 'Notice Date' ;
    rdfs:comment 'Date when the renewal notice was sent to the customer, typically 60-90 days before contract expiration per Service Level Agreement (SLA) terms.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:offerDate rdf:type rdf:Property ;
    rdfs:label 'Offer Date' ;
    rdfs:comment 'Date when formal renewal terms and pricing were presented to the customer. May differ from notice date if negotiation occurred.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:optOutDate rdf:type rdf:Property ;
    rdfs:label 'Opt Out Date' ;
    rdfs:comment 'Date when customer submitted formal opt-out notice for auto-renewal. Must be received within notice period specified in contract (typically 30-90 days before expiration). Null if no opt-out received.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:optOutReceivedFlag rdf:type rdf:Property ;
    rdfs:label 'Opt Out Received Flag' ;
    rdfs:comment 'Indicates whether customer provided written notice to opt out of auto-renewal within the required notice period. True if opt-out notice received; False otherwise. Relevant only for contracts with auto-renewal clauses.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:outcome rdf:type rdf:Property ;
    rdfs:label 'Outcome' ;
    rdfs:comment 'Business result of the renewal process. Retained: customer renewed at similar service level. Lost: customer declined renewal and terminated service. Expanded: customer renewed with increased service scope or value. Downsized: customer renewed with reduced service scope or value.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousAnnualValue rdf:type rdf:Property ;
    rdfs:label 'Previous Annual Value' ;
    rdfs:comment 'Total annual revenue from the contract term prior to renewal, expressed in USD. Used as baseline for rate change calculation.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:previousTermEndDate rdf:type rdf:Property ;
    rdfs:label 'Previous Term End Date' ;
    rdfs:comment 'End date of the contract term that preceded this renewal. Typically one day before renewal_effective_date.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:previousTermStartDate rdf:type rdf:Property ;
    rdfs:label 'Previous Term Start Date' ;
    rdfs:comment 'Start date of the contract term that preceded this renewal. Used for historical tracking and term comparison.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rateEscalationClauseApplied rdf:type rdf:Property ;
    rdfs:label 'Rate Escalation Clause Applied' ;
    rdfs:comment 'Indicates whether a contractual rate escalation clause (e.g., Consumer Price Index (CPI) adjustment, fixed percentage increase) was applied at renewal. True if escalation clause triggered; False if rates remained flat or were manually adjusted.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalNumber rdf:type rdf:Property ;
    rdfs:label 'Renewal Number' ;
    rdfs:comment 'Business-facing unique identifier for the renewal event. Format: RNW-YYYYMMDD followed by sequence. Used in customer communications and internal tracking.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalType rdf:type rdf:Property ;
    rdfs:label 'Renewal Type' ;
    rdfs:comment 'Classification of the renewal mechanism. Auto-renewal executes automatically per contract terms; negotiated renewal requires active renegotiation; evergreen continues indefinitely until terminated; manual renewal requires explicit customer action.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewedAnnualValue rdf:type rdf:Property ;
    rdfs:label 'Renewed Annual Value' ;
    rdfs:comment 'Total annual revenue from the renewed contract term, expressed in USD. Reflects any rate escalation or service changes applied at renewal.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retentionStrategy rdf:type rdf:Property ;
    rdfs:label 'Retention Strategy' ;
    rdfs:comment 'Proactive retention approach applied during renewal process. Standard: normal renewal process. Discount Offered: pricing concession to retain customer. Service Upgrade: enhanced service at no additional cost. Executive Engagement: senior leadership involvement. None: no special retention effort required.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceChangeDescription rdf:type rdf:Property ;
    rdfs:label 'Service Change Description' ;
    rdfs:comment 'Free-text description of any service level or scope changes applied at renewal. Examples: increased pickup frequency from weekly to twice-weekly, added recycling service, reduced container count from 5 to 3 units.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceLevelChangeFlag rdf:type rdf:Property ;
    rdfs:label 'Service Level Change Flag' ;
    rdfs:comment 'Indicates whether Service Level Agreement (SLA) terms or service scope changed at renewal. True if service frequency, container count, or performance commitments were modified; False if service levels remained unchanged.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:termLengthMonths rdf:type rdf:Property ;
    rdfs:label 'Term Length Months' ;
    rdfs:comment 'Duration of the renewed contract term expressed in months. Common values: 12, 24, 36, 60 months.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:circularEconomyProgramId rdf:type rdf:Property ;
    rdfs:label 'Circular Economy Program Id' ;
    rdfs:comment 'Foreign key linking to sustainability.circular_economy_program. Business justification: Recycling/composting service commitments are governed by specific circular economy programs that define material handling, pricing, and diversion reporting requirements. Operations teams need this lin' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CircularEconomyProgram .

ind:containerTypeId rdf:type rdf:Property ;
    rdfs:label 'Container Type Id' ;
    rdfs:comment 'Foreign key linking to service.container_type. Business justification: Service commitments specify exact container equipment for delivery and billing. Direct link needed for asset allocation, delivery scheduling, capacity validation, rental billing, and maintenance track' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContainerType .

ind:landfillSiteId rdf:type rdf:Property ;
    rdfs:label 'Landfill Site Id' ;
    rdfs:comment 'Foreign key linking to landfill.site. Business justification: Service commitments for disposal services specify destination landfill site for capacity reservation and routing. Required for site capacity planning, contract fulfillment tracking, and customer servi' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Site .

ind:activatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Activated Timestamp' ;
    rdfs:comment 'Timestamp when the service commitment transitioned to active status and service delivery commenced.' ;
    rdfs:domain ind:ContractServiceCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cancellationNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Cancellation Notice Days' ;
    rdfs:comment 'Number of days advance notice required for customer to cancel this service commitment.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:commitmentNumber rdf:type rdf:Property ;
    rdfs:label 'Commitment Number' ;
    rdfs:comment 'Business-readable unique identifier for the service commitment, often used in customer communications and operational systems.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentStatus rdf:type rdf:Property ;
    rdfs:label 'Commitment Status' ;
    rdfs:comment 'Current lifecycle status of the service commitment.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monthlyServiceCharge rdf:type rdf:Property ;
    rdfs:label 'Monthly Service Charge' ;
    rdfs:comment 'Base monthly recurring charge for this service commitment, excluding usage-based fees.' ;
    rdfs:domain ind:ContractServiceCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overageChargeRate rdf:type rdf:Property ;
    rdfs:label 'Overage Charge Rate' ;
    rdfs:comment 'Rate charged for service usage exceeding the committed volume or frequency.' ;
    rdfs:domain ind:ContractServiceCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:perPickupCharge rdf:type rdf:Property ;
    rdfs:label 'Per Pickup Charge' ;
    rdfs:comment 'Additional charge applied per individual pickup event, if applicable.' ;
    rdfs:domain ind:ContractServiceCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceCountryCode rdf:type rdf:Property ;
    rdfs:label 'Service Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code where the service is delivered.' ;
    rdfs:domain ind:ContractServiceCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceLatitude rdf:type rdf:Property ;
    rdfs:label 'Service Latitude' ;
    rdfs:comment 'Geographic latitude coordinate of the service delivery location for route optimization and GPS tracking.' ;
    rdfs:domain ind:ContractServiceCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceLongitude rdf:type rdf:Property ;
    rdfs:label 'Service Longitude' ;
    rdfs:comment 'Geographic longitude coordinate of the service delivery location for route optimization and GPS tracking.' ;
    rdfs:domain ind:ContractServiceCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceStartTime rdf:type rdf:Property ;
    rdfs:label 'Service Start Time' ;
    rdfs:comment 'Preferred or contracted start time window for service delivery (e.g., 06:00-08:00).' ;
    rdfs:domain ind:ContractServiceCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:serviceStateProvince rdf:type rdf:Property ;
    rdfs:label 'Service State Province' ;
    rdfs:comment 'State or province where the service is delivered.' ;
    rdfs:domain ind:ContractServiceCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaResolutionTimeHours rdf:type rdf:Property ;
    rdfs:label 'Sla Resolution Time Hours' ;
    rdfs:comment 'Maximum number of hours committed to resolve service issues under this commitment.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Terminated Timestamp' ;
    rdfs:comment 'Timestamp when the service commitment was terminated or cancelled.' ;
    rdfs:domain ind:ContractServiceCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:segmentId rdf:type rdf:Property ;
    rdfs:label 'Segment Id' ;
    rdfs:comment 'Foreign key linking to customer.customer_segment. Business justification: SLA terms vary by customer segment (residential 48hr vs commercial 24hr vs municipal 4hr response). Segment linkage enables segment-specific SLA template application, performance benchmarking, and aut' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:slaDefinitionId rdf:type rdf:Property ;
    rdfs:label 'Sla Definition Id' ;
    rdfs:comment 'Foreign key linking to service.sla_definition. Business justification: Contract SLA terms should reference standard service-level definitions for consistency and template application. Needed for SLA performance measurement standardization, penalty calculation automation,' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SlaDefinition .

ind:baselinePeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Baseline Period End Date' ;
    rdfs:comment 'The end date of the period used to establish the baseline performance value.' ;
    rdfs:domain ind:SlaTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:baselinePeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Baseline Period Start Date' ;
    rdfs:comment 'The start date of the period used to establish the baseline performance value.' ;
    rdfs:domain ind:SlaTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:baselineValue rdf:type rdf:Property ;
    rdfs:label 'Baseline Value' ;
    rdfs:comment 'The historical or initial performance level used as a reference point for measuring improvement or setting targets.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:escalationThresholdValue rdf:type rdf:Property ;
    rdfs:label 'Escalation Threshold Value' ;
    rdfs:comment 'The performance level that triggers escalation procedures or management notification (typically worse than the target threshold).' ;
    rdfs:domain ind:SlaTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exclusionConditions rdf:type rdf:Property ;
    rdfs:label 'Exclusion Conditions' ;
    rdfs:comment 'Circumstances under which the SLA obligation does not apply (e.g., force majeure events, customer-caused delays, extreme weather, equipment failure beyond control, regulatory shutdowns).' ;
    rdfs:domain ind:SlaTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementFrequency rdf:type rdf:Property ;
    rdfs:label 'Measurement Frequency' ;
    rdfs:comment 'How often the SLA metric is measured and evaluated (daily, weekly, monthly, quarterly, annually, per incident, continuous). [ENUM-REF-CANDIDATE: daily|weekly|monthly|quarterly|annually|per_incident|continuous — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SlaTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Measurement Period Days' ;
    rdfs:comment 'The rolling or fixed period in days over which the SLA metric is calculated (e.g., 30 for monthly rolling average, 90 for quarterly).' ;
    rdfs:domain ind:SlaTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:penaltyCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Penalty Calculation Method' ;
    rdfs:comment 'Description of how the penalty is calculated (e.g., flat fee per incident, percentage of monthly service fee, tiered based on severity, prorated by days of non-compliance).' ;
    rdfs:domain ind:SlaTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyProvisionFlag rdf:type rdf:Property ;
    rdfs:label 'Penalty Provision Flag' ;
    rdfs:comment 'Indicates whether financial penalties or service credits apply for non-compliance with this SLA term (True if penalties exist, False otherwise).' ;
    rdfs:domain ind:SlaTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:penaltyType rdf:type rdf:Property ;
    rdfs:label 'Penalty Type' ;
    rdfs:comment 'The type of penalty or remedy applied when the SLA is not met (service credit, financial penalty, rate reduction, contract termination right, none).' ;
    rdfs:domain ind:SlaTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingFormat rdf:type rdf:Property ;
    rdfs:label 'Reporting Format' ;
    rdfs:comment 'The format in which SLA performance must be reported (e.g., PDF dashboard, Excel spreadsheet, online portal, email summary, API feed).' ;
    rdfs:domain ind:SlaTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Reporting Requirement Flag' ;
    rdfs:comment 'Indicates whether formal reporting of this SLA metric to the customer is required (True if reporting is mandatory, False otherwise).' ;
    rdfs:domain ind:SlaTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaCategory rdf:type rdf:Property ;
    rdfs:label 'Sla Category' ;
    rdfs:comment 'The category of SLA term grouping related performance obligations (collection performance, response time, service quality, safety compliance, environmental compliance, customer satisfaction).' ;
    rdfs:domain ind:SlaTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaMetricCode rdf:type rdf:Property ;
    rdfs:label 'Sla Metric Code' ;
    rdfs:comment 'Standardized code for the SLA metric to enable consistent tracking and reporting across contracts.' ;
    rdfs:domain ind:SlaTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaMetricName rdf:type rdf:Property ;
    rdfs:label 'Sla Metric Name' ;
    rdfs:comment 'The name of the performance metric being measured (e.g., On-Time Collection Rate, Missed Pickup Response Time, Container Delivery Lead Time, Complaint Resolution Time, Contamination Notification Time).' ;
    rdfs:domain ind:SlaTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTermStatus rdf:type rdf:Property ;
    rdfs:label 'Sla Term Status' ;
    rdfs:comment 'Current lifecycle status of the SLA term (active, suspended, expired, superseded, draft, cancelled).' ;
    rdfs:domain ind:SlaTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetThresholdValue rdf:type rdf:Property ;
    rdfs:label 'Target Threshold Value' ;
    rdfs:comment 'The numeric target value that must be met or exceeded to satisfy the SLA obligation (e.g., 98.5 for 98.5% on-time rate, 4 for 4-hour response time).' ;
    rdfs:domain ind:SlaTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:thresholdOperator rdf:type rdf:Property ;
    rdfs:label 'Threshold Operator' ;
    rdfs:comment 'The comparison operator defining how actual performance is evaluated against the target (greater than or equal, less than or equal, equal, greater than, less than).' ;
    rdfs:domain ind:SlaTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Threshold Unit Of Measure' ;
    rdfs:comment 'The unit of measurement for the target threshold (percentage, hours, days, minutes, count, tons, cubic yards). [ENUM-REF-CANDIDATE: percentage|hours|days|minutes|count|tons|cubic_yards — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SlaTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationId rdf:type rdf:Property ;
    rdfs:label 'Termination Id' ;
    rdfs:comment 'Unique identifier for the contract termination event. Primary key.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:churnClassification rdf:type rdf:Property ;
    rdfs:label 'Churn Classification' ;
    rdfs:comment 'Classification of customer churn type for analytics and retention program targeting. Voluntary churn: customer chose to leave. Involuntary churn: terminated by company (non-payment, breach). Natural expiration: contract ended without renewal. Regulatory churn: regulatory requirement forced termination.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractValueLost rdf:type rdf:Property ;
    rdfs:label 'Contract Value Lost' ;
    rdfs:comment 'Estimated annual recurring revenue lost due to contract termination in USD. Calculated from contract billing rate and service frequency. Used for revenue loss analysis and churn impact reporting.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:earlyTerminationFlag rdf:type rdf:Property ;
    rdfs:label 'Early Termination Flag' ;
    rdfs:comment 'Indicates whether the contract is being terminated before its natural expiration date. True: early termination (may trigger penalties). False: termination at contract end date.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:earlyTerminationPenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Early Termination Penalty Amount' ;
    rdfs:comment 'Financial penalty assessed for early contract termination per contract terms. Amount in USD. Null if no penalty applies or termination is at natural contract end.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:effectiveTerminationDate rdf:type rdf:Property ;
    rdfs:label 'Effective Termination Date' ;
    rdfs:comment 'Date when the contract termination becomes legally effective and service obligations cease. Calculated from notice date plus required notice period, or as mutually agreed.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:equipmentRetrievalDate rdf:type rdf:Property ;
    rdfs:label 'Equipment Retrieval Date' ;
    rdfs:comment 'Date when company-owned equipment was retrieved from customer site. Used to track asset recovery and close out termination process. Null if no equipment retrieval required.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:equipmentRetrievalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Equipment Retrieval Required Flag' ;
    rdfs:comment 'Indicates whether company-owned equipment (containers, compactors, bins) must be retrieved from customer site. True: retrieval required. False: no equipment to retrieve or customer-owned equipment.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:equipmentRetrievalStatus rdf:type rdf:Property ;
    rdfs:label 'Equipment Retrieval Status' ;
    rdfs:comment 'Current status of equipment retrieval process. Not required: no equipment to retrieve. Scheduled: retrieval appointment set. In progress: retrieval underway. Completed: all equipment recovered. Customer retained: customer purchased equipment. Lost: equipment not recoverable.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exitFeedbackSummary rdf:type rdf:Property ;
    rdfs:label 'Exit Feedback Summary' ;
    rdfs:comment 'Summary of customer feedback from exit interview. Captures key concerns, service issues, and improvement suggestions. Used for service quality improvement and retention strategy development.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exitInterviewCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Exit Interview Completed Flag' ;
    rdfs:comment 'Indicates whether an exit interview or customer feedback survey was completed. True: feedback collected. False: no feedback obtained. Used to assess data quality for churn analysis.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exitInterviewDate rdf:type rdf:Property ;
    rdfs:label 'Exit Interview Date' ;
    rdfs:comment 'Date when exit interview or customer feedback survey was conducted. Null if no exit interview completed.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:finalBillingDate rdf:type rdf:Property ;
    rdfs:label 'Final Billing Date' ;
    rdfs:comment 'Date when the final invoice for the terminated contract was generated. Includes prorated charges, outstanding balances, and any termination penalties.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:finalInvoiceAmount rdf:type rdf:Property ;
    rdfs:label 'Final Invoice Amount' ;
    rdfs:comment 'Total amount of the final invoice for the terminated contract in USD. Includes prorated service charges, outstanding balances, penalties, and any credits or adjustments.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:finalPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Final Payment Date' ;
    rdfs:comment 'Date when final payment was received and account was settled. Null if final payment not yet received or account written off.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:finalPaymentReceivedFlag rdf:type rdf:Property ;
    rdfs:label 'Final Payment Received Flag' ;
    rdfs:comment 'Indicates whether final payment has been received and account is settled. True: final payment received, account closed. False: outstanding balance remains.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:finalServiceDate rdf:type rdf:Property ;
    rdfs:label 'Final Service Date' ;
    rdfs:comment 'Date of the last service delivery (pickup, haul, disposal) under the terminated contract. Used to determine final billing period and service completion.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:initiatedBy rdf:type rdf:Property ;
    rdfs:label 'Initiated By' ;
    rdfs:comment 'Party that initiated the contract termination. Customer: customer requested termination. Waste Management: company initiated termination. Mutual: both parties agreed to terminate. Regulatory authority: termination mandated by regulatory body.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noticePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Notice Period Days' ;
    rdfs:comment 'Number of days notice required per contract terms before termination becomes effective. Typically 30, 60, or 90 days for commercial contracts. Used to validate notice compliance.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:npsScore rdf:type rdf:Property ;
    rdfs:label 'Nps Score' ;
    rdfs:comment 'Customer Net Promoter Score (NPS) at time of termination, scale 0-10. Measures customer satisfaction and likelihood to recommend. Used to correlate satisfaction with churn drivers.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:outstandingBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Outstanding Balance Amount' ;
    rdfs:comment 'Total unpaid balance on the customer account at time of termination in USD. Includes past due invoices and current charges. Used for collections and write-off decisions.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyWaivedFlag rdf:type rdf:Property ;
    rdfs:label 'Penalty Waived Flag' ;
    rdfs:comment 'Indicates whether early termination penalty was waived by management approval. True: penalty waived. False: penalty enforced. Used for revenue impact analysis and customer retention decisions.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:penaltyWaiverReason rdf:type rdf:Property ;
    rdfs:label 'Penalty Waiver Reason' ;
    rdfs:comment 'Business justification for waiving early termination penalty. Examples: customer hardship, service failure, competitive retention, regulatory requirement. Null if penalty not waived.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedTerminationDate rdf:type rdf:Property ;
    rdfs:label 'Requested Termination Date' ;
    rdfs:comment 'Date requested by the customer or initiating party for contract termination. May differ from effective termination date due to notice period requirements or mutual negotiation.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:terminationNumber rdf:type rdf:Property ;
    rdfs:label 'Termination Number' ;
    rdfs:comment 'Business-facing unique identifier for the termination event. Format: TRM-YYYYMMDD sequence. Used in customer communications and internal tracking.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationStatus rdf:type rdf:Property ;
    rdfs:label 'Termination Status' ;
    rdfs:comment 'Current lifecycle status of the termination process. Pending: termination request received, under review. Notice given: formal termination notice issued. Approved: termination approved by management. Equipment retrieved: containers and equipment returned. Final billed: final invoice generated. Completed: all termination activities finished. Cancelled: termination request withdrawn. [ENUM-REF-CANDIDATE: pending|notice_given|approved|equipment_retrieved|final_billed|completed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationType rdf:type rdf:Property ;
    rdfs:label 'Termination Type' ;
    rdfs:comment 'Classification of the termination event by initiating party and legal basis. Voluntary cancellation: customer-initiated. Non-renewal expiration: contract expired without renewal. Breach termination: terminated due to contract violation. Regulatory termination: ended due to regulatory requirement. Mutual agreement: both parties agreed to end. Convenience termination: terminated per convenience clause.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:winBackCampaignCode rdf:type rdf:Property ;
    rdfs:label 'Win Back Campaign Code' ;
    rdfs:comment 'Reference to the marketing campaign targeting this churned customer for re-acquisition. Null if no win-back campaign assigned or customer not eligible.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:winBackEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Win Back Eligible Flag' ;
    rdfs:comment 'Indicates whether the customer is eligible for win-back marketing programs. True: eligible for retention offers. False: not eligible (breach, fraud, regulatory). Used to target re-acquisition campaigns.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:volumeCommitmentId rdf:type rdf:Property ;
    rdfs:label 'Volume Commitment Id' ;
    rdfs:comment 'Unique identifier for the volume commitment record. Primary key.' ;
    rdfs:domain ind:VolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualVolumeToDate rdf:type rdf:Property ;
    rdfs:label 'Actual Volume To Date' ;
    rdfs:comment 'Cumulative actual volume delivered or processed within the current measurement period. Updated continuously from load tickets, scale transactions, and haul manifests. Compared against committed quantity to calculate variance and trigger alerts.' ;
    rdfs:domain ind:VolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commitmentDirection rdf:type rdf:Property ;
    rdfs:label 'Commitment Direction' ;
    rdfs:comment 'Identifies the party making the volume commitment. Customer-to-WM: customer guarantees to deliver minimum volume to WM facility (common for landfill disposal contracts). WM-to-customer: WM guarantees capacity or service availability. WM-to-third-party: WM commits to deliver volume to external disposal facility. Third-party-to-WM: external hauler commits to deliver volume to WM facility.' ;
    rdfs:domain ind:VolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentType rdf:type rdf:Property ;
    rdfs:label 'Commitment Type' ;
    rdfs:comment 'Classification of the volume commitment structure. Minimum volume requires customer to deliver a floor quantity; tonnage guarantee commits WM to accept a minimum; take-or-pay obligates payment regardless of delivery; capacity reservation holds disposal capacity; throughput commitment guarantees processing volume; load guarantee commits to a number of hauls or loads.' ;
    rdfs:domain ind:VolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:committedQuantity rdf:type rdf:Property ;
    rdfs:label 'Committed Quantity' ;
    rdfs:comment 'The minimum or guaranteed volume quantity specified in the commitment. Represents the floor volume (for customer commitments) or ceiling capacity (for WM guarantees). Used as the baseline for shortfall and excess calculations.' ;
    rdfs:domain ind:VolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:excessTonnageRate rdf:type rdf:Property ;
    rdfs:label 'Excess Tonnage Rate' ;
    rdfs:comment 'The pricing rate applied to volume delivered above the committed quantity. May be discounted (incentive for over-delivery) or premium (capacity constraint surcharge). Expressed in currency per unit of measure. Null if standard rates apply to excess volume.' ;
    rdfs:domain ind:VolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forceMajeureApplicable rdf:type rdf:Property ;
    rdfs:label 'Force Majeure Applicable' ;
    rdfs:comment 'Indicates whether force majeure provisions (natural disasters, strikes, regulatory shutdowns) suspend or modify the volume commitment obligations. True means commitment is waived during qualifying events; false means commitment remains in force regardless of external circumstances.' ;
    rdfs:domain ind:VolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastTrueUpAmount rdf:type rdf:Property ;
    rdfs:label 'Last True Up Amount' ;
    rdfs:comment 'The financial adjustment (penalty or excess charge) calculated at the most recent true-up. Positive values represent charges to customer; negative values represent credits. Used for revenue recognition and accounts receivable management.' ;
    rdfs:domain ind:VolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastTrueUpDate rdf:type rdf:Property ;
    rdfs:label 'Last True Up Date' ;
    rdfs:comment 'The date of the most recent volume reconciliation and true-up calculation. Used to track billing cycles and ensure timely reconciliation. Updated after each true-up process completes.' ;
    rdfs:domain ind:VolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastTrueUpVariance rdf:type rdf:Property ;
    rdfs:label 'Last True Up Variance' ;
    rdfs:comment 'The variance quantity calculated at the most recent true-up. Provides historical performance context and trend analysis. Used for forecasting and contract renegotiation discussions.' ;
    rdfs:domain ind:VolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementPeriod rdf:type rdf:Property ;
    rdfs:label 'Measurement Period' ;
    rdfs:comment 'The time interval over which the committed quantity is measured and evaluated. Daily commitments are common for Tons Per Day (TPD) contracts; monthly for MSW hauling; quarterly or annual for large municipal or commercial agreements; contract term for total lifecycle commitments.' ;
    rdfs:domain ind:VolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextTrueUpDate rdf:type rdf:Property ;
    rdfs:label 'Next True Up Date' ;
    rdfs:comment 'The scheduled date for the next volume reconciliation and true-up calculation. Used to trigger billing workflows and variance reporting. Updated after each true-up cycle.' ;
    rdfs:domain ind:VolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:notificationThresholdPercentage rdf:type rdf:Property ;
    rdfs:label 'Notification Threshold Percentage' ;
    rdfs:comment 'The variance percentage threshold that triggers automated alerts to account managers and customers. For example, 80% means alert when actual volume reaches 80% of committed quantity (risk of shortfall) or exceeds 120% (capacity constraint). Used for proactive contract management.' ;
    rdfs:domain ind:VolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shortfallPenaltyRate rdf:type rdf:Property ;
    rdfs:label 'Shortfall Penalty Rate' ;
    rdfs:comment 'The financial penalty rate applied per unit when actual volume delivered falls below the committed quantity. Expressed in currency per unit of measure (e.g., dollars per ton below minimum). Core component of take-or-pay economics. Null if no penalty applies.' ;
    rdfs:domain ind:VolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trueUpFrequency rdf:type rdf:Property ;
    rdfs:label 'True Up Frequency' ;
    rdfs:comment 'The frequency at which actual volume is reconciled against committed volume and shortfall penalties or excess charges are calculated and invoiced. Monthly true-ups provide frequent reconciliation; annual true-ups are common for large municipal contracts; contract-end true-ups settle the entire term at close.' ;
    rdfs:domain ind:VolumeCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountDocumentId rdf:type rdf:Property ;
    rdfs:label 'Account Document Id' ;
    rdfs:comment 'Unique system-generated surrogate key identifying each account document record in the Waste Management customer domain. Primary key for the account_document data product.' ;
    rdfs:domain ind:AccountDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contactId rdf:type rdf:Property ;
    rdfs:label 'Contact Id' ;
    rdfs:comment 'Reference to the specific contact person associated with this document (e.g., the signatory on a service agreement or the authorized representative who submitted a tax exemption certificate). Nullable when the document is account-level rather than contact-specific.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:epaIdRegistrationId rdf:type rdf:Property ;
    rdfs:label 'Epa Id Registration Id' ;
    rdfs:comment 'Foreign key linking to hazmat.epa_id_registration. Business justification: Permits, EPA notifications, certifications, and regulatory correspondence stored as account documents must link to specific EPA ID registrations for compliance audit trails, renewal tracking, and regu' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EpaIdRegistration .

ind:supersededByDocumentAccountDocumentId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Document Account Document Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the newer account_document record that replaced this document when document_status is \'superseded\'. Enables navigation of the document version chain for audit and compliance purposes.' ;
    rdfs:domain ind:AccountDocument ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccountDocument .

ind:daysUntilExpiration rdf:type rdf:Property ;
    rdfs:label 'Days Until Expiration' ;
    rdfs:comment 'Number of calendar days remaining until the document expires, calculated at the time of last refresh. Used by compliance monitoring dashboards and automated renewal notification workflows to prioritize documents requiring action. Negative values indicate the document is already expired.' ;
    rdfs:domain ind:AccountDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:documentCategory rdf:type rdf:Property ;
    rdfs:label 'Document Category' ;
    rdfs:comment 'Broad grouping of the document for reporting and retention management. Compliance documents are subject to EPA/RCRA/DOT retention mandates; contractual documents are governed by SOX and GAAP; financial documents are subject to IFRS/GAAP audit requirements.' ;
    rdfs:domain ind:AccountDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentSource rdf:type rdf:Property ;
    rdfs:label 'Document Source' ;
    rdfs:comment 'Channel or system through which the document was received or uploaded (e.g., Salesforce CRM, Waste Logics customer portal, SAP S/4HANA, Enviance EHS, email submission, physical mail). Used for intake workflow routing and source system traceability. [ENUM-REF-CANDIDATE: salesforce_crm|waste_logics|sap_s4hana|enviance_ehs|email|mail|fax|in_person — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AccountDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentTitle rdf:type rdf:Property ;
    rdfs:label 'Document Title' ;
    rdfs:comment 'Human-readable title or name of the document as it appears on the file (e.g., \'Commercial Waste Service Agreement – Acme Corp\', \'EPA Hazardous Waste Generator Registration\', \'Tax Exemption Certificate – City of Houston\'). Used for display and search in the customer portal and CRM.' ;
    rdfs:domain ind:AccountDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentType rdf:type rdf:Property ;
    rdfs:label 'Document Type' ;
    rdfs:comment 'Classification of the document by its business purpose. Drives workflow routing, retention rules, and compliance checks. [ENUM-REF-CANDIDATE: service_agreement|tax_exemption_certificate|proof_of_identity|municipal_franchise|hazardous_waste_generator_registration|correspondence|permit|bill_of_lading|manifest|rate_schedule|insurance_certificate|power_of_attorney — promote to reference product]' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esignatureProvider rdf:type rdf:Property ;
    rdfs:label 'Esignature Provider' ;
    rdfs:comment 'Name of the electronic signature platform used to execute the document (e.g., DocuSign, Adobe Sign). Nullable when is_electronic_signature is False. Used for audit trail and legal enforceability documentation.' ;
    rdfs:domain ind:AccountDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileFormat rdf:type rdf:Property ;
    rdfs:label 'File Format' ;
    rdfs:comment 'Format or MIME type of the stored document file. Used to determine rendering capability in the customer portal and to enforce format compliance policies (e.g., regulatory submissions may require PDF/A). [ENUM-REF-CANDIDATE: PDF|DOCX|XLSX|JPEG|PNG|TIFF|XML — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AccountDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileName rdf:type rdf:Property ;
    rdfs:label 'File Name' ;
    rdfs:comment 'Original file name of the uploaded document including extension (e.g., \'acme_corp_service_agreement_2024.pdf\'). Preserved for audit trail and user-facing display in the Waste Logics customer portal.' ;
    rdfs:domain ind:AccountDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileSizeKb rdf:type rdf:Property ;
    rdfs:label 'File Size Kb' ;
    rdfs:comment 'Size of the document file in kilobytes at the time of upload. Used for storage capacity planning and to enforce maximum file size policies in the customer portal and document management system.' ;
    rdfs:domain ind:AccountDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fileUri rdf:type rdf:Property ;
    rdfs:label 'File Uri' ;
    rdfs:comment 'Storage path or URI pointing to the physical document file in the enterprise content management system or cloud object store (e.g., Azure Data Lake Storage, S3 bucket path, SharePoint URL). Enables retrieval of the actual document for review, compliance audit, or customer portal display.' ;
    rdfs:domain ind:AccountDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isElectronicSignature rdf:type rdf:Property ;
    rdfs:label 'Is Electronic Signature' ;
    rdfs:comment 'Indicates whether the document was executed via electronic signature (True) or wet ink/physical signature (False). Relevant for legal enforceability under the ESIGN Act and UETA, and for audit trail completeness.' ;
    rdfs:domain ind:AccountDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLatestVersion rdf:type rdf:Property ;
    rdfs:label 'Is Latest Version' ;
    rdfs:comment 'Indicates whether this document record represents the most current version of the document for the account. True when this is the active version; False when superseded by a newer version. Supports efficient querying for current documents without filtering on version_number.' ;
    rdfs:domain ind:AccountDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRegulatoryRequired rdf:type rdf:Property ;
    rdfs:label 'Is Regulatory Required' ;
    rdfs:comment 'Indicates whether this document is mandated by a regulatory authority (True) or is a voluntary/operational document (False). Regulatory-required documents (e.g., RCRA generator registrations, EPA permits, DOT hazmat certifications) trigger compliance alerts if missing or expired.' ;
    rdfs:domain ind:AccountDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSigned rdf:type rdf:Property ;
    rdfs:label 'Is Signed' ;
    rdfs:comment 'Indicates whether the document has been formally signed or executed (True) or is still in draft/unsigned state (False). Critical for service agreement activation workflows and onboarding completion checks in Salesforce CRM.' ;
    rdfs:domain ind:AccountDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuingAuthority rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority' ;
    rdfs:comment 'Name of the governmental agency, regulatory body, or organization that issued or authorized the document (e.g., \'U.S. EPA Region 6\', \'Texas Commission on Environmental Quality\', \'City of Houston Public Works\', \'IRS\'). Critical for regulatory compliance tracking and permit management.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Issuing Jurisdiction' ;
    rdfs:comment 'Geographic jurisdiction under which the document was issued (e.g., state code \'TX\', \'CA\', or federal \'US-FED\'). Used for multi-state compliance reporting and to route documents to the appropriate regulatory compliance team.' ;
    rdfs:domain ind:AccountDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purgeEligibleDate rdf:type rdf:Property ;
    rdfs:label 'Purge Eligible Date' ;
    rdfs:comment 'Date on or after which the document may be legally purged or destroyed per the applicable retention policy. Calculated from the document\'s effective or expiration date plus the retention_period_years. Prevents premature destruction of compliance-critical records.' ;
    rdfs:domain ind:AccountDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalLeadDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Lead Days' ;
    rdfs:comment 'Number of calendar days before expiration_date at which the renewal notification and workflow should be triggered. Configurable per document type (e.g., 90 days for municipal franchise agreements, 30 days for tax exemption certificates). Used by the compliance calendar in Enviance EHS.' ;
    rdfs:domain ind:AccountDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:renewalRequired rdf:type rdf:Property ;
    rdfs:label 'Renewal Required' ;
    rdfs:comment 'Indicates whether this document requires proactive renewal before expiration (True) or is a one-time document with no renewal obligation (False). Drives renewal workflow initiation in Enviance EHS and Salesforce CRM task management.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewedBy rdf:type rdf:Property ;
    rdfs:label 'Reviewed By' ;
    rdfs:comment 'Name or employee identifier of the Waste Management staff member who reviewed and validated the document for completeness and compliance. Used for internal audit trail and accountability tracking.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Source System Document Reference' ;
    rdfs:comment 'Original document identifier from the upstream source system (e.g., Salesforce CRM ContentDocument ID, SAP DMS document key, Enviance EHS permit record ID). Enables cross-system reconciliation and lineage tracing.' ;
    rdfs:domain ind:AccountDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExemptionNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Exemption Number' ;
    rdfs:comment 'Government-issued tax exemption certificate number for accounts exempt from sales tax on waste services (e.g., municipal governments, non-profit organizations). Nullable for non-exempt accounts. Used by Oracle Revenue Management for tax calculation and billing.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExemptionType rdf:type rdf:Property ;
    rdfs:label 'Tax Exemption Type' ;
    rdfs:comment 'Classification of the tax exemption basis (e.g., federal government, state government, municipal, non-profit). Drives tax calculation logic in Oracle Revenue Management and determines applicable billing rates.' ;
    rdfs:domain ind:AccountDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uploadDate rdf:type rdf:Property ;
    rdfs:label 'Upload Date' ;
    rdfs:comment 'Calendar date on which the document was uploaded or ingested into the document management system. Distinct from the document\'s own effective date. Used for onboarding workflow tracking and SLA compliance.' ;
    rdfs:domain ind:AccountDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accountHierarchyId rdf:type rdf:Property ;
    rdfs:label 'Account Hierarchy Id' ;
    rdfs:comment 'Unique surrogate identifier for each account hierarchy relationship record in the Waste Management customer account structure. Primary key for this entity.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:childAccountCustomerAccountId rdf:type rdf:Property ;
    rdfs:label 'Child Account Customer Account Id' ;
    rdfs:comment 'Identifier of the child (subordinate) account in this hierarchy relationship. Represents the site, subsidiary, or district that rolls up to the parent account for consolidated reporting and billing.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerAccount .

ind:parentEpaIdRegistrationId rdf:type rdf:Property ;
    rdfs:label 'Parent Epa Id Registration Id' ;
    rdfs:comment 'Foreign key linking to hazmat.epa_id_registration. Business justification: Corporate hierarchies with multiple EPA IDs require tracking parent-subsidiary generator relationships for consolidated biennial reporting, liability allocation, and multi-site permit management. Supp' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EpaIdRegistration .

ind:primaryCustomerAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Customer Account Id' ;
    rdfs:comment 'Identifier of the parent account in this hierarchy relationship. References the customer account that sits above the child in the corporate, franchise, or municipal umbrella structure.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerAccount .

ind:consolidatedBillingFlag rdf:type rdf:Property ;
    rdfs:label 'Consolidated Billing Flag' ;
    rdfs:comment 'Indicates whether invoices for the child account are consolidated and issued at the parent account level rather than individually at the child site level. True enables enterprise-level consolidated billing for national accounts and municipal umbrella contracts.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consolidatedReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Consolidated Reporting Flag' ;
    rdfs:comment 'Indicates whether operational and environmental compliance reports (e.g., diversion rates, tonnage, GHG emissions) for the child account are aggregated and reported at the parent account level. Supports enterprise sustainability reporting and national account KPI dashboards.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hierarchyCode rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this hierarchy relationship, used in cross-system references and national account management communications. Sourced from Salesforce CRM account hierarchy records.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyDepth rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Depth' ;
    rdfs:comment 'Numeric depth of the child account within the hierarchy tree, where 1 represents a direct child of the ultimate parent. Supports tree traversal queries and enterprise reporting roll-ups for national account management.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hierarchyLevel rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Level' ;
    rdfs:comment 'Designates the positional level of the child account within the hierarchy structure. \'ultimate_parent\' is the root enterprise account, \'intermediate_parent\' is a mid-tier grouping (e.g., regional division), and \'child_site\' is the leaf-level service location.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyName rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Name' ;
    rdfs:comment 'Human-readable name for this hierarchy relationship or grouping, typically reflecting the corporate group, franchise network, or municipal contract name (e.g., \'Acme Corp National Account\', \'City of Houston Municipal District\'). Used in reporting and account management interfaces.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyPath rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Path' ;
    rdfs:comment 'Materialized path string representing the full ancestry chain from the ultimate parent to the child account (e.g., \'/10001/10045/10089\'). Enables efficient subtree queries and hierarchy traversal without recursive joins in the Databricks lakehouse.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyStatus rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Status' ;
    rdfs:comment 'Current lifecycle state of this hierarchy relationship. \'active\' indicates the relationship is in force, \'pending\' indicates awaiting approval or activation, \'suspended\' indicates temporarily paused, \'terminated\' indicates the relationship has ended, and \'inactive\' indicates administratively deactivated.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyType rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Type' ;
    rdfs:comment 'Classifies the structural purpose of this hierarchy. \'corporate\' reflects legal ownership structures, \'franchise\' reflects franchised operator networks, \'municipal\' reflects government contract groupings, \'geographic\' reflects territory-based groupings, and \'billing\' reflects consolidated billing arrangements independent of ownership.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nationalAccountFlag rdf:type rdf:Property ;
    rdfs:label 'National Account Flag' ;
    rdfs:comment 'Indicates whether this hierarchy relationship is part of a national account program, where a single corporate parent has service agreements spanning multiple geographic markets. Drives national account management workflows and pricing tier eligibility.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:relationshipType rdf:type rdf:Property ;
    rdfs:label 'Relationship Type' ;
    rdfs:comment 'Classifies the nature of the parent-child relationship. \'corporate_subsidiary\' applies to owned business entities, \'franchise\' to franchised operators, \'municipal_district\' to government umbrella contracts, \'multi_site_commercial\' to commercial customers with multiple service locations, and \'joint_venture\' to shared-ownership arrangements. [ENUM-REF-CANDIDATE: corporate_subsidiary|franchise|municipal_district|multi_site_commercial|joint_venture|other — promote to reference product]' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceRegionCode rdf:type rdf:Property ;
    rdfs:label 'Service Region Code' ;
    rdfs:comment 'Alphanumeric code identifying the Waste Management operational service region or district in which this hierarchy relationship is primarily managed. Supports regional performance reporting and operational territory alignment.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTier rdf:type rdf:Property ;
    rdfs:label 'Sla Tier' ;
    rdfs:comment 'Service Level Agreement tier applicable to this hierarchy relationship, determining response time commitments, service frequency guarantees, and escalation priorities across all child sites. \'enterprise\' and \'government\' tiers carry enhanced SLA obligations.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemHierarchyReference rdf:type rdf:Property ;
    rdfs:label 'Source System Hierarchy Reference' ;
    rdfs:comment 'The native identifier of this hierarchy relationship in the originating source system (e.g., Salesforce Account Hierarchy ID, SAP Customer Hierarchy Node ID). Enables traceability back to the system of record for reconciliation and audit purposes.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalChildSiteCount rdf:type rdf:Property ;
    rdfs:label 'Total Child Site Count' ;
    rdfs:comment 'Total number of active child service sites or accounts directly or indirectly subordinate to the parent account in this hierarchy. Maintained as a denormalized count to support national account management dashboards and contract scope validation without recursive queries.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountNoteId rdf:type rdf:Property ;
    rdfs:label 'Account Note Id' ;
    rdfs:comment 'Unique system-generated identifier for each account note record. Primary key for the account_note data product.' ;
    rdfs:domain ind:AccountNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryAccountAuthorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Account Author Employee Id' ;
    rdfs:comment 'Identifier of the employee (customer service representative, field operations staff, sales personnel, or system user) who created this note. Used for accountability, audit trails, and note ownership tracking.' ;
    rdfs:domain ind:AccountNote ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:relatedNoteAccountNoteId rdf:type rdf:Property ;
    rdfs:label 'Related Note Account Note Id' ;
    rdfs:comment 'Identifier of a parent or predecessor account note that this note supersedes, amends, or is related to. Enables note versioning and chaining of related instructions (e.g., an updated gate code note referencing the original).' ;
    rdfs:domain ind:AccountNote ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccountNote .

ind:tertiaryAccountAcknowledgedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Account Acknowledged By Employee Id' ;
    rdfs:comment 'Identifier of the field employee (driver or crew member) who most recently acknowledged this note prior to service execution. Used for safety compliance documentation.' ;
    rdfs:domain ind:AccountNote ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accessCode rdf:type rdf:Property ;
    rdfs:label 'Access Code' ;
    rdfs:comment 'Gate code, keypad combination, or access credential required to enter the service location. Stored as a structured field separate from note_text to enable targeted display in driver mobile apps and automated gate systems. Classified as confidential due to security sensitivity.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appliesToAllServices rdf:type rdf:Property ;
    rdfs:label 'Applies To All Services' ;
    rdfs:comment 'Indicates whether this note applies to all service types and lines at the associated account or address (True), or is scoped to a specific service line, container, or route as indicated by other fields (False). Drives note display logic in AMCS and Locus Dispatch.' ;
    rdfs:domain ind:AccountNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:authorName rdf:type rdf:Property ;
    rdfs:label 'Author Name' ;
    rdfs:comment 'Display name of the employee or system process that authored the note, captured at time of creation for audit and display purposes. Retained even if the employee record is later modified.' ;
    rdfs:domain ind:AccountNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorRole rdf:type rdf:Property ;
    rdfs:label 'Author Role' ;
    rdfs:comment 'Functional role of the note author at the time of creation. Supports filtering notes by originating function and enables role-based visibility rules. automated_system indicates notes generated by integration processes (e.g., SAP, AMCS, Enviance).' ;
    rdfs:domain ind:AccountNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Billing Reference Number' ;
    rdfs:comment 'Reference number of the invoice, billing dispute, or accounts receivable (AR) transaction in Oracle Revenue Management associated with this note, when note_type is billing_note. Enables traceability between billing annotations and financial transactions.' ;
    rdfs:domain ind:AccountNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Escalation Case Number' ;
    rdfs:comment 'Reference number of the customer escalation case in Salesforce CRM associated with this note, when note_type is escalation_note. Enables cross-referencing between account notes and formal complaint or escalation case management workflows.' ;
    rdfs:domain ind:AccountNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardType rdf:type rdf:Property ;
    rdfs:label 'Hazard Type' ;
    rdfs:comment 'Specific category of safety hazard documented in this note, when note_type is safety_alert. Enables targeted safety briefings and PPE (Personal Protective Equipment) requirements for field crews. [ENUM-REF-CANDIDATE: aggressive_animal|biohazard|chemical_exposure|weight_restriction|overhead_obstruction|unstable_ground|other — promote to reference product]' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPinned rdf:type rdf:Property ;
    rdfs:label 'Is Pinned' ;
    rdfs:comment 'Indicates whether this note is pinned to the top of the account note list, ensuring it is always prominently displayed to customer service representatives and field crews regardless of creation date. True = pinned; False = standard ordering.' ;
    rdfs:domain ind:AccountNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSafetyCritical rdf:type rdf:Property ;
    rdfs:label 'Is Safety Critical' ;
    rdfs:comment 'Indicates whether this note contains a safety-critical instruction or warning (e.g., aggressive dog, hazardous material on premises, weight-restricted access road, biohazard). Safety-critical notes trigger mandatory acknowledgment workflows in Locus Dispatch and AMCS before service execution.' ;
    rdfs:domain ind:AccountNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:languageCode rdf:type rdf:Property ;
    rdfs:label 'Language Code' ;
    rdfs:comment 'ISO 639-1 language code of the note text content (e.g., en, es, fr). Supports multilingual customer service operations in diverse service territories where notes may be authored in Spanish, English, or other languages.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAcknowledgedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Acknowledged Timestamp' ;
    rdfs:comment 'Date and time when this note was most recently acknowledged by a field crew member or driver via the Locus Dispatch or AMCS mobile application. Relevant for notes where requires_acknowledgment is True.' ;
    rdfs:domain ind:AccountNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastReviewedDate rdf:type rdf:Property ;
    rdfs:label 'Last Reviewed Date' ;
    rdfs:comment 'Date when this note was last reviewed by a supervisor or quality assurance process to confirm its accuracy and continued relevance. Supports note hygiene programs to prevent stale instructions from persisting in operational systems.' ;
    rdfs:domain ind:AccountNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:noteCategory rdf:type rdf:Property ;
    rdfs:label 'Note Category' ;
    rdfs:comment 'Broad functional category of the note indicating which business function originated or owns the note. Supports filtering and reporting by department. Values: operational (field ops), customer_service (CSR-generated), compliance (regulatory or EHS-related), sales (sales team annotation), field_operations (driver or field staff note), automated (system-generated note).' ;
    rdfs:domain ind:AccountNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noteNumber rdf:type rdf:Property ;
    rdfs:label 'Note Number' ;
    rdfs:comment 'Human-readable, externally referenceable business identifier for the account note, used in customer service correspondence and operational communications (e.g., NOTE-202400012345).' ;
    rdfs:domain ind:AccountNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noteStatus rdf:type rdf:Property ;
    rdfs:label 'Note Status' ;
    rdfs:comment 'Current lifecycle state of the account note. Active notes are visible to applicable audiences; expired notes have passed their expiration date; archived notes have been manually retired; superseded notes have been replaced by a newer version.' ;
    rdfs:domain ind:AccountNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noteSubject rdf:type rdf:Property ;
    rdfs:label 'Note Subject' ;
    rdfs:comment 'Short summary or title of the account note, providing a quick-scan description of the note content without requiring the full note text to be read. Used in list views and operational dashboards.' ;
    rdfs:domain ind:AccountNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noteText rdf:type rdf:Property ;
    rdfs:label 'Note Text' ;
    rdfs:comment 'Full free-form or structured text body of the account note. Contains the primary informational content such as special handling instructions, safety warnings, access codes, billing annotations, or escalation details. May contain sensitive operational information.' ;
    rdfs:domain ind:AccountNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noteType rdf:type rdf:Property ;
    rdfs:label 'Note Type' ;
    rdfs:comment 'Classification of the account note by its operational purpose. Drives routing, visibility, and urgency handling. Values: service_instruction (special handling for collection crews), billing_note (billing or payment-related annotation), safety_alert (hazard or safety warning such as aggressive dog or biohazard), access_instruction (gate codes, locked access, weight-restricted roads), escalation_note (customer complaint or escalated issue), general (unclassified free-form note).' ;
    rdfs:domain ind:AccountNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresAcknowledgment rdf:type rdf:Property ;
    rdfs:label 'Requires Acknowledgment' ;
    rdfs:comment 'Indicates whether field staff or drivers must explicitly acknowledge this note before performing service at the associated address. Used for safety alerts, access instructions, and compliance-related notes to ensure crew awareness.' ;
    rdfs:domain ind:AccountNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceLineType rdf:type rdf:Property ;
    rdfs:label 'Service Line Type' ;
    rdfs:comment 'The type of service line to which this note applies, enabling targeted display to relevant operational crews. Values align with Waste Management\'s core service lines: residential, commercial, industrial, municipal, hazardous_waste (RCRA-regulated), recycling (MRF-bound), wte (Waste-to-Energy). [ENUM-REF-CANDIDATE: residential|commercial|industrial|municipal|hazardous_waste|recycling|wte — promote to reference product]' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visibilityLevel rdf:type rdf:Property ;
    rdfs:label 'Visibility Level' ;
    rdfs:comment 'Controls which audiences can view this note. internal_only: visible only to back-office staff; field_visible: visible to field operations crews and drivers via mobile dispatch systems (Locus Dispatch, AMCS); customer_visible: visible to the customer via the Waste Logics customer portal.' ;
    rdfs:domain ind:AccountNote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountStatusHistoryId rdf:type rdf:Property ;
    rdfs:label 'Account Status History Id' ;
    rdfs:comment 'Unique surrogate identifier for each account status history record. Serves as the primary key for this immutable audit trail table.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:finalInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Final Invoice Id' ;
    rdfs:comment 'Reference to the final invoice generated upon account closure or suspension. Links to the Oracle Revenue Management billing system for final billing reconciliation, credit memo processing, and AR write-off procedures.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:primaryAccountEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Account Employee Id' ;
    rdfs:comment 'Reference to the internal user (employee or system service account) who initiated or executed this status transition. Supports audit trail and accountability requirements under SOX compliance.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:arBalanceAtTransition rdf:type rdf:Property ;
    rdfs:label 'Ar Balance At Transition' ;
    rdfs:comment 'The outstanding Accounts Receivable (AR) balance on the customer account at the exact moment of this status transition. Critical for non-payment suspension and closure analysis, collections prioritization, and bad debt provisioning under GAAP.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:collectionsReferralDate rdf:type rdf:Property ;
    rdfs:label 'Collections Referral Date' ;
    rdfs:comment 'The date on which the account was referred to the collections process following a non-payment suspension or closure. Applicable only for financially-driven status transitions. Supports AR aging analysis and bad debt provisioning under GAAP.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:containerRetrievalRequired rdf:type rdf:Property ;
    rdfs:label 'Container Retrieval Required' ;
    rdfs:comment 'Indicates whether Waste Management-owned containers (bins, dumpsters, roll-off containers) must be retrieved from the service address following this status transition. Triggers container retrieval work order creation in AMCS Platform.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:daysInPriorStatus rdf:type rdf:Property ;
    rdfs:label 'Days In Prior Status' ;
    rdfs:comment 'The number of calendar days the account remained in the prior status before this transition occurred. Supports customer lifecycle duration analysis, churn prediction modeling, and SLA compliance measurement.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:effectiveTimestamp rdf:type rdf:Property ;
    rdfs:label 'Effective Timestamp' ;
    rdfs:comment 'The precise date and time at which the new account status became operationally effective. This is the business event timestamp — distinct from the record audit timestamp — and is the authoritative time used for churn analysis, SLA measurement, and regulatory compliance reporting.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:hazardousWasteAccount rdf:type rdf:Property ;
    rdfs:label 'Hazardous Waste Account' ;
    rdfs:comment 'Indicates whether this account involves hazardous waste services subject to RCRA, DOT, and EPA regulatory requirements. Status transitions for hazardous waste accounts require additional regulatory documentation and notification procedures.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:initiatingSystem rdf:type rdf:Property ;
    rdfs:label 'Initiating System' ;
    rdfs:comment 'The operational system of record that originated or triggered this status transition event. Supports data lineage, integration audit trails, and root-cause analysis for unexpected status changes.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manifestClosureRequired rdf:type rdf:Property ;
    rdfs:label 'Manifest Closure Required' ;
    rdfs:comment 'Indicates whether a hazardous waste Manifest (the regulatory tracking document) must be formally closed or reconciled as part of this account status transition. Applicable only for hazardous waste accounts. Supports RCRA compliance and EPA enforcement documentation.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:newStatus rdf:type rdf:Property ;
    rdfs:label 'New Status' ;
    rdfs:comment 'The account lifecycle status immediately after this transition. Captures the \'to\' state in the status change event. Valid values mirror prior_status enumeration. [ENUM-REF-CANDIDATE: prospect|active|suspended|inactive|closed|pending_activation|pending_closure — promote to reference product]' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationChannel rdf:type rdf:Property ;
    rdfs:label 'Notification Channel' ;
    rdfs:comment 'The communication channel used to notify the customer of this status transition. Supports multi-channel communication audit trails and regulatory compliance with required notification method standards.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Notification Timestamp' ;
    rdfs:comment 'The date and time at which the customer notification for this status transition was sent. Supports regulatory compliance documentation for required advance notice periods (e.g., service termination notice requirements under state utility regulations).' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:priorStatus rdf:type rdf:Property ;
    rdfs:label 'Prior Status' ;
    rdfs:comment 'The account lifecycle status immediately before this transition occurred. Captures the \'from\' state in the status change event. Valid values: prospect (pre-service lead), active (receiving service), suspended (temporarily halted), inactive (service ended but record retained), closed (permanently terminated). [ENUM-REF-CANDIDATE: prospect|active|suspended|inactive|closed|pending_activation|pending_closure — promote to reference product]' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorStatusEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Prior Status Effective Date' ;
    rdfs:comment 'The date on which the prior status originally became effective. Combined with effective_timestamp, enables precise calculation of duration in prior status for lifecycle analytics and SLA compliance measurement.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reactivationEligible rdf:type rdf:Property ;
    rdfs:label 'Reactivation Eligible' ;
    rdfs:comment 'Indicates whether the account is eligible for reactivation following this status transition. Set to False for deceased customers, regulatory closures, or fraud-related closures. Supports win-back campaign targeting and collections recovery workflows.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryActionReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Action Reference' ;
    rdfs:comment 'Reference number or identifier for any regulatory enforcement action, permit violation notice, or compliance order that directly caused this status transition. Applicable for regulatory-driven account closures or suspensions. Supports RCRA, EPA, and state environmental agency compliance documentation.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceTerritoryCode rdf:type rdf:Property ;
    rdfs:label 'Service Territory Code' ;
    rdfs:comment 'The Waste Management service territory or district code associated with the account at the time of this status transition. Supports geographic churn analysis, route optimization impact assessment, and regional regulatory compliance reporting.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaBreach rdf:type rdf:Property ;
    rdfs:label 'Sla Breach' ;
    rdfs:comment 'Indicates whether this status transition occurred in breach of a contractual Service Level Agreement (SLA), such as a failure to reactivate service within the committed timeframe or a suspension applied without required advance notice. Supports SLA compliance monitoring and contract penalty calculations.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:suspensionReasonCategory rdf:type rdf:Property ;
    rdfs:label 'Suspension Reason Category' ;
    rdfs:comment 'High-level category for suspension-specific transitions, providing a structured classification above the detailed reason_code. Applicable only when new_status is \'suspended\'. Supports regulatory reporting and collections workflow routing.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transitionType rdf:type rdf:Property ;
    rdfs:label 'Transition Type' ;
    rdfs:comment 'Categorizes how the status transition was initiated: manual (agent or user action), system_automated (triggered by billing engine, collections workflow, or scheduled job), bulk_update (mass data migration or batch operation), or regulatory (mandated by a regulatory authority or compliance requirement).' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:winBackEligibleDate rdf:type rdf:Property ;
    rdfs:label 'Win Back Eligible Date' ;
    rdfs:comment 'The earliest date on which a closed or inactive account becomes eligible for win-back outreach campaigns. May be set based on cooling-off periods, debt clearance timelines, or business rules. Supports Salesforce CRM marketing campaign targeting.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:writeOffAmount rdf:type rdf:Property ;
    rdfs:label 'Write Off Amount' ;
    rdfs:comment 'The dollar amount of outstanding AR balance written off as uncollectable at the time of account closure. Applicable only for closure transitions with unrecoverable debt. Supports GAAP bad debt expense recognition and SOX financial controls.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:communicationPreferenceId rdf:type rdf:Property ;
    rdfs:label 'Communication Preference Id' ;
    rdfs:comment 'Unique surrogate identifier for each communication preference record. Primary key for the communication_preference data product in the customer domain.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:billingAlertOptIn rdf:type rdf:Property ;
    rdfs:label 'Billing Alert Opt In' ;
    rdfs:comment 'Indicates whether the customer has opted in to receive billing-related alerts such as invoice generation, payment due reminders, and payment confirmation notifications. Supports Oracle Revenue Management billing communication workflows.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consentDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Consent Document Reference' ;
    rdfs:comment 'Reference identifier for the consent document, contract clause, or recorded call that evidences the consent. For paper forms, this is the document scan ID; for contracts, this is the contract number and clause reference; for recorded calls, this is the call recording ID.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Consent Expiry Date' ;
    rdfs:comment 'The date on which the recorded consent expires and must be re-obtained. Applicable where regulatory or business policy requires periodic consent renewal. Null indicates consent does not expire under current policy.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consentIpAddress rdf:type rdf:Property ;
    rdfs:label 'Consent Ip Address' ;
    rdfs:comment 'The IP address from which the customer submitted their consent (e.g., via the Waste Logics customer portal or email signup form). Provides technical evidence of consent origin for regulatory audit purposes. Classified as confidential PII as IP addresses may identify individuals in some jurisdictions.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentMethod rdf:type rdf:Property ;
    rdfs:label 'Consent Method' ;
    rdfs:comment 'The legal mechanism by which consent was obtained. \'express_written\' is required for TCPA-regulated SMS and autodialed calls. \'double_opt_in\' provides the strongest evidence of consent for email marketing. Drives compliance reporting and legal defensibility.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentSource rdf:type rdf:Property ;
    rdfs:label 'Consent Source' ;
    rdfs:comment 'The system or touchpoint through which consent was captured. [ENUM-REF-CANDIDATE: customer_portal|salesforce_crm|paper_form|ivr|mobile_app|service_call|email_signup|contract_signature|third_party — promote to reference product]' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentStatus rdf:type rdf:Property ;
    rdfs:label 'Consent Status' ;
    rdfs:comment 'Current regulatory consent status for the specified channel and notification type. \'granted\' indicates valid consent is on file; \'revoked\' indicates consent was withdrawn; \'pending\' indicates awaiting confirmation (double opt-in); \'expired\' indicates consent has lapsed per retention policy; \'not_required\' applies to transactional communications exempt from consent requirements.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Consent Timestamp' ;
    rdfs:comment 'The exact date and time when the customer or contact granted, revoked, or updated consent for this channel and notification type. Critical audit field for TCPA and CAN-SPAM compliance. Stored in ISO 8601 format with timezone offset.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:contactFrequency rdf:type rdf:Property ;
    rdfs:label 'Contact Frequency' ;
    rdfs:comment 'The customer or contact\'s preferred frequency for non-transactional outreach (e.g., promotional offers, NPS surveys, service updates). Transactional and compliance-driven communications (e.g., billing alerts, regulatory notices) are not subject to this frequency cap.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doNotCall rdf:type rdf:Property ;
    rdfs:label 'Do Not Call' ;
    rdfs:comment 'Specific suppression flag for telephone-based outreach (voice calls). Distinct from the master do_not_contact flag to allow granular channel-level suppression. Compliance with the National Do Not Call Registry and TCPA requirements.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:doNotContact rdf:type rdf:Property ;
    rdfs:label 'Do Not Contact' ;
    rdfs:comment 'Master suppression flag indicating the customer or contact must not be contacted through any channel. Overrides all individual channel and notification preferences. Must be honored across all outbound communication systems including Salesforce CRM, Oracle Revenue Management, and Waste Logics portal.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:doNotEmail rdf:type rdf:Property ;
    rdfs:label 'Do Not Email' ;
    rdfs:comment 'Specific suppression flag for email-based outreach. Distinct from the master do_not_contact flag to allow granular channel-level suppression. Compliance with CAN-SPAM Act unsubscribe requirements.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:doNotMail rdf:type rdf:Property ;
    rdfs:label 'Do Not Mail' ;
    rdfs:comment 'Specific suppression flag for physical postal mail outreach. Allows customers to opt out of paper-based communications such as billing statements, promotional mailers, and service notices.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:doNotSms rdf:type rdf:Property ;
    rdfs:label 'Do Not Sms' ;
    rdfs:comment 'Specific suppression flag for SMS/text message outreach. Required for TCPA compliance as SMS requires prior express written consent. Distinct from the master do_not_contact flag.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:effectiveFrom rdf:type rdf:Property ;
    rdfs:label 'Effective From' ;
    rdfs:comment 'The date from which this communication preference record is effective and should be applied to outbound communications. Supports temporal preference management and scheduled preference changes (e.g., a customer requesting preferences to take effect at the start of next billing cycle).' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveUntil rdf:type rdf:Property ;
    rdfs:label 'Effective Until' ;
    rdfs:comment 'The date until which this communication preference record is effective. Null indicates the preference is open-ended with no planned expiry. Used for temporary preference overrides (e.g., vacation holds, seasonal suppression) and consent expiry management.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:languagePreference rdf:type rdf:Property ;
    rdfs:label 'Language Preference' ;
    rdfs:comment 'The customer or contact\'s preferred language for all communications, stored as an IETF BCP 47 language tag (e.g., \'en\', \'es\', \'zh-CN\', \'fr\'). Drives language selection in templated outbound communications across email, SMS, IVR, and portal notifications.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastUpdatedBy rdf:type rdf:Property ;
    rdfs:label 'Last Updated By' ;
    rdfs:comment 'The identifier of the user, system, or agent that last modified this preference record. May be a Salesforce CRM user ID, a Waste Logics portal session identifier, or a system process name (e.g., \'BULK_IMPORT\', \'IVR_SYSTEM\'). Supports audit trail and compliance investigation.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationType rdf:type rdf:Property ;
    rdfs:label 'Notification Type' ;
    rdfs:comment 'The category of notification for which this preference record captures opt-in or opt-out status. [ENUM-REF-CANDIDATE: billing_alert|service_reminder|outage_notification|promotional_offer|nps_survey|collection_schedule|account_update|regulatory_notice|payment_confirmation|route_change — promote to reference product]' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:npsSurveyOptIn rdf:type rdf:Property ;
    rdfs:label 'Nps Survey Opt In' ;
    rdfs:comment 'Indicates whether the customer has opted in to receive Net Promoter Score (NPS) and customer satisfaction surveys. Supports the customer experience measurement program and drives service improvement analytics.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optInStatus rdf:type rdf:Property ;
    rdfs:label 'Opt In Status' ;
    rdfs:comment 'Current opt-in or opt-out status of the customer or contact for the specified channel and notification type combination. \'pending\' indicates consent has been requested but not yet confirmed (e.g., double opt-in flow). \'not_set\' indicates no preference has been recorded.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optOutChannel rdf:type rdf:Property ;
    rdfs:label 'Opt Out Channel' ;
    rdfs:comment 'The channel or mechanism through which the customer submitted their opt-out request. Supports compliance audit trails and process improvement analysis (e.g., identifying which unsubscribe mechanisms are most used). [ENUM-REF-CANDIDATE: email_unsubscribe|sms_stop|ivr|customer_portal|agent_request|written_request|regulatory_order — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optOutReason rdf:type rdf:Property ;
    rdfs:label 'Opt Out Reason' ;
    rdfs:comment 'The reason provided by the customer or contact for opting out of a communication channel or notification type. [ENUM-REF-CANDIDATE: too_frequent|not_relevant|prefer_other_channel|unsubscribe_link|customer_request|complaint|regulatory_request|deceased — promote to reference product]' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optOutTimestamp rdf:type rdf:Property ;
    rdfs:label 'Opt Out Timestamp' ;
    rdfs:comment 'The exact date and time when the customer or contact submitted an opt-out request for this channel or notification type. CAN-SPAM requires opt-out requests to be honored within 10 business days; this timestamp is the compliance clock start.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:outageNotificationOptIn rdf:type rdf:Property ;
    rdfs:label 'Outage Notification Opt In' ;
    rdfs:comment 'Indicates whether the customer has opted in to receive service disruption and outage notifications such as missed collection alerts, route delays, weather-related service suspensions, and facility closures.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:portalNotificationEnabled rdf:type rdf:Property ;
    rdfs:label 'Portal Notification Enabled' ;
    rdfs:comment 'Indicates whether the customer has enabled in-portal notifications within the Waste Logics customer portal. When True, notifications are surfaced within the portal dashboard in addition to or instead of external channels.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferenceType rdf:type rdf:Property ;
    rdfs:label 'Preference Type' ;
    rdfs:comment 'Categorizes the nature of this preference record: channel (preferred delivery channel), notification (opt-in/out for a notification category), language (preferred language), frequency (preferred contact cadence), or do_not_contact (suppression flag). Enables structured querying of preference records.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredContactTimeEnd rdf:type rdf:Property ;
    rdfs:label 'Preferred Contact Time End' ;
    rdfs:comment 'The end of the customer\'s preferred time window for receiving phone or SMS outreach, stored in HH:MM 24-hour format in the customer\'s local time zone. TCPA restricts calls to 8 AM–9 PM local time; this field captures the customer\'s narrower preference within that window.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredContactTimeStart rdf:type rdf:Property ;
    rdfs:label 'Preferred Contact Time Start' ;
    rdfs:comment 'The start of the customer\'s preferred time window for receiving phone or SMS outreach, stored in HH:MM 24-hour format in the customer\'s local time zone. Used by outbound dialer and SMS scheduling systems to respect contact time preferences.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionalOptIn rdf:type rdf:Property ;
    rdfs:label 'Promotional Opt In' ;
    rdfs:comment 'Indicates whether the customer has opted in to receive promotional communications including new service offers, recycling program promotions, and sustainability initiative campaigns. Subject to CAN-SPAM and TCPA consent requirements.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryNoticeOptIn rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notice Opt In' ;
    rdfs:comment 'Indicates whether the customer has opted in to receive regulatory and compliance-related notices such as EPA-mandated service change notifications, RCRA hazardous waste handling updates, and local solid waste authority announcements. Note: some regulatory notices may be mandatory regardless of opt-in status.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceReminderOptIn rdf:type rdf:Property ;
    rdfs:label 'Service Reminder Opt In' ;
    rdfs:comment 'Indicates whether the customer has opted in to receive service reminders such as upcoming collection day notifications, container set-out reminders, and scheduled service confirmations. Supports AMCS Platform and Locus Dispatch customer notification workflows.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:suppressionListFlag rdf:type rdf:Property ;
    rdfs:label 'Suppression List Flag' ;
    rdfs:comment 'Indicates whether this contact has been added to a global suppression list, preventing all marketing and non-transactional outreach regardless of individual channel preferences. Populated from CAN-SPAM unsubscribe lists, TCPA litigation holds, or internal suppression decisions.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:suppressionReason rdf:type rdf:Property ;
    rdfs:label 'Suppression Reason' ;
    rdfs:comment 'The reason this contact was added to the suppression list. \'bounce\' indicates a hard email bounce; \'complaint\' indicates a spam complaint; \'litigation_hold\' indicates legal proceedings; \'regulatory\' indicates a government-mandated suppression order. [ENUM-REF-CANDIDATE: unsubscribe|complaint|bounce|litigation_hold|regulatory|deceased|fraud — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeZone rdf:type rdf:Property ;
    rdfs:label 'Time Zone' ;
    rdfs:comment 'The IANA time zone identifier for the customer\'s or contact\'s local time zone (e.g., \'America/Chicago\', \'America/Los_Angeles\'). Used in conjunction with preferred_contact_time_start and preferred_contact_time_end to schedule compliant outreach.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:envianceIncidentId rdf:type rdf:Property ;
    rdfs:label 'Enviance Incident Id' ;
    rdfs:comment 'External system identifier for complaints that generated an environmental health and safety incident record in Enviance EHS, applicable for environmental concern and hazardous waste complaints requiring regulatory tracking.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Incident .

ind:interactionId rdf:type rdf:Property ;
    rdfs:label 'Interaction Id' ;
    rdfs:comment 'Reference to the originating customer interaction (call, chat, portal submission) that generated this formal complaint, enabling traceability from first contact.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Interaction .

ind:priorComplaintId rdf:type rdf:Property ;
    rdfs:label 'Prior Complaint Id' ;
    rdfs:comment 'Reference to the previous complaint record when repeat_complaint_flag is true, enabling complaint recurrence chain analysis and chronic service failure identification.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Complaint .

ind:resolutionOrgUnitId rdf:type rdf:Property ;
    rdfs:label 'Resolution Org Unit Id' ;
    rdfs:comment 'Foreign key linking to workforce.org_unit. Business justification: Complaints (missed pickups, property damage, billing disputes) are routed to and resolved by specific operational units. Enables unit-level performance metrics, regulatory reporting to municipal autho' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:assignedTeam rdf:type rdf:Property ;
    rdfs:label 'Assigned Team' ;
    rdfs:comment 'Functional team responsible for complaint resolution. Environmental compliance team handles EPA/OSHA-reportable complaints; legal team handles complaints with litigation potential.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingDisputeAmountUsd rdf:type rdf:Property ;
    rdfs:label 'Billing Dispute Amount Usd' ;
    rdfs:comment 'Dollar amount in dispute for billing-related complaints. Populated only when complaint_type is billing_dispute. Used for accounts receivable (AR) adjustment tracking and revenue impact analysis.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complaintDescription rdf:type rdf:Property ;
    rdfs:label 'Complaint Description' ;
    rdfs:comment 'Free-text narrative describing the complaint in detail as reported by the customer or regulatory agency. Captures the full context of the issue including specific circumstances, locations, and impacts.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintNumber rdf:type rdf:Property ;
    rdfs:label 'Complaint Number' ;
    rdfs:comment 'Externally visible, human-readable complaint reference number communicated to the customer and used in regulatory correspondence. Format: CMP-YYYY-NNNNNNN.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintSource rdf:type rdf:Property ;
    rdfs:label 'Complaint Source' ;
    rdfs:comment 'Channel or origination point through which the complaint was received. Regulatory agency source indicates complaints filed directly by EPA, OSHA, DOT, or state environmental bodies requiring mandatory response timelines.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintStatus rdf:type rdf:Property ;
    rdfs:label 'Complaint Status' ;
    rdfs:comment 'Current workflow lifecycle state of the complaint from initial receipt through resolution and closure. Drives SLA tracking and operational dashboards.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintType rdf:type rdf:Property ;
    rdfs:label 'Complaint Type' ;
    rdfs:comment 'Primary classification of the complaint subject matter. Missed pickup covers scheduled collection failures; billing dispute covers invoice or charge disagreements; driver behavior covers conduct or safety concerns; odor/noise covers nuisance impacts; environmental concern covers spills, leachate, or regulatory issues; container damage covers physical damage to customer containers.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditAmountUsd rdf:type rdf:Property ;
    rdfs:label 'Credit Amount Usd' ;
    rdfs:comment 'Dollar value of the billing or service credit issued to the customer as resolution for the complaint. Populated only when credit_issued_flag is true. Feeds into revenue management and EBITDA impact reporting.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerSatisfactionScore rdf:type rdf:Property ;
    rdfs:label 'Customer Satisfaction Score' ;
    rdfs:comment 'Post-resolution customer satisfaction score on a 1-5 scale collected via follow-up survey. Feeds into NPS (Net Promoter Score) and customer retention analytics. Null if survey not completed.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:escalationReason rdf:type rdf:Property ;
    rdfs:label 'Escalation Reason' ;
    rdfs:comment 'Narrative explanation of why the complaint was escalated, capturing the business justification for escalation such as SLA breach, repeat complaint, high-value customer, or regulatory risk.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstResponseTimestamp rdf:type rdf:Property ;
    rdfs:label 'First Response Timestamp' ;
    rdfs:comment 'Date and time when the customer received the first substantive response to their complaint. Used to calculate first response time against SLA targets and regulatory response obligations.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:receivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Received Timestamp' ;
    rdfs:comment 'Date and time when the complaint was formally received and logged in the system. This is the principal business event timestamp used as the SLA clock start for all response time calculations.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:regulatoryEscalationFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Escalation Flag' ;
    rdfs:comment 'Indicates whether this complaint requires mandatory reporting or response to a regulatory body (EPA, OSHA, DOT, state environmental agency). When true, triggers regulatory response workflow with statutory deadlines.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:repeatComplaintFlag rdf:type rdf:Property ;
    rdfs:label 'Repeat Complaint Flag' ;
    rdfs:comment 'Indicates whether this complaint is a recurrence of a previously filed complaint for the same customer and same issue type within a rolling 90-day window. Repeat complaints trigger enhanced resolution workflows and root cause analysis requirements.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resolutionAction rdf:type rdf:Property ;
    rdfs:label 'Resolution Action' ;
    rdfs:comment 'Free-text description of the corrective action taken to resolve the complaint, such as re-collection dispatched, billing credit issued, driver counseling completed, or environmental remediation performed.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionOutcome rdf:type rdf:Property ;
    rdfs:label 'Resolution Outcome' ;
    rdfs:comment 'Final outcome classification of the complaint resolution. Resolved_accepted means customer confirmed satisfaction; resolved_rejected means customer disputed the resolution; referred_to_regulatory means the complaint was escalated to an external regulatory body for adjudication.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Resolved Timestamp' ;
    rdfs:comment 'Date and time when the complaint was marked as resolved, meaning the root cause was addressed and corrective action completed. Used to calculate total resolution time against SLA targets.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rootCauseCode rdf:type rdf:Property ;
    rdfs:label 'Root Cause Code' ;
    rdfs:comment 'Standardized code identifying the underlying operational or systemic cause of the complaint (e.g., driver_error, route_planning_failure, equipment_malfunction, billing_system_error, weather_delay, container_overfill). Used for operational quality improvement and recurring issue analysis. [ENUM-REF-CANDIDATE: driver_error|route_planning_failure|equipment_malfunction|billing_system_error|weather_delay|container_overfill|access_obstruction|contamination|permit_violation|staffing_shortage — promote to reference product]' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesforceCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Salesforce Case Number' ;
    rdfs:comment 'External system identifier for this complaint record in Salesforce CRM, enabling bidirectional synchronization and audit traceability between the data lakehouse and the operational CRM system.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaResolutionDueTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sla Resolution Due Timestamp' ;
    rdfs:comment 'Calculated deadline by which the complaint must be fully resolved and closed based on severity level and SLA tier. Distinct from response due timestamp which only covers initial acknowledgment.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:slaResponseDueTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sla Response Due Timestamp' ;
    rdfs:comment 'Calculated deadline by which the complaint must receive an initial response based on severity level and SLA tier. Regulatory complaints have statutory response deadlines that override standard SLA tiers.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:contactStatus rdf:type rdf:Property ;
    rdfs:label 'Contact Status' ;
    rdfs:comment 'Current lifecycle status of the contact record. Active contacts receive communications and can authorize service changes. Inactive contacts are retained for historical reference. Do_not_contact enforces opt-out compliance. Deceased and unverified statuses support data quality management.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:department rdf:type rdf:Property ;
    rdfs:label 'Department' ;
    rdfs:comment 'Organizational department or business unit the contact belongs to within their company (e.g., Facilities, Finance, Operations, Environmental Health & Safety). Supports routing of service and billing inquiries to the correct team.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emailOptIn rdf:type rdf:Property ;
    rdfs:label 'Email Opt In' ;
    rdfs:comment 'Indicates whether the contact has consented to receive marketing and promotional email communications from Waste Management. True = opted in; False = opted out or never consented. Distinct from transactional/service emails which are sent regardless of this flag.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:firstName rdf:type rdf:Property ;
    rdfs:label 'First Name' ;
    rdfs:comment 'Given (first) name of the individual contact person. Used for personalized communications, billing correspondence, and service notifications.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBillingContact rdf:type rdf:Property ;
    rdfs:label 'Is Billing Contact' ;
    rdfs:comment 'Indicates whether this contact is designated to receive billing-related communications including invoices, payment reminders, Accounts Receivable (AR) notices, and rate change notifications. Supports Oracle Revenue Management billing workflow routing.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isEmergencyContact rdf:type rdf:Property ;
    rdfs:label 'Is Emergency Contact' ;
    rdfs:comment 'Indicates whether this contact should be notified in emergency situations such as hazardous waste spills, service safety incidents, or after-hours urgent service needs. Emergency contacts are prioritized in incident escalation workflows managed through Enviance EHS.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimaryContact rdf:type rdf:Property ;
    rdfs:label 'Is Primary Contact' ;
    rdfs:comment 'Indicates whether this contact is designated as the primary point of contact for the customer account. Each customer account should have exactly one primary contact. Used to determine the default recipient for account-level communications when no specific role routing applies.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isServiceContact rdf:type rdf:Property ;
    rdfs:label 'Is Service Contact' ;
    rdfs:comment 'Indicates whether this contact is designated to receive service-related communications including collection schedule notifications, service disruption alerts, Work Order (WO) confirmations, and container delivery/pickup notices.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobTitle rdf:type rdf:Property ;
    rdfs:label 'Job Title' ;
    rdfs:comment 'Professional title or position of the contact within their organization (e.g., Facilities Manager, Environmental Compliance Officer, Accounts Payable Specialist). Particularly relevant for commercial and municipal accounts.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastName rdf:type rdf:Property ;
    rdfs:label 'Last Name' ;
    rdfs:comment 'Family (last) name of the individual contact person. Combined with first_name to form the full display name for correspondence and account management.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Mailing Address Line1' ;
    rdfs:comment 'First line of the contact\'s mailing address for physical correspondence including paper billing statements, regulatory notices, and formal contract documents. May differ from the service address on the customer account.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Mailing Address Line2' ;
    rdfs:comment 'Second line of the contact\'s mailing address (suite, apartment, floor, unit number, or care-of designation). Supplements mailing_address_line1 for complete address formatting.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingCity rdf:type rdf:Property ;
    rdfs:label 'Mailing City' ;
    rdfs:comment 'City component of the contact\'s mailing address. Used for physical mail delivery and geographic segmentation of contact communications.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingCountry rdf:type rdf:Property ;
    rdfs:label 'Mailing Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 three-letter country code for the contact\'s mailing address (e.g., USA, CAN, MEX). Supports international commercial and industrial accounts and determines applicable privacy regulation framework.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingPostalCode rdf:type rdf:Property ;
    rdfs:label 'Mailing Postal Code' ;
    rdfs:comment 'ZIP or ZIP+4 postal code for the contact\'s mailing address. Used for mail delivery, geographic market analysis, and routing of state-specific regulatory communications.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingState rdf:type rdf:Property ;
    rdfs:label 'Mailing State' ;
    rdfs:comment 'Two-letter US state or territory abbreviation for the contact\'s mailing address (e.g., TX, CA, FL). Follows USPS state code standards. Used for state-level regulatory compliance routing and tax jurisdiction determination.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mobilePhone rdf:type rdf:Property ;
    rdfs:label 'Mobile Phone' ;
    rdfs:comment 'Mobile/cell phone number for the contact. Supports SMS/text message notifications for service day reminders, route change alerts, and two-factor authentication for portal access. Formatted per E.164 standard.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:npsSurveyDate rdf:type rdf:Property ;
    rdfs:label 'Nps Survey Date' ;
    rdfs:comment 'Date on which the most recent Net Promoter Score (NPS) survey response was recorded for this contact. Used to determine survey recency and eligibility for follow-up surveys per survey cadence policies.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:portalAccessEnabled rdf:type rdf:Property ;
    rdfs:label 'Portal Access Enabled' ;
    rdfs:comment 'Indicates whether this contact has been granted access to the Waste Logics self-service customer portal. True = portal account exists and is active. Linked to waste_logics_user_id when enabled. Supports self-service for service scheduling, container management, and billing review.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:portalLastLoginTimestamp rdf:type rdf:Property ;
    rdfs:label 'Portal Last Login Timestamp' ;
    rdfs:comment 'Date and time of the contact\'s most recent login to the Waste Logics customer portal. Used to identify inactive portal users, drive re-engagement campaigns, and support portal access audits. Null if the contact has never logged in.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:preferredContactMethod rdf:type rdf:Property ;
    rdfs:label 'Preferred Contact Method' ;
    rdfs:comment 'Contact\'s stated preference for how Waste Management should reach them. Drives communication channel selection for service notifications, billing statements, and marketing communications. Supports Customer Relationship Management (CRM) personalization and compliance with communication preferences.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredContactTime rdf:type rdf:Property ;
    rdfs:label 'Preferred Contact Time' ;
    rdfs:comment 'Contact\'s preferred time window for receiving outbound calls or communications from Waste Management. Supports compliance with TCPA restrictions and improves customer satisfaction by respecting contact preferences.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:preferredLanguage rdf:type rdf:Property ;
    rdfs:label 'Preferred Language' ;
    rdfs:comment 'ISO 639-1 language code (optionally with ISO 3166-1 country subtag) representing the contact\'s preferred language for communications (e.g., en, es, fr, zh-CN). Drives localization of billing statements, service notifications, and customer portal content.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Email' ;
    rdfs:comment 'Primary email address for the contact. Used for billing notifications, service confirmations, account alerts, and Customer Relationship Management (CRM) communications. Sourced from Salesforce CRM Contact Email field.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Phone' ;
    rdfs:comment 'Main telephone number for reaching the contact. Formatted per E.164 international standard. Used for service scheduling confirmations, billing inquiries, and emergency notifications. Sourced from Salesforce CRM Contact Phone field.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roleType rdf:type rdf:Property ;
    rdfs:label 'Role Type' ;
    rdfs:comment 'Functional role this contact plays on the customer account. Determines routing of communications and authorizations: primary (main account holder), billing (receives invoices and AR communications), service (receives service notifications and scheduling), emergency (after-hours escalation), authorized_representative (can act on behalf of account holder).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesforceContactReference rdf:type rdf:Property ;
    rdfs:label 'Salesforce Contact Reference' ;
    rdfs:comment 'External system identifier for this contact record in Salesforce CRM. Used for cross-system reconciliation and data lineage tracing between the Silver layer and the Salesforce Contact object.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryEmail rdf:type rdf:Property ;
    rdfs:label 'Secondary Email' ;
    rdfs:comment 'Alternate email address for the contact. Used as a fallback communication channel when the primary email is undeliverable or for routing specific communication types (e.g., service alerts to a work email, billing to a personal email).' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:smsOptIn rdf:type rdf:Property ;
    rdfs:label 'Sms Opt In' ;
    rdfs:comment 'Indicates whether the contact has provided express written consent to receive SMS/text message communications from Waste Management, including service reminders, route change alerts, and promotional messages. Required for TCPA compliance.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:wasteLogicsUserReference rdf:type rdf:Property ;
    rdfs:label 'Waste Logics User Reference' ;
    rdfs:comment 'Identifier for the corresponding user account in the Waste Logics customer portal. Populated when the contact has registered for self-service portal access. Null if no portal account exists.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workPhone rdf:type rdf:Property ;
    rdfs:label 'Work Phone' ;
    rdfs:comment 'Business/office telephone number for the contact, including extension if applicable. Primarily used for commercial and municipal account contacts where direct-dial office numbers differ from mobile numbers.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workPhoneExtension rdf:type rdf:Property ;
    rdfs:label 'Work Phone Extension' ;
    rdfs:comment 'Telephone extension number associated with the work phone for the contact. Required for large commercial and municipal accounts where contacts are reached via a main switchboard.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Container Assignment Id' ;
    rdfs:comment 'Unique surrogate identifier for each container assignment record in the Waste Management lakehouse silver layer. Serves as the primary key for this entity.' ;
    rdfs:domain ind:ContainerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:materialStreamWasteStreamId rdf:type rdf:Property ;
    rdfs:label 'Material Stream Waste Stream Id' ;
    rdfs:comment 'Foreign key linking to service.service_waste_stream. Business justification: Container assignments designate which waste stream the container accepts for contamination tracking, diversion rate calculation, proper disposal routing, and regulatory reporting. Critical for recycli' ;
    rdfs:domain ind:ContainerAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WasteStream .

ind:primaryContainerDeliveryWorkOrderId rdf:type rdf:Property ;
    rdfs:label 'Primary Container Delivery Work Order Id' ;
    rdfs:comment 'Reference to the Work Order (WO) created in AMCS Platform or SAP PM module to execute the container delivery. Enables traceability from the assignment record back to the field service event.' ;
    rdfs:domain ind:ContainerAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkOrder .

ind:priorAssignmentContainerAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Prior Assignment Container Assignment Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the previous container assignment at this service address that this record replaces (e.g., after a swap or upgrade). Null for original assignments. Enables container assignment history chain reconstruction.' ;
    rdfs:domain ind:ContainerAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContainerAssignment .

ind:srfProductionLineId rdf:type rdf:Property ;
    rdfs:label 'Srf Production Line Id' ;
    rdfs:comment 'Foreign key linking to energy.srf_production_line. Business justification: Commercial containers for recyclable/combustible waste streams are designated for SRF production lines. Material flow tracking, contamination monitoring, and SRF feedstock quality control require cont' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SrfProductionLine .

ind:collectionDayOfWeek rdf:type rdf:Property ;
    rdfs:label 'Collection Day Of Week' ;
    rdfs:comment 'Scheduled day(s) of the week on which the container is collected. For multi-day schedules, stores the primary collection day. Drives route assignment in AMCS Platform and Locus Dispatch. Sunday collection is not standard in most markets.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionAtDelivery rdf:type rdf:Property ;
    rdfs:label 'Condition At Delivery' ;
    rdfs:comment 'Physical condition of the container at the time it was delivered to the service address. Recorded by the driver or dispatcher at delivery. Used for warranty tracking, asset lifecycle management, and customer dispute resolution.' ;
    rdfs:domain ind:ContainerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionAtRemoval rdf:type rdf:Property ;
    rdfs:label 'Condition At Removal' ;
    rdfs:comment 'Physical condition of the container at the time it was removed from the service address. Recorded by the driver or dispatcher at pickup. Supports damage assessment, customer liability determination, and asset refurbishment decisions.' ;
    rdfs:domain ind:ContainerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:damageDescription rdf:type rdf:Property ;
    rdfs:label 'Damage Description' ;
    rdfs:comment 'Free-text description of any damage observed on the container at delivery or during the assignment period. Populated when condition_at_delivery or condition_at_removal indicates damage. Supports insurance claims and customer billing for damage charges.' ;
    rdfs:domain ind:ContainerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryDate rdf:type rdf:Property ;
    rdfs:label 'Delivery Date' ;
    rdfs:comment 'Calendar date on which the container was physically delivered to the service address and the assignment became active. Sourced from the completed delivery work order in AMCS Platform or Waste Logics.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enclosureRequired rdf:type rdf:Property ;
    rdfs:label 'Enclosure Required' ;
    rdfs:comment 'Indicates whether the container must be placed within a screened enclosure or enclosure structure per local municipal ordinance, HOA requirements, or customer contract terms. True = enclosure required; False = open placement permitted.' ;
    rdfs:domain ind:ContainerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastServicedDate rdf:type rdf:Property ;
    rdfs:label 'Last Serviced Date' ;
    rdfs:comment 'Most recent calendar date on which the container was collected/emptied under this assignment. Updated after each successful collection event. Used for service verification, missed pickup detection, and customer service inquiries.' ;
    rdfs:domain ind:ContainerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lockRequired rdf:type rdf:Property ;
    rdfs:label 'Lock Required' ;
    rdfs:comment 'Indicates whether the container requires a lock mechanism for security or regulatory compliance (e.g., hazardous waste containers, high-theft areas, or customer-requested security). True = lock required; False = no lock required.' ;
    rdfs:domain ind:ContainerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:materialStream rdf:type rdf:Property ;
    rdfs:label 'Material Stream' ;
    rdfs:comment 'Waste material stream designated for this container assignment. \'msw\' = Municipal Solid Waste (MSW) general refuse; \'recycling\' = commingled recyclables for Materials Recovery Facility (MRF) processing; \'organics\' = food/organic waste; \'cd_waste\' = Construction and Demolition (C&D) debris; \'hazardous\' = regulated hazardous waste; \'yard_waste\' = landscaping and green waste.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:missedPickupCount rdf:type rdf:Property ;
    rdfs:label 'Missed Pickup Count' ;
    rdfs:comment 'Cumulative count of missed or skipped scheduled collection events for this container assignment since delivery. Used for SLA compliance monitoring, customer satisfaction tracking, and NPS correlation analysis.' ;
    rdfs:domain ind:ContainerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:monthlyRentalRate rdf:type rdf:Property ;
    rdfs:label 'Monthly Rental Rate' ;
    rdfs:comment 'Monthly rental charge billed to the customer for the use of this container under the current assignment. Expressed in US dollars. Used by Oracle Revenue Management for recurring billing generation and revenue recognition.' ;
    rdfs:domain ind:ContainerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overageAllowed rdf:type rdf:Property ;
    rdfs:label 'Overage Allowed' ;
    rdfs:comment 'Indicates whether the customer\'s service agreement permits overage (excess waste placed beside or on top of the container beyond its rated capacity). True = overage collection is permitted and may trigger additional charges; False = overage is not collected.' ;
    rdfs:domain ind:ContainerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:placementLocation rdf:type rdf:Property ;
    rdfs:label 'Placement Location' ;
    rdfs:comment 'Descriptive text indicating the specific placement location of the container at the service address (e.g., \'curbside\', \'back alley\', \'loading dock bay 3\', \'inside gate\'). Used by drivers for accurate container location during collection.' ;
    rdfs:domain ind:ContainerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryManifestRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Manifest Required' ;
    rdfs:comment 'Indicates whether a Hazardous Waste Manifest (tracking document) is required for the material stream in this container assignment per RCRA regulations. True = manifest required (hazardous waste); False = standard MSW/recycling, no manifest required.' ;
    rdfs:domain ind:ContainerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:removalDate rdf:type rdf:Property ;
    rdfs:label 'Removal Date' ;
    rdfs:comment 'Calendar date on which the container was physically removed from the service address, ending the active assignment. Null if the assignment is still active. Used for container utilization duration calculations and billing period closure.' ;
    rdfs:domain ind:ContainerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Delivery Date' ;
    rdfs:comment 'Originally planned calendar date for container delivery to the service address. Compared against actual delivery_date to measure delivery SLA compliance and route scheduling accuracy.' ;
    rdfs:domain ind:ContainerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sizeCubicYards rdf:type rdf:Property ;
    rdfs:label 'Size Cubic Yards' ;
    rdfs:comment 'Nominal capacity of the container expressed in cubic yards. Used for commercial dumpsters, roll-offs, and compactors (e.g., 2, 4, 6, 8, 10, 20, 30, 40 cubic yards). Null for containers measured in gallons. Supports billing, route planning, and capacity management.' ;
    rdfs:domain ind:ContainerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sizeGallons rdf:type rdf:Property ;
    rdfs:label 'Size Gallons' ;
    rdfs:comment 'Nominal capacity of the container expressed in US gallons. Used for residential carts and toters (e.g., 32, 64, 96 gallons). Null for containers measured in cubic yards. Supports container utilization analysis and route weight estimation.' ;
    rdfs:domain ind:ContainerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:swapReason rdf:type rdf:Property ;
    rdfs:label 'Swap Reason' ;
    rdfs:comment 'Reason code explaining why this container assignment was created as a replacement for a prior assignment. Null if this is an original assignment (not a swap). Supports container lifecycle analysis and operational efficiency reporting.' ;
    rdfs:domain ind:ContainerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardousWasteGeneratorId rdf:type rdf:Property ;
    rdfs:label 'Hazardous Waste Generator Id' ;
    rdfs:comment 'Foreign key linking to hazmat.hazardous_waste_generator. Business justification: Customer accounts that are EPA-registered hazmat generators require direct link for RCRA compliance tracking, manifest generation authority, biennial reporting, and regulatory status monitoring. Essen' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HazardousWasteGenerator .

ind:managerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Commercial waste accounts require dedicated account managers for contract renewals, service optimization, rate negotiations, and billing escalations. Critical for customer retention, upsell opportunit' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:wasteGeneratorClassWasteStreamId rdf:type rdf:Property ;
    rdfs:label 'Waste Generator Class Waste Stream Id' ;
    rdfs:comment 'Foreign key linking to service.service_waste_stream. Business justification: Customer accounts are classified by EPA waste generator class (LQG/SQG/CESQG) which directly determines eligible waste streams for regulatory compliance, service offerings, manifest requirements, and ' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WasteStream .

ind:accountTier rdf:type rdf:Property ;
    rdfs:label 'Account Tier' ;
    rdfs:comment 'Customer value tier assigned by Waste Management based on revenue contribution, contract size, and strategic importance. Drives service priority, dedicated account management assignment, and pricing concessions. Strategic tier typically reserved for large municipal contracts and national commercial accounts.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autopayEnrolled rdf:type rdf:Property ;
    rdfs:label 'Autopay Enrolled' ;
    rdfs:comment 'Indicates whether the customer account is enrolled in automatic payment processing. When True, invoices are automatically charged to the customer\'s payment instrument on the due date via Oracle Revenue Management.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:billingAddressSameAsService rdf:type rdf:Property ;
    rdfs:label 'Billing Address Same As Service' ;
    rdfs:comment 'Indicates whether the customer\'s billing address is identical to the service address. When True, billing correspondence is sent to the service address. When False, a separate billing address is maintained in the billing system.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:billingState rdf:type rdf:Property ;
    rdfs:label 'Billing State' ;
    rdfs:comment 'Two-letter US state code for the customer\'s billing address. Used for tax jurisdiction determination and AR correspondence routing.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedDate rdf:type rdf:Property ;
    rdfs:label 'Closed Date' ;
    rdfs:comment 'Date on which the customer account was permanently closed and all services terminated. Null for active accounts. Used for churn analysis, win-back campaigns, and regulatory record retention compliance.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customerSinceDate rdf:type rdf:Property ;
    rdfs:label 'Customer Since Date' ;
    rdfs:comment 'Date on which the customer account was first activated and services commenced. Represents the start of the customer relationship lifecycle. Used for tenure analysis, loyalty programs, and contract renewal planning.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:industryCode rdf:type rdf:Property ;
    rdfs:label 'Industry Code' ;
    rdfs:comment 'North American Industry Classification System (NAICS) or Standard Industrial Classification (SIC) code identifying the primary industry of the commercial or industrial customer. Used for waste stream profiling, regulatory compliance determination (e.g., RCRA hazardous waste generator status), and market analytics.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingOptIn rdf:type rdf:Property ;
    rdfs:label 'Marketing Opt In' ;
    rdfs:comment 'Indicates whether the customer has consented to receive marketing and promotional communications from Waste Management, including service upgrade offers, sustainability program invitations, and recycling education materials. Managed per CAN-SPAM and CCPA consent requirements.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paperlessBilling rdf:type rdf:Property ;
    rdfs:label 'Paperless Billing' ;
    rdfs:comment 'Indicates whether the customer has opted into electronic (paperless) billing. When True, invoices are delivered via email or the Waste Logics customer portal rather than physical mail. Supports Waste Management\'s sustainability initiatives.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:salesforceAccountReference rdf:type rdf:Property ;
    rdfs:label 'Salesforce Account Reference' ;
    rdfs:comment 'Integration key linking this customer account to the corresponding Account record in Salesforce CRM. Used for bi-directional synchronization of customer profile, service requests, and contract data between the data platform and Salesforce.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapCustomerNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Customer Number' ;
    rdfs:comment 'Customer master number assigned in SAP S/4HANA (SD and FI/CO modules). Used for order-to-cash processing, accounts receivable management, and financial reporting. Links this customer account to SAP billing documents and general ledger (GL) postings.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suspensionDate rdf:type rdf:Property ;
    rdfs:label 'Suspension Date' ;
    rdfs:comment 'Date on which the customer account was most recently placed in suspended status, typically due to non-payment or service dispute. Null for accounts not currently or previously suspended. Used for AR collections workflow and service reinstatement tracking.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:wasteGeneratorClass rdf:type rdf:Property ;
    rdfs:label 'Waste Generator Class' ;
    rdfs:comment 'EPA Resource Conservation and Recovery Act (RCRA) hazardous waste generator classification for the customer account. LQG = Large Quantity Generator (>1,000 kg/month); SQG = Small Quantity Generator (100-1,000 kg/month); VSQG = Very Small Quantity Generator (<100 kg/month); Non_generator = no regulated hazardous waste. Determines regulatory compliance obligations and service requirements.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteLogicsCustomerReference rdf:type rdf:Property ;
    rdfs:label 'Waste Logics Customer Reference' ;
    rdfs:comment 'Integration key linking this customer account to the corresponding customer record in the Waste Logics customer portal. Enables self-service scheduling, container management, and service history access for the customer.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractRequired rdf:type rdf:Property ;
    rdfs:label 'Contract Required' ;
    rdfs:comment 'Indicates whether customers in this segment must have a formal service contract (as opposed to month-to-month or on-demand service). Commercial, Industrial, and Government segments typically require contracts; standard residential may be month-to-month.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditCheckRequired rdf:type rdf:Property ;
    rdfs:label 'Credit Check Required' ;
    rdfs:comment 'Indicates whether a credit check is required during customer onboarding for this segment. Typically required for commercial and industrial segments; waived for government/municipal accounts and standard residential prepay accounts.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crmSegmentCode rdf:type rdf:Property ;
    rdfs:label 'Crm Segment Code' ;
    rdfs:comment 'Corresponding segment identifier code as configured in Salesforce CRM account records. Used for bi-directional synchronization between the Databricks Silver Layer and Salesforce CRM to ensure consistent segment classification across systems.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depositRequired rdf:type rdf:Property ;
    rdfs:label 'Deposit Required' ;
    rdfs:comment 'Indicates whether a security deposit is required from customers in this segment at account activation. Deposit requirements are managed in Oracle Revenue Management and SAP S/4HANA FI module.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:diversionRateTargetPct rdf:type rdf:Property ;
    rdfs:label 'Diversion Rate Target Pct' ;
    rdfs:comment 'Target waste diversion rate percentage (waste diverted from landfill through recycling, composting, or WTE) for customers in this segment. Used for sustainability program goal-setting, MRF throughput planning, and EPA/state environmental compliance reporting. Expressed as a percentage (0.00–100.00).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dotRegulated rdf:type rdf:Property ;
    rdfs:label 'Dot Regulated' ;
    rdfs:comment 'Indicates whether waste collection services for customers in this segment are subject to DOT hazardous materials transportation regulations (49 CFR). Applies to segments generating regulated hazardous waste requiring special vehicle placarding and CDL driver certification.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:epaGeneratorClass rdf:type rdf:Property ;
    rdfs:label 'Epa Generator Class' ;
    rdfs:comment 'EPA hazardous waste generator classification applicable to customers in this segment under RCRA regulations: VSQG (Very Small Quantity Generator), SQG (Small Quantity Generator), LQG (Large Quantity Generator), or Not Applicable for non-hazardous segments. Drives compliance reporting requirements in Enviance EHS.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ghgReportingRequired rdf:type rdf:Property ;
    rdfs:label 'Ghg Reporting Required' ;
    rdfs:comment 'Indicates whether customers in this segment require Greenhouse Gas (GHG) emissions reporting as part of their service agreement or regulatory obligation. Applies to large commercial, industrial, and government segments subject to EPA GHG Reporting Program (40 CFR Part 98). Managed in Enviance EHS.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDefaultSegment rdf:type rdf:Property ;
    rdfs:label 'Is Default Segment' ;
    rdfs:comment 'Indicates whether this segment is the system default assigned to new customer accounts when no explicit segment classification has been determined during onboarding. Only one segment should carry this flag as True at any given time.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lifecycleStatus rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Status' ;
    rdfs:comment 'Current operational status of the customer segment definition within the classification taxonomy. \'active\' segments are available for customer assignment; \'deprecated\' segments are retained for historical reference only; \'draft\' segments are pending approval before activation.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketCategory rdf:type rdf:Property ;
    rdfs:label 'Market Category' ;
    rdfs:comment 'High-level market category grouping for the segment: B2C (Business-to-Consumer residential), B2B (Business-to-Business commercial), Government, Industrial, or Non-Profit. Drives sales channel assignment, pricing strategy, and regulatory reporting classification.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxAnnualRevenueUsd rdf:type rdf:Property ;
    rdfs:label 'Max Annual Revenue Usd' ;
    rdfs:comment 'Maximum annual revenue threshold in US dollars for customer accounts in this segment. Accounts exceeding this threshold are eligible for promotion to a higher segment. Null indicates no upper revenue cap for the segment.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minAnnualRevenueUsd rdf:type rdf:Property ;
    rdfs:label 'Min Annual Revenue Usd' ;
    rdfs:comment 'Minimum annual revenue threshold in US dollars that a customer account must meet to qualify for this segment. Used in Salesforce CRM for automated segment assignment and in Oracle Revenue Management for rate eligibility validation. Null indicates no minimum revenue requirement.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minContractTermMonths rdf:type rdf:Property ;
    rdfs:label 'Min Contract Term Months' ;
    rdfs:comment 'Minimum contract duration in months required for customers in this segment. Null or zero indicates no minimum contract term (e.g., residential month-to-month). Enterprise and National Account segments typically require 12–60 month minimum terms.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:npsBenchmarkTarget rdf:type rdf:Property ;
    rdfs:label 'Nps Benchmark Target' ;
    rdfs:comment 'Target Net Promoter Score (NPS) benchmark for customers in this segment, used to set performance expectations for customer satisfaction programs. NPS ranges from -100 to +100. Residential segments typically target 40+; National Account segments target 60+.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:routingPriority rdf:type rdf:Property ;
    rdfs:label 'Routing Priority' ;
    rdfs:comment 'Numeric priority rank (1 = highest priority) used by AMCS Platform and Locus Dispatch to sequence collection routes when capacity constraints require prioritization. Government and medical waste segments typically carry the highest routing priority.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:salesChannel rdf:type rdf:Property ;
    rdfs:label 'Sales Channel' ;
    rdfs:comment 'Primary sales channel through which customers in this segment are acquired and managed. Drives Salesforce CRM lead routing and opportunity assignment rules. Municipal Bid applies to government/municipal contracts won through competitive procurement.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentCode rdf:type rdf:Property ;
    rdfs:label 'Segment Code' ;
    rdfs:comment 'Short, externally-known alphanumeric code uniquely identifying the customer segment (e.g., RES_SFH, COM_SMB, GOV_MUN). Used as the business key in Salesforce CRM account records, AMCS routing configurations, and Oracle Revenue Management rate schedules.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentDescription rdf:type rdf:Property ;
    rdfs:label 'Segment Description' ;
    rdfs:comment 'Detailed narrative description of the customer segment, including the types of customers it encompasses, qualifying criteria, and intended use in service delivery and sales targeting.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentName rdf:type rdf:Property ;
    rdfs:label 'Segment Name' ;
    rdfs:comment 'Human-readable name of the customer segment (e.g., \'Residential Single-Family\', \'Commercial Small Business\', \'Government/Municipal\'). Displayed in Salesforce CRM, Waste Logics customer portal, and all operational and executive reporting.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentType rdf:type rdf:Property ;
    rdfs:label 'Segment Type' ;
    rdfs:comment 'Operational classification of the segment type used for service eligibility rules, route planning in AMCS, and container management in Waste Logics. Residential covers single-family and multi-family; Commercial covers small business through national accounts; Industrial covers large-scale waste generators.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceEligibilityCommercial rdf:type rdf:Property ;
    rdfs:label 'Service Eligibility Commercial' ;
    rdfs:comment 'Indicates whether customers in this segment are eligible for commercial waste collection services (dumpster/container service, compactor service, FEL/REL/ASL truck service). Used by AMCS Platform for service configuration.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceEligibilityHazardous rdf:type rdf:Property ;
    rdfs:label 'Service Eligibility Hazardous' ;
    rdfs:comment 'Indicates whether customers in this segment are eligible for hazardous waste handling and disposal services under RCRA regulations. Typically restricted to Industrial, Commercial, and Government segments with appropriate EPA generator registration.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceEligibilityRecycling rdf:type rdf:Property ;
    rdfs:label 'Service Eligibility Recycling' ;
    rdfs:comment 'Indicates whether customers in this segment are eligible for recycling collection and Materials Recovery Facility (MRF) processing services. Drives diversion rate reporting and sustainability program enrollment.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceEligibilityResidential rdf:type rdf:Property ;
    rdfs:label 'Service Eligibility Residential' ;
    rdfs:comment 'Indicates whether customers in this segment are eligible for residential waste collection services (curbside pickup, recycling bins, yard waste). Used by Waste Logics to filter available service offerings during customer onboarding.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceEligibilityWte rdf:type rdf:Property ;
    rdfs:label 'Service Eligibility Wte' ;
    rdfs:comment 'Indicates whether customers in this segment are eligible for Waste-to-Energy (WTE) conversion services. Eligibility is typically limited to large commercial, industrial, and municipal segments generating sufficient MSW volume to support WTE processing economics.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sortOrder rdf:type rdf:Property ;
    rdfs:label 'Sort Order' ;
    rdfs:comment 'Numeric sort order for displaying customer segments in UI dropdowns, reports, and dashboards across Salesforce CRM, Waste Logics portal, and internal analytics tools. Lower numbers appear first.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:subSegmentType rdf:type rdf:Property ;
    rdfs:label 'Sub Segment Type' ;
    rdfs:comment 'Granular sub-classification within the segment type (e.g., Single-Family, Multi-Family under Residential; Small Business, Mid-Market, Enterprise, National Account under Commercial). Used for targeted service offerings and NPS benchmark differentiation. [ENUM-REF-CANDIDATE: Single-Family|Multi-Family|Small Business|Mid-Market|Enterprise|National Account|Municipal|County|State Agency|Federal Agency|Light Industrial|Heavy Industrial|Non-Profit — promote to reference product]' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityProgramEligible rdf:type rdf:Property ;
    rdfs:label 'Sustainability Program Eligible' ;
    rdfs:comment 'Indicates whether customers in this segment are eligible to enroll in Waste Management sustainability programs (e.g., zero-waste consulting, RNG offset credits, SRF programs, carbon footprint reporting). Typically available to commercial, industrial, and government segments.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:wasteLogicsSegmentCode rdf:type rdf:Property ;
    rdfs:label 'Waste Logics Segment Code' ;
    rdfs:comment 'Corresponding segment identifier code as configured in the Waste Logics customer portal and service scheduling system. Enables accurate service eligibility filtering and container management rules for customers accessing the self-service portal.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceOrderId rdf:type rdf:Property ;
    rdfs:label 'Service Order Id' ;
    rdfs:comment 'Foreign key linking to hazmat.hazmat_service_order. Business justification: Customer interactions (calls, portal messages, emails) frequently reference specific hazmat service orders for scheduling changes, pricing inquiries, manifest questions, or service issues. Enables com' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceOrder .

ind:activityNumber rdf:type rdf:Property ;
    rdfs:label 'Activity Number' ;
    rdfs:comment 'Externally-known business identifier for this interaction, sourced from Salesforce CRM Activity record number (e.g., ACT-2024-00123456). Used for cross-system traceability and customer-facing reference.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agentName rdf:type rdf:Property ;
    rdfs:label 'Agent Name' ;
    rdfs:comment 'Name of the customer service agent, field representative, or automated system identifier that handled this interaction. For automated interactions, this may contain the system name (e.g., \'IVR_SYSTEM\', \'CHATBOT_V2\'). Used for agent performance reporting and quality assurance.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agentTeam rdf:type rdf:Property ;
    rdfs:label 'Agent Team' ;
    rdfs:comment 'The contact center team, queue, or department to which the handling agent belongs (e.g., \'Residential_Billing\', \'Commercial_Service\', \'Environmental_Compliance\', \'Field_Operations\'). Used for team-level performance analytics and workload distribution reporting.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Completed Timestamp' ;
    rdfs:comment 'Date and time when the interaction was formally closed or resolved. Distinct from interaction_timestamp (when it started) and last_modified_timestamp (last record update). Used for resolution time calculation and SLA (Service Level Agreement) compliance.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:crmActivityReference rdf:type rdf:Property ;
    rdfs:label 'Crm Activity Reference' ;
    rdfs:comment 'Source system identifier from Salesforce CRM Activity record (e.g., \'00T5f000004XXXXX\'). Enables traceability back to the originating CRM record for reconciliation, audit, and cross-system data quality validation.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:csatScore rdf:type rdf:Property ;
    rdfs:label 'Csat Score' ;
    rdfs:comment 'Customer Satisfaction score collected via post-interaction survey, typically on a 1–5 scale. Distinct from NPS (Net Promoter Score) — CSAT measures satisfaction with this specific interaction, while NPS measures overall brand loyalty. Null if no survey was administered.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:direction rdf:type rdf:Property ;
    rdfs:label 'Direction' ;
    rdfs:comment 'Indicates whether the interaction was initiated by the customer (inbound), initiated by Waste Management (outbound), or an internal system-generated event (internal). Critical for contact center workload analysis and proactive outreach tracking.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Escalated Timestamp' ;
    rdfs:comment 'Date and time when the interaction was escalated to a higher support tier, supervisor, or specialized team. Null if no escalation occurred. Used for escalation rate reporting and quality management.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:holdDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Hold Duration Seconds' ;
    rdfs:comment 'Total time in seconds the customer was placed on hold during a phone interaction. Subset of duration_seconds. Used for contact center quality management and customer experience analytics.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:interactionStatus rdf:type rdf:Property ;
    rdfs:label 'Interaction Status' ;
    rdfs:comment 'Current lifecycle state of the interaction record. \'open\' indicates initiated but not yet resolved; \'in_progress\' indicates actively being handled; \'completed\' indicates successfully closed; \'abandoned\' indicates customer disconnected before resolution; \'escalated\' indicates transferred to a higher tier; \'cancelled\' indicates voided interaction.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Interaction Timestamp' ;
    rdfs:comment 'The precise date and time when the customer interaction event occurred (i.e., when the call was received, chat was initiated, email was sent, or field visit commenced). This is the principal real-world event time, distinct from record audit timestamps.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:interactionType rdf:type rdf:Property ;
    rdfs:label 'Interaction Type' ;
    rdfs:comment 'Classification of the interaction by the nature of the touchpoint. Distinguishes between human-initiated contacts (call, chat, email, field visit) and system-generated events (automated notification, portal login). [ENUM-REF-CANDIDATE: call|chat|email|portal_login|field_visit|automated_notification|sms — promote to reference product]' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isEscalated rdf:type rdf:Property ;
    rdfs:label 'Is Escalated' ;
    rdfs:comment 'Indicates whether this interaction was escalated to a higher support tier or supervisor during its lifecycle. True if escalated; False otherwise. Used as a quick filter for escalation rate KPI (Key Performance Indicator) reporting.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFirstContactResolution rdf:type rdf:Property ;
    rdfs:label 'Is First Contact Resolution' ;
    rdfs:comment 'Indicates whether the customer\'s issue was fully resolved during this single interaction without requiring a follow-up contact or callback. True if resolved on first contact; False otherwise. Key KPI (Key Performance Indicator) for contact center performance and NPS (Net Promoter Score) correlation analysis.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:outcomeCode rdf:type rdf:Property ;
    rdfs:label 'Outcome Code' ;
    rdfs:comment 'Standardized code representing the resolution or result of the interaction (e.g., \'RESOLVED\', \'ESCALATED_TIER2\', \'CALLBACK_SCHEDULED\', \'NO_ACTION_REQUIRED\', \'VOICEMAIL_LEFT\', \'WORK_ORDER_CREATED\'). Sourced from Salesforce CRM Activity Result/Disposition field. [ENUM-REF-CANDIDATE: resolved|escalated_tier2|callback_scheduled|no_action_required|voicemail_left|work_order_created|transferred — promote to reference product]' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outcomeDescription rdf:type rdf:Property ;
    rdfs:label 'Outcome Description' ;
    rdfs:comment 'Free-text narrative describing the resolution, action taken, or result of the interaction. Complements the structured outcome_code with agent-entered notes or system-generated summaries. Used for dispute resolution and quality assurance review.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordingAvailable rdf:type rdf:Property ;
    rdfs:label 'Recording Available' ;
    rdfs:comment 'Indicates whether a call or chat recording is available for this interaction in the contact center recording system. True if a recording exists; False otherwise. Used for quality assurance, dispute resolution, and compliance audit purposes.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recordingReference rdf:type rdf:Property ;
    rdfs:label 'Recording Reference' ;
    rdfs:comment 'External reference identifier or URL pointing to the call or chat recording stored in the contact center recording system. Null if recording_available is False. Used for quality assurance review and dispute resolution evidence retrieval.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryComplaintFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Complaint Flag' ;
    rdfs:comment 'Indicates whether this interaction involves a regulatory complaint filed with or referenced from a governing body such as the EPA (Environmental Protection Agency), OSHA (Occupational Safety and Health Administration), DOT (Department of Transportation), or a State Environmental Quality Department. True if regulatory; False otherwise. Triggers compliance escalation workflows.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduledCallbackTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Callback Timestamp' ;
    rdfs:comment 'Date and time when a callback was scheduled for the customer, applicable when the interaction outcome resulted in a deferred follow-up. Null if no callback was scheduled. Used for workforce scheduling and follow-up compliance tracking.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:subject rdf:type rdf:Property ;
    rdfs:label 'Subject' ;
    rdfs:comment 'Brief title or subject line describing the primary topic of the interaction (e.g., \'Missed Pickup Complaint\', \'Billing Inquiry - Invoice #12345\', \'New Service Setup Request\'). Sourced from Salesforce CRM Activity Subject field.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyAdministered rdf:type rdf:Property ;
    rdfs:label 'Survey Administered' ;
    rdfs:comment 'Indicates whether a post-interaction satisfaction survey (NPS or CSAT) was administered to the customer following this interaction. True if survey was sent/offered; False otherwise. Used to calculate survey response rates and coverage.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:topicCategory rdf:type rdf:Property ;
    rdfs:label 'Topic Category' ;
    rdfs:comment 'Standardized business category classifying the primary topic of the interaction. Used for volume trending, root cause analysis, and agent routing. [ENUM-REF-CANDIDATE: billing|service_request|complaint|inquiry|new_service|cancellation|compliance|other — promote to reference product]' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:topicSubcategory rdf:type rdf:Property ;
    rdfs:label 'Topic Subcategory' ;
    rdfs:comment 'Secondary classification providing more granular detail within the topic_category (e.g., under \'billing\': \'rate_dispute\', \'payment_arrangement\', \'invoice_copy_request\'; under \'service_request\': \'missed_pickup\', \'container_swap\', \'bulk_item_pickup\'). Supports detailed analytics and agent knowledge base routing.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferCount rdf:type rdf:Property ;
    rdfs:label 'Transfer Count' ;
    rdfs:comment 'Number of times the interaction was transferred between agents, queues, or departments before final resolution. Zero if handled by the initial agent without transfer. Used for contact center efficiency analysis and customer effort scoring.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:waitDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Wait Duration Seconds' ;
    rdfs:comment 'Time in seconds the customer waited before being connected to an agent or receiving a response. For calls, this is the queue wait time. For chats, this is the time to first agent response. Key metric for SLA (Service Level Agreement) compliance and customer satisfaction.' ;
    rdfs:domain ind:Interaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:leadId rdf:type rdf:Property ;
    rdfs:label 'Lead Id' ;
    rdfs:comment 'Unique surrogate identifier for the lead record in the Waste Management customer acquisition pipeline. Primary key for the lead data product.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:leadAssignedSalesRepEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Lead Assigned Sales Rep Employee Id' ;
    rdfs:comment 'FK to workforce.employee' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:leadEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Lead Employee Id' ;
    rdfs:comment 'Identifier of the Waste Management sales representative assigned to own and progress this lead. References the employee record in Workday HCM. Used for workload balancing, performance tracking, and commission attribution.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:recyclingProgramId rdf:type rdf:Property ;
    rdfs:label 'Recycling Program Id' ;
    rdfs:comment 'Foreign key linking to recycling.recycling_program. Business justification: Sales leads for commercial recycling services are qualified against available recycling programs to verify service availability, accepted materials, and pricing. Required for accurate sales qualificat' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RecyclingProgram .

ind:budgetConfirmed rdf:type rdf:Property ;
    rdfs:label 'Budget Confirmed' ;
    rdfs:comment 'Indicates whether the prospect has confirmed they have an approved budget allocated for waste management services. A key qualification criterion in the sales process; confirmed budget increases conversion probability.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:collectionFrequencyRequested rdf:type rdf:Property ;
    rdfs:label 'Collection Frequency Requested' ;
    rdfs:comment 'Requested frequency of waste collection service as expressed by the prospect. Used for route planning feasibility and SLA (Service Level Agreement) design during the sales process.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyName rdf:type rdf:Property ;
    rdfs:label 'Company Name' ;
    rdfs:comment 'Legal or trade name of the prospective commercial, industrial, or municipal organization. Null for residential (B2C) leads where individual name fields apply.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitorIncumbent rdf:type rdf:Property ;
    rdfs:label 'Competitor Incumbent' ;
    rdfs:comment 'Name of the current waste service provider (competitor) serving the prospect, if known. Used for competitive intelligence, win/loss analysis, and tailoring the sales pitch to differentiate Waste Management\'s service offering.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerTypeRequested rdf:type rdf:Property ;
    rdfs:label 'Container Type Requested' ;
    rdfs:comment 'Type of waste container the prospect has requested or that is appropriate for their service needs. Informs equipment provisioning and CID (Container Identification) assignment upon conversion. Values: cart (residential/small commercial), dumpster (FEL/REL front-end or rear-end loader), roll-off (C&D or large volume), compactor (commercial high-density), tote (recycling), none (service-only).' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractEndDateIncumbent rdf:type rdf:Property ;
    rdfs:label 'Contract End Date Incumbent' ;
    rdfs:comment 'Date on which the prospect\'s current service contract with an incumbent provider expires. Critical for timing outreach and proposal submission to align with the prospect\'s procurement window.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:conversionDate rdf:type rdf:Property ;
    rdfs:label 'Conversion Date' ;
    rdfs:comment 'Date on which the lead was formally converted to an active customer account. Populated when lead_status transitions to \'converted\'. Used for sales cycle duration analysis and conversion rate KPI (Key Performance Indicator) reporting.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:crmLeadReference rdf:type rdf:Property ;
    rdfs:label 'Crm Lead Reference' ;
    rdfs:comment 'External lead identifier sourced from Salesforce CRM Lead object. Used to trace the record back to the originating system of record for reconciliation and audit purposes.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionMakerConfirmed rdf:type rdf:Property ;
    rdfs:label 'Decision Maker Confirmed' ;
    rdfs:comment 'Indicates whether the sales representative has confirmed contact with the actual decision-maker (budget authority) at the prospect organization. Critical qualification criterion; unconfirmed decision-maker contact reduces forecast reliability.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:decisionTimeline rdf:type rdf:Property ;
    rdfs:label 'Decision Timeline' ;
    rdfs:comment 'Prospect\'s anticipated timeframe for making a purchasing decision. Used for pipeline stage management, sales forecasting, and prioritizing follow-up activities by the assigned sales representative.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:email rdf:type rdf:Property ;
    rdfs:label 'Email' ;
    rdfs:comment 'Primary email address of the lead contact used for sales outreach, marketing communications, and follow-up correspondence. Sourced from Salesforce CRM.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedAnnualRevenue rdf:type rdf:Property ;
    rdfs:label 'Estimated Annual Revenue' ;
    rdfs:comment 'Projected annual revenue (USD) expected from this lead if converted to an active account. Used for sales pipeline valuation, quota tracking, and EBITDA (Earnings Before Interest Taxes Depreciation and Amortization) forecasting. Calculated by sales representative based on service scope and applicable rate schedules.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedMonthlyVolumeTons rdf:type rdf:Property ;
    rdfs:label 'Estimated Monthly Volume Tons' ;
    rdfs:comment 'Estimated monthly waste generation volume in tons (short tons) for the prospective customer. Key input for service sizing, container selection, collection frequency determination, and revenue forecasting. Expressed in TPD (Tons Per Day) equivalent basis for commercial and industrial prospects.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:industrySector rdf:type rdf:Property ;
    rdfs:label 'Industry Sector' ;
    rdfs:comment 'Industry classification of the prospective commercial or industrial customer (e.g., healthcare, retail, construction, manufacturing, hospitality, government). Used for targeted sales strategies, regulatory compliance pre-assessment (RCRA, CERCLA), and service customization. Applies to B2B and municipal leads.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isHazardousWasteGenerator rdf:type rdf:Property ;
    rdfs:label 'Is Hazardous Waste Generator' ;
    rdfs:comment 'Indicates whether the prospective customer generates hazardous waste requiring RCRA (Resource Conservation and Recovery Act) compliant handling, manifesting, and disposal through a licensed TSDF (Treatment Storage and Disposal Facility). Triggers specialized sales routing and compliance review.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastContactDate rdf:type rdf:Property ;
    rdfs:label 'Last Contact Date' ;
    rdfs:comment 'Most recent date on which a Waste Management sales representative made contact with the lead (call, email, meeting, or site visit). Used to identify stale leads requiring re-engagement and to enforce follow-up SLA (Service Level Agreement) compliance.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leadSource rdf:type rdf:Property ;
    rdfs:label 'Lead Source' ;
    rdfs:comment 'Channel or method through which the lead was originally generated. Supports marketing attribution analysis and campaign ROI (Return on Investment) measurement. [ENUM-REF-CANDIDATE: web_form|referral|cold_outreach|trade_show|municipal_rfp|partner|inbound_call|digital_ad — promote to reference product]' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadStatus rdf:type rdf:Property ;
    rdfs:label 'Lead Status' ;
    rdfs:comment 'Current lifecycle stage of the lead within the Waste Management customer acquisition pipeline. Tracks progression from initial capture through qualification to conversion or disqualification. Values: new (just captured), contacted (outreach made), qualified (meets service criteria), converted (became active account), lost (disqualified or chose competitor).' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lostReason rdf:type rdf:Property ;
    rdfs:label 'Lost Reason' ;
    rdfs:comment 'Reason code explaining why the lead was marked as lost and did not convert to an active account. Used for win/loss analysis, competitive intelligence, and sales process improvement. Populated only when lead_status = \'lost\'.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phone rdf:type rdf:Property ;
    rdfs:label 'Phone' ;
    rdfs:comment 'Primary phone number for the lead contact. Used by sales representatives for initial outreach and qualification calls. Formatted per E.164 international standard.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prospectType rdf:type rdf:Property ;
    rdfs:label 'Prospect Type' ;
    rdfs:comment 'Classification of the prospective customer by service segment. Residential (B2C household), commercial (B2B business), industrial (large-scale waste generator), or municipal (government/public sector contract). Drives service offering, pricing tier, and sales routing.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationScore rdf:type rdf:Property ;
    rdfs:label 'Qualification Score' ;
    rdfs:comment 'Numeric score (0–100) assigned to the lead based on qualification criteria including service volume, budget authority, decision timeline, and fit with Waste Management service offerings. Higher scores indicate higher conversion probability. Supports sales prioritization and pipeline management.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rfpNumber rdf:type rdf:Property ;
    rdfs:label 'Rfp Number' ;
    rdfs:comment 'Reference number of the formal Request for Proposal issued by a municipal or government prospect. Applicable primarily to municipal contract leads. Used to track competitive bid processes and link to proposal documentation.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesRegion rdf:type rdf:Property ;
    rdfs:label 'Sales Region' ;
    rdfs:comment 'Geographic sales region to which this lead is assigned within Waste Management\'s organizational territory structure (e.g., Northeast, Southeast, Midwest, West). Used for regional performance reporting and territory management.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceCountry rdf:type rdf:Property ;
    rdfs:label 'Service Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code for the prospective service location (e.g., USA). Supports international operations and regulatory jurisdiction determination.' ;
    rdfs:domain ind:Lead ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceTypeRequested rdf:type rdf:Property ;
    rdfs:label 'Service Type Requested' ;
    rdfs:comment 'Primary waste management service type the prospect is interested in. MSW (Municipal Solid Waste) collection, recycling, C&D (Construction and Demolition) waste, hazardous waste handling, WTE (Waste-to-Energy), landfill disposal, roll-off container, or portable sanitation. [ENUM-REF-CANDIDATE: msw_collection|recycling|c_and_d|hazardous_waste|wte|landfill|roll_off|portable_toilet — promote to reference product]' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:npsResponseId rdf:type rdf:Property ;
    rdfs:label 'Nps Response Id' ;
    rdfs:comment 'Unique system-generated identifier for each NPS survey response record. Serves as the primary key for the nps_response data product in the customer domain silver layer.' ;
    rdfs:domain ind:NpsResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceDistrictId rdf:type rdf:Property ;
    rdfs:label 'Service District Id' ;
    rdfs:comment 'Reference to the geographic service district or operational territory associated with the customer\'s service address at the time of the survey. Enables geographic NPS benchmarking and district-level service quality analysis.' ;
    rdfs:domain ind:NpsResponse ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:District .

ind:surveyId rdf:type rdf:Property ;
    rdfs:label 'Survey Id' ;
    rdfs:comment 'Reference to the parent survey campaign or survey definition that generated this response. Links to the survey master record defining the questionnaire version, distribution cohort, and campaign metadata.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Survey .

ind:dataQualityFlag rdf:type rdf:Property ;
    rdfs:label 'Data Quality Flag' ;
    rdfs:comment 'Quality classification assigned to this NPS response during ingestion and validation processing. Flags responses as valid, duplicate submissions, suspected automated/bot responses, internal test responses, or incomplete records. Used to filter analytics datasets to production-quality responses only.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceType rdf:type rdf:Property ;
    rdfs:label 'Device Type' ;
    rdfs:comment 'The type of device used by the customer to complete the NPS survey. Enables channel experience optimization and response quality analysis by device category.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Follow Up Completed Timestamp' ;
    rdfs:comment 'The date and time when the closed-loop follow-up action for this NPS response was completed. Used to measure follow-up response time, SLA adherence for detractor recovery, and closed-loop program effectiveness.' ;
    rdfs:domain ind:NpsResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:followUpRequired rdf:type rdf:Property ;
    rdfs:label 'Follow Up Required' ;
    rdfs:comment 'Indicates whether this NPS response requires a closed-loop follow-up action, typically triggered for Detractor responses (score 0-6) or responses containing escalation keywords in verbatim feedback. Drives CRM case creation and customer recovery workflows in Salesforce.' ;
    rdfs:domain ind:NpsResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:followUpStatus rdf:type rdf:Property ;
    rdfs:label 'Follow Up Status' ;
    rdfs:comment 'Current status of the closed-loop follow-up action for this NPS response. Tracks whether a follow-up has been initiated, is in progress, has been completed, or is not required. Used for closed-loop completion rate reporting and SLA compliance.' ;
    rdfs:domain ind:NpsResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAnonymous rdf:type rdf:Property ;
    rdfs:label 'Is Anonymous' ;
    rdfs:comment 'Indicates whether the customer chose to submit the NPS response anonymously, without linking their identity to the feedback. When True, verbatim feedback and score are retained but customer linkage is suppressed for reporting purposes.' ;
    rdfs:domain ind:NpsResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:relationshipSurveyPeriod rdf:type rdf:Property ;
    rdfs:label 'Relationship Survey Period' ;
    rdfs:comment 'The calendar period identifier (e.g., \'Q1-2025\', \'2024-H2\') for annual or periodic relationship NPS surveys. Populated only for relationship survey trigger types; null for transactional post-service surveys. Enables period-over-period relationship NPS trending.' ;
    rdfs:domain ind:NpsResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:respondentCategory rdf:type rdf:Property ;
    rdfs:label 'Respondent Category' ;
    rdfs:comment 'Derived classification of the customer based on their NPS score: Promoter (9-10), Passive (7-8), or Detractor (0-6). Drives closed-loop follow-up workflows, escalation routing, and customer satisfaction KPI reporting.' ;
    rdfs:domain ind:NpsResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseLatencyHours rdf:type rdf:Property ;
    rdfs:label 'Response Latency Hours' ;
    rdfs:comment 'The elapsed time in hours between the survey sent timestamp and the response submission timestamp. Used to analyze customer engagement speed, optimize survey send timing, and assess the relationship between response latency and NPS score.' ;
    rdfs:domain ind:NpsResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responseReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Response Reference Number' ;
    rdfs:comment 'Externally visible alphanumeric reference number assigned to this NPS response, used in customer communications, closed-loop follow-up correspondence, and cross-system reconciliation with Salesforce CRM and Waste Logics.' ;
    rdfs:domain ind:NpsResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseStatus rdf:type rdf:Property ;
    rdfs:label 'Response Status' ;
    rdfs:comment 'Current lifecycle status of the NPS survey response record. \'submitted\' indicates a complete response; \'partial\' indicates the customer started but did not finish; \'opted_out\' indicates the customer declined to participate; \'expired\' indicates the survey link lapsed; \'invalid\' indicates a response flagged for data quality issues.' ;
    rdfs:domain ind:NpsResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Response Timestamp' ;
    rdfs:comment 'The exact date and time (with timezone offset) when the customer submitted the NPS survey response. Serves as the principal business event timestamp for this transaction. Used for time-series trending, SLA measurement, and response rate analysis.' ;
    rdfs:domain ind:NpsResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:secondaryQuestionScore rdf:type rdf:Property ;
    rdfs:label 'Secondary Question Score' ;
    rdfs:comment 'Numeric score (typically 1-5 or 1-10) provided by the customer in response to a secondary survey question, such as a Customer Effort Score (CES) or Customer Satisfaction Score (CSAT) question included alongside the primary NPS question. Nullable when no secondary question was presented.' ;
    rdfs:domain ind:NpsResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:secondaryQuestionText rdf:type rdf:Property ;
    rdfs:label 'Secondary Question Text' ;
    rdfs:comment 'The text of the secondary survey question answered by the customer (e.g., \'How easy was it to resolve your issue today?\'). Stored to maintain context for the secondary_question_score and to support multi-question survey analysis.' ;
    rdfs:domain ind:NpsResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemResponseReference rdf:type rdf:Property ;
    rdfs:label 'Source System Response Reference' ;
    rdfs:comment 'The native identifier of this NPS response record in the originating source system (e.g., Salesforce Survey Response ID or Waste Logics response key). Used for cross-system reconciliation, deduplication, and audit trail back to the system of record.' ;
    rdfs:domain ind:NpsResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyChannel rdf:type rdf:Property ;
    rdfs:label 'Survey Channel' ;
    rdfs:comment 'The delivery channel through which the NPS survey was sent and the response was collected. Values include email, SMS (Short Message Service), IVR (Interactive Voice Response), customer portal (Waste Logics), or in-app. Enables channel-level response rate and satisfaction analysis.' ;
    rdfs:domain ind:NpsResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyExpiryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Survey Expiry Timestamp' ;
    rdfs:comment 'The date and time after which the survey link or invitation is no longer valid for response submission. Used to classify responses as \'expired\' and to enforce survey response window policies.' ;
    rdfs:domain ind:NpsResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:surveyLanguage rdf:type rdf:Property ;
    rdfs:label 'Survey Language' ;
    rdfs:comment 'ISO 639-1 two-letter language code indicating the language in which the survey was presented and the response was collected (e.g., \'en\' for English, \'es\' for Spanish). Supports multilingual customer base analysis and localization compliance.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveySentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Survey Sent Timestamp' ;
    rdfs:comment 'The date and time when the NPS survey invitation was dispatched to the customer via the selected channel. Used to calculate response latency (time from send to response) and to measure survey expiry windows.' ;
    rdfs:domain ind:NpsResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:surveyVersion rdf:type rdf:Property ;
    rdfs:label 'Survey Version' ;
    rdfs:comment 'The version identifier of the survey questionnaire used to collect this response. Enables longitudinal comparability analysis when survey questions or scales are updated, and supports A/B testing of survey designs.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggerEventType rdf:type rdf:Property ;
    rdfs:label 'Trigger Event Type' ;
    rdfs:comment 'The business event that triggered dispatch of this NPS survey. Classifies whether the survey was sent following a specific service interaction (post_service), as part of an annual relationship survey, during customer onboarding, after a service recovery action, or at contract renewal. Enables segmented satisfaction benchmarking by trigger type.' ;
    rdfs:domain ind:NpsResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verbatimFeedback rdf:type rdf:Property ;
    rdfs:label 'Verbatim Feedback' ;
    rdfs:comment 'Free-text open-ended comment provided by the customer explaining the reason for their NPS score. Used for qualitative analysis, sentiment scoring, service quality benchmarking, and closed-loop feedback management. May contain sensitive customer opinions about service personnel or operations.' ;
    rdfs:domain ind:NpsResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portalAccountId rdf:type rdf:Property ;
    rdfs:label 'Portal Account Id' ;
    rdfs:comment 'Unique system-generated surrogate identifier for the customer self-service portal account record in the Waste Logics customer portal. Primary key for this entity.' ;
    rdfs:domain ind:PortalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountLockedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Account Locked Timestamp' ;
    rdfs:comment 'Date and time at which the portal account was most recently locked due to excessive failed login attempts or an administrative security action. Null if the account has never been locked. Used for security incident tracking and lockout duration reporting.' ;
    rdfs:domain ind:PortalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:authMethod rdf:type rdf:Property ;
    rdfs:label 'Auth Method' ;
    rdfs:comment 'Primary authentication mechanism configured for this portal account. \'password\' — standard username/password credential; \'sso\' — Single Sign-On via enterprise identity provider; \'oauth2\' — OAuth 2.0 delegated authorization; \'saml\' — Security Assertion Markup Language federation. Determines the login flow presented to the customer.' ;
    rdfs:domain ind:PortalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billPaymentAccess rdf:type rdf:Property ;
    rdfs:label 'Bill Payment Access' ;
    rdfs:comment 'Indicates whether this portal account has been granted access to the online bill payment feature, enabling customers to view invoices and submit payments through the Waste Logics portal. May be restricted for accounts under collections or with disputed balances.' ;
    rdfs:domain ind:PortalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:containerRequestAccess rdf:type rdf:Property ;
    rdfs:label 'Container Request Access' ;
    rdfs:comment 'Indicates whether this portal account has been granted access to submit container delivery, swap, or removal requests through the self-service portal. Container ID (CID) management requests are routed to the AMCS Platform for fulfillment.' ;
    rdfs:domain ind:PortalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:documentDownloadAccess rdf:type rdf:Property ;
    rdfs:label 'Document Download Access' ;
    rdfs:comment 'Indicates whether this portal account has been granted access to download documents such as invoices, service agreements, waste manifests, and compliance certificates through the self-service portal.' ;
    rdfs:domain ind:PortalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:emailVerified rdf:type rdf:Property ;
    rdfs:label 'Email Verified' ;
    rdfs:comment 'Indicates whether the registered email address for this portal account has been confirmed via an email verification workflow (e.g., click-through confirmation link). True = verified; False = unverified. Unverified accounts may have restricted portal feature access.' ;
    rdfs:domain ind:PortalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:emailVerifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Email Verified Timestamp' ;
    rdfs:comment 'Date and time at which the portal account email address was confirmed via the verification workflow. Null if email has not yet been verified. Provides audit trail for consent and identity verification compliance.' ;
    rdfs:domain ind:PortalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:failedLoginCount rdf:type rdf:Property ;
    rdfs:label 'Failed Login Count' ;
    rdfs:comment 'Cumulative count of consecutive failed login attempts since the last successful login or since the counter was last reset. Used to trigger account lockout policies per security standards. Reset to zero upon successful authentication.' ;
    rdfs:domain ind:PortalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inactivityThresholdDays rdf:type rdf:Property ;
    rdfs:label 'Inactivity Threshold Days' ;
    rdfs:comment 'Number of consecutive days without a successful login after which this portal account is flagged as inactive and subject to dormancy policies (e.g., notification, auto-suspension). May be set at the account level to override the system default for specific customer segments.' ;
    rdfs:domain ind:PortalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastLoginIpAddress rdf:type rdf:Property ;
    rdfs:label 'Last Login Ip Address' ;
    rdfs:comment 'IP address from which the most recent successful login was performed. Used for security anomaly detection, geographic access monitoring, and fraud investigation. May be considered PII under GDPR and CCPA in some jurisdictions.' ;
    rdfs:domain ind:PortalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastLoginTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Login Timestamp' ;
    rdfs:comment 'Date and time of the most recent successful authenticated login to the Waste Logics customer portal for this account. Used for inactivity detection, dormant account management, security monitoring, and customer engagement analytics.' ;
    rdfs:domain ind:PortalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:linkedAccountCount rdf:type rdf:Property ;
    rdfs:label 'Linked Account Count' ;
    rdfs:comment 'Number of distinct customer service accounts (e.g., multiple service addresses or business locations) currently linked to this portal account. Supports multi-account management use cases common in commercial and municipal customers managing multiple service sites.' ;
    rdfs:domain ind:PortalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mfaEnabled rdf:type rdf:Property ;
    rdfs:label 'Mfa Enabled' ;
    rdfs:comment 'Indicates whether Multi-Factor Authentication (MFA) is currently active for this portal account. True = MFA is enforced at login; False = single-factor authentication only. Supports security compliance reporting and risk-based access control policies.' ;
    rdfs:domain ind:PortalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mfaMethod rdf:type rdf:Property ;
    rdfs:label 'Mfa Method' ;
    rdfs:comment 'The specific second-factor mechanism enrolled for this portal account when MFA is enabled. \'totp\' — Time-based One-Time Password (e.g., Google Authenticator); \'sms\' — SMS text message code; \'email\' — email-delivered OTP; \'authenticator_app\' — push notification via authenticator app; \'none\' — MFA not configured.' ;
    rdfs:domain ind:PortalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationEmailEnabled rdf:type rdf:Property ;
    rdfs:label 'Notification Email Enabled' ;
    rdfs:comment 'Indicates whether the customer has opted in to receive email notifications from the portal (e.g., service reminders, billing alerts, collection schedule changes). True = subscribed; False = unsubscribed. Governs outbound email communication consent.' ;
    rdfs:domain ind:PortalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationPushEnabled rdf:type rdf:Property ;
    rdfs:label 'Notification Push Enabled' ;
    rdfs:comment 'Indicates whether the customer has opted in to receive mobile push notifications via the Waste Logics customer portal mobile application. True = subscribed; False = unsubscribed. Supports real-time service alerts and collection reminders.' ;
    rdfs:domain ind:PortalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationSmsEnabled rdf:type rdf:Property ;
    rdfs:label 'Notification Sms Enabled' ;
    rdfs:comment 'Indicates whether the customer has opted in to receive SMS/text message notifications from the portal (e.g., collection day reminders, service disruption alerts). True = subscribed; False = unsubscribed. Governs outbound SMS communication consent.' ;
    rdfs:domain ind:PortalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paperlessBillingEnabled rdf:type rdf:Property ;
    rdfs:label 'Paperless Billing Enabled' ;
    rdfs:comment 'Indicates whether the customer has enrolled in paperless (electronic) billing through the portal, opting to receive invoices digitally rather than by postal mail. True = paperless billing active; False = paper billing. Supports sustainability reporting on paper reduction and digital adoption KPIs.' ;
    rdfs:domain ind:PortalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:passwordLastChangedDate rdf:type rdf:Property ;
    rdfs:label 'Password Last Changed Date' ;
    rdfs:comment 'Date on which the portal account password was most recently changed or reset. Used to enforce password expiration policies, prompt users to update credentials, and support security compliance audits. Null for SSO-only accounts.' ;
    rdfs:domain ind:PortalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:portalAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Portal Account Number' ;
    rdfs:comment 'Externally visible, human-readable identifier assigned to the portal account by the Waste Logics customer portal system. Used in customer communications, support tickets, and portal UI display. Distinct from the internal surrogate key.' ;
    rdfs:domain ind:PortalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationDate rdf:type rdf:Property ;
    rdfs:label 'Registration Date' ;
    rdfs:comment 'Calendar date on which the customer completed portal account registration in the Waste Logics customer portal. Used for cohort analysis, onboarding funnel reporting, and customer digital adoption tracking.' ;
    rdfs:domain ind:PortalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:registrationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Registration Timestamp' ;
    rdfs:comment 'Precise date and time (with timezone offset) at which the portal account registration was completed and confirmed. Provides audit-grade precision for security forensics, compliance logging, and SLA measurement of onboarding workflows.' ;
    rdfs:domain ind:PortalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:serviceHistoryAccess rdf:type rdf:Property ;
    rdfs:label 'Service History Access' ;
    rdfs:comment 'Indicates whether this portal account has been granted access to view historical service records, including past collection events, work orders (WO), and service requests, through the self-service portal.' ;
    rdfs:domain ind:PortalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceSchedulingAccess rdf:type rdf:Property ;
    rdfs:label 'Service Scheduling Access' ;
    rdfs:comment 'Indicates whether this portal account has been granted access to the self-service scheduling feature, allowing customers to request, modify, or cancel waste collection service appointments online. Controlled by account type and service agreement terms.' ;
    rdfs:domain ind:PortalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ssoExternalReference rdf:type rdf:Property ;
    rdfs:label 'Sso External Reference' ;
    rdfs:comment 'The unique subject identifier (sub claim or NameID) issued by the external SSO identity provider for this portal account. Used to correlate the portal account with the customer\'s federated identity. Null for non-SSO accounts.' ;
    rdfs:domain ind:PortalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ssoProvider rdf:type rdf:Property ;
    rdfs:label 'Sso Provider' ;
    rdfs:comment 'Identity provider (IdP) used for Single Sign-On (SSO) authentication when auth_method is \'sso\' or \'oauth2\'. Identifies the federated identity source. \'none\' for accounts using native password authentication.' ;
    rdfs:domain ind:PortalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suspensionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Suspension Timestamp' ;
    rdfs:comment 'Date and time at which the portal account was most recently placed in a suspended or locked state. Null if the account has never been suspended. Used for SLA tracking on account reinstatement and security incident response timelines.' ;
    rdfs:domain ind:PortalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:termsAccepted rdf:type rdf:Property ;
    rdfs:label 'Terms Accepted' ;
    rdfs:comment 'Indicates whether the customer has accepted the Waste Management portal terms of service and privacy policy during registration or upon a terms update. True = accepted; False = not yet accepted. Accounts with False may have restricted access pending acceptance.' ;
    rdfs:domain ind:PortalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:termsAcceptedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Terms Accepted Timestamp' ;
    rdfs:comment 'Date and time at which the customer most recently accepted the portal terms of service and privacy policy. Provides legally defensible consent audit trail. Updated each time terms are re-accepted following a policy revision.' ;
    rdfs:domain ind:PortalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:termsVersionAccepted rdf:type rdf:Property ;
    rdfs:label 'Terms Version Accepted' ;
    rdfs:comment 'Version identifier of the portal terms of service and privacy policy that the customer most recently accepted (e.g., \'v2.1\', \'v3.0\'). Enables compliance teams to identify customers who have not yet accepted the current version following a policy update.' ;
    rdfs:domain ind:PortalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:username rdf:type rdf:Property ;
    rdfs:label 'Username' ;
    rdfs:comment 'The unique login username chosen by or assigned to the customer for authenticating into the Waste Logics self-service portal. May be an email address or a custom alphanumeric handle. Used as the primary login credential identifier.' ;
    rdfs:domain ind:PortalAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralId rdf:type rdf:Property ;
    rdfs:label 'Referral Id' ;
    rdfs:comment 'Unique system-generated identifier for each customer referral event record in the Waste Management referral tracking system.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:programId rdf:type rdf:Property ;
    rdfs:label 'Program Id' ;
    rdfs:comment 'Identifier of the referral incentive program under which this referral was submitted. Links to the referral program configuration defining reward rules, eligibility, and expiration terms.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReferralProgram .

ind:referralCustomerAccountId rdf:type rdf:Property ;
    rdfs:label 'Referral Customer Account Id' ;
    rdfs:comment 'Identifier of the existing Waste Management customer account that initiated the referral. Links to the customer master record in Salesforce CRM and Waste Logics.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerAccount .

ind:referralReferredAccountCustomerAccountId rdf:type rdf:Property ;
    rdfs:label 'Referral Referred Account Customer Account Id' ;
    rdfs:comment 'Identifier of the prospect or newly converted customer account that was referred. Populated upon conversion from prospect to active customer. Null if the referral has not yet converted.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerAccount .

ind:salesforceLeadId rdf:type rdf:Property ;
    rdfs:label 'Salesforce Lead Id' ;
    rdfs:comment 'The Salesforce CRM Lead or Opportunity record ID associated with the referred prospect. Populated when the referral generates a lead in Salesforce. Used for CRM-to-referral reconciliation and sales pipeline attribution.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lead .

ind:acquisitionCostUsd rdf:type rdf:Property ;
    rdfs:label 'Acquisition Cost Usd' ;
    rdfs:comment 'Total cost attributed to acquiring the referred customer through this referral event, expressed in USD. Includes the reward amount plus any administrative processing costs allocated to this referral. Used for customer acquisition cost (CAC) analysis and ROI measurement of the referral program.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:duplicateFlag rdf:type rdf:Property ;
    rdfs:label 'Duplicate Flag' ;
    rdfs:comment 'Indicates whether this referral has been identified as a duplicate of an existing referral record for the same prospect. True when a duplicate is detected; False otherwise. Duplicate referrals are ineligible for reward fulfillment per program policy.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eligibilityVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Eligibility Verified Flag' ;
    rdfs:comment 'Indicates whether the referral has been validated against program eligibility rules, including service area coverage, account standing of the referring customer, and prospect uniqueness checks. True when eligibility has been confirmed; False when pending or failed validation.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:prospectCity rdf:type rdf:Property ;
    rdfs:label 'Prospect City' ;
    rdfs:comment 'City component of the referred prospect\'s service address. Used for service area eligibility validation and geographic reporting of referral acquisition activity.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prospectEmail rdf:type rdf:Property ;
    rdfs:label 'Prospect Email' ;
    rdfs:comment 'Email address of the referred prospect provided by the referring customer. Used for outreach communications, lead tracking in Salesforce CRM, and identity matching upon conversion to an active account.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prospectFirstName rdf:type rdf:Property ;
    rdfs:label 'Prospect First Name' ;
    rdfs:comment 'First name of the referred prospect as provided at the time of referral submission. Captured before the prospect converts to a full customer account. Used for outreach and identity matching during the conversion process.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prospectLastName rdf:type rdf:Property ;
    rdfs:label 'Prospect Last Name' ;
    rdfs:comment 'Last name of the referred prospect as provided at the time of referral submission. Used in conjunction with prospect_first_name for identity resolution and CRM lead matching in Salesforce.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prospectPhone rdf:type rdf:Property ;
    rdfs:label 'Prospect Phone' ;
    rdfs:comment 'Phone number of the referred prospect as provided at referral submission. Used for outbound sales contact and identity verification during the conversion process.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prospectPostalCode rdf:type rdf:Property ;
    rdfs:label 'Prospect Postal Code' ;
    rdfs:comment 'ZIP or ZIP+4 postal code for the referred prospect\'s service address. Used for service area eligibility checks, route assignment, and geographic segmentation of referral acquisition data.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prospectServiceAddress rdf:type rdf:Property ;
    rdfs:label 'Prospect Service Address' ;
    rdfs:comment 'The service address provided by the referring customer for the prospect. Used to validate service area eligibility, assign the prospect to the correct route and district, and support conversion to an active service account.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prospectStateCode rdf:type rdf:Property ;
    rdfs:label 'Prospect State Code' ;
    rdfs:comment 'Two-letter US state code for the referred prospect\'s service address. Used for service territory validation, state-level regulatory compliance, and geographic referral performance reporting.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralCode rdf:type rdf:Property ;
    rdfs:label 'Referral Code' ;
    rdfs:comment 'Externally visible alphanumeric code assigned to this referral event, used by the referring customer to share with prospects via the Waste Logics customer portal, phone, or written channels. Serves as the business-facing identifier for tracking and attribution.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referralDate rdf:type rdf:Property ;
    rdfs:label 'Referral Date' ;
    rdfs:comment 'The calendar date on which the referring customer submitted the referral. This is the principal business event date used for program eligibility, expiration window calculation, and acquisition cost attribution reporting.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:referralStatus rdf:type rdf:Property ;
    rdfs:label 'Referral Status' ;
    rdfs:comment 'Current lifecycle state of the referral event. \'Pending\' indicates the prospect has not yet signed up; \'converted\' means the prospect became an active customer; \'expired\' means the referral window lapsed without conversion; \'rewarded\' means the reward has been fulfilled; \'cancelled\' means the referral was voided.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rewardAmount rdf:type rdf:Property ;
    rdfs:label 'Reward Amount' ;
    rdfs:comment 'The monetary value of the reward to be issued to the referring customer upon successful referral conversion, expressed in USD. For bill credits, this is the credit amount applied to the account. For gift cards, this is the face value. Zero if reward_type is \'none\'.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rewardCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Reward Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the reward amount. Defaults to USD for domestic US operations. Supports multi-currency reward programs for international or cross-border service territories.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rewardFulfillmentDate rdf:type rdf:Property ;
    rdfs:label 'Reward Fulfillment Date' ;
    rdfs:comment 'The date on which the referral reward was actually issued to the referring customer (e.g., bill credit applied, gift card sent). Null until the reward has been fulfilled. Used to track reward liability, fulfillment SLA compliance, and loyalty program cost accounting.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rewardFulfillmentStatus rdf:type rdf:Property ;
    rdfs:label 'Reward Fulfillment Status' ;
    rdfs:comment 'Current processing status of the reward fulfillment for this referral. \'Pending\' indicates the reward is approved but not yet issued; \'issued\' means the reward has been delivered; \'failed\' indicates a processing error; \'voided\' means the reward was cancelled after approval.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rewardReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Reward Reference Number' ;
    rdfs:comment 'External reference number for the issued reward, such as the bill credit transaction ID in Oracle Revenue Management or the gift card authorization number. Used for reconciliation between the referral record and the billing or fulfillment system.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rewardType rdf:type rdf:Property ;
    rdfs:label 'Reward Type' ;
    rdfs:comment 'The type of incentive reward offered to the referring customer upon successful conversion of the referred prospect. Supports bill credit applied to the referring account, physical or digital gift card, or a service discount. \'None\' indicates no reward is associated with this referral.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:selfReferralFlag rdf:type rdf:Property ;
    rdfs:label 'Self Referral Flag' ;
    rdfs:comment 'Indicates whether the referring customer and the referred prospect have been identified as the same individual or household, which would constitute a fraudulent self-referral. True when self-referral is detected; False otherwise. Self-referrals are ineligible for rewards.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceDistrictCode rdf:type rdf:Property ;
    rdfs:label 'Service District Code' ;
    rdfs:comment 'The Waste Management operational service district code associated with the prospect\'s service address. Used to assign the referral to the correct regional operations team and to measure referral volume and conversion rates by district.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteLogicsReferralReference rdf:type rdf:Property ;
    rdfs:label 'Waste Logics Referral Reference' ;
    rdfs:comment 'The source system referral identifier from the Waste Logics customer portal, where the majority of self-service referrals are submitted. Used for system-of-record traceability and reconciliation between the Silver layer and the operational source system.' ;
    rdfs:domain ind:Referral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designatedFacilityId rdf:type rdf:Property ;
    rdfs:label 'Designated Facility Id' ;
    rdfs:comment 'Foreign key linking to asset.facility. Business justification: Service addresses are assigned a designated disposal facility (landfill, MRF, transfer station) where collected waste is delivered. Route planning, tipping fee calculation, and logistics optimization ' ;
    rdfs:domain ind:ServiceAddress ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:primaryWasteStreamId rdf:type rdf:Property ;
    rdfs:label 'Primary Waste Stream Id' ;
    rdfs:comment 'Foreign key linking to service.service_waste_stream. Business justification: Service addresses must track primary waste stream for route planning, container type assignment, vehicle equipment requirements, and regulatory compliance. Drives operational decisions on collection f' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WasteStream .

ind:addressStatus rdf:type rdf:Property ;
    rdfs:label 'Address Status' ;
    rdfs:comment 'Current lifecycle status of the service address. \'active\' indicates services are currently rendered; \'inactive\' indicates no current services; \'pending_validation\' indicates address requires verification; \'suspended\' indicates temporarily halted; \'demolished\' indicates physical location no longer exists.' ;
    rdfs:domain ind:ServiceAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressValidationStatus rdf:type rdf:Property ;
    rdfs:label 'Address Validation Status' ;
    rdfs:comment 'Result of postal address validation against USPS or third-party address verification service. \'validated\' confirms the address is deliverable and standardized; \'failed\' indicates the address could not be verified; \'overridden\' indicates a manual override was applied by an authorized user.' ;
    rdfs:domain ind:ServiceAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressVerifiedDate rdf:type rdf:Property ;
    rdfs:label 'Address Verified Date' ;
    rdfs:comment 'Date on which the service address was last verified against USPS or third-party address validation service. Used to track address data quality and trigger re-validation workflows when addresses become stale.' ;
    rdfs:domain ind:ServiceAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:diversionProgramEnrolled rdf:type rdf:Property ;
    rdfs:label 'Diversion Program Enrolled' ;
    rdfs:comment 'Indicates whether this service address is enrolled in a waste diversion program (recycling, composting, organics collection). Diversion Rate = percentage of waste diverted from landfill. Used for sustainability reporting, EPA diversion rate calculations, and GHG (Greenhouse Gas) emissions tracking.' ;
    rdfs:domain ind:ServiceAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:externalAddressReference rdf:type rdf:Property ;
    rdfs:label 'External Address Reference' ;
    rdfs:comment 'The externally-known unique identifier for this service address as assigned by the source system of record (e.g., Waste Logics site ID, AMCS location code, or SAP SD ship-to party number). Used for cross-system reconciliation and integration.' ;
    rdfs:domain ind:ServiceAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:franchiseAgreementCode rdf:type rdf:Property ;
    rdfs:label 'Franchise Agreement Code' ;
    rdfs:comment 'Identifier for the municipal franchise or exclusive service agreement under which waste collection services are provided at this address. Links to the applicable franchise contract terms, tipping fee schedules, and municipal reporting obligations.' ;
    rdfs:domain ind:ServiceAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geocodeAccuracy rdf:type rdf:Property ;
    rdfs:label 'Geocode Accuracy' ;
    rdfs:comment 'Precision level of the latitude/longitude geocoding result for this service address. \'rooftop\' indicates exact parcel-level match; \'range_interpolated\' indicates interpolated from street range; \'approximate\' indicates centroid-level. Drives confidence in route optimization and dispatch accuracy.' ;
    rdfs:domain ind:ServiceAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isGated rdf:type rdf:Property ;
    rdfs:label 'Is Gated' ;
    rdfs:comment 'Indicates whether the service address requires gate or controlled access entry. When true, drivers must use the access_code or follow special entry procedures. Used for route planning and driver briefing in AMCS Platform and Locus Dispatch.' ;
    rdfs:domain ind:ServiceAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHazardousWasteSite rdf:type rdf:Property ;
    rdfs:label 'Is Hazardous Waste Site' ;
    rdfs:comment 'Indicates whether this service address is designated for hazardous waste collection or handling services. When true, requires RCRA-compliant manifest tracking, specialized vehicle assignment, and Enviance EHS compliance workflows. Triggers additional regulatory reporting obligations.' ;
    rdfs:domain ind:ServiceAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:municipalityCode rdf:type rdf:Property ;
    rdfs:label 'Municipality Code' ;
    rdfs:comment 'Standardized code identifying the municipality or local enforcement agency (LEA) jurisdiction for this service address. Used for franchise agreement billing, regulatory reporting to State Environmental Quality Departments, and SWIS reporting.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:municipalityName rdf:type rdf:Property ;
    rdfs:label 'Municipality Name' ;
    rdfs:comment 'Name of the local municipality or jurisdiction governing waste collection services at this address (e.g., \'City of Houston\', \'Harris County\'). Determines applicable franchise agreements, tipping fee structures, and regulatory reporting obligations to Local Solid Waste Authorities.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:placementInstructions rdf:type rdf:Property ;
    rdfs:label 'Placement Instructions' ;
    rdfs:comment 'Free-text operational instructions for drivers and collection crews regarding where containers should be placed or retrieved at this service address (e.g., \'Place cart at end of driveway\', \'Containers behind gate on north side\', \'Use rear alley access\'). Sourced from Waste Logics and AMCS Platform driver notes.' ;
    rdfs:domain ind:ServiceAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContainerSizeYards rdf:type rdf:Property ;
    rdfs:label 'Primary Container Size Yards' ;
    rdfs:comment 'Size of the primary waste container at this service address measured in cubic yards (e.g., 2.0, 4.0, 6.0, 8.0, 96-gallon cart = 0.42 yards). Used for capacity planning, tipping fee estimation, and route load calculations. Sourced from Waste Logics container assignment.' ;
    rdfs:domain ind:ServiceAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recyclingProgramType rdf:type rdf:Property ;
    rdfs:label 'Recycling Program Type' ;
    rdfs:comment 'Type of recycling collection program active at this service address. \'single_stream\' = all recyclables commingled; \'dual_stream\' = paper separated from containers; \'source_separated\' = individual material streams. Determines MRF (Materials Recovery Facility) processing requirements and diversion rate calculations.' ;
    rdfs:domain ind:ServiceAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceEndDate rdf:type rdf:Property ;
    rdfs:label 'Service End Date' ;
    rdfs:comment 'Date on which waste collection or environmental services were terminated or are scheduled to end at this service address. Null for currently active addresses. Used for churn analysis, final billing, and container retrieval scheduling.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:serviceSegment rdf:type rdf:Property ;
    rdfs:label 'Service Segment' ;
    rdfs:comment 'Business segment classification for the service address indicating the customer type served at this location. Aligns with B2C residential, B2B commercial, industrial, and government/municipal contract categories. Used for pricing, routing, and regulatory reporting.' ;
    rdfs:domain ind:ServiceAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxJurisdictionCode rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction Code' ;
    rdfs:comment 'Tax jurisdiction identifier for this service address used by Oracle Revenue Management to apply correct state, county, and municipal tax rates to service charges. Determined by address geocoding and jurisdiction boundary mapping.' ;
    rdfs:domain ind:ServiceAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleTypeRestriction rdf:type rdf:Property ;
    rdfs:label 'Vehicle Type Restriction' ;
    rdfs:comment 'Specific vehicle type restrictions applicable to this service address (e.g., \'No rear-loaders\', \'ASL only\', \'No vehicles over 26,000 lbs GVW\'). Used by AMCS Platform and Locus Dispatch to assign compatible collection vehicles. [ENUM-REF-CANDIDATE: asl_only|fel_only|rel_only|no_rear_loader|no_front_loader|no_side_loader|small_vehicle_only — promote to reference product]' ;
    rdfs:domain ind:ServiceAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteStreamTypes rdf:type rdf:Property ;
    rdfs:label 'Waste Stream Types' ;
    rdfs:comment 'Comma-delimited list of waste stream types collected at this service address (e.g., \'MSW,recycling,organics\', \'C&D,hazardous\'). MSW = Municipal Solid Waste; C&D = Construction and Demolition Waste. Drives container assignment, route type, and regulatory classification. [ENUM-REF-CANDIDATE: msw|recycling|organics|c_and_d|hazardous|electronic|bulky|yard_waste — promote to reference product]' ;
    rdfs:domain ind:ServiceAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightRestrictionTons rdf:type rdf:Property ;
    rdfs:label 'Weight Restriction Tons' ;
    rdfs:comment 'Maximum allowable vehicle weight in tons for vehicles accessing this service address, as posted by local road authority or property owner. Constrains which collection vehicle types (ASL, FEL, REL) can service this location. Critical for fleet dispatch and DOT compliance.' ;
    rdfs:domain ind:ServiceAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:zoningClassification rdf:type rdf:Property ;
    rdfs:label 'Zoning Classification' ;
    rdfs:comment 'Land use zoning classification of the service address as defined by local municipal zoning ordinances. Determines applicable service types, container sizes, collection frequency, and regulatory requirements. Drives segmentation between B2C residential, B2B commercial, and government accounts.' ;
    rdfs:domain ind:ServiceAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceTypeId rdf:type rdf:Property ;
    rdfs:label 'Service Type Id' ;
    rdfs:comment 'Reference to the service type catalog entry defining the nature of the waste management service enrolled (e.g., residential MSW cart pickup, commercial FEL dumpster, roll-off container rental, curbside recycling). Links to the service type reference product.' ;
    rdfs:domain ind:ServiceEnrollment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Type .

ind:servicingOrgUnitId rdf:type rdf:Property ;
    rdfs:label 'Servicing Org Unit Id' ;
    rdfs:comment 'Foreign key linking to workforce.org_unit. Business justification: Service enrollments (recurring waste collection, recycling programs, roll-off services) are fulfilled by specific operational units (collection districts, recycling facilities). Enables route planning' ;
    rdfs:domain ind:ServiceEnrollment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:accessRestrictionFlag rdf:type rdf:Property ;
    rdfs:label 'Access Restriction Flag' ;
    rdfs:comment 'Indicates whether the service address for this enrollment has access restrictions (e.g., gated community, locked enclosure, restricted hours, weight-limited road). True = driver must follow special access procedures documented in special_instructions. Used for route planning and driver briefing.' ;
    rdfs:domain ind:ServiceEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cancellationDate rdf:type rdf:Property ;
    rdfs:label 'Cancellation Date' ;
    rdfs:comment 'The date on which the service enrollment was formally cancelled. Distinct from enrollment_end_date, which may reflect a scheduled end; cancellation_date records the actual date the cancellation was processed. Used for churn reporting and final billing cutoff.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:diversionTargetPct rdf:type rdf:Property ;
    rdfs:label 'Diversion Target Pct' ;
    rdfs:comment 'The contractually or operationally agreed target diversion rate (percentage of waste diverted from landfill) for this service enrollment. Applicable primarily to recycling and organics enrollments. Used for sustainability reporting and customer-facing environmental impact dashboards.' ;
    rdfs:domain ind:ServiceEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:enrollmentEndDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment End Date' ;
    rdfs:comment 'The date on which the service enrollment is scheduled to end or was terminated. Null for open-ended recurring service agreements. Populated upon cancellation, contract expiry, or service completion.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enrollmentNumber rdf:type rdf:Property ;
    rdfs:label 'Enrollment Number' ;
    rdfs:comment 'Externally-known, human-readable business identifier for the service enrollment, used in customer communications, Waste Logics portal, and Salesforce CRM service records. Format: SE- followed by 8–12 digits.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentStartDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment Start Date' ;
    rdfs:comment 'The date on which the service enrollment becomes effective and service delivery begins. Used for billing cycle initiation, route assignment, and SLA tracking.' ;
    rdfs:domain ind:ServiceEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enrollmentStatus rdf:type rdf:Property ;
    rdfs:label 'Enrollment Status' ;
    rdfs:comment 'Current lifecycle state of the service enrollment. \'active\' = service is being delivered; \'pending\' = enrollment initiated but not yet started; \'suspended\' = temporarily halted (e.g., customer request, non-payment); \'cancelled\' = terminated before or during service; \'completed\' = service period ended normally.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardousWasteFlag rdf:type rdf:Property ;
    rdfs:label 'Hazardous Waste Flag' ;
    rdfs:comment 'Indicates whether this service enrollment involves the handling, collection, or disposal of RCRA-regulated hazardous waste materials. True = hazardous waste service requiring EPA manifest tracking, TSDF routing, and DOT compliance. Triggers additional regulatory workflows in Enviance EHS.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:monthlyRateUsd rdf:type rdf:Property ;
    rdfs:label 'Monthly Rate Usd' ;
    rdfs:comment 'The contracted or standard monthly charge in US dollars for this service enrollment. Represents the base recurring service fee before fuel surcharges, environmental fees, or taxes. Used for revenue forecasting, billing validation, and contract compliance.' ;
    rdfs:domain ind:ServiceEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originationChannel rdf:type rdf:Property ;
    rdfs:label 'Origination Channel' ;
    rdfs:comment 'The channel through which this service enrollment was initiated. web_portal = customer self-service via Waste Logics portal; call_center = inbound customer service call; field_sales = direct sales representative; crm = Salesforce CRM workflow; edi = electronic data interchange from commercial account; municipal_contract = government contract award.' ;
    rdfs:domain ind:ServiceEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesforceEnrollmentRef rdf:type rdf:Property ;
    rdfs:label 'Salesforce Enrollment Ref' ;
    rdfs:comment 'The Salesforce CRM record ID corresponding to this service enrollment, enabling cross-system traceability between the Databricks lakehouse silver layer and the Salesforce CRM system of record. Standard Salesforce IDs are 15 or 18 alphanumeric characters.' ;
    rdfs:domain ind:ServiceEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceLevel rdf:type rdf:Property ;
    rdfs:label 'Service Level' ;
    rdfs:comment 'The tier of service provided under this enrollment, defining the Service Level Agreement (SLA) commitments such as response time for missed pickups, customer support priority, and on-call availability. Standard = baseline SLA; Premium = enhanced SLA with guaranteed response windows; Basic = minimal SLA.' ;
    rdfs:domain ind:ServiceEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaResponseHours rdf:type rdf:Property ;
    rdfs:label 'Sla Response Hours' ;
    rdfs:comment 'The maximum number of hours within which a missed pickup or service failure must be remediated per the Service Level Agreement (SLA) for this enrollment. Drives customer service escalation workflows and compliance reporting.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:suspensionEndDate rdf:type rdf:Property ;
    rdfs:label 'Suspension End Date' ;
    rdfs:comment 'The date on which a suspended service enrollment is scheduled to resume or was reactivated. Null when enrollment is not suspended or suspension is indefinite. Used for route reinstatement and billing resumption.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:suspensionStartDate rdf:type rdf:Property ;
    rdfs:label 'Suspension Start Date' ;
    rdfs:comment 'The date on which the service enrollment was placed in a suspended state (e.g., seasonal hold, customer-requested pause, non-payment hold). Null when enrollment is not suspended. Used for billing adjustments and route management.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:wasteLogicsEnrollmentRef rdf:type rdf:Property ;
    rdfs:label 'Waste Logics Enrollment Ref' ;
    rdfs:comment 'The enrollment or service record identifier from the Waste Logics customer portal and service scheduling system. Enables cross-system reconciliation between the lakehouse and the Waste Logics operational system of record for container management and service scheduling.' ;
    rdfs:domain ind:ServiceEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfillmentOrgUnitId rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Org Unit Id' ;
    rdfs:comment 'Foreign key linking to workforce.org_unit. Business justification: Service requests (container delivery, special pickups, hazmat handling) are fulfilled by specific operational units (district yards, transfer stations, hazmat teams). Enables workload balancing, SLA c' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:additionalChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Additional Charge Amount' ;
    rdfs:comment 'Dollar amount of any additional charges associated with fulfilling this service request beyond the standard contracted service rate. Includes tipping fees, extra pickup fees, or special handling charges. Sourced from Oracle Revenue Management.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cancelledTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cancelled Timestamp' ;
    rdfs:comment 'The date and time when the service request was cancelled, either by the customer or by operations. Nullable for non-cancelled requests. Used for cancellation rate analysis and customer churn indicators.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:caseNumber rdf:type rdf:Property ;
    rdfs:label 'Case Number' ;
    rdfs:comment 'Externally visible, human-readable case number assigned to the service request, used in customer communications and cross-system tracking. Sourced from Salesforce CRM Case Number or Waste Logics ticket reference.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelSource rdf:type rdf:Property ;
    rdfs:label 'Channel Source' ;
    rdfs:comment 'The intake channel through which the customer submitted the service request. Used for channel analytics, staffing optimization, and digital adoption tracking. Sourced from Salesforce CRM Case Origin or Waste Logics submission metadata.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemCount rdf:type rdf:Property ;
    rdfs:label 'Item Count' ;
    rdfs:comment 'Number of individual bulk items or containers included in the service request. Applicable for bulk item pickup requests where discrete item counts drive truck capacity planning and labor estimation.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Flag' ;
    rdfs:comment 'Indicates whether this service request has regulatory compliance implications, such as hazardous waste handling, RCRA-regulated material pickup, or EPA-reportable incident. When True, triggers compliance workflow and Enviance EHS notification.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requestSubtypeCode rdf:type rdf:Property ;
    rdfs:label 'Request Subtype Code' ;
    rdfs:comment 'Secondary classification providing additional granularity within the request type. For example, under CONTAINER_SWAP: UPSIZE, DOWNSIZE, DAMAGE_REPLACEMENT. Sourced from Salesforce CRM Case Sub-Type.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestTypeCode rdf:type rdf:Property ;
    rdfs:label 'Request Type Code' ;
    rdfs:comment 'Categorical code identifying the nature of the customer service request. Drives workflow routing, SLA assignment, and fulfillment process. [ENUM-REF-CANDIDATE: BULK_PICKUP|EXTRA_PICKUP|MISSED_PICKUP|CONTAINER_SWAP|CONTAINER_REPAIR|START_SERVICE|STOP_SERVICE|BILLING_INQUIRY|HAZMAT_INQUIRY|RECYCLING_INQUIRY|SCHEDULE_CHANGE|OTHER — promote to reference product]' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Timestamp' ;
    rdfs:comment 'The precise date and time when the service request was formally scheduled in the dispatch system. Captures the scheduling event for audit trail and SLA milestone tracking.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:serviceFrequencyType rdf:type rdf:Property ;
    rdfs:label 'Service Frequency Type' ;
    rdfs:comment 'Indicates whether this service request represents a one-time ad hoc service action or a recurring add-on to an existing service schedule. Distinguishes episodic requests from schedule modifications.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceRequestDescription rdf:type rdf:Property ;
    rdfs:label 'Service Request Description' ;
    rdfs:comment 'Full narrative description of the service request as provided by the customer or intake agent. Contains details about the specific issue, location, container, or service need. Sourced from Salesforce CRM Case Description or Waste Logics portal notes.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaDueDate rdf:type rdf:Property ;
    rdfs:label 'Sla Due Date' ;
    rdfs:comment 'The contractual or policy-defined deadline by which the service request must be fulfilled to meet the applicable Service Level Agreement (SLA). Calculated from submitted_timestamp based on request type and priority tier.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceSystemCaseReference rdf:type rdf:Property ;
    rdfs:label 'Source System Case Reference' ;
    rdfs:comment 'The native case or ticket identifier from the originating source system (e.g., Salesforce CRM Case ID or Waste Logics Ticket ID). Enables traceability back to the system of record for reconciliation and audit purposes.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submittedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submitted Timestamp' ;
    rdfs:comment 'The exact date and time when the customer submitted the service request. This is the principal business event timestamp representing when the request entered the system. Used as the baseline for SLA calculation.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:tippingFeeApplicable rdf:type rdf:Property ;
    rdfs:label 'Tipping Fee Applicable' ;
    rdfs:comment 'Indicates whether a tipping fee (charge per ton for waste disposal at a landfill or transfer station) applies to this service request. True for requests involving disposal charges beyond standard service contract terms.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceSuspensionId rdf:type rdf:Property ;
    rdfs:label 'Service Suspension Id' ;
    rdfs:comment 'Unique system-generated identifier for each service suspension event record. Primary key for the service_suspension data product.' ;
    rdfs:domain ind:ServiceSuspension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryServiceEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Service Employee Id' ;
    rdfs:comment 'Reference to the internal employee or system user who created or triggered the suspension record. Supports audit trail requirements under SOX and internal governance policies.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualResumeDate rdf:type rdf:Property ;
    rdfs:label 'Actual Resume Date' ;
    rdfs:comment 'The actual calendar date on which service was restored and the suspension was lifted. Null if the suspension is still active. Compared against expected_resume_date to measure suspension duration accuracy and SLA compliance.' ;
    rdfs:domain ind:ServiceSuspension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:autoResumeEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Resume Enabled' ;
    rdfs:comment 'Indicates whether the system should automatically reinstate service on the expected_resume_date without requiring manual intervention. When True, AMCS Platform and Oracle Revenue Management are triggered automatically on the resume date.' ;
    rdfs:domain ind:ServiceSuspension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:billingAdjustmentRequired rdf:type rdf:Property ;
    rdfs:label 'Billing Adjustment Required' ;
    rdfs:comment 'Indicates whether a billing credit or adjustment must be applied to the customer account for the duration of the suspension. True for voluntary holds and operational interruptions; typically False for non-payment suspensions. Triggers workflow in Oracle Revenue Management.' ;
    rdfs:domain ind:ServiceSuspension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:billingCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Billing Credit Amount' ;
    rdfs:comment 'The monetary credit amount (in USD) to be applied to the customer\'s account for the suspension period. Calculated based on the prorated service rate and suspension duration. Populated by Oracle Revenue Management upon suspension approval.' ;
    rdfs:domain ind:ServiceSuspension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingHoldEndDate rdf:type rdf:Property ;
    rdfs:label 'Billing Hold End Date' ;
    rdfs:comment 'The date on which billing charges resume for the customer account following the suspension. May differ from actual_resume_date due to billing cycle alignment. Used by Oracle Revenue Management.' ;
    rdfs:domain ind:ServiceSuspension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingHoldStartDate rdf:type rdf:Property ;
    rdfs:label 'Billing Hold Start Date' ;
    rdfs:comment 'The date from which billing charges are paused or adjusted for the customer account. May differ from suspension_start_date if billing cycles do not align with service dates. Used by Oracle Revenue Management for invoice generation.' ;
    rdfs:domain ind:ServiceSuspension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:containerRetrievalDate rdf:type rdf:Property ;
    rdfs:label 'Container Retrieval Date' ;
    rdfs:comment 'The scheduled or actual date on which containers are retrieved from the service address during the suspension. Null if container_retrieval_required is False. Tracked in AMCS Platform container management.' ;
    rdfs:domain ind:ServiceSuspension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:crmCaseReference rdf:type rdf:Property ;
    rdfs:label 'Crm Case Reference' ;
    rdfs:comment 'The case or ticket identifier in Salesforce CRM associated with this suspension event. Enables cross-system traceability between the operational suspension record and the customer service case for communication history and resolution tracking.' ;
    rdfs:domain ind:ServiceSuspension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerNotificationStatus rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Status' ;
    rdfs:comment 'Tracks whether the customer has been notified of the suspension event. \'not_sent\' = notification not yet dispatched; \'sent\' = notification dispatched via configured channel; \'acknowledged\' = customer confirmed receipt; \'failed\' = notification delivery failed. Supports SLA compliance and customer communication obligations.' ;
    rdfs:domain ind:ServiceSuspension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedResumeDate rdf:type rdf:Property ;
    rdfs:label 'Expected Resume Date' ;
    rdfs:comment 'The anticipated calendar date on which service is expected to resume. Used for proactive route re-inclusion planning, customer communication scheduling, and billing adjustment calculations. May differ from actual_resume_date.' ;
    rdfs:domain ind:ServiceSuspension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:initiatingDepartment rdf:type rdf:Property ;
    rdfs:label 'Initiating Department' ;
    rdfs:comment 'The internal department that initiated or authorized the suspension event. Supports accountability tracking and root-cause analysis of suspension volumes by department.' ;
    rdfs:domain ind:ServiceSuspension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPermanent rdf:type rdf:Property ;
    rdfs:label 'Is Permanent' ;
    rdfs:comment 'Indicates whether this suspension is permanent (i.e., service will not resume). True for account closures or permanent service terminations processed as suspensions. When True, expected_resume_date and actual_resume_date are expected to be null.' ;
    rdfs:domain ind:ServiceSuspension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationSentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Timestamp' ;
    rdfs:comment 'The exact date and time when the customer notification for this suspension was dispatched. Null if notification has not been sent. Used to measure notification lead time relative to suspension_start_date.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:priorSuspensionCount rdf:type rdf:Property ;
    rdfs:label 'Prior Suspension Count' ;
    rdfs:comment 'The number of previous suspension events recorded for this customer enrollment prior to the current suspension. Used for customer risk scoring, collections escalation, and identifying repeat non-payment patterns.' ;
    rdfs:domain ind:ServiceSuspension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:resumeCondition rdf:type rdf:Property ;
    rdfs:label 'Resume Condition' ;
    rdfs:comment 'The condition that must be met before service can be resumed. \'date_based\' = resumes on expected_resume_date; \'payment_received\' = requires outstanding balance cleared; \'inspection_passed\' = requires safety or compliance inspection; \'regulatory_clearance\' = requires regulatory agency sign-off; \'manual_review\' = requires supervisor approval.' ;
    rdfs:domain ind:ServiceSuspension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeExclusionConfirmed rdf:type rdf:Property ;
    rdfs:label 'Route Exclusion Confirmed' ;
    rdfs:comment 'Indicates whether the route exclusion has been confirmed and applied in the AMCS Platform or Locus Dispatch system. Supports operational verification that the address will not receive service during the suspension.' ;
    rdfs:domain ind:ServiceSuspension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:routeExclusionRequired rdf:type rdf:Property ;
    rdfs:label 'Route Exclusion Required' ;
    rdfs:comment 'Indicates whether the service address must be excluded from active collection routes during the suspension period. When True, triggers route update in AMCS Platform and Locus Dispatch to prevent unnecessary truck dispatches.' ;
    rdfs:domain ind:ServiceSuspension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:safetyIncidentReference rdf:type rdf:Property ;
    rdfs:label 'Safety Incident Reference' ;
    rdfs:comment 'Reference number or identifier linking this suspension to a safety incident record in Enviance EHS (e.g., OSHA recordable incident, PPE violation, hazardous material spill). Null if suspension is not safety-related. Supports OSHA 300 log and incident management reporting.' ;
    rdfs:domain ind:ServiceSuspension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapHoldCode rdf:type rdf:Property ;
    rdfs:label 'Sap Hold Code' ;
    rdfs:comment 'The delivery or billing block code applied in SAP S/4HANA SD or FI module corresponding to this suspension. Used to synchronize the suspension state with SAP order management and accounts receivable processes.' ;
    rdfs:domain ind:ServiceSuspension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suspensionDurationDays rdf:type rdf:Property ;
    rdfs:label 'Suspension Duration Days' ;
    rdfs:comment 'The planned number of calendar days for the suspension, calculated as the difference between expected_resume_date and suspension_start_date at the time of creation. Used for billing credit calculations and route planning horizon.' ;
    rdfs:domain ind:ServiceSuspension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:suspensionNumber rdf:type rdf:Property ;
    rdfs:label 'Suspension Number' ;
    rdfs:comment 'Externally-visible, human-readable business identifier for the suspension event, used in customer communications, billing adjustments, and cross-system references (e.g., Salesforce CRM case number, Oracle Revenue Management hold reference). Format: SUSP-YYYY-NNNNNN.' ;
    rdfs:domain ind:ServiceSuspension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suspensionReasonCode rdf:type rdf:Property ;
    rdfs:label 'Suspension Reason Code' ;
    rdfs:comment 'Standardized reason code identifying the specific cause of the suspension (e.g., NON_PAY, SEASONAL_HOLD, VACATION_HOLD, SAFETY_VIOLATION, WEATHER_EVENT, ROUTE_DISRUPTION, REGULATORY_HOLD, CUSTOMER_REQUEST, HAZMAT_INCIDENT). [ENUM-REF-CANDIDATE: NON_PAY|SEASONAL_HOLD|VACATION_HOLD|SAFETY_VIOLATION|WEATHER_EVENT|ROUTE_DISRUPTION|REGULATORY_HOLD|CUSTOMER_REQUEST|HAZMAT_INCIDENT — promote to reference product]' ;
    rdfs:domain ind:ServiceSuspension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suspensionReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Suspension Reason Description' ;
    rdfs:comment 'Free-text narrative providing additional context or detail about the specific reason for the suspension, supplementing the structured reason code. Captured by the initiating department representative.' ;
    rdfs:domain ind:ServiceSuspension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suspensionStatus rdf:type rdf:Property ;
    rdfs:label 'Suspension Status' ;
    rdfs:comment 'Current lifecycle state of the suspension event. \'pending\' = approved but not yet started; \'active\' = suspension is currently in effect; \'resumed\' = service has been restored; \'cancelled\' = suspension was voided before taking effect; \'expired\' = suspension end date passed without explicit resume action.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suspensionType rdf:type rdf:Property ;
    rdfs:label 'Suspension Type' ;
    rdfs:comment 'High-level classification of the suspension event. \'voluntary\' = customer-initiated hold (seasonal, vacation); \'involuntary\' = company-initiated for non-payment or policy violation; \'regulatory\' = mandated by EPA, OSHA, DOT, or other governing body; \'operational\' = service interruption due to weather, route disruption, or fleet issue.' ;
    rdfs:domain ind:ServiceSuspension ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Sla Assignment Id' ;
    rdfs:comment 'Unique system-generated identifier for each SLA assignment record linking a customer account or service enrollment to a specific SLA tier.' ;
    rdfs:domain ind:SlaAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:billingDisputeResolutionHours rdf:type rdf:Property ;
    rdfs:label 'Billing Dispute Resolution Hours' ;
    rdfs:comment 'Maximum number of hours within which a billing dispute raised by the customer must be investigated and resolved under this SLA tier. Tracked in Oracle Revenue Management and Salesforce CRM for Accounts Receivable (AR) compliance.' ;
    rdfs:domain ind:SlaAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complaintResolutionHours rdf:type rdf:Property ;
    rdfs:label 'Complaint Resolution Hours' ;
    rdfs:comment 'Maximum number of hours within which a customer complaint must be resolved and closed under this SLA tier. Applies to customer service interactions logged in Salesforce CRM and tracked for NPS/CSAT impact.' ;
    rdfs:domain ind:SlaAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceTrackingFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Tracking Flag' ;
    rdfs:comment 'Indicates whether active SLA compliance monitoring and reporting is enabled for this assignment. When true, operational systems (AMCS, Locus Dispatch, Salesforce CRM) feed compliance metrics against this SLA\'s targets for KPI dashboards and regulatory reporting.' ;
    rdfs:domain ind:SlaAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:containerDeliveryLeadDays rdf:type rdf:Property ;
    rdfs:label 'Container Delivery Lead Days' ;
    rdfs:comment 'Maximum number of calendar days within which a new or replacement container must be delivered to the customer site after a confirmed service request, as committed under this SLA tier. Tracked in Waste Logics and AMCS Platform.' ;
    rdfs:domain ind:SlaAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:escalationThresholdHours rdf:type rdf:Property ;
    rdfs:label 'Escalation Threshold Hours' ;
    rdfs:comment 'Number of hours after which an unresolved service request or complaint is automatically escalated to a higher support tier or management under this SLA assignment. Drives automated escalation workflows in Salesforce CRM.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initialResponseHours rdf:type rdf:Property ;
    rdfs:label 'Initial Response Hours' ;
    rdfs:comment 'Maximum number of hours within which the first acknowledgment or response to a customer service request or complaint must be delivered under this SLA tier. Distinct from full resolution time.' ;
    rdfs:domain ind:SlaAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:missedPickupResolutionHours rdf:type rdf:Property ;
    rdfs:label 'Missed Pickup Resolution Hours' ;
    rdfs:comment 'Maximum number of hours within which a missed waste pickup must be resolved and rescheduled under this SLA tier. Core operational commitment tracked against actual resolution times in AMCS Platform and Locus Dispatch.' ;
    rdfs:domain ind:SlaAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:municipalContractFlag rdf:type rdf:Property ;
    rdfs:label 'Municipal Contract Flag' ;
    rdfs:comment 'Indicates whether this SLA assignment is associated with a government or municipal contract subject to Local Solid Waste Authority regulations, public reporting requirements, and enhanced penalty clauses.' ;
    rdfs:domain ind:SlaAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:penaltyAmountPerBreach rdf:type rdf:Property ;
    rdfs:label 'Penalty Amount Per Breach' ;
    rdfs:comment 'Fixed monetary penalty amount (in USD) assessed per SLA breach event when penalty clauses are applicable. Used in Oracle Revenue Management for credit memo generation and financial reporting under GAAP/IFRS contract liability standards.' ;
    rdfs:domain ind:SlaAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyCapAmount rdf:type rdf:Property ;
    rdfs:label 'Penalty Cap Amount' ;
    rdfs:comment 'Maximum cumulative monetary penalty (in USD) that can be assessed against Waste Management under this SLA assignment within a defined period, as stipulated in the contract. Prevents unbounded financial exposure on municipal contracts.' ;
    rdfs:domain ind:SlaAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyCapPeriod rdf:type rdf:Property ;
    rdfs:label 'Penalty Cap Period' ;
    rdfs:comment 'The time period over which the penalty cap amount is measured and reset (monthly, quarterly, or annual). Aligns with contract billing cycles in Oracle Revenue Management.' ;
    rdfs:domain ind:SlaAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyClauseApplicable rdf:type rdf:Property ;
    rdfs:label 'Penalty Clause Applicable' ;
    rdfs:comment 'Indicates whether financial penalty clauses are contractually applicable when SLA targets are breached under this assignment. Typically true for municipal government contracts governed by Local Solid Waste Authority agreements.' ;
    rdfs:domain ind:SlaAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewCycleMonths rdf:type rdf:Property ;
    rdfs:label 'Review Cycle Months' ;
    rdfs:comment 'Number of months between scheduled reviews of this SLA assignment to assess performance, renegotiate targets, or update tier classification. Supports proactive contract management and customer retention workflows.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceAvailabilityTargetPct rdf:type rdf:Property ;
    rdfs:label 'Service Availability Target Pct' ;
    rdfs:comment 'Minimum percentage of scheduled service events (pickups, deliveries) that must be completed on time within the measurement period under this SLA tier. For example, 98.50 means 98.5% on-time service completion is required.' ;
    rdfs:domain ind:SlaAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaTierCode rdf:type rdf:Property ;
    rdfs:label 'Sla Tier Code' ;
    rdfs:comment 'Short alphanumeric code representing the SLA tier, used in system integrations, route management, and operational dispatching (e.g., STD, PREM, MUN, HAZ, EMG). Sourced from AMCS Platform and Salesforce CRM.' ;
    rdfs:domain ind:SlaAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTierName rdf:type rdf:Property ;
    rdfs:label 'Sla Tier Name' ;
    rdfs:comment 'Named classification of the SLA tier assigned to this customer or service enrollment (e.g., Standard, Premium, Municipal, Hazardous, Emergency, Custom). Drives response time targets and escalation thresholds across collection, billing, and customer service operations.' ;
    rdfs:domain ind:SlaAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemSlaReference rdf:type rdf:Property ;
    rdfs:label 'Source System Sla Reference' ;
    rdfs:comment 'The native identifier of this SLA assignment record in the originating source system (e.g., Salesforce Contract ID, SAP SD Agreement Number). Enables cross-system reconciliation and lineage tracing in the Silver Layer.' ;
    rdfs:domain ind:SlaAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceOfficerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Compliance Officer Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Hazardous waste generator profiles require assigned compliance officers for RCRA inspections, manifest reviews, permit renewals, and regulatory correspondence. EPA and state regulations mandate docume' ;
    rdfs:domain ind:WasteGeneratorProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tsdfFacilityId rdf:type rdf:Property ;
    rdfs:label 'Tsdf Facility Id' ;
    rdfs:comment 'Reference to the primary designated Treatment, Storage, and Disposal Facility (TSDF) used by this generator for hazardous waste disposal. The TSDF must hold a valid RCRA permit. Links to the facility/asset master in the Asset Management domain.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TsdfFacility .

ind:accumulationAreaType rdf:type rdf:Property ;
    rdfs:label 'Accumulation Area Type' ;
    rdfs:comment 'Classification of the on-site hazardous waste accumulation area based on RCRA generator category and applicable time limits. LQGs may accumulate up to 90 days; SQGs up to 180 days (or 270 days in rural areas); VSQGs have no time limit but volume limits apply. Satellite areas are small accumulation points feeding a central accumulation area.' ;
    rdfs:domain ind:WasteGeneratorProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:biennialReportDueDate rdf:type rdf:Property ;
    rdfs:label 'Biennial Report Due Date' ;
    rdfs:comment 'Due date for the next EPA Biennial Hazardous Waste Report submission. Required for LQGs in even-numbered years under RCRA 40 CFR Part 262.41. Tracks compliance calendar obligations for large quantity generators.' ;
    rdfs:domain ind:WasteGeneratorProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contingencyPlanOnFile rdf:type rdf:Property ;
    rdfs:label 'Contingency Plan On File' ;
    rdfs:comment 'Indicates whether a RCRA-compliant emergency contingency plan is on file for this generator. LQGs are required to maintain a formal contingency plan under 40 CFR Part 262.261; SQGs must have an emergency plan. Critical for compliance verification and emergency response readiness.' ;
    rdfs:domain ind:WasteGeneratorProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eManifestRegisteredFlag rdf:type rdf:Property ;
    rdfs:label 'E Manifest Registered Flag' ;
    rdfs:comment 'Indicates whether this generator is registered in the EPA\'s national e-Manifest system for electronic hazardous waste tracking. The e-Manifest system replaced paper manifests and is operated by the EPA under RCRA authority.' ;
    rdfs:domain ind:WasteGeneratorProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:emergencyCoordinatorName rdf:type rdf:Property ;
    rdfs:label 'Emergency Coordinator Name' ;
    rdfs:comment 'Full name of the designated emergency coordinator responsible for implementing the contingency plan and coordinating emergency response at the generator site. Required to be listed in the contingency plan and available to local emergency responders under RCRA.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyCoordinatorPhone rdf:type rdf:Property ;
    rdfs:label 'Emergency Coordinator Phone' ;
    rdfs:comment '24-hour contact phone number for the designated emergency coordinator at the generator site. Must be posted at the facility and provided to local emergency response agencies as required under RCRA contingency plan regulations.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedHazardousVolumeKgPerMonth rdf:type rdf:Property ;
    rdfs:label 'Estimated Hazardous Volume Kg Per Month' ;
    rdfs:comment 'Estimated monthly generation quantity of RCRA-regulated hazardous waste in kilograms. This is the primary metric used to classify the generator into VSQG (≤100 kg), SQG (100–999 kg), or LQG (≥1,000 kg) categories and must be re-evaluated whenever operations change.' ;
    rdfs:domain ind:WasteGeneratorProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:generatorCategory rdf:type rdf:Property ;
    rdfs:label 'Generator Category' ;
    rdfs:comment 'RCRA regulatory classification of the waste generator based on monthly hazardous waste generation quantity. LQG (Large Quantity Generator) generates ≥1,000 kg/month; SQG (Small Quantity Generator) generates 100–999 kg/month; VSQG (Very Small Quantity Generator) generates ≤100 kg/month. Determines applicable regulatory requirements, accumulation time limits, and manifest obligations.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:generatorStatus rdf:type rdf:Property ;
    rdfs:label 'Generator Status' ;
    rdfs:comment 'Current lifecycle status of the waste generator regulatory profile. Active indicates the generator is currently producing regulated waste; inactive indicates operations have ceased; pending indicates initial registration is in progress; suspended indicates regulatory hold; closed indicates the site has been formally decommissioned.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardousWasteCodes rdf:type rdf:Property ;
    rdfs:label 'Hazardous Waste Codes' ;
    rdfs:comment 'Comma-delimited list of EPA hazardous waste codes (e.g., D001, F003, U080) applicable to the waste streams generated at this site as determined by TCLP (Toxicity Characteristic Leaching Procedure) testing or listed waste classification. Required for manifest preparation and RCRA compliance reporting.' ;
    rdfs:domain ind:WasteGeneratorProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastBiennialReportDate rdf:type rdf:Property ;
    rdfs:label 'Last Biennial Report Date' ;
    rdfs:comment 'Date on which the most recent EPA Biennial Hazardous Waste Report was submitted for this generator. Used to verify compliance with LQG biennial reporting obligations and to support audit documentation.' ;
    rdfs:domain ind:WasteGeneratorProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Last Notification Date' ;
    rdfs:comment 'Date of the most recent RCRA Site ID notification update submitted to the EPA or authorized state agency. Generators must re-notify when their generator category changes, when they begin generating new hazardous waste streams, or when site information changes.' ;
    rdfs:domain ind:WasteGeneratorProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:manifestRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Manifest Required Flag' ;
    rdfs:comment 'Indicates whether this generator is required to use a Uniform Hazardous Waste Manifest (EPA Form 8700-22) for off-site shipments of hazardous waste. Mandatory for SQGs and LQGs; VSQGs are exempt from manifest requirements under 40 CFR Part 262.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxAccumulationDays rdf:type rdf:Property ;
    rdfs:label 'Max Accumulation Days' ;
    rdfs:comment 'Maximum number of days this generator is permitted to accumulate hazardous waste on-site before it must be shipped to a TSDF, as determined by generator category and applicable RCRA regulations. Exceeding this limit triggers LQG-level requirements or potential RCRA violation.' ;
    rdfs:domain ind:WasteGeneratorProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextNotificationDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Notification Due Date' ;
    rdfs:comment 'Scheduled due date for the next required RCRA notification or re-notification. LQGs must notify every four years under the 2016 Generator Improvements Rule. Used by compliance teams to proactively manage regulatory deadlines.' ;
    rdfs:domain ind:WasteGeneratorProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:openViolationFlag rdf:type rdf:Property ;
    rdfs:label 'Open Violation Flag' ;
    rdfs:comment 'Indicates whether this generator currently has one or more open, unresolved regulatory violations on record with the EPA or state environmental agency. Triggers enhanced compliance monitoring and may affect service agreements and manifest acceptance.' ;
    rdfs:domain ind:WasteGeneratorProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:personnelTrainingCurrentFlag rdf:type rdf:Property ;
    rdfs:label 'Personnel Training Current Flag' ;
    rdfs:comment 'Indicates whether all relevant facility personnel have completed current RCRA hazardous waste management training as required for the generator\'s category. LQGs must provide formal classroom or on-the-job training; SQGs must ensure familiarity with emergency procedures.' ;
    rdfs:domain ind:WasteGeneratorProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryWasteStream rdf:type rdf:Property ;
    rdfs:label 'Primary Waste Stream' ;
    rdfs:comment 'The predominant category of waste generated at this site. MSW (Municipal Solid Waste) covers general commercial/residential refuse; C&D (Construction and Demolition Waste) covers building debris; hazardous covers RCRA-regulated hazardous waste; universal waste covers batteries, lamps, and pesticides; mixed indicates multiple co-dominant streams.' ;
    rdfs:domain ind:WasteGeneratorProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Profile Effective Date' ;
    rdfs:comment 'Date from which this waste generator regulatory profile is considered valid and active. Represents the start of the current regulatory classification period, which may be triggered by initial registration, a generator category change, or a site re-notification.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:profileExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Profile Expiration Date' ;
    rdfs:comment 'Date on which this waste generator regulatory profile expires or must be renewed. Applicable when state permits or generator registrations have fixed validity periods. Null for open-ended federal EPA registrations.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rcraNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Rcra Notification Date' ;
    rdfs:comment 'Date on which the generator submitted the initial RCRA Site Identification (Site ID) notification to the EPA or authorized state agency, establishing the generator\'s regulatory identity and obligations. Required under 40 CFR Part 262.18.' ;
    rdfs:domain ind:WasteGeneratorProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:siteAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Site Address Line1' ;
    rdfs:comment 'Primary street address of the regulated waste-generating facility as registered with the EPA and state environmental authority. Used for regulatory correspondence, manifest routing, and compliance inspections.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteCity rdf:type rdf:Property ;
    rdfs:label 'Site City' ;
    rdfs:comment 'City of the regulated waste-generating facility as registered with the EPA and state environmental authority.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteName rdf:type rdf:Property ;
    rdfs:label 'Site Name' ;
    rdfs:comment 'Legal or operating name of the waste-generating facility or site as registered with the EPA and state environmental agency. May differ from the customer account name if the customer operates multiple sites.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sitePostalCode rdf:type rdf:Property ;
    rdfs:label 'Site Postal Code' ;
    rdfs:comment 'ZIP or ZIP+4 postal code of the regulated waste-generating facility. Used for geographic routing, regulatory jurisdiction mapping, and compliance reporting.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteStateCode rdf:type rdf:Property ;
    rdfs:label 'Site State Code' ;
    rdfs:comment 'Two-letter USPS state abbreviation for the regulated waste-generating facility. Determines which state environmental agency has jurisdiction and which state-specific RCRA regulations apply.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemProfileReference rdf:type rdf:Property ;
    rdfs:label 'Source System Profile Reference' ;
    rdfs:comment 'The native identifier for this waste generator profile record in the originating operational system (e.g., Enviance EHS record ID, SAP EHS business partner number, or RCRAInfo handler ID). Enables cross-system reconciliation and traceability.' ;
    rdfs:domain ind:WasteGeneratorProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateProgramCode rdf:type rdf:Property ;
    rdfs:label 'State Program Code' ;
    rdfs:comment 'Two-letter state code identifying the RCRA-authorized state program under which this generator is regulated. In RCRA-authorized states, the state program operates in lieu of the federal program; in non-authorized states, the EPA directly administers RCRA.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:universalWasteHandlerFlag rdf:type rdf:Property ;
    rdfs:label 'Universal Waste Handler Flag' ;
    rdfs:comment 'Indicates whether this generator is registered as a universal waste handler under 40 CFR Part 273, managing batteries, pesticides, mercury-containing equipment, or lamps under the streamlined universal waste rules rather than full RCRA hazardous waste requirements.' ;
    rdfs:domain ind:WasteGeneratorProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:airPollutionControlUnitId rdf:type rdf:Property ;
    rdfs:label 'Air Pollution Control Unit Id' ;
    rdfs:comment 'Unique identifier for the air pollution control device. Primary key for the APC unit master record.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AirPollutionControlUnit .

ind:boilerUnitId rdf:type rdf:Property ;
    rdfs:label 'Boiler Unit Id' ;
    rdfs:comment 'Reference to the specific boiler or combustion unit that this APC device serves.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BoilerUnit .

ind:primaryAirFacilityId rdf:type rdf:Property ;
    rdfs:label 'Primary Air Facility Id' ;
    rdfs:comment 'Reference to the WTE facility where this APC unit is installed.' ;
    rdfs:domain ind:AirPollutionControlUnit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:stackId rdf:type rdf:Property ;
    rdfs:label 'Stack Id' ;
    rdfs:comment 'Reference to the emission stack where this APC unit is installed for exhaust gas treatment.' ;
    rdfs:domain ind:Energy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Stack .

ind:actualRemovalEfficiencyPercent rdf:type rdf:Property ;
    rdfs:label 'Actual Removal Efficiency Percent' ;
    rdfs:comment 'Measured pollutant removal efficiency percentage based on continuous emissions monitoring system (CEMS) data or stack testing results.' ;
    rdfs:domain ind:AirPollutionControlUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annualOperatingCostUsd rdf:type rdf:Property ;
    rdfs:label 'Annual Operating Cost Usd' ;
    rdfs:comment 'Estimated or actual annual operating cost for the APC unit, including reagent consumption, energy, maintenance, and labor.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:caaComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Caa Compliance Status' ;
    rdfs:comment 'Current compliance status of the APC unit with respect to Clean Air Act Title V permit requirements and emission limits.' ;
    rdfs:domain ind:AirPollutionControlUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cemsIntegrationFlag rdf:type rdf:Property ;
    rdfs:label 'Cems Integration Flag' ;
    rdfs:comment 'Indicates whether this APC unit is integrated with a continuous emission monitoring system for real-time performance tracking and regulatory reporting.' ;
    rdfs:domain ind:AirPollutionControlUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:decommissionDate rdf:type rdf:Property ;
    rdfs:label 'Decommission Date' ;
    rdfs:comment 'Date when the APC unit was permanently taken out of service and decommissioned. Null if the unit is still in service.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:designCapacityScfm rdf:type rdf:Property ;
    rdfs:label 'Design Capacity Scfm' ;
    rdfs:comment 'Design gas flow capacity of the APC unit in standard cubic feet per minute. Represents the maximum exhaust gas volume the unit can treat under design conditions.' ;
    rdfs:domain ind:AirPollutionControlUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:designRemovalEfficiencyPercent rdf:type rdf:Property ;
    rdfs:label 'Design Removal Efficiency Percent' ;
    rdfs:comment 'Manufacturer-specified pollutant removal efficiency percentage for this APC unit under design operating conditions. Critical for permit compliance calculations.' ;
    rdfs:domain ind:AirPollutionControlUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:installationCostUsd rdf:type rdf:Property ;
    rdfs:label 'Installation Cost Usd' ;
    rdfs:comment 'Total capital cost of installing the APC unit, including equipment, labor, and commissioning expenses. Used for capital project tracking and asset valuation.' ;
    rdfs:domain ind:Energy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatingTemperatureFahrenheit rdf:type rdf:Property ;
    rdfs:label 'Operating Temperature Fahrenheit' ;
    rdfs:comment 'Typical operating temperature of the APC unit in degrees Fahrenheit. Critical for performance monitoring and maintenance planning.' ;
    rdfs:domain ind:AirPollutionControlUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pollutantTarget rdf:type rdf:Property ;
    rdfs:label 'Pollutant Target' ;
    rdfs:comment 'Primary pollutant that this APC unit is designed to control. Common targets include NOx (nitrogen oxides), SOx (sulfur oxides), particulate matter (PM), mercury (Hg), dioxins/furans, HCl (hydrogen chloride), CO (carbon monoxide), and VOC (volatile organic compounds). [ENUM-REF-CANDIDATE: nox|sox|particulate_matter|mercury|dioxins_furans|hcl|co|voc — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AirPollutionControlUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pressureDropInchesH2o rdf:type rdf:Property ;
    rdfs:label 'Pressure Drop Inches H2o' ;
    rdfs:comment 'Pressure drop across the APC unit measured in inches of water column. Indicates filter loading and system resistance.' ;
    rdfs:domain ind:AirPollutionControlUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reagentConsumptionRate rdf:type rdf:Property ;
    rdfs:label 'Reagent Consumption Rate' ;
    rdfs:comment 'Average reagent consumption rate in pounds per hour or tons per day, depending on operational scale. Used for inventory management and cost tracking.' ;
    rdfs:domain ind:AirPollutionControlUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reagentConsumptionUom rdf:type rdf:Property ;
    rdfs:label 'Reagent Consumption Uom' ;
    rdfs:comment 'Unit of measure for reagent consumption rate reporting.' ;
    rdfs:domain ind:AirPollutionControlUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reagentType rdf:type rdf:Property ;
    rdfs:label 'Reagent Type' ;
    rdfs:comment 'Type of chemical reagent used by the APC unit for pollutant removal. Common reagents include urea (for SNCR), ammonia (for SCR), lime or hydrated lime (for acid gas scrubbing), activated carbon (for mercury and dioxin removal), and sodium bicarbonate (for dry scrubbing). [ENUM-REF-CANDIDATE: urea|ammonia|lime|hydrated_lime|activated_carbon|sodium_bicarbonate|none — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Energy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scadaIntegrationFlag rdf:type rdf:Property ;
    rdfs:label 'Scada Integration Flag' ;
    rdfs:comment 'Indicates whether this APC unit is integrated with the facility SCADA system for remote monitoring and control.' ;
    rdfs:domain ind:AirPollutionControlUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:technologyType rdf:type rdf:Property ;
    rdfs:label 'Technology Type' ;
    rdfs:comment 'Type of air pollution control technology employed by this unit. Common types include SNCR (Selective Non-Catalytic Reduction), SCR (Selective Catalytic Reduction), ACI (Activated Carbon Injection), fabric filter baghouse, electrostatic precipitator, and dry scrubber systems.' ;
    rdfs:domain ind:Energy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitCode rdf:type rdf:Property ;
    rdfs:label 'Unit Code' ;
    rdfs:comment 'Business identifier code for the APC unit, typically used in operational systems and permit documentation.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitName rdf:type rdf:Property ;
    rdfs:label 'Unit Name' ;
    rdfs:comment 'Descriptive name of the APC unit for operational reference and reporting.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ashResidueRecordId rdf:type rdf:Property ;
    rdfs:label 'Ash Residue Record Id' ;
    rdfs:comment 'Unique identifier for the ash residue record. Primary key for tracking individual ash generation events from WTE combustion processes.' ;
    rdfs:domain ind:AshResidueRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:haulingVehicleId rdf:type rdf:Property ;
    rdfs:label 'Hauling Vehicle Id' ;
    rdfs:comment 'Foreign key linking to fleet.vehicle. Business justification: Ash residue hauling from WTE facilities uses fleet vehicles. Environmental compliance and logistics teams need to track which vehicle transported each ash load for DOT compliance, vehicle contaminatio' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vehicle .

ind:primaryAshFacilityId rdf:type rdf:Property ;
    rdfs:label 'Primary Ash Facility Id' ;
    rdfs:comment 'Identifier of the Waste-to-Energy facility where the ash residue was generated.' ;
    rdfs:domain ind:AshResidueRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:tclpTestId rdf:type rdf:Property ;
    rdfs:label 'Tclp Test Id' ;
    rdfs:comment 'Foreign key linking to hazmat.tclp_test. Business justification: Ash residue TCLP testing determines hazardous waste classification under RCRA toxicity characteristic rules. Links energy facility ash generation to hazmat laboratory characterization results. Essenti' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TclpTest .

ind:transporterRegistrationId rdf:type rdf:Property ;
    rdfs:label 'Transporter Registration Id' ;
    rdfs:comment 'Identifier of the transportation company or fleet that hauled the ash residue from generation site to receiving facility.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TransporterRegistration .

ind:ashGenerationRatePercent rdf:type rdf:Property ;
    rdfs:label 'Ash Generation Rate Percent' ;
    rdfs:comment 'Percentage of input MSW feedstock that resulted in ash residue (ash weight / feedstock weight * 100). Key performance indicator for combustion efficiency and waste reduction.' ;
    rdfs:domain ind:AshResidueRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ashType rdf:type rdf:Property ;
    rdfs:label 'Ash Type' ;
    rdfs:comment 'Classification of ash residue by combustion process output: bottom ash (heavy residue from combustion chamber floor), fly ash (fine particulate captured by air pollution control devices), or combined ash (mixture of both).' ;
    rdfs:domain ind:Energy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficialReuseRevenueUsd rdf:type rdf:Property ;
    rdfs:label 'Beneficial Reuse Revenue Usd' ;
    rdfs:comment 'Revenue generated in US dollars from selling ash residue for beneficial reuse applications such as aggregate substitute in construction. Null if ash was disposed rather than sold.' ;
    rdfs:domain ind:AshResidueRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:combustionTemperatureCelsius rdf:type rdf:Property ;
    rdfs:label 'Combustion Temperature Celsius' ;
    rdfs:comment 'Average combustion chamber temperature in degrees Celsius during the ash generation period. Influences ash characteristics and regulatory compliance with Clean Air Act emission standards.' ;
    rdfs:domain ind:AshResidueRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceNotes rdf:type rdf:Property ;
    rdfs:label 'Compliance Notes' ;
    rdfs:comment 'Free-text notes documenting compliance issues, regulatory exceptions, special handling requirements, or other relevant compliance information for this ash residue batch.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalCostUsd rdf:type rdf:Property ;
    rdfs:label 'Disposal Cost Usd' ;
    rdfs:comment 'Total cost in US dollars for disposing or processing the ash residue, including tipping fees, transportation, and handling charges. Used for cost accounting and financial reporting.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:diversionFromLandfillFlag rdf:type rdf:Property ;
    rdfs:label 'Diversion From Landfill Flag' ;
    rdfs:comment 'Boolean indicator of whether the ash residue was diverted from landfill disposal through beneficial reuse, recycling, or other alternative methods. True if diverted, false if landfilled. Critical for sustainability reporting and diversion rate calculations.' ;
    rdfs:domain ind:AshResidueRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:generationDate rdf:type rdf:Property ;
    rdfs:label 'Generation Date' ;
    rdfs:comment 'Date when the ash residue was generated from the combustion process. Critical for tracking production cycles and regulatory reporting timelines.' ;
    rdfs:domain ind:Energy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:heavyMetalConcentrationPpm rdf:type rdf:Property ;
    rdfs:label 'Heavy Metal Concentration Ppm' ;
    rdfs:comment 'Concentration levels of heavy metals (lead, cadmium, mercury, chromium, etc.) detected in ash residue, measured in parts per million. Stored as JSON or delimited string with metal:value pairs. Critical for environmental compliance and beneficial reuse eligibility.' ;
    rdfs:domain ind:AshResidueRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labAnalysisDate rdf:type rdf:Property ;
    rdfs:label 'Lab Analysis Date' ;
    rdfs:comment 'Date when laboratory analysis (TCLP and other tests) was performed on the ash residue sample. Used for tracking testing timelines and regulatory compliance with testing frequency requirements.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:labCode rdf:type rdf:Property ;
    rdfs:label 'Lab Code' ;
    rdfs:comment 'Identifier of the certified laboratory that performed the ash residue analysis. Links to laboratory vendor master data.' ;
    rdfs:domain ind:AshResidueRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:moistureContentPercent rdf:type rdf:Property ;
    rdfs:label 'Moisture Content Percent' ;
    rdfs:comment 'Percentage of moisture content in the ash residue sample. Affects handling characteristics, transportation weight, and beneficial reuse suitability.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mswFeedstockTons rdf:type rdf:Property ;
    rdfs:label 'Msw Feedstock Tons' ;
    rdfs:comment 'Total tons of MSW feedstock processed in the combustion cycle that generated this ash residue. Used to calculate ash generation rate and combustion efficiency metrics.' ;
    rdfs:domain ind:Energy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:particleSizeDistribution rdf:type rdf:Property ;
    rdfs:label 'Particle Size Distribution' ;
    rdfs:comment 'Distribution of particle sizes in the ash residue sample, typically expressed as percentage passing through standard sieve sizes. Affects beneficial reuse suitability and handling characteristics.' ;
    rdfs:domain ind:AshResidueRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phLevel rdf:type rdf:Property ;
    rdfs:label 'Ph Level' ;
    rdfs:comment 'pH measurement of ash residue indicating acidity or alkalinity. Affects handling requirements, corrosivity classification, and beneficial reuse applications.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryClassification rdf:type rdf:Property ;
    rdfs:label 'Regulatory Classification' ;
    rdfs:comment 'Classification of ash residue as non-hazardous or hazardous waste based on TCLP test results and RCRA criteria. Determines disposal requirements and handling protocols.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentDate rdf:type rdf:Property ;
    rdfs:label 'Shipment Date' ;
    rdfs:comment 'Date when the ash residue was shipped from the WTE facility to the receiving facility. Used for tracking transportation timelines and regulatory reporting.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:stateWasteCode rdf:type rdf:Property ;
    rdfs:label 'State Waste Code' ;
    rdfs:comment 'State-specific waste classification code if the state has additional or more stringent waste classification requirements beyond federal RCRA standards.' ;
    rdfs:domain ind:AshResidueRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageDurationDays rdf:type rdf:Property ;
    rdfs:label 'Storage Duration Days' ;
    rdfs:comment 'Number of days the ash residue was stored on-site at the WTE facility before shipment. Monitored for regulatory compliance with maximum storage time limits.' ;
    rdfs:domain ind:AshResidueRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:annualOperatingHours rdf:type rdf:Property ;
    rdfs:label 'Annual Operating Hours' ;
    rdfs:comment 'Total operating hours per year for the boiler unit. Used for capacity factor calculations, maintenance scheduling, and regulatory reporting. Typical WTE facilities operate 8000+ hours annually.' ;
    rdfs:domain ind:Energy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ashHandlingSystem rdf:type rdf:Property ;
    rdfs:label 'Ash Handling System' ;
    rdfs:comment 'Type of ash removal and handling system. Wet systems use water sluicing, dry systems use conveyors, pneumatic uses air transport, mechanical uses augers or drag chains. Impacts residue management and disposal.' ;
    rdfs:domain ind:BoilerUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetTag rdf:type rdf:Property ;
    rdfs:label 'Asset Tag' ;
    rdfs:comment 'Internal asset management tag or barcode identifier for the boiler unit. Used for fixed asset tracking, depreciation, and physical inventory audits.' ;
    rdfs:domain ind:Energy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Availability Status' ;
    rdfs:comment 'Current availability status for dispatch and operations. Available means ready for full operation, unavailable means offline, limited means operating at reduced capacity, testing means undergoing performance or compliance testing.' ;
    rdfs:domain ind:BoilerUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boilerEfficiencyPercent rdf:type rdf:Property ;
    rdfs:label 'Boiler Efficiency Percent' ;
    rdfs:comment 'Thermal efficiency of the boiler unit expressed as a percentage. Calculated as energy output (steam) divided by energy input (waste fuel). Monitored for performance optimization and sustainability reporting.' ;
    rdfs:domain ind:Energy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:boilerType rdf:type rdf:Property ;
    rdfs:label 'Boiler Type' ;
    rdfs:comment 'Classification of the boiler combustion technology. Mass burn processes unsorted MSW, RDF uses preprocessed fuel, modular is smaller capacity, fluidized bed uses sand bed, stoker uses mechanical grates.' ;
    rdfs:domain ind:BoilerUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:combustionControlSystem rdf:type rdf:Property ;
    rdfs:label 'Combustion Control System' ;
    rdfs:comment 'Type or model of the automated combustion control system (e.g., DCS, PLC) used to optimize air-fuel ratio, temperature, and emissions. Critical for EPA compliance and efficiency.' ;
    rdfs:domain ind:BoilerUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cumulativeOperatingHours rdf:type rdf:Property ;
    rdfs:label 'Cumulative Operating Hours' ;
    rdfs:comment 'Total lifetime operating hours since commissioning. Critical for predictive maintenance, remaining useful life estimation, and major overhaul planning.' ;
    rdfs:domain ind:Energy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designCapacityTpd rdf:type rdf:Property ;
    rdfs:label 'Design Capacity Tpd' ;
    rdfs:comment 'Rated design capacity of the boiler unit measured in tons per day (TPD) of Municipal Solid Waste (MSW) that can be processed. Key metric for facility throughput planning.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emissionsControlTechnology rdf:type rdf:Property ;
    rdfs:label 'Emissions Control Technology' ;
    rdfs:comment 'Description of the air pollution control equipment installed (e.g., electrostatic precipitator, baghouse, scrubber, selective catalytic reduction). Required for CAA compliance reporting.' ;
    rdfs:domain ind:BoilerUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grateType rdf:type rdf:Property ;
    rdfs:label 'Grate Type' ;
    rdfs:comment 'Type of mechanical grate system used for waste combustion. Reciprocating grates move back and forth, roller grates use rotating cylinders, vibrating grates shake waste, traveling grates move continuously.' ;
    rdfs:domain ind:BoilerUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:greenhouseGasReportingRequired rdf:type rdf:Property ;
    rdfs:label 'Greenhouse Gas Reporting Required' ;
    rdfs:comment 'Indicates whether the boiler unit is subject to EPA Greenhouse Gas Reporting Program (GHGRP) requirements. Facilities emitting 25,000+ metric tons CO2e annually must report.' ;
    rdfs:domain ind:BoilerUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:heatRateBtuPerKwh rdf:type rdf:Property ;
    rdfs:label 'Heat Rate Btu Per Kwh' ;
    rdfs:comment 'Heat rate of the boiler-turbine system measured in BTU per kilowatt-hour. Lower values indicate higher efficiency. Key metric for energy conversion performance and benchmarking.' ;
    rdfs:domain ind:Energy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastMajorOverhaulDate rdf:type rdf:Property ;
    rdfs:label 'Last Major Overhaul Date' ;
    rdfs:comment 'Date of the most recent major overhaul or refurbishment of the boiler unit. Major overhauls typically include refractory replacement, tube bundle replacement, and grate system rebuild.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maximumContinuousRatingMw rdf:type rdf:Property ;
    rdfs:label 'Maximum Continuous Rating Mw' ;
    rdfs:comment 'Maximum continuous electrical output capacity in megawatts (MW) when the boiler operates at full design capacity. Used for grid interconnection and revenue calculations.' ;
    rdfs:domain ind:BoilerUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:model rdf:type rdf:Property ;
    rdfs:label 'Model' ;
    rdfs:comment 'Manufacturer model designation for the boiler unit. Used for parts procurement and technical documentation reference.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextScheduledOverhaulDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Overhaul Date' ;
    rdfs:comment 'Planned date for the next major overhaul based on manufacturer recommendations, operating hours, and regulatory inspection requirements.' ;
    rdfs:domain ind:BoilerUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operatingPressurePsi rdf:type rdf:Property ;
    rdfs:label 'Operating Pressure Psi' ;
    rdfs:comment 'Normal operating steam pressure of the boiler measured in pounds per square inch (psi). Critical safety and performance parameter monitored continuously.' ;
    rdfs:domain ind:BoilerUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatingTemperatureF rdf:type rdf:Property ;
    rdfs:label 'Operating Temperature F' ;
    rdfs:comment 'Normal operating steam temperature of the boiler measured in degrees Fahrenheit. Monitored for efficiency and safety compliance.' ;
    rdfs:domain ind:BoilerUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewableEnergyCreditEligible rdf:type rdf:Property ;
    rdfs:label 'Renewable Energy Credit Eligible' ;
    rdfs:comment 'Indicates whether the boiler unit qualifies for Renewable Energy Credits (RECs) under state or federal renewable portfolio standards. Eligibility depends on fuel source classification and technology type.' ;
    rdfs:domain ind:Energy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:steamGenerationRateKlbPerHr rdf:type rdf:Property ;
    rdfs:label 'Steam Generation Rate Klb Per Hr' ;
    rdfs:comment 'Rated steam generation capacity of the boiler measured in thousand pounds per hour (klb/hr). Critical for energy output calculations and turbine sizing.' ;
    rdfs:domain ind:BoilerUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitNumber rdf:type rdf:Property ;
    rdfs:label 'Unit Number' ;
    rdfs:comment 'Business identifier for the boiler unit, typically assigned by the facility (e.g., \'Boiler-1\', \'Unit-A\'). Used for operational communication and work orders.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cemsInstrumentId rdf:type rdf:Property ;
    rdfs:label 'Cems Instrument Id' ;
    rdfs:comment 'Unique identifier for the CEMS instrument record. Primary key.' ;
    rdfs:domain ind:Energy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CemsInstrument .

ind:accuracySpecificationPercent rdf:type rdf:Property ;
    rdfs:label 'Accuracy Specification Percent' ;
    rdfs:comment 'Manufacturer-specified accuracy of the CEMS instrument as a percentage of the measurement range.' ;
    rdfs:domain ind:CemsInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:analyzerPrinciple rdf:type rdf:Property ;
    rdfs:label 'Analyzer Principle' ;
    rdfs:comment 'The analytical principle or technology used by the CEMS instrument (e.g., NDIR, UV, chemiluminescence, paramagnetic, electrochemical).' ;
    rdfs:domain ind:CemsInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Calibration Frequency Days' ;
    rdfs:comment 'Required frequency in days for routine calibration of this CEMS instrument per regulatory and manufacturer requirements.' ;
    rdfs:domain ind:CemsInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dasChannelNumber rdf:type rdf:Property ;
    rdfs:label 'Das Channel Number' ;
    rdfs:comment 'Specific channel or input number on the DAS to which this CEMS instrument is connected.' ;
    rdfs:domain ind:CemsInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dasReference rdf:type rdf:Property ;
    rdfs:label 'Das Reference' ;
    rdfs:comment 'Reference identifier or tag for the Data Acquisition System (DAS) that collects and processes data from this CEMS instrument.' ;
    rdfs:domain ind:CemsInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataReportingFrequencyMinutes rdf:type rdf:Property ;
    rdfs:label 'Data Reporting Frequency Minutes' ;
    rdfs:comment 'Frequency in minutes at which this CEMS instrument reports data to the DAS and regulatory reporting systems.' ;
    rdfs:domain ind:CemsInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:epaProtocolGasRequired rdf:type rdf:Property ;
    rdfs:label 'Epa Protocol Gas Required' ;
    rdfs:comment 'Indicates whether EPA protocol gas is required for calibration and QA/QC testing of this CEMS instrument.' ;
    rdfs:domain ind:CemsInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:instrumentCode rdf:type rdf:Property ;
    rdfs:label 'Instrument Code' ;
    rdfs:comment 'Unique business identifier or tag code for the CEMS instrument, used for operational reference and reporting.' ;
    rdfs:domain ind:CemsInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instrumentName rdf:type rdf:Property ;
    rdfs:label 'Instrument Name' ;
    rdfs:comment 'Descriptive name of the CEMS instrument for operational identification.' ;
    rdfs:domain ind:CemsInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instrumentType rdf:type rdf:Property ;
    rdfs:label 'Instrument Type' ;
    rdfs:comment 'The technology type of the CEMS instrument (e.g., Extractive, Dilution, In-Situ, Ultrasonic Flow, Differential Pressure).' ;
    rdfs:domain ind:CemsInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastQaQcAuditDate rdf:type rdf:Property ;
    rdfs:label 'Last Qa Qc Audit Date' ;
    rdfs:comment 'Date of the most recent QA/QC audit performed on this CEMS instrument, including RATA (Relative Accuracy Test Audit), linearity checks, and calibration error tests.' ;
    rdfs:domain ind:CemsInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measurementRangeMax rdf:type rdf:Property ;
    rdfs:label 'Measurement Range Max' ;
    rdfs:comment 'Maximum value of the measurement range for this CEMS instrument, in the unit of measure specified.' ;
    rdfs:domain ind:CemsInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementRangeMin rdf:type rdf:Property ;
    rdfs:label 'Measurement Range Min' ;
    rdfs:comment 'Minimum value of the measurement range for this CEMS instrument, in the unit of measure specified.' ;
    rdfs:domain ind:CemsInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextQaQcAuditDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Qa Qc Audit Due Date' ;
    rdfs:comment 'Scheduled date for the next required QA/QC audit to maintain certification compliance.' ;
    rdfs:domain ind:CemsInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:part60Applicable rdf:type rdf:Property ;
    rdfs:label 'Part 60 Applicable' ;
    rdfs:comment 'Indicates whether this CEMS instrument is subject to 40 CFR Part 60 New Source Performance Standards (NSPS) requirements.' ;
    rdfs:domain ind:CemsInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:part75Applicable rdf:type rdf:Property ;
    rdfs:label 'Part 75 Applicable' ;
    rdfs:comment 'Indicates whether this CEMS instrument is subject to 40 CFR Part 75 acid rain program requirements.' ;
    rdfs:domain ind:CemsInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pollutantMonitored rdf:type rdf:Property ;
    rdfs:label 'Pollutant Monitored' ;
    rdfs:comment 'The specific pollutant or parameter that this CEMS instrument is designed to monitor (e.g., NOx, SO2, CO, HCl, O2, Particulate Matter, Mercury, Flow). [ENUM-REF-CANDIDATE: NOx|SO2|CO|HCl|O2|Particulate Matter|Mercury|Flow — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CemsInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rataFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Rata Frequency Months' ;
    rdfs:comment 'Required frequency in months for conducting RATA tests on this CEMS instrument per regulatory requirements.' ;
    rdfs:domain ind:CemsInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responseTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Response Time Seconds' ;
    rdfs:comment 'Time in seconds for the CEMS instrument to respond to a step change in the measured parameter.' ;
    rdfs:domain ind:CemsInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spanGasConcentration rdf:type rdf:Property ;
    rdfs:label 'Span Gas Concentration' ;
    rdfs:comment 'Concentration value of the span gas used for calibration of this CEMS instrument, in the unit of measure specified.' ;
    rdfs:domain ind:CemsInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:zeroGasConcentration rdf:type rdf:Property ;
    rdfs:label 'Zero Gas Concentration' ;
    rdfs:comment 'Concentration value of the zero gas used for calibration of this CEMS instrument, typically zero or near-zero.' ;
    rdfs:domain ind:CemsInstrument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:combustionOperatingLogId rdf:type rdf:Property ;
    rdfs:label 'Combustion Operating Log Id' ;
    rdfs:comment 'Unique identifier for the combustion operating log record. Primary key for daily boiler unit operational records.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CombustionOperatingLog .

ind:shiftScheduleId rdf:type rdf:Property ;
    rdfs:label 'Shift Schedule Id' ;
    rdfs:comment 'Identifier of the operator shift during which this log entry was recorded. Links to workforce shift schedule.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ShiftSchedule .

ind:auxiliaryFuelConsumptionGallons rdf:type rdf:Property ;
    rdfs:label 'Auxiliary Fuel Consumption Gallons' ;
    rdfs:comment 'Volume of auxiliary fuel (typically diesel or natural gas) consumed in gallons to support combustion startup, shutdown, or maintain minimum temperature. Tracked for cost and emissions accounting.' ;
    rdfs:domain ind:CombustionOperatingLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:availabilityFactorPercent rdf:type rdf:Property ;
    rdfs:label 'Availability Factor Percent' ;
    rdfs:comment 'Percentage of time the boiler unit was available for operation excluding planned outages. Key performance indicator for operational reliability. Calculated as (24 - forced_outage_hours) / 24 * 100.' ;
    rdfs:domain ind:CombustionOperatingLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bottomAshTons rdf:type rdf:Property ;
    rdfs:label 'Bottom Ash Tons' ;
    rdfs:comment 'Total tons of bottom ash residue removed from the furnace grate during the operating date. Requires proper handling and disposal per RCRA regulations.' ;
    rdfs:domain ind:CombustionOperatingLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carbonIntensityScore rdf:type rdf:Property ;
    rdfs:label 'Carbon Intensity Score' ;
    rdfs:comment 'Carbon intensity score representing grams of CO2 equivalent per megajoule of energy produced. Used for Low Carbon Fuel Standard (LCFS) credit calculations and sustainability reporting.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cemsDataAvailabilityPercent rdf:type rdf:Property ;
    rdfs:label 'Cems Data Availability Percent' ;
    rdfs:comment 'Percentage of time the Continuous Emissions Monitoring System was operational and providing valid data during the operating date. Required to meet 95% quarterly availability per EPA regulations.' ;
    rdfs:domain ind:CombustionOperatingLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coEmissionsPounds rdf:type rdf:Property ;
    rdfs:label 'Co Emissions Pounds' ;
    rdfs:comment 'Total pounds of carbon monoxide emitted during the operating date. Indicator of combustion efficiency and air quality compliance.' ;
    rdfs:domain ind:CombustionOperatingLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Flag' ;
    rdfs:comment 'Boolean flag indicating whether all emissions and operational parameters were within permitted limits during the operating date. False indicates an exceedance or deviation requiring reporting.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deviationReportedFlag rdf:type rdf:Property ;
    rdfs:label 'Deviation Reported Flag' ;
    rdfs:comment 'Boolean flag indicating whether any permit deviations or exceedances were formally reported to regulatory authorities for this operating date.' ;
    rdfs:domain ind:CombustionOperatingLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dioxinFuranEmissionsNgPerDscm rdf:type rdf:Property ;
    rdfs:label 'Dioxin Furan Emissions Ng Per Dscm' ;
    rdfs:comment 'Concentration of dioxins and furans in stack emissions measured in nanograms per dry standard cubic meter. Highly regulated toxic compounds requiring continuous monitoring.' ;
    rdfs:domain ind:CombustionOperatingLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:energyOutputMwh rdf:type rdf:Property ;
    rdfs:label 'Energy Output Mwh' ;
    rdfs:comment 'Total electrical energy generated by the turbine-generator set in megawatt hours during the operating date. Primary revenue and performance metric for WTE operations.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:excessAirPercent rdf:type rdf:Property ;
    rdfs:label 'Excess Air Percent' ;
    rdfs:comment 'Percentage of excess air supplied to the combustion process beyond stoichiometric requirements. Affects combustion efficiency and emissions profile.' ;
    rdfs:domain ind:CombustionOperatingLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:flyAshTons rdf:type rdf:Property ;
    rdfs:label 'Fly Ash Tons' ;
    rdfs:comment 'Total tons of fly ash captured by air pollution control equipment during the operating date. May require special handling as hazardous waste depending on TCLP test results.' ;
    rdfs:domain ind:CombustionOperatingLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forcedOutageHours rdf:type rdf:Property ;
    rdfs:label 'Forced Outage Hours' ;
    rdfs:comment 'Hours of unplanned downtime due to equipment failure, emergency shutdown, or unscheduled maintenance during the operating date. Impacts availability factor calculation.' ;
    rdfs:domain ind:CombustionOperatingLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:furnaceTemperatureFahrenheit rdf:type rdf:Property ;
    rdfs:label 'Furnace Temperature Fahrenheit' ;
    rdfs:comment 'Average furnace combustion chamber temperature in degrees Fahrenheit during the operating period. Critical parameter for combustion efficiency and emissions control.' ;
    rdfs:domain ind:CombustionOperatingLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossHeatRateBtuPerKwh rdf:type rdf:Property ;
    rdfs:label 'Gross Heat Rate Btu Per Kwh' ;
    rdfs:comment 'Gross heat rate representing the thermal efficiency of the combustion and energy conversion process measured in BTU per kWh. Lower values indicate higher efficiency.' ;
    rdfs:domain ind:CombustionOperatingLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hclEmissionsPounds rdf:type rdf:Property ;
    rdfs:label 'Hcl Emissions Pounds' ;
    rdfs:comment 'Total pounds of hydrogen chloride emitted during the operating date. Acid gas requiring scrubber control and regulatory monitoring.' ;
    rdfs:domain ind:CombustionOperatingLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mercuryEmissionsPounds rdf:type rdf:Property ;
    rdfs:label 'Mercury Emissions Pounds' ;
    rdfs:comment 'Total pounds of mercury emitted during the operating date. Toxic metal requiring activated carbon injection and stringent monitoring per MACT standards.' ;
    rdfs:domain ind:CombustionOperatingLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mswThroughputTons rdf:type rdf:Property ;
    rdfs:label 'Msw Throughput Tons' ;
    rdfs:comment 'Total tons of Municipal Solid Waste fed into the boiler unit during the operating date. Primary input measurement for combustion process.' ;
    rdfs:domain ind:CombustionOperatingLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:noxEmissionsPounds rdf:type rdf:Property ;
    rdfs:label 'Nox Emissions Pounds' ;
    rdfs:comment 'Total pounds of nitrogen oxides emitted during the operating date. Monitored for Clean Air Act compliance and air quality permit requirements.' ;
    rdfs:domain ind:CombustionOperatingLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:opacityPercent rdf:type rdf:Property ;
    rdfs:label 'Opacity Percent' ;
    rdfs:comment 'Average stack opacity percentage during the operating date. Visual indicator of particulate emissions and air pollution control system performance.' ;
    rdfs:domain ind:CombustionOperatingLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatingDate rdf:type rdf:Property ;
    rdfs:label 'Operating Date' ;
    rdfs:comment 'The calendar date for which this operating log entry records combustion activity. Primary business event timestamp for daily operational reporting.' ;
    rdfs:domain ind:CombustionOperatingLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:particulateMatterEmissionsPounds rdf:type rdf:Property ;
    rdfs:label 'Particulate Matter Emissions Pounds' ;
    rdfs:comment 'Total pounds of particulate matter emitted during the operating date. Monitored for Clean Air Act compliance and public health protection.' ;
    rdfs:domain ind:CombustionOperatingLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedOutageHours rdf:type rdf:Property ;
    rdfs:label 'Planned Outage Hours' ;
    rdfs:comment 'Hours of scheduled downtime for preventive maintenance, inspections, or planned repairs during the operating date. Excluded from availability factor calculation.' ;
    rdfs:domain ind:CombustionOperatingLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recCreditsGenerated rdf:type rdf:Property ;
    rdfs:label 'Rec Credits Generated' ;
    rdfs:comment 'Number of Renewable Energy Credits generated during the operating date based on qualifying renewable energy output. One REC typically equals one MWh of renewable electricity.' ;
    rdfs:domain ind:CombustionOperatingLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:so2EmissionsPounds rdf:type rdf:Property ;
    rdfs:label 'So2 Emissions Pounds' ;
    rdfs:comment 'Total pounds of sulfur dioxide emitted during the operating date. Monitored for Clean Air Act compliance and acid rain program requirements.' ;
    rdfs:domain ind:CombustionOperatingLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:steamFlowKlb rdf:type rdf:Property ;
    rdfs:label 'Steam Flow Klb' ;
    rdfs:comment 'Total steam flow generated by the boiler unit measured in thousand pounds. Key output metric for energy generation performance.' ;
    rdfs:domain ind:CombustionOperatingLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryId rdf:type rdf:Property ;
    rdfs:label 'Delivery Id' ;
    rdfs:comment 'Unique identifier for the energy delivery transaction. Primary key.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:offtakeAgreementId rdf:type rdf:Property ;
    rdfs:label 'Offtake Agreement Id' ;
    rdfs:comment 'Foreign key linking to energy.offtake_agreement. Business justification: Energy deliveries are made under specific offtake agreements (PPAs or steam sales agreements). This link enables tracking of delivery performance against contractual commitments. The contract_id can b' ;
    rdfs:domain ind:Energy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OfftakeAgreement .

ind:offtakeCounterpartyId rdf:type rdf:Property ;
    rdfs:label 'Offtake Counterparty Id' ;
    rdfs:comment 'Identifier of the utility, industrial customer, or other counterparty receiving the delivered energy under the PPA or sales agreement.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:turbineGeneratorId rdf:type rdf:Property ;
    rdfs:label 'Turbine Generator Id' ;
    rdfs:comment 'Foreign key linking to energy.turbine_generator. Business justification: Each energy delivery comes from a specific turbine-generator unit. This link enables tracking of actual deliveries by asset, which is critical for settlement, performance analysis, and capacity factor' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TurbineGenerator .

ind:curtailmentQuantity rdf:type rdf:Property ;
    rdfs:label 'Curtailment Quantity' ;
    rdfs:comment 'Volume of energy curtailed or not delivered due to grid operator instruction, equipment failure, or contractual limitation.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:curtailmentReason rdf:type rdf:Property ;
    rdfs:label 'Curtailment Reason' ;
    rdfs:comment 'Reason for any curtailment of scheduled delivery (e.g., grid operator instruction, equipment outage, contractual limit, low demand).' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryNumber rdf:type rdf:Property ;
    rdfs:label 'Delivery Number' ;
    rdfs:comment 'Business-facing unique identifier for the delivery transaction, used in invoicing and settlement reconciliation.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryStatus rdf:type rdf:Property ;
    rdfs:label 'Delivery Status' ;
    rdfs:comment 'Current lifecycle status of the energy delivery transaction.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emissionsOffsetQuantity rdf:type rdf:Property ;
    rdfs:label 'Emissions Offset Quantity' ;
    rdfs:comment 'Quantity of greenhouse gas emissions offsets (in metric tons CO2e) associated with this renewable energy delivery, used for sustainability reporting.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:energyType rdf:type rdf:Property ;
    rdfs:label 'Energy Type' ;
    rdfs:comment 'Type of energy delivered: electricity (MWh), steam (klb or MMBtu), Renewable Natural Gas (RNG), or thermal energy.' ;
    rdfs:domain ind:Energy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meterReadTimestamp rdf:type rdf:Property ;
    rdfs:label 'Meter Read Timestamp' ;
    rdfs:comment 'Timestamp when the settlement meter reading was captured for this delivery period.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:meteredQuantity rdf:type rdf:Property ;
    rdfs:label 'Metered Quantity' ;
    rdfs:comment 'Actual quantity of energy delivered as measured by settlement meter, in units appropriate to energy type (MWh, klb, MMBtu, or dekatherms).' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Net Revenue Amount' ;
    rdfs:comment 'Net revenue amount for this delivery after all adjustments, used for financial reporting and revenue recognition.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:periodEnd rdf:type rdf:Property ;
    rdfs:label 'Period End' ;
    rdfs:comment 'End timestamp of the delivery period during which energy was delivered to the offtake counterparty.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:periodStart rdf:type rdf:Property ;
    rdfs:label 'Period Start' ;
    rdfs:comment 'Start timestamp of the delivery period during which energy was delivered to the offtake counterparty.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:point rdf:type rdf:Property ;
    rdfs:label 'Point' ;
    rdfs:comment 'Physical or logical point at which energy was delivered to the offtake counterparty (e.g., grid interconnection point, steam header, pipeline custody transfer point).' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricePerUnit rdf:type rdf:Property ;
    rdfs:label 'Price Per Unit' ;
    rdfs:comment 'Contracted price per unit of energy delivered (e.g., dollars per MWh, dollars per klb, dollars per MMBtu) as specified in the PPA or sales agreement.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityCertificationFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Certification Flag' ;
    rdfs:comment 'Indicates whether the delivered energy met all quality specifications and certifications required by the PPA or sales agreement (e.g., renewable attributes, emissions standards).' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recQuantity rdf:type rdf:Property ;
    rdfs:label 'Rec Quantity' ;
    rdfs:comment 'Number of Renewable Energy Credits (RECs) generated and transferred with this energy delivery, typically one REC per MWh of renewable electricity.' ;
    rdfs:domain ind:Energy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recSerialNumbers rdf:type rdf:Property ;
    rdfs:label 'Rec Serial Numbers' ;
    rdfs:comment 'Comma-separated list of REC serial numbers issued by the regional tracking system (e.g., M-RETS, WREGIS, PJM-GATS) for this delivery.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueAmount rdf:type rdf:Property ;
    rdfs:label 'Revenue Amount' ;
    rdfs:comment 'Total revenue recognized for this delivery, calculated as metered quantity multiplied by delivery price per unit, before adjustments.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduledQuantity rdf:type rdf:Property ;
    rdfs:label 'Scheduled Quantity' ;
    rdfs:comment 'Planned or contracted quantity of energy scheduled for delivery during the period, in units appropriate to energy type.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementDate rdf:type rdf:Property ;
    rdfs:label 'Settlement Date' ;
    rdfs:comment 'Date on which this delivery was financially settled and reconciled with the offtake counterparty.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:settlementMeterNumber rdf:type rdf:Property ;
    rdfs:label 'Settlement Meter Number' ;
    rdfs:comment 'Identifier of the revenue-grade meter used to measure the delivered energy quantity for settlement and invoicing purposes.' ;
    rdfs:domain ind:Delivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emissionsReadingId rdf:type rdf:Property ;
    rdfs:label 'Emissions Reading Id' ;
    rdfs:comment 'Unique identifier for the emissions reading record. Primary key for the emissions_reading data product.' ;
    rdfs:domain ind:EmissionsReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calibrationDate rdf:type rdf:Property ;
    rdfs:label 'Calibration Date' ;
    rdfs:comment 'Date of the most recent calibration or quality assurance test performed on the monitoring equipment prior to this reading. EPA regulations require regular calibration and QA testing of CEMS equipment.' ;
    rdfs:domain ind:Energy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:concentrationUnit rdf:type rdf:Property ;
    rdfs:label 'Concentration Unit' ;
    rdfs:comment 'Unit of measure for the measured concentration. Common units include parts per million (ppm), milligrams per dry standard cubic meter (mg/dscm), nanograms per dry standard cubic meter (ng/dscm), micrograms per dry standard cubic meter (ug/dscm), or pounds per million British thermal units (lb/MMBtu).' ;
    rdfs:domain ind:EmissionsReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlDeviceStatus rdf:type rdf:Property ;
    rdfs:label 'Control Device Status' ;
    rdfs:comment 'Operational status of air pollution control equipment (e.g., scrubbers, baghouses, electrostatic precipitators, selective catalytic reduction systems) at the time of measurement. Control device malfunctions or bypass events may result in elevated emissions and compliance violations.' ;
    rdfs:domain ind:EmissionsReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctedConcentration rdf:type rdf:Property ;
    rdfs:label 'Corrected Concentration' ;
    rdfs:comment 'Pollutant concentration corrected to 7% oxygen (O2) reference basis as required by EPA regulations for combustion sources. This normalization allows for consistent comparison across different operating conditions.' ;
    rdfs:domain ind:EmissionsReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:flowRate rdf:type rdf:Property ;
    rdfs:label 'Flow Rate' ;
    rdfs:comment 'Volumetric flow rate of stack gas at the time of measurement, typically measured in dry standard cubic feet per hour (dscfh) or dry standard cubic meters per hour (dscmh). Used to calculate mass emission rates.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:flowRateUnit rdf:type rdf:Property ;
    rdfs:label 'Flow Rate Unit' ;
    rdfs:comment 'Unit of measure for stack gas flow rate. Common units include dry standard cubic feet per hour (dscfh), dry standard cubic meters per hour (dscmh), actual cubic feet per minute (acfm), or actual cubic meters per hour (acmh).' ;
    rdfs:domain ind:EmissionsReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:massEmissionRate rdf:type rdf:Property ;
    rdfs:label 'Mass Emission Rate' ;
    rdfs:comment 'Calculated mass emission rate of the pollutant, derived from concentration and flow rate. Typically expressed in pounds per hour (lb/hr) or kilograms per hour (kg/hr). Used for permit compliance and annual emission inventory reporting.' ;
    rdfs:domain ind:EmissionsReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:massEmissionRateUnit rdf:type rdf:Property ;
    rdfs:label 'Mass Emission Rate Unit' ;
    rdfs:comment 'Unit of measure for mass emission rate. Common units include pounds per hour (lb/hr), kilograms per hour (kg/hr), tons per year (ton/yr), or grams per second (g/sec).' ;
    rdfs:domain ind:EmissionsReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measuredConcentration rdf:type rdf:Property ;
    rdfs:label 'Measured Concentration' ;
    rdfs:comment 'Raw measured concentration of the pollutant as captured by the Continuous Emissions Monitoring System (CEMS) or stack test equipment. Units vary by pollutant (ppm, mg/dscm, ng/dscm).' ;
    rdfs:domain ind:EmissionsReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:moistureContent rdf:type rdf:Property ;
    rdfs:label 'Moisture Content' ;
    rdfs:comment 'Moisture content of the stack gas expressed as a percentage by volume. Used to convert between wet and dry basis measurements.' ;
    rdfs:domain ind:EmissionsReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatingLoad rdf:type rdf:Property ;
    rdfs:label 'Operating Load' ;
    rdfs:comment 'Operating load of the combustion unit at the time of measurement, expressed as a percentage of maximum rated capacity. Emissions characteristics vary with load, and some permit limits are load-dependent.' ;
    rdfs:domain ind:EmissionsReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oxygenPercent rdf:type rdf:Property ;
    rdfs:label 'Oxygen Percent' ;
    rdfs:comment 'Measured oxygen (O2) percentage in the stack gas at the time of reading. Used to calculate corrected concentration values.' ;
    rdfs:domain ind:EmissionsReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:permitLimit rdf:type rdf:Property ;
    rdfs:label 'Permit Limit' ;
    rdfs:comment 'Maximum allowable concentration or emission rate for this pollutant as specified in the facility\'s air quality permit issued by the state or EPA. Used to determine compliance status.' ;
    rdfs:domain ind:EmissionsReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pollutantType rdf:type rdf:Property ;
    rdfs:label 'Pollutant Type' ;
    rdfs:comment 'Type of air pollutant measured in this emissions reading. Common pollutants include nitrogen oxides (NOx), sulfur dioxide (SO2), carbon monoxide (CO), hydrogen chloride (HCl), dioxins and furans, mercury (Hg), particulate matter (PM), volatile organic compounds (VOC), lead (Pb), and cadmium (Cd). [ENUM-REF-CANDIDATE: NOx|SO2|CO|HCl|Dioxins_Furans|Mercury|Particulates|VOC|Lead|Cadmium — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:EmissionsReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qaQcStatus rdf:type rdf:Property ;
    rdfs:label 'Qa Qc Status' ;
    rdfs:comment 'Quality assurance and quality control status of the emissions reading. Indicates whether the data has passed validation checks, failed QA procedures, or was affected by instrument issues. Data substitution may occur per EPA protocols when CEMS data is unavailable.' ;
    rdfs:domain ind:EmissionsReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:readingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reading Timestamp' ;
    rdfs:comment 'Date and time when the emissions measurement was captured. For CEMS data, this is the end of the averaging period (typically hourly). For stack tests, this is the midpoint of the test run.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reportingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Reporting Required Flag' ;
    rdfs:comment 'Indicates whether this emissions reading must be reported to regulatory agencies (EPA, state environmental quality departments). Exceedances, deviations, and certain periodic reports trigger mandatory reporting under Clean Air Act (CAA) requirements.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stackTemperature rdf:type rdf:Property ;
    rdfs:label 'Stack Temperature' ;
    rdfs:comment 'Temperature of the stack gas at the measurement point, typically in degrees Fahrenheit (°F) or Celsius (°C). Used for flow rate calculations and combustion efficiency analysis.' ;
    rdfs:domain ind:EmissionsReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stackTemperatureUnit rdf:type rdf:Property ;
    rdfs:label 'Stack Temperature Unit' ;
    rdfs:comment 'Unit of measure for stack gas temperature: Fahrenheit (F) or Celsius (C).' ;
    rdfs:domain ind:EmissionsReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testCompany rdf:type rdf:Property ;
    rdfs:label 'Test Company' ;
    rdfs:comment 'Name of the third-party testing company that conducted the stack test. Applicable only to manual stack test readings. Testing companies must be accredited and follow EPA protocols.' ;
    rdfs:domain ind:EmissionsReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testRunNumber rdf:type rdf:Property ;
    rdfs:label 'Test Run Number' ;
    rdfs:comment 'Identifier for the specific test run within a stack test event. EPA methods typically require multiple test runs (usually 3) to establish compliance. Applicable only to manual stack test readings, not CEMS data.' ;
    rdfs:domain ind:EmissionsReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:generationReadingId rdf:type rdf:Property ;
    rdfs:label 'Generation Reading Id' ;
    rdfs:comment 'Unique identifier for the energy generation reading record. Primary key for this transactional measurement entity.' ;
    rdfs:domain ind:GenerationReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ambientTemperatureF rdf:type rdf:Property ;
    rdfs:label 'Ambient Temperature F' ;
    rdfs:comment 'Outdoor ambient air temperature at the facility during this reading interval, measured in degrees Fahrenheit. Impacts turbine performance and thermal efficiency calculations.' ;
    rdfs:domain ind:GenerationReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ashResidueTons rdf:type rdf:Property ;
    rdfs:label 'Ash Residue Tons' ;
    rdfs:comment 'Quantity of bottom ash and fly ash residue generated from combustion during this reading interval, measured in tons. Requires proper handling, testing (TCLP), and disposal per RCRA regulations.' ;
    rdfs:domain ind:GenerationReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:barometricPressureInhg rdf:type rdf:Property ;
    rdfs:label 'Barometric Pressure Inhg' ;
    rdfs:comment 'Atmospheric pressure at the facility during this reading interval, measured in inches of mercury (inHg). Affects combustion air density and turbine performance.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityFactorPercent rdf:type rdf:Property ;
    rdfs:label 'Capacity Factor Percent' ;
    rdfs:comment 'Ratio of actual energy output to maximum possible output over the reading interval, expressed as a percentage. Key performance indicator for turbine efficiency and operational availability.' ;
    rdfs:domain ind:GenerationReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:co2EmissionsTons rdf:type rdf:Property ;
    rdfs:label 'Co2 Emissions Tons' ;
    rdfs:comment 'Quantity of carbon dioxide (CO2) emitted during this reading interval, measured in tons. Required for Clean Air Act (CAA) compliance and greenhouse gas (GHG) reporting.' ;
    rdfs:domain ind:GenerationReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coEmissionsLbs rdf:type rdf:Property ;
    rdfs:label 'Co Emissions Lbs' ;
    rdfs:comment 'Quantity of carbon monoxide (CO) emitted during this reading interval, measured in pounds. Indicator of combustion efficiency and air quality compliance.' ;
    rdfs:domain ind:Energy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelInputScfmLfg rdf:type rdf:Property ;
    rdfs:label 'Fuel Input Scfm Lfg' ;
    rdfs:comment 'Flow rate of Landfill Gas (LFG) fed into the energy conversion system during this reading interval, measured in standard cubic feet per minute (scfm). Primary fuel input metric for LFG-to-energy projects.' ;
    rdfs:domain ind:GenerationReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelInputTonsMsw rdf:type rdf:Property ;
    rdfs:label 'Fuel Input Tons Msw' ;
    rdfs:comment 'Quantity of Municipal Solid Waste (MSW) or Solid Recovered Fuel (SRF) combusted during this reading interval, measured in tons. Primary fuel input metric for WTE facilities.' ;
    rdfs:domain ind:GenerationReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gridExportMwh rdf:type rdf:Property ;
    rdfs:label 'Grid Export Mwh' ;
    rdfs:comment 'Quantity of electrical energy exported to the utility grid during this reading interval, measured in megawatt-hours (MWh). Used for revenue calculation and grid interconnection reporting.' ;
    rdfs:domain ind:GenerationReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossGenerationMwh rdf:type rdf:Property ;
    rdfs:label 'Gross Generation Mwh' ;
    rdfs:comment 'Total electrical energy generated by the turbine-generator unit before accounting for parasitic load or auxiliary consumption, measured in megawatt-hours (MWh).' ;
    rdfs:domain ind:GenerationReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:meterCalibrationDate rdf:type rdf:Property ;
    rdfs:label 'Meter Calibration Date' ;
    rdfs:comment 'Date when the energy meter was last calibrated or verified for accuracy. Required for regulatory compliance and data quality assurance.' ;
    rdfs:domain ind:GenerationReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:meterNumber rdf:type rdf:Property ;
    rdfs:label 'Meter Number' ;
    rdfs:comment 'Unique identifier of the energy meter or monitoring device that captured this reading. Used for traceability and calibration tracking.' ;
    rdfs:domain ind:GenerationReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:methaneContentPercent rdf:type rdf:Property ;
    rdfs:label 'Methane Content Percent' ;
    rdfs:comment 'Percentage of methane (CH4) in the landfill gas stream. Higher methane content indicates better fuel quality and energy yield. Typical range is 45-60% for LFG.' ;
    rdfs:domain ind:Energy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netGenerationMwh rdf:type rdf:Property ;
    rdfs:label 'Net Generation Mwh' ;
    rdfs:comment 'Net electrical energy available for sale or use after subtracting parasitic load and auxiliary consumption from gross generation, measured in megawatt-hours (MWh). Primary metric for utility settlement and revenue recognition.' ;
    rdfs:domain ind:GenerationReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:noxEmissionsLbs rdf:type rdf:Property ;
    rdfs:label 'Nox Emissions Lbs' ;
    rdfs:comment 'Quantity of nitrogen oxides (NOx) emitted during this reading interval, measured in pounds. Regulated pollutant under Clean Air Act (CAA) requiring continuous emissions monitoring.' ;
    rdfs:domain ind:Energy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onSiteConsumptionMwh rdf:type rdf:Property ;
    rdfs:label 'On Site Consumption Mwh' ;
    rdfs:comment 'Quantity of electrical energy consumed on-site by facility operations during this reading interval, measured in megawatt-hours (MWh). Reduces net export to grid.' ;
    rdfs:domain ind:GenerationReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parasiticLoadMwh rdf:type rdf:Property ;
    rdfs:label 'Parasitic Load Mwh' ;
    rdfs:comment 'Electrical energy consumed by auxiliary equipment and facility operations (pumps, fans, controls, lighting) during this reading interval, measured in megawatt-hours (MWh). Subtracted from gross generation to calculate net generation.' ;
    rdfs:domain ind:GenerationReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:particulateMatterLbs rdf:type rdf:Property ;
    rdfs:label 'Particulate Matter Lbs' ;
    rdfs:comment 'Quantity of particulate matter (PM10 and PM2.5) emitted during this reading interval, measured in pounds. Regulated pollutant under Clean Air Act (CAA) requiring continuous emissions monitoring.' ;
    rdfs:domain ind:Energy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:readingIntervalType rdf:type rdf:Property ;
    rdfs:label 'Reading Interval Type' ;
    rdfs:comment 'Frequency or interval at which this reading was captured (hourly, daily, shift-based, real-time, monthly). Determines aggregation and reporting granularity.' ;
    rdfs:domain ind:GenerationReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recCertificationType rdf:type rdf:Property ;
    rdfs:label 'Rec Certification Type' ;
    rdfs:comment 'Type of renewable energy credit certification program under which this generation qualifies (Green-e, M-RETS, PJM-GATS, WREGIS, ERCOT, or none if not certified).' ;
    rdfs:domain ind:GenerationReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewableEnergyCreditsQty rdf:type rdf:Property ;
    rdfs:label 'Renewable Energy Credits Qty' ;
    rdfs:comment 'Number of Renewable Energy Credits (RECs) or Renewable Identification Numbers (RINs) generated from this energy production, based on qualifying renewable fuel sources. Used for compliance and revenue recognition.' ;
    rdfs:domain ind:GenerationReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:so2EmissionsLbs rdf:type rdf:Property ;
    rdfs:label 'So2 Emissions Lbs' ;
    rdfs:comment 'Quantity of sulfur dioxide (SO2) emitted during this reading interval, measured in pounds. Regulated pollutant under Clean Air Act (CAA) requiring continuous emissions monitoring.' ;
    rdfs:domain ind:Energy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:steamOutputKlb rdf:type rdf:Property ;
    rdfs:label 'Steam Output Klb' ;
    rdfs:comment 'Quantity of steam produced by the boiler system during this reading interval, measured in thousand pounds (klb). Applicable for combined heat and power (CHP) or industrial steam sales.' ;
    rdfs:domain ind:GenerationReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:turbineEfficiencyPercent rdf:type rdf:Property ;
    rdfs:label 'Turbine Efficiency Percent' ;
    rdfs:comment 'Ratio of electrical energy output to thermal energy input for the turbine-generator unit, expressed as a percentage. Indicates mechanical and electrical conversion efficiency.' ;
    rdfs:domain ind:Energy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:utilitySettlementMwh rdf:type rdf:Property ;
    rdfs:label 'Utility Settlement Mwh' ;
    rdfs:comment 'Net energy quantity submitted to the utility or grid operator for settlement and revenue calculation, measured in megawatt-hours (MWh). May differ from net generation due to contractual adjustments or metering reconciliation.' ;
    rdfs:domain ind:GenerationReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:energyRateScheduleId rdf:type rdf:Property ;
    rdfs:label 'Energy Rate Schedule Id' ;
    rdfs:comment 'Unique identifier for the energy rate schedule. Primary key for this reference table.' ;
    rdfs:domain ind:Energy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EnergyRateSchedule .

ind:capacityPaymentIncluded rdf:type rdf:Property ;
    rdfs:label 'Capacity Payment Included' ;
    rdfs:comment 'Indicates whether this rate schedule includes a separate capacity payment component in addition to energy payments. Relevant for electricity PPAs with capacity markets. True if capacity payments are included, false otherwise.' ;
    rdfs:domain ind:EnergyRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:counterpartyName rdf:type rdf:Property ;
    rdfs:label 'Counterparty Name' ;
    rdfs:comment 'Name of the buyer or off-taker organization that this rate schedule applies to. The entity purchasing energy under this pricing arrangement.' ;
    rdfs:domain ind:EnergyRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterpartyType rdf:type rdf:Property ;
    rdfs:label 'Counterparty Type' ;
    rdfs:comment 'Classification of the energy buyer. Utility is investor-owned or public utility, industrial is large manufacturing customer, commercial is business customer, aggregator is energy broker/marketer, ISO market is wholesale market participation, and municipal is government entity.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalAttributeTreatment rdf:type rdf:Property ;
    rdfs:label 'Environmental Attribute Treatment' ;
    rdfs:comment 'Specifies how environmental attributes such as RECs, carbon credits, LCFS credits, and RINs are allocated between buyer and seller under this rate schedule. Bundled means attributes transfer with energy, unbundled means sold separately, seller/buyer retains indicates which party keeps the attributes, and shared indicates negotiated split.' ;
    rdfs:domain ind:EnergyRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationMechanism rdf:type rdf:Property ;
    rdfs:label 'Escalation Mechanism' ;
    rdfs:comment 'Method by which the rate schedule adjusts over time. CPI ties to Consumer Price Index, fixed percent applies a contractual annual increase, market indexed follows commodity or power market indices, negotiated annual requires bilateral agreement each period, and none indicates a flat rate for the contract term.' ;
    rdfs:domain ind:EnergyRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationRatePercent rdf:type rdf:Property ;
    rdfs:label 'Escalation Rate Percent' ;
    rdfs:comment 'Annual escalation percentage applied to the base rate when escalation mechanism is fixed percent. Null for non-fixed escalation types.' ;
    rdfs:domain ind:EnergyRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marketIso rdf:type rdf:Property ;
    rdfs:label 'Market Iso' ;
    rdfs:comment 'The Independent System Operator or Regional Transmission Organization market applicable to this rate schedule for electricity products. ISO-NE is ISO New England, PJM is PJM Interconnection, MISO is Midcontinent ISO, CAISO is California ISO, ERCOT is Electric Reliability Council of Texas, SPP is Southwest Power Pool, NYISO is New York ISO. None applies to non-electricity products or bilateral contracts outside ISO markets. [ENUM-REF-CANDIDATE: iso_ne|pjm|miso|caiso|ercot|spp|nyiso|none — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:EnergyRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumQuantity rdf:type rdf:Property ;
    rdfs:label 'Maximum Quantity' ;
    rdfs:comment 'Maximum energy quantity allowed per period under this rate schedule, expressed in the unit specified by rate_unit. Null if no maximum applies.' ;
    rdfs:domain ind:EnergyRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumQuantity rdf:type rdf:Property ;
    rdfs:label 'Minimum Quantity' ;
    rdfs:comment 'Minimum energy quantity commitment per period required under this rate schedule, expressed in the unit specified by rate_unit. Null if no minimum applies.' ;
    rdfs:domain ind:EnergyRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricingBasis rdf:type rdf:Property ;
    rdfs:label 'Pricing Basis' ;
    rdfs:comment 'Fundamental pricing mechanism for the rate schedule. Fixed indicates a set dollar per unit rate, LMP-indexed ties to locational marginal pricing in wholesale electricity markets, Henry Hub-indexed follows natural gas commodity pricing for RNG, cost-plus adds margin to production costs, negotiated reflects bilateral contract terms, and tariff follows regulatory-approved rates.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateUnit rdf:type rdf:Property ;
    rdfs:label 'Rate Unit' ;
    rdfs:comment 'Unit of measure for the base rate. USD per MWh for electricity, USD per thousand pounds for steam, USD per million BTU or therm or dekatherm for gas products.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recBundled rdf:type rdf:Property ;
    rdfs:label 'Rec Bundled' ;
    rdfs:comment 'Indicates whether Renewable Energy Credits are bundled with the energy sale under this rate schedule or sold separately. True if RECs are bundled with energy, false if unbundled or not applicable.' ;
    rdfs:domain ind:EnergyRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:settlementFrequency rdf:type rdf:Property ;
    rdfs:label 'Settlement Frequency' ;
    rdfs:comment 'Frequency at which energy deliveries and payments are settled under this rate schedule. Hourly for real-time markets, daily for day-ahead, monthly for typical utility billing, quarterly or annual for long-term contracts.' ;
    rdfs:domain ind:Energy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tariffReference rdf:type rdf:Property ;
    rdfs:label 'Tariff Reference' ;
    rdfs:comment 'Reference to the regulatory tariff, docket number, or public utility commission filing that governs this rate schedule. Applicable for utility-regulated energy sales.' ;
    rdfs:domain ind:EnergyRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeOfUseApplicable rdf:type rdf:Property ;
    rdfs:label 'Time Of Use Applicable' ;
    rdfs:comment 'Indicates whether this rate schedule includes time-of-use pricing with different rates for peak, off-peak, and shoulder periods. True if TOU pricing applies, false otherwise.' ;
    rdfs:domain ind:EnergyRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ghgEmissionFactorId rdf:type rdf:Property ;
    rdfs:label 'Ghg Emission Factor Id' ;
    rdfs:comment 'Unique identifier for the greenhouse gas emission factor record.' ;
    rdfs:domain ind:GhgEmissionFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supersededByFactorGhgEmissionFactorId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Factor Ghg Emission Factor Id' ;
    rdfs:comment 'Reference to the emission factor ID that supersedes this factor when it expires, enabling traceability of factor evolution.' ;
    rdfs:domain ind:GhgEmissionFactor ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GhgEmissionFactor .

ind:biogenicFlag rdf:type rdf:Property ;
    rdfs:label 'Biogenic Flag' ;
    rdfs:comment 'Indicates whether this emission factor applies to biogenic carbon emissions (from biomass or organic waste) which are reported separately from fossil carbon emissions in many GHG accounting frameworks.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:combustionEfficiencyPercent rdf:type rdf:Property ;
    rdfs:label 'Combustion Efficiency Percent' ;
    rdfs:comment 'Assumed combustion efficiency percentage used in deriving this emission factor, representing the completeness of fuel combustion.' ;
    rdfs:domain ind:GhgEmissionFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataQualityTier rdf:type rdf:Property ;
    rdfs:label 'Data Quality Tier' ;
    rdfs:comment 'IPCC data quality tier classification indicating the level of detail and accuracy of the emission factor: Tier 1 (default factors), Tier 2 (country-specific), Tier 3 (facility-specific measurements), Tier 4 (continuous monitoring).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emissionFactorValue rdf:type rdf:Property ;
    rdfs:label 'Emission Factor Value' ;
    rdfs:comment 'Numeric value of the emission factor used to calculate greenhouse gas emissions from the specified source.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emissionSourceCategory rdf:type rdf:Property ;
    rdfs:label 'Emission Source Category' ;
    rdfs:comment 'Category of the emission source for which this factor applies, such as Municipal Solid Waste (MSW) combustion, Landfill Gas (LFG) flaring, Renewable Natural Gas (RNG) combustion, or fossil fuel auxiliary use.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:factorCode rdf:type rdf:Property ;
    rdfs:label 'Factor Code' ;
    rdfs:comment 'Business identifier code for the emission factor, used for external reference and reporting.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:factorName rdf:type rdf:Property ;
    rdfs:label 'Factor Name' ;
    rdfs:comment 'Descriptive name of the emission factor identifying the source and GHG type.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelFeedstockType rdf:type rdf:Property ;
    rdfs:label 'Fuel Feedstock Type' ;
    rdfs:comment 'Type of fuel or feedstock material for which this emission factor is applicable, such as Municipal Solid Waste (MSW), Landfill Gas (LFG), Solid Recovered Fuel (SRF), diesel, or natural gas.' ;
    rdfs:domain ind:GhgEmissionFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicApplicability rdf:type rdf:Property ;
    rdfs:label 'Geographic Applicability' ;
    rdfs:comment 'Geographic region or jurisdiction where this emission factor is applicable, such as USA, specific state codes, or international regions.' ;
    rdfs:domain ind:GhgEmissionFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ghgType rdf:type rdf:Property ;
    rdfs:label 'Ghg Type' ;
    rdfs:comment 'Type of greenhouse gas covered by this emission factor: Carbon Dioxide (CO2), Methane (CH4), Nitrous Oxide (N2O), or Carbon Dioxide Equivalent (CO2e).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oxidationFactor rdf:type rdf:Property ;
    rdfs:label 'Oxidation Factor' ;
    rdfs:comment 'Fraction of carbon in the fuel that is oxidized to CO2 during combustion, typically between 0.95 and 1.00.' ;
    rdfs:domain ind:GhgEmissionFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scopeClassification rdf:type rdf:Property ;
    rdfs:label 'Scope Classification' ;
    rdfs:comment 'GHG Protocol scope classification for emissions calculated using this factor: Scope 1 (direct emissions), Scope 2 (indirect emissions from purchased energy), or Scope 3 (other indirect emissions).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uncertaintyPercent rdf:type rdf:Property ;
    rdfs:label 'Uncertainty Percent' ;
    rdfs:comment 'Estimated uncertainty or confidence interval percentage associated with this emission factor value, representing measurement and estimation variability.' ;
    rdfs:domain ind:GhgEmissionFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:verifierOrganization rdf:type rdf:Property ;
    rdfs:label 'Verifier Organization' ;
    rdfs:comment 'Name of the third-party organization or regulatory body that verified or validated this emission factor.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lcfsCreditId rdf:type rdf:Property ;
    rdfs:label 'Lcfs Credit Id' ;
    rdfs:comment 'Unique identifier for the LCFS credit transaction record.' ;
    rdfs:domain ind:LcfsCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rngProcessingUnitId rdf:type rdf:Property ;
    rdfs:label 'Rng Processing Unit Id' ;
    rdfs:comment 'Reference to the RNG processing unit that generated the fuel qualifying for LCFS credits.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RngProcessingUnit .

ind:buyerCarbAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Buyer Carb Account Number' ;
    rdfs:comment 'CARB account number of the buyer organization in the LCFS credit trading system.' ;
    rdfs:domain ind:LcfsCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carbTransactionNumber rdf:type rdf:Property ;
    rdfs:label 'Carb Transaction Number' ;
    rdfs:comment 'Official CARB system transaction identifier for credit generation or transfer.' ;
    rdfs:domain ind:LcfsCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Credit Serial Number' ;
    rdfs:comment 'Unique serial number assigned by CARB to this LCFS credit issuance.' ;
    rdfs:domain ind:LcfsCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feedstockType rdf:type rdf:Property ;
    rdfs:label 'Feedstock Type' ;
    rdfs:comment 'Type of organic waste feedstock used to produce the RNG qualifying for LCFS credits.' ;
    rdfs:domain ind:Energy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelPathwayCode rdf:type rdf:Property ;
    rdfs:label 'Fuel Pathway Code' ;
    rdfs:comment 'CARB-approved fuel pathway code identifying the specific production process and feedstock for the RNG. Determines the carbon intensity baseline for credit calculation.' ;
    rdfs:domain ind:LcfsCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelUseType rdf:type rdf:Property ;
    rdfs:label 'Fuel Use Type' ;
    rdfs:comment 'End-use application of the RNG fuel for LCFS credit eligibility.' ;
    rdfs:domain ind:LcfsCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ghgEmissionsAvoidedCo2eTons rdf:type rdf:Property ;
    rdfs:label 'Ghg Emissions Avoided Co2e Tons' ;
    rdfs:comment 'Total greenhouse gas emissions avoided by using RNG instead of conventional fossil fuel, measured in metric tons of CO2 equivalent.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marketValueUsd rdf:type rdf:Property ;
    rdfs:label 'Market Value Usd' ;
    rdfs:comment 'Total market value of the LCFS credits at the time of generation or transfer.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oregonCfpCreditQuantity rdf:type rdf:Property ;
    rdfs:label 'Oregon Cfp Credit Quantity' ;
    rdfs:comment 'Quantity of Oregon CFP credits generated from the same RNG volume, if applicable.' ;
    rdfs:domain ind:LcfsCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oregonCfpEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Oregon Cfp Eligible Flag' ;
    rdfs:comment 'Indicates whether the RNG fuel and credits are also eligible for Oregon Clean Fuels Program credits.' ;
    rdfs:domain ind:LcfsCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Reporting Period End Date' ;
    rdfs:comment 'End date of the quarterly reporting period for which the LCFS credits were generated.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Start Date' ;
    rdfs:comment 'Start date of the quarterly reporting period for which the LCFS credits were generated.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:retirementPurpose rdf:type rdf:Property ;
    rdfs:label 'Retirement Purpose' ;
    rdfs:comment 'Reason for retiring the LCFS credits from circulation.' ;
    rdfs:domain ind:Energy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rinGenerationEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Rin Generation Eligible Flag' ;
    rdfs:comment 'Indicates whether the RNG fuel is also eligible for EPA Renewable Identification Number (RIN) generation under the Renewable Fuel Standard.' ;
    rdfs:domain ind:LcfsCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rngVolumeDge rdf:type rdf:Property ;
    rdfs:label 'Rng Volume Dge' ;
    rdfs:comment 'Volume of renewable natural gas expressed in diesel gallon equivalents for standardized energy content comparison.' ;
    rdfs:domain ind:LcfsCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rngVolumeMmbtu rdf:type rdf:Property ;
    rdfs:label 'Rng Volume Mmbtu' ;
    rdfs:comment 'Volume of renewable natural gas produced and used as transportation fuel during the reporting period, measured in million British thermal units.' ;
    rdfs:domain ind:Energy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitPriceUsd rdf:type rdf:Property ;
    rdfs:label 'Unit Price Usd' ;
    rdfs:comment 'Price per LCFS credit unit in US dollars.' ;
    rdfs:domain ind:Energy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vintageYear rdf:type rdf:Property ;
    rdfs:label 'Vintage Year' ;
    rdfs:comment 'Year in which the RNG fuel was produced and the credits were generated.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lfgCollectionSystemId rdf:type rdf:Property ;
    rdfs:label 'Lfg Collection System Id' ;
    rdfs:comment 'Unique identifier for the landfill gas collection and control system (GCCS). Primary key for the LFG collection system master record.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LfgCollectionSystem .

ind:energyProjectId rdf:type rdf:Property ;
    rdfs:label 'Energy Project Id' ;
    rdfs:comment 'Reference to the associated waste-to-energy or LFG-to-energy project that utilizes gas from this collection system. Null if gas is flared only.' ;
    rdfs:domain ind:LfgCollectionSystem ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CapitalProject .

ind:beneficialUseFlag rdf:type rdf:Property ;
    rdfs:label 'Beneficial Use Flag' ;
    rdfs:comment 'Indicates whether the collected LFG is used for beneficial purposes such as electricity generation, renewable natural gas production, or direct thermal use (True) or is flared for destruction only (False).' ;
    rdfs:domain ind:LfgCollectionSystem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:beneficialUseType rdf:type rdf:Property ;
    rdfs:label 'Beneficial Use Type' ;
    rdfs:comment 'Classification of how collected LFG is utilized: conversion to electricity (LFG-to-electricity), processing to renewable natural gas (LFG-to-RNG), direct thermal use, medium-BTU gas production, or flare-only destruction.' ;
    rdfs:domain ind:LfgCollectionSystem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blowerStationCount rdf:type rdf:Property ;
    rdfs:label 'Blower Station Count' ;
    rdfs:comment 'Number of blower stations that create negative pressure to extract landfill gas from the collection wells.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capitalCostUsd rdf:type rdf:Property ;
    rdfs:label 'Capital Cost Usd' ;
    rdfs:comment 'Total capital expenditure in USD for the design, procurement, and installation of the LFG collection system.' ;
    rdfs:domain ind:LfgCollectionSystem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:collectionAreaAcres rdf:type rdf:Property ;
    rdfs:label 'Collection Area Acres' ;
    rdfs:comment 'Total landfill area in acres covered by this LFG collection system. Used for system coverage and efficiency analysis.' ;
    rdfs:domain ind:LfgCollectionSystem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:collectionEfficiencyPercent rdf:type rdf:Property ;
    rdfs:label 'Collection Efficiency Percent' ;
    rdfs:comment 'Estimated percentage of generated landfill gas that is captured by the collection system. Typical range is 75-95% for well-designed active systems.' ;
    rdfs:domain ind:LfgCollectionSystem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:designEngineer rdf:type rdf:Property ;
    rdfs:label 'Design Engineer' ;
    rdfs:comment 'Name of the engineering firm or professional engineer responsible for the system design and specifications.' ;
    rdfs:domain ind:LfgCollectionSystem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designFlowCapacityScfm rdf:type rdf:Property ;
    rdfs:label 'Design Flow Capacity Scfm' ;
    rdfs:comment 'Maximum design flow capacity of the LFG collection system measured in standard cubic feet per minute (scfm). Represents the engineered extraction capacity.' ;
    rdfs:domain ind:LfgCollectionSystem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedMethaneGenerationRateScfm rdf:type rdf:Property ;
    rdfs:label 'Estimated Methane Generation Rate Scfm' ;
    rdfs:comment 'Estimated methane generation rate from the waste mass in the collection area, measured in standard cubic feet per minute. Based on EPA LandGEM or similar modeling.' ;
    rdfs:domain ind:LfgCollectionSystem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:flareStationCount rdf:type rdf:Property ;
    rdfs:label 'Flare Station Count' ;
    rdfs:comment 'Number of flare stations used to combust collected LFG when beneficial use is not available or during maintenance periods.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:headerPipeDiameterInches rdf:type rdf:Property ;
    rdfs:label 'Header Pipe Diameter Inches' ;
    rdfs:comment 'Primary diameter of the header piping system in inches. Larger diameters support higher flow capacity.' ;
    rdfs:domain ind:LfgCollectionSystem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:headerPipeLengthFeet rdf:type rdf:Property ;
    rdfs:label 'Header Pipe Length Feet' ;
    rdfs:comment 'Total length of header piping in feet that conveys collected gas from extraction wells to the blower or flare station.' ;
    rdfs:domain ind:LfgCollectionSystem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:horizontalWellCount rdf:type rdf:Property ;
    rdfs:label 'Horizontal Well Count' ;
    rdfs:comment 'Number of horizontal extraction wells in the collection system. Horizontal wells are typically installed during active filling operations.' ;
    rdfs:domain ind:LfgCollectionSystem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:monitoringFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Monitoring Frequency Days' ;
    rdfs:comment 'Required frequency in days for routine monitoring of the LFG collection system per regulatory requirements. Typically quarterly (90 days) or monthly (30 days).' ;
    rdfs:domain ind:LfgCollectionSystem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:systemCode rdf:type rdf:Property ;
    rdfs:label 'System Code' ;
    rdfs:comment 'Business identifier for the LFG collection system. Used in operational reporting and regulatory filings.' ;
    rdfs:domain ind:LfgCollectionSystem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:systemManufacturer rdf:type rdf:Property ;
    rdfs:label 'System Manufacturer' ;
    rdfs:comment 'Name of the manufacturer or primary contractor that designed and installed the LFG collection system.' ;
    rdfs:domain ind:LfgCollectionSystem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:systemName rdf:type rdf:Property ;
    rdfs:label 'System Name' ;
    rdfs:comment 'Descriptive name of the landfill gas collection system for operational identification and reporting purposes.' ;
    rdfs:domain ind:LfgCollectionSystem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:systemType rdf:type rdf:Property ;
    rdfs:label 'System Type' ;
    rdfs:comment 'Classification of the gas collection system based on extraction method: active extraction (blower-driven), passive venting (natural pressure), or hybrid (combination).' ;
    rdfs:domain ind:LfgCollectionSystem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalExtractionWellCount rdf:type rdf:Property ;
    rdfs:label 'Total Extraction Well Count' ;
    rdfs:comment 'Total number of vertical and horizontal extraction wells installed in the LFG collection system. Used for system capacity and coverage analysis.' ;
    rdfs:domain ind:LfgCollectionSystem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:verticalWellCount rdf:type rdf:Property ;
    rdfs:label 'Vertical Well Count' ;
    rdfs:comment 'Number of vertical extraction wells in the collection system. Vertical wells are typically installed in closed or capped landfill areas.' ;
    rdfs:domain ind:LfgCollectionSystem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wasteInPlaceTons rdf:type rdf:Property ;
    rdfs:label 'Waste In Place Tons' ;
    rdfs:comment 'Estimated total tons of municipal solid waste in place within the collection system coverage area. Used for gas generation potential modeling.' ;
    rdfs:domain ind:LfgCollectionSystem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lfgFlowReadingId rdf:type rdf:Property ;
    rdfs:label 'Lfg Flow Reading Id' ;
    rdfs:comment 'Unique identifier for the landfill gas flow reading record.' ;
    rdfs:domain ind:LfgFlowReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:instrumentId rdf:type rdf:Property ;
    rdfs:label 'Instrument Id' ;
    rdfs:comment 'Identifier of the monitoring instrument or sensor device used to capture this reading.' ;
    rdfs:domain ind:LfgFlowReading ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CemsInstrument .

ind:lfgCaptureId rdf:type rdf:Property ;
    rdfs:label 'Lfg Capture Id' ;
    rdfs:comment 'Foreign key linking to sustainability.lfg_capture. Business justification: Flow readings are source data for calculating LFG capture volumes and methane avoidance in sustainability reporting. Links operational measurements to aggregated capture records required for carbon cr' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LfgCapture .

ind:lfgExtractionWellId rdf:type rdf:Property ;
    rdfs:label 'Lfg Extraction Well Id' ;
    rdfs:comment 'Identifier of the LFG extraction well from which this reading was taken. Part of the Gas Collection and Control System (GCCS).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LfgExtractionWell .

ind:siteId rdf:type rdf:Property ;
    rdfs:label 'Site Id' ;
    rdfs:comment 'Identifier of the landfill facility where this LFG reading was captured.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Site .

ind:alarmTriggeredFlag rdf:type rdf:Property ;
    rdfs:label 'Alarm Triggered Flag' ;
    rdfs:comment 'Boolean indicator whether this reading triggered an alarm condition (e.g., high LEL, low methane concentration, high O2 intrusion).' ;
    rdfs:domain ind:LfgFlowReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:balanceGasPct rdf:type rdf:Property ;
    rdfs:label 'Balance Gas Pct' ;
    rdfs:comment 'Percentage of other gases (nitrogen, trace compounds) calculated as the remainder after accounting for CH4, CO2, and O2. Typically calculated as 100 - (CH4 + CO2 + O2).' ;
    rdfs:domain ind:LfgFlowReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:co2ConcentrationPct rdf:type rdf:Property ;
    rdfs:label 'Co2 Concentration Pct' ;
    rdfs:comment 'Percentage concentration of carbon dioxide (CO2) in the landfill gas sample.' ;
    rdfs:domain ind:LfgFlowReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:flowRateScfm rdf:type rdf:Property ;
    rdfs:label 'Flow Rate Scfm' ;
    rdfs:comment 'Volumetric flow rate of landfill gas measured in standard cubic feet per minute (SCFM) at the extraction point.' ;
    rdfs:domain ind:LfgFlowReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:headerPipeCode rdf:type rdf:Property ;
    rdfs:label 'Header Pipe Code' ;
    rdfs:comment 'Identifier of the header pipe segment from which this reading was taken, if applicable. Header pipes collect gas from multiple wells.' ;
    rdfs:domain ind:LfgFlowReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hydrogenSulfidePpm rdf:type rdf:Property ;
    rdfs:label 'Hydrogen Sulfide Ppm' ;
    rdfs:comment 'Concentration of hydrogen sulfide (H2S) in parts per million. Corrosive gas that impacts equipment and requires monitoring for safety and operational reasons.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lelReadingPct rdf:type rdf:Property ;
    rdfs:label 'Lel Reading Pct' ;
    rdfs:comment 'Lower Explosive Limit reading as a percentage of the LEL threshold. Safety metric indicating combustion risk. Values above 25% LEL trigger safety protocols.' ;
    rdfs:domain ind:LfgFlowReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:methaneConcentrationPct rdf:type rdf:Property ;
    rdfs:label 'Methane Concentration Pct' ;
    rdfs:comment 'Percentage concentration of methane (CH4) in the landfill gas sample. Critical for energy yield calculations and compliance monitoring.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oxygenConcentrationPct rdf:type rdf:Property ;
    rdfs:label 'Oxygen Concentration Pct' ;
    rdfs:comment 'Percentage concentration of oxygen (O2) in the landfill gas sample. Elevated O2 indicates air intrusion and potential combustion risk.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:readingStatus rdf:type rdf:Property ;
    rdfs:label 'Reading Status' ;
    rdfs:comment 'Quality status of the reading: valid for use, invalid due to instrument error, flagged for review, under investigation, calibration required, or instrument fault detected.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:readingType rdf:type rdf:Property ;
    rdfs:label 'Reading Type' ;
    rdfs:comment 'Classification of the reading event: scheduled routine monitoring, spot check, alarm-triggered investigation, compliance reporting, or calibration verification.' ;
    rdfs:domain ind:LfgFlowReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:staticPressureInchesH2o rdf:type rdf:Property ;
    rdfs:label 'Static Pressure Inches H2o' ;
    rdfs:comment 'Static pressure measurement at the extraction point in inches of water column (H2O). Indicates vacuum applied by the GCCS blower.' ;
    rdfs:domain ind:LfgFlowReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureFahrenheit rdf:type rdf:Property ;
    rdfs:label 'Temperature Fahrenheit' ;
    rdfs:comment 'Temperature of the landfill gas at the measurement point in degrees Fahrenheit.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourcingContractId rdf:type rdf:Property ;
    rdfs:label 'Sourcing Contract Id' ;
    rdfs:comment 'Foreign key linking to procurement.sourcing_contract. Business justification: Offtake agreements are long-term energy sales contracts requiring contract lifecycle management, pricing schedule tracking, renewal management, and counterparty vendor management when offtaker is also' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SourcingContract .

ind:agreementType rdf:type rdf:Property ;
    rdfs:label 'Agreement Type' ;
    rdfs:comment 'Classification of the offtake agreement: Power Purchase Agreement (PPA) for electricity, steam sales for industrial heat, Renewable Natural Gas (RNG) sales, Renewable Energy Credit (REC) sales, capacity agreement, or hybrid multi-product agreement.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractEndDate rdf:type rdf:Property ;
    rdfs:label 'Contract End Date' ;
    rdfs:comment 'Scheduled expiration date of the offtake agreement. Null for evergreen or indefinite-term agreements.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractStartDate rdf:type rdf:Property ;
    rdfs:label 'Contract Start Date' ;
    rdfs:comment 'Effective start date when the offtake agreement becomes binding and energy deliveries may commence.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractTermYears rdf:type rdf:Property ;
    rdfs:label 'Contract Term Years' ;
    rdfs:comment 'Duration of the agreement in years, calculated from contract start date to end date. Null for indefinite-term agreements.' ;
    rdfs:domain ind:OfftakeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractedVolumeAnnual rdf:type rdf:Property ;
    rdfs:label 'Contracted Volume Annual' ;
    rdfs:comment 'Annual contracted volume of energy to be delivered under this agreement, measured in the unit specified by contracted_volume_unit.' ;
    rdfs:domain ind:OfftakeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractedVolumeUnit rdf:type rdf:Property ;
    rdfs:label 'Contracted Volume Unit' ;
    rdfs:comment 'Unit of measure for contracted energy volume: MWh (megawatt-hours) for electricity, klb (thousand pounds) or MMBtu (million British thermal units) for steam, MMBtu for RNG, REC for renewable energy credits, MW for capacity.' ;
    rdfs:domain ind:OfftakeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:curtailmentProvisions rdf:type rdf:Property ;
    rdfs:label 'Curtailment Provisions' ;
    rdfs:comment 'Description of conditions under which the offtaker may curtail or reduce energy deliveries, including notice requirements and compensation terms.' ;
    rdfs:domain ind:OfftakeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryObligationType rdf:type rdf:Property ;
    rdfs:label 'Delivery Obligation Type' ;
    rdfs:comment 'Nature of the delivery commitment: firm (guaranteed delivery), as-available (best-effort), interruptible (subject to curtailment), or must-take (buyer obligated to accept all output).' ;
    rdfs:domain ind:OfftakeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalAttributesIncluded rdf:type rdf:Property ;
    rdfs:label 'Environmental Attributes Included' ;
    rdfs:comment 'Indicates whether the agreement includes transfer of environmental attributes such as carbon offsets, emission reduction credits, or sustainability certifications (True) or not (False).' ;
    rdfs:domain ind:OfftakeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interconnectionPoint rdf:type rdf:Property ;
    rdfs:label 'Interconnection Point' ;
    rdfs:comment 'Physical or logical point where energy is delivered to the offtaker, such as substation name, grid node, or pipeline interconnect identifier.' ;
    rdfs:domain ind:Energy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumDeliveryLimitPercent rdf:type rdf:Property ;
    rdfs:label 'Maximum Delivery Limit Percent' ;
    rdfs:comment 'Maximum percentage of contracted annual volume that the buyer is obligated to accept, above which the seller may sell excess energy to third parties.' ;
    rdfs:domain ind:OfftakeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumDeliveryCommitmentPercent rdf:type rdf:Property ;
    rdfs:label 'Minimum Delivery Commitment Percent' ;
    rdfs:comment 'Minimum percentage of contracted annual volume that the seller is obligated to deliver, below which penalties or liquidated damages may apply.' ;
    rdfs:domain ind:OfftakeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceGuaranteeRequired rdf:type rdf:Property ;
    rdfs:label 'Performance Guarantee Required' ;
    rdfs:comment 'Indicates whether the seller is required to provide a performance bond, letter of credit, or other financial guarantee to secure delivery obligations (True) or not (False).' ;
    rdfs:domain ind:OfftakeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recOwnershipClause rdf:type rdf:Property ;
    rdfs:label 'Rec Ownership Clause' ;
    rdfs:comment 'Specifies which party retains ownership of Renewable Energy Credits (RECs) generated by the facility: seller retains, buyer receives, shared arrangement, or negotiated per delivery.' ;
    rdfs:domain ind:OfftakeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryApprovalRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Required' ;
    rdfs:comment 'Indicates whether the agreement requires approval from a public utility commission, energy regulatory authority, or other governing body (True) or not (False).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Status' ;
    rdfs:comment 'Current status of regulatory approval process for this agreement, if applicable.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewableAttributeTransfer rdf:type rdf:Property ;
    rdfs:label 'Renewable Attribute Transfer' ;
    rdfs:comment 'Indicates whether renewable energy attributes (RECs, carbon credits, green tags) are transferred to the buyer (True) or retained by the seller (False).' ;
    rdfs:domain ind:OfftakeAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalOption rdf:type rdf:Property ;
    rdfs:label 'Renewal Option' ;
    rdfs:comment 'Specifies whether and how the agreement may be renewed upon expiration: automatic renewal, mutual consent required, buyer option, seller option, or no renewal provision.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedOutageId rdf:type rdf:Property ;
    rdfs:label 'Planned Outage Id' ;
    rdfs:comment 'Unique identifier for the planned maintenance outage record. Primary key for the planned outage entity.' ;
    rdfs:domain ind:PlannedOutage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:outagePurchaseOrderId rdf:type rdf:Property ;
    rdfs:label 'Outage Purchase Order Id' ;
    rdfs:comment 'Foreign key linking to procurement.purchase_order. Business justification: Major outages involve significant parts/services procurement; direct PO link enables outage cost tracking, vendor performance correlation with downtime duration, capital project budget reconciliation,' ;
    rdfs:domain ind:PlannedOutage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseOrder .

ind:actualCostUsd rdf:type rdf:Property ;
    rdfs:label 'Actual Cost Usd' ;
    rdfs:comment 'Actual total cost incurred for the planned outage in United States Dollars (USD), captured after outage completion. Used for variance analysis and future cost estimation improvement.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualDurationHours rdf:type rdf:Property ;
    rdfs:label 'Actual Duration Hours' ;
    rdfs:comment 'Actual duration of the outage in hours, calculated from actual start and end dates. Used to measure schedule adherence and improve future planning accuracy.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualEndDate rdf:type rdf:Property ;
    rdfs:label 'Actual End Date' ;
    rdfs:comment 'Actual date when the planned outage work was completed and the asset was returned to service. Used to calculate actual outage duration and variance from plan.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualLostGenerationMwh rdf:type rdf:Property ;
    rdfs:label 'Actual Lost Generation Mwh' ;
    rdfs:comment 'Actual energy generation lost during the outage period in megawatt-hours (MWh), calculated from actual outage duration and asset capacity.' ;
    rdfs:domain ind:PlannedOutage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:completionNotes rdf:type rdf:Property ;
    rdfs:label 'Completion Notes' ;
    rdfs:comment 'Summary notes documenting the outcome of the planned outage after completion, including work performed, issues encountered, deviations from plan, and recommendations for future outages.' ;
    rdfs:domain ind:PlannedOutage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalPathFlag rdf:type rdf:Property ;
    rdfs:label 'Critical Path Flag' ;
    rdfs:comment 'Indicates whether this planned outage is on the critical path for facility operations, meaning any delay would directly impact the facility\'s ability to meet generation commitments or regulatory deadlines. True if critical path, False otherwise.' ;
    rdfs:domain ind:PlannedOutage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:environmentalImpactAssessmentFlag rdf:type rdf:Property ;
    rdfs:label 'Environmental Impact Assessment Flag' ;
    rdfs:comment 'Indicates whether an environmental impact assessment was conducted for the planned outage to evaluate potential emissions, waste generation, or environmental risks during maintenance activities. True if assessment performed, False otherwise.' ;
    rdfs:domain ind:PlannedOutage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedCostUsd rdf:type rdf:Property ;
    rdfs:label 'Estimated Cost Usd' ;
    rdfs:comment 'Estimated total cost of the planned outage in United States Dollars (USD), including labor, materials, contractor fees, and lost revenue from generation downtime. Used for budget planning and cost-benefit analysis.' ;
    rdfs:domain ind:PlannedOutage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedLostGenerationMwh rdf:type rdf:Property ;
    rdfs:label 'Estimated Lost Generation Mwh' ;
    rdfs:comment 'Estimated energy generation lost during the planned outage period in megawatt-hours (MWh). Used for revenue impact analysis and utility settlement planning.' ;
    rdfs:domain ind:PlannedOutage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outageNumber rdf:type rdf:Property ;
    rdfs:label 'Outage Number' ;
    rdfs:comment 'Business-assigned unique identifier or reference number for the planned outage, used for tracking and communication with utility operators and internal stakeholders.' ;
    rdfs:domain ind:PlannedOutage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outageReasonCode rdf:type rdf:Property ;
    rdfs:label 'Outage Reason Code' ;
    rdfs:comment 'Standardized code indicating the primary reason for the planned outage (e.g., boiler tube inspection, turbine blade replacement, emissions testing, regulatory compliance). Aligns with NERC GADS cause codes where applicable.' ;
    rdfs:domain ind:PlannedOutage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outageReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Outage Reason Description' ;
    rdfs:comment 'Detailed narrative description of the reason for the planned outage, including specific maintenance activities, inspections, or regulatory requirements driving the outage.' ;
    rdfs:domain ind:PlannedOutage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outageStatus rdf:type rdf:Property ;
    rdfs:label 'Outage Status' ;
    rdfs:comment 'Current lifecycle status of the planned outage: planned (initial state), scheduled (confirmed with utility), in progress (work underway), completed (work finished and asset returned to service), cancelled, or postponed.' ;
    rdfs:domain ind:PlannedOutage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outageType rdf:type rdf:Property ;
    rdfs:label 'Outage Type' ;
    rdfs:comment 'Classification of the planned outage based on its purpose: annual overhaul (major maintenance), scheduled inspection, regulatory test (compliance-driven), preventive maintenance (PM), component replacement, or performance optimization.' ;
    rdfs:domain ind:PlannedOutage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedDurationHours rdf:type rdf:Property ;
    rdfs:label 'Planned Duration Hours' ;
    rdfs:comment 'Estimated duration of the planned outage in hours, calculated from planned start and end dates. Used for resource planning and generation availability forecasting.' ;
    rdfs:domain ind:PlannedOutage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedEndDate rdf:type rdf:Property ;
    rdfs:label 'Planned End Date' ;
    rdfs:comment 'Scheduled date when the planned outage is expected to be completed and the asset returned to operational service.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:postponementReason rdf:type rdf:Property ;
    rdfs:label 'Postponement Reason' ;
    rdfs:comment 'Explanation for why the planned outage was postponed or rescheduled, if applicable (e.g., weather conditions, parts unavailability, utility request, operational priority change).' ;
    rdfs:domain ind:PlannedOutage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyPlanRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Plan Required Flag' ;
    rdfs:comment 'Indicates whether a formal safety plan is required for the planned outage due to hazardous work conditions (e.g., confined space entry, hot work, high voltage). True if safety plan required, False otherwise.' ;
    rdfs:domain ind:PlannedOutage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scopeOfWork rdf:type rdf:Property ;
    rdfs:label 'Scope Of Work' ;
    rdfs:comment 'Detailed description of the maintenance activities, inspections, tests, and component replacements to be performed during the planned outage. Defines the work scope for planning and execution.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utilityApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Utility Approval Date' ;
    rdfs:comment 'Date when the utility operator or ISO formally approved the planned outage schedule.' ;
    rdfs:domain ind:PlannedOutage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:utilityApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Utility Approval Status' ;
    rdfs:comment 'Status of utility or ISO approval for the planned outage: pending (awaiting response), approved (outage confirmed), conditional (approved with restrictions), or denied (outage must be rescheduled).' ;
    rdfs:domain ind:PlannedOutage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utilityNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Utility Notification Date' ;
    rdfs:comment 'Date when the utility operator or Independent System Operator (ISO) was formally notified of the planned outage, as required by interconnection agreements and grid reliability standards.' ;
    rdfs:domain ind:PlannedOutage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reagentConsumptionId rdf:type rdf:Property ;
    rdfs:label 'Reagent Consumption Id' ;
    rdfs:comment 'Unique identifier for the reagent consumption transaction record.' ;
    rdfs:domain ind:ReagentConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reagentPurchaseOrderId rdf:type rdf:Property ;
    rdfs:label 'Reagent Purchase Order Id' ;
    rdfs:comment 'Foreign key linking to procurement.purchase_order. Business justification: Reagent purchases are high-volume recurring procurement; direct PO link enables consumption-to-invoice three-way match, unit cost variance analysis, supplier performance tracking by consumption effici' ;
    rdfs:domain ind:ReagentConsumption ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseOrder .

ind:boilerOperatingHours rdf:type rdf:Property ;
    rdfs:label 'Boiler Operating Hours' ;
    rdfs:comment 'The number of hours the associated boiler unit operated during the consumption period, used to normalize reagent usage rates.' ;
    rdfs:domain ind:ReagentConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consumptionDate rdf:type rdf:Property ;
    rdfs:label 'Consumption Date' ;
    rdfs:comment 'The date on which the reagent was consumed in the APC system.' ;
    rdfs:domain ind:ReagentConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consumptionMethod rdf:type rdf:Property ;
    rdfs:label 'Consumption Method' ;
    rdfs:comment 'The method by which the reagent was introduced into the APC system (e.g., automatic injection, manual feed, batch addition).' ;
    rdfs:domain ind:ReagentConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consumptionRatePerTonMsw rdf:type rdf:Property ;
    rdfs:label 'Consumption Rate Per Ton Msw' ;
    rdfs:comment 'The reagent consumption rate normalized per ton of MSW processed, a key performance indicator for APC efficiency.' ;
    rdfs:domain ind:ReagentConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consumptionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Consumption Timestamp' ;
    rdfs:comment 'The precise timestamp when the reagent consumption was recorded, supporting real-time monitoring and compliance reporting.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:emissionsComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Emissions Compliance Flag' ;
    rdfs:comment 'Indicates whether the reagent consumption achieved the required emissions compliance targets during the period (True = compliant, False = non-compliant).' ;
    rdfs:domain ind:ReagentConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hclEmissionsLbs rdf:type rdf:Property ;
    rdfs:label 'Hcl Emissions Lbs' ;
    rdfs:comment 'The pounds of hydrochloric acid emitted during the consumption period, tracked to assess reagent effectiveness in acid gas removal.' ;
    rdfs:domain ind:ReagentConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inventoryTransactionNumber rdf:type rdf:Property ;
    rdfs:label 'Inventory Transaction Number' ;
    rdfs:comment 'The identifier of the inventory transaction in the ERP system that recorded the reagent withdrawal from stock.' ;
    rdfs:domain ind:ReagentConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mercuryEmissionsLbs rdf:type rdf:Property ;
    rdfs:label 'Mercury Emissions Lbs' ;
    rdfs:comment 'The pounds of mercury emitted during the consumption period, tracked to assess activated carbon effectiveness in heavy metal capture.' ;
    rdfs:domain ind:ReagentConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityConsumed rdf:type rdf:Property ;
    rdfs:label 'Quantity Consumed' ;
    rdfs:comment 'The quantity of reagent consumed during the specified period.' ;
    rdfs:domain ind:ReagentConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reagentLotNumber rdf:type rdf:Property ;
    rdfs:label 'Reagent Lot Number' ;
    rdfs:comment 'The lot or batch number of the reagent consumed, enabling traceability to supplier shipment and quality specifications.' ;
    rdfs:domain ind:ReagentConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reagentName rdf:type rdf:Property ;
    rdfs:label 'Reagent Name' ;
    rdfs:comment 'The commercial or chemical name of the reagent consumed.' ;
    rdfs:domain ind:ReagentConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCostUsd rdf:type rdf:Property ;
    rdfs:label 'Total Cost Usd' ;
    rdfs:comment 'The total cost of the reagent consumed in this transaction, calculated as quantity consumed multiplied by unit cost, expressed in US dollars.' ;
    rdfs:domain ind:ReagentConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recIssuanceId rdf:type rdf:Property ;
    rdfs:label 'Rec Issuance Id' ;
    rdfs:comment 'Unique identifier for the REC issuance transaction. Primary key for the rec_issuance product.' ;
    rdfs:domain ind:Energy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RecIssuance .

ind:primaryRecFacilityId rdf:type rdf:Property ;
    rdfs:label 'Primary Rec Facility Id' ;
    rdfs:comment 'Identifier of the Waste-to-Energy (WTE) or Landfill Gas-to-Energy (LFG) facility that generated the renewable energy qualifying for REC issuance.' ;
    rdfs:domain ind:RecIssuance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:renewableEnergyCreditId rdf:type rdf:Property ;
    rdfs:label 'Renewable Energy Credit Id' ;
    rdfs:comment 'Foreign key linking to sustainability.renewable_energy_credit. Business justification: REC issuances in energy domain are source records for renewable_energy_credit tracking in sustainability ESG reporting. Links generation certificates to corporate sustainability accounting for Scope 2' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RenewableEnergyCredit .

ind:certificateSerialNumberEnd rdf:type rdf:Property ;
    rdfs:label 'Certificate Serial Number End' ;
    rdfs:comment 'Ending serial number in the range of REC certificates issued in this batch. Defines the upper bound of the certificate range.' ;
    rdfs:domain ind:RecIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateSerialNumberStart rdf:type rdf:Property ;
    rdfs:label 'Certificate Serial Number Start' ;
    rdfs:comment 'Starting serial number in the range of REC certificates issued in this batch. Unique identifier assigned by the REC registry.' ;
    rdfs:domain ind:RecIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibilityState rdf:type rdf:Property ;
    rdfs:label 'Eligibility State' ;
    rdfs:comment 'Comma-separated list of US state postal codes where these RECs are eligible for RPS compliance. Example: MA,CT,RI for New England states.' ;
    rdfs:domain ind:Energy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emissionsAvoidedCo2eTons rdf:type rdf:Property ;
    rdfs:label 'Emissions Avoided Co2e Tons' ;
    rdfs:comment 'Estimated tons of CO2 equivalent greenhouse gas emissions avoided by generating renewable energy instead of fossil fuel energy. Used for sustainability reporting.' ;
    rdfs:domain ind:Energy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:energyQuantityMwh rdf:type rdf:Property ;
    rdfs:label 'Energy Quantity Mwh' ;
    rdfs:comment 'Total quantity of renewable energy generated during the period, measured in megawatt-hours. One REC is typically issued per MWh of qualifying renewable energy.' ;
    rdfs:domain ind:RecIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:generationPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Generation Period End Date' ;
    rdfs:comment 'End date of the energy generation period for which RECs are being issued. Defines the close of the generation measurement window.' ;
    rdfs:domain ind:Energy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:generationPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Generation Period Start Date' ;
    rdfs:comment 'Start date of the energy generation period for which RECs are being issued. Typically aligns with monthly or quarterly reporting periods.' ;
    rdfs:domain ind:Energy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:issuanceDate rdf:type rdf:Property ;
    rdfs:label 'Issuance Date' ;
    rdfs:comment 'Date on which the REC certificates were officially issued by the registry. Typically occurs 30-60 days after the generation period ends to allow for verification.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nameplateCapacityMw rdf:type rdf:Property ;
    rdfs:label 'Nameplate Capacity Mw' ;
    rdfs:comment 'Maximum rated electrical generation capacity of the facility in megawatts. Used to calculate capacity factors and performance metrics.' ;
    rdfs:domain ind:RecIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:registryAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Registry Account Number' ;
    rdfs:comment 'Waste Management\'s account identifier within the REC registry system. Used to track ownership and transfers of RECs.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registryName rdf:type rdf:Property ;
    rdfs:label 'Registry Name' ;
    rdfs:comment 'Name of the regional or national REC tracking registry where the certificates are registered. NEPOOL GIS = New England, M-RETS = Midwest, WREGIS = Western, PJM-GATS = Mid-Atlantic.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradingRestrictionFlag rdf:type rdf:Property ;
    rdfs:label 'Trading Restriction Flag' ;
    rdfs:comment 'Indicates whether these RECs have trading restrictions imposed by the registry or regulatory authority. True = restricted, False = freely tradeable.' ;
    rdfs:domain ind:Energy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tradingRestrictionReason rdf:type rdf:Property ;
    rdfs:label 'Trading Restriction Reason' ;
    rdfs:comment 'Explanation of why trading restrictions are in place, if applicable. Examples: pending verification, compliance hold, legal dispute.' ;
    rdfs:domain ind:Energy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recTransactionId rdf:type rdf:Property ;
    rdfs:label 'Rec Transaction Id' ;
    rdfs:comment 'Unique identifier for the REC transaction record. Primary key for the rec_transaction data product.' ;
    rdfs:domain ind:RecTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:brokerFeeUsd rdf:type rdf:Property ;
    rdfs:label 'Broker Fee Usd' ;
    rdfs:comment 'The fee paid to a broker or intermediary for facilitating the REC transaction, in United States Dollars. Zero if transaction was direct without broker involvement.' ;
    rdfs:domain ind:RecTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:counterpartyAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Counterparty Account Number' ;
    rdfs:comment 'The registry account number or identifier of the counterparty receiving or purchasing the RECs. Used for registry transfer verification and audit trail.' ;
    rdfs:domain ind:RecTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recQuantityMwh rdf:type rdf:Property ;
    rdfs:label 'Rec Quantity Mwh' ;
    rdfs:comment 'The quantity of RECs transacted, measured in megawatt-hours (MWh). One REC typically represents one MWh of renewable electricity generation. This is the primary unit of measure for REC transactions.' ;
    rdfs:domain ind:RecTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:registryTransactionNumber rdf:type rdf:Property ;
    rdfs:label 'Registry Transaction Number' ;
    rdfs:comment 'The unique transaction identifier assigned by the REC tracking registry system (e.g., M-RETS, NAR, NEPOOL GIS, WREGIS) that recorded this transaction. Used for external audit and verification.' ;
    rdfs:domain ind:RecTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rpsCompliancePeriod rdf:type rdf:Property ;
    rdfs:label 'Rps Compliance Period' ;
    rdfs:comment 'The state RPS compliance period (typically a calendar year or program year) for which these RECs may be applied. Format varies by state program (e.g., 2024, 2023-2024, Q4-2023).' ;
    rdfs:domain ind:RecTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementStatus rdf:type rdf:Property ;
    rdfs:label 'Settlement Status' ;
    rdfs:comment 'Current status of the financial and registry settlement for this transaction. Pending = awaiting completion; Settled = payment and registry transfer complete; Failed = settlement did not complete; Disputed = under review or contested; Reversed = transaction was reversed or unwound.' ;
    rdfs:domain ind:RecTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalTransactionValueUsd rdf:type rdf:Property ;
    rdfs:label 'Total Transaction Value Usd' ;
    rdfs:comment 'The total monetary value of the REC transaction in United States Dollars, calculated as rec_quantity_mwh multiplied by unit_price_usd. Represents gross revenue for sales or gross cost for purchases before any fees or adjustments.' ;
    rdfs:domain ind:RecTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionNumber rdf:type rdf:Property ;
    rdfs:label 'Transaction Number' ;
    rdfs:comment 'Business-facing unique transaction number assigned by Waste Management for tracking and reconciliation purposes. Used in financial reporting and customer communications.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rinGenerationId rdf:type rdf:Property ;
    rdfs:label 'Rin Generation Id' ;
    rdfs:comment 'Unique identifier for the RIN generation event. Primary key for the RIN generation transaction.' ;
    rdfs:domain ind:RinGeneration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:btuContentPerScf rdf:type rdf:Property ;
    rdfs:label 'Btu Content Per Scf' ;
    rdfs:comment 'Energy content of the RNG measured in BTU per standard cubic foot. Pipeline-quality natural gas typically ranges from 950-1,050 BTU/scf. Used to calculate total energy delivered.' ;
    rdfs:domain ind:RinGeneration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:co2RemovedTons rdf:type rdf:Property ;
    rdfs:label 'Co2 Removed Tons' ;
    rdfs:comment 'Mass of carbon dioxide removed from the raw biogas during the upgrading process to achieve pipeline quality, measured in tons. CO2 is typically vented or used for other purposes.' ;
    rdfs:domain ind:RinGeneration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dCode rdf:type rdf:Property ;
    rdfs:label 'D Code' ;
    rdfs:comment 'EPA Renewable Fuel Standard D-code classification. D3 represents cellulosic biofuel (landfill gas, MSW biogas), D5 represents advanced biofuel. Determines RIN value and compliance applicability.' ;
    rdfs:domain ind:RinGeneration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emtsSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Emts Submission Date' ;
    rdfs:comment 'Date when the RIN generation event was submitted to the EPA EMTS system for official registration and compliance tracking.' ;
    rdfs:domain ind:RinGeneration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:emtsTransactionNumber rdf:type rdf:Property ;
    rdfs:label 'Emts Transaction Number' ;
    rdfs:comment 'Unique transaction identifier assigned by the EPA EMTS system when the RIN generation event is registered. EMTS is the official EPA system for tracking RIN generation, transfer, and retirement.' ;
    rdfs:domain ind:RinGeneration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epaCompanyRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Epa Company Registration Number' ;
    rdfs:comment 'EPA-issued registration number for the company generating RINs under the Renewable Fuel Standard program. Required for all RIN generation and trading activities.' ;
    rdfs:domain ind:RinGeneration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epaFacilityRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Epa Facility Registration Number' ;
    rdfs:comment 'EPA-issued registration number for the specific facility producing renewable fuel. Each RNG production facility must be registered with EPA to generate valid RINs.' ;
    rdfs:domain ind:RinGeneration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equivalenceValue rdf:type rdf:Property ;
    rdfs:label 'Equivalence Value' ;
    rdfs:comment 'EPA-assigned equivalence value for the fuel pathway, used to adjust RIN generation based on the fuels energy content relative to ethanol. Compressed natural gas (CNG) and liquefied natural gas (LNG) have pathway-specific EVs.' ;
    rdfs:domain ind:RinGeneration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:generationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Generation Timestamp' ;
    rdfs:comment 'Precise timestamp when the RNG injection and RIN generation event occurred, used for detailed operational tracking and audit trails.' ;
    rdfs:domain ind:RinGeneration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ghgReductionPercent rdf:type rdf:Property ;
    rdfs:label 'Ghg Reduction Percent' ;
    rdfs:comment 'Lifecycle greenhouse gas emissions reduction percentage compared to baseline petroleum fuel, as determined by the EPA-approved fuel pathway. Cellulosic biofuels (D3) typically achieve 60%+ reduction.' ;
    rdfs:domain ind:RinGeneration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lcfsCreditEligible rdf:type rdf:Property ;
    rdfs:label 'Lcfs Credit Eligible' ;
    rdfs:comment 'Indicates whether this RNG is eligible for California Low Carbon Fuel Standard (LCFS) credits or similar state-level low-carbon fuel programs. RNG from landfills typically qualifies for LCFS credits.' ;
    rdfs:domain ind:Energy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketValuePerRin rdf:type rdf:Property ;
    rdfs:label 'Market Value Per Rin' ;
    rdfs:comment 'Market trading price per RIN at the time of generation, expressed in US dollars. D3 cellulosic RINs typically command premium prices due to scarcity and higher compliance value.' ;
    rdfs:domain ind:RinGeneration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Modified By User' ;
    rdfs:comment 'Username or identifier of the system user who last modified this RIN generation record. Used for accountability and audit purposes.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pathwayCode rdf:type rdf:Property ;
    rdfs:label 'Pathway Code' ;
    rdfs:comment 'EPA-approved fuel pathway code identifying the specific production process and feedstock combination used to produce the RNG. Each pathway has a unique lifecycle greenhouse gas emissions profile.' ;
    rdfs:domain ind:RinGeneration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pipelineInjectionPoint rdf:type rdf:Property ;
    rdfs:label 'Pipeline Injection Point' ;
    rdfs:comment 'Specific location or meter station where the RNG was injected into the natural gas pipeline system. Critical for custody transfer and RIN generation documentation.' ;
    rdfs:domain ind:RinGeneration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pipelineOperator rdf:type rdf:Property ;
    rdfs:label 'Pipeline Operator' ;
    rdfs:comment 'Name of the natural gas pipeline company or operator that received the RNG injection. Required for RFS2 chain of custody documentation.' ;
    rdfs:domain ind:RinGeneration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qaQcPassed rdf:type rdf:Property ;
    rdfs:label 'Qa Qc Passed' ;
    rdfs:comment 'Indicates whether the RIN generation event passed all internal quality assurance and quality control checks, including gas quality testing, metering verification, and documentation completeness.' ;
    rdfs:domain ind:RinGeneration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rawLfgVolumeScfm rdf:type rdf:Property ;
    rdfs:label 'Raw Lfg Volume Scfm' ;
    rdfs:comment 'Volume of raw landfill gas collected and fed into the RNG upgrading system, measured in standard cubic feet per minute. Used for mass balance and efficiency calculations.' ;
    rdfs:domain ind:RinGeneration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rinQuantity rdf:type rdf:Property ;
    rdfs:label 'Rin Quantity' ;
    rdfs:comment 'Total number of RINs generated from this RNG injection event. Each gallon equivalent of renewable fuel generates one RIN under RFS2.' ;
    rdfs:domain ind:RinGeneration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rinStatus rdf:type rdf:Property ;
    rdfs:label 'Rin Status' ;
    rdfs:comment 'Current lifecycle status of the RIN. Generated = newly created; Assigned = attached to fuel batch; Separated = detached for trading; Retired = used for compliance; Invalidated = voided due to error or fraud.' ;
    rdfs:domain ind:RinGeneration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rinYear rdf:type rdf:Property ;
    rdfs:label 'Rin Year' ;
    rdfs:comment 'Calendar year in which the RIN was generated. RINs are vintage-dated and can only be used for compliance in the year generated or the following year.' ;
    rdfs:domain ind:RinGeneration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rngVolumeGge rdf:type rdf:Property ;
    rdfs:label 'Rng Volume Gge' ;
    rdfs:comment 'Volume of renewable natural gas expressed in gasoline gallon equivalents (GGE), used for RIN quantity calculation under RFS2. One GGE equals approximately 0.1147 MMBtu.' ;
    rdfs:domain ind:RinGeneration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalRinValueUsd rdf:type rdf:Property ;
    rdfs:label 'Total Rin Value Usd' ;
    rdfs:comment 'Total estimated market value of the RINs generated in this event, calculated as RIN quantity multiplied by market value per RIN. Used for revenue recognition and financial reporting.' ;
    rdfs:domain ind:RinGeneration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:upgradingEfficiencyPercent rdf:type rdf:Property ;
    rdfs:label 'Upgrading Efficiency Percent' ;
    rdfs:comment 'Efficiency of the biogas upgrading system in converting raw landfill gas to pipeline-quality RNG, expressed as a percentage of methane recovery. Typical systems achieve 95-98% efficiency.' ;
    rdfs:domain ind:RinGeneration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryRngFacilityId rdf:type rdf:Property ;
    rdfs:label 'Primary Rng Facility Id' ;
    rdfs:comment 'Reference to the parent facility (landfill or WTE site) where this RNG processing unit is located.' ;
    rdfs:domain ind:RngProcessingUnit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:annualCapacityMmbtu rdf:type rdf:Property ;
    rdfs:label 'Annual Capacity Mmbtu' ;
    rdfs:comment 'Estimated annual production capacity of the RNG processing unit in million British thermal units (MMBtu).' ;
    rdfs:domain ind:RngProcessingUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:co2RemovalEfficiencyPercent rdf:type rdf:Property ;
    rdfs:label 'Co2 Removal Efficiency Percent' ;
    rdfs:comment 'Percentage efficiency of the CO2 removal process in the upgrading system, critical for achieving target methane purity.' ;
    rdfs:domain ind:RngProcessingUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:designThroughputScfm rdf:type rdf:Property ;
    rdfs:label 'Design Throughput Scfm' ;
    rdfs:comment 'Nameplate design capacity of the unit in standard cubic feet per minute (SCFM) of raw LFG input.' ;
    rdfs:domain ind:RngProcessingUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gasQualitySpecStandard rdf:type rdf:Property ;
    rdfs:label 'Gas Quality Spec Standard' ;
    rdfs:comment 'The regulatory or contractual gas quality specification standard that the RNG must meet (e.g., FERC, state PUC, pipeline tariff).' ;
    rdfs:domain ind:RngProcessingUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:h2sRemovalSystem rdf:type rdf:Property ;
    rdfs:label 'H2s Removal System' ;
    rdfs:comment 'Indicates whether the unit is equipped with a hydrogen sulfide (H2S) removal system to meet pipeline gas quality and safety standards.' ;
    rdfs:domain ind:RngProcessingUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maintenanceSchedule rdf:type rdf:Property ;
    rdfs:label 'Maintenance Schedule' ;
    rdfs:comment 'Scheduled maintenance frequency for the RNG processing unit to ensure optimal performance and regulatory compliance.' ;
    rdfs:domain ind:RngProcessingUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:methanePurityTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Methane Purity Target Percent' ;
    rdfs:comment 'Target methane concentration percentage in the upgraded RNG output required to meet pipeline quality specifications.' ;
    rdfs:domain ind:RngProcessingUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextMaintenanceDate rdf:type rdf:Property ;
    rdfs:label 'Next Maintenance Date' ;
    rdfs:comment 'Scheduled date for the next preventive maintenance activity on the RNG processing unit.' ;
    rdfs:domain ind:RngProcessingUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rinGenerationEligible rdf:type rdf:Property ;
    rdfs:label 'Rin Generation Eligible' ;
    rdfs:comment 'Indicates whether the RNG produced by this unit is eligible for generating Renewable Identification Numbers (RINs) under EPA Renewable Fuel Standard (RFS).' ;
    rdfs:domain ind:RngProcessingUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scadaIntegration rdf:type rdf:Property ;
    rdfs:label 'Scada Integration' ;
    rdfs:comment 'Indicates whether the RNG processing unit is integrated with the facility SCADA system for real-time monitoring and control.' ;
    rdfs:domain ind:RngProcessingUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:siloxaneRemovalSystem rdf:type rdf:Property ;
    rdfs:label 'Siloxane Removal System' ;
    rdfs:comment 'Indicates whether the unit is equipped with a siloxane removal system to protect downstream equipment and meet gas quality specifications.' ;
    rdfs:domain ind:RngProcessingUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primarySrfFixedAssetId rdf:type rdf:Property ;
    rdfs:label 'Primary Srf Fixed Asset Id' ;
    rdfs:comment 'Reference to the primary shredder equipment asset used in this production line for waste size reduction.' ;
    rdfs:domain ind:SrfProductionLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FixedAsset .

ind:actualThroughputTpd rdf:type rdf:Property ;
    rdfs:label 'Actual Throughput Tpd' ;
    rdfs:comment 'Current average actual throughput of the production line measured in tons per day, based on recent operational performance.' ;
    rdfs:domain ind:SrfProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:automationLevel rdf:type rdf:Property ;
    rdfs:label 'Automation Level' ;
    rdfs:comment 'Degree of automation in the production line operations and control systems.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designThroughputTpd rdf:type rdf:Property ;
    rdfs:label 'Design Throughput Tpd' ;
    rdfs:comment 'Engineered design capacity of the production line measured in tons per day of input material.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emissionsMonitoringRequired rdf:type rdf:Property ;
    rdfs:label 'Emissions Monitoring Required' ;
    rdfs:comment 'Indicates whether continuous emissions monitoring is required for this production line under Clean Air Act (CAA) regulations.' ;
    rdfs:domain ind:Energy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:energyConsumptionKwhPerTon rdf:type rdf:Property ;
    rdfs:label 'Energy Consumption Kwh Per Ton' ;
    rdfs:comment 'Average electrical energy consumption of the production line per ton of SRF produced.' ;
    rdfs:domain ind:SrfProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastMajorUpgradeDate rdf:type rdf:Property ;
    rdfs:label 'Last Major Upgrade Date' ;
    rdfs:comment 'Date of the most recent major equipment upgrade or capacity enhancement to the production line.' ;
    rdfs:domain ind:SrfProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lineCode rdf:type rdf:Property ;
    rdfs:label 'Line Code' ;
    rdfs:comment 'Business identifier code for the SRF production line, used in operational systems and reporting.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineName rdf:type rdf:Property ;
    rdfs:label 'Line Name' ;
    rdfs:comment 'Human-readable name or designation of the SRF production line.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineType rdf:type rdf:Property ;
    rdfs:label 'Line Type' ;
    rdfs:comment 'Classification of the SRF production line based on processing technology and methodology.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceScheduleType rdf:type rdf:Property ;
    rdfs:label 'Maintenance Schedule Type' ;
    rdfs:comment 'Primary maintenance strategy applied to this production line.' ;
    rdfs:domain ind:SrfProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingDaysPerYear rdf:type rdf:Property ;
    rdfs:label 'Operating Days Per Year' ;
    rdfs:comment 'Typical number of operating days per year for this production line, accounting for planned maintenance and shutdowns.' ;
    rdfs:domain ind:SrfProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operatingHoursPerDay rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Per Day' ;
    rdfs:comment 'Typical number of operating hours per day for this production line under normal operations.' ;
    rdfs:domain ind:SrfProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processingStages rdf:type rdf:Property ;
    rdfs:label 'Processing Stages' ;
    rdfs:comment 'Description of the sequential processing stages in this production line (e.g., shredding, screening, air classification, drying, pelletizing).' ;
    rdfs:domain ind:SrfProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectRatePercent rdf:type rdf:Property ;
    rdfs:label 'Reject Rate Percent' ;
    rdfs:comment 'Average percentage of input feedstock that is rejected or diverted to landfill due to quality or contamination issues.' ;
    rdfs:domain ind:SrfProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyCertificationStatus rdf:type rdf:Property ;
    rdfs:label 'Safety Certification Status' ;
    rdfs:comment 'Current status of OSHA safety certification for the production line equipment and operations.' ;
    rdfs:domain ind:SrfProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:srfAshContentPercent rdf:type rdf:Property ;
    rdfs:label 'Srf Ash Content Percent' ;
    rdfs:comment 'Target ash content specification of the SRF output, expressed as percentage by weight.' ;
    rdfs:domain ind:SrfProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:srfCalorificValueMjKg rdf:type rdf:Property ;
    rdfs:label 'Srf Calorific Value Mj Kg' ;
    rdfs:comment 'Target net calorific value specification of the SRF output from this production line, measured in megajoules per kilogram.' ;
    rdfs:domain ind:SrfProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:srfChlorineContentPercent rdf:type rdf:Property ;
    rdfs:label 'Srf Chlorine Content Percent' ;
    rdfs:comment 'Target chlorine content specification of the SRF output, expressed as percentage by weight, critical for emissions control in end-use combustion.' ;
    rdfs:domain ind:SrfProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:srfMoistureContentPercent rdf:type rdf:Property ;
    rdfs:label 'Srf Moisture Content Percent' ;
    rdfs:comment 'Target moisture content specification of the SRF output, expressed as percentage by weight.' ;
    rdfs:domain ind:SrfProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:srfQualityClass rdf:type rdf:Property ;
    rdfs:label 'Srf Quality Class' ;
    rdfs:comment 'ISO 21640 quality classification of the SRF produced by this line, based on calorific value, chlorine content, and mercury content ranges.' ;
    rdfs:domain ind:SrfProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetEndUseMarket rdf:type rdf:Property ;
    rdfs:label 'Target End Use Market' ;
    rdfs:comment 'Primary intended market or application for the SRF output from this production line.' ;
    rdfs:domain ind:SrfProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yieldRatePercent rdf:type rdf:Property ;
    rdfs:label 'Yield Rate Percent' ;
    rdfs:comment 'Average percentage of input feedstock that is converted to marketable SRF output, representing production efficiency.' ;
    rdfs:domain ind:SrfProductionLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tippingFeeReceiptId rdf:type rdf:Property ;
    rdfs:label 'Tipping Fee Receipt Id' ;
    rdfs:comment 'Unique identifier for the tipping fee receipt transaction. Primary key for this entity.' ;
    rdfs:domain ind:TippingFeeReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryTippingScaleEquipmentId rdf:type rdf:Property ;
    rdfs:label 'Primary Tipping Scale Equipment Id' ;
    rdfs:comment 'Identifier of the scale equipment used to weigh the inbound loaded vehicle.' ;
    rdfs:domain ind:TippingFeeReceipt ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ScaleEquipment .

ind:driverName rdf:type rdf:Property ;
    rdfs:label 'Driver Name' ;
    rdfs:comment 'Name of the driver who delivered the waste load to the WTE facility.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:haulerName rdf:type rdf:Property ;
    rdfs:label 'Hauler Name' ;
    rdfs:comment 'Name of the hauling company or entity that delivered the waste load to the WTE facility.' ;
    rdfs:domain ind:TippingFeeReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inboundTimestamp rdf:type rdf:Property ;
    rdfs:label 'Inbound Timestamp' ;
    rdfs:comment 'Date and time when the loaded vehicle was weighed on the inbound scale.' ;
    rdfs:domain ind:TippingFeeReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:loadAcceptanceStatus rdf:type rdf:Property ;
    rdfs:label 'Load Acceptance Status' ;
    rdfs:comment 'Operational status indicating whether the waste load met acceptance criteria and was approved for combustion.' ;
    rdfs:domain ind:TippingFeeReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originLocation rdf:type rdf:Property ;
    rdfs:label 'Origin Location' ;
    rdfs:comment 'Geographic location or municipality from which the waste load originated.' ;
    rdfs:domain ind:TippingFeeReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outboundTimestamp rdf:type rdf:Property ;
    rdfs:label 'Outbound Timestamp' ;
    rdfs:comment 'Date and time when the empty vehicle was weighed on the outbound scale.' ;
    rdfs:domain ind:TippingFeeReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:receiptStatus rdf:type rdf:Property ;
    rdfs:label 'Receipt Status' ;
    rdfs:comment 'Current lifecycle status of the tipping fee receipt transaction indicating whether the load was accepted, rejected, or requires review.' ;
    rdfs:domain ind:TippingFeeReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scaleTicketNumber rdf:type rdf:Property ;
    rdfs:label 'Scale Ticket Number' ;
    rdfs:comment 'Unique scale ticket number issued at the weighbridge when the load was weighed. Serves as the externally-known business identifier for this receipt transaction.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surchargeAmount rdf:type rdf:Property ;
    rdfs:label 'Surcharge Amount' ;
    rdfs:comment 'Additional surcharges applied to the base tipping fee for special handling, contamination, or other factors.' ;
    rdfs:domain ind:TippingFeeReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tippingFeeRatePerTon rdf:type rdf:Property ;
    rdfs:label 'Tipping Fee Rate Per Ton' ;
    rdfs:comment 'Gate fee rate charged per ton of waste accepted for combustion at the WTE facility, expressed in dollars per ton.' ;
    rdfs:domain ind:TippingFeeReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vehicleLicensePlate rdf:type rdf:Property ;
    rdfs:label 'Vehicle License Plate' ;
    rdfs:comment 'License plate number of the vehicle that delivered the waste load.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteSubtype rdf:type rdf:Property ;
    rdfs:label 'Waste Subtype' ;
    rdfs:comment 'More granular classification or description of the waste material within the primary waste type category.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:airQualityPermitId rdf:type rdf:Property ;
    rdfs:label 'Air Quality Permit Id' ;
    rdfs:comment 'Foreign key linking to compliance.permit. Business justification: Turbine generators require air quality permits for emissions and grid interconnection permits. Links generator to air permit for emissions monitoring, permit compliance verification, and regulatory in' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Permit .

ind:primaryTurbineFacilityId rdf:type rdf:Property ;
    rdfs:label 'Primary Turbine Facility Id' ;
    rdfs:comment 'Reference to the WTE (Waste-to-Energy) or LFG-to-energy facility where this turbine-generator set is installed.' ;
    rdfs:domain ind:TurbineGenerator ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:annualOperatingHoursTarget rdf:type rdf:Property ;
    rdfs:label 'Annual Operating Hours Target' ;
    rdfs:comment 'Target number of operating hours per year for this turbine-generator set, used for capacity planning and performance benchmarking.' ;
    rdfs:domain ind:TurbineGenerator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:coolingSystemType rdf:type rdf:Property ;
    rdfs:label 'Cooling System Type' ;
    rdfs:comment 'Type of cooling system used for the generator windings and bearings (air-cooled, water-cooled, hydrogen-cooled, or hybrid).' ;
    rdfs:domain ind:TurbineGenerator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frequencyHz rdf:type rdf:Property ;
    rdfs:label 'Frequency Hz' ;
    rdfs:comment 'Electrical frequency of the generator output in hertz (Hz). Standard values are 60 Hz in North America and 50 Hz in most other regions.' ;
    rdfs:domain ind:TurbineGenerator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelSourceType rdf:type rdf:Property ;
    rdfs:label 'Fuel Source Type' ;
    rdfs:comment 'Primary fuel source driving this turbine-generator: MSW (Municipal Solid Waste) combustion, LFG (Landfill Gas), biogas, SRF (Solid Recovered Fuel), RNG (Renewable Natural Gas), or mixed sources.' ;
    rdfs:domain ind:TurbineGenerator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:generatorVoltageKv rdf:type rdf:Property ;
    rdfs:label 'Generator Voltage Kv' ;
    rdfs:comment 'Rated output voltage of the generator in kilovolts (kV), typically the voltage at which power is delivered to the step-up transformer or grid interconnection point.' ;
    rdfs:domain ind:TurbineGenerator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gridInterconnectionVoltageKv rdf:type rdf:Property ;
    rdfs:label 'Grid Interconnection Voltage Kv' ;
    rdfs:comment 'Voltage level at which this turbine-generator interconnects to the utility grid after step-up transformation, measured in kilovolts (kV).' ;
    rdfs:domain ind:Energy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interconnectionAgreementReference rdf:type rdf:Property ;
    rdfs:label 'Interconnection Agreement Reference' ;
    rdfs:comment 'Reference number or identifier for the utility interconnection agreement governing the connection of this generator to the electrical grid.' ;
    rdfs:domain ind:TurbineGenerator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastMajorInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Last Major Inspection Date' ;
    rdfs:comment 'Date of the most recent major inspection or overhaul of the turbine-generator set, typically involving disassembly and detailed component examination.' ;
    rdfs:domain ind:TurbineGenerator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maintenanceContractReference rdf:type rdf:Property ;
    rdfs:label 'Maintenance Contract Reference' ;
    rdfs:comment 'Reference number for the long-term service agreement (LTSA) or maintenance contract covering this turbine-generator set.' ;
    rdfs:domain ind:TurbineGenerator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:powerFactor rdf:type rdf:Property ;
    rdfs:label 'Power Factor' ;
    rdfs:comment 'Rated power factor of the generator, representing the ratio of real power to apparent power. Typically expressed as a decimal between 0 and 1 (e.g., 0.85 or 0.90).' ;
    rdfs:domain ind:TurbineGenerator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ratedCapacityMw rdf:type rdf:Property ;
    rdfs:label 'Rated Capacity Mw' ;
    rdfs:comment 'Nameplate electrical generation capacity of the turbine-generator set measured in megawatts (MW). This is the maximum continuous power output under design conditions.' ;
    rdfs:domain ind:TurbineGenerator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recTrackingSystemCode rdf:type rdf:Property ;
    rdfs:label 'Rec Tracking System Code' ;
    rdfs:comment 'Identifier for this generator in the regional REC tracking system (e.g., M-RETS, WREGIS, PJM-GATS) used to issue and track renewable energy credits.' ;
    rdfs:domain ind:TurbineGenerator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scadaSystemTag rdf:type rdf:Property ;
    rdfs:label 'Scada System Tag' ;
    rdfs:comment 'Tag identifier used in the facility\'s SCADA system to monitor and control this turbine-generator set in real-time.' ;
    rdfs:domain ind:TurbineGenerator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:steamInletPressurePsi rdf:type rdf:Property ;
    rdfs:label 'Steam Inlet Pressure Psi' ;
    rdfs:comment 'Design steam inlet pressure at the turbine inlet in pounds per square inch (PSI). Applicable to steam turbines in WTE facilities.' ;
    rdfs:domain ind:TurbineGenerator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:steamInletTemperatureF rdf:type rdf:Property ;
    rdfs:label 'Steam Inlet Temperature F' ;
    rdfs:comment 'Design steam inlet temperature at the turbine inlet in degrees Fahrenheit. Applicable to steam turbines in WTE facilities.' ;
    rdfs:domain ind:TurbineGenerator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:turbineType rdf:type rdf:Property ;
    rdfs:label 'Turbine Type' ;
    rdfs:comment 'Classification of the turbine technology used in this generator set. Steam turbines are common in WTE facilities; gas turbines and biogas turbines are used in LFG-to-energy projects.' ;
    rdfs:domain ind:TurbineGenerator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utilityOfftakeMeterNumber rdf:type rdf:Property ;
    rdfs:label 'Utility Offtake Meter Number' ;
    rdfs:comment 'Identifier for the revenue-grade meter that measures electrical energy delivered from this turbine-generator to the utility grid or internal distribution system.' ;
    rdfs:domain ind:TurbineGenerator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:airPollutionControlTechnology rdf:type rdf:Property ;
    rdfs:label 'Air Pollution Control Technology' ;
    rdfs:comment 'Description of emissions control systems installed to meet Clean Air Act standards. Typically includes electrostatic precipitators, scrubbers, baghouses, selective catalytic reduction, and activated carbon injection. [ENUM-REF-CANDIDATE: esp|wet_scrubber|dry_scrubber|baghouse|scr|sncr|carbon_injection — promote to reference product]' ;
    rdfs:domain ind:WteFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ashResidueHandlingMethod rdf:type rdf:Property ;
    rdfs:label 'Ash Residue Handling Method' ;
    rdfs:comment 'Primary method for managing bottom ash and fly ash residue from combustion process. Landfill disposal is most common; beneficial reuse includes aggregate substitution; treatment/stabilization reduces leachability.' ;
    rdfs:domain ind:WteFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boilerCount rdf:type rdf:Property ;
    rdfs:label 'Boiler Count' ;
    rdfs:comment 'Number of waste combustion boilers or thermal conversion units at the facility. Relevant for capacity redundancy and maintenance scheduling.' ;
    rdfs:domain ind:WteFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:continuousEmissionsMonitoring rdf:type rdf:Property ;
    rdfs:label 'Continuous Emissions Monitoring' ;
    rdfs:comment 'Indicates whether the facility has continuous emissions monitoring systems installed for real-time tracking of air pollutants. Required for Title V major sources.' ;
    rdfs:domain ind:WteFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:energyOutputType rdf:type rdf:Property ;
    rdfs:label 'Energy Output Type' ;
    rdfs:comment 'Primary form of energy produced by the facility. Electricity for grid export; steam for industrial/district heating; CHP for both; RNG for pipeline-quality biomethane from LFG or anaerobic digestion.' ;
    rdfs:domain ind:WteFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastPermitRenewalDate rdf:type rdf:Property ;
    rdfs:label 'Last Permit Renewal Date' ;
    rdfs:comment 'Date of the most recent environmental permit renewal or modification. Used to track permit compliance cycles and upcoming renewal deadlines.' ;
    rdfs:domain ind:WteFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nameplateElectricalCapacityMw rdf:type rdf:Property ;
    rdfs:label 'Nameplate Electrical Capacity Mw' ;
    rdfs:comment 'Maximum electrical power generation capacity in megawatts under optimal operating conditions. Used for grid interconnection agreements and renewable energy credit calculations.' ;
    rdfs:domain ind:WteFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextPermitExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Next Permit Expiration Date' ;
    rdfs:comment 'Date when current environmental permits expire and require renewal. Critical for compliance planning and operational continuity.' ;
    rdfs:domain ind:WteFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:powerPurchaseAgreementActive rdf:type rdf:Property ;
    rdfs:label 'Power Purchase Agreement Active' ;
    rdfs:comment 'Indicates whether the facility operates under an active power purchase agreement with a utility or off-taker for electricity sales.' ;
    rdfs:domain ind:WteFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recEligible rdf:type rdf:Property ;
    rdfs:label 'Rec Eligible' ;
    rdfs:comment 'Indicates whether the facility qualifies for renewable energy credits under state or federal renewable portfolio standards. True if eligible for REC generation.' ;
    rdfs:domain ind:WteFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:steamOutputCapacityKlbPerHr rdf:type rdf:Property ;
    rdfs:label 'Steam Output Capacity Klb Per Hr' ;
    rdfs:comment 'Maximum steam production capacity in thousand pounds per hour for facilities producing process steam or district heating. Relevant for combined heat and power (CHP) operations.' ;
    rdfs:domain ind:WteFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:turbineGeneratorCount rdf:type rdf:Property ;
    rdfs:label 'Turbine Generator Count' ;
    rdfs:comment 'Number of steam turbine generators installed for electricity production. Relevant for power generation capacity and reliability analysis.' ;
    rdfs:domain ind:WteFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wasteFeedstockTypes rdf:type rdf:Property ;
    rdfs:label 'Waste Feedstock Types' ;
    rdfs:comment 'Types of waste materials accepted as fuel for energy conversion. Common types include MSW, C&D, SRF, biosolids, medical waste, industrial waste. Comma-separated list.' ;
    rdfs:domain ind:WteFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accidentReportId rdf:type rdf:Property ;
    rdfs:label 'Accident Report Id' ;
    rdfs:comment 'Unique identifier for the accident report record. Primary key.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccidentReport .

ind:incidentWteFacilityId rdf:type rdf:Property ;
    rdfs:label 'Incident Wte Facility Id' ;
    rdfs:comment 'Foreign key linking to energy.wte_facility. Business justification: Accidents occurring at WTE facility locations (tipping floor, access roads, queuing areas) must be linked to the facility for safety reporting, facility-specific incident rate tracking, insurance clai' ;
    rdfs:domain ind:AccidentReport ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WteFacility .

ind:repairVendorId rdf:type rdf:Property ;
    rdfs:label 'Repair Vendor Id' ;
    rdfs:comment 'Foreign key linking to procurement.vendor. Business justification: Accident repairs performed by third-party body shops/collision repair vendors. Essential for repair cost tracking, vendor performance evaluation, insurance claim documentation, and payment processing.' ;
    rdfs:domain ind:AccidentReport ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:accidentDescription rdf:type rdf:Property ;
    rdfs:label 'Accident Description' ;
    rdfs:comment 'Detailed narrative description of how the accident occurred, including sequence of events, contributing factors, and circumstances.' ;
    rdfs:domain ind:AccidentReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:citationDescription rdf:type rdf:Property ;
    rdfs:label 'Citation Description' ;
    rdfs:comment 'Description of the traffic violation or citation issued, including violation code and description if applicable.' ;
    rdfs:domain ind:AccidentReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:citationIssuedFlag rdf:type rdf:Property ;
    rdfs:label 'Citation Issued Flag' ;
    rdfs:comment 'Indicates whether a traffic citation or ticket was issued to the driver as a result of the accident.' ;
    rdfs:domain ind:AccidentReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:csaReportableFlag rdf:type rdf:Property ;
    rdfs:label 'Csa Reportable Flag' ;
    rdfs:comment 'Indicates whether the accident is reportable under FMCSA CSA program and will impact the carriers safety score.' ;
    rdfs:domain ind:AccidentReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dotReportableFlag rdf:type rdf:Property ;
    rdfs:label 'Dot Reportable Flag' ;
    rdfs:comment 'Indicates whether the accident meets DOT reportability criteria (fatality, injury requiring immediate medical treatment away from scene, or disabling damage requiring tow-away).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:driverAtFaultFlag rdf:type rdf:Property ;
    rdfs:label 'Driver At Fault Flag' ;
    rdfs:comment 'Indicates whether the company driver was determined to be at fault for the accident based on investigation findings.' ;
    rdfs:domain ind:AccidentReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedPropertyDamageAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Property Damage Amount' ;
    rdfs:comment 'Estimated total dollar amount of property damage resulting from the accident, including damage to company vehicle, other vehicles, and third-party property.' ;
    rdfs:domain ind:AccidentReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incidentSeverity rdf:type rdf:Property ;
    rdfs:label 'Incident Severity' ;
    rdfs:comment 'Overall severity classification of the accident based on injuries, fatalities, and property damage.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceCarrier rdf:type rdf:Property ;
    rdfs:label 'Insurance Carrier' ;
    rdfs:comment 'Name of the insurance company handling the claim for this accident.' ;
    rdfs:domain ind:AccidentReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationStatus rdf:type rdf:Property ;
    rdfs:label 'Investigation Status' ;
    rdfs:comment 'Current status of the internal accident investigation process.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lightConditions rdf:type rdf:Property ;
    rdfs:label 'Light Conditions' ;
    rdfs:comment 'Lighting conditions at the time of the accident.' ;
    rdfs:domain ind:AccidentReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationLatitude rdf:type rdf:Property ;
    rdfs:label 'Location Latitude' ;
    rdfs:comment 'GPS latitude coordinate of the accident location, captured from telematics or manually entered.' ;
    rdfs:domain ind:AccidentReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:locationLongitude rdf:type rdf:Property ;
    rdfs:label 'Location Longitude' ;
    rdfs:comment 'GPS longitude coordinate of the accident location, captured from telematics or manually entered.' ;
    rdfs:domain ind:AccidentReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:numberOfFatalities rdf:type rdf:Property ;
    rdfs:label 'Number Of Fatalities' ;
    rdfs:comment 'Total count of fatalities resulting from the accident.' ;
    rdfs:domain ind:AccidentReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numberOfInjuries rdf:type rdf:Property ;
    rdfs:label 'Number Of Injuries' ;
    rdfs:comment 'Total count of individuals injured in the accident, including driver, passengers, pedestrians, and occupants of other vehicles.' ;
    rdfs:domain ind:AccidentReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:policeDepartment rdf:type rdf:Property ;
    rdfs:label 'Police Department' ;
    rdfs:comment 'Name of the law enforcement agency that responded to and documented the accident.' ;
    rdfs:domain ind:AccidentReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policeReportNumber rdf:type rdf:Property ;
    rdfs:label 'Police Report Number' ;
    rdfs:comment 'Official police report or case number assigned by law enforcement agency responding to the accident scene.' ;
    rdfs:domain ind:AccidentReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postAccidentTestCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Post Accident Test Completed Flag' ;
    rdfs:comment 'Indicates whether the required post-accident drug and alcohol test was completed within the regulatory timeframe.' ;
    rdfs:domain ind:AccidentReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postAccidentTestDate rdf:type rdf:Property ;
    rdfs:label 'Post Accident Test Date' ;
    rdfs:comment 'Date when the post-accident drug and alcohol test was administered.' ;
    rdfs:domain ind:AccidentReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:postAccidentTestRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Post Accident Test Required Flag' ;
    rdfs:comment 'Indicates whether a post-accident drug and alcohol test is required per FMCSA regulations (49 CFR Part 382) based on accident severity and circumstances.' ;
    rdfs:domain ind:AccidentReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postAccidentTestResult rdf:type rdf:Property ;
    rdfs:label 'Post Accident Test Result' ;
    rdfs:comment 'Result of the post-accident drug and alcohol test (negative, positive, refused, or not completed).' ;
    rdfs:domain ind:AccidentReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportedDate rdf:type rdf:Property ;
    rdfs:label 'Reported Date' ;
    rdfs:comment 'Date when the accident was first reported to the company by the driver or other party.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:roadConditions rdf:type rdf:Property ;
    rdfs:label 'Road Conditions' ;
    rdfs:comment 'Road surface conditions at the time and location of the accident.' ;
    rdfs:domain ind:AccidentReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleSpeedMph rdf:type rdf:Property ;
    rdfs:label 'Vehicle Speed Mph' ;
    rdfs:comment 'Estimated or recorded speed of the company vehicle in miles per hour at the time of the accident, captured from telematics or driver report.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costAllocationId rdf:type rdf:Property ;
    rdfs:label 'Cost Allocation Id' ;
    rdfs:comment 'Primary key for cost_allocation' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalAllocationCostAllocationId rdf:type rdf:Property ;
    rdfs:label 'Original Allocation Cost Allocation Id' ;
    rdfs:comment 'Reference to the original cost allocation record if this record is a reversal or correction.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostAllocation .

ind:allocationBasisQuantity rdf:type rdf:Property ;
    rdfs:label 'Allocation Basis Quantity' ;
    rdfs:comment 'The quantity of the allocation basis used (miles driven, hours operated, tons hauled) for the allocation calculation.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationBasisUnit rdf:type rdf:Property ;
    rdfs:label 'Allocation Basis Unit' ;
    rdfs:comment 'The unit of measure for the allocation basis quantity (miles, kilometers, hours, tons, trips, percentage).' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationMethod rdf:type rdf:Property ;
    rdfs:label 'Allocation Method' ;
    rdfs:comment 'The methodology used to allocate the cost (actual, standard rate, mileage-based, hours-based, tonnage-based, equal distribution).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationNotes rdf:type rdf:Property ;
    rdfs:label 'Allocation Notes' ;
    rdfs:comment 'Free-text notes or comments explaining special circumstances, adjustments, or rationale for this cost allocation.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationPercentage rdf:type rdf:Property ;
    rdfs:label 'Allocation Percentage' ;
    rdfs:comment 'The percentage of total cost allocated to this cost center or service line when using percentage-based allocation (0.00 to 100.00).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Allocation Period End Date' ;
    rdfs:comment 'The last day of the period for which costs are being allocated (typically month or year end).' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allocationPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Allocation Period Start Date' ;
    rdfs:comment 'The first day of the period for which costs are being allocated (typically month or year start).' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allocationRate rdf:type rdf:Property ;
    rdfs:label 'Allocation Rate' ;
    rdfs:comment 'The rate applied per unit of allocation basis (e.g., cost per mile, cost per hour) used to calculate the allocated amount.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationStatus rdf:type rdf:Property ;
    rdfs:label 'Allocation Status' ;
    rdfs:comment 'The current workflow status of the cost allocation record (draft, pending approval, approved, posted, reversed, cancelled).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Category' ;
    rdfs:comment 'The category of fleet operating cost being allocated (fuel, preventive maintenance, corrective repair, tires, insurance, registration, depreciation, lease, other). [ENUM-REF-CANDIDATE: fuel|preventive_maintenance|corrective_repair|tires|insurance|registration|depreciation|lease|other — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mileageDriven rdf:type rdf:Property ;
    rdfs:label 'Mileage Driven' ;
    rdfs:comment 'The total miles driven by the vehicle during the allocation period, sourced from Geotab telematics.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sapCostDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Cost Document Number' ;
    rdfs:comment 'The SAP FI/CO document number that records this cost allocation transaction for financial reporting and audit trail.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapPostingDate rdf:type rdf:Property ;
    rdfs:label 'Sap Posting Date' ;
    rdfs:comment 'The date on which the cost allocation was posted in SAP FI/CO for financial period assignment.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tonnageHauled rdf:type rdf:Property ;
    rdfs:label 'Tonnage Hauled' ;
    rdfs:comment 'The total tonnage hauled by the vehicle during the allocation period, measured in tons, for tonnage-based cost allocation.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tripsCompleted rdf:type rdf:Property ;
    rdfs:label 'Trips Completed' ;
    rdfs:comment 'The total number of trips or runs completed by the vehicle during the allocation period.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vehicleType rdf:type rdf:Property ;
    rdfs:label 'Vehicle Type' ;
    rdfs:comment 'The type of vehicle for which costs are allocated (ASL - Automated Side Loader, FEL - Front End Loader, REL - Rear End Loader, roll-off, transfer, support).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fleetDotInspectionId rdf:type rdf:Property ;
    rdfs:label 'Fleet Dot Inspection Id' ;
    rdfs:comment 'Unique identifier for the DOT inspection record. Primary key.' ;
    rdfs:domain ind:FleetDotInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inspectionVendorId rdf:type rdf:Property ;
    rdfs:label 'Inspection Vendor Id' ;
    rdfs:comment 'Foreign key linking to procurement.vendor. Business justification: DOT inspections performed by third-party certified inspection vendors require vendor tracking for certification validation, performance management, and payment processing. Role-prefixed to distinguish' ;
    rdfs:domain ind:FleetDotInspection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:reviewingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Reviewing Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Internal review of DOT roadside inspections by safety managers is required for CSA score management, corrective action tracking, and FMCSA compliance audits.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:basicCategory rdf:type rdf:Property ;
    rdfs:label 'Basic Category' ;
    rdfs:comment 'CSA BASIC category that the violations fall under (e.g., Unsafe Driving, Hours of Service Compliance, Vehicle Maintenance, Controlled Substances/Alcohol, Driver Fitness, Hazardous Materials Compliance, Crash Indicator). [ENUM-REF-CANDIDATE: Unsafe Driving|Hours of Service|Vehicle Maintenance|Controlled Substances|Driver Fitness|Hazardous Materials|Crash Indicator — promote to reference product]' ;
    rdfs:domain ind:FleetDotInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionStatus rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Status' ;
    rdfs:comment 'Current status of the corrective action process.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:csaScoreImpact rdf:type rdf:Property ;
    rdfs:label 'Csa Score Impact' ;
    rdfs:comment 'Calculated impact of this inspection on the carrier\'s CSA score.' ;
    rdfs:domain ind:FleetDotInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:driverLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Driver License Number' ;
    rdfs:comment 'CDL number of the driver at the time of inspection. Recorded for compliance tracking.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:driverLicenseState rdf:type rdf:Property ;
    rdfs:label 'Driver License State' ;
    rdfs:comment 'Two-letter state code of the issuing state for the driver\'s CDL.' ;
    rdfs:domain ind:FleetDotInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:driverOosFlag rdf:type rdf:Property ;
    rdfs:label 'Driver Oos Flag' ;
    rdfs:comment 'Boolean flag indicating whether the driver specifically was placed out of service.' ;
    rdfs:domain ind:FleetDotInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectionCategory rdf:type rdf:Property ;
    rdfs:label 'Inspection Category' ;
    rdfs:comment 'Category or context of the inspection event (roadside stop, scheduled annual inspection, state patrol enforcement, terminal audit, compliance review, or random selection).' ;
    rdfs:domain ind:FleetDotInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Inspection Document Url' ;
    rdfs:comment 'URL or file path to the scanned or digital copy of the official inspection report.' ;
    rdfs:domain ind:FleetDotInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Inspection Duration Minutes' ;
    rdfs:comment 'Total duration of the inspection in minutes.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inspectionLocation rdf:type rdf:Property ;
    rdfs:label 'Inspection Location' ;
    rdfs:comment 'Physical location where the inspection was conducted (address, weigh station name, or facility identifier).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionNotes rdf:type rdf:Property ;
    rdfs:label 'Inspection Notes' ;
    rdfs:comment 'Additional notes or comments recorded by the inspector during the inspection.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionReportNumber rdf:type rdf:Property ;
    rdfs:label 'Inspection Report Number' ;
    rdfs:comment 'Official inspection report number issued by the inspector or enforcement agency. Unique identifier for the inspection event in DOT/CVSA systems.' ;
    rdfs:domain ind:FleetDotInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionState rdf:type rdf:Property ;
    rdfs:label 'Inspection State' ;
    rdfs:comment 'Two-letter state code where the inspection occurred.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectorAgency rdf:type rdf:Property ;
    rdfs:label 'Inspector Agency' ;
    rdfs:comment 'Name of the enforcement agency or organization that conducted the inspection (e.g., State Highway Patrol, DOT, CVSA).' ;
    rdfs:domain ind:FleetDotInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oosViolationCount rdf:type rdf:Property ;
    rdfs:label 'Oos Violation Count' ;
    rdfs:comment 'Number of violations that met FMCSA out-of-service criteria.' ;
    rdfs:domain ind:FleetDotInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:outOfServiceFlag rdf:type rdf:Property ;
    rdfs:label 'Out Of Service Flag' ;
    rdfs:comment 'Boolean flag indicating whether the vehicle or driver was placed out of service as a result of the inspection. True if OOS order was issued.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:severityWeight rdf:type rdf:Property ;
    rdfs:label 'Severity Weight' ;
    rdfs:comment 'Severity weight assigned to the violations for CSA scoring purposes (1-10 scale, with 10 being most severe).' ;
    rdfs:domain ind:FleetDotInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vehicleOdometerReading rdf:type rdf:Property ;
    rdfs:label 'Vehicle Odometer Reading' ;
    rdfs:comment 'Odometer reading of the vehicle at the time of inspection, in miles.' ;
    rdfs:domain ind:FleetDotInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vehicleOosFlag rdf:type rdf:Property ;
    rdfs:label 'Vehicle Oos Flag' ;
    rdfs:comment 'Boolean flag indicating whether the vehicle specifically was placed out of service.' ;
    rdfs:domain ind:FleetDotInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:violationCodes rdf:type rdf:Property ;
    rdfs:label 'Violation Codes' ;
    rdfs:comment 'Comma-separated list of FMCSA violation codes cited during the inspection (e.g., 393.75B, 396.3A1).' ;
    rdfs:domain ind:FleetDotInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdlTrainingCertificationId rdf:type rdf:Property ;
    rdfs:label 'Cdl Training Certification Id' ;
    rdfs:comment 'Foreign key linking to compliance.training_certification. Business justification: CDL licenses, hazmat endorsements, and DOT medical certifications are regulatory training certifications. Driver qualification files require linking to certification records for FMCSA compliance audit' ;
    rdfs:domain ind:Driver ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TrainingCertification .

ind:homeDistrictId rdf:type rdf:Property ;
    rdfs:label 'Home District Id' ;
    rdfs:comment 'Reference to the primary operational district where the driver is based. Used for route assignment and workforce planning.' ;
    rdfs:domain ind:Driver ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:District .

ind:cdlEndorsements rdf:type rdf:Property ;
    rdfs:label 'Cdl Endorsements' ;
    rdfs:comment 'Comma-separated list of CDL endorsements held by the driver (e.g., H for Hazmat, N for Tanker, T for Doubles/Triples, P for Passenger). Determines specialized vehicle and cargo authorization.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdlExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Cdl Expiration Date' ;
    rdfs:comment 'Date when the Commercial Driver License expires and must be renewed. Critical for DOT compliance monitoring.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cdlIssueDate rdf:type rdf:Property ;
    rdfs:label 'Cdl Issue Date' ;
    rdfs:comment 'Date when the current Commercial Driver License was issued by the state authority.' ;
    rdfs:domain ind:Driver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cdlNumber rdf:type rdf:Property ;
    rdfs:label 'Cdl Number' ;
    rdfs:comment 'Unique Commercial Driver License number issued by the state licensing authority. Required for all drivers operating commercial motor vehicles.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdlState rdf:type rdf:Property ;
    rdfs:label 'Cdl State' ;
    rdfs:comment 'Two-letter state code where the Commercial Driver License was issued (e.g., CA, TX, NY).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dotPhysicalExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Dot Physical Expiration Date' ;
    rdfs:comment 'Date when the DOT medical examiner certificate expires. Drivers must maintain current medical certification to operate commercial vehicles.' ;
    rdfs:domain ind:Driver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dotPhysicalIssueDate rdf:type rdf:Property ;
    rdfs:label 'Dot Physical Issue Date' ;
    rdfs:comment 'Date when the current DOT medical examiner certificate was issued.' ;
    rdfs:domain ind:Driver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:drugAlcoholProgramEnrollmentDate rdf:type rdf:Property ;
    rdfs:label 'Drug Alcohol Program Enrollment Date' ;
    rdfs:comment 'Date when the driver was enrolled in the DOT drug and alcohol testing program.' ;
    rdfs:domain ind:Driver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:drugAlcoholProgramEnrollmentFlag rdf:type rdf:Property ;
    rdfs:label 'Drug Alcohol Program Enrollment Flag' ;
    rdfs:comment 'Indicates whether the driver is enrolled in the DOT-mandated drug and alcohol testing program. Required for all CDL drivers.' ;
    rdfs:domain ind:Driver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazmatClearanceExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Hazmat Clearance Expiration Date' ;
    rdfs:comment 'Expiration date of the driver\'s TSA security threat assessment clearance required for Hazmat endorsement. Must be renewed every five years.' ;
    rdfs:domain ind:Driver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:hazmatEndorsementFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Endorsement Flag' ;
    rdfs:comment 'Indicates whether the driver holds a valid Hazmat endorsement on their CDL, required for transporting hazardous waste materials subject to RCRA regulations.' ;
    rdfs:domain ind:Driver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hireDate rdf:type rdf:Property ;
    rdfs:label 'Hire Date' ;
    rdfs:comment 'Date when the driver was hired by Waste Management. Used for seniority, tenure analysis, and route assignment priority.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastAlcoholTestDate rdf:type rdf:Property ;
    rdfs:label 'Last Alcohol Test Date' ;
    rdfs:comment 'Date of the driver\'s most recent alcohol test (pre-employment, random, post-accident, reasonable suspicion, or return-to-duty).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastAlcoholTestResult rdf:type rdf:Property ;
    rdfs:label 'Last Alcohol Test Result' ;
    rdfs:comment 'Result of the driver\'s most recent alcohol test. Positive results (BAC >= 0.04) or refusals trigger disqualification.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastDrugTestDate rdf:type rdf:Property ;
    rdfs:label 'Last Drug Test Date' ;
    rdfs:comment 'Date of the driver\'s most recent drug test (pre-employment, random, post-accident, reasonable suspicion, or return-to-duty).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastDrugTestResult rdf:type rdf:Property ;
    rdfs:label 'Last Drug Test Result' ;
    rdfs:comment 'Result of the driver\'s most recent drug test. Positive results or refusals trigger disqualification and return-to-duty protocols.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastQualificationReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Qualification Review Date' ;
    rdfs:comment 'Date when the driver\'s qualification file was last reviewed for completeness and compliance with DOT requirements.' ;
    rdfs:domain ind:Driver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:medicalExaminerCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Medical Examiner Certificate Number' ;
    rdfs:comment 'Unique identifier for the driver\'s DOT medical examiner certificate. Required to demonstrate physical fitness to operate commercial motor vehicles.' ;
    rdfs:domain ind:Driver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalExaminerName rdf:type rdf:Property ;
    rdfs:label 'Medical Examiner Name' ;
    rdfs:comment 'Name of the certified medical examiner who issued the DOT physical certificate.' ;
    rdfs:domain ind:Driver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mvrLastReviewDate rdf:type rdf:Property ;
    rdfs:label 'Mvr Last Review Date' ;
    rdfs:comment 'Date when the driver\'s Motor Vehicle Record was last reviewed by the fleet safety department. DOT requires annual MVR reviews.' ;
    rdfs:domain ind:Driver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mvrNextReviewDueDate rdf:type rdf:Property ;
    rdfs:label 'Mvr Next Review Due Date' ;
    rdfs:comment 'Date when the next Motor Vehicle Record review is due. Used for compliance tracking and proactive safety management.' ;
    rdfs:domain ind:Driver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mvrStatus rdf:type rdf:Property ;
    rdfs:label 'Mvr Status' ;
    rdfs:comment 'Current status of the driver\'s Motor Vehicle Record based on the most recent review. Indicates driving history and violation status for risk assessment and DOT compliance.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextQualificationReviewDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Qualification Review Due Date' ;
    rdfs:comment 'Date when the next driver qualification file review is due. Used for proactive compliance management.' ;
    rdfs:domain ind:Driver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:primaryRouteType rdf:type rdf:Property ;
    rdfs:label 'Primary Route Type' ;
    rdfs:comment 'Primary type of collection route the driver is assigned to. Determines vehicle type and operational requirements.' ;
    rdfs:domain ind:Driver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationStatus rdf:type rdf:Property ;
    rdfs:label 'Qualification Status' ;
    rdfs:comment 'Current qualification status of the driver based on DOT requirements, medical certification, license validity, and company safety standards. Determines whether the driver is authorized to operate fleet vehicles.' ;
    rdfs:domain ind:Driver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyScore rdf:type rdf:Property ;
    rdfs:label 'Safety Score' ;
    rdfs:comment 'Composite safety score based on driving behavior, incident history, and compliance metrics captured from Geotab Fleet Telematics. Scale 0-100, higher is better.' ;
    rdfs:domain ind:Driver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalMilesDriven rdf:type rdf:Property ;
    rdfs:label 'Total Miles Driven' ;
    rdfs:comment 'Cumulative total miles driven by the driver across all fleet vehicles since hire date. Used for experience assessment and performance analysis.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:driverBehaviorEventId rdf:type rdf:Property ;
    rdfs:label 'Driver Behavior Event Id' ;
    rdfs:comment 'Primary key for driver_behavior_event' ;
    rdfs:domain ind:DriverBehaviorEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualSpeedMph rdf:type rdf:Property ;
    rdfs:label 'Actual Speed Mph' ;
    rdfs:comment 'Actual vehicle speed in miles per hour at the time of the speeding event, captured from telematics.' ;
    rdfs:domain ind:DriverBehaviorEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:addressText rdf:type rdf:Property ;
    rdfs:label 'Address Text' ;
    rdfs:comment 'Human-readable street address or location description where the driver behavior event occurred, reverse-geocoded from GPS (Global Positioning System) coordinates.' ;
    rdfs:domain ind:DriverBehaviorEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coachingCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Coaching Completed Date' ;
    rdfs:comment 'Date when driver coaching or corrective action was completed for this behavior event.' ;
    rdfs:domain ind:DriverBehaviorEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:coachingCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Coaching Completed Flag' ;
    rdfs:comment 'Indicates whether required driver coaching or corrective action has been completed following the behavior event.' ;
    rdfs:domain ind:DriverBehaviorEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coachingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Coaching Required Flag' ;
    rdfs:comment 'Indicates whether driver coaching or corrective action is required based on the severity and frequency of the behavior event.' ;
    rdfs:domain ind:DriverBehaviorEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:driverScoreImpact rdf:type rdf:Property ;
    rdfs:label 'Driver Score Impact' ;
    rdfs:comment 'Numeric impact of this behavior event on the driver\'s overall safety score, used for performance evaluation and incentive programs.' ;
    rdfs:domain ind:DriverBehaviorEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:engineHours rdf:type rdf:Property ;
    rdfs:label 'Engine Hours' ;
    rdfs:comment 'Cumulative engine hours at the time of the behavior event, captured from telematics.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Event Duration Seconds' ;
    rdfs:comment 'Duration of the behavior event in seconds, applicable to events such as excessive idle or distracted driving.' ;
    rdfs:domain ind:DriverBehaviorEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eventNotes rdf:type rdf:Property ;
    rdfs:label 'Event Notes' ;
    rdfs:comment 'Free-text notes or comments regarding the driver behavior event, including driver explanations or supervisor observations.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventSeverity rdf:type rdf:Property ;
    rdfs:label 'Event Severity' ;
    rdfs:comment 'Severity level assigned to the driver behavior event based on risk assessment algorithms.' ;
    rdfs:domain ind:DriverBehaviorEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Event Source System' ;
    rdfs:comment 'Name of the source system that generated the driver behavior event record, typically Geotab Fleet Telematics.' ;
    rdfs:domain ind:DriverBehaviorEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelLevelPercent rdf:type rdf:Property ;
    rdfs:label 'Fuel Level Percent' ;
    rdfs:comment 'Fuel level as a percentage of tank capacity at the time of the behavior event, captured from telematics.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gForceValue rdf:type rdf:Property ;
    rdfs:label 'G Force Value' ;
    rdfs:comment 'Gravitational force measurement in g-units for harsh braking, acceleration, or cornering events, indicating severity of the maneuver.' ;
    rdfs:domain ind:DriverBehaviorEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:idleDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Idle Duration Minutes' ;
    rdfs:comment 'Duration of excessive idle time in minutes for idle events, used to track fuel efficiency and driver behavior.' ;
    rdfs:domain ind:DriverBehaviorEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incidentFlag rdf:type rdf:Property ;
    rdfs:label 'Incident Flag' ;
    rdfs:comment 'Indicates whether this driver behavior event resulted in or contributed to a safety incident or accident.' ;
    rdfs:domain ind:DriverBehaviorEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insuranceClaimFlag rdf:type rdf:Property ;
    rdfs:label 'Insurance Claim Flag' ;
    rdfs:comment 'Indicates whether this driver behavior event resulted in or contributed to an insurance claim.' ;
    rdfs:domain ind:DriverBehaviorEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postedSpeedLimitMph rdf:type rdf:Property ;
    rdfs:label 'Posted Speed Limit Mph' ;
    rdfs:comment 'Posted speed limit in miles per hour at the location where the speeding event occurred, derived from map data.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reviewedBySupervisorFlag rdf:type rdf:Property ;
    rdfs:label 'Reviewed By Supervisor Flag' ;
    rdfs:comment 'Indicates whether the driver behavior event has been reviewed by a supervisor or fleet manager.' ;
    rdfs:domain ind:DriverBehaviorEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewedDate rdf:type rdf:Property ;
    rdfs:label 'Reviewed Date' ;
    rdfs:comment 'Date when the driver behavior event was reviewed by a supervisor or fleet manager.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:roadType rdf:type rdf:Property ;
    rdfs:label 'Road Type' ;
    rdfs:comment 'Classification of the road type where the driver behavior event occurred, used for contextual risk analysis.' ;
    rdfs:domain ind:DriverBehaviorEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:speedOverLimitMph rdf:type rdf:Property ;
    rdfs:label 'Speed Over Limit Mph' ;
    rdfs:comment 'Amount by which the actual speed exceeded the posted speed limit in miles per hour, calculated for speeding events.' ;
    rdfs:domain ind:DriverBehaviorEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:telematicsDeviceCode rdf:type rdf:Property ;
    rdfs:label 'Telematics Device Code' ;
    rdfs:comment 'Unique identifier of the Geotab telematics device that captured the behavior event.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleOdometerMiles rdf:type rdf:Property ;
    rdfs:label 'Vehicle Odometer Miles' ;
    rdfs:comment 'Vehicle odometer reading in miles at the time of the behavior event, captured from telematics.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:drugAlcoholTestId rdf:type rdf:Property ;
    rdfs:label 'Drug Alcohol Test Id' ;
    rdfs:comment 'Unique identifier for the drug and alcohol test record. Primary key.' ;
    rdfs:domain ind:DrugAlcoholTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:testingVendorId rdf:type rdf:Property ;
    rdfs:label 'Testing Vendor Id' ;
    rdfs:comment 'Foreign key linking to procurement.vendor. Business justification: Drug/alcohol testing performed by contracted laboratories and collection sites. Essential for vendor certification tracking, FMCSA compliance, payment processing. Role-prefixed; removes denormalized c' ;
    rdfs:domain ind:DrugAlcoholTest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:accidentRelated rdf:type rdf:Property ;
    rdfs:label 'Accident Related' ;
    rdfs:comment 'Indicates whether this test was conducted as a post-accident test following a DOT-reportable accident involving fatality, injury requiring immediate medical treatment away from the scene, or disabling damage to any vehicle requiring tow-away.' ;
    rdfs:domain ind:DrugAlcoholTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:alcoholConcentration rdf:type rdf:Property ;
    rdfs:label 'Alcohol Concentration' ;
    rdfs:comment 'The measured blood alcohol concentration (BAC) level if an alcohol test was performed, expressed as a decimal (e.g., 0.040 for 0.04%). Null if drug-only test.' ;
    rdfs:domain ind:DrugAlcoholTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chainOfCustodyNumber rdf:type rdf:Property ;
    rdfs:label 'Chain Of Custody Number' ;
    rdfs:comment 'The Federal CCF (Custody and Control Form) number used to track the specimen from collection through laboratory analysis.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearinghouseReportDate rdf:type rdf:Property ;
    rdfs:label 'Clearinghouse Report Date' ;
    rdfs:comment 'The date the test result was reported to the FMCSA Drug and Alcohol Clearinghouse. Null if not yet reported or not reportable.' ;
    rdfs:domain ind:DrugAlcoholTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:collectionMethod rdf:type rdf:Property ;
    rdfs:label 'Collection Method' ;
    rdfs:comment 'The specimen type or method used for collection: urine (drug test), breath (alcohol), oral fluid (drug or alcohol), or blood (rare, post-accident).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionSiteAddress rdf:type rdf:Property ;
    rdfs:label 'Collection Site Address' ;
    rdfs:comment 'The physical address of the collection site, including street, city, state, and postal code.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectorName rdf:type rdf:Property ;
    rdfs:label 'Collector Name' ;
    rdfs:comment 'The full name of the certified specimen collector who performed the collection procedure.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmationTestDate rdf:type rdf:Property ;
    rdfs:label 'Confirmation Test Date' ;
    rdfs:comment 'The date the confirmation test was conducted, if applicable. Null if no confirmation test was required.' ;
    rdfs:domain ind:DrugAlcoholTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:confirmationTestPerformed rdf:type rdf:Property ;
    rdfs:label 'Confirmation Test Performed' ;
    rdfs:comment 'Indicates whether a confirmation test (GC/MS for drugs, evidential breath test for alcohol) was performed following a non-negative screening result.' ;
    rdfs:domain ind:DrugAlcoholTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:driverNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Driver Notification Date' ;
    rdfs:comment 'The date the driver was notified of the test result by the employer or MRO.' ;
    rdfs:domain ind:DrugAlcoholTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fmcsaReported rdf:type rdf:Property ;
    rdfs:label 'Fmcsa Reported' ;
    rdfs:comment 'Indicates whether this test result has been reported to the FMCSA Drug and Alcohol Clearinghouse as required for positive, refused, adulterated, or substituted results.' ;
    rdfs:domain ind:DrugAlcoholTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:followUpTestCountRequired rdf:type rdf:Property ;
    rdfs:label 'Follow Up Test Count Required' ;
    rdfs:comment 'The minimum number of follow-up tests prescribed by the SAP (typically 6 tests in the first 12 months). Null if no follow-up testing is required.' ;
    rdfs:domain ind:DrugAlcoholTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:followUpTestingEndDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Testing End Date' ;
    rdfs:comment 'The date when the follow-up testing period prescribed by the SAP is scheduled to end (12 to 60 months from return-to-duty). Null if not applicable.' ;
    rdfs:domain ind:DrugAlcoholTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:followUpTestingRequired rdf:type rdf:Property ;
    rdfs:label 'Follow Up Testing Required' ;
    rdfs:comment 'Indicates whether the driver is subject to unannounced follow-up testing for a minimum of 12 months (up to 60 months) as prescribed by the SAP.' ;
    rdfs:domain ind:DrugAlcoholTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laboratoryAccreditationNumber rdf:type rdf:Property ;
    rdfs:label 'Laboratory Accreditation Number' ;
    rdfs:comment 'The SAMHSA certification or accreditation number of the testing laboratory.' ;
    rdfs:domain ind:DrugAlcoholTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mroName rdf:type rdf:Property ;
    rdfs:label 'Mro Name' ;
    rdfs:comment 'The full name of the licensed physician (Medical Review Officer) who reviewed and verified the drug test result.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mroPhone rdf:type rdf:Property ;
    rdfs:label 'Mro Phone' ;
    rdfs:comment 'The contact phone number for the Medical Review Officer who verified the test result.' ;
    rdfs:domain ind:DrugAlcoholTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positiveSubstanceIdentified rdf:type rdf:Property ;
    rdfs:label 'Positive Substance Identified' ;
    rdfs:comment 'The specific controlled substance(s) detected if the test result was positive (e.g., marijuana, cocaine, opiates, amphetamines, PCP). Null if negative or alcohol-only test.' ;
    rdfs:domain ind:DrugAlcoholTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonableSuspicionDocumented rdf:type rdf:Property ;
    rdfs:label 'Reasonable Suspicion Documented' ;
    rdfs:comment 'Indicates whether a trained supervisor documented specific, contemporaneous observations of driver behavior, appearance, or conduct that led to a reasonable suspicion test.' ;
    rdfs:domain ind:DrugAlcoholTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recordRetentionDate rdf:type rdf:Property ;
    rdfs:label 'Record Retention Date' ;
    rdfs:comment 'The date through which this test record must be retained per DOT regulations (typically 5 years from test date for negative results, longer for positive results).' ;
    rdfs:domain ind:DrugAlcoholTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:returnToDutyClearanceDate rdf:type rdf:Property ;
    rdfs:label 'Return To Duty Clearance Date' ;
    rdfs:comment 'The date the driver was cleared by the SAP and passed a return-to-duty test, allowing them to resume safety-sensitive functions. Null if not applicable.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sapEvaluationDate rdf:type rdf:Property ;
    rdfs:label 'Sap Evaluation Date' ;
    rdfs:comment 'The date the driver completed the initial SAP evaluation, if required. Null if no SAP referral was made.' ;
    rdfs:domain ind:DrugAlcoholTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sapName rdf:type rdf:Property ;
    rdfs:label 'Sap Name' ;
    rdfs:comment 'The full name of the Substance Abuse Professional assigned to evaluate and recommend treatment for the driver, if applicable.' ;
    rdfs:domain ind:DrugAlcoholTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapReferralRequired rdf:type rdf:Property ;
    rdfs:label 'Sap Referral Required' ;
    rdfs:comment 'Indicates whether the driver must be referred to a Substance Abuse Professional (SAP) for evaluation and treatment following a positive, adulterated, substituted, or refused test.' ;
    rdfs:domain ind:DrugAlcoholTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specimenNumber rdf:type rdf:Property ;
    rdfs:label 'Specimen Number' ;
    rdfs:comment 'The unique identifier assigned to the specimen (urine, breath, oral fluid) for chain-of-custody tracking.' ;
    rdfs:domain ind:DrugAlcoholTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substanceTested rdf:type rdf:Property ;
    rdfs:label 'Substance Tested' ;
    rdfs:comment 'Indicates whether the test screened for drugs (5-panel or 10-panel), alcohol (breath or saliva), or both substances.' ;
    rdfs:domain ind:DrugAlcoholTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supervisorName rdf:type rdf:Property ;
    rdfs:label 'Supervisor Name' ;
    rdfs:comment 'The name of the trained supervisor who made the reasonable suspicion determination, if applicable. Null if not a reasonable suspicion test.' ;
    rdfs:domain ind:DrugAlcoholTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testResult rdf:type rdf:Property ;
    rdfs:label 'Test Result' ;
    rdfs:comment 'The final outcome of the test as determined by the MRO or Breath Alcohol Technician (BAT): negative (no substances detected), positive (substance detected above threshold), dilute (specimen too diluted), substituted (not human urine), adulterated (specimen tampered), cancelled (invalid test), or refused (driver refused to test). [ENUM-REF-CANDIDATE: negative|positive|dilute|substituted|adulterated|cancelled|refused — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testStatus rdf:type rdf:Property ;
    rdfs:label 'Test Status' ;
    rdfs:comment 'The current administrative status of the test record: scheduled (test appointment set), completed (result finalized), cancelled (test invalidated), refused (driver refused to test), or pending review (awaiting MRO verification).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testTime rdf:type rdf:Property ;
    rdfs:label 'Test Time' ;
    rdfs:comment 'The precise timestamp when the specimen was collected or breath test was administered.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:testType rdf:type rdf:Property ;
    rdfs:label 'Test Type' ;
    rdfs:comment 'The category of DOT-mandated test: pre-employment (before hire), random (unannounced selection), post-accident (after qualifying incident), reasonable suspicion (supervisor-initiated), return-to-duty (after violation), or follow-up (ongoing monitoring).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fleetInsuranceId rdf:type rdf:Property ;
    rdfs:label 'Fleet Insurance Id' ;
    rdfs:comment 'Unique identifier for the fleet insurance policy record. Primary key.' ;
    rdfs:domain ind:FleetInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:carrierVendorId rdf:type rdf:Property ;
    rdfs:label 'Carrier Vendor Id' ;
    rdfs:comment 'Foreign key linking to procurement.vendor. Business justification: Insurance carriers are vendors providing insurance services. Critical for vendor management, policy renewal tracking, claims processing, payment management. Role-prefixed to distinguish from other ven' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:cargoCoverageLimit rdf:type rdf:Property ;
    rdfs:label 'Cargo Coverage Limit' ;
    rdfs:comment 'Maximum amount the insurer will pay for damage to cargo being transported.' ;
    rdfs:domain ind:FleetInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carrierPolicyNumber rdf:type rdf:Property ;
    rdfs:label 'Carrier Policy Number' ;
    rdfs:comment 'Insurance carrier\'s internal identifier for this policy.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateIssueDate rdf:type rdf:Property ;
    rdfs:label 'Certificate Issue Date' ;
    rdfs:comment 'Date when the certificate of insurance was issued.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificateOfInsuranceNumber rdf:type rdf:Property ;
    rdfs:label 'Certificate Of Insurance Number' ;
    rdfs:comment 'Unique identifier for the certificate of insurance document issued for this policy.' ;
    rdfs:domain ind:FleetInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimsPhoneNumber rdf:type rdf:Property ;
    rdfs:label 'Claims Phone Number' ;
    rdfs:comment 'Phone number to contact the insurance carrier for filing claims.' ;
    rdfs:domain ind:FleetInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageTerritory rdf:type rdf:Property ;
    rdfs:label 'Coverage Territory' ;
    rdfs:comment 'Geographic territories where the insurance coverage is valid (e.g., USA, Canada, Mexico).' ;
    rdfs:domain ind:FleetInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dotFilingType rdf:type rdf:Property ;
    rdfs:label 'Dot Filing Type' ;
    rdfs:comment 'Type of DOT insurance filing form submitted to demonstrate financial responsibility.' ;
    rdfs:domain ind:FleetInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dotMinimumComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Dot Minimum Compliance Flag' ;
    rdfs:comment 'Indicates whether this policy meets DOT minimum financial responsibility requirements for commercial motor vehicles.' ;
    rdfs:domain ind:FleetInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:excludedDrivers rdf:type rdf:Property ;
    rdfs:label 'Excluded Drivers' ;
    rdfs:comment 'List of drivers explicitly excluded from coverage under this policy.' ;
    rdfs:domain ind:FleetInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liabilityCoverageLimit rdf:type rdf:Property ;
    rdfs:label 'Liability Coverage Limit' ;
    rdfs:comment 'Maximum amount the insurer will pay for liability claims per occurrence.' ;
    rdfs:domain ind:FleetInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:namedInsured rdf:type rdf:Property ;
    rdfs:label 'Named Insured' ;
    rdfs:comment 'Legal name of the entity or person listed as the insured party on the policy.' ;
    rdfs:domain ind:FleetInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextAuditDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Audit Due Date' ;
    rdfs:comment 'Scheduled date for the next insurance audit.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:physicalDamageCoverageLimit rdf:type rdf:Property ;
    rdfs:label 'Physical Damage Coverage Limit' ;
    rdfs:comment 'Maximum amount the insurer will pay for physical damage to the insured vehicle.' ;
    rdfs:domain ind:FleetInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:policyDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Policy Document Url' ;
    rdfs:comment 'URL or file path to the digital copy of the insurance policy document.' ;
    rdfs:domain ind:FleetInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyEndorsements rdf:type rdf:Property ;
    rdfs:label 'Policy Endorsements' ;
    rdfs:comment 'Additional endorsements or riders attached to the base policy that modify coverage terms.' ;
    rdfs:domain ind:FleetInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyStatus rdf:type rdf:Property ;
    rdfs:label 'Policy Status' ;
    rdfs:comment 'Current lifecycle status of the insurance policy.' ;
    rdfs:domain ind:FleetInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyType rdf:type rdf:Property ;
    rdfs:label 'Policy Type' ;
    rdfs:comment 'Type of commercial auto insurance coverage provided by this policy.' ;
    rdfs:domain ind:FleetInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:radiusOfOperation rdf:type rdf:Property ;
    rdfs:label 'Radius Of Operation' ;
    rdfs:comment 'Geographic operating radius covered by the policy (local, regional, or nationwide).' ;
    rdfs:domain ind:FleetInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Date' ;
    rdfs:comment 'Scheduled date for policy renewal evaluation and processing.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:uninsuredMotoristCoverageLimit rdf:type rdf:Property ;
    rdfs:label 'Uninsured Motorist Coverage Limit' ;
    rdfs:comment 'Maximum amount the insurer will pay for damages caused by uninsured or underinsured motorists.' ;
    rdfs:domain ind:FleetInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vehicleUseClassification rdf:type rdf:Property ;
    rdfs:label 'Vehicle Use Classification' ;
    rdfs:comment 'Classification of how the insured vehicle is used, affecting coverage terms and premium.' ;
    rdfs:domain ind:FleetInsurance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelTransactionId rdf:type rdf:Property ;
    rdfs:label 'Fuel Transaction Id' ;
    rdfs:comment 'Unique identifier for the fuel transaction record. Primary key.' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fuelingStationId rdf:type rdf:Property ;
    rdfs:label 'Fueling Station Id' ;
    rdfs:comment 'Identifier of the fueling location. May be internal yard pump ID or external commercial station identifier from fuel card network.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FuelingStation .

ind:fuelingWteFacilityId rdf:type rdf:Property ;
    rdfs:label 'Fueling Wte Facility Id' ;
    rdfs:comment 'Foreign key linking to energy.wte_facility. Business justification: Many WTE facilities have on-site fueling stations for fleet vehicles. Fuel transactions need to link to the WTE facility where fueling occurred for cost allocation, facility-specific fuel inventory ma' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WteFacility .

ind:authorizationCode rdf:type rdf:Property ;
    rdfs:label 'Authorization Code' ;
    rdfs:comment 'Authorization or approval code from the fuel card processor or yard pump system. Used for transaction reconciliation and dispute resolution.' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defQuantityDispensed rdf:type rdf:Property ;
    rdfs:label 'Def Quantity Dispensed' ;
    rdfs:comment 'Volume of DEF (Diesel Exhaust Fluid) dispensed in gallons during this transaction. Required for diesel vehicles with SCR emissions systems to meet EPA standards.' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelCardNumber rdf:type rdf:Property ;
    rdfs:label 'Fuel Card Number' ;
    rdfs:comment 'Fleet fuel card number used for the transaction. Masked or tokenized for security. Used to reconcile with fuel card provider statements.' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelGrade rdf:type rdf:Property ;
    rdfs:label 'Fuel Grade' ;
    rdfs:comment 'Grade or specification of the fuel dispensed. ULSD = Ultra-Low Sulfur Diesel; B5/B20 = biodiesel blend percentages. Ensures compliance with vehicle manufacturer specifications.' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccount rdf:type rdf:Property ;
    rdfs:label 'Gl Account' ;
    rdfs:comment 'General ledger account code for fuel expense posting in SAP FI. Varies by fuel type and vehicle class.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iftaJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Ifta Jurisdiction' ;
    rdfs:comment 'Two-letter state/province code where fuel was purchased. Required for IFTA quarterly fuel tax reporting for interstate commercial vehicles.' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isEmergencyFuel rdf:type rdf:Property ;
    rdfs:label 'Is Emergency Fuel' ;
    rdfs:comment 'Flag indicating whether this was an unplanned emergency fueling event (e.g., vehicle ran low on route). Used to identify route planning issues and driver behavior patterns.' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:odometerReading rdf:type rdf:Property ;
    rdfs:label 'Odometer Reading' ;
    rdfs:comment 'Vehicle odometer reading in miles at the time of fueling. Used to calculate fuel economy (MPG or MPGe) and validate vehicle utilization.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Pre Tax Amount' ;
    rdfs:comment 'Transaction cost before fuel taxes. Calculated as total_cost minus tax_amount. Used for cost analysis and vendor invoice reconciliation.' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pumpNumber rdf:type rdf:Property ;
    rdfs:label 'Pump Number' ;
    rdfs:comment 'Identifier of the specific fuel pump or dispenser used at the fueling station. Supports pump-level performance tracking and maintenance.' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityDispensed rdf:type rdf:Property ;
    rdfs:label 'Quantity Dispensed' ;
    rdfs:comment 'Volume or energy-equivalent quantity of fuel dispensed. For liquid fuels measured in gallons; for CNG/RNG measured in GGE (Gasoline Gallon Equivalent).' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Source Transaction Reference' ;
    rdfs:comment 'Original transaction identifier from the source system. Maintains traceability to upstream system for reconciliation and issue resolution.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCost rdf:type rdf:Property ;
    rdfs:label 'Total Cost' ;
    rdfs:comment 'Total cost of the fuel transaction (quantity × unit cost). Used for cost allocation and budget tracking.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionSource rdf:type rdf:Property ;
    rdfs:label 'Transaction Source' ;
    rdfs:comment 'System or method that captured this fuel transaction. Fleet card = commercial fuel card network; yard pump = internal automated pump; telematics = vehicle onboard system; manual entry = driver-reported.' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorName rdf:type rdf:Property ;
    rdfs:label 'Vendor Name' ;
    rdfs:comment 'Name of the fuel vendor or station operator (e.g., Shell, BP, internal fleet services). Used for vendor performance analysis and contract compliance.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hosLogId rdf:type rdf:Property ;
    rdfs:label 'Hos Log Id' ;
    rdfs:comment 'Unique identifier for the Hours of Service log record. Primary key for the HOS log entry.' ;
    rdfs:domain ind:HosLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryHosDriverId rdf:type rdf:Property ;
    rdfs:label 'Primary Hos Driver Id' ;
    rdfs:comment 'Identifier of the Commercial Driver\'s License (CDL) driver who generated this HOS log entry.' ;
    rdfs:domain ind:HosLog ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Driver .

ind:breakComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Break Compliance Flag' ;
    rdfs:comment 'Boolean flag indicating whether the driver has taken the required 30-minute break after 8 hours of driving time, as mandated by FMCSA.' ;
    rdfs:domain ind:HosLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Certification Timestamp' ;
    rdfs:comment 'The timestamp when the driver certified this HOS log entry, in yyyy-MM-ddTHH:mm:ss.SSSXXX format.' ;
    rdfs:domain ind:HosLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cumulativeDrivingHours8day rdf:type rdf:Property ;
    rdfs:label 'Cumulative Driving Hours 8day' ;
    rdfs:comment 'The cumulative driving hours accumulated by the driver in the rolling 8-day window at the time of this log entry, used to enforce the 60/70-hour rule.' ;
    rdfs:domain ind:HosLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cumulativeOnDutyHours8day rdf:type rdf:Property ;
    rdfs:label 'Cumulative On Duty Hours 8day' ;
    rdfs:comment 'The cumulative on-duty hours (driving plus on-duty not driving) accumulated by the driver in the rolling 8-day window at the time of this log entry.' ;
    rdfs:domain ind:HosLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dutyStatus rdf:type rdf:Property ;
    rdfs:label 'Duty Status' ;
    rdfs:comment 'The duty status category as defined by FMCSA: off duty, sleeper berth, driving, or on-duty not driving.' ;
    rdfs:domain ind:HosLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dutyStatusEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Duty Status End Timestamp' ;
    rdfs:comment 'The precise timestamp when the driver exited this duty status, in yyyy-MM-ddTHH:mm:ss.SSSXXX format. Null if the status is still active.' ;
    rdfs:domain ind:HosLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dutyStatusStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Duty Status Start Timestamp' ;
    rdfs:comment 'The precise timestamp when the driver entered this duty status, in yyyy-MM-ddTHH:mm:ss.SSSXXX format.' ;
    rdfs:domain ind:HosLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:editFlag rdf:type rdf:Property ;
    rdfs:label 'Edit Flag' ;
    rdfs:comment 'Boolean flag indicating whether this HOS log entry has been manually edited by the driver or carrier after initial creation.' ;
    rdfs:domain ind:HosLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:editReason rdf:type rdf:Property ;
    rdfs:label 'Edit Reason' ;
    rdfs:comment 'The reason provided for any manual edit made to this HOS log entry, as required by FMCSA regulations.' ;
    rdfs:domain ind:HosLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eldDeviceCode rdf:type rdf:Property ;
    rdfs:label 'Eld Device Code' ;
    rdfs:comment 'The unique identifier of the Electronic Logging Device (ELD) that recorded this HOS log entry.' ;
    rdfs:domain ind:HosLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eldSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Eld Serial Number' ;
    rdfs:comment 'The manufacturer serial number of the ELD device used to capture this log entry.' ;
    rdfs:domain ind:HosLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gpsLatitudeEnd rdf:type rdf:Property ;
    rdfs:label 'Gps Latitude End' ;
    rdfs:comment 'The GPS latitude coordinate at the end of this duty status period, captured by the ELD device.' ;
    rdfs:domain ind:HosLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gpsLatitudeStart rdf:type rdf:Property ;
    rdfs:label 'Gps Latitude Start' ;
    rdfs:comment 'The GPS latitude coordinate at the start of this duty status period, captured by the ELD device.' ;
    rdfs:domain ind:HosLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gpsLongitudeEnd rdf:type rdf:Property ;
    rdfs:label 'Gps Longitude End' ;
    rdfs:comment 'The GPS longitude coordinate at the end of this duty status period, captured by the ELD device.' ;
    rdfs:domain ind:HosLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gpsLongitudeStart rdf:type rdf:Property ;
    rdfs:label 'Gps Longitude Start' ;
    rdfs:comment 'The GPS longitude coordinate at the start of this duty status period, captured by the ELD device.' ;
    rdfs:domain ind:HosLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hosViolationFlag rdf:type rdf:Property ;
    rdfs:label 'Hos Violation Flag' ;
    rdfs:comment 'Boolean flag indicating whether this log entry resulted in an HOS violation (exceeding driving hours, on-duty hours, or missing required breaks).' ;
    rdfs:domain ind:HosLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:locationEnd rdf:type rdf:Property ;
    rdfs:label 'Location End' ;
    rdfs:comment 'The geographic location (city, state) where the driver ended this duty status period.' ;
    rdfs:domain ind:HosLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationStart rdf:type rdf:Property ;
    rdfs:label 'Location Start' ;
    rdfs:comment 'The geographic location (city, state) where the driver began this duty status period.' ;
    rdfs:domain ind:HosLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:logDate rdf:type rdf:Property ;
    rdfs:label 'Log Date' ;
    rdfs:comment 'The calendar date for which this HOS log entry applies, in yyyy-MM-dd format.' ;
    rdfs:domain ind:HosLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remarks rdf:type rdf:Property ;
    rdfs:label 'Remarks' ;
    rdfs:comment 'Free-text remarks or annotations entered by the driver to provide additional context for this duty status period.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Shipping Document Number' ;
    rdfs:comment 'The reference number of the shipping document or Bill of Lading (BOL) associated with the load being transported during this duty period.' ;
    rdfs:domain ind:HosLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationTypeCode rdf:type rdf:Property ;
    rdfs:label 'Violation Type Code' ;
    rdfs:comment 'The specific type of HOS violation detected: 11-hour driving limit, 14-hour on-duty limit, 30-minute break requirement, 60/70-hour limit, or none if no violation occurred.' ;
    rdfs:domain ind:HosLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceScheduleId rdf:type rdf:Property ;
    rdfs:label 'Maintenance Schedule Id' ;
    rdfs:comment 'Unique identifier for the preventive maintenance schedule entry. Primary key.' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignedFacilityId rdf:type rdf:Property ;
    rdfs:label 'Assigned Facility Id' ;
    rdfs:comment 'Reference to the maintenance facility or yard where this preventive maintenance is scheduled to be performed.' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:serviceChecklistTemplateId rdf:type rdf:Property ;
    rdfs:label 'Service Checklist Template Id' ;
    rdfs:comment 'Reference to the standardized service checklist template that defines the tasks and inspections to be performed during this preventive maintenance.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceChecklistTemplate .

ind:actualCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Timestamp' ;
    rdfs:comment 'The precise timestamp when this preventive maintenance was completed.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:calendarIntervalDays rdf:type rdf:Property ;
    rdfs:label 'Calendar Interval Days' ;
    rdfs:comment 'The calendar-based interval (in days) at which this preventive maintenance is scheduled to occur.' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:completionEngineHours rdf:type rdf:Property ;
    rdfs:label 'Completion Engine Hours' ;
    rdfs:comment 'The vehicle engine hours at the time this preventive maintenance was completed.' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:completionOdometerMiles rdf:type rdf:Property ;
    rdfs:label 'Completion Odometer Miles' ;
    rdfs:comment 'The vehicle odometer reading (in miles) at the time this preventive maintenance was completed.' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:costCurrency rdf:type rdf:Property ;
    rdfs:label 'Cost Currency' ;
    rdfs:comment 'The ISO 4217 three-letter currency code for cost amounts (e.g., USD).' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectsDescription rdf:type rdf:Property ;
    rdfs:label 'Defects Description' ;
    rdfs:comment 'Detailed description of any defects or issues identified during this preventive maintenance service.' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectsFoundFlag rdf:type rdf:Property ;
    rdfs:label 'Defects Found Flag' ;
    rdfs:comment 'Indicates whether any defects or issues were identified during this preventive maintenance service.' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dotInspectionFlag rdf:type rdf:Property ;
    rdfs:label 'Dot Inspection Flag' ;
    rdfs:comment 'Indicates whether this preventive maintenance includes a DOT annual inspection requirement.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:emissionsInspectionFlag rdf:type rdf:Property ;
    rdfs:label 'Emissions Inspection Flag' ;
    rdfs:comment 'Indicates whether this preventive maintenance includes an emissions inspection requirement per EPA and state regulations.' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:engineHoursInterval rdf:type rdf:Property ;
    rdfs:label 'Engine Hours Interval' ;
    rdfs:comment 'The engine hours interval at which this preventive maintenance is scheduled to occur.' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedDurationHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Duration Hours' ;
    rdfs:comment 'The estimated duration (in hours) required to complete this preventive maintenance service.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedLaborCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Labor Cost' ;
    rdfs:comment 'The estimated labor cost for this preventive maintenance service.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedPartsCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Parts Cost' ;
    rdfs:comment 'The estimated cost of parts required for this preventive maintenance service.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fmcsaRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Fmcsa Required Flag' ;
    rdfs:comment 'Indicates whether this preventive maintenance is required by FMCSA regulations for DOT compliance.' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Last Completed Date' ;
    rdfs:comment 'The date when this preventive maintenance was last completed.' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastCompletedEngineHours rdf:type rdf:Property ;
    rdfs:label 'Last Completed Engine Hours' ;
    rdfs:comment 'The vehicle engine hours at the time this preventive maintenance was last completed.' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastCompletedOdometerMiles rdf:type rdf:Property ;
    rdfs:label 'Last Completed Odometer Miles' ;
    rdfs:comment 'The vehicle odometer reading (in miles) at the time this preventive maintenance was last completed.' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mileageInterval rdf:type rdf:Property ;
    rdfs:label 'Mileage Interval' ;
    rdfs:comment 'The mileage interval (in miles) at which this preventive maintenance is scheduled to occur.' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextDueEngineHours rdf:type rdf:Property ;
    rdfs:label 'Next Due Engine Hours' ;
    rdfs:comment 'The calculated engine hours at which this preventive maintenance is next due based on engine hours interval.' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextDueOdometerMiles rdf:type rdf:Property ;
    rdfs:label 'Next Due Odometer Miles' ;
    rdfs:comment 'The calculated odometer reading (in miles) at which this preventive maintenance is next due based on mileage interval.' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pmType rdf:type rdf:Property ;
    rdfs:label 'Pm Type' ;
    rdfs:comment 'Classification of the preventive maintenance service level (A-service for minor, B-service for intermediate, C-service for major overhaul, annual inspection, DOT inspection, emissions inspection).' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleNumber rdf:type rdf:Property ;
    rdfs:label 'Schedule Number' ;
    rdfs:comment 'Business identifier for the preventive maintenance schedule, used for tracking and reference in Infor EAM.' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggerType rdf:type rdf:Property ;
    rdfs:label 'Trigger Type' ;
    rdfs:comment 'The basis for triggering this preventive maintenance event: mileage-based, engine hours-based, calendar-based, or combined criteria per FMCSA requirements.' ;
    rdfs:domain ind:MaintenanceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prePostTripInspectionId rdf:type rdf:Property ;
    rdfs:label 'Pre Post Trip Inspection Id' ;
    rdfs:comment 'Unique identifier for the pre-trip or post-trip vehicle inspection record.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PrePostTripInspection .

ind:trailerId rdf:type rdf:Property ;
    rdfs:label 'Trailer Id' ;
    rdfs:comment 'Identifier of the trailer unit attached to the vehicle during inspection, if applicable.' ;
    rdfs:domain ind:PrePostTripInspection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TransferTrailer .

ind:bodyFrameStatus rdf:type rdf:Property ;
    rdfs:label 'Body Frame Status' ;
    rdfs:comment 'Inspection result for the vehicle body, frame, and structural integrity including container body, hydraulic systems, and visible damage.' ;
    rdfs:domain ind:PrePostTripInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brakesStatus rdf:type rdf:Property ;
    rdfs:label 'Brakes Status' ;
    rdfs:comment 'Inspection result for the vehicle braking system including service brakes, parking brake, and emergency brake.' ;
    rdfs:domain ind:PrePostTripInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:couplingDevicesStatus rdf:type rdf:Property ;
    rdfs:label 'Coupling Devices Status' ;
    rdfs:comment 'Inspection result for fifth wheel, pintle hook, or other coupling devices used to attach trailers.' ;
    rdfs:domain ind:PrePostTripInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectDescription rdf:type rdf:Property ;
    rdfs:label 'Defect Description' ;
    rdfs:comment 'Detailed description of any defects, safety concerns, or maintenance issues identified during the inspection.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectReportedFlag rdf:type rdf:Property ;
    rdfs:label 'Defect Reported Flag' ;
    rdfs:comment 'Indicates whether any defects or safety concerns were identified during the inspection that require maintenance attention.' ;
    rdfs:domain ind:PrePostTripInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:defectSeverity rdf:type rdf:Property ;
    rdfs:label 'Defect Severity' ;
    rdfs:comment 'Classification of the defect severity: critical (vehicle out-of-service), major (requires immediate attention), or minor (can be scheduled for repair).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyEquipmentStatus rdf:type rdf:Property ;
    rdfs:label 'Emergency Equipment Status' ;
    rdfs:comment 'Inspection result for emergency equipment including fire extinguisher, warning triangles, first aid kit, and spill kit.' ;
    rdfs:domain ind:PrePostTripInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exhaustSystemStatus rdf:type rdf:Property ;
    rdfs:label 'Exhaust System Status' ;
    rdfs:comment 'Inspection result for the exhaust system including muffler, pipes, and emissions control components.' ;
    rdfs:domain ind:PrePostTripInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelSystemStatus rdf:type rdf:Property ;
    rdfs:label 'Fuel System Status' ;
    rdfs:comment 'Inspection result for the fuel system including tank, lines, and connections for leaks or damage. Applies to diesel, CNG, and RNG fuel systems.' ;
    rdfs:domain ind:PrePostTripInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hornStatus rdf:type rdf:Property ;
    rdfs:label 'Horn Status' ;
    rdfs:comment 'Inspection result for the vehicle horn functionality.' ;
    rdfs:domain ind:PrePostTripInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionSource rdf:type rdf:Property ;
    rdfs:label 'Inspection Source' ;
    rdfs:comment 'The method or system used to capture the inspection data: mobile application, paper form (later digitized), or telematics system.' ;
    rdfs:domain ind:PrePostTripInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lightsStatus rdf:type rdf:Property ;
    rdfs:label 'Lights Status' ;
    rdfs:comment 'Inspection result for all vehicle lighting including headlights, taillights, brake lights, turn signals, and hazard lights.' ;
    rdfs:domain ind:PrePostTripInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mechanicAcknowledgmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Mechanic Acknowledgment Timestamp' ;
    rdfs:comment 'The date and time when the mechanic reviewed and acknowledged the inspection report, required for regulatory compliance.' ;
    rdfs:domain ind:PrePostTripInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:mirrorsStatus rdf:type rdf:Property ;
    rdfs:label 'Mirrors Status' ;
    rdfs:comment 'Inspection result for all vehicle mirrors including side mirrors and rearview mirrors for proper adjustment and condition.' ;
    rdfs:domain ind:PrePostTripInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:steeringStatus rdf:type rdf:Property ;
    rdfs:label 'Steering Status' ;
    rdfs:comment 'Inspection result for the steering system including steering wheel, linkage, and power steering operation.' ;
    rdfs:domain ind:PrePostTripInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tiresStatus rdf:type rdf:Property ;
    rdfs:label 'Tires Status' ;
    rdfs:comment 'Inspection result for all vehicle tires including tread depth, inflation, and visible damage.' ;
    rdfs:domain ind:PrePostTripInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trailerUnitNumber rdf:type rdf:Property ;
    rdfs:label 'Trailer Unit Number' ;
    rdfs:comment 'The fleet unit number or asset tag of the trailer inspected, if applicable.' ;
    rdfs:domain ind:PrePostTripInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wipersStatus rdf:type rdf:Property ;
    rdfs:label 'Wipers Status' ;
    rdfs:comment 'Inspection result for windshield wipers and washer system functionality.' ;
    rdfs:domain ind:PrePostTripInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:telematicsEventId rdf:type rdf:Property ;
    rdfs:label 'Telematics Event Id' ;
    rdfs:comment 'Unique identifier for each telematics event record captured from the vehicle tracking system.' ;
    rdfs:domain ind:TelematicsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:geofenceZoneId rdf:type rdf:Property ;
    rdfs:label 'Geofence Zone Id' ;
    rdfs:comment 'Identifier of the geographic boundary zone the vehicle was within at the time of the event.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GeofenceZone .

ind:altitudeFeet rdf:type rdf:Property ;
    rdfs:label 'Altitude Feet' ;
    rdfs:comment 'Elevation of the vehicle above sea level measured in feet at the time of the event.' ;
    rdfs:domain ind:TelematicsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batteryVoltage rdf:type rdf:Property ;
    rdfs:label 'Battery Voltage' ;
    rdfs:comment 'Vehicle battery voltage measured in volts at the time of the event.' ;
    rdfs:domain ind:TelematicsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coolantTemperatureFahrenheit rdf:type rdf:Property ;
    rdfs:label 'Coolant Temperature Fahrenheit' ;
    rdfs:comment 'Engine coolant temperature measured in degrees Fahrenheit at the time of the event.' ;
    rdfs:domain ind:TelematicsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deviceSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Device Serial Number' ;
    rdfs:comment 'Unique serial number of the telematics tracking device installed in the vehicle.' ;
    rdfs:domain ind:TelematicsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engineLoadPercent rdf:type rdf:Property ;
    rdfs:label 'Engine Load Percent' ;
    rdfs:comment 'Percentage of maximum engine load being utilized at the time of the event.' ;
    rdfs:domain ind:TelematicsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:engineRpm rdf:type rdf:Property ;
    rdfs:label 'Engine Rpm' ;
    rdfs:comment 'Engine speed measured in revolutions per minute at the time of the event.' ;
    rdfs:domain ind:TelematicsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fuelConsumptionGallons rdf:type rdf:Property ;
    rdfs:label 'Fuel Consumption Gallons' ;
    rdfs:comment 'Cumulative fuel consumed by the vehicle measured in gallons since the last reset or event.' ;
    rdfs:domain ind:TelematicsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:harshAccelerationFlag rdf:type rdf:Property ;
    rdfs:label 'Harsh Acceleration Flag' ;
    rdfs:comment 'Indicator of whether a harsh acceleration event occurred based on acceleration thresholds.' ;
    rdfs:domain ind:TelematicsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:harshBrakingFlag rdf:type rdf:Property ;
    rdfs:label 'Harsh Braking Flag' ;
    rdfs:comment 'Indicator of whether a harsh braking event occurred based on deceleration thresholds.' ;
    rdfs:domain ind:TelematicsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:idleDurationFlag rdf:type rdf:Property ;
    rdfs:label 'Idle Duration Flag' ;
    rdfs:comment 'Indicator of whether the vehicle was idling for an extended period at the time of the event.' ;
    rdfs:domain ind:TelematicsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:idleTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Idle Time Minutes' ;
    rdfs:comment 'Duration of time the vehicle engine was running while stationary measured in minutes.' ;
    rdfs:domain ind:TelematicsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ignitionStatus rdf:type rdf:Property ;
    rdfs:label 'Ignition Status' ;
    rdfs:comment 'Current state of the vehicle ignition indicating whether the engine is running or off.' ;
    rdfs:domain ind:TelematicsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ptoStatus rdf:type rdf:Property ;
    rdfs:label 'Pto Status' ;
    rdfs:comment 'Current state of the power take-off mechanism indicating whether it is engaged for auxiliary equipment operation.' ;
    rdfs:domain ind:TelematicsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seatbeltStatus rdf:type rdf:Property ;
    rdfs:label 'Seatbelt Status' ;
    rdfs:comment 'Current state of the driver seatbelt indicating whether it is fastened or unfastened.' ;
    rdfs:domain ind:TelematicsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:speedingFlag rdf:type rdf:Property ;
    rdfs:label 'Speeding Flag' ;
    rdfs:comment 'Indicator of whether the vehicle was exceeding the posted speed limit at the time of the event.' ;
    rdfs:domain ind:TelematicsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastComplianceInspectionId rdf:type rdf:Property ;
    rdfs:label 'Last Compliance Inspection Id' ;
    rdfs:comment 'Foreign key linking to compliance.compliance_inspection. Business justification: Vehicles undergo DOT roadside inspections, annual emissions testing, and safety inspections. Fleet managers track last inspection results to schedule corrective actions and maintain CSA scores. Direct' ;
    rdfs:domain ind:Vehicle ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ComplianceInspection .

ind:primaryOperatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Operator Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Fleet operations track primary assigned operator for maintenance scheduling, insurance rating, asset accountability, and lifecycle cost allocation beyond temporary driver assignments in vehicle_assign' ;
    rdfs:domain ind:Vehicle ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryWteFacilityId rdf:type rdf:Property ;
    rdfs:label 'Primary Wte Facility Id' ;
    rdfs:comment 'Foreign key linking to energy.wte_facility. Business justification: Waste collection vehicles are often assigned to deliver to specific WTE facilities as their primary disposal destination. Operations teams need to track which vehicles regularly service which energy f' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WteFacility .

ind:vehicleClassId rdf:type rdf:Property ;
    rdfs:label 'Vehicle Class Id' ;
    rdfs:comment 'Foreign key linking to fleet.vehicle_class. Business justification: Vehicle references its classification for standardized specifications, PM intervals, cost benchmarks, and operational parameters. The vehicle table currently has a vehicle_class STRING attribute that ' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VehicleClass .

ind:axleConfiguration rdf:type rdf:Property ;
    rdfs:label 'Axle Configuration' ;
    rdfs:comment 'Axle arrangement of the vehicle (e.g., 4x2, 6x4, 8x4) indicating total wheels and driven wheels.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bodyCapacityCubicYards rdf:type rdf:Property ;
    rdfs:label 'Body Capacity Cubic Yards' ;
    rdfs:comment 'Maximum volume capacity of the vehicle body measured in cubic yards.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bodyType rdf:type rdf:Property ;
    rdfs:label 'Body Type' ;
    rdfs:comment 'Type of vehicle body configuration. ASL = Automated Side Loader, FEL = Front End Loader, REL = Rear End Loader. [ENUM-REF-CANDIDATE: ASL|FEL|REL|Roll-Off|Transfer Tractor|Service Truck|Pickup|Van|Other — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdlRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Cdl Required Flag' ;
    rdfs:comment 'Indicates whether a Commercial Driver License (CDL) is required to operate this vehicle based on GVWR and vehicle class.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:compactionType rdf:type rdf:Property ;
    rdfs:label 'Compaction Type' ;
    rdfs:comment 'Type of waste compaction mechanism installed on the vehicle body.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentEngineHours rdf:type rdf:Property ;
    rdfs:label 'Current Engine Hours' ;
    rdfs:comment 'Most recent engine hour meter reading recorded for the vehicle.' ;
    rdfs:domain ind:Vehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:currentOdometerMiles rdf:type rdf:Property ;
    rdfs:label 'Current Odometer Miles' ;
    rdfs:comment 'Most recent odometer reading recorded for the vehicle, measured in miles.' ;
    rdfs:domain ind:Vehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dotNumber rdf:type rdf:Property ;
    rdfs:label 'Dot Number' ;
    rdfs:comment 'DOT registration number assigned to the vehicle for interstate commerce compliance.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emissionsCertification rdf:type rdf:Property ;
    rdfs:label 'Emissions Certification' ;
    rdfs:comment 'EPA emissions standard certification level (e.g., EPA 2010, EPA 2021, CARB compliant).' ;
    rdfs:domain ind:Vehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engineMake rdf:type rdf:Property ;
    rdfs:label 'Engine Make' ;
    rdfs:comment 'Manufacturer of the engine installed in the vehicle (e.g., Cummins, Detroit Diesel, Paccar).' ;
    rdfs:domain ind:Vehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engineModel rdf:type rdf:Property ;
    rdfs:label 'Engine Model' ;
    rdfs:comment 'Specific model designation of the engine.' ;
    rdfs:domain ind:Vehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engineSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Engine Serial Number' ;
    rdfs:comment 'Unique serial number assigned to the engine by the manufacturer for warranty and service tracking.' ;
    rdfs:domain ind:Vehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelTankCapacityGallons rdf:type rdf:Property ;
    rdfs:label 'Fuel Tank Capacity Gallons' ;
    rdfs:comment 'Total fuel tank capacity measured in gallons (or gallon-equivalent for CNG/RNG).' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gvwr rdf:type rdf:Property ;
    rdfs:label 'Gvwr' ;
    rdfs:comment 'Maximum operating weight of the vehicle including chassis, body, engine, fuel, driver, passengers, and cargo, measured in pounds.' ;
    rdfs:domain ind:Vehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:homeYardLocation rdf:type rdf:Property ;
    rdfs:label 'Home Yard Location' ;
    rdfs:comment 'Name or identifier of the primary yard or facility where the vehicle is based for daily operations.' ;
    rdfs:domain ind:Vehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hydraulicSystemType rdf:type rdf:Property ;
    rdfs:label 'Hydraulic System Type' ;
    rdfs:comment 'Type of hydraulic system used for compaction and lifting operations (applicable to collection vehicles).' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liftMechanism rdf:type rdf:Property ;
    rdfs:label 'Lift Mechanism' ;
    rdfs:comment 'Type of lifting mechanism used to pick up and empty containers or bins. [ENUM-REF-CANDIDATE: Automated Arm|Manual|Front Forks|Rear Forks|Hook Lift|Cable Hoist|N/A — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:make rdf:type rdf:Property ;
    rdfs:label 'Make' ;
    rdfs:comment 'Manufacturer of the vehicle (e.g., Mack, Peterbilt, Freightliner, International).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextPmDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Pm Due Date' ;
    rdfs:comment 'Scheduled date for the next preventive maintenance service based on time or usage intervals.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:payloadCapacityLbs rdf:type rdf:Property ;
    rdfs:label 'Payload Capacity Lbs' ;
    rdfs:comment 'Maximum weight of waste or cargo the vehicle can legally carry, measured in pounds.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vehicleAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Vehicle Assignment Id' ;
    rdfs:comment 'Unique identifier for the vehicle assignment record. Primary key for the vehicle assignment entity.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VehicleAssignment .

ind:deliveryWteFacilityId rdf:type rdf:Property ;
    rdfs:label 'Delivery Wte Facility Id' ;
    rdfs:comment 'Foreign key linking to energy.wte_facility. Business justification: Daily vehicle assignments include deliveries to WTE facilities. Dispatch and operations need to track which vehicle/driver delivered waste to which energy facility on each shift for load reconciliatio' ;
    rdfs:domain ind:VehicleAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WteFacility .

ind:dispatcherEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Dispatcher Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Dispatchers assign vehicles to routes and drivers daily, critical for operational accountability, shift planning, HOS compliance verification, and route optimization decisions.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:cdlVerified rdf:type rdf:Property ;
    rdfs:label 'Cdl Verified' ;
    rdfs:comment 'Boolean flag indicating whether the drivers Commercial Driver License (CDL) was verified as valid and appropriate for the vehicle class at the time of assignment. Required for DOT compliance.' ;
    rdfs:domain ind:VehicleAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:defectsReported rdf:type rdf:Property ;
    rdfs:label 'Defects Reported' ;
    rdfs:comment 'Boolean flag indicating whether any vehicle defects or maintenance issues were reported during the pre-trip or post-trip inspection for this assignment.' ;
    rdfs:domain ind:VehicleAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dispatchLocation rdf:type rdf:Property ;
    rdfs:label 'Dispatch Location' ;
    rdfs:comment 'The facility or yard location from which the vehicle was dispatched for this assignment. Typically the operating base or depot.' ;
    rdfs:domain ind:VehicleAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engineHoursEnd rdf:type rdf:Property ;
    rdfs:label 'Engine Hours End' ;
    rdfs:comment 'The cumulative engine operating hours at the end of the assignment. Used for preventive maintenance scheduling and asset lifecycle management.' ;
    rdfs:domain ind:VehicleAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:engineHoursStart rdf:type rdf:Property ;
    rdfs:label 'Engine Hours Start' ;
    rdfs:comment 'The cumulative engine operating hours at the beginning of the assignment. Used for preventive maintenance scheduling and asset lifecycle management.' ;
    rdfs:domain ind:VehicleAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelLevelEndPercent rdf:type rdf:Property ;
    rdfs:label 'Fuel Level End Percent' ;
    rdfs:comment 'The fuel tank level as a percentage at the end of the assignment. Used for fuel consumption tracking and refueling planning.' ;
    rdfs:domain ind:VehicleAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelLevelStartPercent rdf:type rdf:Property ;
    rdfs:label 'Fuel Level Start Percent' ;
    rdfs:comment 'The fuel tank level as a percentage at the beginning of the assignment. Used for fuel consumption tracking and refueling planning.' ;
    rdfs:domain ind:VehicleAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hosCompliant rdf:type rdf:Property ;
    rdfs:label 'Hos Compliant' ;
    rdfs:comment 'Boolean flag indicating whether the driver was in compliance with Hours of Service (HOS) regulations at the time of assignment. Ensures driver has adequate rest and is within allowable driving hours.' ;
    rdfs:domain ind:VehicleAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postTripInspectionCompleted rdf:type rdf:Property ;
    rdfs:label 'Post Trip Inspection Completed' ;
    rdfs:comment 'Boolean flag indicating whether the driver completed the mandatory post-trip vehicle inspection after completing the shift. Required for DOT compliance and vehicle maintenance tracking.' ;
    rdfs:domain ind:VehicleAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preTripInspectionCompleted rdf:type rdf:Property ;
    rdfs:label 'Pre Trip Inspection Completed' ;
    rdfs:comment 'Boolean flag indicating whether the driver completed the mandatory pre-trip vehicle inspection before beginning the shift. Required for DOT compliance.' ;
    rdfs:domain ind:VehicleAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:returnLocation rdf:type rdf:Property ;
    rdfs:label 'Return Location' ;
    rdfs:comment 'The facility or yard location to which the vehicle was returned at the end of the assignment. May differ from dispatch location for transfer operations.' ;
    rdfs:domain ind:VehicleAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyIncidentOccurred rdf:type rdf:Property ;
    rdfs:label 'Safety Incident Occurred' ;
    rdfs:comment 'Boolean flag indicating whether any safety incident, accident, or near-miss event occurred during this vehicle assignment. Triggers incident investigation and reporting workflow.' ;
    rdfs:domain ind:VehicleAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fleetManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Fleet Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Fleet managers define vehicle class specifications, PM intervals, lifecycle policies, and procurement standards for fleet standardization, total cost of ownership analysis, and capital planning.' ;
    rdfs:domain ind:VehicleClass ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:annualInspectionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Annual Inspection Required Flag' ;
    rdfs:comment 'Indicates whether vehicles in this class require annual DOT safety inspections. True if required, False if not.' ;
    rdfs:domain ind:VehicleClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:averageAcquisitionCostUsd rdf:type rdf:Property ;
    rdfs:label 'Average Acquisition Cost Usd' ;
    rdfs:comment 'Average acquisition cost for a new vehicle in this class, measured in US dollars. Used for capital planning and budgeting.' ;
    rdfs:domain ind:VehicleClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageAnnualOperatingCostUsd rdf:type rdf:Property ;
    rdfs:label 'Average Annual Operating Cost Usd' ;
    rdfs:comment 'Average annual operating cost for vehicles in this class including fuel, maintenance, insurance, and depreciation, measured in US dollars.' ;
    rdfs:domain ind:VehicleClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageStopsPerShift rdf:type rdf:Property ;
    rdfs:label 'Average Stops Per Shift' ;
    rdfs:comment 'Typical number of service stops this vehicle class can complete in a standard shift. Used for route planning and capacity modeling.' ;
    rdfs:domain ind:VehicleClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:averageTonsPerDay rdf:type rdf:Property ;
    rdfs:label 'Average Tons Per Day' ;
    rdfs:comment 'Average tonnage of waste this vehicle class typically collects per operating day. TPD = Tons Per Day.' ;
    rdfs:domain ind:VehicleClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:backupCameraRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Backup Camera Required Flag' ;
    rdfs:comment 'Indicates whether backup cameras are required safety equipment for this vehicle class. True if required, False if not.' ;
    rdfs:domain ind:VehicleClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bodyManufacturer rdf:type rdf:Property ;
    rdfs:label 'Body Manufacturer' ;
    rdfs:comment 'Typical or preferred body manufacturer for vehicles in this class (e.g., McNeilus, Heil, Labrie, New Way).' ;
    rdfs:domain ind:VehicleClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classCode rdf:type rdf:Property ;
    rdfs:label 'Class Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the vehicle class (e.g., ASL-20, FEL-30, REL-25, ROLLOFF-40). Used as the business identifier for classification.' ;
    rdfs:domain ind:VehicleClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:className rdf:type rdf:Property ;
    rdfs:label 'Class Name' ;
    rdfs:comment 'Full descriptive name of the vehicle class (e.g., Automated Side Loader 20-Yard, Front End Loader 30-Yard, Rear End Loader 25-Yard, Roll-Off Truck 40-Yard).' ;
    rdfs:domain ind:VehicleClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crewSize rdf:type rdf:Property ;
    rdfs:label 'Crew Size' ;
    rdfs:comment 'Standard crew size for vehicles in this class (e.g., 1 for automated side loaders, 2-3 for rear loaders with helpers).' ;
    rdfs:domain ind:VehicleClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dotVehicleClass rdf:type rdf:Property ;
    rdfs:label 'Dot Vehicle Class' ;
    rdfs:comment 'DOT vehicle classification number (1-8) based on GVWR. Class 1-2: light duty, 3-6: medium duty, 7-8: heavy duty.' ;
    rdfs:domain ind:VehicleClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emissionsStandard rdf:type rdf:Property ;
    rdfs:label 'Emissions Standard' ;
    rdfs:comment 'EPA emissions standard certification level for this vehicle class (e.g., EPA 2010, EPA 2021, CARB Ultra-Low NOx).' ;
    rdfs:domain ind:VehicleClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endorsementsRequired rdf:type rdf:Property ;
    rdfs:label 'Endorsements Required' ;
    rdfs:comment 'Comma-separated list of CDL endorsements required for this vehicle class (e.g., H for hazmat, N for tank, X for hazmat+tank). Null if no endorsements required.' ;
    rdfs:domain ind:VehicleClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedUsefulLifeMiles rdf:type rdf:Property ;
    rdfs:label 'Expected Useful Life Miles' ;
    rdfs:comment 'Expected useful life of vehicles in this class measured in miles before replacement is typically required.' ;
    rdfs:domain ind:VehicleClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expectedUsefulLifeYears rdf:type rdf:Property ;
    rdfs:label 'Expected Useful Life Years' ;
    rdfs:comment 'Expected useful life of vehicles in this class measured in years before replacement is typically required.' ;
    rdfs:domain ind:VehicleClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gvwrLbs rdf:type rdf:Property ;
    rdfs:label 'Gvwr Lbs' ;
    rdfs:comment 'Gross Vehicle Weight Rating in pounds. Maximum total weight of the vehicle including chassis, body, fuel, and payload as specified by the manufacturer.' ;
    rdfs:domain ind:VehicleClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:manufacturerMake rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Make' ;
    rdfs:comment 'Typical or preferred manufacturer make for vehicles in this class (e.g., Peterbilt, Mack, Freightliner, Autocar).' ;
    rdfs:domain ind:VehicleClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pmIntervalDays rdf:type rdf:Property ;
    rdfs:label 'Pm Interval Days' ;
    rdfs:comment 'Standard preventive maintenance interval in calendar days for vehicles in this class. PM = Preventive Maintenance.' ;
    rdfs:domain ind:VehicleClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pmIntervalMiles rdf:type rdf:Property ;
    rdfs:label 'Pm Interval Miles' ;
    rdfs:comment 'Standard preventive maintenance interval in miles for vehicles in this class. PM = Preventive Maintenance.' ;
    rdfs:domain ind:VehicleClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ptoEquippedFlag rdf:type rdf:Property ;
    rdfs:label 'Pto Equipped Flag' ;
    rdfs:comment 'Indicates whether vehicles in this class are equipped with Power Take-Off systems for hydraulic operations. True if PTO-equipped, False if not.' ;
    rdfs:domain ind:VehicleClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:telematicsRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Telematics Required Flag' ;
    rdfs:comment 'Indicates whether telematics devices are required for vehicles in this class. True if required, False if optional.' ;
    rdfs:domain ind:VehicleClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:typicalRouteType rdf:type rdf:Property ;
    rdfs:label 'Typical Route Type' ;
    rdfs:comment 'Typical route type this vehicle class is optimized for (residential collection, commercial collection, industrial, transfer haul, landfill operations, or mixed use).' ;
    rdfs:domain ind:VehicleClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleCategory rdf:type rdf:Property ;
    rdfs:label 'Vehicle Category' ;
    rdfs:comment 'High-level operational category of the vehicle class (collection, transfer, roll-off, support, administrative).' ;
    rdfs:domain ind:VehicleClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleClassStatus rdf:type rdf:Property ;
    rdfs:label 'Vehicle Class Status' ;
    rdfs:comment 'Current lifecycle status of this vehicle class. Active = currently in use, Inactive = no longer procuring but existing vehicles still operational, Deprecated = phased out, Planned = future class not yet deployed.' ;
    rdfs:domain ind:VehicleClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleLifecycleEventId rdf:type rdf:Property ;
    rdfs:label 'Vehicle Lifecycle Event Id' ;
    rdfs:comment 'Unique identifier for the vehicle lifecycle event record. Primary key.' ;
    rdfs:domain ind:VehicleLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryVehicleDistrictId rdf:type rdf:Property ;
    rdfs:label 'Primary Vehicle District Id' ;
    rdfs:comment 'Reference to the operational district or service area associated with this lifecycle event. Relevant for transfer, assignment, and deployment events.' ;
    rdfs:domain ind:VehicleLifecycleEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:District .

ind:primaryVehicleId rdf:type rdf:Property ;
    rdfs:label 'Primary Vehicle Id' ;
    rdfs:comment 'Reference to the fleet vehicle unit that this lifecycle event pertains to. Links to the vehicle master record.' ;
    rdfs:domain ind:VehicleLifecycleEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vehicle .

ind:tertiaryVehicleTransferToDistrictId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Vehicle Transfer To District Id' ;
    rdfs:comment 'Reference to the destination district for vehicle transfer events. Null for non-transfer events.' ;
    rdfs:domain ind:VehicleLifecycleEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:District .

ind:yardLocationId rdf:type rdf:Property ;
    rdfs:label 'Yard Location Id' ;
    rdfs:comment 'Reference to the physical yard, depot, or maintenance facility where the vehicle was located at the time of this event.' ;
    rdfs:domain ind:VehicleLifecycleEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Location .

ind:accidentClaimNumber rdf:type rdf:Property ;
    rdfs:label 'Accident Claim Number' ;
    rdfs:comment 'The insurance claim number associated with accident damage events. Links to insurance and risk management systems.' ;
    rdfs:domain ind:VehicleLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualReturnToServiceDate rdf:type rdf:Property ;
    rdfs:label 'Actual Return To Service Date' ;
    rdfs:comment 'The actual date when the vehicle was returned to operational service. Enables comparison against estimated date for performance tracking.' ;
    rdfs:domain ind:VehicleLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disposalVendorName rdf:type rdf:Property ;
    rdfs:label 'Disposal Vendor Name' ;
    rdfs:comment 'The name of the third-party vendor, buyer, or salvage company involved in the vehicle disposal transaction.' ;
    rdfs:domain ind:VehicleLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downtimeHours rdf:type rdf:Property ;
    rdfs:label 'Downtime Hours' ;
    rdfs:comment 'The total number of hours the vehicle was unavailable for service due to this lifecycle event. Used for fleet availability and utilization KPI reporting.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedReturnToServiceDate rdf:type rdf:Property ;
    rdfs:label 'Estimated Return To Service Date' ;
    rdfs:comment 'The projected date when the vehicle is expected to return to operational service. Used for fleet availability planning and resource allocation.' ;
    rdfs:domain ind:VehicleLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:odometerReadingMiles rdf:type rdf:Property ;
    rdfs:label 'Odometer Reading Miles' ;
    rdfs:comment 'The vehicle odometer reading in miles at the time of the lifecycle event. Provides mileage-based lifecycle tracking.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oosReasonCategory rdf:type rdf:Property ;
    rdfs:label 'Oos Reason Category' ;
    rdfs:comment 'The primary reason category for an out-of-service event. Applicable only when event_type is out_of_service. Supports DOT and FMCSA compliance tracking. [ENUM-REF-CANDIDATE: dot_order|mechanical_failure|scheduled_pm|accident_damage|awaiting_parts|regulatory_hold|safety_inspection|body_repair|engine_overhaul|transmission_repair — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:VehicleLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oosReasonDetail rdf:type rdf:Property ;
    rdfs:label 'Oos Reason Detail' ;
    rdfs:comment 'Detailed explanation of the specific reason for the out-of-service status, including technical diagnosis, failure mode, or regulatory citation.' ;
    rdfs:domain ind:VehicleLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replacementVehicleAssignedFlag rdf:type rdf:Property ;
    rdfs:label 'Replacement Vehicle Assigned Flag' ;
    rdfs:comment 'Indicates whether a replacement vehicle was assigned to cover the operational capacity during an out-of-service period. True if replacement assigned, False otherwise.' ;
    rdfs:domain ind:VehicleLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transactionValueUsd rdf:type rdf:Property ;
    rdfs:label 'Transaction Value Usd' ;
    rdfs:comment 'The monetary value associated with the lifecycle event in US Dollars. Applicable for acquisition, sale, disposal, or refurbishment events. Null for non-financial events.' ;
    rdfs:domain ind:VehicleLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Work Order Number' ;
    rdfs:comment 'The maintenance or repair work order number associated with this lifecycle event. Links to Infor EAM work order records for maintenance-related events.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleRegistrationId rdf:type rdf:Property ;
    rdfs:label 'Vehicle Registration Id' ;
    rdfs:comment 'Unique identifier for the vehicle registration record. Primary key.' ;
    rdfs:domain ind:VehicleRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:annualInspectionDueDate rdf:type rdf:Property ;
    rdfs:label 'Annual Inspection Due Date' ;
    rdfs:comment 'Date by which the vehicle must complete its annual DOT safety inspection to maintain compliance. Failure to inspect by this date results in out-of-service status.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cabCardStorageLocation rdf:type rdf:Property ;
    rdfs:label 'Cab Card Storage Location' ;
    rdfs:comment 'Physical or digital location where the IRP cab card (registration document) is stored. Cab cards must be carried in the vehicle at all times for roadside inspection readiness.' ;
    rdfs:domain ind:VehicleRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossVehicleWeight rdf:type rdf:Property ;
    rdfs:label 'Gross Vehicle Weight' ;
    rdfs:comment 'Maximum allowable weight of the vehicle including cargo, as registered with the state DMV. Measured in pounds. Determines registration class and fee structure.' ;
    rdfs:domain ind:VehicleRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:iftaDecalNumber rdf:type rdf:Property ;
    rdfs:label 'Ifta Decal Number' ;
    rdfs:comment 'Unique identifier for the IFTA decal affixed to the vehicle. IFTA simplifies fuel tax reporting for commercial vehicles operating across multiple jurisdictions.' ;
    rdfs:domain ind:VehicleRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iftaExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Ifta Expiration Date' ;
    rdfs:comment 'Date when the IFTA decal expires and must be renewed. Typically aligns with calendar year end.' ;
    rdfs:domain ind:VehicleRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:irpApportionedFlag rdf:type rdf:Property ;
    rdfs:label 'Irp Apportioned Flag' ;
    rdfs:comment 'Indicates whether this vehicle is registered under the International Registration Plan (IRP), which allows commercial vehicles to travel across multiple jurisdictions with a single registration and apportioned fees.' ;
    rdfs:domain ind:VehicleRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:irpBaseJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Irp Base Jurisdiction' ;
    rdfs:comment 'Two-letter state or province code representing the base jurisdiction for IRP apportionment. This is where the carrier maintains its principal place of business.' ;
    rdfs:domain ind:VehicleRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irpFleetNumber rdf:type rdf:Property ;
    rdfs:label 'Irp Fleet Number' ;
    rdfs:comment 'Unique fleet identifier assigned under the IRP program. Used for tracking and reporting across multiple jurisdictions.' ;
    rdfs:domain ind:VehicleRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lienHolderName rdf:type rdf:Property ;
    rdfs:label 'Lien Holder Name' ;
    rdfs:comment 'Name of the financial institution or entity holding a lien on the vehicle, if applicable. Recorded on the title and registration documents.' ;
    rdfs:domain ind:VehicleRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mcNumber rdf:type rdf:Property ;
    rdfs:label 'Mc Number' ;
    rdfs:comment 'Operating authority number issued by FMCSA for carriers transporting regulated commodities in interstate commerce. Not all vehicles require an MC number.' ;
    rdfs:domain ind:VehicleRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredOwnerAddress rdf:type rdf:Property ;
    rdfs:label 'Registered Owner Address' ;
    rdfs:comment 'Mailing address of the registered owner as recorded on the vehicle registration document. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:VehicleRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredOwnerName rdf:type rdf:Property ;
    rdfs:label 'Registered Owner Name' ;
    rdfs:comment 'Legal name of the entity or individual listed as the registered owner on the vehicle registration. Typically the company name for fleet vehicles.' ;
    rdfs:domain ind:VehicleRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationClass rdf:type rdf:Property ;
    rdfs:label 'Registration Class' ;
    rdfs:comment 'Classification of the vehicle registration as defined by state DMV regulations. Determines fee structure and operational restrictions.' ;
    rdfs:domain ind:VehicleRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Registration Document Url' ;
    rdfs:comment 'URL or file path to the digital copy of the vehicle registration document. Used for electronic record-keeping and roadside inspection readiness.' ;
    rdfs:domain ind:VehicleRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Registration Fee Amount' ;
    rdfs:comment 'Total fee paid for the vehicle registration, including base registration, IRP apportionment fees, and any applicable surcharges. Denominated in USD.' ;
    rdfs:domain ind:VehicleRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:registrationFeeCurrency rdf:type rdf:Property ;
    rdfs:label 'Registration Fee Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the registration fee. Typically USD for U.S. operations.' ;
    rdfs:domain ind:VehicleRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationNumber rdf:type rdf:Property ;
    rdfs:label 'Registration Number' ;
    rdfs:comment 'The official license plate or registration number issued by the state Department of Motor Vehicles (DMV). This is the externally-known identifier displayed on the vehicle.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationStatus rdf:type rdf:Property ;
    rdfs:label 'Registration Status' ;
    rdfs:comment 'Current lifecycle status of the vehicle registration. Active registrations are compliant for road operation; expired or suspended registrations require immediate attention to maintain DOT compliance.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:titleNumber rdf:type rdf:Property ;
    rdfs:label 'Title Number' ;
    rdfs:comment 'Unique identifier for the vehicle title document issued by the state. Links registration to proof of ownership.' ;
    rdfs:domain ind:VehicleRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ucrRegistrationYear rdf:type rdf:Property ;
    rdfs:label 'Ucr Registration Year' ;
    rdfs:comment 'Calendar year for which the UCR registration is valid. UCR must be renewed annually.' ;
    rdfs:domain ind:VehicleRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ucrStatus rdf:type rdf:Property ;
    rdfs:label 'Ucr Status' ;
    rdfs:comment 'Current status of the Unified Carrier Registration for this vehicle. UCR is a federally-mandated registration system for commercial motor carriers operating in interstate commerce.' ;
    rdfs:domain ind:VehicleRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleYear rdf:type rdf:Property ;
    rdfs:label 'Vehicle Year' ;
    rdfs:comment 'Model year of the vehicle as recorded on the registration document.' ;
    rdfs:domain ind:VehicleRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vehicleUtilizationId rdf:type rdf:Property ;
    rdfs:label 'Vehicle Utilization Id' ;
    rdfs:comment 'Unique identifier for the daily vehicle utilization summary record.' ;
    rdfs:domain ind:VehicleUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignedRouteCount rdf:type rdf:Property ;
    rdfs:label 'Assigned Route Count' ;
    rdfs:comment 'Total number of routes assigned to the vehicle during the operational day.' ;
    rdfs:domain ind:VehicleUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:availableHours rdf:type rdf:Property ;
    rdfs:label 'Available Hours' ;
    rdfs:comment 'Total hours the vehicle was available for operational use during the scheduled shift.' ;
    rdfs:domain ind:VehicleUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deadheadMiles rdf:type rdf:Property ;
    rdfs:label 'Deadhead Miles' ;
    rdfs:comment 'Non-revenue miles driven, including travel to/from depot, between routes, or repositioning.' ;
    rdfs:domain ind:VehicleUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dotComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Dot Compliance Status' ;
    rdfs:comment 'Compliance status of the vehicle operation with DOT and FMCSA regulations for this operational day.' ;
    rdfs:domain ind:VehicleUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drivingHours rdf:type rdf:Property ;
    rdfs:label 'Driving Hours' ;
    rdfs:comment 'Hours the vehicle was actively in motion during the operational day.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelEfficiencyMpg rdf:type rdf:Property ;
    rdfs:label 'Fuel Efficiency Mpg' ;
    rdfs:comment 'Calculated fuel efficiency in miles per gallon (MPG) or miles per gasoline gallon equivalent (MPGe) for alternative fuel vehicles.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maintenanceFlag rdf:type rdf:Property ;
    rdfs:label 'Maintenance Flag' ;
    rdfs:comment 'Indicates whether the vehicle was flagged for maintenance or experienced a maintenance event during this operational day.' ;
    rdfs:domain ind:VehicleUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:payloadTonsCollected rdf:type rdf:Property ;
    rdfs:label 'Payload Tons Collected' ;
    rdfs:comment 'Total weight of waste collected during the operational day, measured in tons, captured from onboard scales where available.' ;
    rdfs:domain ind:VehicleUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ptoHours rdf:type rdf:Property ;
    rdfs:label 'Pto Hours' ;
    rdfs:comment 'Hours the vehicle Power Take-Off system was engaged for collection operations (compactor, hydraulic lifts).' ;
    rdfs:domain ind:VehicleUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueMiles rdf:type rdf:Property ;
    rdfs:label 'Revenue Miles' ;
    rdfs:comment 'Miles driven while performing revenue-generating collection or hauling activities.' ;
    rdfs:domain ind:VehicleUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:routeCompletionStatus rdf:type rdf:Property ;
    rdfs:label 'Route Completion Status' ;
    rdfs:comment 'Status of route completion for the assigned routes: completed, partial, cancelled, or rescheduled.' ;
    rdfs:domain ind:VehicleUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceStopCount rdf:type rdf:Property ;
    rdfs:label 'Service Stop Count' ;
    rdfs:comment 'Total number of service stops completed during the operational day.' ;
    rdfs:domain ind:VehicleUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:telematicsDataQuality rdf:type rdf:Property ;
    rdfs:label 'Telematics Data Quality' ;
    rdfs:comment 'Quality assessment of telematics data captured for this utilization record: complete, partial, missing, or error.' ;
    rdfs:domain ind:VehicleUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalEngineHours rdf:type rdf:Property ;
    rdfs:label 'Total Engine Hours' ;
    rdfs:comment 'Total hours the vehicle engine was running during the operational day.' ;
    rdfs:domain ind:VehicleUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:utilizationDate rdf:type rdf:Property ;
    rdfs:label 'Utilization Date' ;
    rdfs:comment 'The operational date for which vehicle utilization metrics are captured.' ;
    rdfs:domain ind:VehicleUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:utilizationRatePercent rdf:type rdf:Property ;
    rdfs:label 'Utilization Rate Percent' ;
    rdfs:comment 'Percentage of available hours that the vehicle was actively utilized, calculated as (total_engine_hours / available_hours) * 100.' ;
    rdfs:domain ind:VehicleUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chainOfCustodyId rdf:type rdf:Property ;
    rdfs:label 'Chain Of Custody Id' ;
    rdfs:comment 'Unique identifier for the chain of custody record. Primary key for immutable cradle-to-grave tracking of hazardous waste container transfers.' ;
    rdfs:domain ind:ChainOfCustody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dotHazmatClassificationId rdf:type rdf:Property ;
    rdfs:label 'Dot Hazmat Classification Id' ;
    rdfs:comment 'Foreign key linking to hazmat.dot_hazmat_classification. Business justification: Chain of custody has un_identification_number (string) but no FK to dot_hazmat_classification reference table. Adding FK provides standardized DOT classification lookup. Keep dot_shipping_name, dot_ha' ;
    rdfs:domain ind:Hazmat ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DotHazmatClassification .

ind:hazmatContainerId rdf:type rdf:Property ;
    rdfs:label 'Hazmat Container Id' ;
    rdfs:comment 'Foreign key linking to hazmat.hazmat_container. Business justification: Chain of custody currently links to asset.container (generic container) but should also link to hazmat_container (hazardous waste specific container). This provides hazmat-specific container details i' ;
    rdfs:domain ind:Hazmat ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HazmatContainer .

ind:primaryWasteCodeId rdf:type rdf:Property ;
    rdfs:label 'Primary Waste Code Id' ;
    rdfs:comment 'Foreign key linking to hazmat.waste_code. Business justification: Chain of custody has waste_code (string) but no FK to waste_code reference table. Adding FK provides standardized waste code lookup. Keep waste_code string as point-in-time value (may be recorded diff' ;
    rdfs:domain ind:Hazmat ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WasteCode .

ind:transferringPartyEpaIdRegistrationId rdf:type rdf:Property ;
    rdfs:label 'Transferring Party Epa Id Registration Id' ;
    rdfs:comment 'Foreign key linking to hazmat.epa_id_registration. Business justification: Chain of custody tracks transferring party EPA ID as a string. This should be normalized to FK to epa_id_registration. Labeled FK (transferring_party_epa_id_registration_id) distinguishes this from re' ;
    rdfs:domain ind:ChainOfCustody ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EpaIdRegistration .

ind:wasteShipmentId rdf:type rdf:Property ;
    rdfs:label 'Waste Shipment Id' ;
    rdfs:comment 'Foreign key linking to hazmat.waste_shipment. Business justification: Chain of custody records document transfers during waste shipments. Multiple custody transfer events occur per shipment (generator to transporter, transporter to TSDF, etc.). This links each custody t' ;
    rdfs:domain ind:Hazmat ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WasteShipment .

ind:witnessEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Witness Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Chain of custody transfers often require employee witness per quality assurance procedures and legal defensibility requirements. Links COC event to employee record enables signature verification, trai' ;
    rdfs:domain ind:ChainOfCustody ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:billOfLadingNumber rdf:type rdf:Property ;
    rdfs:label 'Bill Of Lading Number' ;
    rdfs:comment 'Reference number for the DOT bill of lading document accompanying this hazardous waste shipment. Links chain of custody to transportation documentation.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discrepancyIndicator rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Indicator' ;
    rdfs:comment 'Flag indicating whether a discrepancy was noted during this custody transfer (e.g., container count mismatch, quantity variance, damage observed).' ;
    rdfs:domain ind:Hazmat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discrepancyNotes rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Notes' ;
    rdfs:comment 'Detailed notes describing any discrepancy observed during the custody transfer. Required for RCRA exception reporting and CERCLA liability documentation.' ;
    rdfs:domain ind:ChainOfCustody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discrepancyType rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Type' ;
    rdfs:comment 'Classification of the discrepancy noted during custody transfer, if any. Used for exception handling and regulatory reporting.' ;
    rdfs:domain ind:ChainOfCustody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dotHazardClass rdf:type rdf:Property ;
    rdfs:label 'Dot Hazard Class' ;
    rdfs:comment 'DOT hazard class or division number for the material (e.g., 3 for flammable liquids, 6.1 for toxic substances, 8 for corrosives).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dotShippingName rdf:type rdf:Property ;
    rdfs:label 'Dot Shipping Name' ;
    rdfs:comment 'DOT proper shipping name for the hazardous material as required by Hazardous Materials Regulations (HMR). Used for transportation compliance.' ;
    rdfs:domain ind:Hazmat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyResponsePhone rdf:type rdf:Property ;
    rdfs:label 'Emergency Response Phone' ;
    rdfs:comment '24-hour emergency response phone number for incidents involving this hazardous waste shipment. Required by DOT HMR.' ;
    rdfs:domain ind:ChainOfCustody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packingGroup rdf:type rdf:Property ;
    rdfs:label 'Packing Group' ;
    rdfs:comment 'DOT packing group indicating the degree of danger: I (great danger), II (medium danger), III (minor danger).' ;
    rdfs:domain ind:Hazmat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingPartyContactName rdf:type rdf:Property ;
    rdfs:label 'Receiving Party Contact Name' ;
    rdfs:comment 'Full name of the individual representative who physically accepted custody on behalf of the receiving party.' ;
    rdfs:domain ind:ChainOfCustody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingPartyName rdf:type rdf:Property ;
    rdfs:label 'Receiving Party Name' ;
    rdfs:comment 'Legal business name of the organization or facility accepting custody of the hazardous waste container.' ;
    rdfs:domain ind:ChainOfCustody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingPartySignature rdf:type rdf:Property ;
    rdfs:label 'Receiving Party Signature' ;
    rdfs:comment 'Digital signature or signature identifier of the receiving party representative acknowledging acceptance of custody. May be electronic signature hash or physical signature reference.' ;
    rdfs:domain ind:ChainOfCustody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordCreatedBy rdf:type rdf:Property ;
    rdfs:label 'Record Created By' ;
    rdfs:comment 'User ID or system identifier of the person or process that created this chain of custody record. Supports audit and compliance requirements.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalQuantity rdf:type rdf:Property ;
    rdfs:label 'Total Quantity' ;
    rdfs:comment 'Total quantity of hazardous waste transferred in this custody event, measured in the unit specified by quantity_unit.' ;
    rdfs:domain ind:Hazmat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transferEventType rdf:type rdf:Property ;
    rdfs:label 'Transfer Event Type' ;
    rdfs:comment 'Classification of the chain of custody transfer event. Defines the nature of the custody change in the cradle-to-grave lifecycle.' ;
    rdfs:domain ind:ChainOfCustody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferLocationAddress rdf:type rdf:Property ;
    rdfs:label 'Transfer Location Address' ;
    rdfs:comment 'Full street address of the location where the custody transfer occurred. Required for DOT and EPA compliance documentation.' ;
    rdfs:domain ind:ChainOfCustody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferLocationCity rdf:type rdf:Property ;
    rdfs:label 'Transfer Location City' ;
    rdfs:comment 'City where the custody transfer occurred.' ;
    rdfs:domain ind:ChainOfCustody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferLocationLatitude rdf:type rdf:Property ;
    rdfs:label 'Transfer Location Latitude' ;
    rdfs:comment 'Geographic latitude coordinate of the custody transfer location. Supports GPS-based verification and geospatial compliance analysis.' ;
    rdfs:domain ind:ChainOfCustody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transferLocationLongitude rdf:type rdf:Property ;
    rdfs:label 'Transfer Location Longitude' ;
    rdfs:comment 'Geographic longitude coordinate of the custody transfer location. Supports GPS-based verification and geospatial compliance analysis.' ;
    rdfs:domain ind:ChainOfCustody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transferLocationName rdf:type rdf:Property ;
    rdfs:label 'Transfer Location Name' ;
    rdfs:comment 'Name of the physical location where the custody transfer occurred (e.g., generator facility, transporter depot, TSDF receiving dock).' ;
    rdfs:domain ind:ChainOfCustody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferLocationPostalCode rdf:type rdf:Property ;
    rdfs:label 'Transfer Location Postal Code' ;
    rdfs:comment 'ZIP code of the location where the custody transfer occurred.' ;
    rdfs:domain ind:ChainOfCustody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferLocationState rdf:type rdf:Property ;
    rdfs:label 'Transfer Location State' ;
    rdfs:comment 'Two-letter state code where the custody transfer occurred. Used for state-level regulatory reporting.' ;
    rdfs:domain ind:ChainOfCustody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Transfer Sequence Number' ;
    rdfs:comment 'Sequential order of this transfer event within the container\'s complete chain of custody. Starts at 1 for generator handoff and increments with each subsequent transfer.' ;
    rdfs:domain ind:ChainOfCustody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transferTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transfer Timestamp' ;
    rdfs:comment 'Exact date and time when physical custody of the hazardous waste container was transferred from the relinquishing party to the receiving party. Critical for CERCLA liability determination.' ;
    rdfs:domain ind:ChainOfCustody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:transferringPartyContactName rdf:type rdf:Property ;
    rdfs:label 'Transferring Party Contact Name' ;
    rdfs:comment 'Full name of the individual representative who physically relinquished custody on behalf of the transferring party.' ;
    rdfs:domain ind:ChainOfCustody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferringPartyName rdf:type rdf:Property ;
    rdfs:label 'Transferring Party Name' ;
    rdfs:comment 'Legal business name of the organization or facility relinquishing custody of the hazardous waste container.' ;
    rdfs:domain ind:ChainOfCustody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferringPartySignature rdf:type rdf:Property ;
    rdfs:label 'Transferring Party Signature' ;
    rdfs:comment 'Digital signature or signature identifier of the transferring party representative acknowledging relinquishment of custody. May be electronic signature hash or physical signature reference.' ;
    rdfs:domain ind:ChainOfCustody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unIdentificationNumber rdf:type rdf:Property ;
    rdfs:label 'Un Identification Number' ;
    rdfs:comment 'Four-digit UN number assigned to the hazardous material for international transportation. Format: UN followed by 4 digits.' ;
    rdfs:domain ind:ChainOfCustody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteCode rdf:type rdf:Property ;
    rdfs:label 'Waste Code' ;
    rdfs:comment 'EPA hazardous waste code(s) for the material being transferred. Format: letter (D/F/K/P/U) followed by 3 digits. Multiple codes may be comma-separated.' ;
    rdfs:domain ind:Hazmat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteDescription rdf:type rdf:Property ;
    rdfs:label 'Waste Description' ;
    rdfs:comment 'Detailed description of the hazardous waste material being transferred, including physical state, chemical composition, and any special handling requirements.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:witnessSignature rdf:type rdf:Property ;
    rdfs:label 'Witness Signature' ;
    rdfs:comment 'Digital signature or signature identifier of the witness, if present. Provides additional verification for critical transfers.' ;
    rdfs:domain ind:ChainOfCustody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contingencyPlanId rdf:type rdf:Property ;
    rdfs:label 'Contingency Plan Id' ;
    rdfs:comment 'Unique identifier for the RCRA contingency plan document record. Primary key for the contingency plan entity.' ;
    rdfs:domain ind:Hazmat ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContingencyPlan .

ind:emergencyCoordinatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Emergency Coordinator Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: RCRA contingency plans must designate emergency coordinator per 40 CFR 265.52. Links plan to employee record enables certification verification (HAZWOPER, emergency response training), contact informa' ;
    rdfs:domain ind:ContingencyPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:facilityEpaIdRegistrationId rdf:type rdf:Property ;
    rdfs:label 'Facility Epa Id Registration Id' ;
    rdfs:comment 'Foreign key linking to hazmat.epa_id_registration. Business justification: Contingency plans are facility-specific and reference the facility\'s EPA ID. The facility_epa_id string is a denormalized reference. Adding labeled FK (facility_epa_id_registration_id) normalizes this' ;
    rdfs:domain ind:ContingencyPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EpaIdRegistration .

ind:alternateCoordinatorName rdf:type rdf:Property ;
    rdfs:label 'Alternate Coordinator Name' ;
    rdfs:comment 'Full name of the alternate or backup emergency coordinator who assumes responsibility when the primary coordinator is unavailable.' ;
    rdfs:domain ind:ContingencyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alternateCoordinatorPhone rdf:type rdf:Property ;
    rdfs:label 'Alternate Coordinator Phone' ;
    rdfs:comment '24-hour emergency contact phone number for the alternate emergency coordinator.' ;
    rdfs:domain ind:ContingencyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedByName rdf:type rdf:Property ;
    rdfs:label 'Approved By Name' ;
    rdfs:comment 'Full name of the individual who formally approved this contingency plan version (typically facility manager or environmental compliance officer).' ;
    rdfs:domain ind:Hazmat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentStorageLocation rdf:type rdf:Property ;
    rdfs:label 'Document Storage Location' ;
    rdfs:comment 'Physical or electronic location where the official contingency plan document is stored and maintained (e.g., file path, document management system reference, physical file cabinet location).' ;
    rdfs:domain ind:ContingencyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyContractorName rdf:type rdf:Property ;
    rdfs:label 'Emergency Contractor Name' ;
    rdfs:comment 'Name of the contracted emergency response or cleanup contractor with arrangements to respond to hazardous waste incidents at the facility.' ;
    rdfs:domain ind:ContingencyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyContractorPhone rdf:type rdf:Property ;
    rdfs:label 'Emergency Contractor Phone' ;
    rdfs:comment '24-hour emergency contact phone number for the contracted emergency response or cleanup contractor.' ;
    rdfs:domain ind:ContingencyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyCoordinatorTitle rdf:type rdf:Property ;
    rdfs:label 'Emergency Coordinator Title' ;
    rdfs:comment 'Job title or position of the primary emergency coordinator (e.g., Environmental Health and Safety Manager, Facility Manager, Operations Director).' ;
    rdfs:domain ind:Hazmat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyEquipmentList rdf:type rdf:Property ;
    rdfs:label 'Emergency Equipment List' ;
    rdfs:comment 'Comprehensive list of emergency equipment available at the facility, including spill kits, fire extinguishers, decontamination equipment, personal protective equipment (PPE), communication devices, and alarm systems. Required by 40 CFR 265.52.' ;
    rdfs:domain ind:ContingencyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evacuationMapReference rdf:type rdf:Property ;
    rdfs:label 'Evacuation Map Reference' ;
    rdfs:comment 'Reference identifier or document location for the facility evacuation map showing routes, exits, assembly points, and emergency equipment locations.' ;
    rdfs:domain ind:ContingencyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evacuationRoutesDescription rdf:type rdf:Property ;
    rdfs:label 'Evacuation Routes Description' ;
    rdfs:comment 'Detailed description of primary and alternate evacuation routes from the facility, including assembly points and procedures for accounting for personnel during emergencies.' ;
    rdfs:domain ind:ContingencyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazwoperTrainingRequired rdf:type rdf:Property ;
    rdfs:label 'Hazwoper Training Required' ;
    rdfs:comment 'Boolean flag indicating whether HAZWOPER training (29 CFR 1910.120) is required for personnel involved in emergency response at this facility.' ;
    rdfs:domain ind:ContingencyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:localEmergencyAgencyName rdf:type rdf:Property ;
    rdfs:label 'Local Emergency Agency Name' ;
    rdfs:comment 'Name of the local emergency response agency or LEPC that has been notified of the facility operations and will respond to emergencies.' ;
    rdfs:domain ind:ContingencyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localEmergencyAgencyPhone rdf:type rdf:Property ;
    rdfs:label 'Local Emergency Agency Phone' ;
    rdfs:comment 'Primary contact phone number for the local emergency response agency or fire department.' ;
    rdfs:domain ind:ContingencyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localHospitalDistanceMiles rdf:type rdf:Property ;
    rdfs:label 'Local Hospital Distance Miles' ;
    rdfs:comment 'Distance in miles from the facility to the designated local hospital. Used for emergency response time estimation.' ;
    rdfs:domain ind:ContingencyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:localHospitalName rdf:type rdf:Property ;
    rdfs:label 'Local Hospital Name' ;
    rdfs:comment 'Name of the nearest hospital or medical facility with arrangements to treat injured personnel from hazardous waste incidents.' ;
    rdfs:domain ind:ContingencyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localHospitalPhone rdf:type rdf:Property ;
    rdfs:label 'Local Hospital Phone' ;
    rdfs:comment 'Emergency contact phone number for the designated local hospital or medical facility.' ;
    rdfs:domain ind:ContingencyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nrcNotificationRequired rdf:type rdf:Property ;
    rdfs:label 'Nrc Notification Required' ;
    rdfs:comment 'Boolean flag indicating whether National Response Center notification is required for reportable quantity releases at this facility.' ;
    rdfs:domain ind:ContingencyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:planDistributionList rdf:type rdf:Property ;
    rdfs:label 'Plan Distribution List' ;
    rdfs:comment 'List of internal and external parties to whom copies of the contingency plan have been distributed, including local emergency responders, state agencies, and facility personnel.' ;
    rdfs:domain ind:ContingencyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Plan Document Number' ;
    rdfs:comment 'Business-assigned unique document control number for the contingency plan. Used for internal tracking and version control.' ;
    rdfs:domain ind:ContingencyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planVersion rdf:type rdf:Property ;
    rdfs:label 'Plan Version' ;
    rdfs:comment 'Version identifier for the contingency plan document (e.g., 1.0, 2.1, 3.0). Tracks revisions and updates over time.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Date' ;
    rdfs:comment 'Date on which the regulatory authority formally approved this contingency plan, if regulatory approval is required.' ;
    rdfs:domain ind:ContingencyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatorySubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Date' ;
    rdfs:comment 'Date on which this contingency plan was submitted to the regulatory authority (EPA or state agency) if submission is required under the facility permit.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:stateAgencyName rdf:type rdf:Property ;
    rdfs:label 'State Agency Name' ;
    rdfs:comment 'Name of the state environmental quality department or agency that must be notified in case of emergencies.' ;
    rdfs:domain ind:ContingencyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateAgencyNotificationRequired rdf:type rdf:Property ;
    rdfs:label 'State Agency Notification Required' ;
    rdfs:comment 'Boolean flag indicating whether state environmental agency notification is required for emergencies at this facility under state-specific regulations.' ;
    rdfs:domain ind:ContingencyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stateAgencyPhone rdf:type rdf:Property ;
    rdfs:label 'State Agency Phone' ;
    rdfs:comment 'Emergency notification phone number for the state environmental agency.' ;
    rdfs:domain ind:ContingencyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalRecordId rdf:type rdf:Property ;
    rdfs:label 'Disposal Record Id' ;
    rdfs:comment 'Unique identifier for the hazardous waste disposal record. Primary key for tracking final disposal confirmation under RCRA Subtitle C cradle-to-grave requirements.' ;
    rdfs:domain ind:Hazmat ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DisposalRecord .

ind:certifyingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Certifying Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Disposal certifications require authorized employee signature per RCRA land disposal restrictions (40 CFR 268). Tracking certifying employee enables signature authority verification, audit trails, and' ;
    rdfs:domain ind:Hazmat ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:disposalCellId rdf:type rdf:Property ;
    rdfs:label 'Disposal Cell Id' ;
    rdfs:comment 'Foreign key linking to landfill.cell. Business justification: Hazardous waste disposal records should track which specific landfill cell received the waste for long-term liability tracking and closure planning. Currently disposal_unit_id references hazmat.storag' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Cell .

ind:storageUnitId rdf:type rdf:Property ;
    rdfs:label 'Storage Unit Id' ;
    rdfs:comment 'Specific disposal unit identifier within the TSDF facility where waste was placed (e.g., landfill cell number, incinerator unit ID, deep well injection well number). Provides precise location tracking.' ;
    rdfs:domain ind:Hazmat ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageUnit .

ind:transporterEpaEpaIdRegistrationId rdf:type rdf:Property ;
    rdfs:label 'Transporter Epa Epa Id Registration Id' ;
    rdfs:comment 'EPA ID number of the transporter who delivered the waste to the TSDF. Documents the transportation link in the chain of custody.' ;
    rdfs:domain ind:Hazmat ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EpaIdRegistration .

ind:tsdfPermitId rdf:type rdf:Property ;
    rdfs:label 'Tsdf Permit Id' ;
    rdfs:comment 'Foreign key linking to compliance.permit. Business justification: Disposal operations governed by TSDF permit conditions (40 CFR 264 Subpart N). Permit defines disposal unit capacity, waste codes, and LDR compliance requirements. Core regulatory relationship for dis' ;
    rdfs:domain ind:DisposalRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Permit .

ind:certificateOfDisposalNumber rdf:type rdf:Property ;
    rdfs:label 'Certificate Of Disposal Number' ;
    rdfs:comment 'Unique certificate number issued by the TSDF confirming final disposal of the hazardous waste. Provides legal documentation that waste has been properly disposed per RCRA requirements.' ;
    rdfs:domain ind:DisposalRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discrepancyDescription rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Description' ;
    rdfs:comment 'Detailed description of any discrepancies found between manifest documentation and actual waste received. Documents variances for regulatory reporting and resolution.' ;
    rdfs:domain ind:Hazmat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Disposal Completion Timestamp' ;
    rdfs:comment 'Date and time when the disposal process was fully completed and the record was finalized. Marks the official closure of the cradle-to-grave tracking cycle.' ;
    rdfs:domain ind:DisposalRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:disposalCostCurrency rdf:type rdf:Property ;
    rdfs:label 'Disposal Cost Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the disposal cost amount (e.g., USD, CAD, EUR). Supports multi-currency operations for international waste disposal.' ;
    rdfs:domain ind:DisposalRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalMethodCode rdf:type rdf:Property ;
    rdfs:label 'Disposal Method Code' ;
    rdfs:comment 'EPA-standardized code identifying the disposal method used (e.g., D80 for landfill, D81 for underground injection, D82 for incineration ash disposal). Defines the ultimate fate of the hazardous waste.' ;
    rdfs:domain ind:Hazmat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalMethodDescription rdf:type rdf:Property ;
    rdfs:label 'Disposal Method Description' ;
    rdfs:comment 'Detailed description of the disposal method employed at the TSDF, including specific technology, process, or unit operation used for final waste disposition.' ;
    rdfs:domain ind:DisposalRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalStatus rdf:type rdf:Property ;
    rdfs:label 'Disposal Status' ;
    rdfs:comment 'Current status of the disposal record in the TSDF workflow. Tracks progression from receipt through disposal to final certification and manifest closure.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyResponseRequired rdf:type rdf:Property ;
    rdfs:label 'Emergency Response Required' ;
    rdfs:comment 'Boolean flag indicating whether emergency response procedures were activated during receipt or disposal of this waste. Triggers incident reporting and documentation requirements.' ;
    rdfs:domain ind:DisposalRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ldrCertificationDate rdf:type rdf:Property ;
    rdfs:label 'Ldr Certification Date' ;
    rdfs:comment 'Date when the TSDF certified LDR compliance for the disposed waste. Documents when treatment standards were verified prior to land disposal.' ;
    rdfs:domain ind:DisposalRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ldrComplianceCertified rdf:type rdf:Property ;
    rdfs:label 'Ldr Compliance Certified' ;
    rdfs:comment 'Boolean flag indicating whether the TSDF has certified that the waste meets Land Disposal Restriction treatment standards prior to disposal. Required for restricted hazardous wastes under RCRA.' ;
    rdfs:domain ind:DisposalRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ldrTreatmentMethod rdf:type rdf:Property ;
    rdfs:label 'Ldr Treatment Method' ;
    rdfs:comment 'Description of the treatment method applied to meet LDR standards before disposal (e.g., stabilization, neutralization, thermal treatment). Required for restricted waste codes.' ;
    rdfs:domain ind:DisposalRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Date' ;
    rdfs:comment 'Date when regulatory reports related to this disposal were submitted to EPA or state environmental agencies. Documents compliance with reporting deadlines.' ;
    rdfs:domain ind:DisposalRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryReportSubmitted rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Submitted' ;
    rdfs:comment 'Boolean flag indicating whether required regulatory reports (e.g., biennial report, exception report) have been submitted for this disposal event. Tracks compliance reporting obligations.' ;
    rdfs:domain ind:Hazmat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tsdfSignatureName rdf:type rdf:Property ;
    rdfs:label 'Tsdf Signature Name' ;
    rdfs:comment 'Name of the authorized TSDF representative who signed and certified the disposal record. Provides accountability for disposal confirmation.' ;
    rdfs:domain ind:DisposalRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tsdfSignatureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Tsdf Signature Timestamp' ;
    rdfs:comment 'Date and time when the TSDF representative signed the disposal record, confirming receipt and disposal of the hazardous waste shipment.' ;
    rdfs:domain ind:DisposalRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:tsdfSignatureTitle rdf:type rdf:Property ;
    rdfs:label 'Tsdf Signature Title' ;
    rdfs:comment 'Job title of the TSDF representative who signed the disposal record (e.g., Facility Manager, Environmental Compliance Officer). Establishes authority of signatory.' ;
    rdfs:domain ind:DisposalRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteCodePrimary rdf:type rdf:Property ;
    rdfs:label 'Waste Code Primary' ;
    rdfs:comment 'Primary EPA hazardous waste code (D, F, K, P, or U list) identifying the principal hazardous characteristic or listing of the disposed waste. Determines regulatory requirements and disposal restrictions.' ;
    rdfs:domain ind:DisposalRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteCodesAdditional rdf:type rdf:Property ;
    rdfs:label 'Waste Codes Additional' ;
    rdfs:comment 'Comma-separated list of additional EPA hazardous waste codes applicable to the disposed waste. Captures multiple hazardous characteristics or listings for mixed waste streams.' ;
    rdfs:domain ind:DisposalRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteQuantityLbs rdf:type rdf:Property ;
    rdfs:label 'Waste Quantity Lbs' ;
    rdfs:comment 'Total quantity of hazardous waste disposed, measured in pounds. Represents the actual weight accepted and disposed by the TSDF facility.' ;
    rdfs:domain ind:DisposalRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wasteQuantityTons rdf:type rdf:Property ;
    rdfs:label 'Waste Quantity Tons' ;
    rdfs:comment 'Total quantity of hazardous waste disposed, measured in tons. Calculated or measured weight for regulatory reporting and capacity tracking purposes.' ;
    rdfs:domain ind:DisposalRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wasteVolumeGallons rdf:type rdf:Property ;
    rdfs:label 'Waste Volume Gallons' ;
    rdfs:comment 'Volume of liquid or semi-liquid hazardous waste disposed, measured in gallons. Used for liquid waste streams and deep well injection disposal methods.' ;
    rdfs:domain ind:DisposalRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cargoAircraftQuantityLimit rdf:type rdf:Property ;
    rdfs:label 'Cargo Aircraft Quantity Limit' ;
    rdfs:comment 'Maximum net quantity per package permitted on cargo-only aircraft. May be expressed as weight (kg), volume (L), or \'Forbidden\' if not permitted.' ;
    rdfs:domain ind:DotHazmatClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classificationEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Classification Effective Date' ;
    rdfs:comment 'Date when this classification entry became effective in the Hazardous Materials Regulations. Used to track regulatory changes over time.' ;
    rdfs:domain ind:DotHazmatClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:classificationStatus rdf:type rdf:Property ;
    rdfs:label 'Classification Status' ;
    rdfs:comment 'Current regulatory status of this classification entry. Active = currently in force, Superseded = replaced by newer entry, Withdrawn = no longer valid.' ;
    rdfs:domain ind:DotHazmatClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ergGuideNumber rdf:type rdf:Property ;
    rdfs:label 'Erg Guide Number' ;
    rdfs:comment 'Three-digit guide number from the DOT Emergency Response Guidebook that provides first responders with initial action guidance for incidents involving this material.' ;
    rdfs:domain ind:DotHazmatClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptedQuantityCode rdf:type rdf:Property ;
    rdfs:label 'Excepted Quantity Code' ;
    rdfs:comment 'Code (E0-E5) indicating the maximum quantity per inner packaging permitted under excepted quantity provisions, which allow minimal regulatory requirements for very small quantities.' ;
    rdfs:domain ind:DotHazmatClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptions rdf:type rdf:Property ;
    rdfs:label 'Exceptions' ;
    rdfs:comment 'Reference to regulatory sections (e.g., 173.###) that provide exceptions or reduced requirements for limited quantities, small quantities, or specific transport modes.' ;
    rdfs:domain ind:DotHazmatClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forbiddenCargoAircraft rdf:type rdf:Property ;
    rdfs:label 'Forbidden Cargo Aircraft' ;
    rdfs:comment 'Indicates whether transport of this material on cargo-only aircraft is prohibited under any circumstances.' ;
    rdfs:domain ind:DotHazmatClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:forbiddenPassengerAircraft rdf:type rdf:Property ;
    rdfs:label 'Forbidden Passenger Aircraft' ;
    rdfs:comment 'Indicates whether transport of this material on passenger-carrying aircraft is prohibited under any circumstances.' ;
    rdfs:domain ind:DotHazmatClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazardClass rdf:type rdf:Property ;
    rdfs:label 'Hazard Class' ;
    rdfs:comment 'Primary hazard class or division (1-9) assigned to the material based on its predominant hazard. Examples: 1.1 (explosives), 2.1 (flammable gas), 3 (flammable liquid), 4.1 (flammable solid), 5.1 (oxidizer), 6.1 (toxic), 7 (radioactive), 8 (corrosive), 9 (miscellaneous).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardDivision rdf:type rdf:Property ;
    rdfs:label 'Hazard Division' ;
    rdfs:comment 'Subdivision within a hazard class that further categorizes the material by specific hazard characteristics (e.g., 1.1, 1.2, 2.1, 2.2, 6.1). May be null for classes without divisions.' ;
    rdfs:domain ind:DotHazmatClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inhalationHazardZone rdf:type rdf:Property ;
    rdfs:label 'Inhalation Hazard Zone' ;
    rdfs:comment 'For materials that are poisonous by inhalation, the hazard zone (A, B, C, or D) indicating the degree of inhalation toxicity. Zone A is the most toxic.' ;
    rdfs:domain ind:DotHazmatClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelCode rdf:type rdf:Property ;
    rdfs:label 'Label Code' ;
    rdfs:comment 'Code(s) identifying the required hazard warning label(s) that must be affixed to packages. Multiple labels may be required for materials with subsidiary hazards. Examples: 3 (flammable liquid), 6.1 (poison), 8 (corrosive).' ;
    rdfs:domain ind:DotHazmatClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limitedQuantityEligible rdf:type rdf:Property ;
    rdfs:label 'Limited Quantity Eligible' ;
    rdfs:comment 'Indicates whether this material is eligible for limited quantity exceptions, which allow reduced packaging, marking, and labeling requirements when transported in small quantities.' ;
    rdfs:domain ind:DotHazmatClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:limitedQuantityMaxNet rdf:type rdf:Property ;
    rdfs:label 'Limited Quantity Max Net' ;
    rdfs:comment 'Maximum net quantity per inner receptacle or article permitted under limited quantity provisions. Expressed as weight or volume.' ;
    rdfs:domain ind:DotHazmatClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marinePollutant rdf:type rdf:Property ;
    rdfs:label 'Marine Pollutant' ;
    rdfs:comment 'Indicates whether the material is designated as a marine pollutant under DOT and International Maritime Dangerous Goods (IMDG) Code regulations. Requires special marking and handling for water transport.' ;
    rdfs:domain ind:DotHazmatClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:packagingAuthorizations rdf:type rdf:Property ;
    rdfs:label 'Packaging Authorizations' ;
    rdfs:comment 'Codes referencing the authorized packaging sections (e.g., 173.###) that specify which container types and specifications are approved for this material.' ;
    rdfs:domain ind:DotHazmatClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passengerAircraftQuantityLimit rdf:type rdf:Property ;
    rdfs:label 'Passenger Aircraft Quantity Limit' ;
    rdfs:comment 'Maximum net quantity per package permitted on passenger-carrying aircraft. May be expressed as weight (kg), volume (L), or \'Forbidden\' if not permitted.' ;
    rdfs:domain ind:DotHazmatClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:placardCode rdf:type rdf:Property ;
    rdfs:label 'Placard Code' ;
    rdfs:comment 'Code identifying the specific placard design required for the transport vehicle. Examples: FLAMMABLE, CORROSIVE, POISON, OXIDIZER, DANGEROUS.' ;
    rdfs:domain ind:DotHazmatClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:placardRequired rdf:type rdf:Property ;
    rdfs:label 'Placard Required' ;
    rdfs:comment 'Indicates whether placards must be displayed on the transport vehicle for this material when transported in specified quantities.' ;
    rdfs:domain ind:DotHazmatClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:properShippingName rdf:type rdf:Property ;
    rdfs:label 'Proper Shipping Name' ;
    rdfs:comment 'The official DOT-approved name used to describe the hazardous material on shipping papers, manifests, and labels. Must match the Hazardous Materials Table entry exactly.' ;
    rdfs:domain ind:Hazmat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportableQuantityLbs rdf:type rdf:Property ;
    rdfs:label 'Reportable Quantity Lbs' ;
    rdfs:comment 'The threshold quantity (in pounds) at or above which a spill or release of this material must be reported to the National Response Center under CERCLA. Null if no RQ applies.' ;
    rdfs:domain ind:Hazmat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severeMarinePollutant rdf:type rdf:Property ;
    rdfs:label 'Severe Marine Pollutant' ;
    rdfs:comment 'Indicates whether the material is classified as a severe marine pollutant (PP designation) requiring enhanced environmental protection measures during marine transport.' ;
    rdfs:domain ind:DotHazmatClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specialProvisions rdf:type rdf:Property ;
    rdfs:label 'Special Provisions' ;
    rdfs:comment 'Comma-separated list of special provision codes (e.g., B1, IB2, T4, TP1) that impose additional requirements or grant exceptions for packaging, handling, or transport of this material.' ;
    rdfs:domain ind:DotHazmatClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subsidiaryHazardClass rdf:type rdf:Property ;
    rdfs:label 'Subsidiary Hazard Class' ;
    rdfs:comment 'Secondary hazard class(es) for materials that present more than one type of hazard. Multiple subsidiary classes may be listed, separated by commas.' ;
    rdfs:domain ind:DotHazmatClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByUnNaNumber rdf:type rdf:Property ;
    rdfs:label 'Superseded By Un Na Number' ;
    rdfs:comment 'If this classification has been superseded, the UN/NA number of the replacement classification entry. Null if status is active.' ;
    rdfs:domain ind:DotHazmatClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalNameRequired rdf:type rdf:Property ;
    rdfs:label 'Technical Name Required' ;
    rdfs:comment 'Indicates whether the technical or chemical name of the hazardous constituent(s) must be entered in parentheses after the proper shipping name on shipping papers.' ;
    rdfs:domain ind:DotHazmatClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vesselStowageLocation rdf:type rdf:Property ;
    rdfs:label 'Vessel Stowage Location' ;
    rdfs:comment 'Code indicating where the material must be stowed on a vessel (e.g., A = on deck only, B = under deck, C = on or under deck). Applies to marine transport.' ;
    rdfs:domain ind:DotHazmatClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vesselStowageOther rdf:type rdf:Property ;
    rdfs:label 'Vessel Stowage Other' ;
    rdfs:comment 'Additional stowage requirements or restrictions for marine transport, such as segregation from other materials, ventilation requirements, or temperature controls.' ;
    rdfs:domain ind:DotHazmatClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentCommanderEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Incident Commander Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Emergency response incidents require incident commander assignment per contingency plan requirements (40 CFR 265.52). Links to employee HAZWOPER certification, emergency coordinator training, and enab' ;
    rdfs:domain ind:EmergencyResponseIncident ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:incidentFacilityId rdf:type rdf:Property ;
    rdfs:label 'Incident Facility Id' ;
    rdfs:comment 'Foreign key linking to asset.facility. Business justification: Incidents occur at facilities and impact facility risk profiles, insurance premiums, and safety certifications. Links incidents to facility asset records for insurance claims, facility safety scoring,' ;
    rdfs:domain ind:EmergencyResponseIncident ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:safetyIncidentId rdf:type rdf:Property ;
    rdfs:label 'Safety Incident Id' ;
    rdfs:comment 'Foreign key linking to safety.incident. Business justification: Hazmat emergency responses (spills, releases, exposures) are specialized safety incidents requiring unified incident management, OSHA recordkeeping, and workers\' compensation integration. Links EPA em' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Incident .

ind:wasteCodeId rdf:type rdf:Property ;
    rdfs:label 'Waste Code Id' ;
    rdfs:comment 'Foreign key linking to hazmat.waste_code. Business justification: Emergency response incident has waste_code (string) but no FK to waste_code reference table. Adding FK provides standardized waste code lookup and validation. Keep waste_code string for operational fl' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WasteCode .

ind:cleanupCompletionDatetime rdf:type rdf:Property ;
    rdfs:label 'Cleanup Completion Datetime' ;
    rdfs:comment 'Date and time when cleanup and remediation activities were completed and the site was declared safe.' ;
    rdfs:domain ind:EmergencyResponseIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cleanupContractorName rdf:type rdf:Property ;
    rdfs:label 'Cleanup Contractor Name' ;
    rdfs:comment 'Name of the environmental remediation contractor deployed to the incident site for cleanup and remediation activities.' ;
    rdfs:domain ind:EmergencyResponseIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cleanupStartDatetime rdf:type rdf:Property ;
    rdfs:label 'Cleanup Start Datetime' ;
    rdfs:comment 'Date and time when formal cleanup and remediation activities commenced at the incident site.' ;
    rdfs:domain ind:EmergencyResponseIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:discoveryDatetime rdf:type rdf:Property ;
    rdfs:label 'Discovery Datetime' ;
    rdfs:comment 'The date and time when the incident was first discovered or reported to management.' ;
    rdfs:domain ind:EmergencyResponseIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:immediateResponseActions rdf:type rdf:Property ;
    rdfs:label 'Immediate Response Actions' ;
    rdfs:comment 'Description of immediate containment and response actions taken at the time of discovery to mitigate the release.' ;
    rdfs:domain ind:EmergencyResponseIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentClosureDate rdf:type rdf:Property ;
    rdfs:label 'Incident Closure Date' ;
    rdfs:comment 'Date when the incident was formally closed after all response, remediation, and reporting activities were completed.' ;
    rdfs:domain ind:EmergencyResponseIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:incidentDatetime rdf:type rdf:Property ;
    rdfs:label 'Incident Datetime' ;
    rdfs:comment 'The date and time when the hazardous material spill, release, or emergency event occurred.' ;
    rdfs:domain ind:EmergencyResponseIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:injuriesReported rdf:type rdf:Property ;
    rdfs:label 'Injuries Reported' ;
    rdfs:comment 'Indicates whether any personnel injuries or exposures occurred as a result of the incident.' ;
    rdfs:domain ind:EmergencyResponseIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:injuryCount rdf:type rdf:Property ;
    rdfs:label 'Injury Count' ;
    rdfs:comment 'Number of personnel who sustained injuries or exposures during the incident.' ;
    rdfs:domain ind:EmergencyResponseIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lepcNotificationDatetime rdf:type rdf:Property ;
    rdfs:label 'Lepc Notification Datetime' ;
    rdfs:comment 'Date and time when the Local Emergency Planning Committee was notified of the incident.' ;
    rdfs:domain ind:EmergencyResponseIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lepcNotified rdf:type rdf:Property ;
    rdfs:label 'Lepc Notified' ;
    rdfs:comment 'Indicates whether the Local Emergency Planning Committee was notified as required under EPCRA Title III.' ;
    rdfs:domain ind:EmergencyResponseIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nrcNotificationDatetime rdf:type rdf:Property ;
    rdfs:label 'Nrc Notification Datetime' ;
    rdfs:comment 'Date and time when the incident was reported to the National Response Center as required for reportable quantity releases.' ;
    rdfs:domain ind:EmergencyResponseIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:nrcReportNumber rdf:type rdf:Property ;
    rdfs:label 'Nrc Report Number' ;
    rdfs:comment 'Confirmation number issued by the National Response Center upon notification of the incident.' ;
    rdfs:domain ind:EmergencyResponseIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportDueDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Due Date' ;
    rdfs:comment 'Deadline date by which formal regulatory incident reports must be submitted to EPA, state agencies, or other authorities.' ;
    rdfs:domain ind:EmergencyResponseIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryReportSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Submission Date' ;
    rdfs:comment 'Date when the formal regulatory incident report was submitted to EPA, state, or local authorities.' ;
    rdfs:domain ind:EmergencyResponseIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:releasePathway rdf:type rdf:Property ;
    rdfs:label 'Release Pathway' ;
    rdfs:comment 'Environmental pathway through which the hazardous material was released (air, water, soil, etc.).' ;
    rdfs:domain ind:EmergencyResponseIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationStatus rdf:type rdf:Property ;
    rdfs:label 'Remediation Status' ;
    rdfs:comment 'Current status of environmental remediation and cleanup activities at the incident site.' ;
    rdfs:domain ind:EmergencyResponseIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateAgencyNotified rdf:type rdf:Property ;
    rdfs:label 'State Agency Notified' ;
    rdfs:comment 'Indicates whether the state environmental agency was notified of the incident as required by state regulations.' ;
    rdfs:domain ind:Hazmat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stateNotificationDatetime rdf:type rdf:Property ;
    rdfs:label 'State Notification Datetime' ;
    rdfs:comment 'Date and time when the state environmental agency was notified of the incident.' ;
    rdfs:domain ind:EmergencyResponseIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:authorizedStateProgram rdf:type rdf:Property ;
    rdfs:label 'Authorized State Program' ;
    rdfs:comment 'Indicates whether the state has an EPA-authorized RCRA program and administers the program in lieu of the federal EPA.' ;
    rdfs:domain ind:EpaIdRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:facilityContactEmail rdf:type rdf:Property ;
    rdfs:label 'Facility Contact Email' ;
    rdfs:comment 'Email address for the facility contact person for regulatory correspondence.' ;
    rdfs:domain ind:EpaIdRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityContactName rdf:type rdf:Property ;
    rdfs:label 'Facility Contact Name' ;
    rdfs:comment 'Name of the primary contact person for regulatory correspondence and compliance matters at the registered facility.' ;
    rdfs:domain ind:EpaIdRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityContactPhone rdf:type rdf:Property ;
    rdfs:label 'Facility Contact Phone' ;
    rdfs:comment 'Primary phone number for the facility contact person.' ;
    rdfs:domain ind:EpaIdRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:generatorClassification rdf:type rdf:Property ;
    rdfs:label 'Generator Classification' ;
    rdfs:comment 'Generator size classification: LQG (Large Quantity Generator, >1000 kg/month), SQG (Small Quantity Generator, 100-1000 kg/month), VSQG (Very Small Quantity Generator, <100 kg/month), CESQG (Conditionally Exempt Small Quantity Generator, legacy term), or not_applicable for non-generators.' ;
    rdfs:domain ind:EpaIdRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handlerStatus rdf:type rdf:Property ;
    rdfs:label 'Handler Status' ;
    rdfs:comment 'Current operational status of the EPA ID registration: active (currently operating), inactive (not currently handling hazardous waste), pending (application submitted), withdrawn (voluntarily terminated), or suspended (regulatory action).' ;
    rdfs:domain ind:EpaIdRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handlerType rdf:type rdf:Property ;
    rdfs:label 'Handler Type' ;
    rdfs:comment 'Primary regulated activity type for this EPA ID: generator (produces hazardous waste), transporter (hauls hazardous waste), TSDF (Treatment Storage and Disposal Facility), or mixed (multiple activities).' ;
    rdfs:domain ind:EpaIdRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isGenerator rdf:type rdf:Property ;
    rdfs:label 'Is Generator' ;
    rdfs:comment 'Indicates whether this EPA ID is registered as a hazardous waste generator.' ;
    rdfs:domain ind:EpaIdRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTransporter rdf:type rdf:Property ;
    rdfs:label 'Is Transporter' ;
    rdfs:comment 'Indicates whether this EPA ID is registered as a hazardous waste transporter.' ;
    rdfs:domain ind:EpaIdRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTsdf rdf:type rdf:Property ;
    rdfs:label 'Is Tsdf' ;
    rdfs:comment 'Indicates whether this EPA ID is registered as a Treatment, Storage, and Disposal Facility for hazardous waste.' ;
    rdfs:domain ind:EpaIdRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:locationVerificationMethod rdf:type rdf:Property ;
    rdfs:label 'Location Verification Method' ;
    rdfs:comment 'Method used to verify the geographic coordinates of the site: GPS (field measurement), address_geocoding (automated), survey (professional land survey), or map_interpolation (manual map reading).' ;
    rdfs:domain ind:EpaIdRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Notification Effective Date' ;
    rdfs:comment 'Date when the EPA ID registration became effective and the site was authorized to conduct regulated activities.' ;
    rdfs:domain ind:EpaIdRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:notificationSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Notification Submission Date' ;
    rdfs:comment 'Date when the RCRA notification form (EPA Form 8700-12) was submitted to the EPA or authorized state agency.' ;
    rdfs:domain ind:EpaIdRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ownerOperatorName rdf:type rdf:Property ;
    rdfs:label 'Owner Operator Name' ;
    rdfs:comment 'Legal name of the entity that owns or operates the regulated facility.' ;
    rdfs:domain ind:EpaIdRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerOperatorType rdf:type rdf:Property ;
    rdfs:label 'Owner Operator Type' ;
    rdfs:comment 'Type of entity that owns or operates the facility: private (commercial), public (publicly traded), federal (U.S. government), state (state government), or municipal (local government).' ;
    rdfs:domain ind:EpaIdRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rcrainfoLastSyncTimestamp rdf:type rdf:Property ;
    rdfs:label 'Rcrainfo Last Sync Timestamp' ;
    rdfs:comment 'Timestamp of the last successful data synchronization with the EPA RCRAInfo system.' ;
    rdfs:domain ind:EpaIdRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rcrainfoSyncStatus rdf:type rdf:Property ;
    rdfs:label 'Rcrainfo Sync Status' ;
    rdfs:comment 'Status of data synchronization with the EPA RCRAInfo national database: synced (up to date), pending (sync in progress), failed (sync error), or not_synced (not yet synchronized).' ;
    rdfs:domain ind:EpaIdRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Site Address Line2' ;
    rdfs:comment 'Secondary address information (suite, building, floor) for the regulated site.' ;
    rdfs:domain ind:EpaIdRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteCountryCode rdf:type rdf:Property ;
    rdfs:label 'Site Country Code' ;
    rdfs:comment 'Three-letter ISO country code for the regulated site location.' ;
    rdfs:domain ind:EpaIdRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteCounty rdf:type rdf:Property ;
    rdfs:label 'Site County' ;
    rdfs:comment 'County where the regulated site is located.' ;
    rdfs:domain ind:Hazmat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateAgencyNotificationDate rdf:type rdf:Property ;
    rdfs:label 'State Agency Notification Date' ;
    rdfs:comment 'Date when the state environmental agency was notified of this EPA ID registration.' ;
    rdfs:domain ind:EpaIdRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:stateIdNumber rdf:type rdf:Property ;
    rdfs:label 'State Id Number' ;
    rdfs:comment 'State-issued identification number for hazardous waste handling (if different from EPA ID and required by state regulations).' ;
    rdfs:domain ind:EpaIdRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionReportId rdf:type rdf:Property ;
    rdfs:label 'Exception Report Id' ;
    rdfs:comment 'Unique identifier for the RCRA exception report. Primary key.' ;
    rdfs:domain ind:ExceptionReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:generatorContactEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Generator Contact Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Exception reports track generator contact for manifest discrepancy resolution per 40 CFR 262.42. Links to employee record enables accurate contact routing, tracks follow-up actions by responsible part' ;
    rdfs:domain ind:ExceptionReport ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:contactAttemptsCount rdf:type rdf:Property ;
    rdfs:label 'Contact Attempts Count' ;
    rdfs:comment 'Number of documented attempts made by the generator to contact the TSDF regarding the missing signed manifest.' ;
    rdfs:domain ind:ExceptionReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:epaWasteCodes rdf:type rdf:Property ;
    rdfs:label 'Epa Waste Codes' ;
    rdfs:comment 'Comma-separated list of EPA hazardous waste codes (e.g., D001, F005) applicable to the waste shipment covered by this exception report.' ;
    rdfs:domain ind:Hazmat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionType rdf:type rdf:Property ;
    rdfs:label 'Exception Type' ;
    rdfs:comment 'The type of exception being reported: manifest not received within timeframe, unresolved discrepancy, or waste rejection by TSDF.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedReturnDate rdf:type rdf:Property ;
    rdfs:label 'Expected Return Date' ;
    rdfs:comment 'The date by which the generator expected to receive the signed manifest copy from the TSDF (35 days for domestic, 45 days for international shipments).' ;
    rdfs:domain ind:ExceptionReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:followUpActionsTaken rdf:type rdf:Property ;
    rdfs:label 'Follow Up Actions Taken' ;
    rdfs:comment 'Description of the actions taken by the generator to contact the TSDF and attempt to obtain the signed manifest copy before filing the exception report.' ;
    rdfs:domain ind:ExceptionReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:generatorContactEmail rdf:type rdf:Property ;
    rdfs:label 'Generator Contact Email' ;
    rdfs:comment 'Email address of the generator representative who filed the exception report.' ;
    rdfs:domain ind:ExceptionReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:generatorContactPhone rdf:type rdf:Property ;
    rdfs:label 'Generator Contact Phone' ;
    rdfs:comment 'Phone number of the generator representative who filed the exception report.' ;
    rdfs:domain ind:Hazmat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:generatorName rdf:type rdf:Property ;
    rdfs:label 'Generator Name' ;
    rdfs:comment 'Legal name of the hazardous waste generator who filed the exception report.' ;
    rdfs:domain ind:Hazmat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryActionDescription rdf:type rdf:Property ;
    rdfs:label 'Regulatory Action Description' ;
    rdfs:comment 'Description of any enforcement or corrective action taken by the regulatory authority in response to this exception report.' ;
    rdfs:domain ind:ExceptionReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryActionRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Action Required' ;
    rdfs:comment 'Indicates whether the regulatory authority determined that enforcement or corrective action was required based on this exception report.' ;
    rdfs:domain ind:ExceptionReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resolutionStatus rdf:type rdf:Property ;
    rdfs:label 'Resolution Status' ;
    rdfs:comment 'Current status of the exception report resolution process.' ;
    rdfs:domain ind:ExceptionReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentType rdf:type rdf:Property ;
    rdfs:label 'Shipment Type' ;
    rdfs:comment 'Indicates whether the shipment was domestic (35-day rule) or international (45-day rule) for determining exception report deadline.' ;
    rdfs:domain ind:ExceptionReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateAgencyCode rdf:type rdf:Property ;
    rdfs:label 'State Agency Code' ;
    rdfs:comment 'Two-letter state code of the regulatory agency receiving the exception report, if submitted to a state-authorized program.' ;
    rdfs:domain ind:Hazmat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tsdfName rdf:type rdf:Property ;
    rdfs:label 'Tsdf Name' ;
    rdfs:comment 'Name of the designated treatment, storage, or disposal facility that was expected to return the signed manifest.' ;
    rdfs:domain ind:Hazmat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tsdfResponse rdf:type rdf:Property ;
    rdfs:label 'Tsdf Response' ;
    rdfs:comment 'Summary of any response received from the TSDF during follow-up contact attempts.' ;
    rdfs:domain ind:ExceptionReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:generatorFacilityId rdf:type rdf:Property ;
    rdfs:label 'Generator Facility Id' ;
    rdfs:comment 'Foreign key linking to asset.facility. Business justification: Generator sites ARE facilities in waste management operations. Links generator regulatory records to facility asset master for permit tracking, inspection scheduling, facility utilization reporting, a' ;
    rdfs:domain ind:HazardousWasteGenerator ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:responsibleOfficialEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Responsible Official Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: EPA hazardous waste generator notifications require designated responsible official per 40 CFR 262.12. Tracking employee_id enables signature authority verification, certification tracking, regulatory' ;
    rdfs:domain ind:HazardousWasteGenerator ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:trackedSiteId rdf:type rdf:Property ;
    rdfs:label 'Tracked Site Id' ;
    rdfs:comment 'Foreign key linking to sustainability.tracked_site. Business justification: Hazardous waste generators are sustainability tracking sites for ESG reporting. Corporate sustainability teams track emissions, waste metrics, and compliance by generator location. Standard ESG report' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TrackedSite .

ind:accumulationStartDateLimitDays rdf:type rdf:Property ;
    rdfs:label 'Accumulation Start Date Limit Days' ;
    rdfs:comment 'Maximum number of days hazardous waste may be accumulated on-site before shipment, based on generator category. LQG: 90 days; SQG: 180 days (or 270 if >200 miles from TSDF); VSQG: no time limit but quantity limits apply.' ;
    rdfs:domain ind:HazardousWasteGenerator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:biennialReportRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Biennial Report Required Flag' ;
    rdfs:comment 'Indicates whether the generator is required to submit biennial hazardous waste reports to EPA. Required for LQGs and some SQGs.' ;
    rdfs:domain ind:HazardousWasteGenerator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contingencyPlanLastUpdatedDate rdf:type rdf:Property ;
    rdfs:label 'Contingency Plan Last Updated Date' ;
    rdfs:comment 'Date when the contingency plan was last reviewed and updated. Plans must be reviewed annually and updated as needed.' ;
    rdfs:domain ind:HazardousWasteGenerator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contingencyPlanReference rdf:type rdf:Property ;
    rdfs:label 'Contingency Plan Reference' ;
    rdfs:comment 'Reference identifier or document location for the site\'s hazardous waste contingency plan. Required for LQGs and SQGs.' ;
    rdfs:domain ind:HazardousWasteGenerator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enforcementActionCount rdf:type rdf:Property ;
    rdfs:label 'Enforcement Action Count' ;
    rdfs:comment 'Total number of formal enforcement actions (notices of violation, administrative orders, civil penalties) issued against this generator.' ;
    rdfs:domain ind:HazardousWasteGenerator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:federalFacilityFlag rdf:type rdf:Property ;
    rdfs:label 'Federal Facility Flag' ;
    rdfs:comment 'Indicates whether the generator is a federal government facility (e.g., military base, federal laboratory). Federal facilities have specific RCRA compliance requirements.' ;
    rdfs:domain ind:HazardousWasteGenerator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:generatorLegalName rdf:type rdf:Property ;
    rdfs:label 'Generator Legal Name' ;
    rdfs:comment 'The official legal name of the hazardous waste generating entity as registered with EPA and state authorities.' ;
    rdfs:domain ind:HazardousWasteGenerator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initialNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Initial Notification Date' ;
    rdfs:comment 'Date when the generator first notified EPA of hazardous waste generation activities and received EPA ID number.' ;
    rdfs:domain ind:HazardousWasteGenerator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inspectionFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Inspection Frequency Months' ;
    rdfs:comment 'Expected frequency of regulatory inspections by EPA or state authorities, in months. Varies by generator category and compliance history.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastBiennialReportYear rdf:type rdf:Property ;
    rdfs:label 'Last Biennial Report Year' ;
    rdfs:comment 'The reporting year of the most recently submitted biennial hazardous waste report (e.g., 2022 for the 2021-2022 reporting period).' ;
    rdfs:domain ind:HazardousWasteGenerator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastNotificationUpdateDate rdf:type rdf:Property ;
    rdfs:label 'Last Notification Update Date' ;
    rdfs:comment 'Date of the most recent update to the generator\'s EPA notification information. Generators must notify EPA of changes within 30 days.' ;
    rdfs:domain ind:HazardousWasteGenerator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mailingAddress rdf:type rdf:Property ;
    rdfs:label 'Mailing Address' ;
    rdfs:comment 'Mailing address for correspondence and regulatory notifications if different from site address.' ;
    rdfs:domain ind:HazardousWasteGenerator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Record Source System' ;
    rdfs:comment 'Name of the source system from which this generator record originated (e.g., Enviance EHS, SAP EHS, EPA RCRAInfo).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteState rdf:type rdf:Property ;
    rdfs:label 'Site State' ;
    rdfs:comment 'Two-letter state code for the generator site location. Used for jurisdictional compliance determination.' ;
    rdfs:domain ind:HazardousWasteGenerator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteStreetAddress rdf:type rdf:Property ;
    rdfs:label 'Site Street Address' ;
    rdfs:comment 'Physical street address of the hazardous waste generation site. Required for manifest preparation and emergency response.' ;
    rdfs:domain ind:HazardousWasteGenerator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteZipCode rdf:type rdf:Property ;
    rdfs:label 'Site Zip Code' ;
    rdfs:comment 'ZIP code for the generator site. Supports 5-digit or 9-digit (ZIP+4) format.' ;
    rdfs:domain ind:HazardousWasteGenerator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateGeneratorCode rdf:type rdf:Property ;
    rdfs:label 'State Generator Code' ;
    rdfs:comment 'State-specific generator identification number if different from EPA ID. Some states maintain parallel registration systems.' ;
    rdfs:domain ind:HazardousWasteGenerator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteMinimizationPlanFlag rdf:type rdf:Property ;
    rdfs:label 'Waste Minimization Plan Flag' ;
    rdfs:comment 'Indicates whether the generator has a documented waste minimization plan in place. Required for LQGs under some state programs.' ;
    rdfs:domain ind:HazardousWasteGenerator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:manifestLineId rdf:type rdf:Property ;
    rdfs:label 'Manifest Line Id' ;
    rdfs:comment 'Foreign key linking to hazmat.manifest_line. Business justification: Containers are listed on specific manifest line items. One container appears on one manifest line. This links the container to the specific line item on the manifest, replacing the INT manifest_line_n' ;
    rdfs:domain ind:Hazmat ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ManifestLine .

ind:storageFacilityId rdf:type rdf:Property ;
    rdfs:label 'Storage Facility Id' ;
    rdfs:comment 'Reference to the physical facility or site where the container is currently stored. Links to facility EPA ID number and permit information.' ;
    rdfs:domain ind:HazmatContainer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:tsdfEpaEpaIdRegistrationId rdf:type rdf:Property ;
    rdfs:label 'Tsdf Epa Epa Id Registration Id' ;
    rdfs:comment 'EPA ID number of the permitted TSDF facility designated to receive and dispose of this container. Must be listed on the hazardous waste manifest.' ;
    rdfs:domain ind:Hazmat ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EpaIdRegistration .

ind:accumulationDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Accumulation Deadline Date' ;
    rdfs:comment 'Regulatory deadline by which the container must be shipped off-site to avoid RCRA violations. Calculated based on generator status and accumulation start date.' ;
    rdfs:domain ind:HazmatContainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accumulationStartDate rdf:type rdf:Property ;
    rdfs:label 'Accumulation Start Date' ;
    rdfs:comment 'Date when hazardous waste was first placed into this container. Triggers regulatory accumulation time limits (90-day rule for large quantity generators, 180/270-day for small quantity generators).' ;
    rdfs:domain ind:HazmatContainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:capacityGallons rdf:type rdf:Property ;
    rdfs:label 'Capacity Gallons' ;
    rdfs:comment 'Maximum rated capacity of the container in U.S. gallons. Used to calculate fill levels, determine accumulation limits, and plan transportation logistics.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chainOfCustodyStatus rdf:type rdf:Property ;
    rdfs:label 'Chain Of Custody Status' ;
    rdfs:comment 'Current custody status in the cradle-to-grave tracking chain. Indicates which party currently has physical possession and legal responsibility for the container.' ;
    rdfs:domain ind:HazmatContainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:condition rdf:type rdf:Property ;
    rdfs:label 'Condition' ;
    rdfs:comment 'Assessment of the physical integrity and condition of the container. Critical for safety, regulatory compliance, and determining if container requires overpacking or replacement.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerStatus rdf:type rdf:Property ;
    rdfs:label 'Container Status' ;
    rdfs:comment 'Current state of the container in its lifecycle from deployment through final disposal. Drives regulatory compliance timelines (e.g., 90-day accumulation limits) and operational workflows.' ;
    rdfs:domain ind:HazmatContainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dotPackingGroup rdf:type rdf:Property ;
    rdfs:label 'Dot Packing Group' ;
    rdfs:comment 'DOT packing group (I, II, or III) indicating the degree of danger: I = high danger, II = medium danger, III = low danger. Determines packaging requirements.' ;
    rdfs:domain ind:Hazmat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dotUnNumber rdf:type rdf:Property ;
    rdfs:label 'Dot Un Number' ;
    rdfs:comment 'Four-digit UN identification number assigned to the hazardous material for international transportation (e.g., UN1203 for gasoline). Required on shipping papers and labels.' ;
    rdfs:domain ind:HazmatContainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fillLevelPercent rdf:type rdf:Property ;
    rdfs:label 'Fill Level Percent' ;
    rdfs:comment 'Current fill level of the container as a percentage of total capacity. Used to determine when container is full and ready for pickup, and to comply with DOT fill requirements.' ;
    rdfs:domain ind:HazmatContainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:identificationNumber rdf:type rdf:Property ;
    rdfs:label 'Identification Number' ;
    rdfs:comment 'External business identifier for the container, typically a barcode or RFID tag number used for scanning and tracking in the field. May be printed on container label.' ;
    rdfs:domain ind:HazmatContainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelAffixedDate rdf:type rdf:Property ;
    rdfs:label 'Label Affixed Date' ;
    rdfs:comment 'Date when the hazardous waste label was affixed to the container. RCRA requires containers to be labeled upon start of accumulation with waste identity and accumulation start date.' ;
    rdfs:domain ind:HazmatContainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:materialOfConstruction rdf:type rdf:Property ;
    rdfs:label 'Material Of Construction' ;
    rdfs:comment 'Primary material used in container construction. Must be compatible with waste characteristics to prevent corrosion, leakage, or chemical reaction.' ;
    rdfs:domain ind:HazmatContainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netWasteWeightLbs rdf:type rdf:Property ;
    rdfs:label 'Net Waste Weight Lbs' ;
    rdfs:comment 'Calculated weight of waste contents only (gross weight minus tare weight) in pounds. Used for billing, regulatory reporting, and disposal facility acceptance.' ;
    rdfs:domain ind:HazmatContainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:secondaryContainmentRequired rdf:type rdf:Property ;
    rdfs:label 'Secondary Containment Required' ;
    rdfs:comment 'Indicates whether this container must be stored in secondary containment (e.g., spill pallet, containment berm) based on waste characteristics and regulatory requirements.' ;
    rdfs:domain ind:HazmatContainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:storageLocationType rdf:type rdf:Property ;
    rdfs:label 'Storage Location Type' ;
    rdfs:comment 'Classification of the storage area where the container is currently located. Determines applicable regulatory requirements and accumulation time limits.' ;
    rdfs:domain ind:HazmatContainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unPerformanceRating rdf:type rdf:Property ;
    rdfs:label 'Un Performance Rating' ;
    rdfs:comment 'UN packaging specification code indicating the container has been tested and certified for transporting hazardous materials. Format example: UN1A2/X150/S for a steel drum.' ;
    rdfs:domain ind:HazmatContainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crewLeadEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Crew Lead Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Hazmat service orders assign field crew leadership for on-site waste collection. Tracking crew lead enables labor cost allocation, HAZWOPER certification verification, safety accountability, and perfo' ;
    rdfs:domain ind:ServiceOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:fleetFuelConsumptionId rdf:type rdf:Property ;
    rdfs:label 'Fleet Fuel Consumption Id' ;
    rdfs:comment 'Foreign key linking to sustainability.fleet_fuel_consumption. Business justification: Hazmat service orders require specialized vehicles with tracked fuel consumption. Linking orders to fuel records enables accurate Scope 1 emissions allocation per service type and supports DOT complia' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FleetFuelConsumption .

ind:generatorPermitId rdf:type rdf:Property ;
    rdfs:label 'Generator Permit Id' ;
    rdfs:comment 'Foreign key linking to compliance.permit. Business justification: Service orders for hazmat collection require verification that generator operates under valid permit. Pre-service compliance check ensures legal authority to generate and ship waste, protecting servic' ;
    rdfs:domain ind:Hazmat ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Permit .

ind:meetingId rdf:type rdf:Property ;
    rdfs:label 'Meeting Id' ;
    rdfs:comment 'Foreign key linking to safety.safety_meeting. Business justification: Pre-job safety meetings (tailgate meetings) for hazmat service orders document crew briefings on job-specific hazards, controls, and emergency procedures. Links safety communication to specific work o' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Meeting .

ind:orgUnitId rdf:type rdf:Property ;
    rdfs:label 'Org Unit Id' ;
    rdfs:comment 'Reference to the hazardous waste handling crew assigned to perform the service.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:serviceFacilityId rdf:type rdf:Property ;
    rdfs:label 'Service Facility Id' ;
    rdfs:comment 'Foreign key linking to asset.facility. Business justification: Hazmat service orders are fulfilled at facilities (customer sites or company facilities). Links service orders to facility asset records for facility utilization tracking, service history analysis, fa' ;
    rdfs:domain ind:ServiceOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:actualAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Amount' ;
    rdfs:comment 'Final invoiced amount for the hazardous waste service based on actual quantities and services performed.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualQuantityUom rdf:type rdf:Property ;
    rdfs:label 'Actual Quantity Uom' ;
    rdfs:comment 'Unit of measure for the actual waste quantity collected: drums, gallons, pounds, tons, cubic yards, liters, or kilograms. [ENUM-REF-CANDIDATE: drums|gallons|pounds|tons|cubic_yards|liters|kilograms — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualWasteQuantity rdf:type rdf:Property ;
    rdfs:label 'Actual Waste Quantity' ;
    rdfs:comment 'Actual quantity of hazardous waste collected or treated, as measured by the field crew upon service completion.' ;
    rdfs:domain ind:ServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:completedDate rdf:type rdf:Property ;
    rdfs:label 'Completed Date' ;
    rdfs:comment 'Date when the hazardous waste service was actually completed in the field.' ;
    rdfs:domain ind:ServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customerPoNumber rdf:type rdf:Property ;
    rdfs:label 'Customer Po Number' ;
    rdfs:comment 'Customer-provided purchase order number for billing and accounts payable reconciliation.' ;
    rdfs:domain ind:ServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyResponseFlag rdf:type rdf:Property ;
    rdfs:label 'Emergency Response Flag' ;
    rdfs:comment 'Indicates whether this service order is for an emergency spill response or urgent hazardous waste situation requiring immediate action.' ;
    rdfs:domain ind:Hazmat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedQuantityUom rdf:type rdf:Property ;
    rdfs:label 'Estimated Quantity Uom' ;
    rdfs:comment 'Unit of measure for the estimated waste quantity: drums, gallons, pounds, tons, cubic yards, liters, or kilograms. [ENUM-REF-CANDIDATE: drums|gallons|pounds|tons|cubic_yards|liters|kilograms — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedWasteQuantity rdf:type rdf:Property ;
    rdfs:label 'Estimated Waste Quantity' ;
    rdfs:comment 'Estimated quantity of hazardous waste to be collected or treated, as provided by the customer during order placement.' ;
    rdfs:domain ind:ServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderDate rdf:type rdf:Property ;
    rdfs:label 'Order Date' ;
    rdfs:comment 'Date when the hazardous waste service order was placed by the customer.' ;
    rdfs:domain ind:ServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ppeRequirements rdf:type rdf:Property ;
    rdfs:label 'Ppe Requirements' ;
    rdfs:comment 'Required personal protective equipment for field crew performing the hazardous waste service (e.g., Level A, B, C, or D protection; respirator type; chemical-resistant suit).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotedAmount rdf:type rdf:Property ;
    rdfs:label 'Quoted Amount' ;
    rdfs:comment 'Initial quoted price for the hazardous waste service provided to the customer during order placement.' ;
    rdfs:domain ind:ServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyBriefingRequired rdf:type rdf:Property ;
    rdfs:label 'Safety Briefing Required' ;
    rdfs:comment 'Indicates whether a site-specific safety briefing is required before performing the hazardous waste service.' ;
    rdfs:domain ind:ServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceNotes rdf:type rdf:Property ;
    rdfs:label 'Service Notes' ;
    rdfs:comment 'Additional notes, instructions, or observations related to the hazardous waste service order, including site access instructions, customer requests, or field crew observations.' ;
    rdfs:domain ind:ServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialHandlingRequirements rdf:type rdf:Property ;
    rdfs:label 'Special Handling Requirements' ;
    rdfs:comment 'Any special handling, packaging, or safety requirements for the hazardous waste service (e.g., temperature control, inert atmosphere, shock-sensitive, reactive precautions).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousTrainingHazwoperTrainingId rdf:type rdf:Property ;
    rdfs:label 'Previous Training Hazwoper Training Id' ;
    rdfs:comment 'Reference to the previous HAZWOPER training record for this employee, establishing training history chain. Used to track initial training and subsequent refresher courses.' ;
    rdfs:domain ind:HazwoperTraining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HazwoperTraining .

ind:primaryHazwoperEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Hazwoper Employee Id' ;
    rdfs:comment 'Reference to the employee who completed the HAZWOPER training. Links to workforce management system.' ;
    rdfs:domain ind:HazwoperTraining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:safetyTrainingRecordId rdf:type rdf:Property ;
    rdfs:label 'Safety Training Record Id' ;
    rdfs:comment 'Foreign key linking to safety.safety_training_record. Business justification: HAZWOPER certifications are specialized safety training records requiring integration with enterprise training management. Links OSHA 1910.120 compliance to broader safety training tracking for report' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SafetyTrainingRecord .

ind:workSiteEpaIdRegistrationId rdf:type rdf:Property ;
    rdfs:label 'Work Site Epa Id Registration Id' ;
    rdfs:comment 'Foreign key linking to hazmat.epa_id_registration. Business justification: HAZWOPER training is site-specific and references the work site\'s EPA ID. The epa_id_number string is a denormalized reference. Adding labeled FK (work_site_epa_id_registration_id) normalizes this. Re' ;
    rdfs:domain ind:HazwoperTraining ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EpaIdRegistration .

ind:assessmentPassed rdf:type rdf:Property ;
    rdfs:label 'Assessment Passed' ;
    rdfs:comment 'Indicates whether the employee passed the HAZWOPER training assessment. True if passed, False if failed.' ;
    rdfs:domain ind:HazwoperTraining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assessmentScore rdf:type rdf:Property ;
    rdfs:label 'Assessment Score' ;
    rdfs:comment 'Final assessment score or percentage achieved by the employee on the HAZWOPER training examination. Minimum passing score typically 70%.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificateDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Certificate Document Url' ;
    rdfs:comment 'URL or file path to the digital copy of the HAZWOPER training certificate stored in the document management system.' ;
    rdfs:domain ind:HazwoperTraining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateIssued rdf:type rdf:Property ;
    rdfs:label 'Certificate Issued' ;
    rdfs:comment 'Indicates whether a physical or digital training certificate was issued to the employee. True if issued, False if not issued.' ;
    rdfs:domain ind:HazwoperTraining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Compliance Verification Date' ;
    rdfs:comment 'Date when the Environmental Health and Safety (EHS) department verified that the HAZWOPER training meets all regulatory requirements.' ;
    rdfs:domain ind:HazwoperTraining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fitTestDate rdf:type rdf:Property ;
    rdfs:label 'Fit Test Date' ;
    rdfs:comment 'Date when the employee completed respirator fit testing as required for workers who may use respiratory protection during hazardous waste operations.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fitTestExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Fit Test Expiration Date' ;
    rdfs:comment 'Date when the respirator fit test expires. OSHA requires annual fit testing.' ;
    rdfs:domain ind:HazwoperTraining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:jobRole rdf:type rdf:Property ;
    rdfs:label 'Job Role' ;
    rdfs:comment 'Specific job role or position for which the HAZWOPER training was completed (e.g., hazmat technician, site supervisor, emergency responder).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalSurveillanceClearanceDate rdf:type rdf:Property ;
    rdfs:label 'Medical Surveillance Clearance Date' ;
    rdfs:comment 'Date when the employee received medical clearance to work with hazardous materials per OSHA 29 CFR 1910.120(f). Medical surveillance is required before assignment to hazardous waste operations.' ;
    rdfs:domain ind:HazwoperTraining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:medicalSurveillanceExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Medical Surveillance Expiration Date' ;
    rdfs:comment 'Date when the medical surveillance clearance expires. OSHA requires annual medical examinations for hazardous waste workers.' ;
    rdfs:domain ind:HazwoperTraining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reimbursementStatus rdf:type rdf:Property ;
    rdfs:label 'Reimbursement Status' ;
    rdfs:comment 'Status of employee reimbursement for training costs, if applicable.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalNotificationSentDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Notification Sent Date' ;
    rdfs:comment 'Date when the system sent a notification to the employee and supervisor regarding upcoming HAZWOPER training renewal requirement.' ;
    rdfs:domain ind:HazwoperTraining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:supervisorApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Supervisor Approval Date' ;
    rdfs:comment 'Date when the employees supervisor approved the HAZWOPER training completion and authorized the employee for hazardous waste work assignments.' ;
    rdfs:domain ind:HazwoperTraining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trainingCost rdf:type rdf:Property ;
    rdfs:label 'Training Cost' ;
    rdfs:comment 'Total cost incurred for the HAZWOPER training, including tuition, materials, travel, and lodging expenses.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingCostCurrency rdf:type rdf:Property ;
    rdfs:label 'Training Cost Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the training cost (e.g., USD, CAD, EUR).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingStatus rdf:type rdf:Property ;
    rdfs:label 'Training Status' ;
    rdfs:comment 'Current status of the HAZWOPER training certification. Determines whether the employee is authorized to work with hazardous materials.' ;
    rdfs:domain ind:HazwoperTraining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingTopicsCovered rdf:type rdf:Property ;
    rdfs:label 'Training Topics Covered' ;
    rdfs:comment 'Comma-separated list of specific topics covered in the HAZWOPER training (e.g., hazard recognition, PPE selection, decontamination procedures, emergency response, confined space entry).' ;
    rdfs:domain ind:HazwoperTraining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingType rdf:type rdf:Property ;
    rdfs:label 'Training Type' ;
    rdfs:comment 'Type of HAZWOPER training completed per OSHA 29 CFR 1910.120 requirements. 40-hour initial for general site workers, 24-hour initial for occasional site workers, 8-hour annual refresher, supervisor 8-hour, first responder awareness level, or first responder operations level.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workSiteAssignment rdf:type rdf:Property ;
    rdfs:label 'Work Site Assignment' ;
    rdfs:comment 'Treatment, Storage, and Disposal Facility (TSDF) or hazardous waste site where the employee is assigned to work following HAZWOPER training.' ;
    rdfs:domain ind:HazwoperTraining ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:landDisposalRestrictionId rdf:type rdf:Property ;
    rdfs:label 'Land Disposal Restriction Id' ;
    rdfs:comment 'Unique identifier for the land disposal restriction record. Primary key for the LDR notification and certification entity.' ;
    rdfs:domain ind:LandDisposalRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:treatmentRecordId rdf:type rdf:Property ;
    rdfs:label 'Treatment Record Id' ;
    rdfs:comment 'Foreign key linking to hazmat.treatment_record. Business justification: LDR certifications document that treatment standards were met before land disposal. One LDR certification references one treatment batch that achieved compliance. This links the LDR certification to t' ;
    rdfs:domain ind:Hazmat ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TreatmentRecord .

ind:analyticalMethod rdf:type rdf:Property ;
    rdfs:label 'Analytical Method' ;
    rdfs:comment 'EPA-approved analytical method used to determine constituent concentrations for LDR compliance (e.g., SW-846 methods, TCLP).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analyticalResults rdf:type rdf:Property ;
    rdfs:label 'Analytical Results' ;
    rdfs:comment 'Summary of analytical test results showing constituent concentrations compared to treatment standards, formatted as constituent:value:unit triplets.' ;
    rdfs:domain ind:LandDisposalRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifyingOfficialSignatureDate rdf:type rdf:Property ;
    rdfs:label 'Certifying Official Signature Date' ;
    rdfs:comment 'Date when the authorized representative signed the LDR certification document.' ;
    rdfs:domain ind:LandDisposalRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dilutionProhibitionFlag rdf:type rdf:Property ;
    rdfs:label 'Dilution Prohibition Flag' ;
    rdfs:comment 'Indicates whether the waste is subject to dilution prohibition under 40 CFR 268.3. True if dilution as substitute for treatment is prohibited.' ;
    rdfs:domain ind:LandDisposalRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laboratoryName rdf:type rdf:Property ;
    rdfs:label 'Laboratory Name' ;
    rdfs:comment 'Name of the certified laboratory that performed analytical testing to verify LDR compliance.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ldrNotificationType rdf:type rdf:Property ;
    rdfs:label 'Ldr Notification Type' ;
    rdfs:comment 'Type of LDR notification: one-time (single shipment), annual (covers multiple shipments of same waste), or waste-specific (unique waste stream).' ;
    rdfs:domain ind:LandDisposalRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noMigrationPetitionNumber rdf:type rdf:Property ;
    rdfs:label 'No Migration Petition Number' ;
    rdfs:comment 'Reference number for approved no-migration petition under 40 CFR 268.6, if applicable, allowing land disposal without meeting treatment standards.' ;
    rdfs:domain ind:LandDisposalRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prohibitedWasteCodes rdf:type rdf:Property ;
    rdfs:label 'Prohibited Waste Codes' ;
    rdfs:comment 'Comma-separated list of waste codes that are prohibited from land disposal without meeting treatment standards. Used when waste does not meet standards.' ;
    rdfs:domain ind:LandDisposalRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleAnalysisDate rdf:type rdf:Property ;
    rdfs:label 'Sample Analysis Date' ;
    rdfs:comment 'Date when the laboratory completed analysis of the waste sample for LDR compliance verification.' ;
    rdfs:domain ind:LandDisposalRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sampleCollectionDate rdf:type rdf:Property ;
    rdfs:label 'Sample Collection Date' ;
    rdfs:comment 'Date when the waste sample was collected for LDR compliance testing.' ;
    rdfs:domain ind:Hazmat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:storageProhibitionFlag rdf:type rdf:Property ;
    rdfs:label 'Storage Prohibition Flag' ;
    rdfs:comment 'Indicates whether the waste is subject to storage prohibition under 40 CFR 268.50. True if storage of restricted waste is prohibited except for accumulation purposes.' ;
    rdfs:domain ind:LandDisposalRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:subcategory rdf:type rdf:Property ;
    rdfs:label 'Subcategory' ;
    rdfs:comment 'Specific waste subcategory within the EPA waste code that may have different treatment standards (e.g., high mercury, low mercury, radioactive).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatmentDate rdf:type rdf:Property ;
    rdfs:label 'Treatment Date' ;
    rdfs:comment 'Date when the waste was treated to meet LDR standards, if applicable. Required when waste_meets_treatment_standards_flag is True.' ;
    rdfs:domain ind:Hazmat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:treatmentFacilityName rdf:type rdf:Property ;
    rdfs:label 'Treatment Facility Name' ;
    rdfs:comment 'Name of the facility where the waste was treated to meet LDR standards, if treatment occurred prior to shipment.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatmentStandardCode rdf:type rdf:Property ;
    rdfs:label 'Treatment Standard Code' ;
    rdfs:comment 'The specific treatment standard code from 40 CFR Part 268 Subpart D that applies to this waste (e.g., DEACT, RLEAD, STABL, MACRO, CMBST).' ;
    rdfs:domain ind:Hazmat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatmentStandardDescription rdf:type rdf:Property ;
    rdfs:label 'Treatment Standard Description' ;
    rdfs:comment 'Detailed description of the treatment standard requirements, including specific concentration limits or technology specifications that must be met.' ;
    rdfs:domain ind:LandDisposalRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatmentStandardType rdf:type rdf:Property ;
    rdfs:label 'Treatment Standard Type' ;
    rdfs:comment 'Type of treatment standard applicable to this waste: concentration-based (specific constituent levels) or technology-based (specific treatment technology required).' ;
    rdfs:domain ind:LandDisposalRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tsdfAcknowledgmentDate rdf:type rdf:Property ;
    rdfs:label 'Tsdf Acknowledgment Date' ;
    rdfs:comment 'Date when the receiving TSDF acknowledged receipt and acceptance of the LDR notification and certification.' ;
    rdfs:domain ind:LandDisposalRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:uhcTreatmentStandards rdf:type rdf:Property ;
    rdfs:label 'Uhc Treatment Standards' ;
    rdfs:comment 'Specific concentration limits or treatment requirements for each underlying hazardous constituent listed, formatted as constituent:limit pairs.' ;
    rdfs:domain ind:LandDisposalRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:underlyingHazardousConstituents rdf:type rdf:Property ;
    rdfs:label 'Underlying Hazardous Constituents' ;
    rdfs:comment 'Comma-separated list of underlying hazardous constituents present in the waste that are subject to treatment standards, even if not the primary waste code.' ;
    rdfs:domain ind:LandDisposalRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceOrExemptionNumber rdf:type rdf:Property ;
    rdfs:label 'Variance Or Exemption Number' ;
    rdfs:comment 'Reference number for any EPA-granted variance, exemption, or extension from LDR treatment standards applicable to this waste shipment.' ;
    rdfs:domain ind:LandDisposalRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteCategory rdf:type rdf:Property ;
    rdfs:label 'Waste Category' ;
    rdfs:comment 'EPA waste category classification: wastewater (contains less than 1% total organic carbon and less than 1% total suspended solids) or nonwastewater. Determines applicable treatment standards.' ;
    rdfs:domain ind:LandDisposalRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteMeetsTreatmentStandardsFlag rdf:type rdf:Property ;
    rdfs:label 'Waste Meets Treatment Standards Flag' ;
    rdfs:comment 'Indicates whether the waste has been treated to meet applicable LDR treatment standards prior to land disposal. True if waste meets standards, False if waste requires further treatment.' ;
    rdfs:domain ind:LandDisposalRestriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:alternateFacilityEpaEpaIdRegistrationId rdf:type rdf:Property ;
    rdfs:label 'Alternate Facility Epa Epa Id Registration Id' ;
    rdfs:comment 'EPA ID of an alternate TSDF facility designated by the generator if the primary TSDF cannot accept the waste.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EpaIdRegistration .

ind:generatorCertifyingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Generator Certifying Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Hazardous waste manifests require generator certification signature per 40 CFR 262.23. Tracking the certifying employee enables audit trails, signature authority verification, and regulatory complianc' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:transporter2EpaEpaIdRegistrationId rdf:type rdf:Property ;
    rdfs:label 'Transporter 2 Epa Epa Id Registration Id' ;
    rdfs:comment 'EPA ID of the second transporter if multiple transporters are involved in the shipment chain.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EpaIdRegistration .

ind:discrepancyIndication rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Indication' ;
    rdfs:comment 'Boolean flag indicating whether the TSDF identified any discrepancies between the manifest and the actual shipment received (quantity, type, condition).' ;
    rdfs:domain ind:Hazmat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dotIdNumber rdf:type rdf:Property ;
    rdfs:label 'Dot Id Number' ;
    rdfs:comment 'Four-digit UN or NA identification number assigned to the hazardous material for transportation (e.g., UN1203 for gasoline).' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:generatorCity rdf:type rdf:Property ;
    rdfs:label 'Generator City' ;
    rdfs:comment 'City where the generator facility is located.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:generatorContactName rdf:type rdf:Property ;
    rdfs:label 'Generator Contact Name' ;
    rdfs:comment 'Name of the authorized representative at the generator facility responsible for the manifest.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:generatorEmergencyPhone rdf:type rdf:Property ;
    rdfs:label 'Generator Emergency Phone' ;
    rdfs:comment '24-hour emergency response phone number for incidents involving this waste shipment (e.g., CHEMTREC, facility emergency line).' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:generatorSignatureDate rdf:type rdf:Property ;
    rdfs:label 'Generator Signature Date' ;
    rdfs:comment 'Date the generator authorized representative signed the manifest certifying the waste information is accurate.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:generatorSiteAddress rdf:type rdf:Property ;
    rdfs:label 'Generator Site Address' ;
    rdfs:comment 'Physical street address of the generator facility where the hazardous waste was produced.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:generatorState rdf:type rdf:Property ;
    rdfs:label 'Generator State' ;
    rdfs:comment 'Two-letter US state code for the generator facility location.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:generatorZipCode rdf:type rdf:Property ;
    rdfs:label 'Generator Zip Code' ;
    rdfs:comment 'US postal ZIP code for the generator facility (5-digit or ZIP+4 format).' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:importIndication rdf:type rdf:Property ;
    rdfs:label 'Import Indication' ;
    rdfs:comment 'Boolean flag indicating whether this manifest documents an international import of hazardous waste into the United States.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:importPortOfEntry rdf:type rdf:Property ;
    rdfs:label 'Import Port Of Entry' ;
    rdfs:comment 'US port of entry location for international hazardous waste imports.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manifestType rdf:type rdf:Property ;
    rdfs:label 'Manifest Type' ;
    rdfs:comment 'Format type of the manifest submission: paper (traditional hard copy), electronic (e-Manifest via RCRAInfo), or hybrid (combination).' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivedDate rdf:type rdf:Property ;
    rdfs:label 'Received Date' ;
    rdfs:comment 'Date the TSDF facility received and accepted the hazardous waste shipment. Used to calculate transit time and verify timely delivery.' ;
    rdfs:domain ind:Hazmat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rejectionIndication rdf:type rdf:Property ;
    rdfs:label 'Rejection Indication' ;
    rdfs:comment 'Boolean flag indicating whether the TSDF rejected all or part of the waste shipment.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:residueIndication rdf:type rdf:Property ;
    rdfs:label 'Residue Indication' ;
    rdfs:comment 'Boolean flag indicating whether the containers being shipped contain only residue (less than 3% by weight remaining after emptying).' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transporter1Name rdf:type rdf:Property ;
    rdfs:label 'Transporter 1 Name' ;
    rdfs:comment 'Legal name of the first transporter company handling the waste shipment.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transporter2Name rdf:type rdf:Property ;
    rdfs:label 'Transporter 2 Name' ;
    rdfs:comment 'Legal name of the second transporter company if applicable.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transporterSignatureDate rdf:type rdf:Property ;
    rdfs:label 'Transporter Signature Date' ;
    rdfs:comment 'Date the transporter signed the manifest acknowledging receipt of the waste shipment from the generator.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tsdfCity rdf:type rdf:Property ;
    rdfs:label 'Tsdf City' ;
    rdfs:comment 'City where the TSDF facility is located.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tsdfSignatureDate rdf:type rdf:Property ;
    rdfs:label 'Tsdf Signature Date' ;
    rdfs:comment 'Date the TSDF authorized representative signed the manifest certifying receipt of the waste shipment.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tsdfSiteAddress rdf:type rdf:Property ;
    rdfs:label 'Tsdf Site Address' ;
    rdfs:comment 'Physical street address of the TSDF facility receiving the waste.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tsdfState rdf:type rdf:Property ;
    rdfs:label 'Tsdf State' ;
    rdfs:comment 'Two-letter US state code for the TSDF facility location.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tsdfZipCode rdf:type rdf:Property ;
    rdfs:label 'Tsdf Zip Code' ;
    rdfs:comment 'US postal ZIP code for the TSDF facility.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discrepancyComments rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Comments' ;
    rdfs:comment 'Detailed explanation of any discrepancy between the manifest description and the waste received. Required when discrepancy_indication is not none.' ;
    rdfs:domain ind:ManifestLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dotProperShippingName rdf:type rdf:Property ;
    rdfs:label 'Dot Proper Shipping Name' ;
    rdfs:comment 'Official DOT proper shipping name from the Hazardous Materials Table. Must be used on shipping papers and placards.' ;
    rdfs:domain ind:ManifestLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flashPointFahrenheit rdf:type rdf:Property ;
    rdfs:label 'Flash Point Fahrenheit' ;
    rdfs:comment 'Flash point temperature in degrees Fahrenheit. Wastes with flash point below 140°F are characteristic hazardous wastes (D001) and DOT Class 3 flammable liquids.' ;
    rdfs:domain ind:ManifestLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:generatorComments rdf:type rdf:Property ;
    rdfs:label 'Generator Comments' ;
    rdfs:comment 'Additional comments or notes from the waste generator regarding this waste stream. May include process information, generation date, or other relevant details.' ;
    rdfs:domain ind:ManifestLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineStatus rdf:type rdf:Property ;
    rdfs:label 'Line Status' ;
    rdfs:comment 'Current status of this manifest line item in the cradle-to-grave tracking workflow. Tracks progression from draft through final disposition.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managementMethodCode rdf:type rdf:Property ;
    rdfs:label 'Management Method Code' ;
    rdfs:comment 'Code indicating the intended treatment, storage, or disposal method for this waste stream at the designated TSDF facility.' ;
    rdfs:domain ind:ManifestLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marinePollutantFlag rdf:type rdf:Property ;
    rdfs:label 'Marine Pollutant Flag' ;
    rdfs:comment 'Indicates whether the waste is designated as a marine pollutant under DOT regulations. Requires special marking and documentation for water transportation.' ;
    rdfs:domain ind:ManifestLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pcbConcentrationPpm rdf:type rdf:Property ;
    rdfs:label 'Pcb Concentration Ppm' ;
    rdfs:comment 'Concentration of PCBs in parts per million if the waste contains PCBs. Wastes with PCB concentrations of 50 ppm or greater are subject to TSCA PCB regulations.' ;
    rdfs:domain ind:ManifestLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:phValue rdf:type rdf:Property ;
    rdfs:label 'Ph Value' ;
    rdfs:comment 'pH measurement of the waste. Wastes with pH ≤2 or ≥12.5 are characteristic corrosive hazardous wastes (D002).' ;
    rdfs:domain ind:Hazmat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receivedQuantity rdf:type rdf:Property ;
    rdfs:label 'Received Quantity' ;
    rdfs:comment 'Actual quantity received by the designated facility in the specified unit of measure. May differ from total_quantity if discrepancies exist.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportableQuantityFlag rdf:type rdf:Property ;
    rdfs:label 'Reportable Quantity Flag' ;
    rdfs:comment 'Indicates whether this waste stream meets or exceeds the CERCLA reportable quantity threshold. If true, the letters RQ must appear on the manifest and shipping papers.' ;
    rdfs:domain ind:ManifestLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:wasteMinimizationCode rdf:type rdf:Property ;
    rdfs:label 'Waste Minimization Code' ;
    rdfs:comment 'Code indicating the waste minimization efforts applied to this waste stream. Required for biennial reporting under RCRA.' ;
    rdfs:domain ind:Hazmat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rcraBiennialReportId rdf:type rdf:Property ;
    rdfs:label 'Rcra Biennial Report Id' ;
    rdfs:comment 'Unique identifier for the RCRA Biennial Report submission record. Primary key.' ;
    rdfs:domain ind:Hazmat ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RcraBiennialReport .

ind:reportingFacilityId rdf:type rdf:Property ;
    rdfs:label 'Reporting Facility Id' ;
    rdfs:comment 'Foreign key linking to asset.facility. Business justification: Biennial reports are submitted per facility to EPA. Links regulatory reports to facility asset master for compliance tracking, facility performance benchmarking, audit trails, and facility-level waste' ;
    rdfs:domain ind:RcraBiennialReport ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:certificationTitle rdf:type rdf:Property ;
    rdfs:label 'Certification Title' ;
    rdfs:comment 'Job title of the authorized facility representative who certified the biennial report (e.g., Environmental Manager, Facility Director, Compliance Officer).' ;
    rdfs:domain ind:RcraBiennialReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberOfTsdfDestinations rdf:type rdf:Property ;
    rdfs:label 'Number Of Tsdf Destinations' ;
    rdfs:comment 'The count of distinct off-site TSDF facilities to which hazardous waste was shipped during the reporting year. Each TSDF is identified by its EPA ID number.' ;
    rdfs:domain ind:RcraBiennialReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numberOfWasteCodesReported rdf:type rdf:Property ;
    rdfs:label 'Number Of Waste Codes Reported' ;
    rdfs:comment 'The count of distinct EPA hazardous waste codes (e.g., D001, F001, K001) reported in this biennial report. Each waste stream is classified by one or more waste codes.' ;
    rdfs:domain ind:RcraBiennialReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:offsiteShipmentFlag rdf:type rdf:Property ;
    rdfs:label 'Offsite Shipment Flag' ;
    rdfs:comment 'Indicates whether the facility shipped any hazardous waste off-site to TSDFs during the reporting year. True = off-site shipments occurred, False = all waste managed on-site.' ;
    rdfs:domain ind:RcraBiennialReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:onsiteTreatmentFlag rdf:type rdf:Property ;
    rdfs:label 'Onsite Treatment Flag' ;
    rdfs:comment 'Indicates whether the facility performed any on-site treatment, storage, or disposal of hazardous waste during the reporting year. True = on-site management occurred, False = all waste shipped off-site.' ;
    rdfs:domain ind:RcraBiennialReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryTreatmentMethod rdf:type rdf:Property ;
    rdfs:label 'Primary Treatment Method' ;
    rdfs:comment 'The predominant treatment, storage, or disposal method used for hazardous waste during the reporting year. Examples: incineration, stabilization, landfill, fuel blending, recycling, neutralization.' ;
    rdfs:domain ind:RcraBiennialReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryWasteCode rdf:type rdf:Property ;
    rdfs:label 'Primary Waste Code' ;
    rdfs:comment 'The EPA hazardous waste code representing the largest volume of waste generated during the reporting year. Format: one letter (D=characteristic, F=non-specific source, K=specific source, P/U=acute/toxic) followed by three digits.' ;
    rdfs:domain ind:RcraBiennialReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryWasteDescription rdf:type rdf:Property ;
    rdfs:label 'Primary Waste Description' ;
    rdfs:comment 'Textual description of the primary waste stream corresponding to the primary waste code. Describes the waste source, composition, and hazardous characteristics.' ;
    rdfs:domain ind:RcraBiennialReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalWasteGeneratedLbs rdf:type rdf:Property ;
    rdfs:label 'Total Waste Generated Lbs' ;
    rdfs:comment 'The total quantity of RCRA hazardous waste generated during the reporting year, measured in pounds. Aggregated across all waste codes managed by the facility.' ;
    rdfs:domain ind:RcraBiennialReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalWasteManagedOnsiteLbs rdf:type rdf:Property ;
    rdfs:label 'Total Waste Managed Onsite Lbs' ;
    rdfs:comment 'The total quantity of hazardous waste treated, stored, or disposed of on-site at the generator facility during the reporting year, measured in pounds.' ;
    rdfs:domain ind:RcraBiennialReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalWasteShippedOffsiteLbs rdf:type rdf:Property ;
    rdfs:label 'Total Waste Shipped Offsite Lbs' ;
    rdfs:comment 'The total quantity of hazardous waste shipped off-site to Treatment, Storage, and Disposal Facilities (TSDFs) during the reporting year, measured in pounds.' ;
    rdfs:domain ind:RcraBiennialReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wasteMinimizationAchievedFlag rdf:type rdf:Property ;
    rdfs:label 'Waste Minimization Achieved Flag' ;
    rdfs:comment 'Indicates whether the facility achieved measurable waste minimization or source reduction during the reporting year. True = minimization achieved, False = no reduction.' ;
    rdfs:domain ind:RcraBiennialReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:wasteMinimizationActivities rdf:type rdf:Property ;
    rdfs:label 'Waste Minimization Activities' ;
    rdfs:comment 'Narrative description of waste minimization, source reduction, and pollution prevention activities undertaken during the reporting year. Required disclosure per RCRA biennial reporting requirements.' ;
    rdfs:domain ind:RcraBiennialReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buildingLocation rdf:type rdf:Property ;
    rdfs:label 'Building Location' ;
    rdfs:comment 'Physical building or structure identifier where the storage unit is located within the facility campus.' ;
    rdfs:domain ind:StorageUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Closure Certification Number' ;
    rdfs:comment 'Certification number issued by regulatory authority confirming that the storage unit closure was completed in accordance with RCRA requirements.' ;
    rdfs:domain ind:StorageUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentInventoryQuantity rdf:type rdf:Property ;
    rdfs:label 'Current Inventory Quantity' ;
    rdfs:comment 'Current quantity of hazardous waste stored in the unit at the time of last inventory update. Measured in the unit of measure specified for this storage unit.' ;
    rdfs:domain ind:StorageUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emergencyResponseZone rdf:type rdf:Property ;
    rdfs:label 'Emergency Response Zone' ;
    rdfs:comment 'Emergency response zone designation for this storage unit within the facility emergency action plan. Used for HAZWOPER response coordination.' ;
    rdfs:domain ind:StorageUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exemptionBasis rdf:type rdf:Property ;
    rdfs:label 'Exemption Basis' ;
    rdfs:comment 'Regulatory basis under which this storage unit operates without a full RCRA permit. Identifies the specific exemption category that applies.' ;
    rdfs:domain ind:StorageUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fireSuppressionSystem rdf:type rdf:Property ;
    rdfs:label 'Fire Suppression System' ;
    rdfs:comment 'Type of fire suppression system installed to protect the storage unit. Required for certain hazardous waste storage configurations.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incompatibleWasteCodes rdf:type rdf:Property ;
    rdfs:label 'Incompatible Waste Codes' ;
    rdfs:comment 'Comma-separated list of EPA waste codes that must not be stored in this unit due to incompatibility concerns. Used to prevent dangerous chemical reactions.' ;
    rdfs:domain ind:StorageUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Inventory Unit Of Measure' ;
    rdfs:comment 'Unit of measure used for tracking inventory quantity in this storage unit. Must align with the capacity measurement unit.' ;
    rdfs:domain ind:StorageUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumCapacityGallons rdf:type rdf:Property ;
    rdfs:label 'Maximum Capacity Gallons' ;
    rdfs:comment 'Maximum permitted storage capacity of the unit measured in gallons. Applicable for liquid waste storage tanks and container storage areas. Regulatory limit that must not be exceeded.' ;
    rdfs:domain ind:StorageUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumCapacityPounds rdf:type rdf:Property ;
    rdfs:label 'Maximum Capacity Pounds' ;
    rdfs:comment 'Maximum permitted storage capacity of the unit measured in pounds. Applicable for solid waste storage areas and satellite accumulation points. Regulatory limit that must not be exceeded.' ;
    rdfs:domain ind:StorageUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumTemperatureFahrenheit rdf:type rdf:Property ;
    rdfs:label 'Maximum Temperature Fahrenheit' ;
    rdfs:comment 'Maximum allowable temperature in Fahrenheit for safe storage of waste in this unit. Applicable when temperature control is required.' ;
    rdfs:domain ind:StorageUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumTemperatureFahrenheit rdf:type rdf:Property ;
    rdfs:label 'Minimum Temperature Fahrenheit' ;
    rdfs:comment 'Minimum allowable temperature in Fahrenheit for safe storage of waste in this unit. Applicable when temperature control is required.' ;
    rdfs:domain ind:StorageUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:permittedWasteCodes rdf:type rdf:Property ;
    rdfs:label 'Permitted Waste Codes' ;
    rdfs:comment 'Comma-separated list of EPA hazardous waste codes that are authorized for storage in this unit. Restricts the types of waste that may be placed in the unit.' ;
    rdfs:domain ind:Hazmat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roomAreaDesignation rdf:type rdf:Property ;
    rdfs:label 'Room Area Designation' ;
    rdfs:comment 'Specific room number, area code, or zone designation within the building for precise location identification.' ;
    rdfs:domain ind:StorageUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryContainmentCapacityGallons rdf:type rdf:Property ;
    rdfs:label 'Secondary Containment Capacity Gallons' ;
    rdfs:comment 'Volume capacity of the secondary containment system in gallons. Must meet or exceed 110% of the largest container or 10% of total stored volume per RCRA requirements.' ;
    rdfs:domain ind:StorageUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:secondaryContainmentType rdf:type rdf:Property ;
    rdfs:label 'Secondary Containment Type' ;
    rdfs:comment 'Type of secondary containment system installed to prevent environmental release in case of primary container failure. Required for most hazardous waste storage units under RCRA.' ;
    rdfs:domain ind:StorageUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageTimeLimitDays rdf:type rdf:Property ;
    rdfs:label 'Storage Time Limit Days' ;
    rdfs:comment 'Maximum number of days that hazardous waste may be stored in this unit before shipment is required. Varies by unit type: satellite accumulation has no time limit until 55 gallons accumulated; 90-day areas have 90-day limit.' ;
    rdfs:domain ind:StorageUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:temperatureControlRequired rdf:type rdf:Property ;
    rdfs:label 'Temperature Control Required' ;
    rdfs:comment 'Indicates whether this storage unit requires active temperature control to maintain waste stability and prevent hazardous conditions. True for temperature-sensitive wastes.' ;
    rdfs:domain ind:StorageUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unitStatus rdf:type rdf:Property ;
    rdfs:label 'Unit Status' ;
    rdfs:comment 'Current operational status of the storage unit in its lifecycle. Active units are available for waste storage; inactive units are temporarily out of service; closed units have completed closure procedures.' ;
    rdfs:domain ind:StorageUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitType rdf:type rdf:Property ;
    rdfs:label 'Unit Type' ;
    rdfs:comment 'Classification of the storage unit based on RCRA regulatory categories. Determines applicable storage time limits, capacity restrictions, and operational requirements. [ENUM-REF-CANDIDATE: satellite_accumulation_area|90_day_accumulation_area|permitted_storage_tank|container_storage_building|drip_pad|containment_building|less_than_90_day_area — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ventilationSystemType rdf:type rdf:Property ;
    rdfs:label 'Ventilation System Type' ;
    rdfs:comment 'Type of ventilation system installed to control vapor accumulation and maintain air quality in the storage area. Required for volatile hazardous waste storage.' ;
    rdfs:domain ind:StorageUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageUnitInspectionId rdf:type rdf:Property ;
    rdfs:label 'Storage Unit Inspection Id' ;
    rdfs:comment 'Unique identifier for the hazardous waste storage unit inspection record.' ;
    rdfs:domain ind:StorageUnitInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:aisleSpaceAdequate rdf:type rdf:Property ;
    rdfs:label 'Aisle Space Adequate' ;
    rdfs:comment 'Indicates whether aisle space allows unobstructed movement of personnel and emergency equipment for inspection and emergency response, typically requiring minimum 2-foot clearance.' ;
    rdfs:domain ind:StorageUnitInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:aisleSpaceNotes rdf:type rdf:Property ;
    rdfs:label 'Aisle Space Notes' ;
    rdfs:comment 'Details regarding aisle space adequacy, including measurements and any obstructions that impede access or emergency response.' ;
    rdfs:domain ind:StorageUnitInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerClosureCompliant rdf:type rdf:Property ;
    rdfs:label 'Container Closure Compliant' ;
    rdfs:comment 'Indicates whether all containers are properly closed except when adding or removing waste, as required to prevent emissions and spills.' ;
    rdfs:domain ind:StorageUnitInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:containerClosureNotes rdf:type rdf:Property ;
    rdfs:label 'Container Closure Notes' ;
    rdfs:comment 'Observations regarding container closure practices, including any open containers, damaged lids, or improper sealing.' ;
    rdfs:domain ind:StorageUnitInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerConditionNotes rdf:type rdf:Property ;
    rdfs:label 'Container Condition Notes' ;
    rdfs:comment 'Detailed observations regarding the physical condition of containers, including any signs of damage, corrosion, leakage, or deterioration.' ;
    rdfs:domain ind:StorageUnitInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerConditionPass rdf:type rdf:Property ;
    rdfs:label 'Container Condition Pass' ;
    rdfs:comment 'Indicates whether containers were found to be in good condition without signs of leakage, corrosion, bulging, or structural deterioration.' ;
    rdfs:domain ind:StorageUnitInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:correctiveActionVerifiedBy rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Verified By' ;
    rdfs:comment 'Name of the individual who verified completion of corrective actions and confirmed compliance restoration.' ;
    rdfs:domain ind:StorageUnitInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deficienciesIdentifiedCount rdf:type rdf:Property ;
    rdfs:label 'Deficiencies Identified Count' ;
    rdfs:comment 'Total number of deficiencies or non-compliance items identified during the inspection.' ;
    rdfs:domain ind:StorageUnitInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deficiencySummary rdf:type rdf:Property ;
    rdfs:label 'Deficiency Summary' ;
    rdfs:comment 'Consolidated summary of all deficiencies noted during the inspection, including specific checklist items that failed and their severity.' ;
    rdfs:domain ind:StorageUnitInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyEquipmentAvailable rdf:type rdf:Property ;
    rdfs:label 'Emergency Equipment Available' ;
    rdfs:comment 'Indicates whether required emergency equipment (spill kits, fire extinguishers, eyewash stations, safety showers, PPE) is present, accessible, and in working order.' ;
    rdfs:domain ind:StorageUnitInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:emergencyEquipmentNotes rdf:type rdf:Property ;
    rdfs:label 'Emergency Equipment Notes' ;
    rdfs:comment 'Observations regarding the availability, condition, and accessibility of emergency response equipment, including any missing or non-functional items.' ;
    rdfs:domain ind:StorageUnitInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityManagerName rdf:type rdf:Property ;
    rdfs:label 'Facility Manager Name' ;
    rdfs:comment 'Name of the facility manager who reviewed and signed off on the inspection findings.' ;
    rdfs:domain ind:StorageUnitInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incompatibleWasteNotes rdf:type rdf:Property ;
    rdfs:label 'Incompatible Waste Notes' ;
    rdfs:comment 'Details regarding waste segregation practices, including any instances of incompatible materials stored in proximity or inadequate separation measures.' ;
    rdfs:domain ind:StorageUnitInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incompatibleWasteSeparationCompliant rdf:type rdf:Property ;
    rdfs:label 'Incompatible Waste Separation Compliant' ;
    rdfs:comment 'Indicates whether incompatible wastes are properly separated to prevent reactions, as required by RCRA for reactive, ignitable, and incompatible materials.' ;
    rdfs:domain ind:StorageUnitInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectionSignedOff rdf:type rdf:Property ;
    rdfs:label 'Inspection Signed Off' ;
    rdfs:comment 'Indicates whether the inspection has been formally signed off by the inspector and facility manager, confirming review and acceptance of findings.' ;
    rdfs:domain ind:StorageUnitInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectorCertificationExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Inspector Certification Expiration Date' ;
    rdfs:comment 'Date when the inspector\'s certification expires and requires renewal.' ;
    rdfs:domain ind:StorageUnitInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inspectorCertificationType rdf:type rdf:Property ;
    rdfs:label 'Inspector Certification Type' ;
    rdfs:comment 'Type of certification held by the inspector, such as HAZWOPER 40-hour, RCRA Inspector, or facility-specific training credentials.' ;
    rdfs:domain ind:StorageUnitInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelingCompliant rdf:type rdf:Property ;
    rdfs:label 'Labeling Compliant' ;
    rdfs:comment 'Indicates whether all containers are properly labeled with waste description, hazard class, accumulation start date, and EPA waste codes as required by RCRA.' ;
    rdfs:domain ind:StorageUnitInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:labelingDeficiencyNotes rdf:type rdf:Property ;
    rdfs:label 'Labeling Deficiency Notes' ;
    rdfs:comment 'Description of any labeling deficiencies found, such as missing labels, illegible text, incorrect waste codes, or missing accumulation start dates.' ;
    rdfs:domain ind:StorageUnitInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallInspectionResult rdf:type rdf:Property ;
    rdfs:label 'Overall Inspection Result' ;
    rdfs:comment 'Summary result of the inspection indicating whether the storage unit meets all regulatory requirements or requires corrective action.' ;
    rdfs:domain ind:StorageUnitInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryContainmentIntegrityPass rdf:type rdf:Property ;
    rdfs:label 'Secondary Containment Integrity Pass' ;
    rdfs:comment 'Indicates whether secondary containment systems (berms, dikes, spill pallets) are intact, free of cracks, and capable of containing 110% of the largest container volume.' ;
    rdfs:domain ind:StorageUnitInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:secondaryContainmentNotes rdf:type rdf:Property ;
    rdfs:label 'Secondary Containment Notes' ;
    rdfs:comment 'Observations regarding the condition and adequacy of secondary containment, including any cracks, liquid accumulation, or capacity concerns.' ;
    rdfs:domain ind:StorageUnitInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signOffTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sign Off Timestamp' ;
    rdfs:comment 'Date and time when the inspection was formally signed off and approved.' ;
    rdfs:domain ind:StorageUnitInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:originalTestTclpTestId rdf:type rdf:Property ;
    rdfs:label 'Original Test Tclp Test Id' ;
    rdfs:comment 'Reference to the original TCLP test ID if this is a retest. Null if this is the initial test. Maintains audit trail for retested samples.' ;
    rdfs:domain ind:TclpTest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TclpTest .

ind:analyteGroup rdf:type rdf:Property ;
    rdfs:label 'Analyte Group' ;
    rdfs:comment 'Category of contaminants analyzed in the TCLP test. Common groups include RCRA 8 metals, volatile organic compounds (VOCs), semi-volatile organic compounds (SVOCs), and pesticides.' ;
    rdfs:domain ind:TclpTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arsenicResultMgL rdf:type rdf:Property ;
    rdfs:label 'Arsenic Result Mg L' ;
    rdfs:comment 'Measured concentration of arsenic in the TCLP leachate expressed in milligrams per liter. Regulatory threshold is 5.0 mg/L per 40 CFR 261.24.' ;
    rdfs:domain ind:TclpTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignedWasteCodes rdf:type rdf:Property ;
    rdfs:label 'Assigned Waste Codes' ;
    rdfs:comment 'Comma-separated list of EPA hazardous waste codes assigned based on TCLP results. D-codes (D004-D043) indicate toxicity characteristic. Empty if waste passes all thresholds.' ;
    rdfs:domain ind:TclpTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bariumResultMgL rdf:type rdf:Property ;
    rdfs:label 'Barium Result Mg L' ;
    rdfs:comment 'Measured concentration of barium in the TCLP leachate expressed in milligrams per liter. Regulatory threshold is 100.0 mg/L per 40 CFR 261.24.' ;
    rdfs:domain ind:TclpTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:benzeneResultMgL rdf:type rdf:Property ;
    rdfs:label 'Benzene Result Mg L' ;
    rdfs:comment 'Measured concentration of benzene in the TCLP leachate expressed in milligrams per liter. Regulatory threshold is 0.5 mg/L per 40 CFR 261.24.' ;
    rdfs:domain ind:TclpTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cadmiumResultMgL rdf:type rdf:Property ;
    rdfs:label 'Cadmium Result Mg L' ;
    rdfs:comment 'Measured concentration of cadmium in the TCLP leachate expressed in milligrams per liter. Regulatory threshold is 1.0 mg/L per 40 CFR 261.24.' ;
    rdfs:domain ind:TclpTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certifyingChemistLicense rdf:type rdf:Property ;
    rdfs:label 'Certifying Chemist License' ;
    rdfs:comment 'Professional license or certification number of the chemist who certified the test results. Validates professional qualifications.' ;
    rdfs:domain ind:TclpTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifyingChemistName rdf:type rdf:Property ;
    rdfs:label 'Certifying Chemist Name' ;
    rdfs:comment 'Name of the certified chemist or laboratory director who reviewed and certified the analytical results. Responsible for data quality and regulatory compliance.' ;
    rdfs:domain ind:TclpTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chromiumResultMgL rdf:type rdf:Property ;
    rdfs:label 'Chromium Result Mg L' ;
    rdfs:comment 'Measured concentration of total chromium in the TCLP leachate expressed in milligrams per liter. Regulatory threshold is 5.0 mg/L per 40 CFR 261.24.' ;
    rdfs:domain ind:TclpTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:detectionLimitMgL rdf:type rdf:Property ;
    rdfs:label 'Detection Limit Mg L' ;
    rdfs:comment 'Lowest concentration of analyte that the analytical method can reliably detect. Used to interpret non-detect results and ensure regulatory thresholds can be measured.' ;
    rdfs:domain ind:TclpTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:extractionFluid rdf:type rdf:Property ;
    rdfs:label 'Extraction Fluid' ;
    rdfs:comment 'Type of extraction fluid used in the TCLP procedure. Fluid #1 (pH 4.93 ± 0.05) or Fluid #2 (pH 2.88 ± 0.05) based on waste alkalinity.' ;
    rdfs:domain ind:TclpTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadResultMgL rdf:type rdf:Property ;
    rdfs:label 'Lead Result Mg L' ;
    rdfs:comment 'Measured concentration of lead in the TCLP leachate expressed in milligrams per liter. Regulatory threshold is 5.0 mg/L per 40 CFR 261.24.' ;
    rdfs:domain ind:TclpTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mercuryResultMgL rdf:type rdf:Property ;
    rdfs:label 'Mercury Result Mg L' ;
    rdfs:comment 'Measured concentration of mercury in the TCLP leachate expressed in milligrams per liter. Regulatory threshold is 0.2 mg/L per 40 CFR 261.24.' ;
    rdfs:domain ind:TclpTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overallPassFail rdf:type rdf:Property ;
    rdfs:label 'Overall Pass Fail' ;
    rdfs:comment 'Overall determination of whether the waste exhibits the toxicity characteristic. Pass indicates non-hazardous; fail indicates hazardous waste requiring D-code assignment.' ;
    rdfs:domain ind:TclpTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qaQcFlag rdf:type rdf:Property ;
    rdfs:label 'Qa Qc Flag' ;
    rdfs:comment 'Indicates whether the test met all quality assurance and quality control criteria. Qualified results may have data quality limitations but are still reportable.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qaQcNotes rdf:type rdf:Property ;
    rdfs:label 'Qa Qc Notes' ;
    rdfs:comment 'Free-text notes documenting any quality control issues, deviations from standard method, matrix interferences, or data qualifiers applied to the results.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportDate rdf:type rdf:Property ;
    rdfs:label 'Report Date' ;
    rdfs:comment 'Date when the final laboratory analytical report was issued. Used for regulatory reporting timelines and waste profile approval workflows.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportNumber rdf:type rdf:Property ;
    rdfs:label 'Report Number' ;
    rdfs:comment 'Unique report number assigned by the laboratory to the analytical report. Used for document tracking and audit trail.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retestFlag rdf:type rdf:Property ;
    rdfs:label 'Retest Flag' ;
    rdfs:comment 'Indicates whether this test is a retest of a previous sample due to quality control failure, sample integrity issues, or regulatory requirement.' ;
    rdfs:domain ind:TclpTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sampleCollectionTime rdf:type rdf:Property ;
    rdfs:label 'Sample Collection Time' ;
    rdfs:comment 'Precise timestamp when the waste sample was collected, including time zone. Used for hold time calculations and chain-of-custody verification.' ;
    rdfs:domain ind:TclpTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sampleReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Sample Received Date' ;
    rdfs:comment 'Date when the laboratory received the sample for analysis. Used to verify sample hold times and chain-of-custody transfer.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:seleniumResultMgL rdf:type rdf:Property ;
    rdfs:label 'Selenium Result Mg L' ;
    rdfs:comment 'Measured concentration of selenium in the TCLP leachate expressed in milligrams per liter. Regulatory threshold is 1.0 mg/L per 40 CFR 261.24.' ;
    rdfs:domain ind:TclpTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:silverResultMgL rdf:type rdf:Property ;
    rdfs:label 'Silver Result Mg L' ;
    rdfs:comment 'Measured concentration of silver in the TCLP leachate expressed in milligrams per liter. Regulatory threshold is 5.0 mg/L per 40 CFR 261.24.' ;
    rdfs:domain ind:TclpTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:testCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Test Completion Date' ;
    rdfs:comment 'Date when all analytical testing and quality control procedures were completed and results finalized.' ;
    rdfs:domain ind:TclpTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:testMethod rdf:type rdf:Property ;
    rdfs:label 'Test Method' ;
    rdfs:comment 'EPA-approved analytical method used for the TCLP test. Standard method is SW-846 Method 1311 (Toxicity Characteristic Leaching Procedure).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testStartDate rdf:type rdf:Property ;
    rdfs:label 'Test Start Date' ;
    rdfs:comment 'Date when the TCLP extraction procedure was initiated in the laboratory. Used to verify compliance with sample hold time requirements.' ;
    rdfs:domain ind:TclpTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:wasteMatrixType rdf:type rdf:Property ;
    rdfs:label 'Waste Matrix Type' ;
    rdfs:comment 'Physical form of the waste sample tested. Determines the specific TCLP extraction procedure to be followed.' ;
    rdfs:domain ind:TclpTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedForManifestUse rdf:type rdf:Property ;
    rdfs:label 'Approved For Manifest Use' ;
    rdfs:comment 'Boolean flag indicating whether this transporter is currently approved for use on hazardous waste manifests. False indicates transporter cannot be selected for new shipments.' ;
    rdfs:domain ind:TransporterRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:authorizedDotHazardClasses rdf:type rdf:Property ;
    rdfs:label 'Authorized Dot Hazard Classes' ;
    rdfs:comment 'Comma-separated list of DOT hazard classes (1-9) that the transporter is authorized to transport based on DOT operating authority and vehicle placarding.' ;
    rdfs:domain ind:TransporterRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedVehicleTypes rdf:type rdf:Property ;
    rdfs:label 'Authorized Vehicle Types' ;
    rdfs:comment 'Comma-separated list of vehicle types the transporter is authorized and equipped to operate for hazardous waste transport (e.g., tanker truck, box truck, flatbed, roll-off, vacuum truck).' ;
    rdfs:domain ind:TransporterRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedWasteCodes rdf:type rdf:Property ;
    rdfs:label 'Authorized Waste Codes' ;
    rdfs:comment 'Comma-separated list of EPA hazardous waste codes (D, F, K, P, U series) that the transporter is authorized and equipped to handle based on permits, equipment, and training.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cargoInsuranceCarrier rdf:type rdf:Property ;
    rdfs:label 'Cargo Insurance Carrier' ;
    rdfs:comment 'Name of the insurance company providing cargo insurance coverage for hazardous waste in transit.' ;
    rdfs:domain ind:TransporterRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cargoInsuranceCoverageAmount rdf:type rdf:Property ;
    rdfs:label 'Cargo Insurance Coverage Amount' ;
    rdfs:comment 'Total cargo insurance coverage amount in USD for hazardous waste shipments in transit.' ;
    rdfs:domain ind:TransporterRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cargoInsuranceExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Cargo Insurance Expiration Date' ;
    rdfs:comment 'Date when the current cargo insurance policy expires. Transporter must maintain continuous coverage to remain approved.' ;
    rdfs:domain ind:TransporterRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cargoInsurancePolicyNumber rdf:type rdf:Property ;
    rdfs:label 'Cargo Insurance Policy Number' ;
    rdfs:comment 'Policy number for the cargo insurance coverage protecting hazardous waste shipments in transit.' ;
    rdfs:domain ind:TransporterRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dotOperatingAuthorityNumber rdf:type rdf:Property ;
    rdfs:label 'Dot Operating Authority Number' ;
    rdfs:comment 'DOT motor carrier operating authority number (MC, FF, or MX number) required for interstate hazardous materials transportation. Format: MC-XXXXXX or FF-XXXXXX.' ;
    rdfs:domain ind:TransporterRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatEmployeeTrainingComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Hazmat Employee Training Compliance Status' ;
    rdfs:comment 'Current compliance status of the transporters HAZMAT employee training program per DOT HMR requirements. All drivers and handlers must receive training every 3 years.' ;
    rdfs:domain ind:TransporterRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatTrainingLastVerifiedDate rdf:type rdf:Property ;
    rdfs:label 'Hazmat Training Last Verified Date' ;
    rdfs:comment 'Date when Waste Management last verified that the transporter maintains compliant HAZMAT employee training records and certifications.' ;
    rdfs:domain ind:TransporterRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:liabilityInsuranceCarrier rdf:type rdf:Property ;
    rdfs:label 'Liability Insurance Carrier' ;
    rdfs:comment 'Name of the insurance company providing hazardous waste transporter liability coverage for this transporter.' ;
    rdfs:domain ind:TransporterRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liabilityInsuranceCoverageAmount rdf:type rdf:Property ;
    rdfs:label 'Liability Insurance Coverage Amount' ;
    rdfs:comment 'Total liability insurance coverage amount in USD. Minimum coverage requirements vary by waste type and quantity transported.' ;
    rdfs:domain ind:TransporterRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:liabilityInsuranceEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Liability Insurance Effective Date' ;
    rdfs:comment 'Date when the current liability insurance policy became effective.' ;
    rdfs:domain ind:TransporterRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:liabilityInsuranceExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Liability Insurance Expiration Date' ;
    rdfs:comment 'Date when the current liability insurance policy expires. Transporter must maintain continuous coverage to remain approved.' ;
    rdfs:domain ind:Hazmat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:liabilityInsurancePolicyNumber rdf:type rdf:Property ;
    rdfs:label 'Liability Insurance Policy Number' ;
    rdfs:comment 'Policy number for the transporter liability insurance coverage. Required for RCRA compliance and vendor approval.' ;
    rdfs:domain ind:TransporterRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateCode rdf:type rdf:Property ;
    rdfs:label 'State Code' ;
    rdfs:comment 'Two-letter US state code where the transporter company headquarters or principal place of business is located.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateTransporterPermitNumbers rdf:type rdf:Property ;
    rdfs:label 'State Transporter Permit Numbers' ;
    rdfs:comment 'Comma-separated list of state-specific hazardous waste transporter permit or license numbers. Some states require additional permits beyond EPA ID.' ;
    rdfs:domain ind:TransporterRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:streetAddress rdf:type rdf:Property ;
    rdfs:label 'Street Address' ;
    rdfs:comment 'Primary street address of the transporter company headquarters or principal place of business.' ;
    rdfs:domain ind:TransporterRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transporterDbaName rdf:type rdf:Property ;
    rdfs:label 'Transporter Dba Name' ;
    rdfs:comment 'Trade name or doing-business-as name used by the transporter, if different from legal name.' ;
    rdfs:domain ind:TransporterRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transporterLegalName rdf:type rdf:Property ;
    rdfs:label 'Transporter Legal Name' ;
    rdfs:comment 'The full legal business name of the hazardous waste transporter company as registered with EPA and state authorities.' ;
    rdfs:domain ind:TransporterRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usdotNumber rdf:type rdf:Property ;
    rdfs:label 'Usdot Number' ;
    rdfs:comment 'Unique USDOT identification number assigned by FMCSA for commercial motor vehicle operations. Required for all interstate carriers.' ;
    rdfs:domain ind:TransporterRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorPerformanceScore rdf:type rdf:Property ;
    rdfs:label 'Vendor Performance Score' ;
    rdfs:comment 'Internal performance score (0-100) based on on-time performance, compliance incidents, customer feedback, and service quality metrics.' ;
    rdfs:domain ind:TransporterRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Operator Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: RCRA treatment operations require certified operator tracking per 40 CFR 264/265. Links treatment batches to employee certification records (HAZWOPER, equipment-specific training), enables labor cost ' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:treatmentFacilityEpaIdRegistrationId rdf:type rdf:Property ;
    rdfs:label 'Treatment Facility Epa Id Registration Id' ;
    rdfs:comment 'Foreign key linking to hazmat.epa_id_registration. Business justification: Treatment record tracks treatment facility EPA ID as a string. This should be normalized to FK to epa_id_registration. Labeled FK (treatment_facility_epa_id_registration_id) distinguishes this from ge' ;
    rdfs:domain ind:TreatmentRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EpaIdRegistration .

ind:treatmentFacilityId rdf:type rdf:Property ;
    rdfs:label 'Treatment Facility Id' ;
    rdfs:comment 'Foreign key linking to asset.facility. Business justification: Treatment operations occur at specific facilities. Links treatment records to facility asset master for capacity utilization analysis, maintenance scheduling (treatment equipment downtime), facility p' ;
    rdfs:domain ind:TreatmentRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:treatmentFacilityPermitId rdf:type rdf:Property ;
    rdfs:label 'Treatment Facility Permit Id' ;
    rdfs:comment 'Foreign key linking to compliance.permit. Business justification: Treatment operations must comply with permit conditions (40 CFR 264 Subpart X). Permit specifies treatment technologies, waste codes, and operating parameters. Required for demonstrating permit compli' ;
    rdfs:domain ind:TreatmentRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Permit .

ind:treatmentUnitId rdf:type rdf:Property ;
    rdfs:label 'Treatment Unit Id' ;
    rdfs:comment 'Internal identifier for the specific treatment unit or equipment used for the operation (e.g., incinerator, neutralization tank, stabilization mixer, fuel blending unit, solvent recovery still). Each unit has unique operating parameters and permit conditions.' ;
    rdfs:domain ind:TreatmentRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageUnit .

ind:emissionControlSystemCode rdf:type rdf:Property ;
    rdfs:label 'Emission Control System Code' ;
    rdfs:comment 'Identifier for the air pollution control equipment used during thermal treatment operations (e.g., scrubbers, baghouses, electrostatic precipitators). Required for Clean Air Act (CAA) compliance and RCRA air emission standards.' ;
    rdfs:domain ind:TreatmentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inputQuantityUnit rdf:type rdf:Property ;
    rdfs:label 'Input Quantity Unit' ;
    rdfs:comment 'Unit of measure for the input waste quantity. Values: KG=Kilograms, LB=Pounds, GAL=Gallons, L=Liters, TON=US Tons, MT=Metric Tonnes. Must align with manifest and facility reporting units.' ;
    rdfs:domain ind:TreatmentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inputWasteCodes rdf:type rdf:Property ;
    rdfs:label 'Input Waste Codes' ;
    rdfs:comment 'Comma-separated list of EPA hazardous waste codes (D, F, K, P, U series) assigned to the input waste stream. Determines applicable treatment standards and Land Disposal Restrictions (LDR).' ;
    rdfs:domain ind:TreatmentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inputWasteQuantity rdf:type rdf:Property ;
    rdfs:label 'Input Waste Quantity' ;
    rdfs:comment 'The quantity of hazardous waste fed into the treatment unit for this operation, measured in the unit specified by input_quantity_unit. Critical for mass balance calculations and regulatory reporting.' ;
    rdfs:domain ind:TreatmentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ldrComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Ldr Compliance Status' ;
    rdfs:comment 'Indicates whether the treated waste meets EPA Land Disposal Restrictions treatment standards and is eligible for land disposal. Values: COMPLIANT=Meets LDR standards, NON_COMPLIANT=Requires additional treatment, EXEMPT=Waste category exempt from LDR, PENDING_ANALYSIS=Awaiting analytical results.' ;
    rdfs:domain ind:TreatmentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatorCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Operator Certification Number' ;
    rdfs:comment 'Certification number of the trained and certified operator who performed or supervised the treatment operation. RCRA requires personnel training and certification for hazardous waste treatment operations.' ;
    rdfs:domain ind:TreatmentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outputQuantityUnit rdf:type rdf:Property ;
    rdfs:label 'Output Quantity Unit' ;
    rdfs:comment 'Unit of measure for the output residual quantity. Values: KG=Kilograms, LB=Pounds, GAL=Gallons, L=Liters, TON=US Tons, MT=Metric Tonnes.' ;
    rdfs:domain ind:TreatmentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outputResidualQuantity rdf:type rdf:Property ;
    rdfs:label 'Output Residual Quantity' ;
    rdfs:comment 'The quantity of treated residual material or byproduct remaining after treatment, measured in the unit specified by output_quantity_unit. Used for mass balance verification and subsequent disposal or recycling decisions.' ;
    rdfs:domain ind:TreatmentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outputWasteCharacterization rdf:type rdf:Property ;
    rdfs:label 'Output Waste Characterization' ;
    rdfs:comment 'Description of the physical and chemical characteristics of the treated residual, including any remaining hazardous waste codes. Determines whether the residual meets Land Disposal Restrictions (LDR) treatment standards or requires further treatment.' ;
    rdfs:domain ind:TreatmentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pressurePsi rdf:type rdf:Property ;
    rdfs:label 'Pressure Psi' ;
    rdfs:comment 'Operating pressure in pounds per square inch (PSI) during treatment. Relevant for pressurized treatment technologies such as wet air oxidation or supercritical water oxidation.' ;
    rdfs:domain ind:TreatmentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityAssuranceReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Assurance Review Status' ;
    rdfs:comment 'Status of the quality assurance review for this treatment record. Values: APPROVED=Record verified and approved by QA, REJECTED=Record failed QA review, PENDING_REVIEW=Awaiting QA review, NOT_REQUIRED=QA review not required for this operation.' ;
    rdfs:domain ind:TreatmentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryUnitCode rdf:type rdf:Property ;
    rdfs:label 'Regulatory Unit Code' ;
    rdfs:comment 'EPA-assigned code identifying the specific treatment unit under the facility\'s RCRA Part B permit. Each unit has unique permit conditions, operating parameters, and waste acceptance criteria.' ;
    rdfs:domain ind:TreatmentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residenceTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Residence Time Minutes' ;
    rdfs:comment 'The duration in minutes that the waste remained in the treatment unit. Critical for ensuring adequate contact time for chemical reactions, thermal destruction, or physical separation processes per permit specifications.' ;
    rdfs:domain ind:TreatmentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stackEmissionTestResult rdf:type rdf:Property ;
    rdfs:label 'Stack Emission Test Result' ;
    rdfs:comment 'Result of stack emission testing performed during or after the treatment operation to verify compliance with air quality standards. Values: PASS=Emissions within permitted limits, FAIL=Emissions exceed limits, NOT_TESTED=No test performed for this operation.' ;
    rdfs:domain ind:TreatmentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tclpTestPerformed rdf:type rdf:Property ;
    rdfs:label 'Tclp Test Performed' ;
    rdfs:comment 'Boolean flag indicating whether a Toxicity Characteristic Leaching Procedure (TCLP) test was performed on the treated residual to verify that hazardous characteristics have been successfully treated. True=TCLP performed, False=TCLP not performed.' ;
    rdfs:domain ind:TreatmentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tclpTestResult rdf:type rdf:Property ;
    rdfs:label 'Tclp Test Result' ;
    rdfs:comment 'Result of the TCLP test if performed. Values: PASS=Treated waste no longer exhibits toxicity characteristic, FAIL=Waste still exhibits toxicity characteristic, NOT_APPLICABLE=TCLP not required for this waste, PENDING=Test results not yet available.' ;
    rdfs:domain ind:TreatmentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatmentBatchNumber rdf:type rdf:Property ;
    rdfs:label 'Treatment Batch Number' ;
    rdfs:comment 'Internal batch identifier for grouping multiple treatment records that were processed together or as part of a continuous treatment campaign. Enables batch-level quality control and traceability.' ;
    rdfs:domain ind:TreatmentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatmentCostUsd rdf:type rdf:Property ;
    rdfs:label 'Treatment Cost Usd' ;
    rdfs:comment 'The total cost in US dollars incurred for this treatment operation, including labor, energy, consumables, and equipment depreciation. Used for cost accounting and profitability analysis.' ;
    rdfs:domain ind:TreatmentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:treatmentEfficiencyPercent rdf:type rdf:Property ;
    rdfs:label 'Treatment Efficiency Percent' ;
    rdfs:comment 'The calculated treatment efficiency expressed as a percentage, representing the degree of contaminant removal or destruction achieved. For incinerators, this is the Destruction and Removal Efficiency (DRE) which must meet or exceed 99.99% for most hazardous wastes.' ;
    rdfs:domain ind:TreatmentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:treatmentEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Treatment End Timestamp' ;
    rdfs:comment 'The precise date and time when the treatment process was completed. Used to calculate total treatment duration and verify process completion per permit requirements.' ;
    rdfs:domain ind:TreatmentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:treatmentPhLevel rdf:type rdf:Property ;
    rdfs:label 'Treatment Ph Level' ;
    rdfs:comment 'The pH level maintained during chemical treatment processes such as neutralization or chemical oxidation. Must be within permitted operating ranges to ensure effective treatment and regulatory compliance.' ;
    rdfs:domain ind:TreatmentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:treatmentStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Treatment Start Timestamp' ;
    rdfs:comment 'The precise date and time when the treatment process began. Used to calculate residence time and verify compliance with treatment technology specifications.' ;
    rdfs:domain ind:TreatmentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:treatmentStatus rdf:type rdf:Property ;
    rdfs:label 'Treatment Status' ;
    rdfs:comment 'Current status of the treatment operation. Values: COMPLETED=Treatment successfully finished, IN_PROGRESS=Treatment underway, FAILED=Treatment did not meet specifications, ABORTED=Treatment stopped before completion, PENDING_VERIFICATION=Awaiting analytical confirmation of treatment effectiveness.' ;
    rdfs:domain ind:TreatmentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatmentTechnologyCode rdf:type rdf:Property ;
    rdfs:label 'Treatment Technology Code' ;
    rdfs:comment 'EPA-defined code representing the treatment technology applied. Values: INCIN=Incineration, NEUTR=Neutralization, STBLZ=Stabilization, FBLEN=Fuel Blending, SOLVR=Solvent Recovery, CARBN=Carbon Adsorption, WETOX=Wet Air Oxidation, CHOXD=Chemical Oxidation, CMBST=Combustion, DEACT=Deactivation, MACRO=Macroencapsulation, RORGS=Recovery of Organics, RMETL=Recovery of Metals, WTRRX=Water Reaction. [ENUM-REF-CANDIDATE: INCIN|NEUTR|STBLZ|FBLEN|SOLVR|CARBN|WETOX|CHOXD|CMBST|DEACT|MACRO|RORGS|RMETL|WTRRX — 14 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TreatmentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatmentTemperatureCelsius rdf:type rdf:Property ;
    rdfs:label 'Treatment Temperature Celsius' ;
    rdfs:comment 'Operating temperature of the treatment process in degrees Celsius. Critical parameter for thermal treatment technologies (incineration, combustion) to ensure destruction and removal efficiency (DRE) requirements are met.' ;
    rdfs:domain ind:TreatmentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:facilityManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Facility Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: RCRA TSDF permits require designated facility manager per 40 CFR 264.16. Links facility to employee enables certification verification (professional engineer, facility manager training), regulatory co' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:acceptsBulkWaste rdf:type rdf:Property ;
    rdfs:label 'Accepts Bulk Waste' ;
    rdfs:comment 'Boolean flag indicating whether the facility is equipped and permitted to accept bulk hazardous waste shipments (tanker trucks, rail cars).' ;
    rdfs:domain ind:TsdfFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:acceptsContainerizedWaste rdf:type rdf:Property ;
    rdfs:label 'Accepts Containerized Waste' ;
    rdfs:comment 'Boolean flag indicating whether the facility accepts containerized hazardous waste (drums, totes, boxes).' ;
    rdfs:domain ind:TsdfFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disposalCapacityTons rdf:type rdf:Property ;
    rdfs:label 'Disposal Capacity Tons' ;
    rdfs:comment 'Maximum permitted disposal capacity for hazardous waste at the facility measured in tons. Applicable for landfill and land disposal units.' ;
    rdfs:domain ind:TsdfFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emergencyPhoneNumber rdf:type rdf:Property ;
    rdfs:label 'Emergency Phone Number' ;
    rdfs:comment '24-hour emergency contact phone number for the TSDF facility as required by RCRA contingency plans. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:TsdfFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialAssuranceExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Financial Assurance Expiration Date' ;
    rdfs:comment 'Expiration date of the current financial assurance instrument. Must be renewed before expiration to maintain compliance.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:financialAssuranceMechanism rdf:type rdf:Property ;
    rdfs:label 'Financial Assurance Mechanism' ;
    rdfs:comment 'Type of financial assurance mechanism the facility has established to ensure funds are available for closure and post-closure care as required by RCRA.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liabilityInsuranceCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Liability Insurance Certificate Number' ;
    rdfs:comment 'Certificate number for the facility\'s liability insurance coverage for sudden and non-sudden accidental occurrences as required by RCRA.' ;
    rdfs:domain ind:TsdfFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manifestApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Manifest Approval Status' ;
    rdfs:comment 'Approval status indicating whether the facility is authorized to be designated as a receiving facility on hazardous waste manifests. Determines if waste can be shipped to this TSDF.' ;
    rdfs:domain ind:TsdfFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageCapacityTons rdf:type rdf:Property ;
    rdfs:label 'Storage Capacity Tons' ;
    rdfs:comment 'Maximum permitted storage capacity for hazardous waste at the facility measured in tons. Regulatory limit specified in the RCRA permit.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:treatmentMethods rdf:type rdf:Property ;
    rdfs:label 'Treatment Methods' ;
    rdfs:comment 'Comma-separated list of treatment method codes (e.g., incineration, stabilization, neutralization, thermal desorption) that the facility is authorized to perform under its RCRA permit.' ;
    rdfs:domain ind:TsdfFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorRating rdf:type rdf:Property ;
    rdfs:label 'Vendor Rating' ;
    rdfs:comment 'Internal vendor performance rating assigned to the TSDF facility based on compliance history, service quality, and reliability. Used for vendor selection decisions.' ;
    rdfs:domain ind:TsdfFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activeStatus rdf:type rdf:Property ;
    rdfs:label 'Active Status' ;
    rdfs:comment 'Indicates whether this waste code is currently active and should be used for new waste classifications. True for codes in current regulatory use. False for obsolete, superseded, or delisted codes that are retained for historical reference only.' ;
    rdfs:domain ind:WasteCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:acuteHazardousFlag rdf:type rdf:Property ;
    rdfs:label 'Acute Hazardous Flag' ;
    rdfs:comment 'Indicates whether this waste code designates an acutely hazardous waste under RCRA. True for P-listed wastes and certain F-listed wastes that are subject to more stringent quantity thresholds (1 kg vs 100 kg for generator status determination) and management requirements.' ;
    rdfs:domain ind:WasteCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:containerTypeRestriction rdf:type rdf:Property ;
    rdfs:label 'Container Type Restriction' ;
    rdfs:comment 'Specific container or packaging requirements for this waste code during storage and transportation. May specify DOT-approved containers, compatibility requirements, or prohibited container materials. Critical for safe handling and DOT Hazardous Materials Regulations compliance.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:delistingPetitionEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Delisting Petition Eligible Flag' ;
    rdfs:comment 'Indicates whether generators may petition EPA to delist this waste code for specific waste streams that do not exhibit hazardous characteristics. True for listed wastes (F, K, P, U codes) where site-specific delisting is possible. False for characteristic wastes (D codes) which cannot be delisted.' ;
    rdfs:domain ind:WasteCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:generatorAccumulationLimitDays rdf:type rdf:Property ;
    rdfs:label 'Generator Accumulation Limit Days' ;
    rdfs:comment 'Maximum number of days a generator may accumulate this waste on-site before shipping to a TSDF. Typically 90 days for large quantity generators, 180 days for small quantity generators, or 270 days with approved extension. Shorter limits (e.g., 1 day) may apply to acutely hazardous wastes.' ;
    rdfs:domain ind:WasteCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hazardBasis rdf:type rdf:Property ;
    rdfs:label 'Hazard Basis' ;
    rdfs:comment 'Primary hazard characteristic that qualifies this waste as hazardous under RCRA. Ignitability (D001) covers flammable liquids and oxidizers. Corrosivity (D002) covers acids and bases. Reactivity (D003) covers unstable or explosive materials. Toxicity (D004-D043) covers materials that leach toxic constituents. Listed wastes are hazardous by definition regardless of characteristics. Multiple indicates waste exhibits more than one characteristic.' ;
    rdfs:domain ind:WasteCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prohibitedMethodCode rdf:type rdf:Property ;
    rdfs:label 'Prohibited Method Code' ;
    rdfs:comment 'Management method codes that are prohibited for this waste code under Land Disposal Restrictions. Typically references disposal methods that are banned without prior treatment (e.g., landfill disposal, deep well injection). Comma-separated list if multiple methods are prohibited.' ;
    rdfs:domain ind:WasteCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recyclingPotentialFlag rdf:type rdf:Property ;
    rdfs:label 'Recycling Potential Flag' ;
    rdfs:comment 'Indicates whether this waste code has known recycling or reclamation pathways that may qualify for reduced regulatory requirements under RCRA recycling exemptions. True if legitimate recycling options exist (e.g., solvent recovery, metal reclamation, fuel blending).' ;
    rdfs:domain ind:WasteCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:smallQuantityExclusionKg rdf:type rdf:Property ;
    rdfs:label 'Small Quantity Exclusion Kg' ;
    rdfs:comment 'Quantity threshold in kilograms below which a generator may qualify for reduced regulatory requirements. Typically 100 kg per month for hazardous waste or 1 kg per month for acutely hazardous waste. Used to determine generator category (VSQG, SQG, LQG).' ;
    rdfs:domain ind:WasteCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stateSpecificFlag rdf:type rdf:Property ;
    rdfs:label 'State Specific Flag' ;
    rdfs:comment 'Indicates whether this waste code is a state-specific designation beyond federal EPA requirements. True when the code is defined by state environmental regulations and may not be recognized in other states. False for federal EPA codes that apply nationwide.' ;
    rdfs:domain ind:WasteCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sunsetDate rdf:type rdf:Property ;
    rdfs:label 'Sunset Date' ;
    rdfs:comment 'Date when this waste code was or will be removed from regulatory lists. Null for active codes. Populated when EPA or state agencies delist a waste code or when state-specific codes are superseded. Historical record retention required for audit trails.' ;
    rdfs:domain ind:WasteCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tclpConstituent rdf:type rdf:Property ;
    rdfs:label 'Tclp Constituent' ;
    rdfs:comment 'Specific toxic constituent measured in TCLP testing for toxicity characteristic wastes. Examples include arsenic, barium, cadmium, chromium, lead, mercury, selenium, silver, benzene, trichloroethylene. Only populated for D-code toxicity characteristic wastes (D004-D043).' ;
    rdfs:domain ind:WasteCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tclpRegulatoryLevelMgL rdf:type rdf:Property ;
    rdfs:label 'Tclp Regulatory Level Mg L' ;
    rdfs:comment 'Maximum concentration in milligrams per liter of TCLP extract that triggers hazardous waste classification for toxicity characteristic wastes. Waste exceeding this level must be managed as hazardous. Only applicable to D-code toxicity characteristic wastes.' ;
    rdfs:domain ind:WasteCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:toxicityCharacteristicFlag rdf:type rdf:Property ;
    rdfs:label 'Toxicity Characteristic Flag' ;
    rdfs:comment 'Indicates whether this waste code is based on Toxicity Characteristic Leaching Procedure (TCLP) test results. True for D004-D043 codes where waste is hazardous if TCLP extract exceeds regulatory levels for specific contaminants. Requires periodic testing to confirm classification.' ;
    rdfs:domain ind:WasteCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:treatmentSubcategory rdf:type rdf:Property ;
    rdfs:label 'Treatment Subcategory' ;
    rdfs:comment 'Subcategory designation for wastes with multiple treatment standards based on waste form or concentration. Used when a single waste code has different treatment requirements for wastewater versus non-wastewater forms, or for different concentration ranges.' ;
    rdfs:domain ind:WasteCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:universalTreatmentStandard rdf:type rdf:Property ;
    rdfs:label 'Universal Treatment Standard' ;
    rdfs:comment 'Universal Treatment Standard concentration limits for underlying hazardous constituents. Specifies maximum allowable concentrations (in mg/L for TCLP or mg/kg total) for each constituent before the waste can be land disposed. Multiple constituents may be listed with their respective limits.' ;
    rdfs:domain ind:WasteCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteCodeType rdf:type rdf:Property ;
    rdfs:label 'Waste Code Type' ;
    rdfs:comment 'Classification category of the waste code. D-listed are characteristic wastes (ignitability, corrosivity, reactivity, toxicity). F-listed are wastes from non-specific sources. K-listed are wastes from specific sources. P-listed are acutely hazardous discarded commercial chemical products. U-listed are toxic discarded commercial chemical products. State-specific codes are additional classifications imposed by state environmental agencies.' ;
    rdfs:domain ind:WasteCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteMinimizationActivityId rdf:type rdf:Property ;
    rdfs:label 'Waste Minimization Activity Id' ;
    rdfs:comment 'Unique identifier for the waste minimization activity record.' ;
    rdfs:domain ind:WasteMinimizationActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:activityDescription rdf:type rdf:Property ;
    rdfs:label 'Activity Description' ;
    rdfs:comment 'Detailed narrative description of the waste minimization activity, including technical approach and operational changes.' ;
    rdfs:domain ind:WasteMinimizationActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activityStatus rdf:type rdf:Property ;
    rdfs:label 'Activity Status' ;
    rdfs:comment 'Current lifecycle status of the waste minimization activity.' ;
    rdfs:domain ind:WasteMinimizationActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activityType rdf:type rdf:Property ;
    rdfs:label 'Activity Type' ;
    rdfs:comment 'Classification of the waste minimization activity per RCRA waste minimization program categories.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualReductionPercentage rdf:type rdf:Property ;
    rdfs:label 'Actual Reduction Percentage' ;
    rdfs:comment 'Actual measured percentage reduction in waste generation from baseline after implementation.' ;
    rdfs:domain ind:WasteMinimizationActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualReductionQuantity rdf:type rdf:Property ;
    rdfs:label 'Actual Reduction Quantity' ;
    rdfs:comment 'Actual measured quantity of waste reduction achieved after implementation.' ;
    rdfs:domain ind:WasteMinimizationActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annualCostSavings rdf:type rdf:Property ;
    rdfs:label 'Annual Cost Savings' ;
    rdfs:comment 'Estimated or actual annual cost savings achieved through waste reduction, including disposal cost avoidance and material savings.' ;
    rdfs:domain ind:WasteMinimizationActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baselineGenerationQuantity rdf:type rdf:Property ;
    rdfs:label 'Baseline Generation Quantity' ;
    rdfs:comment 'Baseline quantity of hazardous waste generated before implementation of the minimization activity.' ;
    rdfs:domain ind:WasteMinimizationActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baselineMeasurementPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Baseline Measurement Period End' ;
    rdfs:comment 'End date of the period used to establish the baseline generation quantity.' ;
    rdfs:domain ind:WasteMinimizationActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:baselineMeasurementPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Baseline Measurement Period Start' ;
    rdfs:comment 'Start date of the period used to establish the baseline generation quantity.' ;
    rdfs:domain ind:WasteMinimizationActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:baselineUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Baseline Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the baseline generation quantity.' ;
    rdfs:domain ind:WasteMinimizationActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceCertificationFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Certification Flag' ;
    rdfs:comment 'Indicates whether this activity satisfies RCRA waste minimization certification requirements for the biennial report.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ghgReductionCo2eTons rdf:type rdf:Property ;
    rdfs:label 'Ghg Reduction Co2e Tons' ;
    rdfs:comment 'Estimated greenhouse gas emissions reduction achieved through this waste minimization activity, expressed in CO2 equivalent tons.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:implementationCost rdf:type rdf:Property ;
    rdfs:label 'Implementation Cost' ;
    rdfs:comment 'Total cost incurred to implement the waste minimization activity, including capital and operational expenses.' ;
    rdfs:domain ind:WasteMinimizationActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:implementationDate rdf:type rdf:Property ;
    rdfs:label 'Implementation Date' ;
    rdfs:comment 'Date when the waste minimization activity was fully implemented at the generator site.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:materialSubstitutionDetails rdf:type rdf:Property ;
    rdfs:label 'Material Substitution Details' ;
    rdfs:comment 'Details of any hazardous materials substituted with less hazardous or non-hazardous alternatives.' ;
    rdfs:domain ind:WasteMinimizationActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paybackPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Payback Period Months' ;
    rdfs:comment 'Calculated payback period in months for the implementation cost based on annual cost savings.' ;
    rdfs:domain ind:WasteMinimizationActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:processModificationDetails rdf:type rdf:Property ;
    rdfs:label 'Process Modification Details' ;
    rdfs:comment 'Specific details of any process modifications made as part of the waste minimization activity.' ;
    rdfs:domain ind:WasteMinimizationActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectedReductionPercentage rdf:type rdf:Property ;
    rdfs:label 'Projected Reduction Percentage' ;
    rdfs:comment 'Estimated percentage reduction in waste generation from baseline after implementing this activity.' ;
    rdfs:domain ind:WasteMinimizationActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectedReductionQuantity rdf:type rdf:Property ;
    rdfs:label 'Projected Reduction Quantity' ;
    rdfs:comment 'Estimated quantity of waste reduction expected from implementing this activity.' ;
    rdfs:domain ind:WasteMinimizationActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responsiblePersonName rdf:type rdf:Property ;
    rdfs:label 'Responsible Person Name' ;
    rdfs:comment 'Name of the person responsible for implementing and managing the waste minimization activity.' ;
    rdfs:domain ind:WasteMinimizationActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsiblePersonTitle rdf:type rdf:Property ;
    rdfs:label 'Responsible Person Title' ;
    rdfs:comment 'Job title of the person responsible for the waste minimization activity.' ;
    rdfs:domain ind:WasteMinimizationActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Sustainability Reporting Flag' ;
    rdfs:comment 'Indicates whether this activity is included in corporate sustainability reporting and disclosures.' ;
    rdfs:domain ind:WasteMinimizationActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvedTsdfFacilityId rdf:type rdf:Property ;
    rdfs:label 'Approved Tsdf Facility Id' ;
    rdfs:comment 'Reference to the Treatment, Storage, and Disposal Facility authorized to accept this waste profile. Links to facility master data.' ;
    rdfs:domain ind:WasteProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TsdfFacility .

ind:ppeIssuanceId rdf:type rdf:Property ;
    rdfs:label 'Ppe Issuance Id' ;
    rdfs:comment 'Foreign key linking to safety.ppe_issuance. Business justification: Waste profiles specify required PPE (respirators, chemical suits, gloves, face shields) that must be issued to employees handling that waste stream. Links waste hazard characterization to PPE control ' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PpeIssuance .

ind:annualQuantityEstimateTons rdf:type rdf:Property ;
    rdfs:label 'Annual Quantity Estimate Tons' ;
    rdfs:comment 'Estimated annual quantity of waste expected to be generated under this profile, measured in tons. Used for capacity planning and permit compliance.' ;
    rdfs:domain ind:WasteProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:constituentsOfConcern rdf:type rdf:Property ;
    rdfs:label 'Constituents Of Concern' ;
    rdfs:comment 'List of specific chemical constituents or contaminants present in the waste that drive its hazardous classification (e.g., \'Lead, Chromium, Toluene\').' ;
    rdfs:domain ind:WasteProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerTypeApproved rdf:type rdf:Property ;
    rdfs:label 'Container Type Approved' ;
    rdfs:comment 'Approved container types for this waste stream (e.g., \'55-gallon steel drum\', \'Bulk tanker\', \'Fiber drum\', \'Supersack\'). Multiple types may be listed.' ;
    rdfs:domain ind:WasteProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyResponseProcedure rdf:type rdf:Property ;
    rdfs:label 'Emergency Response Procedure' ;
    rdfs:comment 'Summary of emergency response procedures in case of spill, release, or exposure incident involving this waste material.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flashPointCelsius rdf:type rdf:Property ;
    rdfs:label 'Flash Point Celsius' ;
    rdfs:comment 'Lowest temperature at which vapors ignite when exposed to an ignition source. Used to determine ignitability characteristic (D001: flash point <60°C).' ;
    rdfs:domain ind:WasteProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isCorrosive rdf:type rdf:Property ;
    rdfs:label 'Is Corrosive' ;
    rdfs:comment 'Indicates whether the waste exhibits the characteristic of corrosivity per EPA D002 criteria (aqueous with pH ≤2 or ≥12.5, or liquid that corrodes steel at rate >6.35mm per year at 55°C).' ;
    rdfs:domain ind:WasteProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isIgnitable rdf:type rdf:Property ;
    rdfs:label 'Is Ignitable' ;
    rdfs:comment 'Indicates whether the waste exhibits the characteristic of ignitability per EPA D001 criteria (liquid with flash point <60°C, non-liquid capable of spontaneous combustion, ignitable compressed gas, or oxidizer).' ;
    rdfs:domain ind:WasteProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReactive rdf:type rdf:Property ;
    rdfs:label 'Is Reactive' ;
    rdfs:comment 'Indicates whether the waste exhibits the characteristic of reactivity per EPA D003 criteria (unstable, reacts violently with water, generates toxic gases, contains cyanide or sulfide, or capable of detonation).' ;
    rdfs:domain ind:WasteProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isToxic rdf:type rdf:Property ;
    rdfs:label 'Is Toxic' ;
    rdfs:comment 'Indicates whether the waste exhibits the toxicity characteristic per TCLP testing, with contaminant concentrations exceeding regulatory thresholds (D004-D043).' ;
    rdfs:domain ind:WasteProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:landDisposalRestricted rdf:type rdf:Property ;
    rdfs:label 'Land Disposal Restricted' ;
    rdfs:comment 'Indicates whether the waste is subject to Land Disposal Restrictions requiring treatment to meet specific standards before landfill disposal.' ;
    rdfs:domain ind:WasteProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ldrTreatmentStandards rdf:type rdf:Property ;
    rdfs:label 'Ldr Treatment Standards' ;
    rdfs:comment 'Specific treatment standards that must be met before land disposal, including concentration limits for hazardous constituents or required treatment technologies.' ;
    rdfs:domain ind:WasteProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processGeneratingWaste rdf:type rdf:Property ;
    rdfs:label 'Process Generating Waste' ;
    rdfs:comment 'Description of the industrial or commercial process that generates this waste stream (e.g., \'Metal degreasing operation\', \'Paint booth cleaning\').' ;
    rdfs:domain ind:WasteProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileName rdf:type rdf:Property ;
    rdfs:label 'Profile Name' ;
    rdfs:comment 'Descriptive name of the waste stream or material being profiled (e.g., \'Industrial Solvent Waste\', \'Lead-Contaminated Soil\').' ;
    rdfs:domain ind:WasteProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileNumber rdf:type rdf:Property ;
    rdfs:label 'Profile Number' ;
    rdfs:comment 'Business identifier for the waste profile, used for external reference and tracking. Typically formatted as WP- followed by numeric sequence.' ;
    rdfs:domain ind:WasteProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tclpResultsSummary rdf:type rdf:Property ;
    rdfs:label 'Tclp Results Summary' ;
    rdfs:comment 'Summary of TCLP test results listing detected contaminants and their concentrations in mg/L. Used to determine D-code assignments for toxic characteristics.' ;
    rdfs:domain ind:WasteProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tclpTestDate rdf:type rdf:Property ;
    rdfs:label 'Tclp Test Date' ;
    rdfs:comment 'Date when the most recent Toxicity Characteristic Leaching Procedure laboratory test was performed to determine if waste exhibits toxicity characteristic.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:treatmentMethodRequired rdf:type rdf:Property ;
    rdfs:label 'Treatment Method Required' ;
    rdfs:comment 'Approved treatment or disposal method for this waste stream (e.g., \'Incineration\', \'Stabilization\', \'Landfill Disposal\', \'Fuel Blending\').' ;
    rdfs:domain ind:WasteProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualDepartureTime rdf:type rdf:Property ;
    rdfs:label 'Actual Departure Time' ;
    rdfs:comment 'Actual timestamp when the vehicle departed the generator site with the loaded hazardous waste. Captured via Geotab telematics or driver mobile app.' ;
    rdfs:domain ind:WasteShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualTransitHours rdf:type rdf:Property ;
    rdfs:label 'Actual Transit Hours' ;
    rdfs:comment 'Actual elapsed time in hours from departure to arrival. Calculated from actual_departure_time and actual_arrival_time for performance tracking.' ;
    rdfs:domain ind:WasteShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingWeightLbs rdf:type rdf:Property ;
    rdfs:label 'Billing Weight Lbs' ;
    rdfs:comment 'Weight in pounds used for billing purposes. May differ from total_weight_lbs if minimum billing weight or rounding rules apply.' ;
    rdfs:domain ind:WasteShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chainOfCustodyVerified rdf:type rdf:Property ;
    rdfs:label 'Chain Of Custody Verified' ;
    rdfs:comment 'Indicates whether chain-of-custody documentation has been verified and all required signatures obtained from generator, transporter, and TSDF.' ;
    rdfs:domain ind:WasteShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dotPlacardCodes rdf:type rdf:Property ;
    rdfs:label 'Dot Placard Codes' ;
    rdfs:comment 'Comma-separated list of DOT placard codes required for this shipment (e.g., Class 3 Flammable Liquid, Class 8 Corrosive). Determines vehicle marking requirements.' ;
    rdfs:domain ind:WasteShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dotPlacardRequired rdf:type rdf:Property ;
    rdfs:label 'Dot Placard Required' ;
    rdfs:comment 'Indicates whether DOT hazmat placards are required on the vehicle for this shipment based on waste classification and quantity thresholds.' ;
    rdfs:domain ind:WasteShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:emergencyResponseGuideNumber rdf:type rdf:Property ;
    rdfs:label 'Emergency Response Guide Number' ;
    rdfs:comment 'Three-digit ERG guide number from the DOT Emergency Response Guidebook. Used by first responders in case of spill or accident during transport.' ;
    rdfs:domain ind:WasteShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedTransitHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Transit Hours' ;
    rdfs:comment 'Estimated travel time in hours from generator site to destination TSDF. Used for route planning and customer communication.' ;
    rdfs:domain ind:WasteShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exceptionReason rdf:type rdf:Property ;
    rdfs:label 'Exception Reason' ;
    rdfs:comment 'Description of any exception or discrepancy encountered during shipment (e.g., rejected load, quantity mismatch, container damage, route deviation).' ;
    rdfs:domain ind:WasteShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionReportedDate rdf:type rdf:Property ;
    rdfs:label 'Exception Reported Date' ;
    rdfs:comment 'Date when a shipment exception or discrepancy was formally reported to the generator and regulatory authorities. Required within 30 days under RCRA.' ;
    rdfs:domain ind:WasteShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:routeDeviationDetected rdf:type rdf:Property ;
    rdfs:label 'Route Deviation Detected' ;
    rdfs:comment 'Flag indicating whether the vehicle deviated from the planned or approved hazmat route during transport. Triggers compliance review.' ;
    rdfs:domain ind:WasteShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:routeRestrictions rdf:type rdf:Property ;
    rdfs:label 'Route Restrictions' ;
    rdfs:comment 'Special routing restrictions or requirements for this hazardous waste shipment (e.g., avoid tunnels, no residential areas, designated hazmat routes only).' ;
    rdfs:domain ind:WasteShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentNotes rdf:type rdf:Property ;
    rdfs:label 'Shipment Notes' ;
    rdfs:comment 'Free-text field for additional operational notes, driver observations, or special circumstances related to this shipment.' ;
    rdfs:domain ind:WasteShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentStatus rdf:type rdf:Property ;
    rdfs:label 'Shipment Status' ;
    rdfs:comment 'Current lifecycle status of the hazardous waste shipment. Tracks progression from scheduling through final delivery and manifest closure.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureControlled rdf:type rdf:Property ;
    rdfs:label 'Temperature Controlled' ;
    rdfs:comment 'Indicates whether this shipment requires temperature-controlled transport due to waste characteristics (e.g., reactive materials, biological hazards).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalWeightLbs rdf:type rdf:Property ;
    rdfs:label 'Total Weight Lbs' ;
    rdfs:comment 'Total weight of hazardous waste in this shipment measured in pounds. Aggregated from all containers included in the shipment.' ;
    rdfs:domain ind:WasteShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vehicleUnitNumber rdf:type rdf:Property ;
    rdfs:label 'Vehicle Unit Number' ;
    rdfs:comment 'Fleet unit number or license plate identifier of the vehicle used for this shipment. Used for tracking and compliance reporting.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:airspaceConsumptionId rdf:type rdf:Property ;
    rdfs:label 'Airspace Consumption Id' ;
    rdfs:comment 'Unique identifier for the airspace consumption measurement record.' ;
    rdfs:domain ind:AirspaceConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cellId rdf:type rdf:Property ;
    rdfs:label 'Cell Id' ;
    rdfs:comment 'Reference to the specific landfill cell within the site where airspace was consumed.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Cell .

ind:cndTonnageTons rdf:type rdf:Property ;
    rdfs:label 'Cnd Tonnage Tons' ;
    rdfs:comment 'Tonnage of Construction and Demolition waste placed during the measurement period.' ;
    rdfs:domain ind:AirspaceConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coverMaterialVolumeCubicYards rdf:type rdf:Property ;
    rdfs:label 'Cover Material Volume Cubic Yards' ;
    rdfs:comment 'Volume of daily cover material (soil, alternative daily cover) applied during the measurement period, measured in cubic yards.' ;
    rdfs:domain ind:AirspaceConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cumulativeVolumeConsumedCubicYards rdf:type rdf:Property ;
    rdfs:label 'Cumulative Volume Consumed Cubic Yards' ;
    rdfs:comment 'Total cumulative volume of airspace consumed in the cell or site since opening, measured in cubic yards.' ;
    rdfs:domain ind:AirspaceConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:designDensityLbsPerCubicYard rdf:type rdf:Property ;
    rdfs:label 'Design Density Lbs Per Cubic Yard' ;
    rdfs:comment 'Target design density for waste compaction as specified in facility design, measured in pounds per cubic yard.' ;
    rdfs:domain ind:AirspaceConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inPlaceDensityLbsPerCubicYard rdf:type rdf:Property ;
    rdfs:label 'In Place Density Lbs Per Cubic Yard' ;
    rdfs:comment 'Actual density of compacted waste in place, measured in pounds per cubic yard.' ;
    rdfs:domain ind:AirspaceConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementAccuracyCubicYards rdf:type rdf:Property ;
    rdfs:label 'Measurement Accuracy Cubic Yards' ;
    rdfs:comment 'Estimated accuracy or margin of error of the airspace measurement, expressed in cubic yards.' ;
    rdfs:domain ind:AirspaceConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementDate rdf:type rdf:Property ;
    rdfs:label 'Measurement Date' ;
    rdfs:comment 'Date when the airspace consumption measurement was performed.' ;
    rdfs:domain ind:AirspaceConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mswTonnageTons rdf:type rdf:Property ;
    rdfs:label 'Msw Tonnage Tons' ;
    rdfs:comment 'Tonnage of Municipal Solid Waste placed during the measurement period.' ;
    rdfs:domain ind:AirspaceConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectedClosureDate rdf:type rdf:Property ;
    rdfs:label 'Projected Closure Date' ;
    rdfs:comment 'Estimated date when the cell or site will reach permitted capacity based on current consumption rates.' ;
    rdfs:domain ind:AirspaceConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rateCubicYardsPerDay rdf:type rdf:Property ;
    rdfs:label 'Rate Cubic Yards Per Day' ;
    rdfs:comment 'Average daily rate of airspace consumption during the measurement period, calculated as volume consumed divided by days in period.' ;
    rdfs:domain ind:AirspaceConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatorSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Regulator Submission Date' ;
    rdfs:comment 'Date when the airspace consumption measurement was submitted to the regulatory authority.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryReportingPeriod rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Period' ;
    rdfs:comment 'Regulatory reporting period identifier (e.g., Q1 2024, Annual 2024) for which this measurement applies.' ;
    rdfs:domain ind:Landfill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remainingPermittedAirspaceCubicYards rdf:type rdf:Property ;
    rdfs:label 'Remaining Permitted Airspace Cubic Yards' ;
    rdfs:comment 'Remaining permitted airspace capacity available in the cell or site, measured in cubic yards.' ;
    rdfs:domain ind:AirspaceConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:specialWasteTonnageTons rdf:type rdf:Property ;
    rdfs:label 'Special Waste Tonnage Tons' ;
    rdfs:comment 'Tonnage of special waste (non-hazardous industrial, contaminated soil, etc.) placed during the measurement period.' ;
    rdfs:domain ind:AirspaceConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:submittedToRegulatorFlag rdf:type rdf:Property ;
    rdfs:label 'Submitted To Regulator Flag' ;
    rdfs:comment 'Indicates whether this airspace consumption measurement has been submitted to the regulatory authority.' ;
    rdfs:domain ind:AirspaceConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:surveyCertificationDate rdf:type rdf:Property ;
    rdfs:label 'Survey Certification Date' ;
    rdfs:comment 'Date when the surveyor certified the airspace consumption measurement.' ;
    rdfs:domain ind:AirspaceConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:surveyMethod rdf:type rdf:Property ;
    rdfs:label 'Survey Method' ;
    rdfs:comment 'Method used to measure airspace consumption (e.g., drone photogrammetry, GPS survey, LiDAR, total station).' ;
    rdfs:domain ind:AirspaceConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyReportReference rdf:type rdf:Property ;
    rdfs:label 'Survey Report Reference' ;
    rdfs:comment 'Reference number or document identifier for the detailed survey report supporting this measurement.' ;
    rdfs:domain ind:AirspaceConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyorLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Surveyor License Number' ;
    rdfs:comment 'Professional license number of the surveyor who certified the measurement.' ;
    rdfs:domain ind:AirspaceConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyorName rdf:type rdf:Property ;
    rdfs:label 'Surveyor Name' ;
    rdfs:comment 'Name of the licensed surveyor or survey firm that performed the airspace measurement.' ;
    rdfs:domain ind:AirspaceConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalPermittedCapacityCubicYards rdf:type rdf:Property ;
    rdfs:label 'Total Permitted Capacity Cubic Yards' ;
    rdfs:comment 'Total permitted airspace capacity for the cell or site as authorized by regulatory permit, measured in cubic yards.' ;
    rdfs:domain ind:AirspaceConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeConsumedCubicYards rdf:type rdf:Property ;
    rdfs:label 'Volume Consumed Cubic Yards' ;
    rdfs:comment 'Volume of airspace consumed during the measurement period, measured in cubic yards.' ;
    rdfs:domain ind:AirspaceConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wasteTonnagePlacedTons rdf:type rdf:Property ;
    rdfs:label 'Waste Tonnage Placed Tons' ;
    rdfs:comment 'Total tonnage of waste placed in the cell or site during the measurement period.' ;
    rdfs:domain ind:AirspaceConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yearsRemainingCapacity rdf:type rdf:Property ;
    rdfs:label 'Years Remaining Capacity' ;
    rdfs:comment 'Estimated number of years of remaining airspace capacity based on current consumption trends.' ;
    rdfs:domain ind:AirspaceConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityPlanId rdf:type rdf:Property ;
    rdfs:label 'Capacity Plan Id' ;
    rdfs:comment 'Unique identifier for the capacity plan version record. Primary key.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:airspaceSurveyDate rdf:type rdf:Property ;
    rdfs:label 'Airspace Survey Date' ;
    rdfs:comment 'Date of the most recent topographic survey used to determine consumed and remaining airspace for this capacity plan.' ;
    rdfs:domain ind:Landfill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:annualWasteAcceptanceRateTons rdf:type rdf:Property ;
    rdfs:label 'Annual Waste Acceptance Rate Tons' ;
    rdfs:comment 'Assumed annual waste acceptance volume in tons used for capacity planning. Calculated from daily rate assumptions.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annualWasteAcceptanceRateTpd rdf:type rdf:Property ;
    rdfs:label 'Annual Waste Acceptance Rate Tpd' ;
    rdfs:comment 'Assumed average daily waste acceptance rate in Tons Per Day (TPD) used for capacity planning projections. Based on historical trends and market forecasts.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assumptionsNotes rdf:type rdf:Property ;
    rdfs:label 'Assumptions Notes' ;
    rdfs:comment 'Detailed narrative describing key assumptions, methodologies, constraints, and special considerations used in developing this capacity plan.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityConsumedToDateCy rdf:type rdf:Property ;
    rdfs:label 'Capacity Consumed To Date Cy' ;
    rdfs:comment 'Cumulative airspace consumed as of the plan effective date, measured in cubic yards. Based on topographic surveys and waste placement records.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityConsumedToDateTons rdf:type rdf:Property ;
    rdfs:label 'Capacity Consumed To Date Tons' ;
    rdfs:comment 'Cumulative waste tonnage received as of the plan effective date. Based on scale house records and historical acceptance data.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capitalInvestmentRequired rdf:type rdf:Property ;
    rdfs:label 'Capital Investment Required' ;
    rdfs:comment 'Estimated total capital investment required to execute this capacity plan, including expansion construction, infrastructure, and equipment. Measured in US dollars.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compactionRatioAssumption rdf:type rdf:Property ;
    rdfs:label 'Compaction Ratio Assumption' ;
    rdfs:comment 'Assumed waste compaction ratio (volume reduction factor) used in capacity calculations. Represents the ratio of in-place compacted waste density to loose waste density.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dailyCoverFactorPercent rdf:type rdf:Property ;
    rdfs:label 'Daily Cover Factor Percent' ;
    rdfs:comment 'Percentage of airspace consumed by daily cover material application. Used to adjust net waste capacity calculations.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:engineerLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Engineer License Number' ;
    rdfs:comment 'Professional engineering license number of the responsible engineer who certified this capacity plan.' ;
    rdfs:domain ind:Landfill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expansionPermitStatus rdf:type rdf:Property ;
    rdfs:label 'Expansion Permit Status' ;
    rdfs:comment 'Current status of permit applications for planned capacity expansions (vertical or lateral). Not applicable if no expansion is planned.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expansionTargetCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Expansion Target Completion Date' ;
    rdfs:comment 'Target date for completion of planned expansion construction and availability of additional capacity. Null if no expansion is planned.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:finalCoverFactorPercent rdf:type rdf:Property ;
    rdfs:label 'Final Cover Factor Percent' ;
    rdfs:comment 'Percentage of airspace consumed by final cap system installation. Includes liner, drainage, and vegetation layers.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:intermediateCoverFactorPercent rdf:type rdf:Property ;
    rdfs:label 'Intermediate Cover Factor Percent' ;
    rdfs:comment 'Percentage of airspace consumed by intermediate cover systems. Applied to areas inactive for extended periods.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lateralExpansionCapacityCy rdf:type rdf:Property ;
    rdfs:label 'Lateral Expansion Capacity Cy' ;
    rdfs:comment 'Additional airspace capacity (cubic yards) to be gained through lateral expansion, if planned. Null if no lateral expansion is planned.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lateralExpansionPlanned rdf:type rdf:Property ;
    rdfs:label 'Lateral Expansion Planned' ;
    rdfs:comment 'Indicates whether lateral expansion (footprint increase) is included in this capacity plan. True if lateral expansion is planned and permitted.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:permitRenewalRequired rdf:type rdf:Property ;
    rdfs:label 'Permit Renewal Required' ;
    rdfs:comment 'Indicates whether permit renewal or modification is required to execute this capacity plan. True if regulatory action is needed.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:permitRenewalTargetDate rdf:type rdf:Property ;
    rdfs:label 'Permit Renewal Target Date' ;
    rdfs:comment 'Target date for obtaining required permit renewals or modifications to support this capacity plan. Null if no permit action is required.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Plan Approval Date' ;
    rdfs:comment 'Date when this capacity plan version was formally approved by management or regulatory authorities.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planName rdf:type rdf:Property ;
    rdfs:label 'Plan Name' ;
    rdfs:comment 'Descriptive name for this capacity plan version (e.g., \'FY2024 Long-Range Capacity Plan\', \'10-Year Airspace Projection\').' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningHorizonYears rdf:type rdf:Property ;
    rdfs:label 'Planning Horizon Years' ;
    rdfs:comment 'Number of years covered by this capacity plan (e.g., 1, 5, 10, 20).' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:projectedClosureYear rdf:type rdf:Property ;
    rdfs:label 'Projected Closure Year' ;
    rdfs:comment 'Calendar year in which the landfill is projected to reach capacity and begin final closure activities.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:projectedSiteLifeYears rdf:type rdf:Property ;
    rdfs:label 'Projected Site Life Years' ;
    rdfs:comment 'Estimated number of years until the landfill reaches permitted capacity and requires closure, based on current waste acceptance rates and compaction assumptions.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remainingAirspaceCy rdf:type rdf:Property ;
    rdfs:label 'Remaining Airspace Cy' ;
    rdfs:comment 'Available airspace remaining for waste placement, measured in cubic yards. Calculated as total permitted capacity minus capacity consumed to date.' ;
    rdfs:domain ind:Landfill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remainingCapacityTons rdf:type rdf:Property ;
    rdfs:label 'Remaining Capacity Tons' ;
    rdfs:comment 'Available waste capacity remaining, measured in tons. Calculated using remaining airspace and assumed compaction ratios.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responsibleEngineer rdf:type rdf:Property ;
    rdfs:label 'Responsible Engineer' ;
    rdfs:comment 'Name of the professional engineer responsible for preparing and certifying this capacity plan.' ;
    rdfs:domain ind:Landfill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalPermittedCapacityCy rdf:type rdf:Property ;
    rdfs:label 'Total Permitted Capacity Cy' ;
    rdfs:comment 'Total airspace capacity permitted for the landfill site, measured in cubic yards. Represents the maximum volume authorized by regulatory permits.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPermittedCapacityTons rdf:type rdf:Property ;
    rdfs:label 'Total Permitted Capacity Tons' ;
    rdfs:comment 'Total waste capacity permitted for the landfill site, measured in tons. Derived from cubic yards using assumed compaction ratios.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:verticalExpansionCapacityCy rdf:type rdf:Property ;
    rdfs:label 'Vertical Expansion Capacity Cy' ;
    rdfs:comment 'Additional airspace capacity (cubic yards) to be gained through vertical expansion, if planned. Null if no vertical expansion is planned.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:verticalExpansionPlanned rdf:type rdf:Property ;
    rdfs:label 'Vertical Expansion Planned' ;
    rdfs:comment 'Indicates whether vertical expansion (height increase) is included in this capacity plan. True if vertical expansion is planned and permitted.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:actualFillDate rdf:type rdf:Property ;
    rdfs:label 'Actual Fill Date' ;
    rdfs:comment 'Actual date when the cell reached design capacity and was closed to further waste placement.' ;
    rdfs:domain ind:Cell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:areaAcres rdf:type rdf:Property ;
    rdfs:label 'Area Acres' ;
    rdfs:comment 'Horizontal footprint area of the cell in acres, measured at the base liner surface.' ;
    rdfs:domain ind:Cell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseElevationFeet rdf:type rdf:Property ;
    rdfs:label 'Base Elevation Feet' ;
    rdfs:comment 'Elevation of the cell base (liner surface) in feet above mean sea level, used for airspace calculations and grading plans.' ;
    rdfs:domain ind:Cell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cellName rdf:type rdf:Property ;
    rdfs:label 'Cell Name' ;
    rdfs:comment 'Descriptive name for the cell used in operational and planning documents.' ;
    rdfs:domain ind:Cell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cellNumber rdf:type rdf:Property ;
    rdfs:label 'Cell Number' ;
    rdfs:comment 'Business identifier for the cell, typically alphanumeric code used in operational communications and regulatory reporting (e.g., CELL-A1, PHASE2-C3).' ;
    rdfs:domain ind:Cell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cellStatus rdf:type rdf:Property ;
    rdfs:label 'Cell Status' ;
    rdfs:comment 'Current operational status of the cell in its lifecycle: planned (designed but not built), under_construction (being prepared), active (receiving waste), filled (at capacity but not closed), closed (operations ceased, interim cover applied), capped (final cover system installed).' ;
    rdfs:domain ind:Cell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compactionRatioTarget rdf:type rdf:Property ;
    rdfs:label 'Compaction Ratio Target' ;
    rdfs:comment 'Target volume reduction ratio for waste compaction operations in this cell, typically expressed as ratio of loose volume to compacted volume (e.g., 4.0 means 4:1 reduction).' ;
    rdfs:domain ind:Cell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:constructionCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Construction Completion Date' ;
    rdfs:comment 'Date when cell construction was completed and the cell was certified ready for waste placement.' ;
    rdfs:domain ind:Cell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:constructionStartDate rdf:type rdf:Property ;
    rdfs:label 'Construction Start Date' ;
    rdfs:comment 'Date when physical construction of the cell (excavation, liner installation) commenced.' ;
    rdfs:domain ind:Cell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:currentElevationFeet rdf:type rdf:Property ;
    rdfs:label 'Current Elevation Feet' ;
    rdfs:comment 'Current elevation of the active waste surface in feet above mean sea level, updated from periodic topographic surveys.' ;
    rdfs:domain ind:Cell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dailyCoverMaterialType rdf:type rdf:Property ;
    rdfs:label 'Daily Cover Material Type' ;
    rdfs:comment 'Type of material used for daily cover application to control odors, vectors, and litter: soil (traditional 6-inch soil cover), alternative_daily_cover (ADC such as compost, shredded green waste), tarps (reusable geomembrane tarps), foam (spray-applied foam), auto_daily_cover (automated tarp systems).' ;
    rdfs:domain ind:Cell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designCapacityCubicYards rdf:type rdf:Property ;
    rdfs:label 'Design Capacity Cubic Yards' ;
    rdfs:comment 'Total permitted airspace volume for waste placement in cubic yards, as specified in the engineering design and regulatory permit.' ;
    rdfs:domain ind:Cell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:designCapacityTons rdf:type rdf:Property ;
    rdfs:label 'Design Capacity Tons' ;
    rdfs:comment 'Total permitted waste tonnage capacity, calculated from design volume and assumed compaction density.' ;
    rdfs:domain ind:Cell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalMonitoringFrequency rdf:type rdf:Property ;
    rdfs:label 'Environmental Monitoring Frequency' ;
    rdfs:comment 'Required frequency for environmental monitoring activities (groundwater sampling, gas monitoring, leachate testing) as specified in the permit.' ;
    rdfs:domain ind:Cell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finalCapInstallationDate rdf:type rdf:Property ;
    rdfs:label 'Final Cap Installation Date' ;
    rdfs:comment 'Date when the final cover system (cap) was installed over the closed cell, marking the beginning of post-closure care period.' ;
    rdfs:domain ind:Cell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gasCollectionStartDate rdf:type rdf:Property ;
    rdfs:label 'Gas Collection Start Date' ;
    rdfs:comment 'Date when active gas collection operations commenced in this cell, required for EPA NSPS/EG compliance tracking.' ;
    rdfs:domain ind:Cell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gasCollectionSystemInstalled rdf:type rdf:Property ;
    rdfs:label 'Gas Collection System Installed' ;
    rdfs:comment 'Indicates whether an active landfill gas collection system (vertical wells and/or horizontal collectors) has been installed in this cell.' ;
    rdfs:domain ind:Cell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geometryCoordinates rdf:type rdf:Property ;
    rdfs:label 'Geometry Coordinates' ;
    rdfs:comment 'Well-Known Text (WKT) representation of the cell boundary polygon coordinates for GIS mapping and spatial analysis.' ;
    rdfs:domain ind:Cell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groundwaterMonitoringWells rdf:type rdf:Property ;
    rdfs:label 'Groundwater Monitoring Wells' ;
    rdfs:comment 'Comma-separated list of groundwater monitoring well identifiers assigned to this cell for environmental compliance monitoring per RCRA Subtitle D requirements.' ;
    rdfs:domain ind:Cell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linerSystemType rdf:type rdf:Property ;
    rdfs:label 'Liner System Type' ;
    rdfs:comment 'Classification of the engineered liner system installed at the base of the cell to prevent leachate migration: single_composite (one geomembrane + clay layer), double_composite (two geomembrane layers with leak detection), single_geomembrane, clay_only (compacted clay liner), enhanced_composite (advanced multi-layer system).' ;
    rdfs:domain ind:Landfill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linerThicknessInches rdf:type rdf:Property ;
    rdfs:label 'Liner Thickness Inches' ;
    rdfs:comment 'Total thickness of the liner system in inches, including all geomembrane and clay layers.' ;
    rdfs:domain ind:Cell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:openingDate rdf:type rdf:Property ;
    rdfs:label 'Opening Date' ;
    rdfs:comment 'Date when the cell was opened for active waste placement operations.' ;
    rdfs:domain ind:Cell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:phaseNumber rdf:type rdf:Property ;
    rdfs:label 'Phase Number' ;
    rdfs:comment 'Development phase identifier indicating the sequential construction phase of the landfill expansion plan.' ;
    rdfs:domain ind:Cell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postClosureCareEndDate rdf:type rdf:Property ;
    rdfs:label 'Post Closure Care End Date' ;
    rdfs:comment 'Projected or actual date when the 30-year post-closure care period (monitoring, maintenance, gas management) will end or ended.' ;
    rdfs:domain ind:Landfill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:projectedFillDate rdf:type rdf:Property ;
    rdfs:label 'Projected Fill Date' ;
    rdfs:comment 'Forecasted date when the cell is expected to reach design capacity based on current waste placement rates and airspace consumption trends.' ;
    rdfs:domain ind:Cell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remainingCapacityCubicYards rdf:type rdf:Property ;
    rdfs:label 'Remaining Capacity Cubic Yards' ;
    rdfs:comment 'Current available airspace for waste placement in cubic yards, updated based on survey measurements and waste placement records.' ;
    rdfs:domain ind:Cell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:topElevationFeet rdf:type rdf:Property ;
    rdfs:label 'Top Elevation Feet' ;
    rdfs:comment 'Permitted final elevation of the cell top surface in feet above mean sea level, defining the maximum fill height.' ;
    rdfs:domain ind:Cell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalTonnageReceived rdf:type rdf:Property ;
    rdfs:label 'Total Tonnage Received' ;
    rdfs:comment 'Cumulative tonnage of waste placed in this cell since opening, tracked for capacity management and regulatory reporting.' ;
    rdfs:domain ind:Cell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:closurePlanId rdf:type rdf:Property ;
    rdfs:label 'Closure Plan Id' ;
    rdfs:comment 'Unique identifier for the landfill closure and post-closure care plan record. Primary key.' ;
    rdfs:domain ind:Landfill ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ClosurePlan .

ind:disposalPermitId rdf:type rdf:Property ;
    rdfs:label 'Disposal Permit Id' ;
    rdfs:comment 'Foreign key linking to landfill.disposal_permit. Business justification: Closure plans are regulatory documents that must be approved by the permitting authority under the disposal permit. The closure plan defines cap system design, post-closure care period, monitoring sch' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WasteManagement .

ind:actualClosureCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Closure Completion Date' ;
    rdfs:comment 'Actual date on which all closure construction activities were completed and the final cap system was installed.' ;
    rdfs:domain ind:ClosurePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualClosureStartDate rdf:type rdf:Property ;
    rdfs:label 'Actual Closure Start Date' ;
    rdfs:comment 'Actual date on which closure activities commenced.' ;
    rdfs:domain ind:ClosurePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:capBarrierMaterial rdf:type rdf:Property ;
    rdfs:label 'Cap Barrier Material' ;
    rdfs:comment 'Type of impermeable barrier material used in the cap system (e.g., geomembrane, clay, composite liner).' ;
    rdfs:domain ind:ClosurePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capDrainageSystem rdf:type rdf:Property ;
    rdfs:label 'Cap Drainage System' ;
    rdfs:comment 'Description of the drainage layer and system designed to manage stormwater runoff and prevent infiltration into the waste mass.' ;
    rdfs:domain ind:ClosurePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capInspectionFrequency rdf:type rdf:Property ;
    rdfs:label 'Cap Inspection Frequency' ;
    rdfs:comment 'Frequency of visual inspections of the final cap system during the post-closure care period (e.g., quarterly, semi-annually).' ;
    rdfs:domain ind:ClosurePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capLayerCount rdf:type rdf:Property ;
    rdfs:label 'Cap Layer Count' ;
    rdfs:comment 'Number of distinct layers in the final cap system (e.g., barrier layer, drainage layer, soil layer, vegetation layer).' ;
    rdfs:domain ind:ClosurePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capSystemDesign rdf:type rdf:Property ;
    rdfs:label 'Cap System Design' ;
    rdfs:comment 'Detailed description of the final cover system design, including layer composition, materials, and engineering specifications.' ;
    rdfs:domain ind:ClosurePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capTotalThicknessInches rdf:type rdf:Property ;
    rdfs:label 'Cap Total Thickness Inches' ;
    rdfs:comment 'Total thickness of the final cap system measured in inches, from the waste surface to the top of the vegetation layer.' ;
    rdfs:domain ind:ClosurePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capVegetationType rdf:type rdf:Property ;
    rdfs:label 'Cap Vegetation Type' ;
    rdfs:comment 'Type of vegetation to be established on the final cap surface (e.g., native grasses, low-maintenance groundcover).' ;
    rdfs:domain ind:ClosurePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costEstimateBasis rdf:type rdf:Property ;
    rdfs:label 'Cost Estimate Basis' ;
    rdfs:comment 'Methodology or standard used to prepare the cost estimate (e.g., third-party engineer estimate, regulatory cost formula).' ;
    rdfs:domain ind:ClosurePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costEstimateDate rdf:type rdf:Property ;
    rdfs:label 'Cost Estimate Date' ;
    rdfs:comment 'Date on which the closure and post-closure cost estimates were prepared or last updated.' ;
    rdfs:domain ind:ClosurePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:estimatedClosureCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Closure Cost' ;
    rdfs:comment 'Estimated total cost for completing all closure activities, including final cap installation, grading, and site preparation.' ;
    rdfs:domain ind:ClosurePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedPostClosureCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Post Closure Cost' ;
    rdfs:comment 'Estimated total cost for the 30-year post-closure care period, including monitoring, maintenance, and reporting activities.' ;
    rdfs:domain ind:ClosurePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financialAssuranceProvider rdf:type rdf:Property ;
    rdfs:label 'Financial Assurance Provider' ;
    rdfs:comment 'Name of the institution or entity providing the financial assurance instrument (e.g., bank, insurance company, surety).' ;
    rdfs:domain ind:ClosurePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groundwaterSamplingFrequency rdf:type rdf:Property ;
    rdfs:label 'Groundwater Sampling Frequency' ;
    rdfs:comment 'Frequency of groundwater monitoring well sampling during the post-closure care period (e.g., quarterly, semi-annually).' ;
    rdfs:domain ind:ClosurePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leachateMonitoringFrequency rdf:type rdf:Property ;
    rdfs:label 'Leachate Monitoring Frequency' ;
    rdfs:comment 'Frequency of leachate collection system inspections and monitoring during the post-closure care period.' ;
    rdfs:domain ind:ClosurePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lfgMonitoringFrequency rdf:type rdf:Property ;
    rdfs:label 'Lfg Monitoring Frequency' ;
    rdfs:comment 'Frequency of landfill gas monitoring activities during the post-closure care period, including Lower Explosive Limit (LEL) readings.' ;
    rdfs:domain ind:ClosurePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringSchedule rdf:type rdf:Property ;
    rdfs:label 'Monitoring Schedule' ;
    rdfs:comment 'Detailed schedule of post-closure monitoring activities, including frequency and timing of inspections, sampling, and reporting.' ;
    rdfs:domain ind:ClosurePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Plan Document Reference' ;
    rdfs:comment 'File path, document management system reference, or URL to the full closure plan document.' ;
    rdfs:domain ind:ClosurePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedClosureCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Planned Closure Completion Date' ;
    rdfs:comment 'Scheduled date for completion of all closure construction activities, including final cap installation.' ;
    rdfs:domain ind:ClosurePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedClosureStartDate rdf:type rdf:Property ;
    rdfs:label 'Planned Closure Start Date' ;
    rdfs:comment 'Scheduled date for commencement of closure activities for the landfill site or cell.' ;
    rdfs:domain ind:ClosurePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:postClosureCarePeriodYears rdf:type rdf:Property ;
    rdfs:label 'Post Closure Care Period Years' ;
    rdfs:comment 'Duration of the post-closure care period in years, typically 30 years as required under RCRA Subtitle D.' ;
    rdfs:domain ind:ClosurePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:postClosureCareStartDate rdf:type rdf:Property ;
    rdfs:label 'Post Closure Care Start Date' ;
    rdfs:comment 'Date on which the 30-year post-closure care period begins, typically following completion of closure construction.' ;
    rdfs:domain ind:ClosurePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revisionHistory rdf:type rdf:Property ;
    rdfs:label 'Revision History' ;
    rdfs:comment 'Summary of major revisions and amendments to the closure plan, including dates and reasons for changes.' ;
    rdfs:domain ind:ClosurePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementSurveyFrequency rdf:type rdf:Property ;
    rdfs:label 'Settlement Survey Frequency' ;
    rdfs:comment 'Frequency of topographic surveys to monitor settlement and subsidence of the final cap during post-closure care.' ;
    rdfs:domain ind:ClosurePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vegetationAssessmentFrequency rdf:type rdf:Property ;
    rdfs:label 'Vegetation Assessment Frequency' ;
    rdfs:comment 'Frequency of vegetation health and erosion control assessments on the final cap during post-closure care.' ;
    rdfs:domain ind:ClosurePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compactionRecordId rdf:type rdf:Property ;
    rdfs:label 'Compaction Record Id' ;
    rdfs:comment 'Primary key for compaction_record' ;
    rdfs:domain ind:CompactionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:achievedCompactionRatio rdf:type rdf:Property ;
    rdfs:label 'Achieved Compaction Ratio' ;
    rdfs:comment 'The actual in-place density achieved during this compaction operation, measured in pounds per cubic yard. Calculated from waste tonnage and volume after compaction. Key performance indicator for operational efficiency.' ;
    rdfs:domain ind:CompactionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compactionDate rdf:type rdf:Property ;
    rdfs:label 'Compaction Date' ;
    rdfs:comment 'The calendar date on which the compaction operation was performed at the landfill working face. Primary business event date for this transaction.' ;
    rdfs:domain ind:CompactionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:compactionEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Compaction End Timestamp' ;
    rdfs:comment 'The precise date and time when the compaction operation was completed. Used to calculate duration and operational efficiency metrics.' ;
    rdfs:domain ind:CompactionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:compactionMethod rdf:type rdf:Property ;
    rdfs:label 'Compaction Method' ;
    rdfs:comment 'The operational method or technique used for compaction. Different methods achieve different density results and are selected based on waste type and operational goals.' ;
    rdfs:domain ind:CompactionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compactionStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Compaction Start Timestamp' ;
    rdfs:comment 'The precise date and time when the compaction operation began at the working face. Supports operational efficiency tracking and shift analysis.' ;
    rdfs:domain ind:CompactionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:compactionVariancePercent rdf:type rdf:Property ;
    rdfs:label 'Compaction Variance Percent' ;
    rdfs:comment 'The percentage variance between achieved and target compaction ratios. Positive values indicate over-achievement, negative values indicate under-achievement. Used for operational performance monitoring.' ;
    rdfs:domain ind:CompactionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coverMaterialType rdf:type rdf:Property ;
    rdfs:label 'Cover Material Type' ;
    rdfs:comment 'The type of daily cover material applied after compaction, if applicable. Alternative Daily Cover (ADC) options may be used per permit requirements.' ;
    rdfs:domain ind:Landfill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverMaterialVolumeCy rdf:type rdf:Property ;
    rdfs:label 'Cover Material Volume Cy' ;
    rdfs:comment 'The volume of cover material applied in cubic yards. Tracked for airspace consumption calculations and material inventory management.' ;
    rdfs:domain ind:CompactionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dailyCoverAppliedFlag rdf:type rdf:Property ;
    rdfs:label 'Daily Cover Applied Flag' ;
    rdfs:comment 'Indicates whether daily cover material was applied following this compaction operation. Required for regulatory compliance under RCRA Subtitle D.' ;
    rdfs:domain ind:CompactionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:equipmentHoursLogged rdf:type rdf:Property ;
    rdfs:label 'Equipment Hours Logged' ;
    rdfs:comment 'The total equipment operating hours logged during this compaction operation. Used for preventive maintenance (PM) scheduling and asset lifecycle management.' ;
    rdfs:domain ind:CompactionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interruptionReason rdf:type rdf:Property ;
    rdfs:label 'Interruption Reason' ;
    rdfs:comment 'The reason for any interruption or cancellation of the compaction operation. Captured for operational analysis and continuous improvement.' ;
    rdfs:domain ind:CompactionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberOfPasses rdf:type rdf:Property ;
    rdfs:label 'Number Of Passes' ;
    rdfs:comment 'The count of compaction passes made over the waste material during this operation. Key operational metric for achieving target compaction ratios.' ;
    rdfs:domain ind:CompactionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualityControlFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Control Flag' ;
    rdfs:comment 'Indicates whether this compaction operation passed quality control inspection. Used to identify operations requiring corrective action or re-work.' ;
    rdfs:domain ind:CompactionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetCompactionRatio rdf:type rdf:Property ;
    rdfs:label 'Target Compaction Ratio' ;
    rdfs:comment 'The design compaction ratio target in pounds per cubic yard that operations aim to achieve. Sourced from cell design specifications and permit requirements.' ;
    rdfs:domain ind:CompactionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeAfterCompactionCy rdf:type rdf:Property ;
    rdfs:label 'Volume After Compaction Cy' ;
    rdfs:comment 'The measured volume of waste in cubic yards after compaction operations were completed. Critical for airspace consumption tracking and capacity planning.' ;
    rdfs:domain ind:CompactionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeBeforeCompactionCy rdf:type rdf:Property ;
    rdfs:label 'Volume Before Compaction Cy' ;
    rdfs:comment 'The estimated volume of waste in cubic yards before compaction operations began. Used to calculate compaction effectiveness and airspace optimization.' ;
    rdfs:domain ind:CompactionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wasteTonnageCompacted rdf:type rdf:Property ;
    rdfs:label 'Waste Tonnage Compacted' ;
    rdfs:comment 'The total weight in tons of waste material compacted during this operation. Sourced from tonnage receipt records for the working face during the compaction period.' ;
    rdfs:domain ind:CompactionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wasteTypeCompacted rdf:type rdf:Property ;
    rdfs:label 'Waste Type Compacted' ;
    rdfs:comment 'The primary classification of waste material compacted during this operation. MSW = Municipal Solid Waste, C&D = Construction and Demolition Waste. Affects achievable compaction ratios and operational planning.' ;
    rdfs:domain ind:CompactionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workingFaceHeightFeet rdf:type rdf:Property ;
    rdfs:label 'Working Face Height Feet' ;
    rdfs:comment 'The vertical height of the active working face in feet during this compaction operation. Critical for slope stability and operational safety monitoring.' ;
    rdfs:domain ind:CompactionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workingFaceLengthFeet rdf:type rdf:Property ;
    rdfs:label 'Working Face Length Feet' ;
    rdfs:comment 'The length dimension of the active working face in feet during this compaction operation. Used for operational planning and airspace calculations.' ;
    rdfs:domain ind:CompactionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workingFaceWidthFeet rdf:type rdf:Property ;
    rdfs:label 'Working Face Width Feet' ;
    rdfs:comment 'The width dimension of the active working face in feet during this compaction operation. Used for operational planning and airspace calculations.' ;
    rdfs:domain ind:CompactionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dailyCoverId rdf:type rdf:Property ;
    rdfs:label 'Daily Cover Id' ;
    rdfs:comment 'Unique identifier for the daily cover application event record.' ;
    rdfs:domain ind:DailyCover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Last Modified By User Employee Id' ;
    rdfs:comment 'Reference to the system user who last modified this daily cover record.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryDailyEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Daily Employee Id' ;
    rdfs:comment 'Reference to the equipment operator who performed the daily cover application.' ;
    rdfs:domain ind:DailyCover ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:adcPermitNumber rdf:type rdf:Property ;
    rdfs:label 'Adc Permit Number' ;
    rdfs:comment 'EPA or state-issued permit number authorizing use of alternative daily cover materials in lieu of traditional soil cover.' ;
    rdfs:domain ind:DailyCover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Completed Timestamp' ;
    rdfs:comment 'Timestamp when corrective action was completed and verified.' ;
    rdfs:domain ind:DailyCover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:coverApplicationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cover Application Timestamp' ;
    rdfs:comment 'Precise timestamp when the daily cover application was completed.' ;
    rdfs:domain ind:DailyCover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:coverDate rdf:type rdf:Property ;
    rdfs:label 'Cover Date' ;
    rdfs:comment 'The date on which the daily cover was applied to the active working face.' ;
    rdfs:domain ind:DailyCover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:coverMaterialCostUsd rdf:type rdf:Property ;
    rdfs:label 'Cover Material Cost Usd' ;
    rdfs:comment 'Total cost of cover material used in this application event, measured in US dollars. Includes material purchase or extraction cost.' ;
    rdfs:domain ind:DailyCover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coverMaterialDescription rdf:type rdf:Property ;
    rdfs:label 'Cover Material Description' ;
    rdfs:comment 'Detailed description of the specific cover material used, including brand name, product specifications, or soil classification.' ;
    rdfs:domain ind:DailyCover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deficienciesIdentified rdf:type rdf:Property ;
    rdfs:label 'Deficiencies Identified' ;
    rdfs:comment 'Description of any deficiencies or non-conformances identified during inspection, such as inadequate thickness, incomplete coverage, or material failure.' ;
    rdfs:domain ind:Landfill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentHours rdf:type rdf:Property ;
    rdfs:label 'Equipment Hours' ;
    rdfs:comment 'Total equipment operating hours logged during this daily cover application event.' ;
    rdfs:domain ind:DailyCover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fireRiskMitigation rdf:type rdf:Property ;
    rdfs:label 'Fire Risk Mitigation' ;
    rdfs:comment 'Assessment of how effectively the daily cover reduced subsurface fire risk by limiting oxygen infiltration.' ;
    rdfs:domain ind:DailyCover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gpsCoordinates rdf:type rdf:Property ;
    rdfs:label 'Gps Coordinates' ;
    rdfs:comment 'GPS coordinates (latitude, longitude) of the covered working face area for spatial tracking and airspace management.' ;
    rdfs:domain ind:Landfill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionPerformedFlag rdf:type rdf:Property ;
    rdfs:label 'Inspection Performed Flag' ;
    rdfs:comment 'Indicates whether a formal inspection of the daily cover application was performed by supervisory or compliance staff. True = inspection performed, False = no inspection.' ;
    rdfs:domain ind:DailyCover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laborHours rdf:type rdf:Property ;
    rdfs:label 'Labor Hours' ;
    rdfs:comment 'Total labor hours expended for this daily cover application event, including operator time and support crew.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:litterControlEffectiveness rdf:type rdf:Property ;
    rdfs:label 'Litter Control Effectiveness' ;
    rdfs:comment 'Assessment of how effectively the daily cover prevented windblown litter and debris dispersal from the working face.' ;
    rdfs:domain ind:DailyCover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:odorControlEffectiveness rdf:type rdf:Property ;
    rdfs:label 'Odor Control Effectiveness' ;
    rdfs:comment 'Subjective assessment of how effectively the daily cover controlled odor emissions from the working face.' ;
    rdfs:domain ind:DailyCover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:photoDocumentationUrl rdf:type rdf:Property ;
    rdfs:label 'Photo Documentation Url' ;
    rdfs:comment 'URL or file path to photographic documentation of the daily cover application, used for compliance records and quality assurance.' ;
    rdfs:domain ind:Landfill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shift rdf:type rdf:Property ;
    rdfs:label 'Shift' ;
    rdfs:comment 'Work shift during which the daily cover application was performed.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thicknessAchievedInches rdf:type rdf:Property ;
    rdfs:label 'Thickness Achieved Inches' ;
    rdfs:comment 'Actual thickness of cover material achieved after compaction, measured in inches. RCRA Subtitle D requires minimum 6 inches of soil or approved ADC equivalent.' ;
    rdfs:domain ind:DailyCover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vectorControlEffectiveness rdf:type rdf:Property ;
    rdfs:label 'Vector Control Effectiveness' ;
    rdfs:comment 'Assessment of how effectively the daily cover prevented access by birds, rodents, and insects (disease vectors).' ;
    rdfs:domain ind:DailyCover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeAppliedCubicYards rdf:type rdf:Property ;
    rdfs:label 'Volume Applied Cubic Yards' ;
    rdfs:comment 'Total volume of cover material applied measured in cubic yards. Applicable primarily to soil and bulk ADC materials.' ;
    rdfs:domain ind:DailyCover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workingFaceAreaSquareFeet rdf:type rdf:Property ;
    rdfs:label 'Working Face Area Square Feet' ;
    rdfs:comment 'Total surface area of the active working face covered during this application event, measured in square feet.' ;
    rdfs:domain ind:DailyCover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalCoordinatorName rdf:type rdf:Property ;
    rdfs:label 'Environmental Coordinator Name' ;
    rdfs:comment 'Name of the internal environmental coordinator responsible for managing this permit.' ;
    rdfs:domain ind:DisposalPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastRenewalDate rdf:type rdf:Property ;
    rdfs:label 'Last Renewal Date' ;
    rdfs:comment 'Date when the permit was most recently renewed.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastReportSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Last Report Submission Date' ;
    rdfs:comment 'Date when the most recent compliance report was submitted to the regulatory authority.' ;
    rdfs:domain ind:DisposalPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextReportDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Report Due Date' ;
    rdfs:comment 'Deadline for the next compliance report submission required under this permit.' ;
    rdfs:domain ind:DisposalPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:permitConditionsSummary rdf:type rdf:Property ;
    rdfs:label 'Permit Conditions Summary' ;
    rdfs:comment 'High-level summary of key conditions, restrictions, and operational requirements imposed by the permit.' ;
    rdfs:domain ind:DisposalPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Permit Document Reference' ;
    rdfs:comment 'File path, URL, or document management system reference to the official permit document.' ;
    rdfs:domain ind:DisposalPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permittedTotalCapacityCubicYards rdf:type rdf:Property ;
    rdfs:label 'Permitted Total Capacity Cubic Yards' ;
    rdfs:comment 'Total lifetime capacity authorized under this permit, measured in cubic yards.' ;
    rdfs:domain ind:DisposalPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:permittedTotalCapacityTons rdf:type rdf:Property ;
    rdfs:label 'Permitted Total Capacity Tons' ;
    rdfs:comment 'Total lifetime capacity authorized under this permit, measured in tons.' ;
    rdfs:domain ind:DisposalPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewalApplicationDueDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Application Due Date' ;
    rdfs:comment 'Deadline by which the permit renewal application must be submitted to the regulatory authority to avoid lapse.' ;
    rdfs:domain ind:DisposalPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responsiblePartyContact rdf:type rdf:Property ;
    rdfs:label 'Responsible Party Contact' ;
    rdfs:comment 'Contact information (phone or email) for the responsible party.' ;
    rdfs:domain ind:DisposalPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialConditions rdf:type rdf:Property ;
    rdfs:label 'Special Conditions' ;
    rdfs:comment 'Detailed description of any special or site-specific conditions attached to the permit (e.g., enhanced monitoring, restricted hours, buffer zone requirements).' ;
    rdfs:domain ind:DisposalPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groundwaterMonitoringWellId rdf:type rdf:Property ;
    rdfs:label 'Groundwater Monitoring Well Id' ;
    rdfs:comment 'Unique identifier for the groundwater monitoring well record. Primary key for the entity.' ;
    rdfs:domain ind:Landfill ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GroundwaterMonitoringWell .

ind:analyteListCode rdf:type rdf:Property ;
    rdfs:label 'Analyte List Code' ;
    rdfs:comment 'Code or reference to the list of chemical analytes (parameters) tested during sampling events at this well. Typically Appendix I, Appendix II, or site-specific list per RCRA.' ;
    rdfs:domain ind:GroundwaterMonitoringWell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aquiferZone rdf:type rdf:Property ;
    rdfs:label 'Aquifer Zone' ;
    rdfs:comment 'Name or designation of the aquifer zone or hydrogeologic unit being monitored by this well (e.g., Upper Alluvial, Bedrock, Perched Water Table).' ;
    rdfs:domain ind:Landfill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decommissionReason rdf:type rdf:Property ;
    rdfs:label 'Decommission Reason' ;
    rdfs:comment 'Business or regulatory reason for decommissioning the well (e.g., landfill closure, well damage, redundant monitoring point, permit modification).' ;
    rdfs:domain ind:GroundwaterMonitoringWell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:elevationFeetMsl rdf:type rdf:Property ;
    rdfs:label 'Elevation Feet Msl' ;
    rdfs:comment 'Elevation of the well top-of-casing or ground surface reference point in feet above mean sea level. Critical for calculating hydraulic gradients and groundwater flow direction.' ;
    rdfs:domain ind:GroundwaterMonitoringWell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:epaSwisWellCode rdf:type rdf:Property ;
    rdfs:label 'Epa Swis Well Code' ;
    rdfs:comment 'Unique identifier assigned by EPA SWIS for this monitoring well. Used in federal reporting and data exchange with EPA.' ;
    rdfs:domain ind:GroundwaterMonitoringWell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filterPackMaterial rdf:type rdf:Property ;
    rdfs:label 'Filter Pack Material' ;
    rdfs:comment 'Material placed around the well screen to prevent fine sediment from entering the well while allowing groundwater flow. Typically clean silica sand.' ;
    rdfs:domain ind:GroundwaterMonitoringWell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastSamplingDate rdf:type rdf:Property ;
    rdfs:label 'Last Sampling Date' ;
    rdfs:comment 'Date of the most recent groundwater sampling event at this well. Used to track compliance with sampling frequency requirements.' ;
    rdfs:domain ind:GroundwaterMonitoringWell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextScheduledSamplingDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Sampling Date' ;
    rdfs:comment 'Planned date for the next groundwater sampling event. Calculated based on sampling frequency and last sampling date. Used for field scheduling.' ;
    rdfs:domain ind:GroundwaterMonitoringWell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:permitReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Permit Reference Number' ;
    rdfs:comment 'Reference number of the environmental permit or regulatory order that mandates monitoring at this well. Links well to specific compliance obligations.' ;
    rdfs:domain ind:GroundwaterMonitoringWell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Flag' ;
    rdfs:comment 'Indicates whether sampling results from this well must be included in regulatory reports to EPA or state agencies. True for compliance wells; false for supplemental monitoring points.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:screenIntervalBottomFeet rdf:type rdf:Property ;
    rdfs:label 'Screen Interval Bottom Feet' ;
    rdfs:comment 'Depth in feet from ground surface to the bottom of the screened interval. Defines the monitored zone lower boundary.' ;
    rdfs:domain ind:Landfill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:screenIntervalTopFeet rdf:type rdf:Property ;
    rdfs:label 'Screen Interval Top Feet' ;
    rdfs:comment 'Depth in feet from ground surface to the top of the screened interval where groundwater enters the well. Defines the monitored zone upper boundary.' ;
    rdfs:domain ind:Landfill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sealMaterial rdf:type rdf:Property ;
    rdfs:label 'Seal Material' ;
    rdfs:comment 'Material used to seal the annular space between the borehole wall and well casing. Prevents surface water infiltration and cross-contamination between aquifer zones.' ;
    rdfs:domain ind:GroundwaterMonitoringWell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateWellPermitNumber rdf:type rdf:Property ;
    rdfs:label 'State Well Permit Number' ;
    rdfs:comment 'State-issued permit or registration number for the monitoring well. Required in many jurisdictions for all groundwater monitoring wells.' ;
    rdfs:domain ind:GroundwaterMonitoringWell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:staticWaterLevelFeet rdf:type rdf:Property ;
    rdfs:label 'Static Water Level Feet' ;
    rdfs:comment 'Most recent measured depth to groundwater from the top of casing, in feet. Used to calculate groundwater elevation and flow direction. Updated after each sampling event.' ;
    rdfs:domain ind:GroundwaterMonitoringWell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDepthFeet rdf:type rdf:Property ;
    rdfs:label 'Total Depth Feet' ;
    rdfs:comment 'Total depth of the monitoring well from ground surface to bottom, measured in feet. Determines the aquifer zone being monitored.' ;
    rdfs:domain ind:GroundwaterMonitoringWell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wellConstructionMethod rdf:type rdf:Property ;
    rdfs:label 'Well Construction Method' ;
    rdfs:comment 'Drilling and installation method used to construct the monitoring well. Hollow stem auger is most common for shallow environmental wells.' ;
    rdfs:domain ind:GroundwaterMonitoringWell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wellDesignation rdf:type rdf:Property ;
    rdfs:label 'Well Designation' ;
    rdfs:comment 'Business identifier for the monitoring well, typically assigned per site naming convention (e.g., MW-01, GW-UG-03). Used in regulatory reports and field operations.' ;
    rdfs:domain ind:GroundwaterMonitoringWell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wellDevelopmentDate rdf:type rdf:Property ;
    rdfs:label 'Well Development Date' ;
    rdfs:comment 'Date when well development (removal of drilling fluids and fines) was completed and the well was ready for sampling. Typically occurs shortly after installation.' ;
    rdfs:domain ind:GroundwaterMonitoringWell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:wellNotes rdf:type rdf:Property ;
    rdfs:label 'Well Notes' ;
    rdfs:comment 'Free-text field for operational notes, field observations, maintenance history, or special sampling instructions for this well.' ;
    rdfs:domain ind:GroundwaterMonitoringWell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wellStatus rdf:type rdf:Property ;
    rdfs:label 'Well Status' ;
    rdfs:comment 'Current operational status of the monitoring well in its lifecycle. Active wells are sampled per schedule; inactive wells are not currently monitored.' ;
    rdfs:domain ind:GroundwaterMonitoringWell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wellType rdf:type rdf:Property ;
    rdfs:label 'Well Type' ;
    rdfs:comment 'Classification of the well based on its position relative to the landfill and regulatory purpose. Upgradient wells establish baseline conditions; downgradient wells detect contamination migration.' ;
    rdfs:domain ind:Landfill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groundwaterSampleId rdf:type rdf:Property ;
    rdfs:label 'Groundwater Sample Id' ;
    rdfs:comment 'Unique identifier for the groundwater sampling event record.' ;
    rdfs:domain ind:GroundwaterSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:analysisCompleteDate rdf:type rdf:Property ;
    rdfs:label 'Analysis Complete Date' ;
    rdfs:comment 'Date when laboratory analysis of the sample was completed.' ;
    rdfs:domain ind:GroundwaterSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:analysisStartDate rdf:type rdf:Property ;
    rdfs:label 'Analysis Start Date' ;
    rdfs:comment 'Date when laboratory analysis of the sample began.' ;
    rdfs:domain ind:GroundwaterSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:analyticalParametersTested rdf:type rdf:Property ;
    rdfs:label 'Analytical Parameters Tested' ;
    rdfs:comment 'Comma-separated list of analytical parameters and contaminants tested in this sample (e.g., VOCs, metals, indicator parameters).' ;
    rdfs:domain ind:GroundwaterSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cerclaReportableFlag rdf:type rdf:Property ;
    rdfs:label 'Cercla Reportable Flag' ;
    rdfs:comment 'Indicates whether detected concentrations trigger CERCLA (Superfund) reporting obligations.' ;
    rdfs:domain ind:GroundwaterSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exceedanceDetectedFlag rdf:type rdf:Property ;
    rdfs:label 'Exceedance Detected Flag' ;
    rdfs:comment 'Indicates whether any detected concentrations exceeded applicable Groundwater Protection Standard (GWPS) limits or regulatory thresholds.' ;
    rdfs:domain ind:GroundwaterSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exceedanceParameters rdf:type rdf:Property ;
    rdfs:label 'Exceedance Parameters' ;
    rdfs:comment 'Comma-separated list of specific parameters that exceeded applicable Groundwater Protection Standard (GWPS) limits.' ;
    rdfs:domain ind:Landfill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fieldConductivityUmhos rdf:type rdf:Property ;
    rdfs:label 'Field Conductivity Umhos' ;
    rdfs:comment 'Specific conductivity measured in the field at the time of sample collection, in micromhos per centimeter.' ;
    rdfs:domain ind:GroundwaterSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fieldDissolvedOxygenMgL rdf:type rdf:Property ;
    rdfs:label 'Field Dissolved Oxygen Mg L' ;
    rdfs:comment 'Dissolved oxygen concentration measured in the field at the time of sample collection, in milligrams per liter.' ;
    rdfs:domain ind:GroundwaterSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fieldNotes rdf:type rdf:Property ;
    rdfs:label 'Field Notes' ;
    rdfs:comment 'Additional field observations, notes, or comments recorded by the sampling technician during sample collection.' ;
    rdfs:domain ind:GroundwaterSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fieldOxidationReductionPotentialMv rdf:type rdf:Property ;
    rdfs:label 'Field Oxidation Reduction Potential Mv' ;
    rdfs:comment 'Oxidation-reduction potential (ORP) measured in the field at the time of sample collection, in millivolts.' ;
    rdfs:domain ind:GroundwaterSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fieldPh rdf:type rdf:Property ;
    rdfs:label 'Field Ph' ;
    rdfs:comment 'pH measurement taken in the field at the time of sample collection.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fieldTemperatureCelsius rdf:type rdf:Property ;
    rdfs:label 'Field Temperature Celsius' ;
    rdfs:comment 'Water temperature measured in the field at the time of sample collection, in degrees Celsius.' ;
    rdfs:domain ind:GroundwaterSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fieldTurbidityNtu rdf:type rdf:Property ;
    rdfs:label 'Field Turbidity Ntu' ;
    rdfs:comment 'Turbidity measured in the field at the time of sample collection, in Nephelometric Turbidity Units.' ;
    rdfs:domain ind:GroundwaterSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gwpsLimitExceeded rdf:type rdf:Property ;
    rdfs:label 'Gwps Limit Exceeded' ;
    rdfs:comment 'Description of the specific Groundwater Protection Standard limit that was exceeded, including the parameter name and limit value.' ;
    rdfs:domain ind:GroundwaterSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laboratorySampleNumber rdf:type rdf:Property ;
    rdfs:label 'Laboratory Sample Number' ;
    rdfs:comment 'Unique identifier assigned by the analytical laboratory for tracking and reporting purposes.' ;
    rdfs:domain ind:GroundwaterSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metalsAnalysisMethod rdf:type rdf:Property ;
    rdfs:label 'Metals Analysis Method' ;
    rdfs:comment 'EPA analytical method used for metals analysis (typically ICP or ICP-MS). [ENUM-REF-CANDIDATE: EPA_6010|EPA_6010B|EPA_6010C|EPA_6010D|EPA_6020|EPA_6020A|EPA_6020B|not_tested — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GroundwaterSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purgeVolumeGallons rdf:type rdf:Property ;
    rdfs:label 'Purge Volume Gallons' ;
    rdfs:comment 'Volume of water purged from the monitoring well prior to sample collection, measured in gallons.' ;
    rdfs:domain ind:GroundwaterSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Date' ;
    rdfs:comment 'Date when regulatory authorities were notified of exceedance or other reportable conditions.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryNotificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Required Flag' ;
    rdfs:comment 'Indicates whether regulatory notification to EPA, state, or Local Enforcement Agency (LEA) is required based on sample results.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sampleAppearance rdf:type rdf:Property ;
    rdfs:label 'Sample Appearance' ;
    rdfs:comment 'Visual description of the sample appearance (e.g., clear, cloudy, discolored, odor present).' ;
    rdfs:domain ind:GroundwaterSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleDate rdf:type rdf:Property ;
    rdfs:label 'Sample Date' ;
    rdfs:comment 'Date when the groundwater sample was collected from the monitoring well.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sampleNumber rdf:type rdf:Property ;
    rdfs:label 'Sample Number' ;
    rdfs:comment 'Unique field sample identification number assigned by the sampling technician or laboratory.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleTime rdf:type rdf:Property ;
    rdfs:label 'Sample Time' ;
    rdfs:comment 'Precise timestamp when the groundwater sample was collected, including time zone.' ;
    rdfs:domain ind:GroundwaterSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sampleType rdf:type rdf:Property ;
    rdfs:label 'Sample Type' ;
    rdfs:comment 'Classification of the sample purpose (routine monitoring, confirmation, assessment, background, quality control duplicate, or blank).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:swisReportingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Swis Reporting Required Flag' ;
    rdfs:comment 'Indicates whether this sample result must be included in EPA Solid Waste Information System (SWIS) reporting.' ;
    rdfs:domain ind:GroundwaterSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vocAnalysisMethod rdf:type rdf:Property ;
    rdfs:label 'Voc Analysis Method' ;
    rdfs:comment 'EPA analytical method used for volatile organic compound analysis.' ;
    rdfs:domain ind:GroundwaterSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:landfillTippingFeeScheduleId rdf:type rdf:Property ;
    rdfs:label 'Landfill Tipping Fee Schedule Id' ;
    rdfs:comment 'Unique identifier for the tipping fee schedule record. Primary key.' ;
    rdfs:domain ind:Landfill ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LandfillTippingFeeSchedule .

ind:applicableOfferingId rdf:type rdf:Property ;
    rdfs:label 'Applicable Offering Id' ;
    rdfs:comment 'Foreign key linking to service.offering. Business justification: Tipping fee schedules are often structured by service offering type to enable service-specific pricing, competitive analysis, and margin management. Linking schedules to offerings ensures fee structur' ;
    rdfs:domain ind:LandfillTippingFeeSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Offering .

ind:billingInvoiceLineId rdf:type rdf:Property ;
    rdfs:label 'Billing Invoice Line Id' ;
    rdfs:comment 'Foreign key linking to billing.invoice_line. Business justification: Invoice lines reference specific tipping fee schedule entries to show which rate was applied, providing audit trail for billing disputes. Real-world: invoice line shows \'MSW disposal @ $45/ton per sch' ;
    rdfs:domain ind:LandfillTippingFeeSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InvoiceLine .

ind:contractReference rdf:type rdf:Property ;
    rdfs:label 'Contract Reference' ;
    rdfs:comment 'Reference number or identifier of the customer contract or municipal agreement that governs this fee schedule. Links pricing to contractual terms.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalSurchargeRate rdf:type rdf:Property ;
    rdfs:label 'Environmental Surcharge Rate' ;
    rdfs:comment 'Per-unit fee to cover environmental compliance costs including monitoring, remediation, and regulatory reporting. Supports EPA and state environmental program funding.' ;
    rdfs:domain ind:LandfillTippingFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hostCommunityFeeRate rdf:type rdf:Property ;
    rdfs:label 'Host Community Fee Rate' ;
    rdfs:comment 'Per-unit fee paid to the host municipality or community as part of host community agreements. Compensates local jurisdictions for hosting landfill operations.' ;
    rdfs:domain ind:LandfillTippingFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatorySurchargeRate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Surcharge Rate' ;
    rdfs:comment 'Per-unit fee to cover regulatory compliance costs including permit fees, inspections, and mandated reporting. Varies by jurisdiction and waste type.' ;
    rdfs:domain ind:LandfillTippingFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduleVersion rdf:type rdf:Property ;
    rdfs:label 'Schedule Version' ;
    rdfs:comment 'Version identifier for the fee schedule to track revisions and updates over time. Supports historical fee analysis and audit trails.' ;
    rdfs:domain ind:LandfillTippingFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialHandlingRequired rdf:type rdf:Property ;
    rdfs:label 'Special Handling Required' ;
    rdfs:comment 'Indicates whether waste under this fee schedule requires special handling procedures, equipment, or disposal methods. True if special handling is required, False otherwise.' ;
    rdfs:domain ind:LandfillTippingFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:volumeThresholdTons rdf:type rdf:Property ;
    rdfs:label 'Volume Threshold Tons' ;
    rdfs:comment 'Minimum tonnage threshold required to qualify for this fee schedule or pricing tier. Supports volume-based pricing incentives.' ;
    rdfs:domain ind:LandfillTippingFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leachateCollectionId rdf:type rdf:Property ;
    rdfs:label 'Leachate Collection Id' ;
    rdfs:comment 'Unique identifier for the leachate collection event record.' ;
    rdfs:domain ind:LeachateCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:collectionPointId rdf:type rdf:Property ;
    rdfs:label 'Collection Point Id' ;
    rdfs:comment 'Identifier of the specific collection point such as sump ID, pipe segment, or monitoring well where leachate was collected.' ;
    rdfs:domain ind:Landfill ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CollectionPoint .

ind:ammoniaNitrogenMgL rdf:type rdf:Property ;
    rdfs:label 'Ammonia Nitrogen Mg L' ;
    rdfs:comment 'Ammonia nitrogen concentration in milligrams per liter, a key nutrient pollutant parameter.' ;
    rdfs:domain ind:LeachateCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bodMgL rdf:type rdf:Property ;
    rdfs:label 'Bod Mg L' ;
    rdfs:comment 'Biological Oxygen Demand measurement in milligrams per liter, indicating biodegradable organic matter in the leachate.' ;
    rdfs:domain ind:Landfill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:codMgL rdf:type rdf:Property ;
    rdfs:label 'Cod Mg L' ;
    rdfs:comment 'Chemical Oxygen Demand measurement in milligrams per liter, indicating organic pollutant load in the leachate.' ;
    rdfs:domain ind:Landfill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:collectionDate rdf:type rdf:Property ;
    rdfs:label 'Collection Date' ;
    rdfs:comment 'Date when the leachate collection event occurred.' ;
    rdfs:domain ind:LeachateCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:collectionPointType rdf:type rdf:Property ;
    rdfs:label 'Collection Point Type' ;
    rdfs:comment 'Type of collection infrastructure where leachate was gathered.' ;
    rdfs:domain ind:LeachateCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionSystemStatus rdf:type rdf:Property ;
    rdfs:label 'Collection System Status' ;
    rdfs:comment 'Operational status of the leachate collection system at the time of the event.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Collection Timestamp' ;
    rdfs:comment 'Precise timestamp when the leachate collection measurement was recorded.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:conductivityUmhosCm rdf:type rdf:Property ;
    rdfs:label 'Conductivity Umhos Cm' ;
    rdfs:comment 'Electrical conductivity of the leachate sample measured in micromhos per centimeter, indicating dissolved solids concentration.' ;
    rdfs:domain ind:LeachateCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disposalVolumeGallons rdf:type rdf:Property ;
    rdfs:label 'Disposal Volume Gallons' ;
    rdfs:comment 'Volume of leachate disposed or treated, measured in gallons.' ;
    rdfs:domain ind:LeachateCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:heavyMetalsDetected rdf:type rdf:Property ;
    rdfs:label 'Heavy Metals Detected' ;
    rdfs:comment 'Comma-separated list of heavy metals detected in the leachate sample (e.g., lead, cadmium, mercury, arsenic) per TCLP testing.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labSampleNumber rdf:type rdf:Property ;
    rdfs:label 'Lab Sample Number' ;
    rdfs:comment 'Unique identifier assigned to the laboratory sample for chain-of-custody tracking and analysis.' ;
    rdfs:domain ind:Landfill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leachateHeadLevelInches rdf:type rdf:Property ;
    rdfs:label 'Leachate Head Level Inches' ;
    rdfs:comment 'Measured leachate head level in inches above the liner at the collection point, critical for liner integrity monitoring.' ;
    rdfs:domain ind:LeachateCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:linerIntegrityStatus rdf:type rdf:Property ;
    rdfs:label 'Liner Integrity Status' ;
    rdfs:comment 'Assessment of liner integrity at the collection point based on leachate head levels and monitoring data.' ;
    rdfs:domain ind:Landfill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitLimitComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Permit Limit Compliance Flag' ;
    rdfs:comment 'Boolean flag indicating whether the leachate quality parameters were within permitted discharge limits (True = compliant, False = violation).' ;
    rdfs:domain ind:LeachateCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:precipitationLast24hInches rdf:type rdf:Property ;
    rdfs:label 'Precipitation Last 24h Inches' ;
    rdfs:comment 'Total precipitation in inches during the 24 hours prior to collection, affecting leachate generation volume.' ;
    rdfs:domain ind:Landfill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryReportSubmittedFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Submitted Flag' ;
    rdfs:comment 'Boolean flag indicating whether this collection event data has been included in regulatory reporting submissions (True = submitted, False = pending).' ;
    rdfs:domain ind:Landfill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sampleCollectedFlag rdf:type rdf:Property ;
    rdfs:label 'Sample Collected Flag' ;
    rdfs:comment 'Boolean flag indicating whether a laboratory sample was collected during this event for detailed analysis (True = sample collected, False = no sample).' ;
    rdfs:domain ind:Landfill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalDissolvedSolidsMgL rdf:type rdf:Property ;
    rdfs:label 'Total Dissolved Solids Mg L' ;
    rdfs:comment 'Total dissolved solids concentration in milligrams per liter.' ;
    rdfs:domain ind:LeachateCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalSuspendedSolidsMgL rdf:type rdf:Property ;
    rdfs:label 'Total Suspended Solids Mg L' ;
    rdfs:comment 'Total suspended solids concentration in milligrams per liter.' ;
    rdfs:domain ind:LeachateCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeCollectedGallons rdf:type rdf:Property ;
    rdfs:label 'Volume Collected Gallons' ;
    rdfs:comment 'Total volume of leachate collected during this event, measured in gallons.' ;
    rdfs:domain ind:LeachateCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:headerPipeSegmentId rdf:type rdf:Property ;
    rdfs:label 'Header Pipe Segment Id' ;
    rdfs:comment 'Reference to the LFG collection header pipe segment that this well is connected to. Supports gas flow network modeling and system optimization.' ;
    rdfs:domain ind:LfgExtractionWell ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:landfillCellId rdf:type rdf:Property ;
    rdfs:label 'Landfill Cell Id' ;
    rdfs:comment 'Reference to the specific landfill cell where this extraction well is located. Supports cell-level gas collection tracking and capacity planning.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Cell .

ind:abandonmentDate rdf:type rdf:Property ;
    rdfs:label 'Abandonment Date' ;
    rdfs:comment 'Date when the well was permanently closed and abandoned. Wells are abandoned when no longer needed due to cell closure, system reconfiguration, or end of gas generation. Null for active wells.' ;
    rdfs:domain ind:LfgExtractionWell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:abandonmentMethod rdf:type rdf:Property ;
    rdfs:label 'Abandonment Method' ;
    rdfs:comment 'Method used to permanently close the well. Grouted wells are filled with cement grout; capped wells have sealed wellheads; removed wells are fully extracted; other methods per site-specific procedures. Null for active wells.' ;
    rdfs:domain ind:LfgExtractionWell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetTagNumber rdf:type rdf:Property ;
    rdfs:label 'Asset Tag Number' ;
    rdfs:comment 'Fixed asset tag or barcode identifier assigned by the asset management system. Links to Infor EAM for maintenance scheduling, parts inventory, and lifecycle tracking.' ;
    rdfs:domain ind:LfgExtractionWell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constructionContractor rdf:type rdf:Property ;
    rdfs:label 'Construction Contractor' ;
    rdfs:comment 'Name of the contractor or vendor that installed the extraction well. Used for warranty claims, quality tracking, and vendor performance evaluation.' ;
    rdfs:domain ind:LfgExtractionWell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constructionCostUsd rdf:type rdf:Property ;
    rdfs:label 'Construction Cost Usd' ;
    rdfs:comment 'Total cost of well installation including materials, labor, and equipment in US dollars. Used for capital expenditure tracking, asset valuation, and ROI analysis.' ;
    rdfs:domain ind:LfgExtractionWell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:designExtractionRateScfm rdf:type rdf:Property ;
    rdfs:label 'Design Extraction Rate Scfm' ;
    rdfs:comment 'Designed gas extraction capacity of the well measured in standard cubic feet per minute (SCFM) at standard temperature and pressure. Used for system capacity planning and performance evaluation.' ;
    rdfs:domain ind:LfgExtractionWell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:designVacuumInchesH2o rdf:type rdf:Property ;
    rdfs:label 'Design Vacuum Inches H2o' ;
    rdfs:comment 'Target vacuum pressure at the wellhead measured in inches of water column. Optimal vacuum range is typically 2-6 inches H2O to maximize gas extraction while minimizing air intrusion.' ;
    rdfs:domain ind:LfgExtractionWell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:elevationFeet rdf:type rdf:Property ;
    rdfs:label 'Elevation Feet' ;
    rdfs:comment 'Ground surface elevation at the well location measured in feet above mean sea level. Used for hydraulic gradient calculations and leachate management.' ;
    rdfs:domain ind:LfgExtractionWell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rngProductionEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Rng Production Eligible Flag' ;
    rdfs:comment 'Indicates whether gas from this well is routed to the RNG production facility. True if well contributes to RNG production; false if gas is flared or used for waste-to-energy only. Supports RNG revenue allocation and environmental credit tracking.' ;
    rdfs:domain ind:LfgExtractionWell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:wellDepthFeet rdf:type rdf:Property ;
    rdfs:label 'Well Depth Feet' ;
    rdfs:comment 'Total depth of the extraction well measured in feet from ground surface to bottom of well screen. Critical for gas collection efficiency and design capacity calculations.' ;
    rdfs:domain ind:LfgExtractionWell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wellDiameterInches rdf:type rdf:Property ;
    rdfs:label 'Well Diameter Inches' ;
    rdfs:comment 'Internal diameter of the well casing measured in inches. Affects gas flow capacity and extraction efficiency.' ;
    rdfs:domain ind:LfgExtractionWell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wellIdentifier rdf:type rdf:Property ;
    rdfs:label 'Well Identifier' ;
    rdfs:comment 'Business identifier or tag number for the LFG extraction well. Used for field operations, maintenance work orders, and regulatory reporting. May follow site-specific naming conventions (e.g., SITE-CELL-WELL-###).' ;
    rdfs:domain ind:LfgExtractionWell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wellheadEquipmentType rdf:type rdf:Property ;
    rdfs:label 'Wellhead Equipment Type' ;
    rdfs:comment 'Classification of wellhead control and monitoring equipment. Standard wellheads have manual valves; adjustable wellheads allow field tuning; automated wellheads have remote control capability; monitoring-only wellheads are for observation wells.' ;
    rdfs:domain ind:LfgExtractionWell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lfgMonitoringId rdf:type rdf:Property ;
    rdfs:label 'Lfg Monitoring Id' ;
    rdfs:comment 'Unique identifier for the landfill gas monitoring record.' ;
    rdfs:domain ind:LfgMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:correctiveWorkOrderId rdf:type rdf:Property ;
    rdfs:label 'Corrective Work Order Id' ;
    rdfs:comment 'Foreign key linking to maintenance.work_order. Business justification: When LFG monitoring detects exceedances requiring corrective maintenance (well repairs, header pipe leaks), operations generate work orders. Tracking this linkage is essential for demonstrating regula' ;
    rdfs:domain ind:LfgMonitoring ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkOrder .

ind:monitoringEquipmentMaterialId rdf:type rdf:Property ;
    rdfs:label 'Monitoring Equipment Material Id' ;
    rdfs:comment 'Foreign key linking to procurement.material. Business justification: Landfill gas monitoring equipment (portable meters, sensors, calibration gases) are procured materials requiring tracking for calibration schedules, maintenance, replacement cycles, and regulatory com' ;
    rdfs:domain ind:LfgMonitoring ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Material .

ind:monitoringPointId rdf:type rdf:Property ;
    rdfs:label 'Monitoring Point Id' ;
    rdfs:comment 'Unique identifier for the specific monitoring point, probe, well, or perimeter location where the reading was taken. Examples include extraction well IDs, perimeter probe IDs, or interior monitoring point codes.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MonitoringPoint .

ind:carbonDioxideConcentrationPct rdf:type rdf:Property ;
    rdfs:label 'Carbon Dioxide Concentration Pct' ;
    rdfs:comment 'Carbon dioxide concentration measured as a percentage by volume at the monitoring point. Used to assess landfill gas composition and biological activity.' ;
    rdfs:domain ind:LfgMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carbonMonoxidePpm rdf:type rdf:Property ;
    rdfs:label 'Carbon Monoxide Ppm' ;
    rdfs:comment 'Carbon monoxide concentration measured in parts per million. Elevated CO levels may indicate incomplete combustion or subsurface smoldering.' ;
    rdfs:domain ind:LfgMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exceedanceType rdf:type rdf:Property ;
    rdfs:label 'Exceedance Type' ;
    rdfs:comment 'Classification of the type of regulatory or operational threshold that was exceeded during the monitoring event.' ;
    rdfs:domain ind:LfgMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lelPercentage rdf:type rdf:Property ;
    rdfs:label 'Lel Percentage' ;
    rdfs:comment 'Lower Explosive Limit reading expressed as a percentage. LEL measures the concentration of combustible gas relative to the minimum concentration required for ignition. Regulatory action is triggered when LEL exceeds 25%.' ;
    rdfs:domain ind:LfgMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lfgFlowRateScfm rdf:type rdf:Property ;
    rdfs:label 'Lfg Flow Rate Scfm' ;
    rdfs:comment 'Volumetric flow rate of landfill gas measured in standard cubic feet per minute at the monitoring point. Used to calculate total gas extraction and energy recovery potential.' ;
    rdfs:domain ind:LfgMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:monitoringPointType rdf:type rdf:Property ;
    rdfs:label 'Monitoring Point Type' ;
    rdfs:comment 'Classification of the monitoring point indicating its purpose and location within the landfill gas collection and monitoring system.' ;
    rdfs:domain ind:LfgMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nitrogenConcentrationPct rdf:type rdf:Property ;
    rdfs:label 'Nitrogen Concentration Pct' ;
    rdfs:comment 'Nitrogen concentration measured as a percentage by volume. Elevated nitrogen levels may indicate air intrusion or dilution of landfill gas.' ;
    rdfs:domain ind:LfgMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryReportFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Flag' ;
    rdfs:comment 'Boolean indicator that is set to True when this monitoring record must be included in mandatory regulatory reports to EPA, state agencies, or local enforcement authorities.' ;
    rdfs:domain ind:LfgMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:staticPressureInchesWc rdf:type rdf:Property ;
    rdfs:label 'Static Pressure Inches Wc' ;
    rdfs:comment 'Static pressure measured in inches of water column at the monitoring point. Indicates the vacuum or pressure within the landfill gas collection system.' ;
    rdfs:domain ind:LfgMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:linerIntegrityEventId rdf:type rdf:Property ;
    rdfs:label 'Liner Integrity Event Id' ;
    rdfs:comment 'Unique identifier for the liner integrity inspection or testing event. Primary key for this transactional record.' ;
    rdfs:domain ind:LinerIntegrityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:defectLocationCoordinates rdf:type rdf:Property ;
    rdfs:label 'Defect Location Coordinates' ;
    rdfs:comment 'Geographic or grid coordinates identifying the location of defects within the cell. May be GPS coordinates, station/offset measurements, or grid references per site survey system.' ;
    rdfs:domain ind:LinerIntegrityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectSizeDescription rdf:type rdf:Property ;
    rdfs:label 'Defect Size Description' ;
    rdfs:comment 'Description of the size and extent of identified defects, typically including dimensions (length, width, area) and severity classification.' ;
    rdfs:domain ind:LinerIntegrityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectType rdf:type rdf:Property ;
    rdfs:label 'Defect Type' ;
    rdfs:comment 'Classification of the type of defect identified in the liner system. Common types include punctures, tears, seam separations, wrinkles, stress cracks, holes, abrasion, and chemical degradation. [ENUM-REF-CANDIDATE: puncture|tear|seam_separation|wrinkle|stress_crack|hole|abrasion|chemical_degradation — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LinerIntegrityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectsIdentifiedCount rdf:type rdf:Property ;
    rdfs:label 'Defects Identified Count' ;
    rdfs:comment 'Total number of defects, anomalies, or integrity issues identified during the inspection. Zero indicates no defects found.' ;
    rdfs:domain ind:LinerIntegrityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inspectionAreaSquareFeet rdf:type rdf:Property ;
    rdfs:label 'Inspection Area Square Feet' ;
    rdfs:comment 'Total area of liner surface inspected during this event, measured in square feet. Used to calculate inspection coverage and defect density metrics.' ;
    rdfs:domain ind:LinerIntegrityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inspectionDurationHours rdf:type rdf:Property ;
    rdfs:label 'Inspection Duration Hours' ;
    rdfs:comment 'Total duration of the inspection activity in hours. Used for resource planning and cost allocation.' ;
    rdfs:domain ind:Landfill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inspectionReportReference rdf:type rdf:Property ;
    rdfs:label 'Inspection Report Reference' ;
    rdfs:comment 'Reference number or document identifier for the formal inspection report generated from this event. Links to document management system.' ;
    rdfs:domain ind:Landfill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linerLayerInspected rdf:type rdf:Property ;
    rdfs:label 'Liner Layer Inspected' ;
    rdfs:comment 'The specific liner layer or component that was inspected. Landfills typically have primary and secondary liner systems, which may be composite systems combining geomembranes, geosynthetic clay liners, and compacted clay.' ;
    rdfs:domain ind:LinerIntegrityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Permit Compliance Status' ;
    rdfs:comment 'Assessment of whether the inspection findings and any corrective actions meet the requirements of the sites RCRA Subtitle D permit and state permit conditions.' ;
    rdfs:domain ind:LinerIntegrityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postRepairVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Post Repair Verification Date' ;
    rdfs:comment 'Date on which the post-repair verification inspection was performed. Null if no verification was required or is pending.' ;
    rdfs:domain ind:LinerIntegrityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:postRepairVerificationResult rdf:type rdf:Property ;
    rdfs:label 'Post Repair Verification Result' ;
    rdfs:comment 'Result of the verification inspection performed after repair completion to confirm the repair was successful and liner integrity is restored. Not applicable if no repair was performed.' ;
    rdfs:domain ind:LinerIntegrityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repairActionTaken rdf:type rdf:Property ;
    rdfs:label 'Repair Action Taken' ;
    rdfs:comment 'Detailed description of the repair actions performed to address identified defects. Includes repair method, materials used, and extent of work.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repairContractor rdf:type rdf:Property ;
    rdfs:label 'Repair Contractor' ;
    rdfs:comment 'Name of the contractor or organization that performed the liner repair work. May be internal crew or external specialist contractor.' ;
    rdfs:domain ind:LinerIntegrityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repairCostAmount rdf:type rdf:Property ;
    rdfs:label 'Repair Cost Amount' ;
    rdfs:comment 'Total cost incurred for repair actions resulting from this inspection event. Null if no repair was required.' ;
    rdfs:domain ind:LinerIntegrityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:repairDate rdf:type rdf:Property ;
    rdfs:label 'Repair Date' ;
    rdfs:comment 'Date on which repair actions were completed. Null if no repair was required or repair is pending.' ;
    rdfs:domain ind:LinerIntegrityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:repairRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Repair Required Flag' ;
    rdfs:comment 'Boolean indicator of whether repair actions are required based on the inspection findings. True indicates repair is necessary; False indicates no repair needed.' ;
    rdfs:domain ind:LinerIntegrityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postClosureMonitoringId rdf:type rdf:Property ;
    rdfs:label 'Post Closure Monitoring Id' ;
    rdfs:comment 'Unique identifier for the post-closure monitoring activity record.' ;
    rdfs:domain ind:PostClosureMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:closureStatus rdf:type rdf:Property ;
    rdfs:label 'Closure Status' ;
    rdfs:comment 'Current closure status of the site or cell at the time of monitoring.' ;
    rdfs:domain ind:PostClosureMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costUsd rdf:type rdf:Property ;
    rdfs:label 'Cost Usd' ;
    rdfs:comment 'Total cost in US dollars for conducting this monitoring activity, including labor, equipment, and laboratory analysis.' ;
    rdfs:domain ind:PostClosureMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deficiencySeverity rdf:type rdf:Property ;
    rdfs:label 'Deficiency Severity' ;
    rdfs:comment 'Severity classification of identified deficiencies.' ;
    rdfs:domain ind:PostClosureMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingsSummary rdf:type rdf:Property ;
    rdfs:label 'Findings Summary' ;
    rdfs:comment 'Summary of observations and findings from the monitoring activity.' ;
    rdfs:domain ind:Landfill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labSampleCollectedFlag rdf:type rdf:Property ;
    rdfs:label 'Lab Sample Collected Flag' ;
    rdfs:comment 'Indicates whether laboratory samples were collected during this monitoring activity.' ;
    rdfs:domain ind:PostClosureMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maintenanceActionCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Maintenance Action Completed Date' ;
    rdfs:comment 'Date when required maintenance or corrective action was completed.' ;
    rdfs:domain ind:PostClosureMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maintenanceActionDescription rdf:type rdf:Property ;
    rdfs:label 'Maintenance Action Description' ;
    rdfs:comment 'Description of maintenance or corrective actions taken or planned in response to monitoring findings.' ;
    rdfs:domain ind:PostClosureMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceActionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Maintenance Action Required Flag' ;
    rdfs:comment 'Indicates whether maintenance or corrective action is required based on monitoring findings.' ;
    rdfs:domain ind:PostClosureMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:monitoringEquipmentUsed rdf:type rdf:Property ;
    rdfs:label 'Monitoring Equipment Used' ;
    rdfs:comment 'Description of equipment and instruments used during the monitoring activity.' ;
    rdfs:domain ind:PostClosureMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextMonitoringDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Monitoring Due Date' ;
    rdfs:comment 'Scheduled date for the next required monitoring activity based on regulatory frequency requirements.' ;
    rdfs:domain ind:PostClosureMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:postClosureCareYear rdf:type rdf:Property ;
    rdfs:label 'Post Closure Care Year' ;
    rdfs:comment 'Year number within the 30-year post-closure care period (1 through 30) as required by RCRA Subtitle D.' ;
    rdfs:domain ind:PostClosureMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reportSubmittedFlag rdf:type rdf:Property ;
    rdfs:label 'Report Submitted Flag' ;
    rdfs:comment 'Indicates whether monitoring results have been submitted to the regulatory agency.' ;
    rdfs:domain ind:PostClosureMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryInspectionId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Inspection Id' ;
    rdfs:comment 'Unique identifier for the regulatory inspection record. Primary key.' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:areasInspected rdf:type rdf:Property ;
    rdfs:label 'Areas Inspected' ;
    rdfs:comment 'Comma-separated list or detailed description of specific physical areas and operational zones inspected (e.g., active face, leachate treatment plant, gas collection wells, perimeter monitoring stations, equipment yard).' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cerclaRelevance rdf:type rdf:Property ;
    rdfs:label 'Cercla Relevance' ;
    rdfs:comment 'Boolean flag indicating whether this inspection has relevance to CERCLA (Superfund) obligations or potential liability (True) or not (False).' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:correctiveActionCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Completion Date' ;
    rdfs:comment 'Actual date on which all required corrective actions were completed and documented by the facility.' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enforcementActionTaken rdf:type rdf:Property ;
    rdfs:label 'Enforcement Action Taken' ;
    rdfs:comment 'Type of formal enforcement action taken by the regulatory agency as a result of the inspection findings (none, warning letter, notice of violation, consent order, or monetary penalty).' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityResponseDate rdf:type rdf:Property ;
    rdfs:label 'Facility Response Date' ;
    rdfs:comment 'Date on which the facility submitted its formal response or corrective action plan to the regulatory agency.' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:facilityResponseReference rdf:type rdf:Property ;
    rdfs:label 'Facility Response Reference' ;
    rdfs:comment 'Document reference number or file path to the facility\'s formal response, corrective action plan, or appeal submitted to the regulatory agency.' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Inspection Date' ;
    rdfs:comment 'Scheduled or actual date of the follow-up inspection conducted to verify corrective action implementation and compliance restoration.' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:followUpInspectionRequired rdf:type rdf:Property ;
    rdfs:label 'Follow Up Inspection Required' ;
    rdfs:comment 'Boolean flag indicating whether the regulatory agency has mandated a follow-up inspection to verify corrective action completion (True) or not (False).' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectingAgency rdf:type rdf:Property ;
    rdfs:label 'Inspecting Agency' ;
    rdfs:comment 'Name of the regulatory agency that conducted the inspection (e.g., EPA, state environmental quality department, Local Enforcement Agency).' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionClosureDate rdf:type rdf:Property ;
    rdfs:label 'Inspection Closure Date' ;
    rdfs:comment 'Date on which the inspection case was officially closed by the regulatory agency, indicating all corrective actions have been verified and compliance has been restored.' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rcraComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Rcra Compliance Status' ;
    rdfs:comment 'Overall RCRA Subtitle D compliance status determination resulting from the inspection (compliant, non-compliant, or conditional compliance with corrective action plan).' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryCitations rdf:type rdf:Property ;
    rdfs:label 'Regulatory Citations' ;
    rdfs:comment 'Specific regulatory code sections, permit conditions, or rule citations that were violated or referenced in the inspection findings (e.g., 40 CFR 258.28, state permit condition 4.2.1).' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleManager rdf:type rdf:Property ;
    rdfs:label 'Responsible Manager' ;
    rdfs:comment 'Name of the facility manager or compliance officer responsible for coordinating the inspection response and corrective action implementation.' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:swisSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Swis Submission Date' ;
    rdfs:comment 'Date on which the inspection data was submitted to the EPA Solid Waste Information System for regulatory reporting.' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:siteEnvianceFacilityId rdf:type rdf:Property ;
    rdfs:label 'Site Enviance Facility Id' ;
    rdfs:comment 'Facility identifier as configured in the Enviance EHS system, which is the system of record for environmental compliance, permit tracking, and incident management at this facility. Used for cross-system data integration and compliance record linkage.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:siteEpaFacilityId rdf:type rdf:Property ;
    rdfs:label 'Site Epa Facility Id' ;
    rdfs:comment 'EPA-assigned facility identifier used for federal environmental reporting, RCRA compliance tracking, and CERCLA/Superfund obligations. Format: two-letter state code followed by 10-digit numeric identifier.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:capSystemType rdf:type rdf:Property ;
    rdfs:label 'Cap System Type' ;
    rdfs:comment 'Type of final cover (cap) system installed or planned for the landfill. The cap is the final cover system placed over closed portions of the landfill to minimize infiltration and control LFG emissions. \'final_cap\' indicates permanent closure cap installed; \'interim_cap\' indicates temporary cover on inactive areas; \'none\' indicates active filling area; \'planned\' indicates cap design approved but not yet constructed.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cerclaStatus rdf:type rdf:Property ;
    rdfs:label 'Cercla Status' ;
    rdfs:comment 'Current CERCLA/Superfund status of the facility. Indicates whether the site is listed on the National Priorities List (NPL) or subject to CERCLA remedial action obligations. Drives legal liability accruals and environmental compliance reporting. [ENUM-REF-CANDIDATE: not_listed|npl_listed|remedial_investigation|remedial_action|completed|other — promote to reference product]' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classification rdf:type rdf:Property ;
    rdfs:label 'Classification' ;
    rdfs:comment 'Regulatory and operational classification of the landfill facility. MSW (Municipal Solid Waste) accepts household and commercial waste; C&D (Construction and Demolition) accepts construction debris; monofill accepts a single waste type; industrial accepts non-hazardous industrial waste; hazardous is a RCRA Subtitle C facility. Drives applicable regulatory framework and permitted waste streams.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:county rdf:type rdf:Property ;
    rdfs:label 'County' ;
    rdfs:comment 'County in which the landfill facility is located. Critical for determining applicable local solid waste authority jurisdiction, host community agreement obligations, and county-level regulatory reporting.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groundwaterMonitoringRequired rdf:type rdf:Property ;
    rdfs:label 'Groundwater Monitoring Required' ;
    rdfs:comment 'Indicates whether the facility is subject to groundwater monitoring requirements under RCRA Subtitle D or state permit conditions. Drives scheduling of monitoring well sampling events and Enviance EHS compliance tracking.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hostCommunityAgreementRef rdf:type rdf:Property ;
    rdfs:label 'Host Community Agreement Ref' ;
    rdfs:comment 'Reference number or document identifier for the host community agreement (HCA) between the facility operator and the local municipality. HCAs govern tipping fee sharing, traffic mitigation, odor controls, and community benefit obligations. Links to contract management records in Salesforce CRM.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaName rdf:type rdf:Property ;
    rdfs:label 'Lea Name' ;
    rdfs:comment 'Name of the Local Enforcement Agency (LEA) responsible for routine inspection and enforcement at the facility. In California and other states, LEAs are county-level agencies delegated enforcement authority by the state. Required for compliance contact management and inspection scheduling.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leachateManagementType rdf:type rdf:Property ;
    rdfs:label 'Leachate Management Type' ;
    rdfs:comment 'Type of leachate collection and management system installed at the facility. Leachate is the liquid that drains through the waste mass and must be managed to prevent groundwater contamination. Drives operational costs, permit conditions, and Clean Water Act (CWA) compliance obligations.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lfgCollectionSystem rdf:type rdf:Property ;
    rdfs:label 'Lfg Collection System' ;
    rdfs:comment 'Indicates whether an active landfill gas (LFG) collection and control system is installed at the facility. LFG systems capture methane for waste-to-energy (WTE) or renewable natural gas (RNG) conversion, and are required under EPA New Source Performance Standards (NSPS) for qualifying facilities. Drives Clean Air Act compliance and sustainability reporting.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lfgUtilizationType rdf:type rdf:Property ;
    rdfs:label 'Lfg Utilization Type' ;
    rdfs:comment 'Method by which captured landfill gas (LFG) is utilized or destroyed. \'flare_only\' indicates gas is combusted without energy recovery; \'electricity_generation\' indicates WTE power generation; \'RNG\' indicates renewable natural gas pipeline injection; \'direct_use\' indicates direct thermal use; \'none\' indicates no LFG system. Drives GHG emissions reporting and sustainability metrics.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringWellCount rdf:type rdf:Property ;
    rdfs:label 'Monitoring Well Count' ;
    rdfs:comment 'Total number of groundwater monitoring wells installed at the facility perimeter and downgradient locations as required by the facility permit. Used for compliance scheduling, sampling cost estimation, and permit condition verification.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:permitIssuedDate rdf:type rdf:Property ;
    rdfs:label 'Permit Issued Date' ;
    rdfs:comment 'Date on which the current operating permit was issued by the regulatory authority. Used to calculate permit duration, track renewal cycles, and support compliance audit documentation.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:permittedAcreage rdf:type rdf:Property ;
    rdfs:label 'Permitted Acreage' ;
    rdfs:comment 'Total land area in acres authorized under the current operating permit for waste disposal activities. Drives capacity planning, cell development scheduling, and permit boundary compliance monitoring.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:permittedDailyReceiptTons rdf:type rdf:Property ;
    rdfs:label 'Permitted Daily Receipt Tons' ;
    rdfs:comment 'Maximum tonnage per day (TPD) the facility is permitted to receive under its current operating permit. Operational throughput must not exceed this limit without permit modification. Used for daily tonnage monitoring and permit compliance alerts in Enviance EHS.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postClosureEndDate rdf:type rdf:Property ;
    rdfs:label 'Post Closure End Date' ;
    rdfs:comment 'Projected or actual date on which the mandatory post-closure care period ends (minimum 30 years after closure under RCRA Subtitle D). Used for long-range financial liability estimation and closure cost accrual under IFRS/GAAP.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rcraPermitNumber rdf:type rdf:Property ;
    rdfs:label 'Rcra Permit Number' ;
    rdfs:comment 'State-issued RCRA Subtitle D operating permit number authorizing the facility to receive and dispose of municipal solid waste (MSW) or other permitted waste streams. Required for regulatory compliance and annual permit renewal tracking.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapPlantCode rdf:type rdf:Property ;
    rdfs:label 'Sap Plant Code' ;
    rdfs:comment 'Four-character SAP S/4HANA plant code assigned to this landfill facility. Used for financial cost center assignment, materials management (MM), plant maintenance (PM), and EHS module integration. Enables cross-domain financial and operational reporting.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteCode rdf:type rdf:Property ;
    rdfs:label 'Site Code' ;
    rdfs:comment 'Internally assigned alphanumeric code uniquely identifying the landfill site across enterprise systems including SAP S/4HANA, Enviance EHS, and Infor EAM. Used as the cross-system business key.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardTippingFee rdf:type rdf:Property ;
    rdfs:label 'Standard Tipping Fee' ;
    rdfs:comment 'Standard gate rate charged per short ton for waste disposal at the facility (tipping fee). This is the base rate before contractual discounts or surcharges. Confidential commercial pricing data used in Oracle Revenue Management rate configuration and financial planning.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:swisRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Swis Registration Number' ;
    rdfs:comment 'State Solid Waste Information System (SWIS) registration number assigned by the state environmental agency. Used for EPA SWIS reporting submissions and state-level compliance tracking.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalDesignCapacityCy rdf:type rdf:Property ;
    rdfs:label 'Total Design Capacity Cy' ;
    rdfs:comment 'Total permitted airspace capacity of the landfill in cubic yards as approved in the facility design engineering report. Represents the maximum volume of waste and cover material the site is engineered and permitted to contain. Used for long-range capacity planning and permit compliance.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDesignCapacityTons rdf:type rdf:Property ;
    rdfs:label 'Total Design Capacity Tons' ;
    rdfs:comment 'Total permitted disposal capacity of the landfill in short tons as approved in the facility design engineering report. Complements cubic yard capacity for tonnage-based regulatory reporting and financial capacity valuation.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wasteStreamsAccepted rdf:type rdf:Property ;
    rdfs:label 'Waste Streams Accepted' ;
    rdfs:comment 'Comma-delimited list of waste stream types the facility is permitted to accept (e.g., \'MSW, C&D, industrial non-hazardous, special waste\'). Drives waste acceptance screening, manifest verification, and permit compliance. [ENUM-REF-CANDIDATE: MSW|C&D|industrial_non_hazardous|special_waste|ash|sludge|other — promote to reference product]' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialWasteApprovalId rdf:type rdf:Property ;
    rdfs:label 'Special Waste Approval Id' ;
    rdfs:comment 'Unique identifier for the special waste approval record. Primary key.' ;
    rdfs:domain ind:SpecialWasteApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Approving Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Special waste approvals are high-risk decisions requiring documented authority and audit trails. Linking to employee enables authorization verification, delegation tracking, and compliance with approv' ;
    rdfs:domain ind:SpecialWasteApproval ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:originatingOfferingId rdf:type rdf:Property ;
    rdfs:label 'Originating Offering Id' ;
    rdfs:comment 'Foreign key linking to service.offering. Business justification: Special waste approvals are triggered by specific service offerings requiring non-standard waste acceptance. Tracking the originating service offering is essential for approval workflow routing, prici' ;
    rdfs:domain ind:SpecialWasteApproval ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Offering .

ind:proposedDisposalCellId rdf:type rdf:Property ;
    rdfs:label 'Proposed Disposal Cell Id' ;
    rdfs:comment 'Reference to the specific landfill cell proposed for disposal of the special waste stream.' ;
    rdfs:domain ind:SpecialWasteApproval ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Cell .

ind:analyticalProfileReference rdf:type rdf:Property ;
    rdfs:label 'Analytical Profile Reference' ;
    rdfs:comment 'Reference number or identifier for the complete analytical profile and laboratory test results submitted with the approval request.' ;
    rdfs:domain ind:SpecialWasteApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalDecisionDate rdf:type rdf:Property ;
    rdfs:label 'Approval Decision Date' ;
    rdfs:comment 'Date when the final approval or rejection decision was made by the approving authority.' ;
    rdfs:domain ind:SpecialWasteApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvalDecisionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approval Decision Timestamp' ;
    rdfs:comment 'Precise timestamp when the approval or rejection decision was recorded in the system.' ;
    rdfs:domain ind:SpecialWasteApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:approvalExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Approval Expiration Date' ;
    rdfs:comment 'Date when the special waste approval expires and a new approval request must be submitted for continued disposal.' ;
    rdfs:domain ind:SpecialWasteApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvalRequestNumber rdf:type rdf:Property ;
    rdfs:label 'Approval Request Number' ;
    rdfs:comment 'Business identifier for the special waste approval request, used for tracking and reference in communications with customers and regulatory agencies.' ;
    rdfs:domain ind:SpecialWasteApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedDisposalConditions rdf:type rdf:Property ;
    rdfs:label 'Approved Disposal Conditions' ;
    rdfs:comment 'Specific conditions, restrictions, or requirements that must be met for disposal of the approved special waste stream, such as placement requirements, cover specifications, or monitoring protocols.' ;
    rdfs:domain ind:SpecialWasteApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedTonnageLimit rdf:type rdf:Property ;
    rdfs:label 'Approved Tonnage Limit' ;
    rdfs:comment 'Maximum tonnage of the special waste stream approved for disposal under this approval, measured in tons.' ;
    rdfs:domain ind:SpecialWasteApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalReviewRequired rdf:type rdf:Property ;
    rdfs:label 'Environmental Review Required' ;
    rdfs:comment 'Indicates whether an additional environmental impact review or assessment is required before final approval can be granted.' ;
    rdfs:domain ind:SpecialWasteApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedVolumeTons rdf:type rdf:Property ;
    rdfs:label 'Estimated Volume Tons' ;
    rdfs:comment 'Estimated total weight of the special waste stream proposed for disposal, measured in tons.' ;
    rdfs:domain ind:SpecialWasteApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:labName rdf:type rdf:Property ;
    rdfs:label 'Lab Name' ;
    rdfs:comment 'Name of the certified laboratory that performed the waste characterization analysis.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rcraWasteCode rdf:type rdf:Property ;
    rdfs:label 'Rcra Waste Code' ;
    rdfs:comment 'RCRA waste code(s) assigned to the special waste stream if applicable, indicating specific regulatory requirements.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryNotificationRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Required' ;
    rdfs:comment 'Indicates whether the approval decision must be reported to state or federal regulatory agencies.' ;
    rdfs:domain ind:SpecialWasteApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requestDate rdf:type rdf:Property ;
    rdfs:label 'Request Date' ;
    rdfs:comment 'Date when the special waste approval request was submitted for review.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestTimestamp rdf:type rdf:Property ;
    rdfs:label 'Request Timestamp' ;
    rdfs:comment 'Precise timestamp when the special waste approval request was received in the system.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:tclpResultsAvailable rdf:type rdf:Property ;
    rdfs:label 'Tclp Results Available' ;
    rdfs:comment 'Indicates whether TCLP analytical test results have been provided as part of the waste characterization data.' ;
    rdfs:domain ind:SpecialWasteApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:wasteClassification rdf:type rdf:Property ;
    rdfs:label 'Waste Classification' ;
    rdfs:comment 'Regulatory classification of the special waste stream based on RCRA Subtitle D criteria and state-specific waste acceptance standards.' ;
    rdfs:domain ind:SpecialWasteApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteOriginAddress rdf:type rdf:Property ;
    rdfs:label 'Waste Origin Address' ;
    rdfs:comment 'Physical address of the facility or location where the special waste was generated.' ;
    rdfs:domain ind:SpecialWasteApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteOriginCity rdf:type rdf:Property ;
    rdfs:label 'Waste Origin City' ;
    rdfs:comment 'City where the special waste was generated.' ;
    rdfs:domain ind:SpecialWasteApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteOriginDescription rdf:type rdf:Property ;
    rdfs:label 'Waste Origin Description' ;
    rdfs:comment 'Description of the industrial process, facility, or activity that generated the special waste stream.' ;
    rdfs:domain ind:SpecialWasteApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteOriginPostalCode rdf:type rdf:Property ;
    rdfs:label 'Waste Origin Postal Code' ;
    rdfs:comment 'Postal code of the location where the special waste was generated.' ;
    rdfs:domain ind:SpecialWasteApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteOriginStateCode rdf:type rdf:Property ;
    rdfs:label 'Waste Origin State Code' ;
    rdfs:comment 'Two-letter state code where the special waste was generated.' ;
    rdfs:domain ind:SpecialWasteApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stormwaterEventId rdf:type rdf:Property ;
    rdfs:label 'Stormwater Event Id' ;
    rdfs:comment 'Unique identifier for the stormwater management event record.' ;
    rdfs:domain ind:StormwaterEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:outfallId rdf:type rdf:Property ;
    rdfs:label 'Outfall Id' ;
    rdfs:comment 'Identifier for the discharge point where stormwater exits the landfill site, as designated in the NPDES (National Pollutant Discharge Elimination System) permit.' ;
    rdfs:domain ind:Landfill ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Outfall .

ind:bmpDeficiencies rdf:type rdf:Property ;
    rdfs:label 'Bmp Deficiencies' ;
    rdfs:comment 'Detailed description of any deficiencies or maintenance needs identified during BMP inspection, such as erosion, sediment accumulation, damaged controls, or inadequate coverage.' ;
    rdfs:domain ind:StormwaterEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bmpInspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Bmp Inspection Status' ;
    rdfs:comment 'Assessment result of the BMP inspection. Satisfactory indicates controls are functioning as designed, needs maintenance indicates minor repairs required, deficient indicates significant issues requiring prompt attention, and failed indicates BMP is not functioning and requires immediate corrective action.' ;
    rdfs:domain ind:StormwaterEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:copperMgL rdf:type rdf:Property ;
    rdfs:label 'Copper Mg L' ;
    rdfs:comment 'Concentration of copper in the stormwater discharge, measured in milligrams per liter. Copper is a regulated heavy metal that can be toxic to aquatic life.' ;
    rdfs:domain ind:StormwaterEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:correctiveActionDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Date' ;
    rdfs:comment 'Date when corrective actions were completed to address permit exceedances or BMP deficiencies.' ;
    rdfs:domain ind:StormwaterEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dischargeFlowRateGpm rdf:type rdf:Property ;
    rdfs:label 'Discharge Flow Rate Gpm' ;
    rdfs:comment 'Rate of stormwater discharge measured in gallons per minute at the time of monitoring.' ;
    rdfs:domain ind:StormwaterEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dischargeVolumeGallons rdf:type rdf:Property ;
    rdfs:label 'Discharge Volume Gallons' ;
    rdfs:comment 'Total volume of stormwater discharged from the outfall during the event, measured in gallons.' ;
    rdfs:domain ind:StormwaterEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eventStatus rdf:type rdf:Property ;
    rdfs:label 'Event Status' ;
    rdfs:comment 'Current lifecycle status of the stormwater event record in the compliance workflow.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectorCertification rdf:type rdf:Property ;
    rdfs:label 'Inspector Certification' ;
    rdfs:comment 'Professional certification or qualification held by the inspector, such as Certified Professional in Erosion and Sediment Control (CPESC) or Qualified Stormwater Manager (QSM).' ;
    rdfs:domain ind:StormwaterEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadMgL rdf:type rdf:Property ;
    rdfs:label 'Lead Mg L' ;
    rdfs:comment 'Concentration of lead in the stormwater discharge, measured in milligrams per liter. Lead is a toxic heavy metal regulated under NPDES permits.' ;
    rdfs:domain ind:StormwaterEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oilGreaseMgL rdf:type rdf:Property ;
    rdfs:label 'Oil Grease Mg L' ;
    rdfs:comment 'Concentration of oil and grease in the stormwater discharge, measured in milligrams per liter. Indicates petroleum-based contamination from vehicles and equipment.' ;
    rdfs:domain ind:StormwaterEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:permitLimitPhMax rdf:type rdf:Property ;
    rdfs:label 'Permit Limit Ph Max' ;
    rdfs:comment 'Maximum allowable pH level specified in the NPDES permit for this outfall.' ;
    rdfs:domain ind:StormwaterEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:permitLimitPhMin rdf:type rdf:Property ;
    rdfs:label 'Permit Limit Ph Min' ;
    rdfs:comment 'Minimum allowable pH level specified in the NPDES permit for this outfall.' ;
    rdfs:domain ind:StormwaterEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:permitLimitTssMgL rdf:type rdf:Property ;
    rdfs:label 'Permit Limit Tss Mg L' ;
    rdfs:comment 'Maximum allowable concentration of total suspended solids specified in the NPDES permit for this outfall.' ;
    rdfs:domain ind:StormwaterEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:precipitationAmountInches rdf:type rdf:Property ;
    rdfs:label 'Precipitation Amount Inches' ;
    rdfs:comment 'Total rainfall measured in inches during the monitoring period or prior to the discharge event, used to assess stormwater runoff volume and pollutant loading.' ;
    rdfs:domain ind:StormwaterEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalNitrogenMgL rdf:type rdf:Property ;
    rdfs:label 'Total Nitrogen Mg L' ;
    rdfs:comment 'Total nitrogen concentration in the stormwater discharge, measured in milligrams per liter. Nitrogen is a nutrient pollutant that can cause eutrophication in receiving waters.' ;
    rdfs:domain ind:StormwaterEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPhosphorusMgL rdf:type rdf:Property ;
    rdfs:label 'Total Phosphorus Mg L' ;
    rdfs:comment 'Total phosphorus concentration in the stormwater discharge, measured in milligrams per liter. Phosphorus is a nutrient pollutant that contributes to algal blooms and water quality degradation.' ;
    rdfs:domain ind:StormwaterEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tssMgL rdf:type rdf:Property ;
    rdfs:label 'Tss Mg L' ;
    rdfs:comment 'Concentration of total suspended solids in the stormwater discharge, measured in milligrams per liter. TSS is a key indicator of sediment and particulate pollution.' ;
    rdfs:domain ind:StormwaterEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:zincMgL rdf:type rdf:Property ;
    rdfs:label 'Zinc Mg L' ;
    rdfs:comment 'Concentration of zinc in the stormwater discharge, measured in milligrams per liter. Zinc is a regulated heavy metal commonly found in stormwater runoff.' ;
    rdfs:domain ind:StormwaterEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tonnageReceiptId rdf:type rdf:Property ;
    rdfs:label 'Tonnage Receipt Id' ;
    rdfs:comment 'Unique identifier for the tonnage receipt transaction. Primary key for the tonnage receipt record.' ;
    rdfs:domain ind:TonnageReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:collectionRouteExecutionId rdf:type rdf:Property ;
    rdfs:label 'Collection Route Execution Id' ;
    rdfs:comment 'Foreign key linking to collection.route_execution. Business justification: Landfill tonnage receipts from direct collection routes (not transfer station hauls) need route execution reference for proof-of-service, billing reconciliation, and route-to-disposal tracking. Core d' ;
    rdfs:domain ind:TonnageReceipt ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RouteExecution .

ind:collectionWeightTicketId rdf:type rdf:Property ;
    rdfs:label 'Collection Weight Ticket Id' ;
    rdfs:comment 'Foreign key linking to collection.weight_ticket. Business justification: Landfill tonnage receipts should reference originating collection weight tickets for end-to-end waste tracking, weight reconciliation, and audit trail from collection through disposal. Core collection' ;
    rdfs:domain ind:TonnageReceipt ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WeightTicket .

ind:tonnageLandfillSiteId rdf:type rdf:Property ;
    rdfs:label 'Tonnage Landfill Site Id' ;
    rdfs:comment 'Identifier of the landfill facility where this tonnage receipt was recorded. Supports multi-site operations and reporting.' ;
    rdfs:domain ind:TonnageReceipt ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Site .

ind:tonnageSiteId rdf:type rdf:Property ;
    rdfs:label 'Tonnage Site Id' ;
    rdfs:comment 'FK to landfill.site.site_id — Every tonnage receipt must reference which landfill site received the waste. Core to airspace consumption tracking and revenue reporting by site.' ;
    rdfs:domain ind:TonnageReceipt ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Site .

ind:contaminationNotes rdf:type rdf:Property ;
    rdfs:label 'Contamination Notes' ;
    rdfs:comment 'Detailed notes describing any contamination, prohibited materials, or acceptance criteria violations observed during load inspection.' ;
    rdfs:domain ind:TonnageReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inboundScaleTime rdf:type rdf:Property ;
    rdfs:label 'Inbound Scale Time' ;
    rdfs:comment 'Timestamp when the loaded vehicle was weighed on the inbound scale.' ;
    rdfs:domain ind:TonnageReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:loadInspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Load Inspection Status' ;
    rdfs:comment 'Status of visual or detailed inspection performed on the waste load at the scale house to verify compliance with acceptance criteria.' ;
    rdfs:domain ind:TonnageReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadRejectedFlag rdf:type rdf:Property ;
    rdfs:label 'Load Rejected Flag' ;
    rdfs:comment 'Boolean indicator of whether the waste load was rejected and not accepted for disposal at the landfill.' ;
    rdfs:domain ind:TonnageReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netTonnage rdf:type rdf:Property ;
    rdfs:label 'Net Tonnage' ;
    rdfs:comment 'Calculated net weight of waste material in tons (gross weight minus tare weight). Primary measure for TPD (Tons Per Day) reporting and tipping fee calculation.' ;
    rdfs:domain ind:TonnageReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outboundScaleTime rdf:type rdf:Property ;
    rdfs:label 'Outbound Scale Time' ;
    rdfs:comment 'Timestamp when the empty vehicle was weighed on the outbound scale after waste disposal.' ;
    rdfs:domain ind:TonnageReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:specialHandlingCode rdf:type rdf:Property ;
    rdfs:label 'Special Handling Code' ;
    rdfs:comment 'Code indicating any special handling requirements for this waste load (e.g., asbestos protocols, odor control, immediate cover).' ;
    rdfs:domain ind:TonnageReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteOriginType rdf:type rdf:Property ;
    rdfs:label 'Waste Origin Type' ;
    rdfs:comment 'Classification of the source from which the waste load originated (collection route, transfer station, direct customer haul, etc.).' ;
    rdfs:domain ind:TonnageReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bulletinComplianceId rdf:type rdf:Property ;
    rdfs:label 'Bulletin Compliance Id' ;
    rdfs:comment 'Unique surrogate identifier for each bulletin compliance tracking record in the Waste Management fleet and facility asset compliance system.' ;
    rdfs:domain ind:BulletinCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceBulletinId rdf:type rdf:Property ;
    rdfs:label 'Service Bulletin Id' ;
    rdfs:comment 'Foreign key linking to maintenance.service_bulletin. Business justification: Each bulletin_compliance record tracks compliance status for a specific service bulletin. Currently has bulletin_number (STRING) and duplicates bulletin master data. Adding FK enables JOIN to service_' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceBulletin .

ind:actualLaborHours rdf:type rdf:Property ;
    rdfs:label 'Actual Labor Hours' ;
    rdfs:comment 'Actual number of technician labor hours expended to complete the bulletin compliance corrective action. Compared against estimated_labor_hours for maintenance efficiency analysis and future bulletin cost estimation.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:affectedComponent rdf:type rdf:Property ;
    rdfs:label 'Affected Component' ;
    rdfs:comment 'The specific vehicle or equipment component addressed by the service bulletin or recall (e.g., \'Hydraulic Lift System\', \'CNG Fuel Line\', \'Brake Actuator\', \'Packer Body\'). Used for maintenance planning and parts procurement.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Compliance Deadline Date' ;
    rdfs:comment 'The mandatory or recommended deadline by which the bulletin compliance action must be completed for this asset. Drives prioritization in fleet-wide recall compliance reporting and regulatory audit readiness.' ;
    rdfs:domain ind:BulletinCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dotInspectionRequired rdf:type rdf:Property ;
    rdfs:label 'Dot Inspection Required' ;
    rdfs:comment 'Indicates whether completion of this bulletin compliance action requires a formal DOT inspection or re-inspection of the asset before it can return to service. True = DOT inspection mandatory post-completion.' ;
    rdfs:domain ind:BulletinCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedLaborHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Labor Hours' ;
    rdfs:comment 'Estimated number of technician labor hours required to complete the bulletin compliance corrective action. Used for workforce planning, work order scheduling, and maintenance cost estimation.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:notApplicableReason rdf:type rdf:Property ;
    rdfs:label 'Not Applicable Reason' ;
    rdfs:comment 'Documented reason why the service bulletin or recall does not apply to this specific asset (e.g., \'Different engine configuration\', \'Component not installed\', \'Asset retired before bulletin issue date\'). Required when compliance_status is \'not_applicable\' for audit defensibility.' ;
    rdfs:domain ind:BulletinCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outOfServiceRequired rdf:type rdf:Property ;
    rdfs:label 'Out Of Service Required' ;
    rdfs:comment 'Indicates whether the asset must be taken out of service immediately pending completion of the bulletin compliance action. True = asset must not be operated until compliance is achieved. Drives fleet availability and route planning impacts.' ;
    rdfs:domain ind:BulletinCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:partsAvailabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Parts Availability Status' ;
    rdfs:comment 'Current availability status of the parts required to complete the bulletin compliance action. Drives scheduling decisions when parts_required_flag is True. \'backordered\' status may justify compliance deadline extension requests.' ;
    rdfs:domain ind:BulletinCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partsRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Parts Required Flag' ;
    rdfs:comment 'Indicates whether replacement parts are required to complete the bulletin compliance action. True = parts must be procured before work can be scheduled. Drives parts inventory and procurement planning in Infor EAM.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduledCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Completion Date' ;
    rdfs:comment 'The planned date on which the bulletin compliance work is scheduled to be performed for this asset. Populated when compliance_status transitions to \'scheduled\' or \'in_progress\'.' ;
    rdfs:domain ind:BulletinCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:technicianNotes rdf:type rdf:Property ;
    rdfs:label 'Technician Notes' ;
    rdfs:comment 'Free-text notes entered by the technician during or after performing the bulletin compliance work. May include observations about asset condition, deviations from bulletin instructions, or additional defects found during the repair.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Verification Timestamp' ;
    rdfs:comment 'Date and time when the completed bulletin compliance work was formally verified and signed off by the authorized verifier. Provides audit-grade timestamp for regulatory compliance records.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:waiverFlag rdf:type rdf:Property ;
    rdfs:label 'Waiver Flag' ;
    rdfs:comment 'Indicates whether a formal waiver has been granted for this asset\'s compliance with the service bulletin or recall. True = waiver approved; waiver_justification must be populated. Waivers require documented approval per regulatory audit requirements.' ;
    rdfs:domain ind:BulletinCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waiverJustification rdf:type rdf:Property ;
    rdfs:label 'Waiver Justification' ;
    rdfs:comment 'Documented business or technical justification for waiving compliance with the service bulletin or recall for this asset (e.g., \'Asset scheduled for retirement within 30 days\', \'Component not installed on this configuration\'). Required when waiver_flag is True for regulatory audit readiness.' ;
    rdfs:domain ind:BulletinCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyCovered rdf:type rdf:Property ;
    rdfs:label 'Warranty Covered' ;
    rdfs:comment 'Indicates whether the bulletin compliance corrective action is covered under the manufacturer\'s warranty or recall program, meaning costs will be reimbursed by the OEM. True = OEM warranty/recall reimbursement applicable.' ;
    rdfs:domain ind:BulletinCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:downtimeEventId rdf:type rdf:Property ;
    rdfs:label 'Downtime Event Id' ;
    rdfs:comment 'Unique system-generated identifier for each discrete asset downtime event record in the maintenance domain.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:failureModeId rdf:type rdf:Property ;
    rdfs:label 'Failure Mode Id' ;
    rdfs:comment 'Foreign key linking to maintenance.failure_mode. Business justification: Downtime events are caused by specific failure modes. Currently has failure_mode (STRING) and failure_cause (STRING) which should reference the standardized failure_mode catalog for consistent root ca' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FailureMode .

ind:nearMissId rdf:type rdf:Property ;
    rdfs:label 'Near Miss Id' ;
    rdfs:comment 'Foreign key linking to safety.near_miss. Business justification: Downtime events may be preceded by near-miss incidents (equipment malfunction almost causing injury). Real business process: leading indicator tracking for predictive safety management. Waste Manageme' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NearMiss .

ind:primaryDowntimeEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Downtime Employee Id' ;
    rdfs:comment 'Reference to the maintenance technician or mechanic assigned to resolve the downtime event. Links to the workforce/employee record.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:serviceOfferingId rdf:type rdf:Property ;
    rdfs:label 'Service Offering Id' ;
    rdfs:comment 'Foreign key linking to service.offering. Business justification: Service equipment downtime (compactor failure, container damage) is tracked against service offerings for SLA compliance, customer credits, and service quality metrics. Real WM operations require link' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Offering .

ind:assetIdentifier rdf:type rdf:Property ;
    rdfs:label 'Asset Identifier' ;
    rdfs:comment 'Human-readable asset tag, vehicle unit number, or equipment identifier as registered in the fleet management system (e.g., truck unit number, equipment tag). Used for operational cross-referencing with Geotab telematics and AMCS dispatch.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dotInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Dot Inspection Date' ;
    rdfs:comment 'Date on which the DOT inspection was completed for this downtime event. Populated only when is_dot_inspection_required is True. Required for regulatory compliance documentation.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dotInspectionResult rdf:type rdf:Property ;
    rdfs:label 'Dot Inspection Result' ;
    rdfs:comment 'Outcome of the DOT inspection conducted during or following the downtime event: passed (vehicle cleared for service), failed (vehicle requires additional repairs before service), conditional_pass (vehicle approved with restrictions), not_applicable (no DOT inspection required).' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downtimeCategory rdf:type rdf:Property ;
    rdfs:label 'Downtime Category' ;
    rdfs:comment 'Primary classification of the downtime event type: planned_pm (scheduled Preventive Maintenance cycle), unplanned_breakdown (unexpected mechanical or operational failure), awaiting_parts (asset idle pending parts availability from BOM/inventory), awaiting_technician (asset idle pending technician assignment), dot_hold (asset placed out-of-service pending Department of Transportation (DOT) inspection or compliance resolution).' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downtimeDurationHours rdf:type rdf:Property ;
    rdfs:label 'Downtime Duration Hours' ;
    rdfs:comment 'Total elapsed time in hours that the asset was unavailable for service, calculated as the difference between downtime_end_timestamp and downtime_start_timestamp. Populated upon event closure. Critical for fleet availability KPI and Mean Time to Repair (MTTR) calculations.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:downtimeEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Downtime End Timestamp' ;
    rdfs:comment 'The exact date and time when the asset was returned to service and the downtime event was closed. Null if the asset is still unavailable.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:downtimeStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Downtime Start Timestamp' ;
    rdfs:comment 'The exact date and time when the asset became unavailable for service, marking the beginning of the downtime event. This is the principal real-world event time used for duration calculations and KPI reporting.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:downtimeStatus rdf:type rdf:Property ;
    rdfs:label 'Downtime Status' ;
    rdfs:comment 'Current lifecycle status of the downtime event: open (event recorded, work not yet started), in_progress (maintenance actively underway), resolved (repair complete, asset returned to service), closed (event fully documented and closed in CMMS), cancelled (event voided, e.g., duplicate entry).' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDotInspectionRequired rdf:type rdf:Property ;
    rdfs:label 'Is Dot Inspection Required' ;
    rdfs:comment 'Indicates whether a Department of Transportation (DOT) inspection is required before the asset can be returned to service. True when downtime_category is dot_hold or when a safety-critical failure is identified. Supports DOT FMCSR compliance tracking.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRepeatFailure rdf:type rdf:Property ;
    rdfs:label 'Is Repeat Failure' ;
    rdfs:comment 'Indicates whether this downtime event represents a recurrence of the same failure mode on the same asset within a defined lookback period (typically 90 days). True signals a chronic reliability issue requiring escalated investigation or asset replacement consideration.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laborCost rdf:type rdf:Property ;
    rdfs:label 'Labor Cost' ;
    rdfs:comment 'Total labor cost in USD incurred for technician time associated with this downtime event, including regular and overtime rates. Sourced from Infor EAM labor records and Workday HCM payroll rates.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lostRevenueEstimate rdf:type rdf:Property ;
    rdfs:label 'Lost Revenue Estimate' ;
    rdfs:comment 'Estimated revenue in USD lost due to service disruptions caused by this downtime event, based on affected stops and applicable service rates. Used for operational impact financial assessment and ROI analysis of maintenance investments.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operationalImpactType rdf:type rdf:Property ;
    rdfs:label 'Operational Impact Type' ;
    rdfs:comment 'Classification of the operational impact caused by the downtime event on waste collection or facility operations: route_cancellation (entire route not serviced), route_delay (route completed late), service_disruption (partial or degraded service), partial_service (some stops serviced by alternate vehicle), no_impact (downtime absorbed without service effect).' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partsCost rdf:type rdf:Property ;
    rdfs:label 'Parts Cost' ;
    rdfs:comment 'Total cost in USD of parts and materials consumed during the repair or maintenance activity associated with this downtime event. Sourced from Infor EAM parts inventory and SAP MM purchase orders.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partsWaitHours rdf:type rdf:Property ;
    rdfs:label 'Parts Wait Hours' ;
    rdfs:comment 'Total hours the asset was idle specifically waiting for parts or materials to become available from inventory or procurement. Supports parts inventory optimization and supply chain analysis.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:repairTimeHours rdf:type rdf:Property ;
    rdfs:label 'Repair Time Hours' ;
    rdfs:comment 'Actual hands-on repair or maintenance labor time in hours, excluding waiting time for parts or technician. Used to calculate Mean Time to Repair (MTTR) and labor efficiency metrics.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responseTimeHours rdf:type rdf:Property ;
    rdfs:label 'Response Time Hours' ;
    rdfs:comment 'Elapsed time in hours between the reported_timestamp and the time a technician began active work on the asset. Key KPI for maintenance responsiveness and SLA compliance measurement.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stopsAffectedCount rdf:type rdf:Property ;
    rdfs:label 'Stops Affected Count' ;
    rdfs:comment 'Number of customer service stops that were not completed or were disrupted as a direct result of this downtime event. Used to quantify customer impact and SLA compliance reporting.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalDowntimeCost rdf:type rdf:Property ;
    rdfs:label 'Total Downtime Cost' ;
    rdfs:comment 'Total financial cost in USD attributable to this downtime event, encompassing labor cost, parts cost, and any additional costs such as rental equipment or contractor fees. Used for cost of downtime analysis and EBITDA impact assessment.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:facilityMaintenanceRequestId rdf:type rdf:Property ;
    rdfs:label 'Facility Maintenance Request Id' ;
    rdfs:comment 'Unique surrogate identifier for the facility maintenance request record in the lakehouse silver layer. Primary key for this entity.' ;
    rdfs:domain ind:FacilityMaintenanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentRequestFacilityMaintenanceRequestId rdf:type rdf:Property ;
    rdfs:label 'Parent Request Facility Maintenance Request Id' ;
    rdfs:comment 'Reference to a parent facility maintenance request when this request is a follow-up, sub-task, or related recurrence of a prior request. Enables request lineage tracking and recurring issue analysis.' ;
    rdfs:domain ind:FacilityMaintenanceRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FacilityMaintenanceRequest .

ind:primaryFacilityEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Facility Employee Id' ;
    rdfs:comment 'Reference to the employee who submitted the maintenance request. Used for accountability, communication, and follow-up notifications. Sourced from Workday HCM employee master.' ;
    rdfs:domain ind:FacilityMaintenanceRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:approvedCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Approved Completion Date' ;
    rdfs:comment 'Date confirmed by the maintenance supervisor or planner as the target completion date after reviewing resource availability and priority. May differ from the requestor\'s requested completion date. Drives SLA compliance measurement.' ;
    rdfs:domain ind:FacilityMaintenanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:confinedSpaceFlag rdf:type rdf:Property ;
    rdfs:label 'Confined Space Flag' ;
    rdfs:comment 'Indicates whether the maintenance work requires entry into a permit-required confined space (e.g., leachate collection vault, underground utility vault, tank). Triggers confined space entry permit workflow per OSHA standards.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:downtimeExpectedFlag rdf:type rdf:Property ;
    rdfs:label 'Downtime Expected Flag' ;
    rdfs:comment 'Indicates whether the maintenance work is expected to require taking the affected asset or facility area out of service (downtime). Used for operational planning, production scheduling, and capacity impact assessment.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:environmentalImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Environmental Impact Flag' ;
    rdfs:comment 'Indicates whether the maintenance issue has potential environmental impact such as leachate containment breach, LFG leak, chemical spill, or stormwater system failure. When true, triggers Enviance EHS notification and EPA/state regulatory reporting workflow.' ;
    rdfs:domain ind:FacilityMaintenanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedDowntimeHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Downtime Hours' ;
    rdfs:comment 'Estimated number of hours the affected asset or facility area will be out of service to complete the maintenance work. Used for operational impact planning and throughput loss estimation. Populated when downtime_expected_flag is true.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:locationWithinFacility rdf:type rdf:Property ;
    rdfs:label 'Location Within Facility' ;
    rdfs:comment 'Specific area, zone, building section, floor, room, or equipment bay within the facility where the maintenance issue is located (e.g., \'Tipping Floor Bay 2\', \'Compactor Room\', \'Cell 4 Leachate Pump Station\'). Enables precise technician dispatch.' ;
    rdfs:domain ind:FacilityMaintenanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lotoRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Loto Required Flag' ;
    rdfs:comment 'Indicates whether Lockout/Tagout (LOTO) energy isolation procedures are required to safely perform the maintenance work. When true, LOTO permit must be issued before WO execution. Critical for OSHA compliance.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:problemDescription rdf:type rdf:Property ;
    rdfs:label 'Problem Description' ;
    rdfs:comment 'Free-text narrative provided by the requestor describing the maintenance issue, observed symptoms, and any relevant context (e.g., \'Conveyor belt on tipping floor making grinding noise and slipping under load since Monday morning\'). Primary input for WO creation.' ;
    rdfs:domain ind:FacilityMaintenanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recurrenceFlag rdf:type rdf:Property ;
    rdfs:label 'Recurrence Flag' ;
    rdfs:comment 'Indicates whether this maintenance request represents a recurring issue that has been reported previously for the same asset or location. When true, triggers root cause analysis workflow and may escalate priority. Supports reliability improvement programs.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requestType rdf:type rdf:Property ;
    rdfs:label 'Request Type' ;
    rdfs:comment 'Classification of the maintenance request by nature of need. Corrective addresses existing failures; preventive is scheduled upkeep; emergency requires immediate response; safety and environmental types trigger regulatory notification workflows. [ENUM-REF-CANDIDATE: corrective|preventive|emergency|inspection|safety|environmental|capital_improvement — promote to reference product]' ;
    rdfs:domain ind:FacilityMaintenanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Requested Completion Date' ;
    rdfs:comment 'Date by which the requestor needs the maintenance work to be completed, based on operational or regulatory requirements. Used as input to WO scheduling and SLA target-setting. May differ from the approved scheduled completion date.' ;
    rdfs:domain ind:FacilityMaintenanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestorDepartment rdf:type rdf:Property ;
    rdfs:label 'Requestor Department' ;
    rdfs:comment 'Organizational department or business unit of the employee who submitted the request (e.g., Landfill Operations, Fleet Maintenance, Environmental Compliance). Used for cost allocation and reporting.' ;
    rdfs:domain ind:FacilityMaintenanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestorName rdf:type rdf:Property ;
    rdfs:label 'Requestor Name' ;
    rdfs:comment 'Full name of the employee who submitted the maintenance request, captured at time of submission for historical reference even if the employee record changes. Stored as a denormalized snapshot.' ;
    rdfs:domain ind:FacilityMaintenanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestorPhone rdf:type rdf:Property ;
    rdfs:label 'Requestor Phone' ;
    rdfs:comment 'Phone number of the requestor for follow-up communication regarding the maintenance request status or clarification of problem details.' ;
    rdfs:domain ind:FacilityMaintenanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyHazardFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Hazard Flag' ;
    rdfs:comment 'Indicates whether the reported maintenance issue presents an immediate or potential safety hazard to personnel or the public. When true, triggers expedited review and OSHA notification workflow per safety management protocols.' ;
    rdfs:domain ind:FacilityMaintenanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceRequestReference rdf:type rdf:Property ;
    rdfs:label 'Source Request Reference' ;
    rdfs:comment 'Native identifier of this maintenance request in the originating source system (e.g., Infor EAM service request ID, SAP PM notification number). Enables cross-system traceability and reconciliation.' ;
    rdfs:domain ind:FacilityMaintenanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:urgencyLevel rdf:type rdf:Property ;
    rdfs:label 'Urgency Level' ;
    rdfs:comment 'Requestor-assigned urgency classification indicating the business impact and speed of response required. Critical indicates immediate safety or operational risk; high indicates same-day response needed; medium and low allow scheduled response. Drives SLA target assignment.' ;
    rdfs:domain ind:FacilityMaintenanceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableVehicleTypes rdf:type rdf:Property ;
    rdfs:label 'Applicable Vehicle Types' ;
    rdfs:comment 'Comma-delimited list of vehicle or equipment types to which this failure mode applies (e.g., \'ASL, FEL, REL, CNG Truck, Roll-Off, Transfer Trailer\'). Restricts failure code availability in work order entry to relevant asset types, reducing misclassification. Null if applicable to all asset types.' ;
    rdfs:domain ind:FailureMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentSystem rdf:type rdf:Property ;
    rdfs:label 'Component System' ;
    rdfs:comment 'The primary vehicle or facility component system affected by this failure mode (e.g., \'Engine\', \'Transmission\', \'Hydraulic Lift System\', \'Braking System\', \'Electrical System\', \'Compactor Body\', \'Chassis\'). Aligns with VMRS system codes for fleet assets and EAM component hierarchy for facility assets.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionMethod rdf:type rdf:Property ;
    rdfs:label 'Detection Method' ;
    rdfs:comment 'Standard method by which this failure mode is typically detected. Informs PM schedule design and sensor/telematics alert configuration. Sensor alerts integrate with Geotab telematics; diagnostic codes align with OBD-II/J1939 fault code systems for fleet assets. [ENUM-REF-CANDIDATE: visual_inspection|sensor_alert|driver_report|pm_inspection|diagnostic_code|operator_complaint|third_party_inspection — promote to reference product]' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epaReportableFlag rdf:type rdf:Property ;
    rdfs:label 'Epa Reportable Flag' ;
    rdfs:comment 'Indicates whether this failure mode may result in an EPA-reportable environmental incident (e.g., hydraulic fluid spill, leachate containment breach, LFG emission exceedance). When true, triggers environmental incident notification workflows in Enviance EHS and CERCLA/RCRA compliance reporting.' ;
    rdfs:domain ind:FailureMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:failureCategory rdf:type rdf:Property ;
    rdfs:label 'Failure Category' ;
    rdfs:comment 'High-level classification grouping failure modes by the nature of the failure mechanism. Drives routing of work orders to the appropriate technician skill set and supports trend analysis by failure type. [ENUM-REF-CANDIDATE: mechanical|electrical|hydraulic|structural|operator_induced|pneumatic|software — promote to reference product if additional categories are needed]' ;
    rdfs:domain ind:FailureMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureCode rdf:type rdf:Property ;
    rdfs:label 'Failure Code' ;
    rdfs:comment 'Standardized alphanumeric code uniquely identifying the failure mode within the enterprise catalog. Used as the externally-known business identifier on work orders, repair records, and FMEA documentation. Sourced from Infor EAM failure code configuration.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureDescription rdf:type rdf:Property ;
    rdfs:label 'Failure Description' ;
    rdfs:comment 'Detailed narrative describing the nature of the failure, observable symptoms, and conditions under which it typically occurs. Provides technicians and engineers with sufficient context to identify and classify the failure accurately in the field.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureModeGroup rdf:type rdf:Property ;
    rdfs:label 'Failure Mode Group' ;
    rdfs:comment 'Logical grouping of related failure modes for reporting and analysis purposes (e.g., \'Powertrain Failures\', \'Body and Compactor Failures\', \'Hydraulic System Failures\', \'Containment Failures\'). Supports roll-up reporting in maintenance dashboards and FMEA analysis by system group.' ;
    rdfs:domain ind:FailureMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureModeStatus rdf:type rdf:Property ;
    rdfs:label 'Failure Mode Status' ;
    rdfs:comment 'Current lifecycle status of the failure mode record in the enterprise catalog. Active records are available for selection on work orders and PM schedules. Inactive or deprecated records are retained for historical reporting but cannot be assigned to new work orders.' ;
    rdfs:domain ind:FailureMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureName rdf:type rdf:Property ;
    rdfs:label 'Failure Name' ;
    rdfs:comment 'Short, human-readable name for the failure mode (e.g., \'Hydraulic Hose Burst\', \'Brake Pad Wear\', \'Electrical Short Circuit\'). Used as the identity label in work order dropdowns, dashboards, and maintenance reports.' ;
    rdfs:domain ind:FailureMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fmeaDetectabilityScore rdf:type rdf:Property ;
    rdfs:label 'Fmea Detectability Score' ;
    rdfs:comment 'FMEA detectability rating on a 1-10 scale representing the ability of current inspection and monitoring controls to detect the failure before it causes asset breakdown. Score of 10 indicates the failure is virtually undetectable. Component of the RPN calculation.' ;
    rdfs:domain ind:FailureMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fmeaOccurrenceScore rdf:type rdf:Property ;
    rdfs:label 'Fmea Occurrence Score' ;
    rdfs:comment 'FMEA occurrence rating on a 1-10 scale representing the likelihood of this failure mode occurring within a given operating period. Score of 10 indicates near-certain occurrence. Derived from historical work order frequency data and OEM reliability data. Component of the RPN calculation.' ;
    rdfs:domain ind:FailureMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fmeaRpn rdf:type rdf:Property ;
    rdfs:label 'Fmea Rpn' ;
    rdfs:comment 'Composite risk score calculated as the product of Severity, Occurrence, and Detectability ratings (each 1-10) per FMEA methodology. Range 1-1000. Higher RPN values indicate higher priority for preventive maintenance investment and engineering redesign. Maintained by reliability engineering and reviewed during PM optimization cycles.' ;
    rdfs:domain ind:FailureMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fmeaSeverityScore rdf:type rdf:Property ;
    rdfs:label 'Fmea Severity Score' ;
    rdfs:comment 'FMEA severity rating on a 1-10 scale representing the seriousness of the failure effect on asset function, safety, or regulatory compliance. Score of 10 indicates catastrophic safety or environmental impact. Component of the RPN calculation.' ;
    rdfs:domain ind:FailureMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:industryStandardCode rdf:type rdf:Property ;
    rdfs:label 'Industry Standard Code' ;
    rdfs:comment 'External industry standard code that maps this failure mode to a recognized classification system beyond VMRS (e.g., ISO 14224 failure mechanism code, SWANA equipment failure taxonomy, or OEM-specific fault code). Enables cross-system benchmarking and regulatory reporting alignment.' ;
    rdfs:domain ind:FailureMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meanTimeBetweenFailures rdf:type rdf:Property ;
    rdfs:label 'Mean Time Between Failures' ;
    rdfs:comment 'Average operating hours between occurrences of this failure mode across the asset population, expressed in hours. Derived from historical work order data and used to calibrate PM interval recommendations and reliability forecasting models. Null for newly cataloged failure modes with insufficient history.' ;
    rdfs:domain ind:FailureMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:meanTimeToRepair rdf:type rdf:Property ;
    rdfs:label 'Mean Time To Repair' ;
    rdfs:comment 'Average labor hours required to diagnose and repair this failure mode, expressed in hours. Used for maintenance scheduling, technician capacity planning, and downtime impact estimation on work orders. Derived from actual labor hours recorded in Infor EAM and SAP PM work order history.' ;
    rdfs:domain ind:FailureMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:obdFaultCode rdf:type rdf:Property ;
    rdfs:label 'Obd Fault Code' ;
    rdfs:comment 'SAE J1939 or OBD-II diagnostic trouble code (DTC) associated with this failure mode for fleet assets. Enables automatic failure mode classification from telematics fault code alerts received via Geotab. Null for non-fleet or non-electronic failure modes.' ;
    rdfs:domain ind:FailureMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pmTriggerFlag rdf:type rdf:Property ;
    rdfs:label 'Pm Trigger Flag' ;
    rdfs:comment 'Indicates whether detection of this failure mode should automatically trigger creation of a preventive maintenance work order or PM schedule review. Supports proactive maintenance strategy by escalating recurring failure patterns to PM program adjustments.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recommendedCorrectiveAction rdf:type rdf:Property ;
    rdfs:label 'Recommended Corrective Action' ;
    rdfs:comment 'Standardized guidance on the preferred corrective maintenance action to resolve this failure mode (e.g., \'Replace hydraulic hose assembly\', \'Inspect and replace brake pads\', \'Perform electrical continuity test and rewire\'). Used to pre-populate work order task instructions and support technician decision-making.' ;
    rdfs:domain ind:FailureMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Risk Flag' ;
    rdfs:comment 'Indicates whether this failure mode presents a direct safety risk to operators, technicians, or the public. When true, triggers mandatory safety review, LOTO (Lockout/Tagout) procedures, and potential DOT out-of-service designation on associated work orders. Supports OSHA and DOT compliance workflows.' ;
    rdfs:domain ind:FailureMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:typicalRootCause rdf:type rdf:Property ;
    rdfs:label 'Typical Root Cause' ;
    rdfs:comment 'Narrative description of the most common underlying root cause(s) associated with this failure mode (e.g., \'Lack of lubrication\', \'Fatigue cracking due to overloading\', \'Corrosion from leachate exposure\'). Supports root cause analysis (RCA) and FMEA documentation. Populated by maintenance engineering based on historical repair data.' ;
    rdfs:domain ind:FailureMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vmrsCode rdf:type rdf:Property ;
    rdfs:label 'Vmrs Code' ;
    rdfs:comment 'Industry-standard VMRS code mapping this failure mode to the American Trucking Associations Vehicle Maintenance Reporting Standards taxonomy. Enables benchmarking against industry fleet maintenance data, DOT compliance reporting, and interoperability with fleet telematics systems such as Geotab. Null for non-fleet (facility) failure modes.' ;
    rdfs:domain ind:FailureMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Warranty Impact Flag' ;
    rdfs:comment 'Indicates whether this failure mode may be covered under OEM or vendor warranty, triggering warranty claim initiation in SAP MM. When true, work orders associated with this failure mode are flagged for warranty review before parts are charged to the maintenance cost center.' ;
    rdfs:domain ind:FailureMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fluidSampleId rdf:type rdf:Property ;
    rdfs:label 'Fluid Sample Id' ;
    rdfs:comment 'Unique surrogate identifier for each oil and fluid analysis sample record in the predictive maintenance program. Primary key for the fluid_sample data product.' ;
    rdfs:domain ind:FluidSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryFluidWorkOrderId rdf:type rdf:Property ;
    rdfs:label 'Primary Fluid Work Order Id' ;
    rdfs:comment 'Reference to the maintenance work order associated with the fluid sample collection event. Links to the work_order product for operational context and cost tracking.' ;
    rdfs:domain ind:FluidSample ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkOrder .

ind:aluminumPpm rdf:type rdf:Property ;
    rdfs:label 'Aluminum Ppm' ;
    rdfs:comment 'Concentration of aluminum wear particles in the fluid sample, expressed in parts per million (ppm). Elevated aluminum indicates wear in pistons, bearings, or pump housings.' ;
    rdfs:domain ind:FluidSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:componentSampled rdf:type rdf:Property ;
    rdfs:label 'Component Sampled' ;
    rdfs:comment 'The specific fluid system or component from which the sample was drawn. Identifies the type of fluid analyzed (e.g., engine oil, transmission fluid, hydraulic fluid, coolant, Diesel Exhaust Fluid (DEF)). [ENUM-REF-CANDIDATE: engine_oil|transmission_fluid|hydraulic_fluid|coolant|def|differential_fluid|gear_oil — promote to reference product]' ;
    rdfs:domain ind:FluidSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionAssessment rdf:type rdf:Property ;
    rdfs:label 'Condition Assessment' ;
    rdfs:comment 'Overall fluid and component condition rating assigned by the laboratory based on analysis results. Drives maintenance urgency: \'normal\' = no action required, \'caution\' = monitor closely or schedule service, \'critical\' = immediate maintenance action required.' ;
    rdfs:domain ind:FluidSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:copperPpm rdf:type rdf:Property ;
    rdfs:label 'Copper Ppm' ;
    rdfs:comment 'Concentration of copper wear particles in the fluid sample, expressed in parts per million (ppm). Elevated copper indicates wear in bearings, bushings, thrust washers, or cooler cores.' ;
    rdfs:domain ind:FluidSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fluidBrand rdf:type rdf:Property ;
    rdfs:label 'Fluid Brand' ;
    rdfs:comment 'Brand or trade name of the fluid currently in service at the time of sampling (e.g., Shell Rotella, Mobil Delvac, Chevron Delo). Used to correlate fluid performance across brands and validate approved fluid usage.' ;
    rdfs:domain ind:FluidSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fluidGrade rdf:type rdf:Property ;
    rdfs:label 'Fluid Grade' ;
    rdfs:comment 'SAE viscosity grade or specification of the fluid in service at the time of sampling (e.g., 15W-40, 5W-30, Dexron VI). Used to validate correct fluid specification and interpret viscosity analysis results.' ;
    rdfs:domain ind:FluidSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fluidHoursInService rdf:type rdf:Property ;
    rdfs:label 'Fluid Hours In Service' ;
    rdfs:comment 'Number of operating hours the sampled fluid has been in service since the last fluid change. Key metric for assessing fluid degradation relative to OEM-recommended change intervals.' ;
    rdfs:domain ind:FluidSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fluidMilesInService rdf:type rdf:Property ;
    rdfs:label 'Fluid Miles In Service' ;
    rdfs:comment 'Number of miles the sampled fluid has been in service since the last fluid change. Used alongside fluid_hours_in_service to assess oil life for on-road fleet vehicles.' ;
    rdfs:domain ind:FluidSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelDilutionPct rdf:type rdf:Property ;
    rdfs:label 'Fuel Dilution Pct' ;
    rdfs:comment 'Percentage of fuel contamination detected in the engine oil sample. Fuel dilution reduces oil viscosity and lubricating film strength, indicating injector leaks, ring blow-by, or short-trip operation patterns.' ;
    rdfs:domain ind:FluidSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ironPpm rdf:type rdf:Property ;
    rdfs:label 'Iron Ppm' ;
    rdfs:comment 'Concentration of iron wear particles in the fluid sample, expressed in parts per million (ppm). Elevated iron levels indicate wear in cylinder liners, crankshafts, camshafts, or gears depending on the component sampled.' ;
    rdfs:domain ind:FluidSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:labComments rdf:type rdf:Property ;
    rdfs:label 'Lab Comments' ;
    rdfs:comment 'Free-text narrative comments provided by the laboratory analyst interpreting the fluid analysis results. May include trend observations, anomaly explanations, and specific component wear hypotheses.' ;
    rdfs:domain ind:FluidSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Lab Received Date' ;
    rdfs:comment 'Date the fluid sample was received and logged by the external analysis laboratory. Used to calculate turnaround time and monitor laboratory service level performance.' ;
    rdfs:domain ind:FluidSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:labReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Lab Reference Number' ;
    rdfs:comment 'Unique identifier assigned by the external fluid analysis laboratory to this sample submission. Used to cross-reference laboratory reports, chain-of-custody documentation, and result retrieval.' ;
    rdfs:domain ind:FluidSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadPpm rdf:type rdf:Property ;
    rdfs:label 'Lead Ppm' ;
    rdfs:comment 'Concentration of lead wear particles in the fluid sample, expressed in parts per million (ppm). Elevated lead indicates bearing overlay wear, particularly in connecting rod and main bearings.' ;
    rdfs:domain ind:FluidSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:particleCountIso rdf:type rdf:Property ;
    rdfs:label 'Particle Count Iso' ;
    rdfs:comment 'ISO 4406 cleanliness code representing the particle count per milliliter at 4, 6, and 14 micron thresholds (e.g., \'18/16/13\'). Used to assess hydraulic fluid cleanliness and filter effectiveness.' ;
    rdfs:domain ind:FluidSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resampleDueDate rdf:type rdf:Property ;
    rdfs:label 'Resample Due Date' ;
    rdfs:comment 'Target date by which a follow-up fluid sample should be collected, as recommended by the laboratory or maintenance planner. Populated when resample_required is True.' ;
    rdfs:domain ind:FluidSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:resampleRequired rdf:type rdf:Property ;
    rdfs:label 'Resample Required' ;
    rdfs:comment 'Indicates whether the laboratory or maintenance team has determined that a follow-up fluid sample is required to confirm findings, monitor a developing condition, or validate corrective action effectiveness.' ;
    rdfs:domain ind:FluidSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resultsReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Results Received Date' ;
    rdfs:comment 'Date on which the fluid analysis results were received from the laboratory and made available for maintenance decision-making. Used to measure laboratory turnaround time and SLA compliance.' ;
    rdfs:domain ind:FluidSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sampleCollectionMethod rdf:type rdf:Property ;
    rdfs:label 'Sample Collection Method' ;
    rdfs:comment 'Method used to extract the fluid sample from the component. Affects result interpretation as live-zone sampling provides more representative contamination data than drain-plug sampling.' ;
    rdfs:domain ind:FluidSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleStatus rdf:type rdf:Property ;
    rdfs:label 'Sample Status' ;
    rdfs:comment 'Current lifecycle state of the fluid sample record, tracking progression from collection through laboratory analysis to closure. Drives workflow actions and follow-up maintenance decisions.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siliconPpm rdf:type rdf:Property ;
    rdfs:label 'Silicon Ppm' ;
    rdfs:comment 'Concentration of silicon in the fluid sample, expressed in parts per million (ppm). Elevated silicon indicates dirt/dust ingestion through air filtration failures or gasket sealant contamination, accelerating abrasive wear.' ;
    rdfs:domain ind:FluidSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sootPct rdf:type rdf:Property ;
    rdfs:label 'Soot Pct' ;
    rdfs:comment 'Percentage of soot (combustion byproduct) measured in the engine oil sample. Elevated soot levels indicate incomplete combustion, EGR system issues, or extended oil drain intervals in diesel fleet engines.' ;
    rdfs:domain ind:FluidSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalAcidNumber rdf:type rdf:Property ;
    rdfs:label 'Total Acid Number' ;
    rdfs:comment 'Total Acid Number (TAN) of the sampled fluid in mg KOH/g. Measures fluid oxidation and acidic degradation byproducts. Rising TAN indicates fluid life depletion and increased corrosion risk to engine components.' ;
    rdfs:domain ind:FluidSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalBaseNumber rdf:type rdf:Property ;
    rdfs:label 'Total Base Number' ;
    rdfs:comment 'Total Base Number (TBN) of the sampled fluid in mg KOH/g. Measures remaining alkaline reserve in engine oil that neutralizes combustion acids. Declining TBN indicates oil life depletion and need for oil change.' ;
    rdfs:domain ind:FluidSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:viscosityCst100 rdf:type rdf:Property ;
    rdfs:label 'Viscosity Cst 100' ;
    rdfs:comment 'Kinematic viscosity of the sampled fluid measured at 100 degrees Celsius, expressed in centistokes (cSt). Used to assess viscosity index and high-temperature fluid performance for engine and transmission fluids.' ;
    rdfs:domain ind:FluidSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:viscosityCst40 rdf:type rdf:Property ;
    rdfs:label 'Viscosity Cst 40' ;
    rdfs:comment 'Kinematic viscosity of the sampled fluid measured at 40 degrees Celsius, expressed in centistokes (cSt). Deviation from OEM specification indicates fluid degradation, contamination, or incorrect fluid grade.' ;
    rdfs:domain ind:FluidSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waterContentPpm rdf:type rdf:Property ;
    rdfs:label 'Water Content Ppm' ;
    rdfs:comment 'Water contamination level in the sampled fluid, expressed in parts per million (ppm). Elevated water content indicates coolant leaks, condensation ingress, or seal failures that can cause corrosion and accelerated wear.' ;
    rdfs:domain ind:FluidSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inspectionDefectId rdf:type rdf:Property ;
    rdfs:label 'Inspection Defect Id' ;
    rdfs:comment 'Unique surrogate identifier for each individual defect line item recorded during a DOT or internal maintenance inspection. Primary key for this entity.' ;
    rdfs:domain ind:InspectionDefect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cleanupWasteProfileId rdf:type rdf:Property ;
    rdfs:label 'Cleanup Waste Profile Id' ;
    rdfs:comment 'Foreign key linking to hazmat.waste_profile. Business justification: Defects involving hazardous material leaks or contamination must reference waste profiles for cleanup material disposal and spill response tracking. Essential for environmental compliance, waste chara' ;
    rdfs:domain ind:InspectionDefect ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WasteProfile .

ind:maintenanceDotInspectionId rdf:type rdf:Property ;
    rdfs:label 'Maintenance Dot Inspection Id' ;
    rdfs:comment 'Reference to the parent inspection event that produced this defect line item. Links the defect to its originating inspection header record.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaintenanceDotInspection .

ind:primaryInspectionEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Inspection Employee Id' ;
    rdfs:comment 'Reference to the maintenance technician assigned to and responsible for completing the repair of this defect. Null if no technician has been assigned yet.' ;
    rdfs:domain ind:InspectionDefect ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:defectNumber rdf:type rdf:Property ;
    rdfs:label 'Defect Number' ;
    rdfs:comment 'Externally visible alphanumeric identifier for this defect line item, used in regulatory reports, driver vehicle inspection reports (DVIR), and maintenance communications. Sourced from Infor EAM or SAP PM defect numbering sequence.' ;
    rdfs:domain ind:InspectionDefect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectStatus rdf:type rdf:Property ;
    rdfs:label 'Defect Status' ;
    rdfs:comment 'Current lifecycle status of the defect: open (identified, no action taken), in_progress (repair work order active), repaired (repair completed, pending verification), verified (repair confirmed by inspector or supervisor), waived (formally accepted risk with documented justification), closed (fully resolved and documented).' ;
    rdfs:domain ind:InspectionDefect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Detected Timestamp' ;
    rdfs:comment 'Precise date and time when this defect was identified and recorded during the inspection. Provides exact event time for regulatory audit trails and time-to-repair calculations.' ;
    rdfs:domain ind:InspectionDefect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dotOosCategory rdf:type rdf:Property ;
    rdfs:label 'Dot Oos Category' ;
    rdfs:comment 'DOT FMCSA out-of-service category applicable to this defect: driver OOS (driver condition), vehicle OOS (mechanical condition), hazmat OOS (hazardous materials violation), or not_applicable for non-OOS defects.' ;
    rdfs:domain ind:InspectionDefect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dotViolationCode rdf:type rdf:Property ;
    rdfs:label 'Dot Violation Code' ;
    rdfs:comment 'Official DOT FMCSA violation code associated with this defect when it constitutes a regulatory violation (e.g., 393.45 for brake hose and tubing). Null for internal defects that do not map to a DOT violation code.' ;
    rdfs:domain ind:InspectionDefect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isOutOfService rdf:type rdf:Property ;
    rdfs:label 'Is Out Of Service' ;
    rdfs:comment 'Indicates whether this defect triggers an out-of-service (OOS) condition requiring the vehicle or equipment to be immediately removed from operation until repaired, per DOT FMCSA or CVSA out-of-service criteria.' ;
    rdfs:domain ind:InspectionDefect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRepairCompleted rdf:type rdf:Property ;
    rdfs:label 'Is Repair Completed' ;
    rdfs:comment 'Indicates whether the repair for this defect has been completed and verified. Used to track open versus resolved defects and to confirm regulatory compliance before returning an asset to service.' ;
    rdfs:domain ind:InspectionDefect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRepairRequired rdf:type rdf:Property ;
    rdfs:label 'Is Repair Required' ;
    rdfs:comment 'Indicates whether a repair action is required to resolve this defect. True for all major and critical defects; may be false for minor cosmetic observations that are logged but do not require immediate corrective action.' ;
    rdfs:domain ind:InspectionDefect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:partNumber rdf:type rdf:Property ;
    rdfs:label 'Part Number' ;
    rdfs:comment 'Bill of Materials (BOM) part number of the primary replacement part used to repair this defect. Supports parts consumption tracking, inventory management, and recurring failure analysis by part.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:photoReference rdf:type rdf:Property ;
    rdfs:label 'Photo Reference' ;
    rdfs:comment 'File path or document management system reference to photographic evidence of the defect captured during inspection. Supports visual documentation for regulatory compliance, insurance claims, and repair verification.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recurrenceCount rdf:type rdf:Property ;
    rdfs:label 'Recurrence Count' ;
    rdfs:comment 'Number of times this same defect type (by defect_code and component_system) has been recorded on this asset within the trailing 12-month period. Supports recurring failure identification and escalation thresholds.' ;
    rdfs:domain ind:InspectionDefect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:repairCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Repair Completed Date' ;
    rdfs:comment 'Date on which the repair for this defect was completed. Used to calculate time-to-repair, assess SLA compliance, and confirm regulatory compliance before returning the asset to service.' ;
    rdfs:domain ind:InspectionDefect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:repairCost rdf:type rdf:Property ;
    rdfs:label 'Repair Cost' ;
    rdfs:comment 'Total cost incurred to repair this defect, including labor, parts, and any subcontracted services. Expressed in USD. Used for maintenance cost analysis, asset lifecycle costing, and budget management.' ;
    rdfs:domain ind:InspectionDefect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:repairDueDate rdf:type rdf:Property ;
    rdfs:label 'Repair Due Date' ;
    rdfs:comment 'Target date by which the repair for this defect must be completed, based on severity level, regulatory requirements, and operational scheduling. Critical defects require same-day resolution; major defects may have a defined SLA window.' ;
    rdfs:domain ind:InspectionDefect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceSystemDefectCode rdf:type rdf:Property ;
    rdfs:label 'Source System Defect Code' ;
    rdfs:comment 'The native defect or notification identifier from the originating operational system (e.g., Infor EAM defect ID, SAP PM notification number). Enables traceability back to the system of record for audit and reconciliation purposes.' ;
    rdfs:domain ind:InspectionDefect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleEngineHours rdf:type rdf:Property ;
    rdfs:label 'Vehicle Engine Hours' ;
    rdfs:comment 'Engine hours recorded at the time of the inspection when this defect was identified. Used for hour-based defect trend analysis on equipment where engine hours are the primary usage metric (e.g., off-road equipment, compactors).' ;
    rdfs:domain ind:InspectionDefect ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetId rdf:type rdf:Property ;
    rdfs:label 'Budget Id' ;
    rdfs:comment 'Unique surrogate identifier for each maintenance budget record in the Silver Layer lakehouse. Primary key for the maintenance_budget data product.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Budget .

ind:budgetApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Budget Approved By Employee Id' ;
    rdfs:comment 'Reference to the employee who formally approved this maintenance budget or the most recent budget revision. Required for SOX compliance and financial authorization audit trails.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:budgetEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Budget Employee Id' ;
    rdfs:comment 'Reference to the employee (typically a Maintenance Manager or Fleet Manager) who owns and is accountable for this budget allocation. Used for approval workflows and spend governance escalation.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:typeId rdf:type rdf:Property ;
    rdfs:label 'Type Id' ;
    rdfs:comment 'Foreign key linking to maintenance.maintenance_type. Business justification: Maintenance budgets are allocated by standardized maintenance type categories. Currently has maintenance_type (STRING) which should reference the maintenance_type master table for consistent classific' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Type .

ind:budgetNumber rdf:type rdf:Property ;
    rdfs:label 'Budget Number' ;
    rdfs:comment 'Externally-known alphanumeric identifier for the maintenance budget record, used in financial planning documents, cost center reports, and cross-system references. Format: MB-{YYYY}-{NNNNNN}.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetSource rdf:type rdf:Property ;
    rdfs:label 'Budget Source' ;
    rdfs:comment 'Classification of the funding source for this maintenance budget: capital expenditure (CapEx), operating expenditure (OpEx), emergency reserve, regulatory compliance fund, or external grant. Drives financial reporting and EBITDA impact analysis.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetStatus rdf:type rdf:Property ;
    rdfs:label 'Budget Status' ;
    rdfs:comment 'Current lifecycle state of the maintenance budget record, tracking progression from initial draft through approval, active spend, revision, and closure. Drives workflow approvals and spend authorization.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dotInspectionBudgetFlag rdf:type rdf:Property ;
    rdfs:label 'Dot Inspection Budget Flag' ;
    rdfs:comment 'Indicates whether this budget record specifically covers Department of Transportation (DOT) mandated vehicle inspection and compliance maintenance costs. Supports DOT compliance cost tracking and regulatory reporting.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:encumberedAmount rdf:type rdf:Property ;
    rdfs:label 'Encumbered Amount' ;
    rdfs:comment 'Total value of open Purchase Orders (POs) and open Work Orders (WOs) that have been committed against this budget but not yet invoiced or posted as actuals. Represents financial obligations that reduce available budget.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laborBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Labor Budget Amount' ;
    rdfs:comment 'Portion of the total budget allocated for internal technician labor costs, including regular time and overtime. Supports workforce planning and labor cost governance within the maintenance function.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maintenanceCategory rdf:type rdf:Property ;
    rdfs:label 'Maintenance Category' ;
    rdfs:comment 'Classification of the maintenance type covered by this budget: fleet Preventive Maintenance (PM), fleet corrective/repair, facility PM, facility corrective, or subcontracted work. Core dimension for maintenance spend governance and KPI reporting.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Original Budget Amount' ;
    rdfs:comment 'The initial approved maintenance budget amount for the period, as established during the annual or quarterly planning cycle. Serves as the baseline for variance analysis and budget governance.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partsBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Parts Budget Amount' ;
    rdfs:comment 'Portion of the total budget allocated for spare parts, consumables, and materials (Bill of Materials — BOM items) required for maintenance activities. Supports parts inventory planning and procurement governance.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:periodEndDate rdf:type rdf:Property ;
    rdfs:label 'Period End Date' ;
    rdfs:comment 'The calendar date on which the budget period ends. Defines the boundary for spend authorization and variance calculation for the budget record.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodStartDate rdf:type rdf:Property ;
    rdfs:label 'Period Start Date' ;
    rdfs:comment 'The calendar date on which the budget period begins. Used to align maintenance spend tracking with the fiscal calendar and to calculate time-phased budget consumption.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priorYearActualAmount rdf:type rdf:Property ;
    rdfs:label 'Prior Year Actual Amount' ;
    rdfs:comment 'Actual maintenance spend for the equivalent period in the prior fiscal year. Used as a baseline reference for budget planning, year-over-year variance analysis, and trend reporting.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regionCode rdf:type rdf:Property ;
    rdfs:label 'Region Code' ;
    rdfs:comment 'Operational region code to which this maintenance budget is assigned (e.g., NE, SE, MW, SW, W). Enables regional maintenance spend benchmarking and geographic budget governance across Waste Management\'s distributed operations.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remainingBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Remaining Budget Amount' ;
    rdfs:comment 'Available budget balance calculated as revised (or original if no revision) budget minus actual spend minus encumbered amounts. Represents the uncommitted, unspent budget available for new work authorization.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revisedBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Revised Budget Amount' ;
    rdfs:comment 'The most recently approved revised budget amount, reflecting mid-period budget adjustments, supplemental approvals, or reforecasting. Null if no revision has been made. Used as the current authorized spend ceiling.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceBudgetReference rdf:type rdf:Property ;
    rdfs:label 'Source Budget Reference' ;
    rdfs:comment 'The native identifier of this budget record in the originating source system (e.g., SAP CO internal order number, Infor EAM budget reference). Enables traceability and reconciliation between the lakehouse Silver Layer and operational systems.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spendToBudgetPct rdf:type rdf:Property ;
    rdfs:label 'Spend To Budget Pct' ;
    rdfs:comment 'Ratio of actual spend to date divided by the current authorized budget, expressed as a percentage. Provides a real-time utilization indicator for budget monitoring dashboards and KPI reporting.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:subcontractBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Subcontract Budget Amount' ;
    rdfs:comment 'Portion of the total budget allocated specifically for subcontracted maintenance work (third-party vendors, specialized repair shops). Enables make-vs-buy analysis and subcontract spend governance.' ;
    rdfs:domain ind:Budget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costId rdf:type rdf:Property ;
    rdfs:label 'Cost Id' ;
    rdfs:comment 'Unique surrogate identifier for each maintenance cost record at the work order level. Primary key for the maintenance_cost data product in the Databricks Silver Layer.' ;
    rdfs:domain ind:Cost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualCostAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Cost Amount' ;
    rdfs:comment 'Total cost actually incurred for this cost category on the work order, as posted to SAP FI/CO upon WO completion. Expressed in USD. Core metric for fleet maintenance spend and EBITDA impact analysis.' ;
    rdfs:domain ind:Cost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costType rdf:type rdf:Property ;
    rdfs:label 'Cost Type' ;
    rdfs:comment 'Indicates whether this record represents a planned (budgeted) cost, actual (incurred) cost, variance (planned minus actual), or accrual (estimated but not yet invoiced). Supports plan-vs-actual financial analysis.' ;
    rdfs:domain ind:Cost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laborRate rdf:type rdf:Property ;
    rdfs:label 'Labor Rate' ;
    rdfs:comment 'Blended or standard hourly labor rate (USD/hour) applied to calculate the labor cost for this work order. May reflect straight-time, overtime, or contract rates. Classified as confidential due to sensitivity of internal wage rate data.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:note rdf:type rdf:Property ;
    rdfs:label 'Note' ;
    rdfs:comment 'Free-text notes or justification provided by the maintenance planner, technician, or financial controller regarding this cost record. May include explanations for cost variances, warranty claim details, or approval conditions.' ;
    rdfs:domain ind:Cost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partsQuantity rdf:type rdf:Property ;
    rdfs:label 'Parts Quantity' ;
    rdfs:comment 'Total quantity of parts or materials consumed on this work order for the parts cost category, as recorded in the Bill of Materials (BOM) confirmation in Infor EAM or SAP MM. Supports inventory reconciliation and parts usage analysis.' ;
    rdfs:domain ind:Cost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partsUnitCost rdf:type rdf:Property ;
    rdfs:label 'Parts Unit Cost' ;
    rdfs:comment 'Standard or actual unit cost per part or material item consumed on this work order, as sourced from SAP MM material master or Infor EAM parts catalog. Classified as confidential due to procurement pricing sensitivity.' ;
    rdfs:domain ind:Cost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedCostAmount rdf:type rdf:Property ;
    rdfs:label 'Planned Cost Amount' ;
    rdfs:comment 'Budgeted or estimated cost for this cost category on the work order, as established during WO creation or PM scheduling in Infor EAM or SAP PM. Expressed in USD. Used for budget variance analysis.' ;
    rdfs:domain ind:Cost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Source Document Number' ;
    rdfs:comment 'The originating document number from the source system (e.g., SAP accounting document number, Infor EAM transaction ID, or vendor invoice number) that generated this cost record. Enables end-to-end audit traceability from the Silver Layer back to the system of record.' ;
    rdfs:domain ind:Cost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subcontractVendorName rdf:type rdf:Property ;
    rdfs:label 'Subcontract Vendor Name' ;
    rdfs:comment 'Name of the external vendor or subcontractor providing services for this work order when cost_category is \'subcontract\'. Sourced from SAP MM vendor master. Used for vendor spend analysis and contract compliance tracking.' ;
    rdfs:domain ind:Cost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyClaimFlag rdf:type rdf:Property ;
    rdfs:label 'Warranty Claim Flag' ;
    rdfs:comment 'Indicates whether any portion of this maintenance cost is expected to be recovered through a manufacturer or vendor warranty claim. True = warranty claim initiated. Supports warranty cost recovery tracking and net cost reporting.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:warrantyRecoveryAmount rdf:type rdf:Property ;
    rdfs:label 'Warranty Recovery Amount' ;
    rdfs:comment 'Amount expected to be or already recovered from a manufacturer or vendor warranty claim against this maintenance cost. Reduces net maintenance cost for asset lifecycle costing. Expressed in USD.' ;
    rdfs:domain ind:Cost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:woCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Wo Completion Date' ;
    rdfs:comment 'The date the associated work order was technically completed and costs were confirmed in Infor EAM or SAP PM. Represents the principal business event date for this cost record. Used to align maintenance activity with financial period.' ;
    rdfs:domain ind:Cost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:woType rdf:type rdf:Property ;
    rdfs:label 'Wo Type' ;
    rdfs:comment 'Classification of the maintenance work order driving this cost: preventive (PM cycle-based), corrective (repair after failure), emergency (unplanned breakdown), inspection (DOT or regulatory), or overhaul (major rebuild). Enables cost analysis by maintenance strategy.' ;
    rdfs:domain ind:Cost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workCenterCode rdf:type rdf:Property ;
    rdfs:label 'Work Center Code' ;
    rdfs:comment 'SAP or Infor EAM work center code identifying the maintenance shop, garage, or facility where the work was performed. Used for cost allocation by operational location and capacity planning.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryMaintenanceEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Maintenance Employee Id' ;
    rdfs:comment 'Internal employee ID or external badge/certification number of the inspector who performed the DOT inspection. Used to cross-reference with Workday HCM for internal technicians or external certification registries for third-party inspectors.' ;
    rdfs:domain ind:MaintenanceDotInspection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:certifyingMechanicName rdf:type rdf:Property ;
    rdfs:label 'Certifying Mechanic Name' ;
    rdfs:comment 'Full name of the qualified mechanic or technician who certified that all corrective actions were completed and the vehicle is safe for operation. Required for FMCSA DVIR sign-off and annual inspection certification per 49 CFR Part 396.17.' ;
    rdfs:domain ind:MaintenanceDotInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:csaBasicCategory rdf:type rdf:Property ;
    rdfs:label 'Csa Basic Category' ;
    rdfs:comment 'FMCSA Compliance, Safety, Accountability (CSA) Behavior Analysis and Safety Improvement Category (BASIC) most relevant to the violations cited in this inspection. Used for CSA score impact analysis and targeted safety improvement programs. [ENUM-REF-CANDIDATE: unsafe_driving|hos_compliance|driver_fitness|controlled_substances|vehicle_maintenance|hazmat_compliance|crash_indicator — promote to reference product]' ;
    rdfs:domain ind:MaintenanceDotInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:driverSignatureObtained rdf:type rdf:Property ;
    rdfs:label 'Driver Signature Obtained' ;
    rdfs:comment 'Indicates whether the CDL driver\'s signature was obtained on the Driver Vehicle Inspection Report (DVIR) as required by FMCSA 49 CFR Part 396.11. True confirms the driver acknowledged the inspection findings. Required for FMCSA audit compliance.' ;
    rdfs:domain ind:MaintenanceDotInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fmcsaReportNumber rdf:type rdf:Property ;
    rdfs:label 'Fmcsa Report Number' ;
    rdfs:comment 'Federal Motor Carrier Safety Administration (FMCSA) assigned report number for roadside inspections entered into the FMCSA Motor Carrier Management Information System (MCMIS). Used for DataQs challenge submissions and CSA score reconciliation.' ;
    rdfs:domain ind:MaintenanceDotInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossVehicleWeightRatingLbs rdf:type rdf:Property ;
    rdfs:label 'Gross Vehicle Weight Rating Lbs' ;
    rdfs:comment 'Manufacturer-specified Gross Vehicle Weight Rating (GVWR) in pounds for the inspected vehicle. Determines applicable DOT inspection requirements, weight limit compliance, and bridge formula applicability under FHWA regulations.' ;
    rdfs:domain ind:MaintenanceDotInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hazmatPlacardRequired rdf:type rdf:Property ;
    rdfs:label 'Hazmat Placard Required' ;
    rdfs:comment 'Indicates whether the vehicle was required to display hazardous materials (HAZMAT) placards at the time of inspection, triggering additional DOT HAZMAT inspection requirements under 49 CFR Part 172. Relevant for Waste Management hazardous waste collection vehicles.' ;
    rdfs:domain ind:MaintenanceDotInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectionEndTime rdf:type rdf:Property ;
    rdfs:label 'Inspection End Time' ;
    rdfs:comment 'Precise date and time when the DOT inspection was completed. Used to calculate inspection duration, assess thoroughness, and support operational scheduling.' ;
    rdfs:domain ind:MaintenanceDotInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:inspectionReportSource rdf:type rdf:Property ;
    rdfs:label 'Inspection Report Source' ;
    rdfs:comment 'Originating system or channel from which this inspection record was captured. Infor EAM for internally-scheduled inspections, SAP PM for work order-linked inspections, FMCSA DataQs for roadside inspection data feeds, manual entry for paper-based records, or roadside enforcement for law enforcement-issued reports.' ;
    rdfs:domain ind:MaintenanceDotInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionStartTime rdf:type rdf:Property ;
    rdfs:label 'Inspection Start Time' ;
    rdfs:comment 'Precise date and time when the DOT inspection commenced. Used for Hours of Service (HOS) compliance correlation, driver log verification, and operational scheduling in Infor EAM.' ;
    rdfs:domain ind:MaintenanceDotInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent modification to this DOT inspection record. Used for change tracking, data synchronization between Infor EAM and the Databricks Silver Layer, and audit trail maintenance.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:licensePlateNumber rdf:type rdf:Property ;
    rdfs:label 'License Plate Number' ;
    rdfs:comment 'State-issued license plate number of the commercial vehicle at the time of inspection. Required for roadside inspection documentation and DOT compliance verification.' ;
    rdfs:domain ind:MaintenanceDotInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licensePlateState rdf:type rdf:Property ;
    rdfs:label 'License Plate State' ;
    rdfs:comment 'Two-letter US state abbreviation (or Canadian province code) where the commercial vehicle is registered. Used for multi-jurisdictional DOT compliance tracking.' ;
    rdfs:domain ind:MaintenanceDotInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryCitationCodes rdf:type rdf:Property ;
    rdfs:label 'Regulatory Citation Codes' ;
    rdfs:comment 'Pipe-delimited list of FMCSA or state regulatory citation codes associated with defects identified during the inspection (e.g., 393.75|396.3). Used for CSA BASIC scoring, violation tracking, and regulatory audit response. Sourced from FMCSA violation code tables.' ;
    rdfs:domain ind:MaintenanceDotInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleReturnToServiceDate rdf:type rdf:Property ;
    rdfs:label 'Vehicle Return To Service Date' ;
    rdfs:comment 'Date on which the vehicle was officially cleared and returned to active service following an out-of-service order or corrective action completion. Used for fleet availability reporting and downtime cost analysis.' ;
    rdfs:domain ind:MaintenanceDotInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvalThresholdUsd rdf:type rdf:Property ;
    rdfs:label 'Approval Threshold Usd' ;
    rdfs:comment 'Minimum estimated cost in US dollars above which a work order of this maintenance type requires management approval. Supports tiered authorization controls for maintenance spend in compliance with SOX internal control requirements.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:avgLaborCostUsd rdf:type rdf:Property ;
    rdfs:label 'Avg Labor Cost Usd' ;
    rdfs:comment 'Standard average labor cost for a maintenance activity of this type, expressed in US dollars. Derived from technician labor rates and estimated duration. Used for work order cost estimation, maintenance budget planning, and COGS reporting.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:avgPartsCostUsd rdf:type rdf:Property ;
    rdfs:label 'Avg Parts Cost Usd' ;
    rdfs:comment 'Standard average cost of parts and materials consumed for a maintenance activity of this type, expressed in US dollars. Used for maintenance budget planning, work order cost estimation, and BOM cost benchmarking in SAP MM and Infor EAM.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Cost Category Code' ;
    rdfs:comment 'Maps this maintenance type to a cost accounting category in SAP FI/CO for GL posting and COGS allocation (e.g., PREV_MAINT, CORR_MAINT, EMER_MAINT, DOT_INSP, WARRANTY). Enables financial reporting by maintenance type and supports EBITDA analysis for fleet operations.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultPriorityCode rdf:type rdf:Property ;
    rdfs:label 'Default Priority Code' ;
    rdfs:comment 'Default work order priority assigned when a work order is created under this maintenance type. Drives scheduling urgency, technician dispatch sequencing, and SLA compliance tracking. Can be overridden at the individual work order level.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eamTypeCode rdf:type rdf:Property ;
    rdfs:label 'Eam Type Code' ;
    rdfs:comment 'Native maintenance type code as defined in Infor EAM, used for system integration and data lineage tracing. Enables bidirectional synchronization between the lakehouse silver layer and the Infor EAM CMMS source system.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalServiceFlag rdf:type rdf:Property ;
    rdfs:label 'External Service Flag' ;
    rdfs:comment 'Indicates whether maintenance activities of this type are typically performed by an external vendor or contractor (True) rather than internal technicians (False). When True, triggers purchase order (PO) creation workflow in SAP MM for external service procurement.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:failureModeApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Failure Mode Applicable Flag' ;
    rdfs:comment 'Indicates whether failure mode and root cause analysis is required for work orders of this maintenance type (True) or not (False). When True, technicians must document failure codes, cause codes, and remediation actions in Infor EAM for reliability-centered maintenance (RCM) analysis.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ghgReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Ghg Reporting Flag' ;
    rdfs:comment 'Indicates whether maintenance activities of this type generate reportable GHG emissions data (True) or not (False). Applicable for maintenance involving CNG/RNG fuel systems, LFG equipment, or WTE facility assets where EPA GHG reporting under the Clean Air Act is required.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxAllowableDowntimeHours rdf:type rdf:Property ;
    rdfs:label 'Max Allowable Downtime Hours' ;
    rdfs:comment 'Maximum number of hours an asset is permitted to remain out of service for maintenance of this type before escalation is triggered. Used to enforce SLA compliance for fleet availability and to drive escalation workflows in Infor EAM and AMCS dispatch.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:meterUnit rdf:type rdf:Property ;
    rdfs:label 'Meter Unit' ;
    rdfs:comment 'Unit of measure for the recurrence_interval_meter field, defining the measurement basis for meter-triggered PM schedules (e.g., miles for vehicle odometer, hours for engine runtime, cycles for lift/compaction cycles, tons for throughput-based equipment).' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Planning Lead Time Days' ;
    rdfs:comment 'Standard number of calendar days required to plan and prepare for a maintenance activity of this type before execution. Used by maintenance planners to schedule parts procurement, technician availability, and asset downtime windows. Sourced from Infor EAM PM cycle configuration.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pmTriggerBasis rdf:type rdf:Property ;
    rdfs:label 'Pm Trigger Basis' ;
    rdfs:comment 'Defines the basis on which PM schedules of this maintenance type are triggered: time-based (fixed calendar intervals), meter-based (mileage, engine hours, cycles), condition-based (sensor thresholds), event-based (after specific operational events), or calendar-based (fixed dates). Drives PM cycle configuration in Infor EAM.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recurrenceIntervalDays rdf:type rdf:Property ;
    rdfs:label 'Recurrence Interval Days' ;
    rdfs:comment 'Default calendar-based recurrence interval in days for PM schedules of this maintenance type. Used when pm_trigger_basis is \'time\' or \'calendar\'. Drives automatic PM work order generation in Infor EAM and SAP PM scheduling cycles.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recurrenceIntervalMeter rdf:type rdf:Property ;
    rdfs:label 'Recurrence Interval Meter' ;
    rdfs:comment 'Default meter-based recurrence interval for PM schedules of this maintenance type (e.g., miles, engine hours, lift cycles). Used when pm_trigger_basis is \'meter\'. The unit of measure is defined by meter_unit. Drives meter-based PM work order generation in Infor EAM.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requiredCertificationCode rdf:type rdf:Property ;
    rdfs:label 'Required Certification Code' ;
    rdfs:comment 'Code identifying the specific technician certification required to perform maintenance of this type (e.g., CDL_CLASS_A, ASE_MASTER, DOT_INSPECTOR, HAZMAT_HANDLER). Enforced during work order technician assignment in Infor EAM and Workday HCM. Applicable when requires_certified_technician is True.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresAssetShutdown rdf:type rdf:Property ;
    rdfs:label 'Requires Asset Shutdown' ;
    rdfs:comment 'Indicates whether maintenance of this type requires the asset (vehicle, equipment, or facility) to be taken out of service (True) or can be performed while the asset remains operational (False). Drives downtime planning and route coverage adjustments in AMCS and Locus Dispatch.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresCertifiedTechnician rdf:type rdf:Property ;
    rdfs:label 'Requires Certified Technician' ;
    rdfs:comment 'Indicates whether maintenance activities of this type must be performed by a technician holding a specific certification (True) or can be performed by any qualified technician (False). When True, the required_certification_code field specifies the certification. Supports CDL, ASE, and DOT certification enforcement.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sapOrderTypeCode rdf:type rdf:Property ;
    rdfs:label 'Sap Order Type Code' ;
    rdfs:comment 'SAP PM order type code corresponding to this maintenance type (e.g., PM01, PM02, PM03). Used for GL posting, cost settlement, and integration with SAP FI/CO for maintenance cost reporting and EBITDA analysis.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:typeCategory rdf:type rdf:Property ;
    rdfs:label 'Type Category' ;
    rdfs:comment 'High-level grouping of the maintenance type indicating whether the activity is planned (scheduled in advance), unplanned (reactive/emergency), regulatory (DOT/EPA/OSHA mandated), or warranty (covered under manufacturer or service warranty). Supports cost allocation and KPI segmentation.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:typeStatus rdf:type rdf:Property ;
    rdfs:label 'Type Status' ;
    rdfs:comment 'Current lifecycle status of the maintenance type record indicating whether it is actively used in work order and PM schedule creation (active), temporarily disabled (inactive), or retired from use (deprecated). Controls availability in downstream scheduling and dispatch systems.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Warranty Applicable Flag' ;
    rdfs:comment 'Indicates whether maintenance activities of this type may be covered under an OEM or service warranty (True) or are not warranty-eligible (False). When True, triggers warranty claim validation workflow in Infor EAM before cost posting to internal cost centers.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workOrderClass rdf:type rdf:Property ;
    rdfs:label 'Work Order Class' ;
    rdfs:comment 'SAP PM and Infor EAM work order class associated with this maintenance type. Determines the work order processing workflow, approval routing, and cost settlement rules. Maps directly to the order type configuration in SAP PM (e.g., PM01 Corrective, PM02 Preventive, PM03 Inspection).' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meterReadingId rdf:type rdf:Property ;
    rdfs:label 'Meter Reading Id' ;
    rdfs:comment 'Unique surrogate identifier for each meter reading record in the Databricks Silver Layer. Primary key for the meter_reading data product.' ;
    rdfs:domain ind:MeterReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryMeterReaderEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Meter Reader Employee Id' ;
    rdfs:comment 'Reference to the employee who recorded or submitted this meter reading. Applicable for manual entry readings; null for automated telematics or sensor sources.' ;
    rdfs:domain ind:MeterReading ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:confirmationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Confirmation Timestamp' ;
    rdfs:comment 'Date and time when the meter reading was confirmed and approved by the responsible supervisor or maintenance planner. Supports audit trail requirements for DOT and regulatory compliance. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:MeterReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:expectedReadingValue rdf:type rdf:Property ;
    rdfs:label 'Expected Reading Value' ;
    rdfs:comment 'The anticipated meter reading value based on historical usage rate and elapsed time since the last reading. Used as the baseline for variance calculation and anomaly detection in PM scheduling.' ;
    rdfs:domain ind:MeterReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geotabDeviceCode rdf:type rdf:Property ;
    rdfs:label 'Geotab Device Code' ;
    rdfs:comment 'Identifier of the Geotab telematics device installed on the vehicle that transmitted this meter reading. Populated only when reading_source is \'geotab_telematics\'. Enables traceability back to the specific telematics hardware unit.' ;
    rdfs:domain ind:MeterReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geotabTripReference rdf:type rdf:Property ;
    rdfs:label 'Geotab Trip Reference' ;
    rdfs:comment 'Reference to the specific Geotab trip or engine activity session during which this telematics-sourced meter reading was captured. Supports correlation with GPS route data and driver behavior events.' ;
    rdfs:domain ind:MeterReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incrementalUsage rdf:type rdf:Property ;
    rdfs:label 'Incremental Usage' ;
    rdfs:comment 'Usage accumulated since the previous meter reading (current reading value minus previous reading value). Stored as a business field to support PM trigger evaluation and utilization rate calculations without requiring a self-join at query time.' ;
    rdfs:domain ind:MeterReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:meterType rdf:type rdf:Property ;
    rdfs:label 'Meter Type' ;
    rdfs:comment 'Classification of the meter or usage counter being read. Determines the unit of measure and PM trigger logic. Common types include odometer (miles), engine hours, hydraulic hours, cycle count (lifts/compactions), and tonnage processed (TPD). [ENUM-REF-CANDIDATE: odometer|engine_hours|hydraulic_hours|cycle_count|tonnage_processed|fuel_consumed|pressurized_cycles|electrical_hours — promote to reference product]' ;
    rdfs:domain ind:MeterReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pmDueAtValue rdf:type rdf:Property ;
    rdfs:label 'Pm Due At Value' ;
    rdfs:comment 'The meter value at which the next Preventive Maintenance (PM) task is scheduled to be triggered for this asset and meter type. Calculated from the PM schedule interval and the last PM completion meter reading.' ;
    rdfs:domain ind:MeterReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:previousReadingDate rdf:type rdf:Property ;
    rdfs:label 'Previous Reading Date' ;
    rdfs:comment 'Date of the most recent prior confirmed meter reading for the same asset and meter type. Used to compute elapsed time and usage rate between readings for PM scheduling and utilization analytics.' ;
    rdfs:domain ind:MeterReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:previousReadingValue rdf:type rdf:Property ;
    rdfs:label 'Previous Reading Value' ;
    rdfs:comment 'The most recent prior confirmed meter reading value for the same asset and meter type. Used to calculate incremental usage since last reading and to detect rollover or anomalous variance conditions.' ;
    rdfs:domain ind:MeterReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:readingDate rdf:type rdf:Property ;
    rdfs:label 'Reading Date' ;
    rdfs:comment 'Calendar date on which the meter reading was taken. Used for day-level PM due-date calculations, utilization reporting, and DOT inspection scheduling. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:MeterReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:readingNotes rdf:type rdf:Property ;
    rdfs:label 'Reading Notes' ;
    rdfs:comment 'Free-text notes entered by the technician or driver at the time of reading. May include observations about meter condition, suspected inaccuracies, or contextual information relevant to variance investigation.' ;
    rdfs:domain ind:MeterReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:readingNumber rdf:type rdf:Property ;
    rdfs:label 'Reading Number' ;
    rdfs:comment 'Externally-known business identifier for this meter reading record, sourced from Infor EAM or SAP PM. Used for cross-system traceability and audit reference.' ;
    rdfs:domain ind:MeterReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:readingSource rdf:type rdf:Property ;
    rdfs:label 'Reading Source' ;
    rdfs:comment 'Indicates the originating source or method by which this meter reading was captured. Manual entries are submitted by technicians or drivers; Geotab telematics readings are automatically transmitted via GPS/OBD integration; automated sensor readings come from onboard equipment sensors.' ;
    rdfs:domain ind:MeterReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:readingUnit rdf:type rdf:Property ;
    rdfs:label 'Reading Unit' ;
    rdfs:comment 'Unit of measure corresponding to the meter type and reading value (e.g., miles for odometer, hours for engine/hydraulic meters, cycles for compaction counters, tons for tonnage processed). Aligns with Infor EAM unit of measure configuration.' ;
    rdfs:domain ind:MeterReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:readingValue rdf:type rdf:Property ;
    rdfs:label 'Reading Value' ;
    rdfs:comment 'The actual numeric value recorded on the meter or usage counter at the time of reading (e.g., 125,432.5 miles on odometer, 4,820.25 engine hours). This is the principal quantitative measurement for this event log record.' ;
    rdfs:domain ind:MeterReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remainingUntilPm rdf:type rdf:Property ;
    rdfs:label 'Remaining Until Pm' ;
    rdfs:comment 'Calculated remaining usage (in the meter\'s unit of measure) before the next PM task is due (PM due-at value minus current reading value). Supports proactive maintenance scheduling and fleet availability planning.' ;
    rdfs:domain ind:MeterReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rolloverFlag rdf:type rdf:Property ;
    rdfs:label 'Rollover Flag' ;
    rdfs:comment 'Indicates whether the meter counter rolled over (reset to zero) between the previous and current reading, as can occur with odometers reaching maximum counter capacity. When true, incremental usage is adjusted for rollover in PM calculations.' ;
    rdfs:domain ind:MeterReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceReadingReference rdf:type rdf:Property ;
    rdfs:label 'Source Reading Reference' ;
    rdfs:comment 'The native identifier of this meter reading record in the originating source system (Infor EAM, SAP PM, or Geotab). Enables idempotent upserts and cross-system reconciliation in the Databricks Silver Layer.' ;
    rdfs:domain ind:MeterReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceFlag rdf:type rdf:Property ;
    rdfs:label 'Variance Flag' ;
    rdfs:comment 'Indicates whether the reading value deviates from the expected value beyond the configured tolerance threshold. True when the absolute variance exceeds the asset\'s defined variance tolerance, triggering a review workflow in Infor EAM.' ;
    rdfs:domain ind:MeterReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:varianceFromExpected rdf:type rdf:Property ;
    rdfs:label 'Variance From Expected' ;
    rdfs:comment 'Numeric difference between the actual reading value and the expected reading value (actual minus expected). Positive values indicate higher-than-expected usage; negative values indicate lower-than-expected usage. Used to flag anomalous readings for review.' ;
    rdfs:domain ind:MeterReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:variancePct rdf:type rdf:Property ;
    rdfs:label 'Variance Pct' ;
    rdfs:comment 'Percentage deviation of the actual reading from the expected reading value, expressed as a decimal (e.g., 0.1500 = 15%). Supports threshold-based alerting and trend analysis for asset utilization anomalies.' ;
    rdfs:domain ind:MeterReading ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partsCatalogId rdf:type rdf:Property ;
    rdfs:label 'Parts Catalog Id' ;
    rdfs:comment 'Unique surrogate identifier for each part record in the master parts catalog. Primary key for the parts_catalog data product. Entity role: MASTER_RESOURCE.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PartsCatalog .

ind:disposalWasteCodeId rdf:type rdf:Property ;
    rdfs:label 'Disposal Waste Code Id' ;
    rdfs:comment 'Foreign key linking to hazmat.waste_code. Business justification: Parts containing hazardous materials (batteries, mercury switches, PCB capacitors) must link to EPA waste codes for disposal planning, waste characterization, and regulatory compliance. Essential for ' ;
    rdfs:domain ind:PartsCatalog ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WasteCode .

ind:materialId rdf:type rdf:Property ;
    rdfs:label 'Material Id' ;
    rdfs:comment 'Foreign key linking to procurement.material. Business justification: Parts catalog entries map to procurement material master for standardized purchasing. Enables consolidated sourcing, contract pricing application, hazmat compliance validation (RCRA codes, UN numbers)' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Material .

ind:preferredSupplierVendorId rdf:type rdf:Property ;
    rdfs:label 'Preferred Supplier Vendor Id' ;
    rdfs:comment 'FK to procurement.vendor' ;
    rdfs:domain ind:PartsCatalog ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:requiredPpeIssuanceId rdf:type rdf:Property ;
    rdfs:label 'Required Ppe Issuance Id' ;
    rdfs:comment 'Foreign key linking to safety.ppe_issuance. Business justification: Certain parts require specific PPE for handling (hazmat gloves for batteries, respirators for chemicals, cut-resistant gloves for sharp components). Real business need: worker protection during parts ' ;
    rdfs:domain ind:PartsCatalog ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PpeIssuance .

ind:catalogEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Catalog Effective Date' ;
    rdfs:comment 'Date on which this part record became effective and available for use in work orders and purchasing. Supports catalog version management and historical BOM accuracy.' ;
    rdfs:domain ind:PartsCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:coreChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Core Charge Amount' ;
    rdfs:comment 'Refundable deposit amount charged by the supplier for a remanufactured part\'s core. Credited back upon return of the used core. Expressed in USD. Applicable only when is_core_returnable is True.' ;
    rdfs:domain ind:PartsCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dotInspectionPart rdf:type rdf:Property ;
    rdfs:label 'Dot Inspection Part' ;
    rdfs:comment 'Indicates whether this part is a safety-critical component subject to Department of Transportation (DOT) vehicle inspection requirements (True). Examples include brake components, tires, lights, and steering parts. Ensures compliance tracking for DOT roadworthiness inspections.' ;
    rdfs:domain ind:PartsCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:expectedServiceLifeDays rdf:type rdf:Property ;
    rdfs:label 'Expected Service Life Days' ;
    rdfs:comment 'Manufacturer or engineering-specified expected useful service life of the part in calendar days under normal operating conditions. Used for PM interval planning, lifecycle cost analysis, and asset reliability modeling.' ;
    rdfs:domain ind:PartsCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hazmatClass rdf:type rdf:Property ;
    rdfs:label 'Hazmat Class' ;
    rdfs:comment 'DOT hazardous material classification code for the part when is_hazardous_material is True (e.g., Class 3 Flammable Liquid, Class 8 Corrosive, Class 9 Miscellaneous). Required for compliant storage, handling, and disposal documentation.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCoreReturnable rdf:type rdf:Property ;
    rdfs:label 'Is Core Returnable' ;
    rdfs:comment 'Indicates whether a core (used/rebuildable) part must be returned to the supplier upon installation of a replacement (True). Common for remanufactured parts such as alternators, starters, and hydraulic pumps. Drives core charge tracking in procurement.' ;
    rdfs:domain ind:PartsCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHazardousMaterial rdf:type rdf:Property ;
    rdfs:label 'Is Hazardous Material' ;
    rdfs:comment 'Indicates whether this part or material is classified as a hazardous material requiring special handling, storage, and disposal procedures under DOT, EPA, and OSHA regulations (e.g., certain fluids, batteries, refrigerants). True = hazardous; False = non-hazardous.' ;
    rdfs:domain ind:PartsCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSerialized rdf:type rdf:Property ;
    rdfs:label 'Is Serialized' ;
    rdfs:comment 'Indicates whether individual units of this part are tracked by unique serial number (True) or managed as bulk/lot inventory (False). Serialized parts (e.g., engines, transmissions, compactors) require individual asset tracking in Infor EAM.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastCostReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Cost Review Date' ;
    rdfs:comment 'Date on which the standard cost for this part was last reviewed and updated. Supports annual cost roll-up processes and ensures standard costs remain aligned with market pricing.' ;
    rdfs:domain ind:PartsCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maximumStockQuantity rdf:type rdf:Property ;
    rdfs:label 'Maximum Stock Quantity' ;
    rdfs:comment 'Maximum allowable on-hand inventory quantity to prevent overstocking and excess carrying costs. Used in min-max inventory planning. Expressed in the part\'s unit of measure.' ;
    rdfs:domain ind:PartsCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumStockQuantity rdf:type rdf:Property ;
    rdfs:label 'Minimum Stock Quantity' ;
    rdfs:comment 'Safety stock level — the absolute minimum quantity that must be maintained on hand to prevent stockouts during lead time. Distinct from reorder_point which is the trigger level. Expressed in the part\'s unit of measure.' ;
    rdfs:domain ind:PartsCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:obsoleteDate rdf:type rdf:Property ;
    rdfs:label 'Obsolete Date' ;
    rdfs:comment 'Date on which this part was designated as obsolete or discontinued. After this date, the part is no longer available for new work orders or purchase orders. Null if the part is still active.' ;
    rdfs:domain ind:PartsCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:oemPartNumber rdf:type rdf:Property ;
    rdfs:label 'Oem Part Number' ;
    rdfs:comment 'The Original Equipment Manufacturer (OEM) part number as assigned by the vehicle or equipment manufacturer (e.g., Mack Trucks, Heil Environmental, McNeilus). Used for cross-referencing with manufacturer catalogs and sourcing OEM replacements.' ;
    rdfs:domain ind:PartsCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partCategory rdf:type rdf:Property ;
    rdfs:label 'Part Category' ;
    rdfs:comment 'High-level classification of the part by functional system or component group. Drives Bill of Materials (BOM) organization, work order planning, and inventory segmentation. [ENUM-REF-CANDIDATE: engine|hydraulic|electrical|body|tire|filter|fluid|brake|transmission|exhaust|pneumatic|safety|chassis|cooling|fuel|waste_body|compaction|lift_system|cab — promote to reference product]' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partDescription rdf:type rdf:Property ;
    rdfs:label 'Part Description' ;
    rdfs:comment 'Detailed technical description of the part including specifications, dimensions, material composition, and application context. Supports technician identification and procurement accuracy.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partName rdf:type rdf:Property ;
    rdfs:label 'Part Name' ;
    rdfs:comment 'Human-readable short name or title of the part (e.g., \'Hydraulic Pump Assembly\', \'Air Filter Element\', \'Brake Caliper\'). Used as the primary identity label for display in work orders, purchase orders, and inventory reports.' ;
    rdfs:domain ind:PartsCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partStatus rdf:type rdf:Property ;
    rdfs:label 'Part Status' ;
    rdfs:comment 'Current lifecycle status of the part in the catalog. Active parts are available for use in work orders and purchasing. Obsolete parts are no longer procured. Superseded parts have been replaced by a newer part number. Pending_approval parts are under review before activation.' ;
    rdfs:domain ind:PartsCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partType rdf:type rdf:Property ;
    rdfs:label 'Part Type' ;
    rdfs:comment 'Classification of the part by its maintenance disposition: consumable (single-use, e.g., filters, fluids), repairable (can be rebuilt), rotable (tracked serialized item returned to stock after repair), expendable (low-cost, not tracked), or capital (high-value tracked asset component).' ;
    rdfs:domain ind:PartsCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pmApplicable rdf:type rdf:Property ;
    rdfs:label 'Pm Applicable' ;
    rdfs:comment 'Indicates whether this part is used in scheduled Preventive Maintenance (PM) cycles (True) versus only in corrective/unplanned repairs (False). Drives PM parts kit planning and stocking strategies.' ;
    rdfs:domain ind:PartsCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sdsNumber rdf:type rdf:Property ;
    rdfs:label 'Sds Number' ;
    rdfs:comment 'Reference number for the Safety Data Sheet (SDS) associated with this part or material. Required by OSHA Hazard Communication Standard for hazardous chemicals. Enables technicians to access handling, storage, and emergency response information.' ;
    rdfs:domain ind:PartsCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardCost rdf:type rdf:Property ;
    rdfs:label 'Standard Cost' ;
    rdfs:comment 'Standard cost per unit of measure for the part as maintained in the cost accounting system. Used for work order cost estimation, budget planning, and variance analysis. Expressed in USD. Corresponds to the standard price in SAP MM Material Master costing view.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warrantyDurationDays rdf:type rdf:Property ;
    rdfs:label 'Warranty Duration Days' ;
    rdfs:comment 'Standard warranty period in calendar days provided by the manufacturer or supplier for this part. Used to track warranty claims and determine eligibility for no-cost replacements on failed parts.' ;
    rdfs:domain ind:PartsCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:weightLbs rdf:type rdf:Property ;
    rdfs:label 'Weight Lbs' ;
    rdfs:comment 'Physical weight of the part in pounds. Used for shipping cost estimation, DOT weight compliance on service vehicles, and ergonomic safety assessments for technician handling under OSHA guidelines.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partsInventoryId rdf:type rdf:Property ;
    rdfs:label 'Parts Inventory Id' ;
    rdfs:comment 'Unique surrogate identifier for each parts inventory record representing the on-hand stock position of a specific part at a specific storeroom and bin location. Primary key for the parts_inventory data product in the Databricks Silver Layer.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryPartsCatalogId rdf:type rdf:Property ;
    rdfs:label 'Primary Parts Catalog Id' ;
    rdfs:comment 'Reference to the part master record in the parts catalog. Links this inventory position to the part definition including description, specifications, and classification. Sourced from Infor EAM parts catalog.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PartsCatalog .

ind:storeroomId rdf:type rdf:Property ;
    rdfs:label 'Storeroom Id' ;
    rdfs:comment 'Reference to the maintenance storeroom or warehouse location where this part inventory is physically held. Each storeroom is associated with a facility or depot serving fleet and facility maintenance operations.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Storeroom .

ind:abcClassification rdf:type rdf:Property ;
    rdfs:label 'Abc Classification' ;
    rdfs:comment 'ABC analysis classification of the part based on annual consumption value. \'A\' items represent high-value/high-usage parts requiring tight inventory control; \'B\' items are moderate; \'C\' items are low-value/low-usage parts. Used to prioritize cycle count frequency and inventory management effort.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualUsageQuantity rdf:type rdf:Property ;
    rdfs:label 'Annual Usage Quantity' ;
    rdfs:comment 'Total quantity of this part issued from this storeroom over the trailing 12-month period. Used for ABC classification, reorder point calculation, safety stock sizing, and inventory carrying cost analysis. Updated periodically from goods issue history.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:binLocation rdf:type rdf:Property ;
    rdfs:label 'Bin Location' ;
    rdfs:comment 'Specific bin, shelf, rack, or aisle location within the storeroom where the part is physically stored (e.g., \'A-12-3\', \'RACK-B-SHELF-4\'). Enables efficient parts picking during work order execution and physical inventory counts.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countVarianceQuantity rdf:type rdf:Property ;
    rdfs:label 'Count Variance Quantity' ;
    rdfs:comment 'Difference between last_count_quantity and the system quantity_on_hand at the time of the physical count. Positive values indicate more stock found than recorded; negative values indicate shrinkage or unrecorded usage. Used to trigger inventory adjustments and investigate discrepancies.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:criticalityLevel rdf:type rdf:Property ;
    rdfs:label 'Criticality Level' ;
    rdfs:comment 'Classification of the part\'s operational criticality based on the impact of a stockout on fleet or facility operations. \'critical\' parts (e.g., DOT-required safety components, CNG system parts) cause immediate vehicle out-of-service if unavailable. Used to prioritize reorder actions and safety stock levels.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleCountFrequency rdf:type rdf:Property ;
    rdfs:label 'Cycle Count Frequency' ;
    rdfs:comment 'Required frequency for physical cycle counting of this part at this storeroom. Typically driven by ABC classification (A=monthly, B=quarterly, C=annual) and criticality level. Used to schedule cycle count tasks and ensure inventory accuracy for SOX compliance.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryValue rdf:type rdf:Property ;
    rdfs:label 'Inventory Value' ;
    rdfs:comment 'Total monetary value of the on-hand inventory for this part at this storeroom, calculated as quantity_on_hand multiplied by unit_cost. Expressed in USD. Used for balance sheet inventory asset reporting, carrying cost analysis, and financial close processes per GAAP/IFRS.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isHazardous rdf:type rdf:Property ;
    rdfs:label 'Is Hazardous' ;
    rdfs:comment 'Indicates whether this part or material is classified as hazardous under DOT, EPA, or OSHA regulations (e.g., solvents, lubricants, refrigerants, battery acid). Triggers special handling, storage, and disposal requirements. True = hazardous material requiring regulatory compliance controls.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLotControlled rdf:type rdf:Property ;
    rdfs:label 'Is Lot Controlled' ;
    rdfs:comment 'Indicates whether this part is managed by lot or batch number for traceability purposes (True). Lot-controlled parts (e.g., lubricants, chemicals, safety-critical components) require lot tracking for quality control, recall management, and regulatory compliance.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastCountQuantity rdf:type rdf:Property ;
    rdfs:label 'Last Count Quantity' ;
    rdfs:comment 'Actual quantity recorded during the most recent physical inventory count for this part at this storeroom. Compared against the system quantity_on_hand to identify and reconcile inventory discrepancies.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastIssueDate rdf:type rdf:Property ;
    rdfs:label 'Last Issue Date' ;
    rdfs:comment 'Date on which the most recent stock issue (goods issue to a work order or cost center) was posted for this part at this storeroom. Used to identify slow-moving or obsolete inventory and support inventory rationalization decisions.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Last Receipt Date' ;
    rdfs:comment 'Date on which the most recent stock receipt (goods receipt from a purchase order or transfer) was posted for this part at this storeroom. Used to assess replenishment frequency and identify slow-moving or dormant inventory.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maxStockLevel rdf:type rdf:Property ;
    rdfs:label 'Max Stock Level' ;
    rdfs:comment 'Maximum quantity of the part that should be held in the storeroom at any time. Used to prevent overstocking, control carrying costs, and optimize storeroom space utilization. Replenishment orders are sized to bring stock up to but not exceed this level.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minStockLevel rdf:type rdf:Property ;
    rdfs:label 'Min Stock Level' ;
    rdfs:comment 'Minimum reorder point quantity below which a replenishment requisition or purchase order should be triggered. Used by the CMMS to generate automatic reorder alerts and prevent stockouts that could cause fleet or facility downtime.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextCycleCountDate rdf:type rdf:Property ;
    rdfs:label 'Next Cycle Count Date' ;
    rdfs:comment 'Scheduled date for the next physical cycle count of this part at this storeroom. Calculated based on last_physical_count_date and cycle_count_frequency. Used by storeroom supervisors to plan and assign counting tasks.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quantityOnOrder rdf:type rdf:Property ;
    rdfs:label 'Quantity On Order' ;
    rdfs:comment 'Total quantity of the part currently on open Purchase Orders (POs) that have been issued to suppliers but not yet received into the storeroom. Used for replenishment planning and projected stock availability calculations.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyStockQuantity rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Quantity' ;
    rdfs:comment 'Buffer stock quantity maintained above the minimum stock level to protect against demand variability and supplier lead time uncertainty. Particularly important for critical fleet parts (e.g., DOT-required components) where stockouts cause vehicle out-of-service events.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shelfLifeDays rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Days' ;
    rdfs:comment 'Maximum number of days this part can be stored before it expires or degrades and must be disposed of (e.g., lubricants, adhesives, rubber seals, safety equipment with expiry dates). Null for parts with no shelf life restriction. Used to manage FIFO rotation and prevent use of expired materials.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:partsUsageId rdf:type rdf:Property ;
    rdfs:label 'Parts Usage Id' ;
    rdfs:comment 'Unique surrogate identifier for each parts usage transaction record in the Silver Layer lakehouse. Primary key for this transactional line entity.' ;
    rdfs:domain ind:PartsUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:generatedWasteProfileId rdf:type rdf:Property ;
    rdfs:label 'Generated Waste Profile Id' ;
    rdfs:comment 'Foreign key linking to hazmat.waste_profile. Business justification: Hazardous parts replacement transactions must reference waste profiles for disposal tracking, manifest preparation, and cost allocation. Critical for tracking waste generation at the transaction level' ;
    rdfs:domain ind:PartsUsage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WasteProfile .

ind:bomReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Bom Reference Number' ;
    rdfs:comment 'Reference to the Bill of Materials (BOM) component line from which this parts usage was derived. Enables traceability from actual consumption back to the planned maintenance BOM for variance analysis.' ;
    rdfs:domain ind:PartsUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dotInspectionRelated rdf:type rdf:Property ;
    rdfs:label 'Dot Inspection Related' ;
    rdfs:comment 'Indicates whether the parts usage was associated with a DOT-required vehicle inspection or compliance repair. Supports regulatory reporting for DOT out-of-service violations and fleet compliance audits.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:goodsIssueNumber rdf:type rdf:Property ;
    rdfs:label 'Goods Issue Number' ;
    rdfs:comment 'SAP MM goods issue document number generated at the time of physical parts issuance from inventory. Provides cross-system traceability between Infor EAM work order and SAP MM inventory movement.' ;
    rdfs:domain ind:PartsUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatPartFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Part Flag' ;
    rdfs:comment 'Indicates whether the part or material is classified as hazardous (e.g., certain lubricants, solvents, refrigerants). Triggers special handling, storage, and disposal requirements per EPA and OSHA regulations.' ;
    rdfs:domain ind:PartsUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issueStatus rdf:type rdf:Property ;
    rdfs:label 'Issue Status' ;
    rdfs:comment 'Current lifecycle status of the parts issuance transaction. Tracks progression from initial request through reservation, physical issuance, and potential return. Satisfies TRANSACTION_LINE LINE_VALUE_OR_RESULT lifecycle state.' ;
    rdfs:domain ind:PartsUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issueTimestamp rdf:type rdf:Property ;
    rdfs:label 'Issue Timestamp' ;
    rdfs:comment 'Precise date and time when the parts were physically issued from the storeroom. Enables time-of-day analysis for storeroom operations and supports audit trail requirements. Satisfies TRANSACTION_HEADER BUSINESS_EVENT_TIMESTAMP category.' ;
    rdfs:domain ind:PartsUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:quantityIssued rdf:type rdf:Property ;
    rdfs:label 'Quantity Issued' ;
    rdfs:comment 'Actual number of units physically dispensed from the storeroom to the work order. May differ from quantity requested due to partial availability or over-issuance. Satisfies TRANSACTION_LINE LINE_QUANTITY category.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityRequested rdf:type rdf:Property ;
    rdfs:label 'Quantity Requested' ;
    rdfs:comment 'Number of units of the part originally requested by the technician or planner for the work order. Compared against quantity issued to identify fulfillment gaps and partial issuances.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityReturned rdf:type rdf:Property ;
    rdfs:label 'Quantity Returned' ;
    rdfs:comment 'Number of units returned to the storeroom after work order completion because they were not consumed. Used to calculate net consumption and adjust inventory balances.' ;
    rdfs:domain ind:PartsUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reorderTriggeredFlag rdf:type rdf:Property ;
    rdfs:label 'Reorder Triggered Flag' ;
    rdfs:comment 'Indicates whether this parts issuance triggered an automatic reorder request because inventory fell below the minimum reorder point. Supports proactive inventory replenishment and prevents stockout-driven maintenance delays.' ;
    rdfs:domain ind:PartsUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reservationNumber rdf:type rdf:Property ;
    rdfs:label 'Reservation Number' ;
    rdfs:comment 'Externally-known reservation or pick ticket number generated when parts are reserved against a work order prior to physical issuance. Enables pre-staging and kitting of parts for planned maintenance. Satisfies TRANSACTION_HEADER BUSINESS_IDENTIFIER category.' ;
    rdfs:domain ind:PartsUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnDate rdf:type rdf:Property ;
    rdfs:label 'Return Date' ;
    rdfs:comment 'Date on which unused parts were returned to the storeroom after work order completion. Null if no parts were returned. Used to calculate net consumption and storeroom restocking timelines.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:workOrderType rdf:type rdf:Property ;
    rdfs:label 'Work Order Type' ;
    rdfs:comment 'Classification of the parent work order type indicating whether parts were consumed for planned preventive maintenance (PM), unplanned corrective repair, scheduled inspection, major overhaul, or emergency breakdown response.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskListId rdf:type rdf:Property ;
    rdfs:label 'Task List Id' ;
    rdfs:comment 'Reference to the standardized task list (checklist of operations) associated with this PM schedule. The task list defines the specific maintenance operations, inspection steps, and parts required. Sourced from Infor EAM task list master or SAP PM task list.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TaskList .

ind:autoWoGeneration rdf:type rdf:Property ;
    rdfs:label 'Auto Wo Generation' ;
    rdfs:comment 'Indicates whether work orders are automatically generated by the CMMS (Infor EAM or SAP PM) when the PM due date or meter threshold is reached. When false, a planner must manually release the work order. Supports both automated and manual scheduling workflows.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:frequencyInterval rdf:type rdf:Property ;
    rdfs:label 'Frequency Interval' ;
    rdfs:comment 'Numeric value representing how often the PM task recurs, interpreted in conjunction with frequency_unit. For example, a value of 90 with frequency_unit of \'days\' means every 90 days. For meter-based plans, this is the meter increment (e.g., 5000 miles).' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:frequencyUnit rdf:type rdf:Property ;
    rdfs:label 'Frequency Unit' ;
    rdfs:comment 'Unit of measure for the frequency_interval. Defines whether the PM cycle is driven by elapsed time (days, weeks, months) or asset utilization meters (miles, engine_hours, operating_hours). Critical for calculating next due date or meter reading.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalLocationCode rdf:type rdf:Property ;
    rdfs:label 'Functional Location Code' ;
    rdfs:comment 'SAP PM or Infor EAM functional location code identifying the physical installation point or system hierarchy node where the asset is installed (e.g., fleet depot bay, landfill pump station). Supports hierarchical maintenance reporting.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDotInspection rdf:type rdf:Property ;
    rdfs:label 'Is Dot Inspection' ;
    rdfs:comment 'Indicates whether this PM schedule represents a federally mandated Department of Transportation (DOT) vehicle inspection cycle (e.g., annual inspection per 49 CFR Part 396.17). When true, completion records are subject to DOT recordkeeping requirements and regulatory audit.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isEpaRequired rdf:type rdf:Property ;
    rdfs:label 'Is Epa Required' ;
    rdfs:comment 'Indicates whether this PM schedule is mandated by EPA environmental regulations (e.g., landfill gas (LFG) collection system inspections, leachate system checks, or CNG fueling station inspections). When true, records are subject to EPA reporting requirements.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOshaRequired rdf:type rdf:Property ;
    rdfs:label 'Is Osha Required' ;
    rdfs:comment 'Indicates whether this PM schedule is mandated by OSHA regulations (e.g., crane inspections per 29 CFR 1910.179, powered industrial truck inspections per 29 CFR 1910.178). When true, records must be retained per OSHA recordkeeping requirements.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastPerformedDate rdf:type rdf:Property ;
    rdfs:label 'Last Performed Date' ;
    rdfs:comment 'Calendar date on which the most recent PM task was completed for this schedule. Used as the baseline for calculating the next due date for time-based plans. Populated from work order completion records in Infor EAM or SAP PM.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastPerformedMeterReading rdf:type rdf:Property ;
    rdfs:label 'Last Performed Meter Reading' ;
    rdfs:comment 'Odometer (miles) or engine hour meter reading recorded at the time the most recent PM was completed. Used as the baseline for calculating the next due meter reading for meter-based plans. Sourced from Geotab Fleet Telematics or Infor EAM meter readings.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextDueMeterReading rdf:type rdf:Property ;
    rdfs:label 'Next Due Meter Reading' ;
    rdfs:comment 'Calculated odometer or engine hour meter value at which the next PM task must be performed. For meter-based plans, derived from last_performed_meter_reading plus frequency_interval. Null for time-based plans.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceSystemPlanReference rdf:type rdf:Property ;
    rdfs:label 'Source System Plan Reference' ;
    rdfs:comment 'Native identifier of this PM plan record in the originating source system (Infor EAM plan number or SAP PM maintenance plan number). Enables traceability and reconciliation between the lakehouse Silver layer and the operational system of record.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicianRole rdf:type rdf:Property ;
    rdfs:label 'Technician Role' ;
    rdfs:comment 'Skill or trade classification required to perform this PM task. Used for workforce planning and technician qualification matching. Examples include mechanic for engine service, electrician for CNG system checks, or inspector for DOT annual inspections. [ENUM-REF-CANDIDATE: mechanic|electrician|hydraulic_tech|tire_tech|inspector|welder|general_tech — promote to reference product]' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toleranceDays rdf:type rdf:Property ;
    rdfs:label 'Tolerance Days' ;
    rdfs:comment 'Allowable number of days before or after the next_due_date within which the PM task can be completed without being flagged as overdue. Provides scheduling flexibility while maintaining compliance. Negative values indicate early completion tolerance.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:toleranceMeterUnits rdf:type rdf:Property ;
    rdfs:label 'Tolerance Meter Units' ;
    rdfs:comment 'Allowable meter reading variance (miles or engine hours) above or below the next_due_meter_reading within which the PM task can be completed without being flagged as overdue. Applicable only to meter-based PM plans. Null for time-based plans.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:repairHistoryId rdf:type rdf:Property ;
    rdfs:label 'Repair History Id' ;
    rdfs:comment 'Unique surrogate identifier for each closed/archived repair or maintenance event record in the repair history. Primary key for this data product.' ;
    rdfs:domain ind:RepairHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:componentRepaired rdf:type rdf:Property ;
    rdfs:label 'Component Repaired' ;
    rdfs:comment 'Name or description of the specific component, sub-assembly, or system on the asset that was repaired or replaced (e.g., rear axle, hydraulic pump, compactor blade, engine air filter, brake caliper). Supports Bill of Materials (BOM) analysis and component-level MTBF tracking.' ;
    rdfs:domain ind:RepairHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dotInspectionNumber rdf:type rdf:Property ;
    rdfs:label 'Dot Inspection Number' ;
    rdfs:comment 'Official DOT inspection report number assigned by the inspecting authority for DOT-mandated inspections. Required for regulatory compliance documentation and FMCSA audit response. Populated only when is_dot_inspection is True.' ;
    rdfs:domain ind:RepairHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engineHoursAtRepair rdf:type rdf:Property ;
    rdfs:label 'Engine Hours At Repair' ;
    rdfs:comment 'Engine hour meter reading recorded at the time of repair for hour-metered assets (compactors, generators, heavy equipment, Waste-to-Energy (WTE) plant equipment). Used for hour-based PM interval tracking and MTBF analysis where mileage is not applicable.' ;
    rdfs:domain ind:RepairHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isWarrantyClaim rdf:type rdf:Property ;
    rdfs:label 'Is Warranty Claim' ;
    rdfs:comment 'Indicates whether the repair costs are recoverable under an OEM or vendor warranty. When True, triggers the warranty recovery process and cost reclassification from maintenance expense to warranty receivable.' ;
    rdfs:domain ind:RepairHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:odometerAtRepair rdf:type rdf:Property ;
    rdfs:label 'Odometer At Repair' ;
    rdfs:comment 'Odometer reading in miles recorded at the time of repair for wheeled fleet assets (trucks, ASL, FEL, REL vehicles). Used to calculate mileage-based Mean Time Between Failures (MTBF), establish PM trigger intervals, and support DOT inspection compliance records.' ;
    rdfs:domain ind:RepairHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:repairDescription rdf:type rdf:Property ;
    rdfs:label 'Repair Description' ;
    rdfs:comment 'Free-text narrative describing the work performed, findings, corrective actions taken, and any relevant observations by the technician. Provides the detailed maintenance record for audit, warranty claims, and future diagnostic reference.' ;
    rdfs:domain ind:RepairHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repairStatus rdf:type rdf:Property ;
    rdfs:label 'Repair Status' ;
    rdfs:comment 'Lifecycle status of the repair history record. Completed indicates work was finished and verified; closed indicates the WO was formally archived; cancelled indicates the WO was voided; deferred indicates work was postponed and re-scheduled.' ;
    rdfs:domain ind:RepairHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repairType rdf:type rdf:Property ;
    rdfs:label 'Repair Type' ;
    rdfs:comment 'Classification of the maintenance event: corrective (reactive repair after failure), preventive (scheduled Preventive Maintenance (PM) cycle), predictive (condition-based), emergency (unplanned critical failure), or inspection (DOT/regulatory inspection). Drives MTBF and MTTR segmentation.' ;
    rdfs:domain ind:RepairHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subcontractorCost rdf:type rdf:Property ;
    rdfs:label 'Subcontractor Cost' ;
    rdfs:comment 'Cost in US dollars paid to external vendors or subcontractors for work performed on this repair event (e.g., specialized engine rebuilds, body shop work, OEM warranty repairs). Tracked separately from internal labor cost for make-vs-buy analysis.' ;
    rdfs:domain ind:RepairHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supervisorApprovedBy rdf:type rdf:Property ;
    rdfs:label 'Supervisor Approved By' ;
    rdfs:comment 'Name or employee ID of the maintenance supervisor or fleet manager who reviewed and approved the completed repair before work order closure. Required for DOT annual inspection certification and internal quality control.' ;
    rdfs:domain ind:RepairHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicianName rdf:type rdf:Property ;
    rdfs:label 'Technician Name' ;
    rdfs:comment 'Full name of the primary technician who performed the repair, as recorded at the time of work order closure. Retained in the historical record for audit and accountability purposes even if the technician record changes. Classified confidential as it is employee data.' ;
    rdfs:domain ind:RepairHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalRepairCost rdf:type rdf:Property ;
    rdfs:label 'Total Repair Cost' ;
    rdfs:comment 'Total cost in US dollars for the complete repair event, encompassing labor, parts, subcontractor, and any other direct costs. Primary financial metric for asset lifecycle cost analysis, EBITDA impact assessment, and repair vs. replace decision support.' ;
    rdfs:domain ind:RepairHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vmrsSystemCode rdf:type rdf:Property ;
    rdfs:label 'Vmrs System Code' ;
    rdfs:comment 'Three-digit Vehicle Maintenance Reporting Standards (VMRS) system code identifying the major vehicle system affected by the repair (e.g., 011 = Air Brakes, 013 = Cooling System, 032 = Engine). Industry-standard classification for fleet maintenance benchmarking and DOT compliance reporting.' ;
    rdfs:domain ind:RepairHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyClaimNumber rdf:type rdf:Property ;
    rdfs:label 'Warranty Claim Number' ;
    rdfs:comment 'OEM or vendor-assigned warranty claim reference number for repairs covered under warranty. Populated only when is_warranty_claim is True. Used to track warranty recovery status and receivable amounts.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:woNumber rdf:type rdf:Property ;
    rdfs:label 'Wo Number' ;
    rdfs:comment 'Human-readable, externally-known Work Order (WO) number assigned by the CMMS (Infor EAM or SAP PM) at the time the work order was created. Serves as the primary business identifier for cross-system traceability and audit.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partsKitPartsCatalogId rdf:type rdf:Property ;
    rdfs:label 'Parts Kit Parts Catalog Id' ;
    rdfs:comment 'Foreign key linking to maintenance.parts_catalog. Business justification: Service bulletins often specify required parts kits for compliance. Currently has parts_kit_number (STRING) which should be replaced with FK to parts_catalog for proper inventory integration. Removes ' ;
    rdfs:domain ind:ServiceBulletin ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PartsCatalog .

ind:affectedAssetMake rdf:type rdf:Property ;
    rdfs:label 'Affected Asset Make' ;
    rdfs:comment 'Manufacturer or brand of the fleet vehicle or equipment affected by this bulletin (e.g., Mack, Peterbilt, McNeilus, Heil, Leach). Used to filter the fleet asset register in Infor EAM to identify all affected units.' ;
    rdfs:domain ind:ServiceBulletin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedAssetModel rdf:type rdf:Property ;
    rdfs:label 'Affected Asset Model' ;
    rdfs:comment 'Specific model designation of the fleet vehicle or equipment affected by this bulletin (e.g., LR64T, McNeilus Rear Loader, Heil Half/Pack). Combined with make and year range to precisely identify affected assets in the fleet.' ;
    rdfs:domain ind:ServiceBulletin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedComponentCode rdf:type rdf:Property ;
    rdfs:label 'Affected Component Code' ;
    rdfs:comment 'Standardized code identifying the affected component per OEM or internal parts taxonomy. Enables automated BOM lookup and parts reservation in SAP MM and Infor EAM for bulletin-driven work orders.' ;
    rdfs:domain ind:ServiceBulletin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedVinRangeEnd rdf:type rdf:Property ;
    rdfs:label 'Affected Vin Range End' ;
    rdfs:comment 'Ending Vehicle Identification Number (VIN) of the range of vehicles affected by this bulletin. Null if the bulletin applies to all VINs from affected_vin_range_start onward or if VIN-range scoping is not applicable.' ;
    rdfs:domain ind:ServiceBulletin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedVinRangeStart rdf:type rdf:Property ;
    rdfs:label 'Affected Vin Range Start' ;
    rdfs:comment 'Starting Vehicle Identification Number (VIN) of the range of vehicles affected by this bulletin, as specified by the OEM or NHTSA. Used with affected_vin_range_end to precisely identify affected fleet units beyond make/model/year filtering.' ;
    rdfs:domain ind:ServiceBulletin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedYearFrom rdf:type rdf:Property ;
    rdfs:label 'Affected Year From' ;
    rdfs:comment 'Starting model year (inclusive) of the asset range affected by this bulletin. Combined with affected_year_to to define the model year band for fleet asset identification and compliance scoping.' ;
    rdfs:domain ind:ServiceBulletin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedYearTo rdf:type rdf:Property ;
    rdfs:label 'Affected Year To' ;
    rdfs:comment 'Ending model year (inclusive) of the asset range affected by this bulletin. Null if the bulletin applies to all model years from affected_year_from onward. Used with affected_year_from to scope fleet compliance queries.' ;
    rdfs:domain ind:ServiceBulletin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bulletinDescription rdf:type rdf:Property ;
    rdfs:label 'Bulletin Description' ;
    rdfs:comment 'Full narrative description of the bulletin including the problem statement, root cause, risk assessment, and corrective action required. Sourced from the OEM technical service notice or internal engineering documentation. Referenced by technicians during work order execution.' ;
    rdfs:domain ind:ServiceBulletin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bulletinNumber rdf:type rdf:Property ;
    rdfs:label 'Bulletin Number' ;
    rdfs:comment 'Externally-known alphanumeric identifier assigned by the issuing organization (OEM, internal engineering, or DOT) to uniquely identify this bulletin. Used for cross-referencing with manufacturer recall databases, DOT safety notices, and internal CMMS work order execution in SAP PM and Infor EAM.' ;
    rdfs:domain ind:ServiceBulletin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bulletinStatus rdf:type rdf:Property ;
    rdfs:label 'Bulletin Status' ;
    rdfs:comment 'Current lifecycle state of the service bulletin. Active bulletins require fleet action; superseded bulletins have been replaced by a newer revision; cancelled bulletins are withdrawn by the issuer; expired bulletins have passed their compliance deadline without regulatory consequence.' ;
    rdfs:domain ind:ServiceBulletin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bulletinTitle rdf:type rdf:Property ;
    rdfs:label 'Bulletin Title' ;
    rdfs:comment 'Short descriptive title of the service bulletin as issued by the originating organization. Provides a human-readable summary of the bulletin subject for fleet maintenance staff and compliance officers.' ;
    rdfs:domain ind:ServiceBulletin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bulletinType rdf:type rdf:Property ;
    rdfs:label 'Bulletin Type' ;
    rdfs:comment 'Classification of the bulletin by its nature and urgency. Safety recalls are mandated by NHTSA or OEM; mandatory repairs are required for continued operation; recommended repairs are advisory; informational bulletins provide technical guidance; regulatory notices originate from DOT/OSHA/EPA; field service actions are OEM-initiated campaigns.' ;
    rdfs:domain ind:ServiceBulletin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionRatePct rdf:type rdf:Property ;
    rdfs:label 'Completion Rate Pct' ;
    rdfs:comment 'Percentage of total affected assets for which the bulletin corrective action has been completed (completed assets / total affected assets × 100). Provides a real-time compliance posture metric for fleet managers and regulatory reporting.' ;
    rdfs:domain ind:ServiceBulletin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:completionStatus rdf:type rdf:Property ;
    rdfs:label 'Completion Status' ;
    rdfs:comment 'Aggregate completion status of the bulletin across all affected fleet assets in Waste Management\'s fleet. Tracks overall compliance posture for the bulletin. Detailed per-asset completion is tracked in the bulletin_asset_compliance association table.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceDeadline rdf:type rdf:Property ;
    rdfs:label 'Compliance Deadline' ;
    rdfs:comment 'Date by which all affected fleet assets must have the bulletin action completed to remain in regulatory or OEM compliance. Null for informational bulletins with no mandatory deadline. Drives prioritization of PM work orders and DOT inspection readiness.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveAction rdf:type rdf:Property ;
    rdfs:label 'Corrective Action' ;
    rdfs:comment 'Specific repair, inspection, or modification procedure required to address the bulletin. Describes the technical steps technicians must perform, referencing OEM repair manuals or internal engineering procedures. Populates the task description in SAP PM work orders.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dotInspectionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Dot Inspection Required Flag' ;
    rdfs:comment 'Indicates whether completion of this bulletin requires a formal DOT (Department of Transportation) inspection or roadworthiness certification (True). Triggers DOT inspection workflow in SAP EHS and Enviance EHS upon work order completion.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuingOrganization rdf:type rdf:Property ;
    rdfs:label 'Issuing Organization' ;
    rdfs:comment 'Name of the organization that issued the bulletin, such as the OEM (e.g., Mack Trucks, McNeilus, Heil), a regulatory body (DOT, OSHA, EPA), or Waste Management internal engineering. Determines the authority level and compliance obligation of the bulletin.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingOrganizationType rdf:type rdf:Property ;
    rdfs:label 'Issuing Organization Type' ;
    rdfs:comment 'Category of the organization that issued the bulletin. Drives compliance workflow routing: OEM bulletins route to fleet maintenance; DOT/OSHA/EPA bulletins route to environmental compliance and safety teams; internal engineering bulletins route to fleet operations. [ENUM-REF-CANDIDATE: oem|internal_engineering|dot|osha|epa|state_agency|industry_association — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ServiceBulletin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mandatoryFlag rdf:type rdf:Property ;
    rdfs:label 'Mandatory Flag' ;
    rdfs:comment 'Indicates whether compliance with this bulletin is mandatory (True) or optional/advisory (False). Mandatory bulletins trigger automatic work order creation in SAP PM and Infor EAM and may affect DOT roadworthiness certification.' ;
    rdfs:domain ind:ServiceBulletin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nhtsaRecallNumber rdf:type rdf:Property ;
    rdfs:label 'Nhtsa Recall Number' ;
    rdfs:comment 'National Highway Traffic Safety Administration (NHTSA) recall campaign number associated with this bulletin, in the format YYVnnnnnn (e.g., 23V123456). Populated for safety recalls mandated by NHTSA. Enables cross-referencing with the NHTSA public recall database for compliance verification.' ;
    rdfs:domain ind:ServiceBulletin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oemWarrantyCoveredFlag rdf:type rdf:Property ;
    rdfs:label 'Oem Warranty Covered Flag' ;
    rdfs:comment 'Indicates whether the OEM will cover the cost of parts and/or labor for this bulletin under an active warranty or recall program (True) or whether Waste Management bears the cost (False). Drives warranty claim processing in SAP SD and cost allocation in SAP FI/CO.' ;
    rdfs:domain ind:ServiceBulletin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiredTechnicianCertification rdf:type rdf:Property ;
    rdfs:label 'Required Technician Certification' ;
    rdfs:comment 'Certification or qualification required for the technician performing the bulletin corrective action (e.g., ASE Master Technician, CNG Fuel System Certified, CDL Class B, OEM-specific certification). Used for technician assignment in SAP PM and Workday HCM workforce planning.' ;
    rdfs:domain ind:ServiceBulletin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyCriticalFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Critical Flag' ;
    rdfs:comment 'Indicates whether the bulletin addresses a safety-critical defect or condition (True) that could result in injury, accident, or regulatory violation if not addressed. Safety-critical bulletins trigger immediate fleet grounding review and OSHA/DOT notification workflows.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supersededByBulletinNumber rdf:type rdf:Property ;
    rdfs:label 'Superseded By Bulletin Number' ;
    rdfs:comment 'Bulletin number of the newer revision that replaces this bulletin when bulletin_status is \'superseded\'. Enables traceability of bulletin revision history and ensures technicians reference the most current corrective action procedures.' ;
    rdfs:domain ind:ServiceBulletin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalAffectedAssets rdf:type rdf:Property ;
    rdfs:label 'Total Affected Assets' ;
    rdfs:comment 'Count of fleet assets within Waste Management\'s fleet that are identified as affected by this bulletin, as determined at the time of bulletin intake. Used for compliance planning, resource allocation, and executive reporting on recall exposure.' ;
    rdfs:domain ind:ServiceBulletin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentStoreroomId rdf:type rdf:Property ;
    rdfs:label 'Parent Storeroom Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the parent storeroom in a hierarchical storeroom network (e.g., a satellite storeroom references its central hub storeroom). Enables multi-tier inventory replenishment and inter-storeroom transfer management.' ;
    rdfs:domain ind:Storeroom ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Storeroom .

ind:binLocationCount rdf:type rdf:Property ;
    rdfs:label 'Bin Location Count' ;
    rdfs:comment 'Total number of discrete bin, shelf, or rack locations within the storeroom. Drives bin-level inventory tracking configuration in the CMMS and determines the granularity of parts storage management.' ;
    rdfs:domain ind:Storeroom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eamStoreroomRef rdf:type rdf:Property ;
    rdfs:label 'Eam Storeroom Ref' ;
    rdfs:comment 'External reference identifier for this storeroom as recorded in the Infor EAM system. Used for cross-system reconciliation between the lakehouse silver layer and the operational CMMS source of record.' ;
    rdfs:domain ind:Storeroom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:establishedDate rdf:type rdf:Property ;
    rdfs:label 'Established Date' ;
    rdfs:comment 'Date on which the storeroom was formally established and made operational. Used for asset lifecycle tracking, depreciation scheduling, and historical inventory network analysis.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fireSuppressionType rdf:type rdf:Property ;
    rdfs:label 'Fire Suppression Type' ;
    rdfs:comment 'Type of fire suppression system installed in the storeroom. Required for OSHA and local fire code compliance, particularly for storerooms holding flammable lubricants, solvents, or compressed gas cylinders.' ;
    rdfs:domain ind:Storeroom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatPermitExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Hazmat Permit Expiry Date' ;
    rdfs:comment 'Expiration date of the hazardous materials storage permit for this storeroom. Triggers permit renewal workflows and compliance alerts to prevent lapse of regulatory authorization.' ;
    rdfs:domain ind:Storeroom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:hazmatPermitNumber rdf:type rdf:Property ;
    rdfs:label 'Hazmat Permit Number' ;
    rdfs:comment 'Regulatory permit number issued by the applicable authority (EPA, state environmental agency, or local fire marshal) authorizing hazardous materials storage at this storeroom. Required when is_hazmat_certified is true.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryValuationMethod rdf:type rdf:Property ;
    rdfs:label 'Inventory Valuation Method' ;
    rdfs:comment 'Accounting method used to value parts inventory held in this storeroom. Standard cost uses predetermined prices; moving average recalculates cost with each receipt; FIFO and LIFO are queue-based methods. Determines how parts cost flows to work orders and financial statements.' ;
    rdfs:domain ind:Storeroom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBonded rdf:type rdf:Property ;
    rdfs:label 'Is Bonded' ;
    rdfs:comment 'Indicates whether the storeroom operates as a bonded (secured, access-controlled) inventory location where parts are tracked under formal custody and issuance controls. Bonded storerooms require documented check-in/check-out procedures and are subject to periodic audits.' ;
    rdfs:domain ind:Storeroom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isClimateControlled rdf:type rdf:Property ;
    rdfs:label 'Is Climate Controlled' ;
    rdfs:comment 'Indicates whether the storeroom maintains controlled temperature and humidity conditions. Climate-controlled storerooms are required for storing temperature-sensitive parts such as electronic control modules, batteries, lubricants, and certain chemical supplies.' ;
    rdfs:domain ind:Storeroom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHazmatCertified rdf:type rdf:Property ;
    rdfs:label 'Is Hazmat Certified' ;
    rdfs:comment 'Indicates whether the storeroom is certified to store hazardous materials such as solvents, lubricants, batteries, and other regulated substances. Certification requires compliance with EPA, DOT, and OSHA hazmat storage regulations.' ;
    rdfs:domain ind:Storeroom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVendorManaged rdf:type rdf:Property ;
    rdfs:label 'Is Vendor Managed' ;
    rdfs:comment 'Indicates whether inventory replenishment for this storeroom is managed by an external vendor under a Vendor Managed Inventory (VMI) agreement. VMI storerooms have supplier-controlled reorder triggers and consignment stock arrangements.' ;
    rdfs:domain ind:Storeroom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastCycleCountDate rdf:type rdf:Property ;
    rdfs:label 'Last Cycle Count Date' ;
    rdfs:comment 'Date on which the most recent physical inventory cycle count was completed for this storeroom. Used to track compliance with cycle count schedules and identify storerooms overdue for physical verification.' ;
    rdfs:domain ind:Storeroom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maxInventoryValueUsd rdf:type rdf:Property ;
    rdfs:label 'Max Inventory Value Usd' ;
    rdfs:comment 'Authorized maximum dollar value of parts inventory that may be held in this storeroom at any time. Used for capital budgeting, insurance coverage determination, and inventory investment controls. Expressed in US dollars.' ;
    rdfs:domain ind:Storeroom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryCostCenterCode rdf:type rdf:Property ;
    rdfs:label 'Primary Cost Center Code' ;
    rdfs:comment 'SAP cost center code to which storeroom operating expenses (overhead, labor, utilities) are charged. Enables financial reporting of storeroom costs within the maintenance domain P&L.' ;
    rdfs:domain ind:Storeroom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replenishmentMethod rdf:type rdf:Property ;
    rdfs:label 'Replenishment Method' ;
    rdfs:comment 'The inventory replenishment strategy applied to this storeroom. Min/max triggers reorder when stock falls below minimum level; reorder_point uses statistical demand forecasting; kanban uses visual pull signals; vmi delegates replenishment to the vendor; manual requires human-initiated purchase orders.' ;
    rdfs:domain ind:Storeroom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapStorageLocationCode rdf:type rdf:Property ;
    rdfs:label 'Sap Storage Location Code' ;
    rdfs:comment 'Four-character SAP S/4HANA MM storage location code corresponding to this storeroom. Used for purchase order goods receipt, material document posting, and inventory reconciliation between SAP and Infor EAM.' ;
    rdfs:domain ind:Storeroom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityAccessLevel rdf:type rdf:Property ;
    rdfs:label 'Security Access Level' ;
    rdfs:comment 'Physical security access control level for the storeroom. Open storerooms have no access restriction; badge_access requires electronic credential; supervised requires attendant presence; locked requires key/combination access. Drives access control configuration and audit requirements.' ;
    rdfs:domain ind:Storeroom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageCapacitySqft rdf:type rdf:Property ;
    rdfs:label 'Storage Capacity Sqft' ;
    rdfs:comment 'Total physical floor area of the storeroom in square feet. Used for capacity planning, storeroom utilization analysis, and determining maximum parts inventory volume that can be physically accommodated.' ;
    rdfs:domain ind:Storeroom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storeroomCode rdf:type rdf:Property ;
    rdfs:label 'Storeroom Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the storeroom within the enterprise maintenance network. Used in work orders, purchase orders, and parts requisitions to reference the issuing storeroom. Aligns with Infor EAM storeroom code field.' ;
    rdfs:domain ind:Storeroom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storeroomName rdf:type rdf:Property ;
    rdfs:label 'Storeroom Name' ;
    rdfs:comment 'Human-readable descriptive name of the storeroom (e.g., \'Houston Central Fleet Parts Storeroom\', \'Dallas North Satellite Storeroom\'). Used in reports, dashboards, and user interfaces.' ;
    rdfs:domain ind:Storeroom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storeroomStatus rdf:type rdf:Property ;
    rdfs:label 'Storeroom Status' ;
    rdfs:comment 'Current lifecycle status of the storeroom record. Active storerooms are operational and available for parts issuance and receipt. Inactive storerooms are temporarily closed. Decommissioned storerooms are permanently closed and no longer used.' ;
    rdfs:domain ind:Storeroom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storeroomType rdf:type rdf:Property ;
    rdfs:label 'Storeroom Type' ;
    rdfs:comment 'Classification of the storeroom by its operational role within the parts distribution network. Central storerooms serve as primary hubs; satellite storerooms serve regional yards; mobile storerooms are truck-mounted for field use; field_cache are small on-site bins; virtual storerooms represent consignment or vendor-managed inventory locations.' ;
    rdfs:domain ind:Storeroom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subcontractWorkId rdf:type rdf:Property ;
    rdfs:label 'Subcontract Work Id' ;
    rdfs:comment 'Unique surrogate identifier for each subcontracted maintenance work record in the Databricks Silver Layer. Primary key for this entity.' ;
    rdfs:domain ind:SubcontractWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:subcontractorTransporterRegistrationId rdf:type rdf:Property ;
    rdfs:label 'Subcontractor Transporter Registration Id' ;
    rdfs:comment 'Foreign key linking to hazmat.transporter_registration. Business justification: Subcontractors generating or transporting hazardous waste must have verified EPA transporter registration for compliance. Essential for contractor qualification verification, regulatory compliance, an' ;
    rdfs:domain ind:SubcontractWork ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TransporterRegistration .

ind:actualInvoicedCost rdf:type rdf:Property ;
    rdfs:label 'Actual Invoiced Cost' ;
    rdfs:comment 'The actual amount invoiced by the vendor upon completion of the subcontracted maintenance work. Compared against quoted cost to identify cost overruns and support three-way match in SAP AP.' ;
    rdfs:domain ind:SubcontractWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costVariance rdf:type rdf:Property ;
    rdfs:label 'Cost Variance' ;
    rdfs:comment 'Difference between actual invoiced cost and quoted cost (actual_invoiced_cost minus quoted_cost). Positive value indicates cost overrun; negative indicates savings. Supports vendor performance management and budget control.' ;
    rdfs:domain ind:SubcontractWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:makeVsBuyCategory rdf:type rdf:Property ;
    rdfs:label 'Make Vs Buy Category' ;
    rdfs:comment 'Classification of the business reason for subcontracting this maintenance work rather than performing it in-house. Supports make-vs-buy analysis and strategic workforce planning. Values: specialty_skill, capacity_overflow, emergency, cost_efficiency, oem_required.' ;
    rdfs:domain ind:SubcontractWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partsSuppliedBy rdf:type rdf:Property ;
    rdfs:label 'Parts Supplied By' ;
    rdfs:comment 'Indicates whether parts and materials for the subcontracted repair were supplied by the external vendor, by Waste Management from internal inventory, or shared between both parties. Affects cost allocation and BOM tracking.' ;
    rdfs:domain ind:SubcontractWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poNumber rdf:type rdf:Property ;
    rdfs:label 'Po Number' ;
    rdfs:comment 'The externally communicated purchase order (PO) number issued to the vendor for this subcontracted work. Used for invoice matching, three-way match, and AP reconciliation in SAP S/4HANA.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promisedCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Promised Completion Date' ;
    rdfs:comment 'The date the vendor committed to completing the subcontracted work at time of engagement. Compared against actual completion date to measure vendor on-time delivery performance.' ;
    rdfs:domain ind:SubcontractWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualityAcceptanceFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Acceptance Flag' ;
    rdfs:comment 'Indicates whether the completed subcontracted work passed internal quality inspection and was formally accepted. False triggers rework requests or dispute initiation.' ;
    rdfs:domain ind:SubcontractWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quotedCost rdf:type rdf:Property ;
    rdfs:label 'Quoted Cost' ;
    rdfs:comment 'The vendor\'s quoted price for the subcontracted maintenance work prior to work commencement. Used as the baseline for budget approval, make-vs-buy analysis, and variance tracking against actual invoiced cost.' ;
    rdfs:domain ind:SubcontractWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Service Completion Date' ;
    rdfs:comment 'The date on which the external vendor completed and delivered the subcontracted maintenance work. Used to calculate turnaround time, asset downtime duration, and vendor on-time performance.' ;
    rdfs:domain ind:SubcontractWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:serviceLocationType rdf:type rdf:Property ;
    rdfs:label 'Service Location Type' ;
    rdfs:comment 'Indicates where the subcontracted maintenance work was physically performed. Distinguishes on-site repairs at Waste Management facilities from work performed at the vendor\'s shop, dealer, or via mobile service unit.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subcontractNumber rdf:type rdf:Property ;
    rdfs:label 'Subcontract Number' ;
    rdfs:comment 'Externally visible, human-readable identifier for the subcontract work record. Used in vendor communications, PO references, and invoice matching. Format: SC-YYYY-NNNNNN.' ;
    rdfs:domain ind:SubcontractWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorCompletionNotes rdf:type rdf:Property ;
    rdfs:label 'Vendor Completion Notes' ;
    rdfs:comment 'Free-text notes provided by the external vendor upon completion of the subcontracted work, describing work performed, parts replaced, and any recommendations. Captured in Infor EAM service entry.' ;
    rdfs:domain ind:SubcontractWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorPerformanceRating rdf:type rdf:Property ;
    rdfs:label 'Vendor Performance Rating' ;
    rdfs:comment 'Numeric rating (1.0 to 5.0 scale) assigned to the vendor for this subcontract work engagement, evaluating quality, timeliness, and cost adherence. Feeds vendor performance management and future sourcing decisions.' ;
    rdfs:domain ind:SubcontractWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Reference Number' ;
    rdfs:comment 'The vendor\'s own internal reference or job number for this subcontracted work engagement. Used for invoice reconciliation and vendor communication tracking.' ;
    rdfs:domain ind:SubcontractWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Warranty Expiry Date' ;
    rdfs:comment 'The date on which the vendor\'s repair warranty expires. Enables proactive warranty claim management before expiration and supports asset maintenance planning.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:workStatus rdf:type rdf:Property ;
    rdfs:label 'Work Status' ;
    rdfs:comment 'Current lifecycle status of the subcontracted maintenance work execution. Tracks progression from open engagement through completion, invoicing, and closure. [ENUM-REF-CANDIDATE: open|in_progress|completed|invoiced|closed|disputed — promote to reference product]' ;
    rdfs:domain ind:SubcontractWork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicianAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Technician Assignment Id' ;
    rdfs:comment 'Unique surrogate identifier for each technician assignment record linking a maintenance technician to a specific work order and task in the Infor EAM / SAP PM system.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TechnicianAssignment .

ind:primaryTechnicianEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Technician Employee Id' ;
    rdfs:comment 'Reference to the maintenance technician\'s employee record in Workday HCM. Used for labor cost allocation, utilization tracking, and payroll integration. Distinct from the workforce employee master — this domain owns the maintenance-specific assignment record.' ;
    rdfs:domain ind:TechnicianAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:requiredHazwoperTrainingId rdf:type rdf:Property ;
    rdfs:label 'Required Hazwoper Training Id' ;
    rdfs:comment 'Foreign key linking to hazmat.hazwoper_training. Business justification: Technicians assigned to work involving hazardous materials must have current HAZWOPER certification verified before assignment. Mandatory for worker safety, OSHA 29 CFR 1910.120 compliance, and qualif' ;
    rdfs:domain ind:TechnicianAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HazwoperTraining .

ind:tertiaryTechnicianConfirmedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Technician Confirmed By Employee Id' ;
    rdfs:comment 'Reference to the supervisor or authorized personnel who confirmed and approved the labor hours for this assignment in SAP PM or Infor EAM. Supports approval audit trail and SOX compliance for labor cost postings.' ;
    rdfs:domain ind:TechnicianAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:woTaskId rdf:type rdf:Property ;
    rdfs:label 'Wo Task Id' ;
    rdfs:comment 'Reference to the specific maintenance task or operation within the work order to which this technician is assigned. Supports multi-task WO decomposition and individual task-level labor tracking.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WoTask .

ind:actualEndDatetime rdf:type rdf:Property ;
    rdfs:label 'Actual End Datetime' ;
    rdfs:comment 'Actual date and time the technician completed work on the assigned task, as confirmed in Infor EAM. Used to calculate actual labor hours, measure WO cycle time, and support payroll confirmation. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:TechnicianAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualStartDatetime rdf:type rdf:Property ;
    rdfs:label 'Actual Start Datetime' ;
    rdfs:comment 'Actual date and time the technician began work on the assigned task, as recorded in Infor EAM or via mobile confirmation. Compared against scheduled start to measure schedule adherence and response time. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:TechnicianAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:certificationUsed rdf:type rdf:Property ;
    rdfs:label 'Certification Used' ;
    rdfs:comment 'Specific certification or license applied by the technician for this assignment (e.g., CDL, DOT Inspector, RCRA Hazardous Waste Handler, ASE Certification). Ensures regulatory compliance and documents that qualified personnel performed the work. [ENUM-REF-CANDIDATE: CDL|DOT_INSPECTOR|RCRA_HANDLER|ASE|OSHA_30|HAZWOPER|CDL_HAZMAT — promote to reference product]' ;
    rdfs:domain ind:TechnicianAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionCode rdf:type rdf:Property ;
    rdfs:label 'Completion Code' ;
    rdfs:comment 'Standardized outcome code recorded at assignment closure: completed_normal (fully executed as planned), completed_partial (partial work done, follow-up required), deferred (rescheduled), cancelled_no_fault (cancelled without technician fault), or cancelled_parts (cancelled due to parts unavailability).' ;
    rdfs:domain ind:TechnicianAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmedDatetime rdf:type rdf:Property ;
    rdfs:label 'Confirmed Datetime' ;
    rdfs:comment 'Date and time when the labor hours for this assignment were formally confirmed and approved in SAP PM or Infor EAM. Used for payroll cutoff processing, financial period allocation, and audit trail. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:TechnicianAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:craftCode rdf:type rdf:Property ;
    rdfs:label 'Craft Code' ;
    rdfs:comment 'Trade or craft classification code identifying the technician\'s skill category for this assignment (e.g., MECH for mechanic, ELEC for electrician, WELD for welder, HVAC for HVAC technician). Used in Infor EAM for labor planning and rate determination. [ENUM-REF-CANDIDATE: MECH|ELEC|WELD|HVAC|LUBE|DIAG|BODY|TIRE|INSP — promote to reference product]' ;
    rdfs:domain ind:TechnicianAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatWorkFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Work Flag' ;
    rdfs:comment 'Indicates whether this assignment involves work on hazardous waste handling equipment or requires HAZMAT-certified personnel (True). Triggers PPE requirements, RCRA compliance documentation, and OSHA HAZWOPER certification verification.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laborConfirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Labor Confirmation Number' ;
    rdfs:comment 'SAP PM or Infor EAM labor confirmation document number generated when the technician\'s actual hours are posted and confirmed against the work order. Serves as the audit reference linking this assignment to the financial posting in SAP FI/CO.' ;
    rdfs:domain ind:TechnicianAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laborConfirmedFlag rdf:type rdf:Property ;
    rdfs:label 'Labor Confirmed Flag' ;
    rdfs:comment 'Indicates whether the technician\'s actual labor hours have been formally confirmed and posted in SAP PM or Infor EAM (True), triggering financial posting to the work order cost object. False indicates hours are still pending confirmation.' ;
    rdfs:domain ind:TechnicianAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overtimeHours rdf:type rdf:Property ;
    rdfs:label 'Overtime Hours' ;
    rdfs:comment 'Number of overtime hours logged by the technician for this assignment beyond the standard shift, as tracked per FLSA and company policy. Drives overtime cost calculation and labor budget variance reporting.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduledEndDatetime rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Datetime' ;
    rdfs:comment 'Planned date and time the technician is expected to complete work on the assigned task. Used for shift planning, resource availability, and work order duration estimation. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:TechnicianAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledLaborHours rdf:type rdf:Property ;
    rdfs:label 'Scheduled Labor Hours' ;
    rdfs:comment 'Planned number of labor hours allocated to this technician for the assigned task, as estimated during work order planning. Used for capacity planning, cost estimation, and variance analysis against actual hours.' ;
    rdfs:domain ind:TechnicianAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduledStartDatetime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Datetime' ;
    rdfs:comment 'Planned date and time the technician is scheduled to begin work on the assigned task. Used for crew scheduling, resource capacity planning, and SLA compliance monitoring. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:TechnicianAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shiftCode rdf:type rdf:Property ;
    rdfs:label 'Shift Code' ;
    rdfs:comment 'Work shift during which this technician assignment is scheduled or executed: day, evening, night, weekend, or on_call. Used for shift differential pay calculation, labor scheduling, and 24/7 maintenance coverage analysis.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skillLevel rdf:type rdf:Property ;
    rdfs:label 'Skill Level' ;
    rdfs:comment 'Proficiency level of the technician for the craft applied in this assignment: apprentice (entry-level under supervision), journeyman (qualified independent), senior (experienced), master (highest craft level), or specialist (domain-specific expert). Used for crew composition validation and training gap analysis.' ;
    rdfs:domain ind:TechnicianAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:travelTimeHours rdf:type rdf:Property ;
    rdfs:label 'Travel Time Hours' ;
    rdfs:comment 'Number of hours the technician spent traveling to and from the maintenance site for this assignment. Captured separately from labor hours for accurate cost allocation, technician utilization analysis, and field service efficiency reporting.' ;
    rdfs:domain ind:TechnicianAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workOrderPriority rdf:type rdf:Property ;
    rdfs:label 'Work Order Priority' ;
    rdfs:comment 'Priority level of the parent work order, denormalized to the assignment level to support technician dispatch sequencing and scheduling decisions: emergency (immediate response), urgent (same-day), high (next available), normal (scheduled), or low (deferred).' ;
    rdfs:domain ind:TechnicianAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyClaimId rdf:type rdf:Property ;
    rdfs:label 'Warranty Claim Id' ;
    rdfs:comment 'Unique surrogate identifier for the warranty claim record in the Databricks Silver Layer. Primary key for this entity.' ;
    rdfs:domain ind:WarrantyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:appealDate rdf:type rdf:Property ;
    rdfs:label 'Appeal Date' ;
    rdfs:comment 'The date on which a formal appeal was submitted to the OEM or supplier for a denied or partially approved claim. Populated only when appeal_flag is True.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:appealFlag rdf:type rdf:Property ;
    rdfs:label 'Appeal Flag' ;
    rdfs:comment 'Indicates whether a denied or partially approved warranty claim has been formally appealed to the OEM or supplier. Enables tracking of appeal activity and outcomes for supplier quality management.' ;
    rdfs:domain ind:WarrantyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvedAmount rdf:type rdf:Property ;
    rdfs:label 'Approved Amount' ;
    rdfs:comment 'The monetary amount approved by the OEM or supplier for reimbursement. May differ from the claimed amount due to partial approvals, labor rate caps, or disputed items.' ;
    rdfs:domain ind:WarrantyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assetMeterAtFailure rdf:type rdf:Property ;
    rdfs:label 'Asset Meter At Failure' ;
    rdfs:comment 'The odometer or hour-meter reading of the asset at the time of component failure. Used to validate warranty coverage based on mileage or operating hour limits (e.g., 100,000-mile powertrain warranty).' ;
    rdfs:domain ind:WarrantyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:claimNumber rdf:type rdf:Property ;
    rdfs:label 'Claim Number' ;
    rdfs:comment 'Externally-known, human-readable claim reference number assigned at submission to the OEM manufacturer or parts supplier. Used for all correspondence and tracking with the counterparty. Sourced from Infor EAM warranty module.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimStatus rdf:type rdf:Property ;
    rdfs:label 'Claim Status' ;
    rdfs:comment 'Current lifecycle state of the warranty claim. Tracks progression from initial submission through OEM/supplier review, approval or denial, and final payment or closure.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimedAmount rdf:type rdf:Property ;
    rdfs:label 'Claimed Amount' ;
    rdfs:comment 'The gross monetary amount submitted to the OEM or supplier for reimbursement, including labor costs, parts costs, and any associated repair expenses. Represents the total recovery sought.' ;
    rdfs:domain ind:WarrantyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:denialReasonCode rdf:type rdf:Property ;
    rdfs:label 'Denial Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for claim denial or partial denial by the OEM or supplier (e.g., out-of-warranty, improper installation, normal wear). Supports supplier quality analysis and denial pattern tracking. [ENUM-REF-CANDIDATE: out_of_warranty|improper_installation|normal_wear|missing_documentation|coverage_exclusion|duplicate_claim|other — promote to reference product]' ;
    rdfs:domain ind:WarrantyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dotInspectionRelatedFlag rdf:type rdf:Property ;
    rdfs:label 'Dot Inspection Related Flag' ;
    rdfs:comment 'Indicates whether the component failure was identified during or is related to a DOT (Department of Transportation) vehicle inspection. Supports regulatory compliance tracking and DOT out-of-service event correlation.' ;
    rdfs:domain ind:WarrantyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:failedComponentDescription rdf:type rdf:Property ;
    rdfs:label 'Failed Component Description' ;
    rdfs:comment 'Human-readable description of the specific component or assembly that failed (e.g., \'hydraulic pump\', \'CNG fuel injector\', \'compactor blade\'). Complements the part number for claim documentation.' ;
    rdfs:domain ind:WarrantyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureDate rdf:type rdf:Property ;
    rdfs:label 'Failure Date' ;
    rdfs:comment 'The date on which the component failure or defect was first observed or reported. Used to validate that the failure occurred within the warranty coverage period.' ;
    rdfs:domain ind:WarrantyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:laborCostClaimed rdf:type rdf:Property ;
    rdfs:label 'Labor Cost Claimed' ;
    rdfs:comment 'The portion of the claimed amount attributable to technician labor hours expended on diagnosing and repairing the failed component. Supports detailed cost recovery analysis by cost category.' ;
    rdfs:domain ind:WarrantyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oemClaimReference rdf:type rdf:Property ;
    rdfs:label 'Oem Claim Reference' ;
    rdfs:comment 'The claim reference or RMA (Return Merchandise Authorization) number assigned by the OEM manufacturer or parts supplier upon receipt of the claim. Used for external tracking and correspondence.' ;
    rdfs:domain ind:WarrantyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oemResponseDate rdf:type rdf:Property ;
    rdfs:label 'Oem Response Date' ;
    rdfs:comment 'The date on which the OEM manufacturer or parts supplier provided their formal response (approval, denial, or request for additional information) to the submitted claim.' ;
    rdfs:domain ind:WarrantyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:oemResponseNotes rdf:type rdf:Property ;
    rdfs:label 'Oem Response Notes' ;
    rdfs:comment 'Free-text notes or rationale provided by the OEM or supplier in their claim response, including reasons for denial, partial approval justification, or conditions for reimbursement.' ;
    rdfs:domain ind:WarrantyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partReturnedDate rdf:type rdf:Property ;
    rdfs:label 'Part Returned Date' ;
    rdfs:comment 'The date on which the failed component was physically returned to the OEM or supplier. Populated only when return_required_flag is True. Used to confirm return compliance and trigger reimbursement.' ;
    rdfs:domain ind:WarrantyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:partsCostClaimed rdf:type rdf:Property ;
    rdfs:label 'Parts Cost Claimed' ;
    rdfs:comment 'The portion of the claimed amount attributable to replacement parts and materials used in the repair of the failed component. Supports detailed cost recovery analysis by cost category.' ;
    rdfs:domain ind:WarrantyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reimbursedAmount rdf:type rdf:Property ;
    rdfs:label 'Reimbursed Amount' ;
    rdfs:comment 'The actual monetary amount received from the OEM or supplier as reimbursement. May differ from the approved amount if partial payments were made. Used for accounts receivable reconciliation.' ;
    rdfs:domain ind:WarrantyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reimbursementReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Reimbursement Received Date' ;
    rdfs:comment 'The date on which the reimbursement payment was received from the OEM or supplier. Used for cash flow tracking, accounts receivable aging, and warranty recovery performance reporting.' ;
    rdfs:domain ind:WarrantyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:returnRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Return Required Flag' ;
    rdfs:comment 'Indicates whether the OEM or supplier requires the failed component to be physically returned as a condition of claim approval. Drives parts return logistics and core charge management.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceClaimReference rdf:type rdf:Property ;
    rdfs:label 'Source Claim Reference' ;
    rdfs:comment 'The native claim identifier from the originating source system (Infor EAM or SAP PM). Enables traceability and reconciliation between the Silver Layer data product and the operational system of record.' ;
    rdfs:domain ind:WarrantyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyAgreementNumber rdf:type rdf:Property ;
    rdfs:label 'Warranty Agreement Number' ;
    rdfs:comment 'The warranty contract or agreement number under which coverage is claimed. References the specific OEM vehicle warranty, extended warranty contract, or supplier parts warranty agreement.' ;
    rdfs:domain ind:WarrantyClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryWoEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Wo Employee Id' ;
    rdfs:comment 'Reference to the workforce employee record of the technician assigned to execute this task. Used for labor tracking, productivity analysis, and certification compliance verification via Workday HCM integration.' ;
    rdfs:domain ind:WoTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryWorkOrderId rdf:type rdf:Property ;
    rdfs:label 'Primary Work Order Id' ;
    rdfs:comment 'Reference to the parent work order header that this task belongs to. Establishes the header-detail relationship between the work order and its constituent task steps.' ;
    rdfs:domain ind:WoTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkOrder .

ind:workCenterId rdf:type rdf:Property ;
    rdfs:label 'Work Center Id' ;
    rdfs:comment 'Reference to the maintenance work center or shop (e.g., Fleet Garage Bay 3, Transfer Station Workshop) where this task is to be performed. Used for capacity planning, resource allocation, and facility utilization reporting.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkCenter .

ind:actualLaborCost rdf:type rdf:Property ;
    rdfs:label 'Actual Labor Cost' ;
    rdfs:comment 'Actual labor cost incurred for this task based on actual hours worked and the technician\'s labor rate. Feeds into work order total cost and asset maintenance cost reporting in SAP FI/CO.' ;
    rdfs:domain ind:WoTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualPartsCost rdf:type rdf:Property ;
    rdfs:label 'Actual Parts Cost' ;
    rdfs:comment 'Actual cost of parts and materials consumed during task execution, recorded upon parts issuance from inventory. Used for work order cost variance analysis and asset lifecycle cost tracking.' ;
    rdfs:domain ind:WoTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Start Timestamp' ;
    rdfs:comment 'Date and time when the technician actually began executing this task. Captured via CMMS mobile app or time-clock entry. Used for schedule adherence analysis and downtime duration calculation.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:defectFoundFlag rdf:type rdf:Property ;
    rdfs:label 'Defect Found Flag' ;
    rdfs:comment 'Indicates whether a defect, fault, or out-of-tolerance condition was identified during execution of this task. Triggers corrective action workflow and defect documentation in Infor EAM and Enviance EHS.' ;
    rdfs:domain ind:WoTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:downtimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Downtime Minutes' ;
    rdfs:comment 'Total minutes the asset was taken out of service specifically for this task. Contributes to overall work order downtime and feeds fleet availability and Mean Time to Repair (MTTR) calculations. Distinct from labor hours as it includes wait time for parts or approvals.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:meterReadingAtTask rdf:type rdf:Property ;
    rdfs:label 'Meter Reading At Task' ;
    rdfs:comment 'Odometer (miles) or engine hours reading recorded at the time this task was performed. Critical for mileage-based and hour-based PM interval tracking, DOT inspection records, and asset lifecycle management in Infor EAM.' ;
    rdfs:domain ind:WoTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorityCode rdf:type rdf:Property ;
    rdfs:label 'Priority Code' ;
    rdfs:comment 'Priority level assigned to this task, which may differ from the parent work order priority if specific steps are more time-critical (e.g., a safety-critical brake inspection step within a broader PM work order). Drives technician scheduling and dispatch sequencing.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredCertification rdf:type rdf:Property ;
    rdfs:label 'Required Certification' ;
    rdfs:comment 'Specific regulatory or industry certification required to perform this task (e.g., CDL for vehicle brake inspection, ASE for engine diagnostics, DOT_INSPECTOR for federal vehicle inspection). Enforces compliance with DOT 49 CFR Part 396 and OSHA standards. [ENUM-REF-CANDIDATE: CDL|ASE|DOT_INSPECTOR|HAZMAT|OSHA_30|FORKLIFT|NONE|EPA_608|RCRA_HAZWASTE — promote to reference product]' ;
    rdfs:domain ind:WoTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredSkillCode rdf:type rdf:Property ;
    rdfs:label 'Required Skill Code' ;
    rdfs:comment 'Code identifying the minimum skill or trade qualification required to perform this task (e.g., \'MECH-DIESEL\', \'ELEC-HV\', \'HVAC-CERT\'). Used for technician assignment validation and workforce capability gap analysis.' ;
    rdfs:domain ind:WoTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyInstructions rdf:type rdf:Property ;
    rdfs:label 'Safety Instructions' ;
    rdfs:comment 'Mandatory safety procedures, lockout/tagout (LOTO) requirements, Personal Protective Equipment (PPE) specifications, and hazard warnings that must be followed before and during task execution. Sourced from EHS system and linked to OSHA compliance requirements.' ;
    rdfs:domain ind:WoTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Timestamp' ;
    rdfs:comment 'Planned date and time when the technician is scheduled to begin this task. Used for maintenance scheduling, shift planning, and asset downtime window management.' ;
    rdfs:domain ind:WoTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:skipReason rdf:type rdf:Property ;
    rdfs:label 'Skip Reason' ;
    rdfs:comment 'Reason code explaining why a task was skipped or bypassed in the work order execution. Required when task_status is \'skipped\' to maintain audit trail integrity and support PM compliance reporting. [ENUM-REF-CANDIDATE: not_applicable|deferred|parts_unavailable|asset_unavailable|safety_hold|supervisor_override|weather|other — promote to reference product]' ;
    rdfs:domain ind:WoTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardTaskCode rdf:type rdf:Property ;
    rdfs:label 'Standard Task Code' ;
    rdfs:comment 'Reference code linking this task to a standardized maintenance task template in the CMMS library (e.g., \'HYD-INSP-001\' for hydraulic inspection). Enables consistent task definition, labor estimation benchmarking, and cross-fleet maintenance analytics.' ;
    rdfs:domain ind:WoTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskDescription rdf:type rdf:Property ;
    rdfs:label 'Task Description' ;
    rdfs:comment 'Detailed narrative description of the maintenance task to be performed, including the specific action, component, and expected outcome (e.g., \'Inspect and replace hydraulic hose on compactor lift arm\'). Sourced from standard task library or entered by planner.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskNumber rdf:type rdf:Property ;
    rdfs:label 'Task Number' ;
    rdfs:comment 'Externally visible alphanumeric identifier for the task, typically formatted as the parent WO number suffixed with a task sequence (e.g., WO-2024-00123-T01). Used in technician communications, printed work packets, and audit trails.' ;
    rdfs:domain ind:WoTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskSequence rdf:type rdf:Property ;
    rdfs:label 'Task Sequence' ;
    rdfs:comment 'Numeric ordering of this task within the parent work order, defining the execution sequence of multi-step maintenance procedures (e.g., 10, 20, 30 in SAP PM operation numbering convention). Enables dependency management and step-by-step workflow tracking.' ;
    rdfs:domain ind:WoTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:taskStatus rdf:type rdf:Property ;
    rdfs:label 'Task Status' ;
    rdfs:comment 'Current lifecycle state of the maintenance task within the work order execution workflow. Drives technician dashboard visibility, WO completion logic, and downtime reporting. [ENUM-REF-CANDIDATE: pending|in_progress|complete|skipped|on_hold|cancelled — promote to reference product]' ;
    rdfs:domain ind:WoTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskType rdf:type rdf:Property ;
    rdfs:label 'Task Type' ;
    rdfs:comment 'Classification of the maintenance task by the nature of the work performed. Used for labor planning, parts forecasting, and maintenance cost categorization. [ENUM-REF-CANDIDATE: inspection|repair|replacement|lubrication|calibration|cleaning|adjustment|testing|documentation — promote to reference product]' ;
    rdfs:domain ind:WoTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenancePlanId rdf:type rdf:Property ;
    rdfs:label 'Maintenance Plan Id' ;
    rdfs:comment 'Reference to the preventive maintenance plan or PM cycle that generated this work order, if applicable. Null for corrective or emergency work orders not originating from a scheduled PM cycle.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaintenancePlan .

ind:actualEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual End Timestamp' ;
    rdfs:comment 'Actual date and time when the maintenance work was completed and the asset was returned to service. Used to calculate actual labor duration, downtime, and mean time to repair (MTTR) metrics.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assetMeterReading rdf:type rdf:Property ;
    rdfs:label 'Asset Meter Reading' ;
    rdfs:comment 'Odometer (miles) or engine hours reading of the asset at the time the work order was executed. Used to track PM intervals (e.g., oil change every 5,000 miles), calculate mean time between failures (MTBF), and validate DOT inspection compliance.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dotInspectionType rdf:type rdf:Property ;
    rdfs:label 'Dot Inspection Type' ;
    rdfs:comment 'Type of DOT inspection associated with this work order, if applicable. Annual = federally mandated annual vehicle inspection; Pre_Trip = driver pre-trip inspection defect repair; Post_Trip = post-trip defect repair; Roadside = repair following roadside enforcement inspection; None = not a DOT inspection work order.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalServiceCost rdf:type rdf:Property ;
    rdfs:label 'External Service Cost' ;
    rdfs:comment 'Cost of external contractor or vendor services engaged to complete or support the work order in USD. Linked to purchase orders (PO) in SAP MM. Relevant for outsourced repairs, specialized inspections, and warranty work.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lotoCleared rdf:type rdf:Property ;
    rdfs:label 'Loto Cleared' ;
    rdfs:comment 'Indicates whether the required LOTO energy isolation procedure has been completed and verified prior to work commencement. Must be True before work begins on LOTO-required work orders. Supports OSHA compliance audit trails.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lotoRequired rdf:type rdf:Property ;
    rdfs:label 'Loto Required' ;
    rdfs:comment 'Indicates whether Lockout/Tagout (LOTO) energy isolation procedures are required before executing this work order. Mandatory safety clearance flag per OSHA 29 CFR 1910.147 for work on equipment with hazardous energy sources (hydraulics, electrical, pneumatic).' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:originatingSystem rdf:type rdf:Property ;
    rdfs:label 'Originating System' ;
    rdfs:comment 'Source system that created and owns this work order record. Determines the authoritative system of record for reconciliation. SAP_PM indicates SAP S/4HANA Plant Maintenance module; INFOR_EAM indicates Infor Enterprise Asset Management.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledEndDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Date' ;
    rdfs:comment 'Planned date on which the maintenance work is expected to be completed. Used for fleet availability commitments, route planning coordination, and maintenance window management.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceSystemWoReference rdf:type rdf:Property ;
    rdfs:label 'Source System Wo Reference' ;
    rdfs:comment 'Native primary key or internal identifier of this work order in the originating system (SAP PM order number or Infor EAM internal WO ID). Enables bidirectional traceability between the lakehouse Silver layer and the operational system of record.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:woStatus rdf:type rdf:Property ;
    rdfs:label 'Wo Status' ;
    rdfs:comment 'Current lifecycle state of the work order. Open = created but not started; In_Progress = technician actively working; On_Hold = paused pending approval or resources; Pending_Parts = awaiting parts from inventory; Completed = work finished, pending closure review; Closed = fully closed and costed; Cancelled = voided without execution. [ENUM-REF-CANDIDATE: open|in_progress|on_hold|pending_parts|completed|closed|cancelled — promote to reference product]' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apPaymentId rdf:type rdf:Property ;
    rdfs:label 'Ap Payment Id' ;
    rdfs:comment 'Unique identifier for the accounts payable payment transaction. Primary key.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bankAccountId rdf:type rdf:Property ;
    rdfs:label 'Bank Account Id' ;
    rdfs:comment 'Reference to the company bank account from which funds were disbursed for this payment.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BankAccount .

ind:paymentRunId rdf:type rdf:Property ;
    rdfs:label 'Payment Run Id' ;
    rdfs:comment 'Identifier for the batch payment run that generated this payment. Multiple payments may share the same payment run ID.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Run .

ind:vendorInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Vendor Invoice Id' ;
    rdfs:comment 'Reference to the vendor invoice being paid by this payment transaction.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VendorInvoice .

ind:baselineDate rdf:type rdf:Property ;
    rdfs:label 'Baseline Date' ;
    rdfs:comment 'The date from which payment terms are calculated. Typically the invoice date or goods receipt date. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:checkNumber rdf:type rdf:Property ;
    rdfs:label 'Check Number' ;
    rdfs:comment 'The physical or virtual check number if payment method is check. Null for electronic payment methods.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Clearing Document Number' ;
    rdfs:comment 'The financial document number that cleared the open vendor invoice items. Links payment to invoice clearing in the general ledger.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Net Payment Amount' ;
    rdfs:comment 'The final net amount disbursed after applying discounts and adjustments. Equals payment_amount minus discount_amount.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentAmount rdf:type rdf:Property ;
    rdfs:label 'Payment Amount' ;
    rdfs:comment 'The gross amount disbursed to the vendor in this payment transaction, before any adjustments or discounts.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentBatchNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Batch Number' ;
    rdfs:comment 'Identifier for the payment batch file sent to the bank or payment processor. Used for reconciliation and error tracking.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentBlockCode rdf:type rdf:Property ;
    rdfs:label 'Payment Block Code' ;
    rdfs:comment 'Single-character code indicating if payment was blocked for review or approval. Blank if no block applied.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentMemo rdf:type rdf:Property ;
    rdfs:label 'Payment Memo' ;
    rdfs:comment 'Free-text memo or notes field providing additional context about the payment for internal reference.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentProcessor rdf:type rdf:Property ;
    rdfs:label 'Payment Processor' ;
    rdfs:comment 'The name of the third-party payment processor or banking partner that executed the payment (e.g., JP Morgan, Bank of America, PayPal).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorBankAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Bank Account Number' ;
    rdfs:comment 'The vendor\'s bank account number to which payment was sent. Confidential financial information.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorBankRoutingNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Bank Routing Number' ;
    rdfs:comment 'The ABA routing number for the vendor\'s bank (US payments). Nine-digit code identifying the financial institution.' ;
    rdfs:domain ind:ApPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withholdingTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Amount' ;
    rdfs:comment 'The amount of withholding tax deducted from the payment as required by tax regulations. Reduces net payment to vendor.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvalWorkflowId rdf:type rdf:Property ;
    rdfs:label 'Approval Workflow Id' ;
    rdfs:comment 'Unique identifier for the approval workflow instance. Primary key for the approval workflow product.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryApprovalEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Approval Employee Id' ;
    rdfs:comment 'Foreign key reference to the employee assigned as the approver for this workflow step. Links to the workforce/employee master data.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:requesterEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Requester Employee Id' ;
    rdfs:comment 'Foreign key reference to the employee who initiated the procurement request. Used for segregation of duties validation and audit trail.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:rfqId rdf:type rdf:Property ;
    rdfs:label 'Rfq Id' ;
    rdfs:comment 'Foreign key linking to procurement.rfq. Business justification: Approval workflows for RFQs need a typed FK to the RFQ being approved. RFQs above certain thresholds require approval before being issued to vendors. This typed relationship enables tracking of RFQ ap' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Rfq .

ind:approvalAction rdf:type rdf:Property ;
    rdfs:label 'Approval Action' ;
    rdfs:comment 'Action taken by the approver at this workflow step. Indicates whether the approver approved, rejected, delegated to another person, requested additional information, escalated to higher authority, or withdrew the request.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalComments rdf:type rdf:Property ;
    rdfs:label 'Approval Comments' ;
    rdfs:comment 'Free-text comments or notes provided by the approver explaining the rationale for their decision, especially for rejections or requests for additional information.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalStepSequence rdf:type rdf:Property ;
    rdfs:label 'Approval Step Sequence' ;
    rdfs:comment 'Sequential order of the current approval step within the workflow. Indicates the position in the approval chain (e.g., 1 for first approver, 2 for second approver).' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approverRole rdf:type rdf:Property ;
    rdfs:label 'Approver Role' ;
    rdfs:comment 'Organizational role or position responsible for approval at this step (e.g., Procurement Manager, Finance Director, VP Operations, CFO). Defines the authority level required.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedApproverEmail rdf:type rdf:Property ;
    rdfs:label 'Assigned Approver Email' ;
    rdfs:comment 'Email address of the assigned approver. Used for workflow notifications and audit trail. Classified as confidential PII.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedApproverName rdf:type rdf:Property ;
    rdfs:label 'Assigned Approver Name' ;
    rdfs:comment 'Full name of the employee assigned as the approver for this workflow step. Denormalized for reporting convenience.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Budget Check Status' ;
    rdfs:comment 'Result of the budget availability check performed during the approval workflow. Indicates whether sufficient budget exists for the procurement spend.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetCheckTimestamp rdf:type rdf:Property ;
    rdfs:label 'Budget Check Timestamp' ;
    rdfs:comment 'Date and time when the budget availability check was performed. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:delegatedToApproverName rdf:type rdf:Property ;
    rdfs:label 'Delegated To Approver Name' ;
    rdfs:comment 'Full name of the employee to whom approval authority was delegated. Denormalized for reporting convenience.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:delegationReason rdf:type rdf:Property ;
    rdfs:label 'Delegation Reason' ;
    rdfs:comment 'Free-text explanation for why the approval was delegated to another person (e.g., out of office, conflict of interest, lack of expertise).' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Document Reference Number' ;
    rdfs:comment 'Foreign key reference to the specific procurement document (purchase requisition, purchase order, or contract) that is subject to this approval workflow.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Escalation Timestamp' ;
    rdfs:comment 'Date and time when the workflow was escalated to a higher authority. Null if no escalation occurred. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requesterDepartment rdf:type rdf:Property ;
    rdfs:label 'Requester Department' ;
    rdfs:comment 'Department or organizational unit of the employee who initiated the procurement request. Used for spend analytics and budget tracking.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requesterName rdf:type rdf:Property ;
    rdfs:label 'Requester Name' ;
    rdfs:comment 'Full name of the employee who initiated the procurement request. Denormalized for reporting convenience.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segregationOfDutiesCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Segregation Of Duties Check Status' ;
    rdfs:comment 'Result of the segregation of duties validation. Ensures that the requester, approver, and receiver are different individuals to prevent fraud. Critical for SOX compliance.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaActualHours rdf:type rdf:Property ;
    rdfs:label 'Sla Actual Hours' ;
    rdfs:comment 'Actual number of hours taken to complete the approval workflow. Calculated as the difference between workflow_initiated_timestamp and workflow_completed_timestamp. Used for SLA compliance reporting.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spendAmount rdf:type rdf:Property ;
    rdfs:label 'Spend Amount' ;
    rdfs:comment 'Total monetary value of the procurement document subject to approval. Used to determine approval authority levels and routing. Drives SOX segregation of duties controls.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spendThresholdTier rdf:type rdf:Property ;
    rdfs:label 'Spend Threshold Tier' ;
    rdfs:comment 'Categorization of the spend amount into approval tiers (e.g., tier_1_under_5k, tier_2_5k_to_25k, tier_3_25k_to_100k, tier_4_over_100k). Determines the number and level of approvers required.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalApprovalSteps rdf:type rdf:Property ;
    rdfs:label 'Total Approval Steps' ;
    rdfs:comment 'Total number of approval steps required for this workflow instance. Determined by spend threshold, document type, and organizational approval rules.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:workflowCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Workflow Completed Timestamp' ;
    rdfs:comment 'Date and time when the approval workflow was completed (either fully approved or rejected). Null if workflow is still in progress. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:workflowInitiatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Workflow Initiated Timestamp' ;
    rdfs:comment 'Date and time when the approval workflow was initiated. Marks the start of the approval cycle for SLA tracking. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:workflowInstanceNumber rdf:type rdf:Property ;
    rdfs:label 'Workflow Instance Number' ;
    rdfs:comment 'Business-facing unique identifier for the workflow instance, typically generated by the workflow engine (SAP workflow ID).' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workflowStatus rdf:type rdf:Property ;
    rdfs:label 'Workflow Status' ;
    rdfs:comment 'Current lifecycle status of the approval workflow instance. Indicates whether the workflow is pending initiation, in progress, fully approved, rejected, cancelled, escalated to higher authority, or delegated to another approver. [ENUM-REF-CANDIDATE: pending|in_progress|approved|rejected|cancelled|escalated|delegated — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ApprovalWorkflow ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approverEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Approver Employee Id' ;
    rdfs:comment 'Employee who provided final approval for this disposal purchase order per authorization limits and approval workflow.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:disposalServiceOfferingId rdf:type rdf:Property ;
    rdfs:label 'Disposal Service Offering Id' ;
    rdfs:comment 'Foreign key linking to service.offering. Business justification: Disposal POs purchase disposal services from TSDFs, which are service offerings in the catalog. Real business process: hazardous waste disposal procurement, rate management, and vendor service trackin' ;
    rdfs:domain ind:DisposalPurchaseOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Offering .

ind:originatingFacilityId rdf:type rdf:Property ;
    rdfs:label 'Originating Facility Id' ;
    rdfs:comment 'Foreign key linking to asset.facility. Business justification: Disposal POs for offsite waste treatment must track the originating facility for EPA/state regulatory reporting, hazardous waste manifest reconciliation, cost allocation by facility, and environmental' ;
    rdfs:domain ind:DisposalPurchaseOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:deliveryLocation rdf:type rdf:Property ;
    rdfs:label 'Delivery Location' ;
    rdfs:comment 'Physical address or site identifier where waste will be delivered for disposal. Typically the TSDF facility address.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalSitePermitNumber rdf:type rdf:Property ;
    rdfs:label 'Disposal Site Permit Number' ;
    rdfs:comment 'State or local permit number authorizing the disposal facility to accept and process waste. Required for regulatory compliance verification.' ;
    rdfs:domain ind:DisposalPurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedTotalAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Total Amount' ;
    rdfs:comment 'Total estimated cost for disposal services under this purchase order. Calculated as estimated tonnage multiplied by tipping fee, plus any surcharges.' ;
    rdfs:domain ind:DisposalPurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incotermsCode rdf:type rdf:Property ;
    rdfs:label 'Incoterms Code' ;
    rdfs:comment 'Incoterms code defining the delivery terms and transfer of risk between buyer and seller for waste transportation to disposal site. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermsCode rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Code' ;
    rdfs:comment 'SAP payment terms code defining the payment schedule and discount terms for this purchase order.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poDate rdf:type rdf:Property ;
    rdfs:label 'Po Date' ;
    rdfs:comment 'Date when the disposal purchase order was created and issued to the vendor.' ;
    rdfs:domain ind:DisposalPurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:poStatus rdf:type rdf:Property ;
    rdfs:label 'Po Status' ;
    rdfs:comment 'Current lifecycle status of the disposal purchase order in the procurement workflow. [ENUM-REF-CANDIDATE: draft|submitted|approved|in_process|partially_received|completed|cancelled|closed — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poType rdf:type rdf:Property ;
    rdfs:label 'Po Type' ;
    rdfs:comment 'Classification of the purchase order type indicating the procurement method and workflow.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchasingGroup rdf:type rdf:Property ;
    rdfs:label 'Purchasing Group' ;
    rdfs:comment 'SAP purchasing group (buyer team) responsible for managing this disposal purchase order and vendor relationship.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchasingOrganization rdf:type rdf:Property ;
    rdfs:label 'Purchasing Organization' ;
    rdfs:comment 'SAP purchasing organization responsible for procuring disposal services and managing vendor relationships.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryComplianceAttestation rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Attestation' ;
    rdfs:comment 'Attestation status confirming that the disposal vendor and method meet all applicable EPA, RCRA, state, and local regulatory requirements.' ;
    rdfs:domain ind:DisposalPurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Requested Delivery Date' ;
    rdfs:comment 'Target date by which waste disposal services are required to be completed.' ;
    rdfs:domain ind:DisposalPurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tippingFeePerUnit rdf:type rdf:Property ;
    rdfs:label 'Tipping Fee Per Unit' ;
    rdfs:comment 'Contracted disposal fee charged per unit of waste (typically per ton). Core pricing component for disposal cost calculation and COGS allocation.' ;
    rdfs:domain ind:DisposalPurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wbsElement rdf:type rdf:Property ;
    rdfs:label 'Wbs Element' ;
    rdfs:comment 'Project WBS element for capital projects or special initiatives requiring disposal services. Used for project cost tracking.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsReceiptId rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Id' ;
    rdfs:comment 'Foreign key linking to procurement.goods_receipt. Business justification: Fuel purchases should link to goods receipt records for three-way match validation (PO-GR-Invoice). Currently has goods_receipt_number as string but no FK to goods_receipt table. Adding goods_receipt_' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GoodsReceipt .

ind:receivingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Receiving Employee Id' ;
    rdfs:comment 'Employee who received and verified the fuel delivery at the site.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:deliveryNoteNumber rdf:type rdf:Property ;
    rdfs:label 'Delivery Note Number' ;
    rdfs:comment 'Delivery note or packing slip number provided by the vendor at the time of fuel delivery.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Delivery Timestamp' ;
    rdfs:comment 'Precise date and time when the fuel delivery was completed at the receiving site.' ;
    rdfs:domain ind:FuelPurchase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:freightCharge rdf:type rdf:Property ;
    rdfs:label 'Freight Charge' ;
    rdfs:comment 'Delivery or freight charge for transporting the fuel to the delivery site.' ;
    rdfs:domain ind:FuelPurchase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plantCode rdf:type rdf:Property ;
    rdfs:label 'Plant Code' ;
    rdfs:comment 'SAP plant code representing the operational site or facility receiving the fuel.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseNumber rdf:type rdf:Property ;
    rdfs:label 'Purchase Number' ;
    rdfs:comment 'Business-facing unique identifier for the fuel purchase transaction, used for tracking and reconciliation.' ;
    rdfs:domain ind:FuelPurchase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseStatus rdf:type rdf:Property ;
    rdfs:label 'Purchase Status' ;
    rdfs:comment 'Current lifecycle status of the fuel purchase transaction.' ;
    rdfs:domain ind:FuelPurchase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewableFuelFlag rdf:type rdf:Property ;
    rdfs:label 'Renewable Fuel Flag' ;
    rdfs:comment 'Indicates whether the fuel is a renewable type (RNG, biodiesel) for sustainability tracking and reporting.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tankGaugeReadingPostDelivery rdf:type rdf:Property ;
    rdfs:label 'Tank Gauge Reading Post Delivery' ;
    rdfs:comment 'Fuel tank gauge reading (in gallons or liters) recorded after the delivery, used to verify delivered quantity.' ;
    rdfs:domain ind:FuelPurchase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tankGaugeReadingPreDelivery rdf:type rdf:Property ;
    rdfs:label 'Tank Gauge Reading Pre Delivery' ;
    rdfs:comment 'Fuel tank gauge reading (in gallons or liters) recorded before the delivery, used for reconciliation.' ;
    rdfs:domain ind:FuelPurchase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:poLineId rdf:type rdf:Property ;
    rdfs:label 'Po Line Id' ;
    rdfs:comment 'Reference to the specific line item on the purchase order for which goods were received. Enables line-level three-way match.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PoLine .

ind:generalLedgerAccount rdf:type rdf:Property ;
    rdfs:label 'General Ledger Account' ;
    rdfs:comment 'The general ledger account number to which the goods receipt value is posted. Determines the financial statement line item impacted by the receipt.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Gr Document Number' ;
    rdfs:comment 'The externally-known unique document number assigned to this goods receipt transaction in the source ERP system. Used for audit trails and cross-system reconciliation.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grLineNumber rdf:type rdf:Property ;
    rdfs:label 'Gr Line Number' ;
    rdfs:comment 'Sequential line item number within the goods receipt document. Supports multi-line receipts where multiple materials are received in a single transaction.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:movementType rdf:type rdf:Property ;
    rdfs:label 'Movement Type' ;
    rdfs:comment 'SAP movement type code indicating the nature of the inventory transaction (e.g., 101 for GR against PO, 501 for transfer posting). Determines accounting and inventory impact.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityInspectionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Required Flag' ;
    rdfs:comment 'Indicates whether the received goods require quality inspection before being released to unrestricted inventory. True for chemicals, hazardous materials, and critical fleet parts.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityInspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Inspection Status' ;
    rdfs:comment 'Current status of the quality inspection process for this goods receipt. Determines whether goods can be used or must remain in blocked stock.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Document Number' ;
    rdfs:comment 'External reference document number such as a Bill of Lading (BOL), shipping manifest, or work order (WO) number. Provides additional traceability for the receipt.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reversal Document Number' ;
    rdfs:comment 'The document number of the reversal transaction if this goods receipt was cancelled. Provides audit trail for corrected transactions.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockType rdf:type rdf:Property ;
    rdfs:label 'Stock Type' ;
    rdfs:comment 'Classification of the inventory stock status after goods receipt. Unrestricted stock is available for use; quality inspection and blocked stock require clearance before use.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationAmount rdf:type rdf:Property ;
    rdfs:label 'Valuation Amount' ;
    rdfs:comment 'The total value of the goods received in the local currency, calculated as received quantity multiplied by the standard or moving average price. Updates inventory value and triggers financial postings.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:infoRecordId rdf:type rdf:Property ;
    rdfs:label 'Info Record Id' ;
    rdfs:comment 'Unique identifier for the purchasing info record. Primary key.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InfoRecord .

ind:deletionFlag rdf:type rdf:Property ;
    rdfs:label 'Deletion Flag' ;
    rdfs:comment 'Indicates whether this info record is marked for deletion and should not be used for new purchase orders.' ;
    rdfs:domain ind:InfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:grProcessingTimeDays rdf:type rdf:Property ;
    rdfs:label 'Gr Processing Time Days' ;
    rdfs:comment 'Number of days required for internal goods receipt processing after delivery. Added to planned delivery time for total lead time.' ;
    rdfs:domain ind:InfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:incoterms rdf:type rdf:Property ;
    rdfs:label 'Incoterms' ;
    rdfs:comment 'International Commercial Terms defining the responsibilities of buyer and seller for delivery, insurance, and risk transfer (e.g., FOB, CIF, EXW).' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incotermsLocation rdf:type rdf:Property ;
    rdfs:label 'Incoterms Location' ;
    rdfs:comment 'The specific location or point referenced in the Incoterms (e.g., port name, facility address).' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:infoRecordCategory rdf:type rdf:Property ;
    rdfs:label 'Info Record Category' ;
    rdfs:comment 'Category of the purchasing info record indicating the procurement type (standard purchase, subcontracting, consignment, pipeline).' ;
    rdfs:domain ind:InfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:infoRecordNumber rdf:type rdf:Property ;
    rdfs:label 'Info Record Number' ;
    rdfs:comment 'Business identifier for the purchasing info record, typically system-generated or manually assigned.' ;
    rdfs:domain ind:InfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:infoRecordStatus rdf:type rdf:Property ;
    rdfs:label 'Info Record Status' ;
    rdfs:comment 'Current lifecycle status of the purchasing info record indicating whether it is available for use in purchase order creation.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastPurchaseOrderDate rdf:type rdf:Property ;
    rdfs:label 'Last Purchase Order Date' ;
    rdfs:comment 'The date of the most recent purchase order created using this info record.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastPurchaseOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Last Purchase Order Number' ;
    rdfs:comment 'The most recent purchase order number created using this info record, used for audit and reference purposes.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Minimum Order Quantity' ;
    rdfs:comment 'The minimum quantity that must be ordered from this vendor for this material. Used to enforce vendor MOQ requirements in PO creation.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netPriceFlag rdf:type rdf:Property ;
    rdfs:label 'Net Price Flag' ;
    rdfs:comment 'Indicates whether the standard price is a net price (no further discounts apply) or a gross price (subject to discounts and conditions).' ;
    rdfs:domain ind:InfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orderUnit rdf:type rdf:Property ;
    rdfs:label 'Order Unit' ;
    rdfs:comment 'Unit of measure in which the material is ordered from the vendor (e.g., EA, GAL, TON, LB).' ;
    rdfs:domain ind:InfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overdeliveryTolerancePercent rdf:type rdf:Property ;
    rdfs:label 'Overdelivery Tolerance Percent' ;
    rdfs:comment 'Percentage by which the vendor is allowed to overdeliver against the purchase order quantity without triggering an exception.' ;
    rdfs:domain ind:InfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedDeliveryTimeDays rdf:type rdf:Property ;
    rdfs:label 'Planned Delivery Time Days' ;
    rdfs:comment 'The number of calendar days from purchase order placement to expected delivery at the receiving location. Used for MRP and scheduling.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priceDateCategory rdf:type rdf:Property ;
    rdfs:label 'Price Date Category' ;
    rdfs:comment 'Indicates how the price is determined: fixed price, variable price based on market conditions, or contract-based pricing.' ;
    rdfs:domain ind:InfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceUnit rdf:type rdf:Property ;
    rdfs:label 'Price Unit' ;
    rdfs:comment 'The quantity unit to which the standard price applies (e.g., price per 1, per 10, per 100 units).' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:purchaseOrderAcknowledgmentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Acknowledgment Required Flag' ;
    rdfs:comment 'Indicates whether the vendor is required to send a formal acknowledgment of the purchase order before processing can proceed.' ;
    rdfs:domain ind:InfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:purchasingGroupCode rdf:type rdf:Property ;
    rdfs:label 'Purchasing Group Code' ;
    rdfs:comment 'Code identifying the purchasing group or buyer responsible for managing this vendor-material relationship.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchasingOrganizationCode rdf:type rdf:Property ;
    rdfs:label 'Purchasing Organization Code' ;
    rdfs:comment 'Code identifying the purchasing organization responsible for this vendor-material relationship. Aligns with SAP organizational structure.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotationDate rdf:type rdf:Property ;
    rdfs:label 'Quotation Date' ;
    rdfs:comment 'Date of the vendor quotation or RFQ response that established the pricing and terms in this info record.' ;
    rdfs:domain ind:InfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quotationNumber rdf:type rdf:Property ;
    rdfs:label 'Quotation Number' ;
    rdfs:comment 'Reference number of the vendor quotation or request for quotation (RFQ) that led to the creation of this info record.' ;
    rdfs:domain ind:InfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regularVendorFlag rdf:type rdf:Property ;
    rdfs:label 'Regular Vendor Flag' ;
    rdfs:comment 'Indicates whether this vendor is designated as the regular or preferred supplier for this material, used for automatic source determination.' ;
    rdfs:domain ind:InfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reminderDays rdf:type rdf:Property ;
    rdfs:label 'Reminder Days' ;
    rdfs:comment 'Number of days before delivery date when a reminder should be sent to the vendor if no goods receipt has been posted.' ;
    rdfs:domain ind:InfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:standardOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Standard Order Quantity' ;
    rdfs:comment 'The standard or recommended order quantity for this vendor-material combination, often used for lot-sizing.' ;
    rdfs:domain ind:InfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardPrice rdf:type rdf:Property ;
    rdfs:label 'Standard Price' ;
    rdfs:comment 'The agreed standard price per unit for the material or service from this vendor. This is the base price before any discounts or surcharges.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:underdeliveryTolerancePercent rdf:type rdf:Property ;
    rdfs:label 'Underdelivery Tolerance Percent' ;
    rdfs:comment 'Percentage by which the vendor is allowed to underdeliver against the purchase order quantity without triggering an exception.' ;
    rdfs:domain ind:InfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unlimitedOverdeliveryFlag rdf:type rdf:Property ;
    rdfs:label 'Unlimited Overdelivery Flag' ;
    rdfs:comment 'Indicates whether unlimited overdelivery is allowed for this vendor-material combination, overriding the overdelivery tolerance percentage.' ;
    rdfs:domain ind:InfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:validFromDate rdf:type rdf:Property ;
    rdfs:label 'Valid From Date' ;
    rdfs:comment 'The date from which this purchasing info record and its pricing conditions become effective.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validToDate rdf:type rdf:Property ;
    rdfs:label 'Valid To Date' ;
    rdfs:comment 'The date until which this purchasing info record and its pricing conditions remain effective. Null indicates no expiration.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:vendorMaterialNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Material Number' ;
    rdfs:comment 'The vendors own part number or material identifier for this item, used for cross-referencing in purchase orders and communications.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceExceptionId rdf:type rdf:Property ;
    rdfs:label 'Invoice Exception Id' ;
    rdfs:comment 'Unique identifier for the invoice exception record. Primary key for the invoice exception entity.' ;
    rdfs:domain ind:InvoiceException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryInvoiceResolverEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Invoice Resolver Employee Id' ;
    rdfs:comment 'Reference to the employee who resolved or is assigned to resolve the exception. Typically an AP specialist or procurement analyst.' ;
    rdfs:domain ind:InvoiceException ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryInvoiceLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Invoice Last Modified By User Employee Id' ;
    rdfs:comment 'System user ID of the person who last updated the exception record.' ;
    rdfs:domain ind:InvoiceException ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:creditMemoNumber rdf:type rdf:Property ;
    rdfs:label 'Credit Memo Number' ;
    rdfs:comment 'Reference number of the credit memo requested or received from vendor to correct the invoice discrepancy. Null if no credit memo was involved.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionAmount rdf:type rdf:Property ;
    rdfs:label 'Exception Amount' ;
    rdfs:comment 'Monetary value of the discrepancy between expected and actual invoice amount. Positive values indicate invoice overcharge, negative values indicate undercharge.' ;
    rdfs:domain ind:InvoiceException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exceptionDetectedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Exception Detected Timestamp' ;
    rdfs:comment 'Date and time when the invoice matching exception was first identified by the system during invoice verification processing.' ;
    rdfs:domain ind:InvoiceException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:finalDisposition rdf:type rdf:Property ;
    rdfs:label 'Final Disposition' ;
    rdfs:comment 'Final outcome of the exception resolution process. Indicates whether the invoice was ultimately accepted, rejected, or required adjustment.' ;
    rdfs:domain ind:InvoiceException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grQuantity rdf:type rdf:Property ;
    rdfs:label 'Gr Quantity' ;
    rdfs:comment 'Quantity recorded on the goods receipt document. Null for service-based transactions.' ;
    rdfs:domain ind:InvoiceException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceExceptionNumber rdf:type rdf:Property ;
    rdfs:label 'Invoice Exception Number' ;
    rdfs:comment 'Business-facing unique exception tracking number assigned to this invoice matching discrepancy for reference and communication with vendors and AP team.' ;
    rdfs:domain ind:InvoiceException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceQuantity rdf:type rdf:Property ;
    rdfs:label 'Invoice Quantity' ;
    rdfs:comment 'Quantity stated on the vendor invoice that is being compared against PO and GR quantities.' ;
    rdfs:domain ind:InvoiceException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceUnitPrice rdf:type rdf:Property ;
    rdfs:label 'Invoice Unit Price' ;
    rdfs:comment 'Unit price stated on the vendor invoice that is being compared against the PO price.' ;
    rdfs:domain ind:InvoiceException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:poQuantity rdf:type rdf:Property ;
    rdfs:label 'Po Quantity' ;
    rdfs:comment 'Quantity specified on the purchase order line item for comparison during three-way match.' ;
    rdfs:domain ind:InvoiceException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:poUnitPrice rdf:type rdf:Property ;
    rdfs:label 'Po Unit Price' ;
    rdfs:comment 'Unit price specified on the purchase order line item for comparison during three-way match.' ;
    rdfs:domain ind:InvoiceException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceVarianceAmount rdf:type rdf:Property ;
    rdfs:label 'Price Variance Amount' ;
    rdfs:comment 'Calculated difference between PO unit price and invoice unit price, multiplied by quantity. Null if exception type is not price-related.' ;
    rdfs:domain ind:InvoiceException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityVariance rdf:type rdf:Property ;
    rdfs:label 'Quantity Variance' ;
    rdfs:comment 'Calculated difference between expected quantity (PO or GR) and invoice quantity. Null if exception type is not quantity-related.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:toleranceBreachedFlag rdf:type rdf:Property ;
    rdfs:label 'Tolerance Breached Flag' ;
    rdfs:comment 'Indicates whether the exception variance exceeded the configured tolerance thresholds (true) or fell within acceptable limits (false).' ;
    rdfs:domain ind:InvoiceException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:toleranceThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Tolerance Threshold Amount' ;
    rdfs:comment 'Absolute monetary tolerance threshold configured for this PO line item or vendor. Exception is triggered when variance exceeds this amount.' ;
    rdfs:domain ind:InvoiceException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:toleranceThresholdPercent rdf:type rdf:Property ;
    rdfs:label 'Tolerance Threshold Percent' ;
    rdfs:comment 'Percentage tolerance threshold configured for this PO line item or vendor. Exception is triggered when variance exceeds this threshold.' ;
    rdfs:domain ind:InvoiceException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorResponseDate rdf:type rdf:Property ;
    rdfs:label 'Vendor Response Date' ;
    rdfs:comment 'Date when the vendor provided a response or corrective action regarding the exception. Null if no vendor response was required or received.' ;
    rdfs:domain ind:InvoiceException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:generatedWasteStreamId rdf:type rdf:Property ;
    rdfs:label 'Generated Waste Stream Id' ;
    rdfs:comment 'Foreign key linking to service.service_waste_stream. Business justification: Materials used in operations (PPE, chemicals, supplies) generate specific waste streams requiring proper characterization and disposal. Real business process: waste characterization, disposal planning' ;
    rdfs:domain ind:Material ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WasteStream .

ind:materialGroupId rdf:type rdf:Property ;
    rdfs:label 'Material Group Id' ;
    rdfs:comment 'Foreign key linking to procurement.material_group. Business justification: Material classification FK. material.material_group is a STRING code; need FK to material_group.material_group_id for proper normalization. Remove material_group code column as it becomes redundant (c' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialGroup .

ind:abcIndicator rdf:type rdf:Property ;
    rdfs:label 'Abc Indicator' ;
    rdfs:comment 'ABC classification for inventory management prioritization. A = high-value/high-usage, B = moderate, C = low-value/low-usage.' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Base Unit Of Measure' ;
    rdfs:comment 'Primary unit of measure for inventory, ordering, and usage tracking. Common values: EA (each), GAL (gallon), LB (pound), TON, KG (kilogram), L (liter), M (meter), FT (foot), BOX, CASE, DRUM, PALLET. [ENUM-REF-CANDIDATE: EA|GAL|LB|TON|KG|L|M|FT|BOX|CASE|DRUM|PALLET — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchManagedFlag rdf:type rdf:Property ;
    rdfs:label 'Batch Managed Flag' ;
    rdfs:comment 'Indicates whether the material requires batch/lot number tracking for quality control, expiration management, and recall capability.' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:createdDate rdf:type rdf:Property ;
    rdfs:label 'Created Date' ;
    rdfs:comment 'Date when the material master record was first created in the system.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossWeight rdf:type rdf:Property ;
    rdfs:label 'Gross Weight' ;
    rdfs:comment 'Total weight of the material including packaging. Used for transportation planning and freight cost calculation.' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hazardousMaterialFlag rdf:type rdf:Property ;
    rdfs:label 'Hazardous Material Flag' ;
    rdfs:comment 'Indicates whether the material is classified as hazardous under RCRA, DOT, or OSHA regulations, requiring special handling, storage, and disposal procedures.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastModifiedDate rdf:type rdf:Property ;
    rdfs:label 'Last Modified Date' ;
    rdfs:comment 'Date when the material master record was last updated or changed.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:longDescription rdf:type rdf:Property ;
    rdfs:label 'Long Description' ;
    rdfs:comment 'Extended description providing detailed specifications, usage instructions, or technical details for the material.' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialDescription rdf:type rdf:Property ;
    rdfs:label 'Material Description' ;
    rdfs:comment 'Short textual description of the material for identification and procurement purposes.' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialStatus rdf:type rdf:Property ;
    rdfs:label 'Material Status' ;
    rdfs:comment 'Current lifecycle status of the material master record. Active materials are available for procurement and use; inactive/obsolete materials are phased out.' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movingAveragePrice rdf:type rdf:Property ;
    rdfs:label 'Moving Average Price' ;
    rdfs:comment 'Moving average price calculated from actual procurement costs. Used for inventory valuation and variance analysis.' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netWeight rdf:type rdf:Property ;
    rdfs:label 'Net Weight' ;
    rdfs:comment 'Weight of the material excluding packaging. Used for usage tracking and disposal cost calculation.' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ppeCategory rdf:type rdf:Property ;
    rdfs:label 'Ppe Category' ;
    rdfs:comment 'Classification of PPE type if applicable (e.g., gloves, hi-vis vests, respirators, safety boots, hard hats). Used for OSHA compliance and workforce safety tracking.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procurementType rdf:type rdf:Property ;
    rdfs:label 'Procurement Type' ;
    rdfs:comment 'Defines whether the material is procured externally from vendors, produced internally, or both.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseOrderUnit rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Unit' ;
    rdfs:comment 'Unit of measure used when creating purchase orders for this material. May differ from base UOM for bulk purchasing. [ENUM-REF-CANDIDATE: EA|GAL|LB|TON|KG|L|M|FT|BOX|CASE|DRUM|PALLET — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serialNumberProfile rdf:type rdf:Property ;
    rdfs:label 'Serial Number Profile' ;
    rdfs:comment 'Configuration code indicating whether the material requires serial number tracking for individual unit traceability (e.g., high-value equipment, containers).' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageClass rdf:type rdf:Property ;
    rdfs:label 'Storage Class' ;
    rdfs:comment 'Classification code defining storage requirements and warehouse location assignment (e.g., flammable storage, refrigerated, outdoor, hazmat cage).' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volume rdf:type rdf:Property ;
    rdfs:label 'Volume' ;
    rdfs:comment 'Physical volume of the material used for storage space planning and transportation optimization.' ;
    rdfs:domain ind:Material ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeUnit rdf:type rdf:Property ;
    rdfs:label 'Volume Unit' ;
    rdfs:comment 'Unit of measure for volume (e.g., GAL, L, FT3, M3, IN3).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightUnit rdf:type rdf:Property ;
    rdfs:label 'Weight Unit' ;
    rdfs:comment 'Unit of measure for gross and net weight (e.g., LB, KG, TON, G, OZ).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentMaterialGroupId rdf:type rdf:Property ;
    rdfs:label 'Parent Material Group Id' ;
    rdfs:comment 'Reference to parent material group for hierarchical classification. Supports multi-level spend category rollups and reporting. Null for top-level groups.' ;
    rdfs:domain ind:MaterialGroup ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MaterialGroup .

ind:approvalWorkflowCode rdf:type rdf:Property ;
    rdfs:label 'Approval Workflow Code' ;
    rdfs:comment 'Code identifying the approval workflow required for purchase requisitions and purchase orders in this material group. Maps to SAP MM release strategy.' ;
    rdfs:domain ind:MaterialGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carbonFootprintCategory rdf:type rdf:Property ;
    rdfs:label 'Carbon Footprint Category' ;
    rdfs:comment 'Carbon footprint classification for materials in this group, used for greenhouse gas (GHG) emissions tracking and carbon dioxide equivalent (CO2e) reporting.' ;
    rdfs:domain ind:MaterialGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commodityCode rdf:type rdf:Property ;
    rdfs:label 'Commodity Code' ;
    rdfs:comment 'United Nations Standard Products and Services Code (UNSPSC) for global commodity classification and supplier catalog alignment.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Contract Required Flag' ;
    rdfs:comment 'Indicates whether purchases from this material group require an active supplier contract or blanket purchase order (PO) before procurement.' ;
    rdfs:domain ind:MaterialGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dotRegulatedIndicator rdf:type rdf:Property ;
    rdfs:label 'Dot Regulated Indicator' ;
    rdfs:comment 'Flag indicating whether materials in this group require DOT compliance for transportation, including placarding, manifesting, and driver certification.' ;
    rdfs:domain ind:MaterialGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:epaRegulatedIndicator rdf:type rdf:Property ;
    rdfs:label 'Epa Regulated Indicator' ;
    rdfs:comment 'Flag indicating whether materials in this group are subject to EPA environmental compliance tracking and reporting requirements.' ;
    rdfs:domain ind:MaterialGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:materialGroupCode rdf:type rdf:Property ;
    rdfs:label 'Material Group Code' ;
    rdfs:comment 'SAP material group code (MATKL) used for classification and procurement categorization. Alphanumeric identifier matching SAP MM material group master.' ;
    rdfs:domain ind:MaterialGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialGroupDescription rdf:type rdf:Property ;
    rdfs:label 'Material Group Description' ;
    rdfs:comment 'Detailed description of the material group, including scope, typical items, and usage guidance for procurement teams.' ;
    rdfs:domain ind:MaterialGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialGroupName rdf:type rdf:Property ;
    rdfs:label 'Material Group Name' ;
    rdfs:comment 'Full business name of the material group for display and reporting purposes.' ;
    rdfs:domain ind:MaterialGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oshaPpeRequiredIndicator rdf:type rdf:Property ;
    rdfs:label 'Osha Ppe Required Indicator' ;
    rdfs:comment 'Flag indicating whether handling materials in this group requires specific PPE under OSHA safety standards.' ;
    rdfs:domain ind:MaterialGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:spendCategory rdf:type rdf:Property ;
    rdfs:label 'Spend Category' ;
    rdfs:comment 'High-level spend classification for strategic sourcing and budget allocation. Aligns with COGS and EBITDA reporting categories. [ENUM-REF-CANDIDATE: Fleet Parts & Components|Fuel & Energy|PPE & Safety Equipment|Containers & Equipment|Chemicals & Reagents|Facility Supplies|Professional Services|Third-Party Disposal Services|IT & Technology|Other — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MaterialGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageConditionCode rdf:type rdf:Property ;
    rdfs:label 'Storage Condition Code' ;
    rdfs:comment 'Required storage conditions for materials in this group: ambient, refrigerated, frozen, climate-controlled, hazmat-compliant storage, outdoor, or secure storage. [ENUM-REF-CANDIDATE: AMBIENT|REFRIGERATED|FROZEN|CLIMATE_CONTROLLED|HAZMAT_STORAGE|OUTDOOR|SECURE — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MaterialGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategicSourcingFlag rdf:type rdf:Property ;
    rdfs:label 'Strategic Sourcing Flag' ;
    rdfs:comment 'Indicates whether this material group is managed under a strategic sourcing program with negotiated contracts, preferred suppliers, and volume commitments.' ;
    rdfs:domain ind:MaterialGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supplierDiversityFlag rdf:type rdf:Property ;
    rdfs:label 'Supplier Diversity Flag' ;
    rdfs:comment 'Indicates whether this material group is targeted for supplier diversity programs (minority-owned, women-owned, veteran-owned, small business suppliers).' ;
    rdfs:domain ind:MaterialGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sustainabilityCategory rdf:type rdf:Property ;
    rdfs:label 'Sustainability Category' ;
    rdfs:comment 'Sustainability classification for materials in this group, supporting green procurement initiatives and ESG reporting. [ENUM-REF-CANDIDATE: Renewable|Recycled Content|Energy Efficient|Low Emission|Biodegradable|Conventional|Not Applicable — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MaterialGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxClassificationCode rdf:type rdf:Property ;
    rdfs:label 'Tax Classification Code' ;
    rdfs:comment 'Tax classification code for materials in this group, determining applicable sales tax, use tax, or VAT treatment. Maps to SAP SD tax determination.' ;
    rdfs:domain ind:MaterialGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationClass rdf:type rdf:Property ;
    rdfs:label 'Valuation Class' ;
    rdfs:comment 'SAP valuation class for inventory accounting and balance sheet classification. Determines how material value is posted to financial accounts.' ;
    rdfs:domain ind:MaterialGroup ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deletionIndicator rdf:type rdf:Property ;
    rdfs:label 'Deletion Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this purchase order line has been marked for deletion. Deleted lines are excluded from further processing but retained for audit history.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:finalInvoiceIndicator rdf:type rdf:Property ;
    rdfs:label 'Final Invoice Indicator' ;
    rdfs:comment 'Boolean flag indicating whether the final invoice has been received for this line item. When true, no further invoices are expected and the line can be closed.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:goodsReceiptBasedInvoiceVerification rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Based Invoice Verification' ;
    rdfs:comment 'Boolean flag indicating whether invoice verification is based on goods receipt rather than purchase order. When true, invoices are matched against goods receipts.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:goodsReceiptIndicator rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Indicator' ;
    rdfs:comment 'Boolean flag indicating whether a goods receipt is required for this line item. When true, a goods receipt transaction must be posted before invoice verification.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:invoiceReceiptIndicator rdf:type rdf:Property ;
    rdfs:label 'Invoice Receipt Indicator' ;
    rdfs:comment 'Boolean flag indicating whether invoice verification is required for this line item. Controls the three-way match process (Purchase Order - Goods Receipt - Invoice).' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:itemCategory rdf:type rdf:Property ;
    rdfs:label 'Item Category' ;
    rdfs:comment 'The purchase order item category code that controls the procurement behavior (e.g., standard item, consignment, subcontracting, service, text item). Determines processing rules and account assignment.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netValue rdf:type rdf:Property ;
    rdfs:label 'Net Value' ;
    rdfs:comment 'The total net value of this purchase order line (quantity ordered multiplied by unit price). Excludes taxes and surcharges. Key metric for spend analytics and Cost of Goods Sold (COGS) reporting.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:openQuantity rdf:type rdf:Property ;
    rdfs:label 'Open Quantity' ;
    rdfs:comment 'The remaining quantity still outstanding for delivery. Calculated as quantity ordered minus quantity received.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overDeliveryTolerancePercent rdf:type rdf:Property ;
    rdfs:label 'Over Delivery Tolerance Percent' ;
    rdfs:comment 'The acceptable percentage over-delivery tolerance for this line item. Allows goods receipt posting up to this percentage above the ordered quantity.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:purchasingInfoRecord rdf:type rdf:Property ;
    rdfs:label 'Purchasing Info Record' ;
    rdfs:comment 'Reference to the purchasing info record that contains vendor-specific material data, pricing conditions, and delivery terms. Supports vendor performance tracking and price history.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityInvoiced rdf:type rdf:Property ;
    rdfs:label 'Quantity Invoiced' ;
    rdfs:comment 'The cumulative quantity that has been invoiced by the vendor against this purchase order line. Used for three-way match validation.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityOrdered rdf:type rdf:Property ;
    rdfs:label 'Quantity Ordered' ;
    rdfs:comment 'The total quantity of material or service units ordered on this line item. Represents the original purchase order commitment.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityReceived rdf:type rdf:Property ;
    rdfs:label 'Quantity Received' ;
    rdfs:comment 'The cumulative quantity of goods or services that have been received against this purchase order line. Updated through goods receipt (GR) transactions.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requisitionerName rdf:type rdf:Property ;
    rdfs:label 'Requisitioner Name' ;
    rdfs:comment 'The name of the employee or department that requested this procurement. Used for accountability and spend analysis by requesting organization.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortText rdf:type rdf:Property ;
    rdfs:label 'Short Text' ;
    rdfs:comment 'Brief description of the material or service being procured on this line. Provides human-readable context for the line item.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:underDeliveryTolerancePercent rdf:type rdf:Property ;
    rdfs:label 'Under Delivery Tolerance Percent' ;
    rdfs:comment 'The acceptable percentage under-delivery tolerance for this line item. Allows the line to be closed when delivery is within this percentage below the ordered quantity.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:purchaseRequisitionId rdf:type rdf:Property ;
    rdfs:label 'Purchase Requisition Id' ;
    rdfs:comment 'Foreign key linking to procurement.purchase_requisition. Business justification: Purchase orders are created from purchase requisitions. Currently has requisition_reference (STRING PR number); need FK to purchase_requisition.purchase_requisition_id for proper lineage tracking. Rem' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseRequisition .

ind:collectiveNumber rdf:type rdf:Property ;
    rdfs:label 'Collective Number' ;
    rdfs:comment 'Grouping identifier for related purchase orders processed together. Used for batch processing and consolidated vendor communication.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netPoValue rdf:type rdf:Property ;
    rdfs:label 'Net Po Value' ;
    rdfs:comment 'Total purchase order value including tax. Represents the final amount payable to the vendor upon fulfillment.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plant rdf:type rdf:Property ;
    rdfs:label 'Plant' ;
    rdfs:comment 'Physical location or facility where goods will be received or services will be performed. May represent landfill sites, Materials Recovery Facility (MRF), fleet maintenance depots, or administrative offices.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseDate rdf:type rdf:Property ;
    rdfs:label 'Release Date' ;
    rdfs:comment 'Date when the purchase order was released and transmitted to the vendor. Marks the start of vendor fulfillment obligations.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shippingInstructions rdf:type rdf:Property ;
    rdfs:label 'Shipping Instructions' ;
    rdfs:comment 'Special instructions for delivery, handling, or transportation of goods. May include requirements for hazardous materials handling, Department of Transportation (DOT) compliance, or site-specific access procedures.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalPoValue rdf:type rdf:Property ;
    rdfs:label 'Total Po Value' ;
    rdfs:comment 'Total monetary value of the purchase order including all line items, before tax. Used for spend analytics, budget tracking, and Cost of Goods Sold (COGS) reporting.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:validityEndDate rdf:type rdf:Property ;
    rdfs:label 'Validity End Date' ;
    rdfs:comment 'End date of the purchase order validity period. After this date, no further releases or goods receipts are permitted against the PO.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validityStartDate rdf:type rdf:Property ;
    rdfs:label 'Validity Start Date' ;
    rdfs:comment 'Start date of the purchase order validity period. Relevant for blanket and framework orders with defined time windows.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:vendorContactPerson rdf:type rdf:Property ;
    rdfs:label 'Vendor Contact Person' ;
    rdfs:comment 'Name of the primary contact person at the vendor organization for this purchase order. Used for order clarification and issue resolution.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetPeriod rdf:type rdf:Property ;
    rdfs:label 'Budget Period' ;
    rdfs:comment 'Fiscal period (month) within the budget year for granular budget tracking and variance analysis.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:budgetYear rdf:type rdf:Property ;
    rdfs:label 'Budget Year' ;
    rdfs:comment 'Fiscal year against which the requisition expense is budgeted and tracked for financial planning.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedTotalValue rdf:type rdf:Property ;
    rdfs:label 'Estimated Total Value' ;
    rdfs:comment 'Total estimated value of the requisition (quantity × estimated unit price) for budget authorization and spend control.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedUnitPrice rdf:type rdf:Property ;
    rdfs:label 'Estimated Unit Price' ;
    rdfs:comment 'Estimated price per unit for budget planning and pre-commitment purposes.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:internalOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Internal Order Number' ;
    rdfs:comment 'Internal order number for tracking costs related to specific operational activities or maintenance work orders.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCapitalExpenditure rdf:type rdf:Property ;
    rdfs:label 'Is Capital Expenditure' ;
    rdfs:comment 'Flag indicating whether the requisition is for capital expenditure requiring asset capitalization (true) or operational expenditure (false).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isEmergencyPurchase rdf:type rdf:Property ;
    rdfs:label 'Is Emergency Purchase' ;
    rdfs:comment 'Flag indicating whether this is an emergency requisition requiring expedited approval and procurement due to operational urgency.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:justification rdf:type rdf:Property ;
    rdfs:label 'Justification' ;
    rdfs:comment 'Business justification or reason for the purchase requisition, explaining the operational need and urgency.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prNumber rdf:type rdf:Property ;
    rdfs:label 'Pr Number' ;
    rdfs:comment 'Business-facing unique purchase requisition number used for tracking and reference across procurement workflows.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prStatus rdf:type rdf:Property ;
    rdfs:label 'Pr Status' ;
    rdfs:comment 'Current lifecycle status of the purchase requisition in the approval and procurement workflow. [ENUM-REF-CANDIDATE: draft|submitted|pending_approval|approved|rejected|partially_ordered|fully_ordered|cancelled|closed — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prType rdf:type rdf:Property ;
    rdfs:label 'Pr Type' ;
    rdfs:comment 'Classification of the requisition based on procurement category: standard purchase, stock replenishment, service procurement, subcontracting, consignment, or third-party.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredVendorCode rdf:type rdf:Property ;
    rdfs:label 'Preferred Vendor Code' ;
    rdfs:comment 'Vendor code for the preferred or suggested supplier, if specified by the requester.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestingDepartmentCode rdf:type rdf:Property ;
    rdfs:label 'Requesting Department Code' ;
    rdfs:comment 'Code identifying the operational department initiating the requisition (e.g., fleet maintenance, landfill operations, MRF, hazmat, facilities).' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestingDepartmentName rdf:type rdf:Property ;
    rdfs:label 'Requesting Department Name' ;
    rdfs:comment 'Full name of the department requesting the goods or services.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Required Delivery Date' ;
    rdfs:comment 'Date by which the requested goods or services must be delivered to meet operational needs.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requisitionDate rdf:type rdf:Property ;
    rdfs:label 'Requisition Date' ;
    rdfs:comment 'Date when the purchase requisition was created or submitted by the requesting department.' ;
    rdfs:domain ind:PurchaseRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:awardedVendorId rdf:type rdf:Property ;
    rdfs:label 'Awarded Vendor Id' ;
    rdfs:comment 'Identifier of the vendor selected and awarded the business following RFQ evaluation. Null if RFQ is not yet awarded or was cancelled.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:sourcingEventId rdf:type rdf:Property ;
    rdfs:label 'Sourcing Event Id' ;
    rdfs:comment 'Identifier linking this RFQ to a broader strategic sourcing event or category management initiative. Used for spend analytics and sourcing program tracking.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SourcingEvent .

ind:awardDate rdf:type rdf:Property ;
    rdfs:label 'Award Date' ;
    rdfs:comment 'Date when the RFQ was formally awarded to the selected vendor. Marks the transition from sourcing to contracting phase.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:awardJustification rdf:type rdf:Property ;
    rdfs:label 'Award Justification' ;
    rdfs:comment 'Business rationale and documentation for the vendor selection decision. Includes evaluation summary and compliance with procurement policies.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commodityDescription rdf:type rdf:Property ;
    rdfs:label 'Commodity Description' ;
    rdfs:comment 'Detailed textual description of the materials, equipment, fuel, containers, or services being requested. Includes specifications, quality requirements, and technical details.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Delivery Address Line 1' ;
    rdfs:comment 'Primary street address line for delivery of goods or performance of services. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Delivery Address Line 2' ;
    rdfs:comment 'Secondary address line for delivery location (suite, building, department). Organizational contact data classified as confidential.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryCity rdf:type rdf:Property ;
    rdfs:label 'Delivery City' ;
    rdfs:comment 'City name for the delivery address. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryCountryCode rdf:type rdf:Property ;
    rdfs:label 'Delivery Country Code' ;
    rdfs:comment 'Three-letter ISO country code for the delivery address (e.g., USA, CAN, MEX).' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryPostalCode rdf:type rdf:Property ;
    rdfs:label 'Delivery Postal Code' ;
    rdfs:comment 'Postal or ZIP code for the delivery address. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryStateProvince rdf:type rdf:Property ;
    rdfs:label 'Delivery State Province' ;
    rdfs:comment 'State or province code for the delivery address. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Budget Amount' ;
    rdfs:comment 'Internal budget estimate or target price for the procurement. Confidential business data not shared with vendors. Used for cost control and EBITDA planning.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evaluationCriteria rdf:type rdf:Property ;
    rdfs:label 'Evaluation Criteria' ;
    rdfs:comment 'Documented criteria and weighting factors used to evaluate and compare vendor quotations. May include price, quality, delivery time, vendor performance history, sustainability, and compliance factors.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumQualificationRequirements rdf:type rdf:Property ;
    rdfs:label 'Minimum Qualification Requirements' ;
    rdfs:comment 'Mandatory qualifications vendors must meet to be considered, such as certifications, insurance coverage, safety records, or regulatory compliance (e.g., RCRA, DOT, OSHA).' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minorityOwnedPreferenceFlag rdf:type rdf:Property ;
    rdfs:label 'Minority Owned Preference Flag' ;
    rdfs:comment 'Indicates whether this RFQ includes preference or set-aside provisions for minority-owned businesses. Supports supplier diversity goals.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:numberOfResponsesReceived rdf:type rdf:Property ;
    rdfs:label 'Number Of Responses Received' ;
    rdfs:comment 'Count of vendor quotations received by the submission deadline. Indicates market interest and competitive intensity.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numberOfVendorsInvited rdf:type rdf:Property ;
    rdfs:label 'Number Of Vendors Invited' ;
    rdfs:comment 'Count of vendors to whom the RFQ was issued. Used to measure competitive sourcing effectiveness.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rfqNumber rdf:type rdf:Property ;
    rdfs:label 'Rfq Number' ;
    rdfs:comment 'Business document number assigned to the RFQ in the procurement system. Externally visible identifier used for vendor communication and tracking.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfqStatus rdf:type rdf:Property ;
    rdfs:label 'Rfq Status' ;
    rdfs:comment 'Current lifecycle status of the RFQ. Draft indicates preparation phase, issued means sent to vendors, open indicates awaiting responses, closed means submission deadline passed, awarded means vendor selected, cancelled means RFQ withdrawn.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfqType rdf:type rdf:Property ;
    rdfs:label 'Rfq Type' ;
    rdfs:comment 'Classification of the RFQ based on procurement strategy and urgency. Standard for routine sourcing, blanket for framework agreements, spot for one-time purchases, emergency for urgent needs, strategic for high-value or high-risk categories.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:smallBusinessPreferenceFlag rdf:type rdf:Property ;
    rdfs:label 'Small Business Preference Flag' ;
    rdfs:comment 'Indicates whether this RFQ includes preference or set-aside provisions for small businesses. Supports supplier diversity and local sourcing goals.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:submissionDeadlineTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submission Deadline Timestamp' ;
    rdfs:comment 'Date and time by which vendors must submit their quotations. After this timestamp, the RFQ is typically closed to new submissions.' ;
    rdfs:domain ind:Rfq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sustainabilityRequirements rdf:type rdf:Property ;
    rdfs:label 'Sustainability Requirements' ;
    rdfs:comment 'Environmental and sustainability criteria vendors must meet, such as greenhouse gas (GHG) emissions reporting, renewable natural gas (RNG) availability, recycled content, or ISO 14001 certification.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceEntrySheetId rdf:type rdf:Property ;
    rdfs:label 'Service Entry Sheet Id' ;
    rdfs:comment 'Unique identifier for the service entry sheet record. Primary key.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceEntrySheet .

ind:tertiaryServiceLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Service Last Modified By User Employee Id' ;
    rdfs:comment 'User ID of the person who last modified the service entry sheet record.' ;
    rdfs:domain ind:ServiceEntrySheet ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:acceptanceDate rdf:type rdf:Property ;
    rdfs:label 'Acceptance Date' ;
    rdfs:comment 'Date when the service entry was formally accepted by the approver, enabling invoice verification and payment processing.' ;
    rdfs:domain ind:ServiceEntrySheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:acceptanceStatus rdf:type rdf:Property ;
    rdfs:label 'Acceptance Status' ;
    rdfs:comment 'Current lifecycle status of the service entry sheet: draft (being prepared), submitted (awaiting approval), accepted (approved for payment), rejected (not accepted), or cancelled.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approverName rdf:type rdf:Property ;
    rdfs:label 'Approver Name' ;
    rdfs:comment 'Full name of the employee who approved the service entry sheet.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Invoice Reference Number' ;
    rdfs:comment 'Vendor invoice number that references this service entry sheet for payment verification.' ;
    rdfs:domain ind:ServiceEntrySheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceVerificationStatus rdf:type rdf:Property ;
    rdfs:label 'Invoice Verification Status' ;
    rdfs:comment 'Status of invoice verification against this service entry: not verified, verified (matched to invoice), blocked (discrepancy found), or posted (payment released).' ;
    rdfs:domain ind:ServiceEntrySheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceEntrySheetNumber rdf:type rdf:Property ;
    rdfs:label 'Service Entry Sheet Number' ;
    rdfs:comment 'Business identifier for the service entry sheet, externally visible document number used for tracking and reference in SAP MM.' ;
    rdfs:domain ind:ServiceEntrySheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:servicePerformerName rdf:type rdf:Property ;
    rdfs:label 'Service Performer Name' ;
    rdfs:comment 'Name of the individual or team from the vendor who performed the service.' ;
    rdfs:domain ind:ServiceEntrySheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceTotalAmount rdf:type rdf:Property ;
    rdfs:label 'Service Total Amount' ;
    rdfs:comment 'Total monetary value of the service entry, calculated as service quantity multiplied by unit price.' ;
    rdfs:domain ind:ServiceEntrySheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceUnitPrice rdf:type rdf:Property ;
    rdfs:label 'Service Unit Price' ;
    rdfs:comment 'Price per unit of service as agreed in the purchase order, used for invoice verification.' ;
    rdfs:domain ind:ServiceEntrySheet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceListId rdf:type rdf:Property ;
    rdfs:label 'Source List Id' ;
    rdfs:comment 'Unique identifier for the source list record. Primary key.' ;
    rdfs:domain ind:SourceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceCreatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Source Created By User Employee Id' ;
    rdfs:comment 'The system user ID of the procurement employee who created this source list entry. Provides audit trail for record creation.' ;
    rdfs:domain ind:SourceList ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:sourceEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Source Employee Id' ;
    rdfs:comment 'The system user ID of the procurement or vendor management employee who blocked this source list entry. Provides accountability for blocking decisions.' ;
    rdfs:domain ind:SourceList ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:sourceLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Source Last Modified By User Employee Id' ;
    rdfs:comment 'The system user ID of the procurement employee who last modified this source list entry. Provides audit trail for record changes.' ;
    rdfs:domain ind:SourceList ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:agreementItemNumber rdf:type rdf:Property ;
    rdfs:label 'Agreement Item Number' ;
    rdfs:comment 'Five-digit line item number within the referenced purchasing agreement that corresponds to this source list entry. Identifies the specific material line in the contract.' ;
    rdfs:domain ind:SourceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockedDate rdf:type rdf:Property ;
    rdfs:label 'Blocked Date' ;
    rdfs:comment 'The date on which this source list entry was blocked from use. Used for audit trails and vendor performance tracking.' ;
    rdfs:domain ind:SourceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:blockedFlag rdf:type rdf:Property ;
    rdfs:label 'Blocked Flag' ;
    rdfs:comment 'Flag indicating whether this source list entry is temporarily blocked from use. When true, prevents new purchase orders from being created with this vendor for this material, typically due to quality issues, contract disputes, or vendor performance problems.' ;
    rdfs:domain ind:SourceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:blockedReasonCode rdf:type rdf:Property ;
    rdfs:label 'Blocked Reason Code' ;
    rdfs:comment 'Categorical code indicating the reason why this source list entry is blocked, if applicable. Provides context for procurement restrictions and vendor management actions.' ;
    rdfs:domain ind:SourceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalMaterialFlag rdf:type rdf:Property ;
    rdfs:label 'Critical Material Flag' ;
    rdfs:comment 'Flag indicating whether this material is classified as business-critical at this plant, requiring special procurement controls. Examples include CNG fuel for fleet operations, hazmat disposal services, or OEM parts for critical equipment.' ;
    rdfs:domain ind:SourceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:environmentalComplianceCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Environmental Compliance Certified Flag' ;
    rdfs:comment 'Flag indicating whether this vendor holds required environmental certifications such as ISO 14001, EPA permits, or state environmental quality approvals relevant to the material being supplied.' ;
    rdfs:domain ind:SourceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fixedSourceIndicator rdf:type rdf:Property ;
    rdfs:label 'Fixed Source Indicator' ;
    rdfs:comment 'Flag indicating whether this vendor is the sole authorized source for the material at this plant. When true, enforces sole-source procurement policy and prevents PO creation with other vendors.' ;
    rdfs:domain ind:SourceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazmatApprovedFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Approved Flag' ;
    rdfs:comment 'Flag indicating whether this vendor is approved and certified to supply hazardous materials per RCRA, DOT, and EPA requirements. Required for vendors supplying chemicals, hazardous waste disposal services, or regulated substances.' ;
    rdfs:domain ind:SourceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mrpRelevantFlag rdf:type rdf:Property ;
    rdfs:label 'Mrp Relevant Flag' ;
    rdfs:comment 'Flag indicating whether this source list entry is considered during MRP runs for automatic purchase requisition generation. When true, MRP will propose this vendor for material replenishment.' ;
    rdfs:domain ind:SourceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:oemAuthorizedFlag rdf:type rdf:Property ;
    rdfs:label 'Oem Authorized Flag' ;
    rdfs:comment 'Flag indicating whether this vendor is an authorized OEM supplier or distributor for the material. Critical for fleet parts procurement to ensure warranty compliance and genuine parts sourcing.' ;
    rdfs:domain ind:SourceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orderUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Order Unit Of Measure' ;
    rdfs:comment 'The unit of measure in which orders must be placed with this vendor for this material. Examples include EA (each), GAL (gallon), TON (ton), LB (pound), or CY (cubic yard).' ;
    rdfs:domain ind:SourceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredVendorRank rdf:type rdf:Property ;
    rdfs:label 'Preferred Vendor Rank' ;
    rdfs:comment 'Numeric ranking indicating vendor preference order when multiple approved sources exist for the same material at the same plant. Lower numbers indicate higher preference. Used for automated vendor selection in procurement workflows.' ;
    rdfs:domain ind:SourceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quotaArrangementNumber rdf:type rdf:Property ;
    rdfs:label 'Quota Arrangement Number' ;
    rdfs:comment 'Reference to the quota arrangement that governs order distribution when multiple vendors supply the same material. Defines percentage splits and allocation rules across approved sources.' ;
    rdfs:domain ind:SourceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceDeterminationRule rdf:type rdf:Property ;
    rdfs:label 'Source Determination Rule' ;
    rdfs:comment 'Defines how the system should select this vendor during purchase requisition processing. Automatic allows system-driven vendor selection, manual requires buyer intervention, and quota arrangement distributes orders across multiple vendors per defined percentages.' ;
    rdfs:domain ind:SourceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardDeliveryLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Standard Delivery Lead Time Days' ;
    rdfs:comment 'The expected number of calendar days from purchase order placement to material delivery for this vendor-material-plant combination. Used for MRP planning and delivery date calculation.' ;
    rdfs:domain ind:SourceList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primarySourcingApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Sourcing Approved By Employee Id' ;
    rdfs:comment 'Identifier of the employee who provided final approval for this sourcing contract, typically a procurement director or authorized signatory.' ;
    rdfs:domain ind:SourcingContract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:complianceCertificationsRequired rdf:type rdf:Property ;
    rdfs:label 'Compliance Certifications Required' ;
    rdfs:comment 'List of regulatory certifications and compliance documentation required from the vendor (e.g., ISO 14001, OSHA compliance, DOT certification, EPA permits). Pipe-separated if multiple.' ;
    rdfs:domain ind:SourcingContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityFlag rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Flag' ;
    rdfs:comment 'Indicates whether this contract contains confidential or proprietary terms that require restricted access. True if confidential, False if standard business terms.' ;
    rdfs:domain ind:SourcingContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractValueTotal rdf:type rdf:Property ;
    rdfs:label 'Contract Value Total' ;
    rdfs:comment 'Total monetary value committed under this sourcing contract over its full term. Used for spend tracking and EBITDA reporting.' ;
    rdfs:domain ind:SourcingContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryTerms rdf:type rdf:Property ;
    rdfs:label 'Delivery Terms' ;
    rdfs:comment 'Specific delivery requirements and conditions negotiated with the vendor, including lead times, delivery windows, and special handling instructions.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceRequirements rdf:type rdf:Property ;
    rdfs:label 'Insurance Requirements' ;
    rdfs:comment 'Insurance coverage types and minimum limits required from the vendor (e.g., general liability, professional liability, workers compensation). Null if no insurance requirements.' ;
    rdfs:domain ind:SourcingContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumQuantityCommitment rdf:type rdf:Property ;
    rdfs:label 'Maximum Quantity Commitment' ;
    rdfs:comment 'Maximum quantity of goods or services that can be purchased under this contract. Null if no maximum limit exists.' ;
    rdfs:domain ind:SourcingContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumQuantityCommitment rdf:type rdf:Property ;
    rdfs:label 'Minimum Quantity Commitment' ;
    rdfs:comment 'Minimum quantity of goods or services that Waste Management commits to purchase under this contract. Null if no minimum commitment exists.' ;
    rdfs:domain ind:SourcingContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyProvisions rdf:type rdf:Property ;
    rdfs:label 'Penalty Provisions' ;
    rdfs:comment 'Financial penalties or liquidated damages applicable for vendor non-performance, late delivery, quality failures, or other contract breaches.' ;
    rdfs:domain ind:SourcingContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceMetrics rdf:type rdf:Property ;
    rdfs:label 'Performance Metrics' ;
    rdfs:comment 'Key Performance Indicators (KPIs) and Service Level Agreements (SLAs) defined for vendor performance measurement (e.g., on-time delivery rate, defect rate, response time).' ;
    rdfs:domain ind:SourcingContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingConditionType rdf:type rdf:Property ;
    rdfs:label 'Pricing Condition Type' ;
    rdfs:comment 'Pricing structure applied to this contract. Fixed Price for constant unit cost, Variable Price for fluctuating rates, Cost Plus for cost recovery plus margin, Market Indexed for prices tied to commodity indices, Tiered Pricing for volume-based rates, Volume Discount for quantity-based reductions.' ;
    rdfs:domain ind:SourcingContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityRequirements rdf:type rdf:Property ;
    rdfs:label 'Quality Requirements' ;
    rdfs:comment 'Quality standards, specifications, and acceptance criteria that goods or services must meet under this contract. May reference industry standards or internal specifications.' ;
    rdfs:domain ind:SourcingContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourcingContractLineId rdf:type rdf:Property ;
    rdfs:label 'Sourcing Contract Line Id' ;
    rdfs:comment 'Unique identifier for the sourcing contract line item. Primary key.' ;
    rdfs:domain ind:SourcingContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lineValidFromDate rdf:type rdf:Property ;
    rdfs:label 'Line Valid From Date' ;
    rdfs:comment 'Start date from which this contract line item becomes effective and can be used for procurement.' ;
    rdfs:domain ind:SourcingContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lineValidToDate rdf:type rdf:Property ;
    rdfs:label 'Line Valid To Date' ;
    rdfs:comment 'End date after which this contract line item expires and can no longer be used for procurement. Nullable for open-ended lines.' ;
    rdfs:domain ind:SourcingContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maximumOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Maximum Order Quantity' ;
    rdfs:comment 'Maximum quantity that can be ordered per release against this contract line. Enforces contract limits or vendor capacity constraints.' ;
    rdfs:domain ind:SourcingContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceScaleBasis rdf:type rdf:Property ;
    rdfs:label 'Price Scale Basis' ;
    rdfs:comment 'Basis for price scaling: quantity-based tiers, value-based tiers, or none if flat pricing applies.' ;
    rdfs:domain ind:SourcingContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceScaleIndicator rdf:type rdf:Property ;
    rdfs:label 'Price Scale Indicator' ;
    rdfs:comment 'Flag indicating whether this contract line uses tiered or volume-based pricing scales. True if price varies by quantity thresholds.' ;
    rdfs:domain ind:SourcingContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:releaseOrderCount rdf:type rdf:Property ;
    rdfs:label 'Release Order Count' ;
    rdfs:comment 'Total number of purchase orders (PO) or release orders created against this contract line. Tracks utilization frequency.' ;
    rdfs:domain ind:SourcingContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:releasedQuantity rdf:type rdf:Property ;
    rdfs:label 'Released Quantity' ;
    rdfs:comment 'Cumulative quantity released against this contract line through purchase orders (PO) or release orders. Tracks spend-against-contract compliance.' ;
    rdfs:domain ind:SourcingContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remainingQuantity rdf:type rdf:Property ;
    rdfs:label 'Remaining Quantity' ;
    rdfs:comment 'Remaining quantity available for release under this contract line. Calculated as target quantity minus released quantity.' ;
    rdfs:domain ind:SourcingContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetQuantity rdf:type rdf:Property ;
    rdfs:label 'Target Quantity' ;
    rdfs:comment 'Total contracted quantity or volume commitment for this line item over the contract validity period. Used for contract utilization tracking.' ;
    rdfs:domain ind:SourcingContractLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spendCategoryId rdf:type rdf:Property ;
    rdfs:label 'Spend Category Id' ;
    rdfs:comment 'Unique identifier for the spend category. Primary key.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SpendCategory .

ind:parentCategorySpendCategoryId rdf:type rdf:Property ;
    rdfs:label 'Parent Category Spend Category Id' ;
    rdfs:comment 'Foreign key reference to the parent spend category in the hierarchical taxonomy. Null for top-level categories.' ;
    rdfs:domain ind:SpendCategory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SpendCategory .

ind:primarySpendEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Spend Employee Id' ;
    rdfs:comment 'System user identifier of the person who created this spend category record.' ;
    rdfs:domain ind:SpendCategory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:annualSpendBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Spend Budget Amount' ;
    rdfs:comment 'Budgeted annual spend amount for this category in the current fiscal year. Used for budget variance reporting and spend analytics.' ;
    rdfs:domain ind:SpendCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvalWorkflowRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Approval Workflow Required Flag' ;
    rdfs:comment 'Indicates whether purchases in this category require multi-level approval workflow beyond standard Purchase Order (PO) authorization.' ;
    rdfs:domain ind:SpendCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:categoryCode rdf:type rdf:Property ;
    rdfs:label 'Category Code' ;
    rdfs:comment 'Unique alphanumeric code identifying the spend category in the enterprise taxonomy. Used for reporting and system integration.' ;
    rdfs:domain ind:SpendCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryDescription rdf:type rdf:Property ;
    rdfs:label 'Category Description' ;
    rdfs:comment 'Detailed description of the spend category scope, including examples of goods or services classified under this category.' ;
    rdfs:domain ind:SpendCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryName rdf:type rdf:Property ;
    rdfs:label 'Category Name' ;
    rdfs:comment 'Full business name of the spend category (e.g., Fleet Parts, Diesel Fuel, Personal Protective Equipment).' ;
    rdfs:domain ind:SpendCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryType rdf:type rdf:Property ;
    rdfs:label 'Category Type' ;
    rdfs:comment 'Indicates whether this category applies to goods, services, or both.' ;
    rdfs:domain ind:SpendCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cogsClassification rdf:type rdf:Property ;
    rdfs:label 'Cogs Classification' ;
    rdfs:comment 'Classification indicating how spend in this category impacts Cost of Goods Sold (COGS) and Earnings Before Interest Taxes Depreciation and Amortization (EBITDA) reporting.' ;
    rdfs:domain ind:SpendCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractCoveragePercent rdf:type rdf:Property ;
    rdfs:label 'Contract Coverage Percent' ;
    rdfs:comment 'Percentage of spend in this category covered by active supplier contracts. Higher coverage indicates better cost control and compliance.' ;
    rdfs:domain ind:SpendCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costElementGroup rdf:type rdf:Property ;
    rdfs:label 'Cost Element Group' ;
    rdfs:comment 'SAP Controlling (CO) cost element group code associated with this spend category. Used for internal cost allocation and profitability analysis.' ;
    rdfs:domain ind:SpendCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ebitdaImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Ebitda Impact Flag' ;
    rdfs:comment 'Indicates whether spend in this category directly impacts EBITDA calculations. True if the category affects EBITDA, False otherwise.' ;
    rdfs:domain ind:SpendCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:environmentalComplianceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Environmental Compliance Required Flag' ;
    rdfs:comment 'Indicates whether procurement in this category requires environmental compliance documentation or certifications (e.g., ISO 14001, EPA permits).' ;
    rdfs:domain ind:SpendCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:glAccountRangeEnd rdf:type rdf:Property ;
    rdfs:label 'Gl Account Range End' ;
    rdfs:comment 'Ending General Ledger account number in the range mapped to this spend category. Used for financial reporting and Cost of Goods Sold (COGS) allocation.' ;
    rdfs:domain ind:SpendCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccountRangeStart rdf:type rdf:Property ;
    rdfs:label 'Gl Account Range Start' ;
    rdfs:comment 'Starting General Ledger account number in the range mapped to this spend category. Used for financial reporting and Cost of Goods Sold (COGS) allocation.' ;
    rdfs:domain ind:SpendCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:level1Category rdf:type rdf:Property ;
    rdfs:label 'Level 1 Category' ;
    rdfs:comment 'Top-level classification in the spend hierarchy. Direct Operations includes operational expenditures directly tied to service delivery. Indirect includes support and administrative costs. Capital includes long-term asset investments.' ;
    rdfs:domain ind:SpendCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:level2Category rdf:type rdf:Property ;
    rdfs:label 'Level 2 Category' ;
    rdfs:comment 'Second-level classification providing functional grouping within Level 1 (e.g., Fleet, Fuel, Disposal, Facilities, Safety, Professional Services). [ENUM-REF-CANDIDATE: Fleet|Fuel|Disposal|Facilities|Safety|Professional Services|Equipment|Containers|Chemicals|IT|HR|Marketing — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SpendCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:level3Category rdf:type rdf:Property ;
    rdfs:label 'Level 3 Category' ;
    rdfs:comment 'Granular sub-category providing detailed classification within Level 2 (e.g., Diesel Fuel, Compressed Natural Gas (CNG), Hydraulic Fluids, Brake Parts, Safety Gloves).' ;
    rdfs:domain ind:SpendCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumOrderValue rdf:type rdf:Property ;
    rdfs:label 'Minimum Order Value' ;
    rdfs:comment 'Minimum purchase order value threshold for this category. Orders below this threshold may require consolidation or alternative procurement methods.' ;
    rdfs:domain ind:SpendCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preferredVendorCount rdf:type rdf:Property ;
    rdfs:label 'Preferred Vendor Count' ;
    rdfs:comment 'Number of preferred or approved vendors for this spend category. Used to track supplier concentration and sourcing strategy execution.' ;
    rdfs:domain ind:SpendCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:safetyCertificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Certification Required Flag' ;
    rdfs:comment 'Indicates whether goods or services in this category require Occupational Safety and Health Administration (OSHA) or other safety certifications.' ;
    rdfs:domain ind:SpendCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:spendCategoryStatus rdf:type rdf:Property ;
    rdfs:label 'Spend Category Status' ;
    rdfs:comment 'Current lifecycle status of the spend category. Active categories are available for use in procurement transactions. Inactive or deprecated categories are retained for historical reporting only.' ;
    rdfs:domain ind:SpendCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategicSourcingPriority rdf:type rdf:Property ;
    rdfs:label 'Strategic Sourcing Priority' ;
    rdfs:comment 'Priority level assigned to this spend category for strategic sourcing initiatives. Critical and High priority categories receive focused supplier negotiation and contract management.' ;
    rdfs:domain ind:SpendCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountsPayableContactEmail rdf:type rdf:Property ;
    rdfs:label 'Accounts Payable Contact Email' ;
    rdfs:comment 'Email address for the vendor\'s accounts payable contact.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountsPayableContactName rdf:type rdf:Property ;
    rdfs:label 'Accounts Payable Contact Name' ;
    rdfs:comment 'Full name of the vendor\'s accounts payable or billing contact for invoice and payment inquiries.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dunsNumber rdf:type rdf:Property ;
    rdfs:label 'Duns Number' ;
    rdfs:comment 'Nine-digit unique identifier assigned by Dun & Bradstreet, used for vendor credit checks and risk assessment.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceCertificateOnFileFlag rdf:type rdf:Property ;
    rdfs:label 'Insurance Certificate On File Flag' ;
    rdfs:comment 'Indicates whether a current certificate of insurance (COI) is on file for the vendor, required for risk management and contract compliance.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minorityOwnedFlag rdf:type rdf:Property ;
    rdfs:label 'Minority Owned Flag' ;
    rdfs:comment 'Indicates whether the vendor is certified as a minority-owned business enterprise (MBE) for diversity spend reporting.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:name2 rdf:type rdf:Property ;
    rdfs:label 'Name 2' ;
    rdfs:comment 'Additional name line for vendor, used for extended legal names or doing-business-as (DBA) names.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onboardingStatus rdf:type rdf:Property ;
    rdfs:label 'Onboarding Status' ;
    rdfs:comment 'Status of the vendor onboarding process, tracking completion of required documentation, insurance certificates, and compliance checks.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceRating rdf:type rdf:Property ;
    rdfs:label 'Performance Rating' ;
    rdfs:comment 'Overall performance rating for the vendor based on quality, delivery, responsiveness, and compliance. Used for vendor scorecard and sourcing decisions.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:smallBusinessFlag rdf:type rdf:Property ;
    rdfs:label 'Small Business Flag' ;
    rdfs:comment 'Indicates whether the vendor is certified as a small business for government contracting and diversity reporting.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxClassification rdf:type rdf:Property ;
    rdfs:label 'Tax Classification' ;
    rdfs:comment 'IRS tax classification of the vendor entity, determines tax reporting requirements and withholding rules. [ENUM-REF-CANDIDATE: corporation|s_corporation|partnership|sole_proprietor|llc|non_profit|government — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Number' ;
    rdfs:comment 'External business identifier for the vendor, used in procurement documents, purchase orders, and invoices. Unique across the enterprise.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorStatus rdf:type rdf:Property ;
    rdfs:label 'Vendor Status' ;
    rdfs:comment 'Current lifecycle status of the vendor record. Active vendors can receive purchase orders; blocked vendors cannot transact.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorType rdf:type rdf:Property ;
    rdfs:label 'Vendor Type' ;
    rdfs:comment 'Indicates whether the vendor provides goods, services, or both.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:veteranOwnedFlag rdf:type rdf:Property ;
    rdfs:label 'Veteran Owned Flag' ;
    rdfs:comment 'Indicates whether the vendor is certified as a veteran-owned business enterprise for diversity spend reporting.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:w9OnFileFlag rdf:type rdf:Property ;
    rdfs:label 'W9 On File Flag' ;
    rdfs:comment 'Indicates whether a completed IRS Form W-9 is on file for the vendor, required for tax reporting and 1099 processing.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:websiteUrl rdf:type rdf:Property ;
    rdfs:label 'Website Url' ;
    rdfs:comment 'Vendor\'s corporate website URL for reference and supplier portal access.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:womanOwnedFlag rdf:type rdf:Property ;
    rdfs:label 'Woman Owned Flag' ;
    rdfs:comment 'Indicates whether the vendor is certified as a woman-owned business enterprise (WBE) for diversity spend reporting.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vendorCertificationId rdf:type rdf:Property ;
    rdfs:label 'Vendor Certification Id' ;
    rdfs:comment 'Unique identifier for the vendor certification record. Primary key.' ;
    rdfs:domain ind:VendorCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:attachmentDocumentId rdf:type rdf:Property ;
    rdfs:label 'Attachment Document Id' ;
    rdfs:comment 'Reference to the document management system record containing the scanned or uploaded copy of the certification, permit, or insurance certificate. Links to document repository.' ;
    rdfs:domain ind:VendorCertification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Document .

ind:primaryVendorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Vendor Employee Id' ;
    rdfs:comment 'Reference to the Waste Management employee who performed the most recent verification. Links to user or employee master data.' ;
    rdfs:domain ind:VendorCertification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryVendorLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Vendor Last Modified By User Employee Id' ;
    rdfs:comment 'Reference to the user who most recently modified this vendor certification record. Links to user or employee master data.' ;
    rdfs:domain ind:VendorCertification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:certificateHolderName rdf:type rdf:Property ;
    rdfs:label 'Certificate Holder Name' ;
    rdfs:comment 'The name of the entity designated as the certificate holder or additional insured on insurance certificates. Typically Waste Management or a subsidiary. Null for non-insurance certifications.' ;
    rdfs:domain ind:VendorCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationScope rdf:type rdf:Property ;
    rdfs:label 'Certification Scope' ;
    rdfs:comment 'A description of the scope, coverage, or limitations of the certification. For EPA TSDF permits, this includes waste types and treatment methods authorized. For DOT hazmat carriers, this includes hazard classes authorized. For insurance, this includes coverage limits and exclusions. For ISO certifications, this includes the facilities or processes covered.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceGateFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Gate Flag' ;
    rdfs:comment 'Boolean indicator of whether this certification is a mandatory compliance gate for vendor qualification. True indicates that the vendor cannot be approved or used for relevant procurement categories without this certification being active and valid. False indicates the certification is supplementary or optional.' ;
    rdfs:domain ind:VendorCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coverageAmount rdf:type rdf:Property ;
    rdfs:label 'Coverage Amount' ;
    rdfs:comment 'The monetary coverage limit for insurance certificates or bonding amounts. Expressed in USD. Null for non-financial certifications such as permits or quality certifications.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coverageCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Coverage Currency Code' ;
    rdfs:comment 'The three-letter ISO 4217 currency code for the coverage amount. Typically USD for U.S. operations.' ;
    rdfs:domain ind:VendorCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingAuthorityJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority Jurisdiction' ;
    rdfs:comment 'The geographic or regulatory jurisdiction of the issuing authority. Examples include federal (USA), state (e.g., California, Texas), regional (e.g., EPA Region 5), or international (e.g., ISO global).' ;
    rdfs:domain ind:VendorCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextRenewalDate rdf:type rdf:Property ;
    rdfs:label 'Next Renewal Date' ;
    rdfs:comment 'The scheduled date for the next certification renewal. May differ from expiration date if renewal must be initiated before expiration.' ;
    rdfs:domain ind:VendorCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:policyHolderName rdf:type rdf:Property ;
    rdfs:label 'Policy Holder Name' ;
    rdfs:comment 'The legal name of the policy holder for insurance certificates. Should match the vendor legal name. Null for non-insurance certifications.' ;
    rdfs:domain ind:VendorCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procurementCategory rdf:type rdf:Property ;
    rdfs:label 'Procurement Category' ;
    rdfs:comment 'The procurement category or service line for which this certification is required or relevant. Examples include hazardous waste disposal, fleet parts, fuel supply, PPE, third-party hauling, landfill services, recycling services. Multiple categories may be pipe-separated if the certification applies broadly.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalAlertThresholdDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Alert Threshold Days' ;
    rdfs:comment 'The number of days before expiration when the system should trigger a renewal alert to procurement and vendor management teams. Typical values range from 30 to 90 days depending on certification type and renewal complexity.' ;
    rdfs:domain ind:VendorCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vendorContactId rdf:type rdf:Property ;
    rdfs:label 'Vendor Contact Id' ;
    rdfs:comment 'Unique identifier for the vendor contact record. Primary key.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VendorContact .

ind:contactType rdf:type rdf:Property ;
    rdfs:label 'Contact Type' ;
    rdfs:comment 'Classification of the contact\'s role within the vendor relationship. Determines routing and escalation workflows.' ;
    rdfs:domain ind:VendorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:extension rdf:type rdf:Property ;
    rdfs:label 'Extension' ;
    rdfs:comment 'Telephone extension number within the vendor\'s phone system for direct routing to this contact.' ;
    rdfs:domain ind:VendorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fullName rdf:type rdf:Property ;
    rdfs:label 'Full Name' ;
    rdfs:comment 'Complete formatted name of the vendor contact as it should appear in correspondence and reports.' ;
    rdfs:domain ind:VendorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAuthorizedSigner rdf:type rdf:Property ;
    rdfs:label 'Is Authorized Signer' ;
    rdfs:comment 'Indicates whether this contact has authority to sign contracts, Purchase Orders (PO), or other legally binding documents on behalf of the vendor.' ;
    rdfs:domain ind:VendorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:middleName rdf:type rdf:Property ;
    rdfs:label 'Middle Name' ;
    rdfs:comment 'Middle name or initial of the vendor contact person.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mobilePhoneNumber rdf:type rdf:Property ;
    rdfs:label 'Mobile Phone Number' ;
    rdfs:comment 'Mobile telephone number for the vendor contact. Used for emergency escalations and after-hours support coordination.' ;
    rdfs:domain ind:VendorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredCommunicationChannel rdf:type rdf:Property ;
    rdfs:label 'Preferred Communication Channel' ;
    rdfs:comment 'The contact\'s preferred method of communication for routine business matters. Guides procurement workflow routing and notification preferences.' ;
    rdfs:domain ind:VendorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryEmailAddress rdf:type rdf:Property ;
    rdfs:label 'Secondary Email Address' ;
    rdfs:comment 'Alternate email address for the vendor contact, used for backup communication or escalation purposes.' ;
    rdfs:domain ind:VendorContact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Amount' ;
    rdfs:comment 'The total invoice amount before any deductions, including all line items, taxes, and surcharges. This is the headline invoice value from the vendor.' ;
    rdfs:domain ind:VendorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceType rdf:type rdf:Property ;
    rdfs:label 'Invoice Type' ;
    rdfs:comment 'The type of invoice document (e.g., standard invoice, credit memo for returns, debit memo for additional charges, prepayment invoice).' ;
    rdfs:domain ind:VendorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentBlockFlag rdf:type rdf:Property ;
    rdfs:label 'Payment Block Flag' ;
    rdfs:comment 'Boolean indicator (True/False) showing whether payment is currently blocked. When True, the invoice cannot be paid until the block is released.' ;
    rdfs:domain ind:VendorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentBlockReason rdf:type rdf:Property ;
    rdfs:label 'Payment Block Reason' ;
    rdfs:comment 'The reason code or description explaining why payment is blocked (e.g., price variance, quantity mismatch, missing goods receipt, quality issue, duplicate invoice).' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:threeWayMatchStatus rdf:type rdf:Property ;
    rdfs:label 'Three Way Match Status' ;
    rdfs:comment 'Status of the three-way match validation comparing Purchase Order (PO), Goods Receipt (GR), and Invoice. Indicates whether quantities, prices, and terms align across all three documents.' ;
    rdfs:domain ind:VendorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorInvoiceLineId rdf:type rdf:Property ;
    rdfs:label 'Vendor Invoice Line Id' ;
    rdfs:comment 'Unique identifier for the vendor invoice line item. Primary key for this entity.' ;
    rdfs:domain ind:VendorInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:blockedForPayment rdf:type rdf:Property ;
    rdfs:label 'Blocked For Payment' ;
    rdfs:comment 'Indicates whether this invoice line is blocked from payment due to matching errors, quality issues, or pending approval. True if blocked, false if cleared for payment.' ;
    rdfs:domain ind:VendorInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:invoicedQuantity rdf:type rdf:Property ;
    rdfs:label 'Invoiced Quantity' ;
    rdfs:comment 'Quantity of material or service units being invoiced on this line. Compared against PO quantity and GR quantity for variance analysis.' ;
    rdfs:domain ind:VendorInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineDescription rdf:type rdf:Property ;
    rdfs:label 'Line Description' ;
    rdfs:comment 'Detailed text description of the material or service being invoiced. May include vendor-specific item descriptions, specifications, or service details.' ;
    rdfs:domain ind:VendorInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineGrossAmount rdf:type rdf:Property ;
    rdfs:label 'Line Gross Amount' ;
    rdfs:comment 'Total gross amount for this invoice line including taxes and surcharges. Sum of line net amount and line tax amount.' ;
    rdfs:domain ind:VendorInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineNetAmount rdf:type rdf:Property ;
    rdfs:label 'Line Net Amount' ;
    rdfs:comment 'Net amount for this invoice line before taxes and surcharges. Calculated as invoiced quantity multiplied by unit price, minus any line-level discounts.' ;
    rdfs:domain ind:VendorInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineNotes rdf:type rdf:Property ;
    rdfs:label 'Line Notes' ;
    rdfs:comment 'Free-text notes or comments specific to this invoice line. May include variance explanations, special handling instructions, or dispute details.' ;
    rdfs:domain ind:VendorInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Line Tax Amount' ;
    rdfs:comment 'Total tax amount applicable to this invoice line. Calculated based on tax code and jurisdiction.' ;
    rdfs:domain ind:VendorInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:matchStatus rdf:type rdf:Property ;
    rdfs:label 'Match Status' ;
    rdfs:comment 'Status of the three-way match process comparing invoice line to PO and GR. Indicates whether the line passed validation or has discrepancies requiring resolution.' ;
    rdfs:domain ind:VendorInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceVariance rdf:type rdf:Property ;
    rdfs:label 'Price Variance' ;
    rdfs:comment 'Difference between invoiced unit price and PO unit price. Used for spend variance analysis and vendor performance evaluation.' ;
    rdfs:domain ind:VendorInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction' ;
    rdfs:comment 'Geographic tax jurisdiction (state, county, city) where the tax is assessed. Critical for multi-state operations and compliance reporting.' ;
    rdfs:domain ind:VendorInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorPerformanceId rdf:type rdf:Property ;
    rdfs:label 'Vendor Performance Id' ;
    rdfs:comment 'Unique identifier for the vendor performance evaluation record.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryVendorEvaluatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Vendor Evaluator Employee Id' ;
    rdfs:comment 'Reference to the employee who conducted the vendor performance evaluation.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:contractComplianceRatePercent rdf:type rdf:Property ;
    rdfs:label 'Contract Compliance Rate Percent' ;
    rdfs:comment 'Percentage of transactions that adhered to negotiated contract terms including pricing, payment terms, and service level agreements (SLA) during the evaluation period.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalComplianceViolationCount rdf:type rdf:Property ;
    rdfs:label 'Environmental Compliance Violation Count' ;
    rdfs:comment 'Total number of environmental compliance violations or non-conformances identified during the evaluation period. Tracked per U.S. Environmental Protection Agency (EPA) and Resource Conservation and Recovery Act (RCRA) requirements.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:evaluationDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Date' ;
    rdfs:comment 'Date when the vendor performance evaluation was completed and recorded.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluationNotes rdf:type rdf:Property ;
    rdfs:label 'Evaluation Notes' ;
    rdfs:comment 'Free-text comments and observations from the evaluator regarding vendor performance, strengths, weaknesses, and recommendations.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Period End Date' ;
    rdfs:comment 'End date of the performance evaluation period.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluationPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Period Start Date' ;
    rdfs:comment 'Start date of the performance evaluation period.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluationStatus rdf:type rdf:Property ;
    rdfs:label 'Evaluation Status' ;
    rdfs:comment 'Current status of the vendor performance evaluation in the approval workflow.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fillRatePercent rdf:type rdf:Property ;
    rdfs:label 'Fill Rate Percent' ;
    rdfs:comment 'Percentage of purchase order line items completely fulfilled without backorders or shortages during the evaluation period.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceAccuracyRatePercent rdf:type rdf:Property ;
    rdfs:label 'Invoice Accuracy Rate Percent' ;
    rdfs:comment 'Percentage of invoices received without pricing errors, quantity discrepancies, or other billing issues requiring correction.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leadTimeDaysAvg rdf:type rdf:Property ;
    rdfs:label 'Lead Time Days Avg' ;
    rdfs:comment 'Average number of days from purchase order (PO) placement to delivery during the evaluation period.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextEvaluationDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Evaluation Due Date' ;
    rdfs:comment 'Scheduled date for the next periodic vendor performance evaluation.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:onTimeDeliveryRatePercent rdf:type rdf:Property ;
    rdfs:label 'On Time Delivery Rate Percent' ;
    rdfs:comment 'Percentage of purchase orders delivered on or before the scheduled delivery date during the evaluation period. Key performance indicator (KPI) for vendor reliability.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overallScorecardRating rdf:type rdf:Property ;
    rdfs:label 'Overall Scorecard Rating' ;
    rdfs:comment 'Composite vendor performance score calculated from weighted performance metrics. Scale typically 0-100 or 0-5 depending on organizational scoring methodology.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityDefectRatePercent rdf:type rdf:Property ;
    rdfs:label 'Quality Defect Rate Percent' ;
    rdfs:comment 'Percentage of received goods or services that failed quality inspection or were rejected due to defects during the evaluation period.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responseTimeDaysAvg rdf:type rdf:Property ;
    rdfs:label 'Response Time Days Avg' ;
    rdfs:comment 'Average number of days for the vendor to respond to inquiries, requests for quotation, or issue resolution during the evaluation period.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalInvoiceCountEvaluated rdf:type rdf:Property ;
    rdfs:label 'Total Invoice Count Evaluated' ;
    rdfs:comment 'Total number of vendor invoices reviewed during the evaluation period for accuracy assessment.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalPurchaseOrdersEvaluated rdf:type rdf:Property ;
    rdfs:label 'Total Purchase Orders Evaluated' ;
    rdfs:comment 'Total number of purchase orders (PO) included in the evaluation period sample for performance calculation.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Total Spend Amount' ;
    rdfs:comment 'Total procurement spend with the vendor during the evaluation period in USD. Used for spend analytics and cost control reporting aligned with Cost of Goods Sold (COGS) and Earnings Before Interest Taxes Depreciation and Amortization (EBITDA) metrics.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorTier rdf:type rdf:Property ;
    rdfs:label 'Vendor Tier' ;
    rdfs:comment 'Strategic vendor classification tier based on performance evaluation results. Determines eligibility for preferred pricing, contract renewals, and sourcing priority.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorQuoteId rdf:type rdf:Property ;
    rdfs:label 'Vendor Quote Id' ;
    rdfs:comment 'Unique identifier for the vendor quote record. Primary key.' ;
    rdfs:domain ind:VendorQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:awardDecisionDate rdf:type rdf:Property ;
    rdfs:label 'Award Decision Date' ;
    rdfs:comment 'Date when the award decision was made and the quote was accepted or rejected.' ;
    rdfs:domain ind:VendorQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:awardDecisionFlag rdf:type rdf:Property ;
    rdfs:label 'Award Decision Flag' ;
    rdfs:comment 'Indicates whether this quote was selected and awarded a purchase order. True if awarded, false otherwise.' ;
    rdfs:domain ind:VendorQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:evaluationScore rdf:type rdf:Property ;
    rdfs:label 'Evaluation Score' ;
    rdfs:comment 'Composite evaluation score assigned to the quote based on weighted criteria (price, quality, delivery, vendor performance). Supports competitive bid comparison.' ;
    rdfs:domain ind:VendorQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightTerms rdf:type rdf:Property ;
    rdfs:label 'Freight Terms' ;
    rdfs:comment 'Freight and shipping terms specified in the quote, indicating who pays for transportation costs.' ;
    rdfs:domain ind:VendorQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netQuoteAmount rdf:type rdf:Property ;
    rdfs:label 'Net Quote Amount' ;
    rdfs:comment 'Net total amount after applying discounts and adding taxes. Final amount for competitive bid comparison.' ;
    rdfs:domain ind:VendorQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quoteNotes rdf:type rdf:Property ;
    rdfs:label 'Quote Notes' ;
    rdfs:comment 'Additional notes, comments, or special conditions provided by the vendor or procurement team regarding the quote.' ;
    rdfs:domain ind:VendorQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quoteNumber rdf:type rdf:Property ;
    rdfs:label 'Quote Number' ;
    rdfs:comment 'Externally-known unique quote number assigned by the vendor or system. Business identifier for the quotation.' ;
    rdfs:domain ind:VendorQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quoteRanking rdf:type rdf:Property ;
    rdfs:label 'Quote Ranking' ;
    rdfs:comment 'Comparative ranking of this quote among all quotes received for the same RFQ, based on price, lead time, and technical compliance. Used for award decision.' ;
    rdfs:domain ind:VendorQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quoteStatus rdf:type rdf:Property ;
    rdfs:label 'Quote Status' ;
    rdfs:comment 'Current lifecycle status of the vendor quote in the procurement workflow. [ENUM-REF-CANDIDATE: draft|submitted|under_review|accepted|rejected|expired|withdrawn — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:VendorQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quoteSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Quote Submission Date' ;
    rdfs:comment 'Date when the vendor submitted the quote in response to the RFQ.' ;
    rdfs:domain ind:VendorQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quoteValidFromDate rdf:type rdf:Property ;
    rdfs:label 'Quote Valid From Date' ;
    rdfs:comment 'Start date of the quote validity period. The quoted price is effective from this date.' ;
    rdfs:domain ind:VendorQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quoteValidToDate rdf:type rdf:Property ;
    rdfs:label 'Quote Valid To Date' ;
    rdfs:comment 'End date of the quote validity period. The quoted price expires after this date.' ;
    rdfs:domain ind:VendorQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quotedQuantity rdf:type rdf:Property ;
    rdfs:label 'Quoted Quantity' ;
    rdfs:comment 'Quantity of material or service that the vendor is offering to supply at the quoted price.' ;
    rdfs:domain ind:VendorQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:technicalComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Technical Compliance Flag' ;
    rdfs:comment 'Indicates whether the quoted material or service meets the technical specifications and requirements defined in the RFQ.' ;
    rdfs:domain ind:VendorQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:technicalComplianceNotes rdf:type rdf:Property ;
    rdfs:label 'Technical Compliance Notes' ;
    rdfs:comment 'Detailed notes on technical compliance, deviations, or exceptions to RFQ specifications. Supports award decision documentation.' ;
    rdfs:domain ind:VendorQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalQuoteAmount rdf:type rdf:Property ;
    rdfs:label 'Total Quote Amount' ;
    rdfs:comment 'Total amount for the quoted quantity (unit price multiplied by quantity). Gross quote value before taxes and adjustments.' ;
    rdfs:domain ind:VendorQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warrantyPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Warranty Period Months' ;
    rdfs:comment 'Duration of the warranty period in months, as offered by the vendor in the quote.' ;
    rdfs:domain ind:VendorQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:baleEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Bale Employee Id' ;
    rdfs:comment 'Reference to the MRF operator or baler technician who produced this bale. Used for workforce productivity tracking, quality accountability, and OSHA compliance recordkeeping via Workday HCM.' ;
    rdfs:domain ind:Bale ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:commodityBuyerId rdf:type rdf:Property ;
    rdfs:label 'Commodity Buyer Id' ;
    rdfs:comment 'Reference to the commodity buyer or end-market customer who purchased or is contracted to receive this bale. Links bale to buyer account for sales order management, buyer-specific quality specification enforcement, and market channel analytics.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CommodityBuyer .

ind:mrfEquipmentId rdf:type rdf:Property ;
    rdfs:label 'Mrf Equipment Id' ;
    rdfs:comment 'Reference to the baler machine that produced this bale. Supports equipment performance monitoring, preventive maintenance scheduling, and bale quality correlation with specific baler units via Infor EAM.' ;
    rdfs:domain ind:Recycling ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MrfEquipment .

ind:sortLineId rdf:type rdf:Property ;
    rdfs:label 'Sort Line Id' ;
    rdfs:comment 'Reference to the sorting line within the MRF where the commodity was processed and separated prior to baling. Used for equipment performance tracking and throughput analysis by sort line.' ;
    rdfs:domain ind:Recycling ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SortLine .

ind:sourcePurchaseOrderId rdf:type rdf:Property ;
    rdfs:label 'Source Purchase Order Id' ;
    rdfs:comment 'Foreign key linking to procurement.purchase_order. Business justification: When bales are produced from purchased recyclables (buy-back programs), traceability to originating PO enables COGS calculation, margin analysis, and cost accounting for purchased material - critical ' ;
    rdfs:domain ind:Bale ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseOrder .

ind:storageLocationId rdf:type rdf:Property ;
    rdfs:label 'Storage Location Id' ;
    rdfs:comment 'Reference to the designated storage bay, pad, or warehouse location within the MRF where this bale is currently stored. Supports inventory management, FIFO rotation, and outbound logistics planning.' ;
    rdfs:domain ind:Bale ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Location .

ind:allocatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Allocated Timestamp' ;
    rdfs:comment 'Date and time when this bale was allocated to a specific sales order or outbound shipment. Marks the transition from in_storage to allocated lifecycle status. Used for inventory turnover analysis and order fulfillment lead time tracking.' ;
    rdfs:domain ind:Bale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:barcode rdf:type rdf:Property ;
    rdfs:label 'Barcode' ;
    rdfs:comment 'Human-readable barcode label affixed to the bale for physical identification and scanning during storage, quality inspection, and outbound shipment. Printed at time of production and scanned at each lifecycle checkpoint.' ;
    rdfs:domain ind:Bale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commoditySubtype rdf:type rdf:Property ;
    rdfs:label 'Commodity Subtype' ;
    rdfs:comment 'Specific material subtype within the commodity category (e.g., OCC for Old Corrugated Cardboard, HDPE for High-Density Polyethylene, aluminum, steel, clear glass, mixed paper). Drives commodity-specific market pricing and buyer contract matching. [ENUM-REF-CANDIDATE: OCC|ONP|mixed_paper|HDPE|PET|LDPE|aluminum|steel|tin|clear_glass|brown_glass|green_glass — promote to reference product]' ;
    rdfs:domain ind:Recycling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commodityType rdf:type rdf:Property ;
    rdfs:label 'Commodity Type' ;
    rdfs:comment 'Primary commodity category of the bale. Classifies the recovered material stream for inventory management, market pricing, and EPA recycling diversion reporting. Core classification for MRF commodity recovery analytics. [ENUM-REF-CANDIDATE: paper|plastic|metal|glass|mixed|textile|electronics|organics — promote to reference product]' ;
    rdfs:domain ind:Recycling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contaminationPct rdf:type rdf:Property ;
    rdfs:label 'Contamination Pct' ;
    rdfs:comment 'Measured percentage of non-target or non-recyclable material (contaminants) present in the bale, expressed as a percentage of total bale weight. Determined during quality inspection. Exceeding buyer-specified contamination thresholds results in grade downgrade, price deduction, or rejection. Key MRF quality KPI.' ;
    rdfs:domain ind:Recycling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daysInStorage rdf:type rdf:Property ;
    rdfs:label 'Days In Storage' ;
    rdfs:comment 'Number of days this bale has been in MRF storage since production. Tracked to manage inventory aging, prioritize FIFO shipment sequencing, and identify slow-moving commodity inventory that may be subject to quality degradation or market price risk. Updated daily.' ;
    rdfs:domain ind:Bale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:densityKgPerM3 rdf:type rdf:Property ;
    rdfs:label 'Density Kg Per M3' ;
    rdfs:comment 'Calculated density of the bale expressed as kilograms per cubic meter, derived from weight and physical dimensions. Indicates baler compression performance and material compaction ratio. Low density may signal baler maintenance needs or loose material feed. Used for baler performance KPI tracking.' ;
    rdfs:domain ind:Bale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedValueUsd rdf:type rdf:Property ;
    rdfs:label 'Estimated Value Usd' ;
    rdfs:comment 'Estimated monetary value of this bale in USD, calculated as weight in tons multiplied by the applicable commodity market price per ton. Used for MRF commodity inventory valuation, revenue forecasting, and financial reporting in SAP FI/CO. Not a final invoiced amount — actual sale price is recorded on the sales order.' ;
    rdfs:domain ind:Bale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grade rdf:type rdf:Property ;
    rdfs:label 'Grade' ;
    rdfs:comment 'Quality grade assigned to the bale based on contamination level, moisture content, and material purity. Grade A represents premium quality meeting buyer specifications; Grade B is acceptable with minor deviations; Grade C is marginal; off-spec fails buyer specs but is saleable at discount; rejected is unsaleable. Directly impacts commodity sale price.' ;
    rdfs:domain ind:Bale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:heightCm rdf:type rdf:Property ;
    rdfs:label 'Height Cm' ;
    rdfs:comment 'Physical height dimension of the bale in centimeters as measured at production. Combined with length and width for volume calculation, stacking safety assessment, and storage bay capacity planning.' ;
    rdfs:domain ind:Bale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lengthCm rdf:type rdf:Property ;
    rdfs:label 'Length Cm' ;
    rdfs:comment 'Physical length dimension of the bale in centimeters as measured at production. Used with width and height to calculate bale volume, verify baler performance, and plan trailer loading configurations for outbound commodity shipments.' ;
    rdfs:domain ind:Bale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marketPricePerTon rdf:type rdf:Property ;
    rdfs:label 'Market Price Per Ton' ;
    rdfs:comment 'Prevailing commodity market price per ton in USD at the time this bale was produced or allocated to a sales order. Captured for commodity inventory valuation, revenue forecasting, and market price trend analysis. Reflects spot market or contracted price depending on buyer agreement type.' ;
    rdfs:domain ind:Recycling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:moisturePct rdf:type rdf:Property ;
    rdfs:label 'Moisture Pct' ;
    rdfs:comment 'Measured moisture content of the bale expressed as a percentage of total bale weight. Excess moisture reduces net commodity value, increases transport weight without material value, and can cause mold or degradation in paper bales. Monitored against buyer moisture tolerance thresholds.' ;
    rdfs:domain ind:Bale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productionShift rdf:type rdf:Property ;
    rdfs:label 'Production Shift' ;
    rdfs:comment 'MRF operating shift during which this bale was produced. Used for shift-level productivity analysis, quality trend analysis by shift, and workforce scheduling optimization. Correlates bale quality and throughput metrics to specific shift teams.' ;
    rdfs:domain ind:Bale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Production Timestamp' ;
    rdfs:comment 'Date and time when the bale was ejected from the baler and production was completed. The principal business event timestamp for this MASTER_RESOURCE. Used for throughput calculations (Tons Per Day), shift productivity reporting, and bale age tracking for FIFO inventory management.' ;
    rdfs:domain ind:Bale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reinspectionRequired rdf:type rdf:Property ;
    rdfs:label 'Reinspection Required' ;
    rdfs:comment 'Indicates whether this bale requires a follow-up quality inspection, typically after remediation of a failed inspection, buyer dispute, or conditional pass with noted concerns. True triggers a re-inspection workflow in the MRF quality management process.' ;
    rdfs:domain ind:Recycling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shippedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Shipped Timestamp' ;
    rdfs:comment 'Date and time when this bale was loaded onto an outbound transport vehicle and departed the MRF facility. Marks the transition to shipped lifecycle status. Used for inventory reconciliation, Bill of Lading (BOL) documentation, and commodity revenue recognition timing.' ;
    rdfs:domain ind:Bale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:weightKg rdf:type rdf:Property ;
    rdfs:label 'Weight Kg' ;
    rdfs:comment 'Gross weight of the bale in kilograms as measured by the baler scale or floor scale at time of production. The principal quantitative measurement for this resource. Used for Tons Per Day (TPD) throughput calculations, commodity inventory valuation, sales order fulfillment, and EPA recycling tonnage reporting.' ;
    rdfs:domain ind:Bale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:widthCm rdf:type rdf:Property ;
    rdfs:label 'Width Cm' ;
    rdfs:comment 'Physical width dimension of the bale in centimeters as measured at production. Combined with length and height for volume calculation, storage space planning, and trailer load optimization.' ;
    rdfs:domain ind:Bale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wireCount rdf:type rdf:Property ;
    rdfs:label 'Wire Count' ;
    rdfs:comment 'Number of wire ties or strapping bands securing the bale. Standard bale configurations use 4, 5, or 6 wires depending on commodity type and baler model. Deviations from standard wire count may indicate bale integrity risk during transport and are flagged during quality inspection.' ;
    rdfs:domain ind:Bale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:baleInspectionId rdf:type rdf:Property ;
    rdfs:label 'Bale Inspection Id' ;
    rdfs:comment 'Unique identifier for the bale inspection record. Primary key for the bale inspection transaction.' ;
    rdfs:domain ind:BaleInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:previousInspectionBaleInspectionId rdf:type rdf:Property ;
    rdfs:label 'Previous Inspection Bale Inspection Id' ;
    rdfs:comment 'Reference to the prior inspection record for this bale. Populated for reinspections to track inspection history and corrective action effectiveness.' ;
    rdfs:domain ind:BaleInspection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BaleInspection .

ind:primaryBaleEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Bale Employee Id' ;
    rdfs:comment 'Reference to the employee who performed the inspection. Links to workforce/employee master data.' ;
    rdfs:domain ind:BaleInspection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualWeightLbs rdf:type rdf:Property ;
    rdfs:label 'Actual Weight Lbs' ;
    rdfs:comment 'Measured weight of the bale in pounds at time of inspection. Used to verify production weight and calculate commodity value.' ;
    rdfs:domain ind:BaleInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedForShipment rdf:type rdf:Property ;
    rdfs:label 'Approved For Shipment' ;
    rdfs:comment 'Indicates whether the bale is approved for shipment to buyer based on inspection results. True when inspection passes and all quality criteria are met.' ;
    rdfs:domain ind:BaleInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceStandard rdf:type rdf:Property ;
    rdfs:label 'Compliance Standard' ;
    rdfs:comment 'Industry or regulatory standard against which the bale was inspected (e.g., ISRI specifications, buyer-specific requirements, EPA guidelines). Supports regulatory reporting and buyer certification.' ;
    rdfs:domain ind:BaleInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contaminationPercentage rdf:type rdf:Property ;
    rdfs:label 'Contamination Percentage' ;
    rdfs:comment 'Measured percentage of non-target materials or contaminants in the bale. Critical metric for commodity grade determination and buyer acceptance. Expressed as percentage (0.00 to 100.00).' ;
    rdfs:domain ind:BaleInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gradeAssigned rdf:type rdf:Property ;
    rdfs:label 'Grade Assigned' ;
    rdfs:comment 'Quality grade assigned to the bale based on inspection results. Determines commodity pricing tier and buyer eligibility. Premium is highest quality, Grade A-C are standard tiers, off-spec requires rework, reject is unsaleable.' ;
    rdfs:domain ind:BaleInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:moistureContentPercentage rdf:type rdf:Property ;
    rdfs:label 'Moisture Content Percentage' ;
    rdfs:comment 'Measured moisture content in the bale as a percentage of total weight. Affects commodity value and grade classification. Expressed as percentage (0.00 to 100.00).' ;
    rdfs:domain ind:BaleInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sampleSize rdf:type rdf:Property ;
    rdfs:label 'Sample Size' ;
    rdfs:comment 'Number of samples taken from the bale for inspection. Larger sample sizes provide more accurate contamination and moisture measurements.' ;
    rdfs:domain ind:BaleInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shipmentHoldReason rdf:type rdf:Property ;
    rdfs:label 'Shipment Hold Reason' ;
    rdfs:comment 'Explanation of why shipment was not approved. Populated when approved_for_shipment is false. Used for logistics coordination and customer communication.' ;
    rdfs:domain ind:BaleInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recyclingBuyerContractId rdf:type rdf:Property ;
    rdfs:label 'Recycling Buyer Contract Id' ;
    rdfs:comment 'Unique surrogate identifier for the MRF commodity offtake agreement or sales contract record in the Databricks Silver Layer.' ;
    rdfs:domain ind:Recycling ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RecyclingBuyerContract .

ind:commodityId rdf:type rdf:Property ;
    rdfs:label 'Commodity Id' ;
    rdfs:comment 'Reference to the recovered commodity master record (e.g., OCC, HDPE, aluminum, glass) that is the subject of this offtake agreement.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Commodity .

ind:exportPermitId rdf:type rdf:Property ;
    rdfs:label 'Export Permit Id' ;
    rdfs:comment 'Foreign key linking to compliance.permit. Business justification: Export contracts for recyclable commodities require EPA export permits and international waste shipment permits (Basel Convention compliance). Enables verification of export authorization and tracking' ;
    rdfs:domain ind:RecyclingBuyerContract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Permit .

ind:salesforceContractId rdf:type rdf:Property ;
    rdfs:label 'Salesforce Contract Id' ;
    rdfs:comment 'The Salesforce CRM contract record identifier linked to this commodity offtake agreement. Used for cross-system traceability between the MRF data product and the CRM contract management module.' ;
    rdfs:domain ind:RecyclingBuyerContract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contract .

ind:autoRenewal rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal' ;
    rdfs:comment 'Indicates whether this contract automatically renews at expiration unless either party provides written notice of non-renewal within the renewal_notice_days period.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:baleWeightSpecLbs rdf:type rdf:Property ;
    rdfs:label 'Bale Weight Spec Lbs' ;
    rdfs:comment 'The contractually specified target bale weight in pounds for commodity shipments under this agreement. Deviations from this specification may trigger price adjustments or load rejections.' ;
    rdfs:domain ind:RecyclingBuyerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:basePricePerTon rdf:type rdf:Property ;
    rdfs:label 'Base Price Per Ton' ;
    rdfs:comment 'The contractually agreed base price per short ton for the commodity in US dollars. For fixed-price contracts, this is the locked price. For index-linked contracts, this may represent the base or floor price. Used in revenue recognition and commodity sales reporting.' ;
    rdfs:domain ind:Recycling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ceilingPricePerTon rdf:type rdf:Property ;
    rdfs:label 'Ceiling Price Per Ton' ;
    rdfs:comment 'The maximum price per short ton the buyer will pay, applicable when price_mechanism is \'floor_and_ceiling\'. Caps the MRF\'s upside in exchange for floor price protection. Null for non-floor-and-ceiling contracts.' ;
    rdfs:domain ind:RecyclingBuyerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:committedVolumeTonsMonthly rdf:type rdf:Property ;
    rdfs:label 'Committed Volume Tons Monthly' ;
    rdfs:comment 'The contractually committed volume of recovered commodity in short tons per month that Waste Management agrees to supply to the buyer. Used for production planning, route optimization, and SLA compliance tracking.' ;
    rdfs:domain ind:RecyclingBuyerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contaminationPenaltyBasis rdf:type rdf:Property ;
    rdfs:label 'Contamination Penalty Basis' ;
    rdfs:comment 'The method by which contamination penalties are assessed: per_ton (rate applied to excess contamination weight), flat_fee (fixed charge per non-conforming load), price_deduction_pct (percentage reduction from invoice price), or load_rejection (load refused and returned at seller\'s cost).' ;
    rdfs:domain ind:RecyclingBuyerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractNotes rdf:type rdf:Property ;
    rdfs:label 'Contract Notes' ;
    rdfs:comment 'Free-text field for capturing additional contract terms, special conditions, buyer-specific requirements, or operational notes not captured in structured fields.' ;
    rdfs:domain ind:RecyclingBuyerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diversionRateCredit rdf:type rdf:Property ;
    rdfs:label 'Diversion Rate Credit' ;
    rdfs:comment 'Indicates whether this contract includes provisions for diversion rate credits or incentives tied to the MRF\'s overall diversion rate performance. Supports EPA recycling reporting and circular economy goal tracking.' ;
    rdfs:domain ind:Recycling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exclusivityFlag rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Flag' ;
    rdfs:comment 'Indicates whether this contract grants the buyer exclusive rights to purchase a specific commodity from this MRF facility, preventing Waste Management from selling that commodity to competing buyers during the contract term.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:floorPricePerTon rdf:type rdf:Property ;
    rdfs:label 'Floor Price Per Ton' ;
    rdfs:comment 'The minimum guaranteed price per short ton below which the buyer will not pay, applicable when price_mechanism is \'floor_and_ceiling\'. Protects the MRF from extreme market downturns. Null for non-floor-and-ceiling contracts.' ;
    rdfs:domain ind:RecyclingBuyerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:governingLawState rdf:type rdf:Property ;
    rdfs:label 'Governing Law State' ;
    rdfs:comment 'The U.S. state whose laws govern the interpretation and enforcement of this commodity sales contract (e.g., \'TX\', \'CA\', \'FL\'). Relevant for dispute resolution and regulatory compliance.' ;
    rdfs:domain ind:RecyclingBuyerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoicingFrequency rdf:type rdf:Property ;
    rdfs:label 'Invoicing Frequency' ;
    rdfs:comment 'The frequency at which invoices are generated and submitted to the buyer for commodity shipments under this contract. Drives Oracle Revenue Management billing cycle configuration.' ;
    rdfs:domain ind:RecyclingBuyerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxContaminationPct rdf:type rdf:Property ;
    rdfs:label 'Max Contamination Pct' ;
    rdfs:comment 'The maximum percentage of contaminants (by weight) permitted in each shipment under this contract before contamination penalty clauses are triggered. Aligns with buyer\'s incoming quality acceptance criteria.' ;
    rdfs:domain ind:Recycling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumQualityGrade rdf:type rdf:Property ;
    rdfs:label 'Minimum Quality Grade' ;
    rdfs:comment 'The minimum acceptable quality grade or specification for the commodity as defined by ISRI or the buyer\'s specification sheet (e.g., \'OCC #11\', \'HDPE Natural Grade A\', \'Zorba 90/10\'). Shipments below this grade may trigger rejection or price deductions.' ;
    rdfs:domain ind:RecyclingBuyerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceIndexReference rdf:type rdf:Property ;
    rdfs:label 'Price Index Reference' ;
    rdfs:comment 'The published market index or benchmark used to determine the commodity price when price_mechanism is \'index_linked\' or \'floor_and_ceiling\' (e.g., \'RISI Yellow Sheet OCC #11\', \'LME Aluminum\', \'ISRI Zorba\'). Null for fixed-price contracts.' ;
    rdfs:domain ind:Recycling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceMechanism rdf:type rdf:Property ;
    rdfs:label 'Price Mechanism' ;
    rdfs:comment 'The pricing methodology governing how the commodity sale price is determined under this contract. Fixed: set price per ton; Index-linked: tied to a published market index; Floor-and-ceiling: bounded index pricing; Negotiated: periodic bilateral negotiation; Revenue-share: buyer and seller split net proceeds.' ;
    rdfs:domain ind:RecyclingBuyerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapSdContractNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Sd Contract Number' ;
    rdfs:comment 'The SAP S/4HANA SD module contract document number (scheduling agreement or quantity contract) linked to this MRF commodity sales agreement. Used for cross-system reconciliation.' ;
    rdfs:domain ind:RecyclingBuyerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transportResponsibility rdf:type rdf:Property ;
    rdfs:label 'Transport Responsibility' ;
    rdfs:comment 'Identifies which party is responsible for arranging and paying for transportation of commodity bales from the MRF to the buyer\'s facility. Impacts logistics cost allocation and fleet planning.' ;
    rdfs:domain ind:RecyclingBuyerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeTolerancePct rdf:type rdf:Property ;
    rdfs:label 'Volume Tolerance Pct' ;
    rdfs:comment 'The allowable percentage variance (plus or minus) from the committed monthly volume before penalty or renegotiation clauses are triggered. For example, 10% means the MRF may deliver between 90% and 110% of committed volume without penalty.' ;
    rdfs:domain ind:RecyclingBuyerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acceptedMaterials rdf:type rdf:Property ;
    rdfs:label 'Accepted Materials' ;
    rdfs:comment 'Narrative description of materials explicitly accepted within this commodity stream (e.g., \'Corrugated containers, kraft paper bags\' for OCC). Complements the prohibited materials list to fully define the commodity specification for MRF operations and customer education.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amcsCommodityCode rdf:type rdf:Property ;
    rdfs:label 'Amcs Commodity Code' ;
    rdfs:comment 'Commodity identifier as configured in the AMCS Platform for route management and MRF dispatching. Used to link commodity master records to AMCS recycling route assignments, container tracking, and inbound material receiving workflows.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:balingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Baling Required Flag' ;
    rdfs:comment 'Indicates whether this commodity must be baled prior to outbound shipment to end-market buyers. Drives MRF baler scheduling, bale production tracking, and outbound logistics planning. False for loose commodities such as glass cullet or scrap metal.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commodityCategory rdf:type rdf:Property ;
    rdfs:label 'Commodity Category' ;
    rdfs:comment 'High-level material category grouping for the commodity. Drives MRF sorting line configuration, equipment routing, and EPA diversion rate reporting by material stream. Serves as the primary CLASSIFICATION_OR_TYPE for this MASTER_RESOURCE. [ENUM-REF-CANDIDATE: paper|plastics|metals|glass|organics|electronics|textiles|residue|other — promote to reference product]' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commodityName rdf:type rdf:Property ;
    rdfs:label 'Commodity Name' ;
    rdfs:comment 'Full descriptive name of the recovered commodity (e.g., \'Old Corrugated Containers\', \'High-Density Polyethylene Natural\', \'Aluminum Used Beverage Cans\'). Serves as the IDENTITY_LABEL for this MASTER_RESOURCE and is used in customer-facing reports, commodity sales invoices, and EPA recycling disclosures.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commodityStatus rdf:type rdf:Property ;
    rdfs:label 'Commodity Status' ;
    rdfs:comment 'Current lifecycle status of the commodity master record. Active commodities are processed and sold from MRF operations. Inactive or discontinued commodities are retained for historical reporting. Pending_approval records are under review for addition to the MRF commodity catalog. Serves as the LIFECYCLE_STATUS for this MASTER_RESOURCE.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contaminationFeePerTon rdf:type rdf:Property ;
    rdfs:label 'Contamination Fee Per Ton' ;
    rdfs:comment 'Fee charged per ton (USD) when a commodity load exceeds the maximum contamination percentage threshold. Applied as a deduction from the commodity sale price or as a separate charge to the originating customer account. Configured in Oracle Revenue Management billing rules.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:diversionEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Diversion Eligible Flag' ;
    rdfs:comment 'Indicates whether tonnage of this commodity counts toward the diversion rate calculation (percentage of waste diverted from landfill). True for recyclable and compostable commodities; false for residue streams that are landfilled. Drives EPA and state-level diversion rate reporting.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:endMarketType rdf:type rdf:Property ;
    rdfs:label 'End Market Type' ;
    rdfs:comment 'Indicates whether this commodity is sold to domestic end-market buyers, exported to international markets, or both. Drives logistics planning, export documentation requirements (BOL, customs), and market pricing strategy. Export commodities may require additional DOT and customs compliance.' ;
    rdfs:domain ind:Recycling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epaMaterialCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Epa Material Category Code' ;
    rdfs:comment 'EPA-assigned material category code used in mandatory recycling and diversion rate reporting submissions. Aligns commodity records with EPA\'s Advancing Sustainable Materials Management (SMM) reporting framework and state environmental quality department reporting requirements.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ghgEmissionFactor rdf:type rdf:Property ;
    rdfs:label 'Ghg Emission Factor' ;
    rdfs:comment 'Greenhouse gas (GHG) emission factor in metric tons of carbon dioxide equivalent (CO2e) per ton of commodity recycled versus landfilled. Used to calculate GHG emission reductions from recycling activities for sustainability reporting, EPA GHG inventory submissions, and circular economy goal tracking.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gradeDescription rdf:type rdf:Property ;
    rdfs:label 'Grade Description' ;
    rdfs:comment 'Narrative description of the ISRI grade specification including allowable materials, prohibited items, and quality characteristics. Used by MRF quality control staff to assess bale acceptance and by sales teams to communicate product quality to end-market buyers.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isriGradeCode rdf:type rdf:Property ;
    rdfs:label 'Isri Grade Code' ;
    rdfs:comment 'Standardized grade code assigned by the Institute of Scrap Recycling Industries (ISRI) Scrap Specifications Circular. Defines the accepted quality standard for the commodity and is referenced in commodity purchase/sale contracts, bill of lading (BOL) documentation, and end-market buyer specifications.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketClassification rdf:type rdf:Property ;
    rdfs:label 'Market Classification' ;
    rdfs:comment 'Indicates whether the commodity generates revenue (positive_value — MRF receives payment from buyer), incurs a cost (negative_value — MRF pays buyer to accept), or is non-marketable residue. Critical for commodity sales pricing strategy, P&L reporting, and Oracle Revenue Management billing configuration.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxBaleDensityLbsPerCf rdf:type rdf:Property ;
    rdfs:label 'Max Bale Density Lbs Per Cf' ;
    rdfs:comment 'Maximum allowable bale density in pounds per cubic foot for this commodity. Overly dense bales may be rejected by buyers due to handling or processing constraints. Used alongside minimum density to define the acceptable bale density range for quality control.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxMoisturePct rdf:type rdf:Property ;
    rdfs:label 'Max Moisture Pct' ;
    rdfs:comment 'Maximum allowable moisture content percentage (by weight) for this commodity. Excess moisture reduces commodity value, increases transportation weight, and may cause rejection by end-market buyers. Used in MRF quality control inspections and bale certification.' ;
    rdfs:domain ind:Recycling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxStorageDays rdf:type rdf:Property ;
    rdfs:label 'Max Storage Days' ;
    rdfs:comment 'Maximum number of days this commodity may be stored at the MRF before quality degradation or regulatory limits require outbound shipment. Drives inventory turnover alerts in SAP MM and AMCS commodity inventory management. Critical for hazardous commodities with RCRA storage time limits.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minBaleDensityLbsPerCf rdf:type rdf:Property ;
    rdfs:label 'Min Bale Density Lbs Per Cf' ;
    rdfs:comment 'Minimum required bale density in pounds per cubic foot for this commodity. Bales below this density threshold may be rejected by buyers or subject to price discounts. Used to configure MRF baling equipment settings and quality control acceptance criteria.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minProcessingThroughputTpd rdf:type rdf:Property ;
    rdfs:label 'Min Processing Throughput Tpd' ;
    rdfs:comment 'Minimum expected processing throughput in tons per day (TPD) for this commodity on the MRF sort line. Used for MRF capacity planning, equipment performance benchmarking, and operational KPI reporting. Below-threshold throughput triggers operational review.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceFloorPerTon rdf:type rdf:Property ;
    rdfs:label 'Price Floor Per Ton' ;
    rdfs:comment 'Minimum acceptable sale price per ton (USD) below which the commodity should not be sold without management approval. Used in Oracle Revenue Management to trigger pricing exception workflows and protect MRF revenue margins during market downturns.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prohibitedMaterials rdf:type rdf:Property ;
    rdfs:label 'Prohibited Materials' ;
    rdfs:comment 'Narrative description of materials explicitly prohibited from inclusion in this commodity stream (e.g., \'No food-soiled paper, no wax-coated board\' for OCC; \'No PVC, no colored HDPE\' for natural HDPE). Used by MRF sorting staff, quality control inspectors, and driver education programs to prevent contamination.' ;
    rdfs:domain ind:Recycling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recyclabilityTier rdf:type rdf:Property ;
    rdfs:label 'Recyclability Tier' ;
    rdfs:comment 'Classification of the commodity\'s recyclability and market demand: tier_1 (high-value, readily recyclable with established markets), tier_2 (moderate-value, recyclable with limited markets), tier_3 (low-value, difficult to recycle), residue (non-recyclable, destined for disposal). Drives diversion rate calculations and sustainability reporting.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referencePriceIndex rdf:type rdf:Property ;
    rdfs:label 'Reference Price Index' ;
    rdfs:comment 'Name of the published commodity price index used as the pricing reference for index-priced commodities (e.g., \'RISI OCC Index\', \'AMM Aluminum Index\', \'Fastmarkets HDPE Index\'). Null for spot or contract-priced commodities. Used in Oracle Revenue Management for automated price updates.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resinCode rdf:type rdf:Property ;
    rdfs:label 'Resin Code' ;
    rdfs:comment 'Society of the Plastics Industry (SPI) Resin Identification Code (RIC) for plastic commodities (1=PET, 2=HDPE, 3=PVC, 4=LDPE, 5=PP, 6=PS, 7=Other). Null for non-plastic commodities. Required for plastics market reporting and end-market buyer specifications. [ENUM-REF-CANDIDATE: 1|2|3|4|5|6|7 — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sortLineCode rdf:type rdf:Property ;
    rdfs:label 'Sort Line Code' ;
    rdfs:comment 'Code identifying the MRF sorting line or processing stream assigned to this commodity (e.g., \'FIBER-1\', \'PLASTIC-2\', \'METAL-OCC\'). Used by AMCS Platform for route-to-sort-line assignment and MRF equipment configuration. Supports throughput (TPD) reporting by sort line.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardBaleWeightLbs rdf:type rdf:Property ;
    rdfs:label 'Standard Bale Weight Lbs' ;
    rdfs:comment 'Target or standard weight in pounds for a single bale of this commodity as produced by MRF baling equipment. Used for bale production planning, outbound load configuration, and weight-based pricing reconciliation with end-market buyers.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageRequirement rdf:type rdf:Property ;
    rdfs:label 'Storage Requirement' ;
    rdfs:comment 'Storage condition requirement for this commodity at the MRF prior to outbound shipment (e.g., indoor for paper to prevent moisture, hazmat_storage for hazardous commodities, outdoor for metals). Drives MRF facility layout planning and OSHA/EPA storage compliance.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tclpTestingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Tclp Testing Required Flag' ;
    rdfs:comment 'Indicates whether Toxicity Characteristic Leaching Procedure (TCLP) testing is required for this commodity prior to disposal or sale. Applicable to commodities that may exhibit hazardous characteristics under RCRA. Triggers laboratory testing workflow in Enviance EHS.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:buyerEstablishedDate rdf:type rdf:Property ;
    rdfs:label 'Buyer Established Date' ;
    rdfs:comment 'Date when the business relationship with this commodity buyer was first established. Used for buyer tenure analysis and relationship management.' ;
    rdfs:domain ind:CommodityBuyer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:buyerType rdf:type rdf:Property ;
    rdfs:label 'Buyer Type' ;
    rdfs:comment 'Classification of the commodity buyer based on their role in the recovered materials supply chain. Domestic mills process materials domestically, export brokers facilitate international sales, reprocessors transform materials into new feedstock, direct end-users consume materials in manufacturing, aggregators consolidate materials from multiple sources, and traders buy and resell commodities.' ;
    rdfs:domain ind:CommodityBuyer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastTransactionDate rdf:type rdf:Property ;
    rdfs:label 'Last Transaction Date' ;
    rdfs:comment 'Date of the most recent commodity sale transaction with this buyer. Used to identify dormant buyer relationships and trigger reactivation campaigns.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:minimumOrderQuantityTons rdf:type rdf:Property ;
    rdfs:label 'Minimum Order Quantity Tons' ;
    rdfs:comment 'Minimum shipment size in tons that the buyer will accept per order. Used for load planning and sales order validation.' ;
    rdfs:domain ind:Recycling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preferredCommodities rdf:type rdf:Property ;
    rdfs:label 'Preferred Commodities' ;
    rdfs:comment 'Comma-separated list of recovered material commodity types the buyer prefers to purchase (e.g., OCC, mixed paper, PET, HDPE, aluminum, ferrous metals, glass). Supports sales planning and material allocation decisions.' ;
    rdfs:domain ind:CommodityBuyer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredDeliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Preferred Delivery Method' ;
    rdfs:comment 'Buyer\'s preferred logistics arrangement. FOB MRF (Free On Board at Materials Recovery Facility) means buyer arranges transport, delivered means seller delivers to buyer facility, buyer pickup means buyer collects from MRF, third-party carrier means mutually agreed logistics provider.' ;
    rdfs:domain ind:CommodityBuyer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityCertificationRequired rdf:type rdf:Property ;
    rdfs:label 'Quality Certification Required' ;
    rdfs:comment 'Indicates whether the buyer requires quality certification documentation (e.g., contamination reports, bale composition analysis) with each shipment. True means certification is mandatory, False means standard documentation suffices.' ;
    rdfs:domain ind:CommodityBuyer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sapVendorNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Vendor Number' ;
    rdfs:comment 'SAP MM vendor master record number linking this commodity buyer to the enterprise procurement and accounts payable system. Used for purchase order and invoice reconciliation when buyer also supplies services or materials.' ;
    rdfs:domain ind:CommodityBuyer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Shipping Address Line1' ;
    rdfs:comment 'First line of the buyer\'s shipping or delivery address. Used for logistics planning and Bill of Lading (BOL) documentation.' ;
    rdfs:domain ind:CommodityBuyer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Shipping Address Line2' ;
    rdfs:comment 'Second line of the buyer\'s shipping address for dock, gate, or facility-specific routing information.' ;
    rdfs:domain ind:CommodityBuyer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingCity rdf:type rdf:Property ;
    rdfs:label 'Shipping City' ;
    rdfs:comment 'City name for the buyer\'s shipping or receiving facility.' ;
    rdfs:domain ind:CommodityBuyer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Shipping Country Code' ;
    rdfs:comment 'Three-letter ISO country code for the buyer\'s shipping destination. Critical for export compliance and international logistics.' ;
    rdfs:domain ind:CommodityBuyer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingPostalCode rdf:type rdf:Property ;
    rdfs:label 'Shipping Postal Code' ;
    rdfs:comment 'Postal or ZIP code for the buyer\'s shipping facility.' ;
    rdfs:domain ind:CommodityBuyer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingStateProvince rdf:type rdf:Property ;
    rdfs:label 'Shipping State Province' ;
    rdfs:comment 'State or province code for the buyer\'s shipping address.' ;
    rdfs:domain ind:CommodityBuyer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxIdNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Id Number' ;
    rdfs:comment 'Buyer organization\'s tax identification number (EIN in USA, VAT number in EU, or equivalent). Required for tax reporting and compliance with revenue recognition standards.' ;
    rdfs:domain ind:CommodityBuyer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commodityGradeId rdf:type rdf:Property ;
    rdfs:label 'Commodity Grade Id' ;
    rdfs:comment 'Unique surrogate identifier for each commodity grade specification record in the Materials Recovery Facility (MRF) quality reference table. [REFERENCE_LOOKUP role — this is a reference/specification table defining grade standards; per canonical-attrs-enforced rule, REFERENCE_LOOKUP is exempt from per-role minimums. _canonical_skip_reason: commodity_grade is a reference lookup table defining quality grade specifications for MRF commodities; it has its own identity and lifecycle but functions as a standards reference, not a transactional or master-party entity.]' ;
    rdfs:domain ind:CommodityGrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supersededByGradeCommodityGradeId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Grade Commodity Grade Id' ;
    rdfs:comment 'Reference to the commodity_grade_id of the newer grade specification that replaces this record when a grade is deprecated or revised. Null if this is the current active version. Supports grade version lineage tracking and ensures operational systems transition to updated specifications.' ;
    rdfs:domain ind:CommodityGrade ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CommodityGrade .

ind:applicableMrfRegion rdf:type rdf:Property ;
    rdfs:label 'Applicable Mrf Region' ;
    rdfs:comment 'Geographic region or operational division for which this grade specification applies (e.g., \'Northeast\', \'Southeast\', \'National\'). Some grade specifications may vary by region due to local buyer requirements or state recycling regulations. Null or \'National\' indicates the grade applies enterprise-wide.' ;
    rdfs:domain ind:CommodityGrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baleDimensionSpec rdf:type rdf:Property ;
    rdfs:label 'Bale Dimension Spec' ;
    rdfs:comment 'Required or target bale dimensions (length x width x height in inches) for this commodity grade as specified by buyers or ISRI standards (e.g., \'60x30x48\'). Ensures compatibility with buyer receiving equipment and maximizes trailer load efficiency. Used in baler setup configuration.' ;
    rdfs:domain ind:CommodityGrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buyerAcceptanceRequired rdf:type rdf:Property ;
    rdfs:label 'Buyer Acceptance Required' ;
    rdfs:comment 'Indicates whether material classified under this grade requires explicit buyer acceptance confirmation before outbound shipment. True for specialty or off-grade materials where buyers must pre-approve loads. False for standard grades with standing purchase agreements. Drives outbound logistics workflow in AMCS.' ;
    rdfs:domain ind:CommodityGrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:co2eAvoidedPerTon rdf:type rdf:Property ;
    rdfs:label 'Co2e Avoided Per Ton' ;
    rdfs:comment 'Estimated metric tons of CO2e greenhouse gas emissions avoided per ton of commodity recovered and sold at this grade, compared to virgin material production. Used for GHG emissions reporting, sustainability disclosures, and circular economy impact quantification. Sourced from EPA WARM (Waste Reduction Model) emission factors.' ;
    rdfs:domain ind:CommodityGrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:colorSpecification rdf:type rdf:Property ;
    rdfs:label 'Color Specification' ;
    rdfs:comment 'Color or color mix specification required for this commodity grade (e.g., \'clear only\', \'clear and green\', \'mixed colors acceptable\', \'brown only\'). Primarily applicable to glass and PET plastic grades where color separation directly impacts end-market value and processing requirements at buyer facilities.' ;
    rdfs:domain ind:CommodityGrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:domesticExportEligibility rdf:type rdf:Property ;
    rdfs:label 'Domestic Export Eligibility' ;
    rdfs:comment 'Indicates whether this commodity grade is eligible for domestic sale only, export sale only, or both. Export eligibility is subject to Basel Convention restrictions on hazardous waste exports and country-specific import regulations. Drives market routing decisions in commodity sales management.' ;
    rdfs:domain ind:CommodityGrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epaCommodityCode rdf:type rdf:Property ;
    rdfs:label 'Epa Commodity Code' ;
    rdfs:comment 'EPA-assigned commodity classification code used for federal recycling diversion rate reporting and Solid Waste Information System (SWIS) submissions. Enables accurate tracking of material recovery volumes by commodity type for regulatory compliance and sustainability reporting.' ;
    rdfs:domain ind:CommodityGrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gradeCode rdf:type rdf:Property ;
    rdfs:label 'Grade Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the commodity grade specification (e.g., OCC-A, PET-1, ALU-P). Used as the externally-known business identifier in SAP MM material master, AMCS commodity tracking, and buyer purchase orders. Aligns with ISRI commodity grade coding conventions.' ;
    rdfs:domain ind:CommodityGrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gradeName rdf:type rdf:Property ;
    rdfs:label 'Grade Name' ;
    rdfs:comment 'Human-readable name of the commodity grade specification (e.g., \'Grade A Old Corrugated Containers\', \'Premium Clear PET\', \'Standard Mixed Paper\', \'Off-Grade Aluminum\'). Used in quality control reports, buyer contracts, and MRF operational dashboards.' ;
    rdfs:domain ind:CommodityGrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gradeStatus rdf:type rdf:Property ;
    rdfs:label 'Grade Status' ;
    rdfs:comment 'Current lifecycle status of the commodity grade specification. Active grades are in use for quality control and pricing. Inactive grades are suspended from use. Deprecated grades have been superseded by updated specifications. Under Review grades are pending revision approval. Controls whether the grade is available for selection in MRF quality control workflows.' ;
    rdfs:domain ind:CommodityGrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gradeTier rdf:type rdf:Property ;
    rdfs:label 'Grade Tier' ;
    rdfs:comment 'Quality tier classification of the grade specification indicating relative market value and purity level. Premium and Grade A command market premiums; Standard meets baseline buyer requirements; Off-Grade triggers price discounts; Rejected material is non-saleable and requires alternative disposition. Drives pricing factor application in Oracle Revenue Management.' ;
    rdfs:domain ind:CommodityGrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isriSpecReference rdf:type rdf:Property ;
    rdfs:label 'Isri Spec Reference' ;
    rdfs:comment 'Official ISRI Scrap Specifications Circular grade designation code that this internal grade maps to (e.g., \'ISRI-11\' for OCC, \'ISRI-600\' for Aluminum Cans). Enables standardized communication with commodity buyers, brokers, and end-markets. Required for export commodity sales documentation.' ;
    rdfs:domain ind:CommodityGrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketPriceFactor rdf:type rdf:Property ;
    rdfs:label 'Market Price Factor' ;
    rdfs:comment 'Multiplicative premium or discount factor applied to the base commodity market price for this grade (e.g., 1.15 = 15% premium for Premium grade; 0.85 = 15% discount for Off-Grade; 1.00 = no adjustment for Standard). Used in Oracle Revenue Management to calculate commodity sale prices and MRF revenue projections.' ;
    rdfs:domain ind:CommodityGrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxBaleWeightLbs rdf:type rdf:Property ;
    rdfs:label 'Max Bale Weight Lbs' ;
    rdfs:comment 'Maximum allowable bale weight in pounds for this commodity grade. Ensures compliance with DOT weight regulations for transport and safe handling limits for forklift and loading equipment. Bales exceeding this limit require splitting before outbound shipment.' ;
    rdfs:domain ind:CommodityGrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxParticleSizeInches rdf:type rdf:Property ;
    rdfs:label 'Max Particle Size Inches' ;
    rdfs:comment 'Maximum allowable individual particle or item size in inches for material classified under this grade. Oversized items can damage processing equipment at end-market facilities and may trigger load rejection. Particularly relevant for glass, metal, and plastic grades.' ;
    rdfs:domain ind:CommodityGrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minBaleDensityLbsPerCuft rdf:type rdf:Property ;
    rdfs:label 'Min Bale Density Lbs Per Cuft' ;
    rdfs:comment 'Minimum required bale density in pounds per cubic foot for this commodity grade. Ensures structural integrity during transport and storage, and maximizes trailer payload efficiency. Bales failing density requirements may be rejected by buyers or require re-baling. Monitored via baler equipment sensors integrated with AMCS.' ;
    rdfs:domain ind:CommodityGrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minPurityPct rdf:type rdf:Property ;
    rdfs:label 'Min Purity Pct' ;
    rdfs:comment 'Minimum required percentage of the target commodity material in a bale or load for this grade classification (e.g., 98.00 for Premium Aluminum = minimum 98% pure aluminum content). Complements the contamination threshold by specifying the positive purity floor rather than the negative contamination ceiling.' ;
    rdfs:domain ind:CommodityGrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minSampleSizeLbs rdf:type rdf:Property ;
    rdfs:label 'Min Sample Size Lbs' ;
    rdfs:comment 'Minimum weight in pounds of material sample required for quality control testing under this grade specification. Ensures statistical validity of contamination and purity measurements. Applies when sort_purity_test_method is grab_sample or full_sort.' ;
    rdfs:domain ind:CommodityGrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rejectionDisposition rdf:type rdf:Property ;
    rdfs:label 'Rejection Disposition' ;
    rdfs:comment 'Default disposition action for material that fails to meet this grade specification. Landfill routes rejected material to disposal; Reprocess returns material to the MRF sorting line; Downgrade reclassifies to a lower grade; Return to Sender sends contaminated loads back to the collection route origin; WTE (Waste-to-Energy) routes to energy recovery. Drives operational workflow in AMCS.' ;
    rdfs:domain ind:CommodityGrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresLabTesting rdf:type rdf:Property ;
    rdfs:label 'Requires Lab Testing' ;
    rdfs:comment 'Indicates whether material classified under this grade requires laboratory analysis (e.g., TCLP — Toxicity Characteristic Leaching Procedure testing, moisture analysis, or purity assay) before sale or shipment. True for grades with strict purity or regulatory requirements. Triggers lab sample workflow in Enviance EHS.' ;
    rdfs:domain ind:CommodityGrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sortPurityTestMethod rdf:type rdf:Property ;
    rdfs:label 'Sort Purity Test Method' ;
    rdfs:comment 'Quality control testing method used to verify that a bale or load meets this grade specification. Visual Sort is a manual inspector review; Grab Sample is a representative sample extraction; Full Sort is complete material separation and weighing; Lab Analysis is laboratory chemical or physical testing; Automated Sensor uses optical or NIR sorting equipment data.' ;
    rdfs:domain ind:CommodityGrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commodityInventoryId rdf:type rdf:Property ;
    rdfs:label 'Commodity Inventory Id' ;
    rdfs:comment 'Unique identifier for the commodity inventory snapshot record.' ;
    rdfs:domain ind:CommodityInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocatedBales rdf:type rdf:Property ;
    rdfs:label 'Allocated Bales' ;
    rdfs:comment 'Number of bales committed to pending sales orders or customer allocations.' ;
    rdfs:domain ind:CommodityInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocatedWeightTons rdf:type rdf:Property ;
    rdfs:label 'Allocated Weight Tons' ;
    rdfs:comment 'Total weight in tons of commodity inventory allocated to pending sales orders.' ;
    rdfs:domain ind:CommodityInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:availableBales rdf:type rdf:Property ;
    rdfs:label 'Available Bales' ;
    rdfs:comment 'Number of bales available for sale, calculated as total bales on hand minus allocated bales.' ;
    rdfs:domain ind:CommodityInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:availableWeightTons rdf:type rdf:Property ;
    rdfs:label 'Available Weight Tons' ;
    rdfs:comment 'Total weight in tons of commodity inventory available for sale, calculated as total weight minus allocated weight.' ;
    rdfs:domain ind:CommodityInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageBaleAgeDays rdf:type rdf:Property ;
    rdfs:label 'Average Bale Age Days' ;
    rdfs:comment 'Average age in days of all bales in inventory, calculated from production date to snapshot date.' ;
    rdfs:domain ind:CommodityInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:commodityGrade rdf:type rdf:Property ;
    rdfs:label 'Commodity Grade' ;
    rdfs:comment 'Quality grade classification of the recovered commodity bales based on contamination levels and material purity standards.' ;
    rdfs:domain ind:Recycling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contaminationRatePercent rdf:type rdf:Property ;
    rdfs:label 'Contamination Rate Percent' ;
    rdfs:comment 'Average contamination rate percentage across all bales in inventory, indicating non-recyclable material content.' ;
    rdfs:domain ind:Recycling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inventoryTurnoverDays rdf:type rdf:Property ;
    rdfs:label 'Inventory Turnover Days' ;
    rdfs:comment 'Average number of days commodity inventory remains in storage before being sold, calculated over a rolling period.' ;
    rdfs:domain ind:CommodityInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inventoryValuationAmount rdf:type rdf:Property ;
    rdfs:label 'Inventory Valuation Amount' ;
    rdfs:comment 'Total financial valuation of the commodity inventory on hand based on current market pricing or standard cost.' ;
    rdfs:domain ind:CommodityInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastQualityInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Last Quality Inspection Date' ;
    rdfs:comment 'Date of the most recent quality inspection or certification performed on this commodity inventory.' ;
    rdfs:domain ind:CommodityInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maximumCapacityTons rdf:type rdf:Property ;
    rdfs:label 'Maximum Capacity Tons' ;
    rdfs:comment 'Maximum storage capacity in tons for this commodity type at this facility.' ;
    rdfs:domain ind:CommodityInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oldestBaleProductionDate rdf:type rdf:Property ;
    rdfs:label 'Oldest Bale Production Date' ;
    rdfs:comment 'Production date of the oldest bale currently in inventory, used to track inventory aging and FIFO management.' ;
    rdfs:domain ind:CommodityInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priceEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Price Effective Date' ;
    rdfs:comment 'Effective date of the current market price per ton used for inventory valuation.' ;
    rdfs:domain ind:Recycling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualityCertificationStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Certification Status' ;
    rdfs:comment 'Status of quality certification or inspection for the commodity inventory against ISRI or customer specifications.' ;
    rdfs:domain ind:CommodityInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reorderPointTons rdf:type rdf:Property ;
    rdfs:label 'Reorder Point Tons' ;
    rdfs:comment 'Minimum inventory threshold in tons that triggers production planning or sales acceleration actions.' ;
    rdfs:domain ind:CommodityInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:snapshotDate rdf:type rdf:Property ;
    rdfs:label 'Snapshot Date' ;
    rdfs:comment 'Business date for which this inventory snapshot was captured, representing the inventory position as of end of day.' ;
    rdfs:domain ind:CommodityInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:snapshotTimestamp rdf:type rdf:Property ;
    rdfs:label 'Snapshot Timestamp' ;
    rdfs:comment 'Precise timestamp when this inventory snapshot was captured from the source system.' ;
    rdfs:domain ind:CommodityInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:storageCapacityUtilizationPercent rdf:type rdf:Property ;
    rdfs:label 'Storage Capacity Utilization Percent' ;
    rdfs:comment 'Percentage of total MRF storage capacity utilized by this commodity inventory.' ;
    rdfs:domain ind:CommodityInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalBalesOnHand rdf:type rdf:Property ;
    rdfs:label 'Total Bales On Hand' ;
    rdfs:comment 'Total count of commodity bales currently in MRF storage at the snapshot date.' ;
    rdfs:domain ind:CommodityInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalWeightTons rdf:type rdf:Property ;
    rdfs:label 'Total Weight Tons' ;
    rdfs:comment 'Total weight of commodity inventory on hand measured in tons.' ;
    rdfs:domain ind:CommodityInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valuationCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Valuation Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for inventory valuation amount.' ;
    rdfs:domain ind:CommodityInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buyerVendorId rdf:type rdf:Property ;
    rdfs:label 'Buyer Vendor Id' ;
    rdfs:comment 'Foreign key linking to procurement.vendor. Business justification: Commodity buyers are often vendors in reverse logistics/circular supply chains. Linking buyer to vendor master enables consolidated vendor/customer management, rebate tracking, and closed-loop supply ' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:createdByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Created By User Employee Id' ;
    rdfs:comment 'Reference to the user who created the commodity sale record in the system.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:adjustmentAmountUsd rdf:type rdf:Property ;
    rdfs:label 'Adjustment Amount Usd' ;
    rdfs:comment 'Any price adjustments, discounts, or surcharges applied to the sale in USD. Can be positive or negative.' ;
    rdfs:domain ind:CommoditySale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:destinationAddress rdf:type rdf:Property ;
    rdfs:label 'Destination Address' ;
    rdfs:comment 'Full delivery address where the commodity materials were shipped. Buyer facility or designated receiving location.' ;
    rdfs:domain ind:Recycling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationCity rdf:type rdf:Property ;
    rdfs:label 'Destination City' ;
    rdfs:comment 'City name of the commodity delivery destination.' ;
    rdfs:domain ind:Recycling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationCountryCode rdf:type rdf:Property ;
    rdfs:label 'Destination Country Code' ;
    rdfs:comment 'Three-letter ISO country code of the commodity delivery destination. Typically USA for domestic sales.' ;
    rdfs:domain ind:CommoditySale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationPostalCode rdf:type rdf:Property ;
    rdfs:label 'Destination Postal Code' ;
    rdfs:comment 'ZIP or postal code of the commodity delivery destination.' ;
    rdfs:domain ind:Recycling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationState rdf:type rdf:Property ;
    rdfs:label 'Destination State' ;
    rdfs:comment 'Two-letter state code of the commodity delivery destination.' ;
    rdfs:domain ind:Recycling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightChargeUsd rdf:type rdf:Property ;
    rdfs:label 'Freight Charge Usd' ;
    rdfs:comment 'Freight or transportation charges in USD associated with the commodity sale. May be billed to buyer or absorbed by seller.' ;
    rdfs:domain ind:CommoditySale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isExportSale rdf:type rdf:Property ;
    rdfs:label 'Is Export Sale' ;
    rdfs:comment 'Flag indicating whether this commodity sale is an international export transaction requiring customs documentation and compliance.' ;
    rdfs:domain ind:CommoditySale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketIndexReference rdf:type rdf:Property ;
    rdfs:label 'Market Index Reference' ;
    rdfs:comment 'Reference to the commodity market pricing index used for this sale. Examples include RISI, Fastmarkets, or regional market indices.' ;
    rdfs:domain ind:CommoditySale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netSaleAmountUsd rdf:type rdf:Property ;
    rdfs:label 'Net Sale Amount Usd' ;
    rdfs:comment 'Final net revenue amount in USD after all adjustments and freight charges. Amount to be invoiced and collected.' ;
    rdfs:domain ind:CommoditySale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentDueDate rdf:type rdf:Property ;
    rdfs:label 'Payment Due Date' ;
    rdfs:comment 'Date by which payment for the commodity sale is due from the buyer, calculated based on payment terms.' ;
    rdfs:domain ind:CommoditySale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Payment Received Date' ;
    rdfs:comment 'Date when payment was received from the buyer for this commodity sale. Null if payment is still outstanding.' ;
    rdfs:domain ind:CommoditySale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualityGradeCertification rdf:type rdf:Property ;
    rdfs:label 'Quality Grade Certification' ;
    rdfs:comment 'Quality certification or grade verification documentation for the commodity materials. May reference third-party inspection reports.' ;
    rdfs:domain ind:CommoditySale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:saleDate rdf:type rdf:Property ;
    rdfs:label 'Sale Date' ;
    rdfs:comment 'Date when the commodity sale transaction was executed and ownership transferred to the buyer.' ;
    rdfs:domain ind:CommoditySale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:saleOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Sale Order Number' ;
    rdfs:comment 'Business identifier for the commodity sale order. Externally-known unique reference number used for tracking and reconciliation with buyers and billing systems.' ;
    rdfs:domain ind:CommoditySale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:saleStatus rdf:type rdf:Property ;
    rdfs:label 'Sale Status' ;
    rdfs:comment 'Current lifecycle status of the commodity sale transaction. Tracks progression from order creation through payment completion. [ENUM-REF-CANDIDATE: draft|confirmed|shipped|delivered|invoiced|paid|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CommoditySale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapDeliveryNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Delivery Number' ;
    rdfs:comment 'SAP SD module delivery document number. Tracks the outbound delivery and goods issue for the commodity shipment.' ;
    rdfs:domain ind:CommoditySale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapSalesOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Sales Order Number' ;
    rdfs:comment 'SAP SD module sales order document number. System reference for integration with ERP financial and logistics processes.' ;
    rdfs:domain ind:CommoditySale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentMethod rdf:type rdf:Property ;
    rdfs:label 'Shipment Method' ;
    rdfs:comment 'Transportation method used to deliver the commodity to the buyer. Indicates logistics mode for the sale.' ;
    rdfs:domain ind:CommoditySale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalBaleCount rdf:type rdf:Property ;
    rdfs:label 'Total Bale Count' ;
    rdfs:comment 'Total number of bales included in this commodity sale transaction across all line items.' ;
    rdfs:domain ind:CommoditySale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalGrossWeightTons rdf:type rdf:Property ;
    rdfs:label 'Total Gross Weight Tons' ;
    rdfs:comment 'Total gross weight in tons including bale wrapping and any packaging materials. Used for transportation and logistics planning.' ;
    rdfs:domain ind:CommoditySale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalSaleAmountUsd rdf:type rdf:Property ;
    rdfs:label 'Total Sale Amount Usd' ;
    rdfs:comment 'Total revenue amount in USD for the entire commodity sale transaction. Sum of all line item values before adjustments.' ;
    rdfs:domain ind:CommoditySale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sortSessionId rdf:type rdf:Property ;
    rdfs:label 'Sort Session Id' ;
    rdfs:comment 'Reference to the sorting session during which the contamination event was identified. Used when analysis occurs during active sorting operations.' ;
    rdfs:domain ind:Recycling ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SortSession .

ind:sourceRouteId rdf:type rdf:Property ;
    rdfs:label 'Source Route Id' ;
    rdfs:comment 'Identifier of the collection route from which the contaminated material originated. Enables geographic contamination trending.' ;
    rdfs:domain ind:ContaminationEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Route .

ind:analysisType rdf:type rdf:Property ;
    rdfs:label 'Analysis Type' ;
    rdfs:comment 'Type of material quality analysis performed. Contamination check focuses on non-recyclable content; full composition audit provides complete material breakdown; NIR scan uses near-infrared technology for automated detection.' ;
    rdfs:domain ind:ContaminationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commodityValueLossUsd rdf:type rdf:Property ;
    rdfs:label 'Commodity Value Loss Usd' ;
    rdfs:comment 'Estimated revenue loss due to reduced commodity quality or rejected material, measured in US dollars.' ;
    rdfs:domain ind:ContaminationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contaminantsPercentage rdf:type rdf:Property ;
    rdfs:label 'Contaminants Percentage' ;
    rdfs:comment 'Percentage of non-recyclable contaminants (trash, hazardous materials, textiles, electronics) in the sample by weight. Primary metric for contamination rate tracking.' ;
    rdfs:domain ind:ContaminationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerNotificationSent rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Sent' ;
    rdfs:comment 'Indicates whether the source generator was notified about the contamination event for education and corrective action purposes.' ;
    rdfs:domain ind:ContaminationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dispositionAction rdf:type rdf:Property ;
    rdfs:label 'Disposition Action' ;
    rdfs:comment 'Action taken on the contaminated load or material. Determines whether material proceeds through MRF processing or is diverted.' ;
    rdfs:domain ind:ContaminationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diversionImpactTons rdf:type rdf:Property ;
    rdfs:label 'Diversion Impact Tons' ;
    rdfs:comment 'Estimated tonnage impact on facility diversion rate due to this contamination event. Negative value indicates material diverted to landfill instead of recycling.' ;
    rdfs:domain ind:ContaminationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:epaReportable rdf:type rdf:Property ;
    rdfs:label 'Epa Reportable' ;
    rdfs:comment 'Indicates whether this contamination event must be included in EPA recycling and diversion rate reporting.' ;
    rdfs:domain ind:ContaminationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fiberPercentage rdf:type rdf:Property ;
    rdfs:label 'Fiber Percentage' ;
    rdfs:comment 'Percentage of fiber materials (paper, cardboard, newsprint) in the sample by weight. Key commodity category for MRF revenue and EPA recycling reporting.' ;
    rdfs:domain ind:ContaminationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:glassPercentage rdf:type rdf:Property ;
    rdfs:label 'Glass Percentage' ;
    rdfs:comment 'Percentage of glass materials (clear, green, brown) in the sample by weight. Tracked separately due to processing challenges and market constraints.' ;
    rdfs:domain ind:ContaminationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:metalsPercentage rdf:type rdf:Property ;
    rdfs:label 'Metals Percentage' ;
    rdfs:comment 'Percentage of metal materials (aluminum, steel, tin) in the sample by weight. High-value commodity category for MRF operations.' ;
    rdfs:domain ind:ContaminationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:organicsPercentage rdf:type rdf:Property ;
    rdfs:label 'Organics Percentage' ;
    rdfs:comment 'Percentage of organic materials (food waste, yard waste, compostables) in the sample by weight. Considered contamination in single-stream recycling.' ;
    rdfs:domain ind:ContaminationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:photoEvidenceUrl rdf:type rdf:Property ;
    rdfs:label 'Photo Evidence Url' ;
    rdfs:comment 'URL or file path to photographic documentation of the contamination event. Used for customer education, training, and dispute resolution.' ;
    rdfs:domain ind:ContaminationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plasticsPercentage rdf:type rdf:Property ;
    rdfs:label 'Plastics Percentage' ;
    rdfs:comment 'Percentage of plastic materials (PET, HDPE, PP, film) in the sample by weight. Includes all resin types recovered at the MRF.' ;
    rdfs:domain ind:ContaminationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processingCostImpactUsd rdf:type rdf:Property ;
    rdfs:label 'Processing Cost Impact Usd' ;
    rdfs:comment 'Estimated additional processing cost incurred due to contamination, including labor, equipment downtime, and disposal fees, measured in US dollars.' ;
    rdfs:domain ind:ContaminationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sampleWeightLbs rdf:type rdf:Property ;
    rdfs:label 'Sample Weight Lbs' ;
    rdfs:comment 'Total weight of the material sample analyzed, measured in pounds. Used to calculate contamination rates and material composition percentages.' ;
    rdfs:domain ind:Recycling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:epaRecyclingReportId rdf:type rdf:Property ;
    rdfs:label 'Epa Recycling Report Id' ;
    rdfs:comment 'Unique surrogate identifier for each EPA recycling report submission record in the Waste Management lakehouse silver layer.' ;
    rdfs:domain ind:EpaRecyclingReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:epaFacilityId rdf:type rdf:Property ;
    rdfs:label 'Epa Facility Id' ;
    rdfs:comment 'Reference to the MRF facility that is the subject of this recycling report submission.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:originalReportEpaRecyclingReportId rdf:type rdf:Property ;
    rdfs:label 'Original Report Epa Recycling Report Id' ;
    rdfs:comment 'Reference to the original epa_recycling_report record that this submission corrects or supersedes. Populated only when resubmission_flag is True. Enables lineage tracking of report amendment history.' ;
    rdfs:domain ind:EpaRecyclingReport ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EpaRecyclingReport .

ind:primaryEpaFacilityId rdf:type rdf:Property ;
    rdfs:label 'Primary Epa Facility Id' ;
    rdfs:comment 'EPA-assigned facility identifier for the MRF, used as the official facility reference on all federal recycling report submissions. Corresponds to the EPA facility registry identifier.' ;
    rdfs:domain ind:EpaRecyclingReport ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:averageDailyThroughputTpd rdf:type rdf:Property ;
    rdfs:label 'Average Daily Throughput Tpd' ;
    rdfs:comment 'Average weight in short tons of material processed per operational day during the reporting period. Calculated as total_tons_received divided by processing_days. Key MRF capacity utilization metric reported to regulatory agencies and used for permit compliance verification.' ;
    rdfs:domain ind:EpaRecyclingReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contaminationRatePct rdf:type rdf:Property ;
    rdfs:label 'Contamination Rate Pct' ;
    rdfs:comment 'Average contamination rate as a decimal percentage of inbound recyclable material that was non-recyclable or improperly sorted during the reporting period. High contamination rates impact commodity quality and diversion rates. Reported to state agencies in contamination reduction programs.' ;
    rdfs:domain ind:Recycling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:diversionRatePct rdf:type rdf:Property ;
    rdfs:label 'Diversion Rate Pct' ;
    rdfs:comment 'Percentage of total inbound material weight that was diverted from landfill disposal through recycling or recovery during the reporting period. Calculated as total_tons_recycled divided by total_tons_received, expressed as a decimal (e.g., 0.8750 = 87.50%). Core KPI for EPA and state recycling compliance reporting.' ;
    rdfs:domain ind:Recycling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:envianceSubmissionReference rdf:type rdf:Property ;
    rdfs:label 'Enviance Submission Reference' ;
    rdfs:comment 'Reference identifier from the Enviance EHS system for the corresponding compliance submission record. Enables traceability between the lakehouse data product and the operational EHS system of record.' ;
    rdfs:domain ind:EpaRecyclingReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glassTonsRecycled rdf:type rdf:Property ;
    rdfs:label 'Glass Tons Recycled' ;
    rdfs:comment 'Total weight in short tons of glass commodities recovered and diverted from landfill during the reporting period. Required for material-specific recovery reporting to EPA and state agencies.' ;
    rdfs:domain ind:EpaRecyclingReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:metalTonsRecycled rdf:type rdf:Property ;
    rdfs:label 'Metal Tons Recycled' ;
    rdfs:comment 'Total weight in short tons of ferrous and non-ferrous metal commodities (aluminum, steel, tin) recovered and diverted from landfill during the reporting period. Required for material-specific recovery reporting to EPA and state agencies.' ;
    rdfs:domain ind:EpaRecyclingReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:organicsTonsRecycled rdf:type rdf:Property ;
    rdfs:label 'Organics Tons Recycled' ;
    rdfs:comment 'Total weight in short tons of organic materials (food waste, yard waste, compostables) recovered and diverted from landfill during the reporting period. Increasingly required by state organics diversion mandates.' ;
    rdfs:domain ind:EpaRecyclingReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otherCommodityTonsRecycled rdf:type rdf:Property ;
    rdfs:label 'Other Commodity Tons Recycled' ;
    rdfs:comment 'Total weight in short tons of recovered materials not classified under paper, plastic, metal, glass, or organics categories (e.g., electronics, textiles, rubber) during the reporting period.' ;
    rdfs:domain ind:EpaRecyclingReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paperTonsRecycled rdf:type rdf:Property ;
    rdfs:label 'Paper Tons Recycled' ;
    rdfs:comment 'Total weight in short tons of paper and cardboard commodities (OCC, ONP, mixed paper) recovered and diverted from landfill during the reporting period. Required for material-specific recovery reporting to EPA and state agencies.' ;
    rdfs:domain ind:EpaRecyclingReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plasticTonsRecycled rdf:type rdf:Property ;
    rdfs:label 'Plastic Tons Recycled' ;
    rdfs:comment 'Total weight in short tons of plastic commodities (PET, HDPE, mixed plastics) recovered and diverted from landfill during the reporting period. Required for material-specific recovery reporting to EPA and state agencies.' ;
    rdfs:domain ind:EpaRecyclingReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processingDays rdf:type rdf:Property ;
    rdfs:label 'Processing Days' ;
    rdfs:comment 'Number of operational days the MRF processed inbound recyclable material during the reporting period. Used to calculate average daily throughput (Tons Per Day) for regulatory performance benchmarking.' ;
    rdfs:domain ind:EpaRecyclingReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryAgencyName rdf:type rdf:Property ;
    rdfs:label 'Regulatory Agency Name' ;
    rdfs:comment 'Full legal name of the specific regulatory agency receiving this report (e.g., \'Texas Commission on Environmental Quality\', \'California Department of Resources Recycling and Recovery\'). Provides the precise agency identity beyond the classification in regulatory_agency.' ;
    rdfs:domain ind:EpaRecyclingReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportNotes rdf:type rdf:Property ;
    rdfs:label 'Report Notes' ;
    rdfs:comment 'Free-text field for operational notes, explanatory comments, or supplemental context associated with this recycling report submission. May include explanations for anomalous tonnage figures, facility disruptions, or agency correspondence notes.' ;
    rdfs:domain ind:EpaRecyclingReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportPreparerName rdf:type rdf:Property ;
    rdfs:label 'Report Preparer Name' ;
    rdfs:comment 'Full name of the Waste Management employee responsible for preparing and compiling this recycling report. Required on regulatory submissions for accountability and agency correspondence.' ;
    rdfs:domain ind:EpaRecyclingReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportPreparerTitle rdf:type rdf:Property ;
    rdfs:label 'Report Preparer Title' ;
    rdfs:comment 'Job title of the Waste Management employee who prepared this recycling report (e.g., \'Environmental Compliance Manager\', \'MRF Operations Director\'). Required on regulatory submissions.' ;
    rdfs:domain ind:EpaRecyclingReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportStatus rdf:type rdf:Property ;
    rdfs:label 'Report Status' ;
    rdfs:comment 'Current lifecycle status of the recycling report submission. Draft indicates report is being prepared; submitted indicates it has been sent to the regulatory agency; accepted indicates agency confirmation of receipt and compliance; rejected indicates agency returned the report for correction; under_review indicates agency is actively reviewing the submission.' ;
    rdfs:domain ind:EpaRecyclingReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingPeriodType rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Type' ;
    rdfs:comment 'Frequency classification of the reporting period covered by this submission. Determines the temporal scope of the recycling performance data included in the report.' ;
    rdfs:domain ind:EpaRecyclingReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residueTons rdf:type rdf:Property ;
    rdfs:label 'Residue Tons' ;
    rdfs:comment 'Total weight in short tons of material received at the MRF that could not be recovered and was disposed of as residue (landfilled) during the reporting period. Residue rate is a key MRF efficiency metric reported to regulatory agencies.' ;
    rdfs:domain ind:EpaRecyclingReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resubmissionFlag rdf:type rdf:Property ;
    rdfs:label 'Resubmission Flag' ;
    rdfs:comment 'Indicates whether this report is a resubmission of a previously rejected or corrected report. True when this record represents a corrected resubmission; False for original submissions. Supports audit trail and compliance history tracking.' ;
    rdfs:domain ind:EpaRecyclingReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalTonsReceived rdf:type rdf:Property ;
    rdfs:label 'Total Tons Received' ;
    rdfs:comment 'Total weight in short tons of all inbound material received at the MRF during the reporting period, including both recyclable and residue streams. Used as the denominator for diversion rate calculation.' ;
    rdfs:domain ind:EpaRecyclingReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalTonsRecycled rdf:type rdf:Property ;
    rdfs:label 'Total Tons Recycled' ;
    rdfs:comment 'Total weight in short tons of all recovered materials processed and diverted from landfill during the reporting period across all commodity streams at the MRF. This is the primary quantitative outcome metric of the recycling report.' ;
    rdfs:domain ind:EpaRecyclingReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wasteAcceptancePermitId rdf:type rdf:Property ;
    rdfs:label 'Waste Acceptance Permit Id' ;
    rdfs:comment 'Foreign key linking to compliance.permit. Business justification: Inbound loads must comply with facility waste acceptance permits specifying allowed material types, contamination limits, and capacity thresholds. Critical for scale house permit verification and regu' ;
    rdfs:domain ind:InboundLoad ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Permit .

ind:amcsLoadReference rdf:type rdf:Property ;
    rdfs:label 'Amcs Load Reference' ;
    rdfs:comment 'Reference identifier from the AMCS Platform linking this MRF inbound load record to the originating route dispatch and collection event. Enables route-to-MRF load reconciliation and confirms that collected materials were delivered to the correct facility.' ;
    rdfs:domain ind:InboundLoad ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contaminationSurcharge rdf:type rdf:Property ;
    rdfs:label 'Contamination Surcharge' ;
    rdfs:comment 'Additional fee assessed on this load due to contamination exceeding the contractual threshold, expressed in US dollars. Applied per customer contract terms when contamination percentage exceeds the agreed acceptable contamination rate. Posted to Oracle Revenue Management for billing.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedDiversionTons rdf:type rdf:Property ;
    rdfs:label 'Estimated Diversion Tons' ;
    rdfs:comment 'Estimated tonnage of this load that is expected to be diverted from landfill through recycling or recovery, based on material stream type and historical contamination-adjusted yield rates. Expressed in short tons. Used for real-time diversion rate tracking and EPA recycling program reporting. Distinct from actual recovered commodity weight which is captured at bale production.' ;
    rdfs:domain ind:InboundLoad ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isAudited rdf:type rdf:Property ;
    rdfs:label 'Is Audited' ;
    rdfs:comment 'Indicates whether this inbound load has been selected for and completed a formal sort audit or waste characterization study. True = audit completed. Sort audits are used to validate contamination estimates, measure commodity composition, and support EPA recycling program reporting accuracy.' ;
    rdfs:domain ind:InboundLoad ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loadNotes rdf:type rdf:Property ;
    rdfs:label 'Load Notes' ;
    rdfs:comment 'Free-text field for scale operator or supervisor notes regarding this inbound load. May include observations about load quality, unusual materials, driver communications, or special handling instructions. Supports operational exception management.' ;
    rdfs:domain ind:InboundLoad ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadSourceType rdf:type rdf:Property ;
    rdfs:label 'Load Source Type' ;
    rdfs:comment 'Classification of how the load arrived at the MRF. \'direct_haul\' = collection vehicle delivering directly from route; \'transfer_station\' = consolidated load from a transfer station; \'drop_off_center\' = aggregated materials from a public drop-off facility; \'special_event\' = community recycling event; \'third_party_hauler\' = independent hauler delivering under contract.' ;
    rdfs:domain ind:InboundLoad ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadStatus rdf:type rdf:Property ;
    rdfs:label 'Load Status' ;
    rdfs:comment 'Current workflow state of the inbound load record. \'received\' = weighed and logged at scale; \'accepted\' = cleared for processing; \'rejected\' = refused entry (contamination, wrong material, etc.); \'pending_review\' = flagged for supervisor review; \'posted\' = SAP MM material receipt posted; \'voided\' = record cancelled.' ;
    rdfs:domain ind:InboundLoad ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialStreamType rdf:type rdf:Property ;
    rdfs:label 'Material Stream Type' ;
    rdfs:comment 'Classification of the inbound material stream. \'single_stream_residential\' = commingled recyclables from residential curbside collection; \'commercial_mixed\' = mixed recyclables from commercial accounts; \'cnd\' = Construction and Demolition (C&D) debris; \'drop_off\' = materials from public drop-off programs; \'organics\' = food/yard waste streams; \'special_collection\' = event or special program collections. Drives sorting line configuration and commodity yield expectations.' ;
    rdfs:domain ind:Recycling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingShift rdf:type rdf:Property ;
    rdfs:label 'Processing Shift' ;
    rdfs:comment 'Work shift during which this inbound load was received and processed at the MRF. Used for shift-level throughput reporting, labor allocation, and operational performance benchmarking.' ;
    rdfs:domain ind:InboundLoad ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingDock rdf:type rdf:Property ;
    rdfs:label 'Receiving Dock' ;
    rdfs:comment 'Identifier of the MRF tipping floor dock or bay assigned to receive this load. Used for floor traffic management, sorting line assignment, and operational throughput balancing across dock positions.' ;
    rdfs:domain ind:InboundLoad ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapMaterialDocNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Material Doc Number' ;
    rdfs:comment 'SAP MM material document number generated upon goods receipt posting for this inbound load. Confirms the load has been formally received into SAP inventory management. Null until load_status = \'posted\'. Enables reconciliation between MRF scale records and SAP MM inventory.' ;
    rdfs:domain ind:InboundLoad ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sortLineAssignment rdf:type rdf:Property ;
    rdfs:label 'Sort Line Assignment' ;
    rdfs:comment 'Identifier of the MRF sorting line or processing line to which this load was directed after tipping floor receipt. Used for equipment utilization tracking, throughput balancing, and sort line performance analytics.' ;
    rdfs:domain ind:Recycling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supervisorReviewFlag rdf:type rdf:Property ;
    rdfs:label 'Supervisor Review Flag' ;
    rdfs:comment 'Indicates whether this load record has been flagged for or has undergone supervisor review. True = supervisor review required or completed. Triggered by contamination above threshold, weight anomalies, rejected loads, or missing documentation.' ;
    rdfs:domain ind:InboundLoad ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supervisorReviewTimestamp rdf:type rdf:Property ;
    rdfs:label 'Supervisor Review Timestamp' ;
    rdfs:comment 'Date and time the supervisor completed review of this flagged load record. Null if supervisor_review_flag is False or review is pending. Used for SLA compliance on review turnaround and audit trail.' ;
    rdfs:domain ind:InboundLoad ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:marketPriceId rdf:type rdf:Property ;
    rdfs:label 'Market Price Id' ;
    rdfs:comment 'Unique identifier for the market price record. Primary key.' ;
    rdfs:domain ind:MarketPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contaminationAdjustmentFactor rdf:type rdf:Property ;
    rdfs:label 'Contamination Adjustment Factor' ;
    rdfs:comment 'Multiplier applied to base price to account for contamination levels in recovered materials. Values less than 1.0 indicate price reductions for contaminated loads. Critical for MRF quality control and revenue management.' ;
    rdfs:domain ind:MarketPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marketCondition rdf:type rdf:Property ;
    rdfs:label 'Market Condition' ;
    rdfs:comment 'Qualitative assessment of the current market condition for this commodity. Strong indicates high demand and rising prices, weak indicates oversupply and falling prices, volatile indicates rapid price fluctuations, stable indicates consistent pricing.' ;
    rdfs:domain ind:MarketPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceAdjustmentFrequency rdf:type rdf:Property ;
    rdfs:label 'Price Adjustment Frequency' ;
    rdfs:comment 'How often this market price is reviewed and updated. Daily for spot markets, weekly or monthly for published indices, quarterly or annual for long-term contracts, as-published for index-linked pricing.' ;
    rdfs:domain ind:MarketPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceCeilingPerTonUsd rdf:type rdf:Property ;
    rdfs:label 'Price Ceiling Per Ton Usd' ;
    rdfs:comment 'Maximum price per ton in contract agreements. Protects buyer from extreme market spikes. Nullable if no ceiling is negotiated.' ;
    rdfs:domain ind:MarketPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceChangePercentage rdf:type rdf:Property ;
    rdfs:label 'Price Change Percentage' ;
    rdfs:comment 'Percentage change in price compared to the previous pricing period. Positive values indicate price increases, negative values indicate decreases. Used for trend analysis and revenue forecasting.' ;
    rdfs:domain ind:MarketPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceChangeReason rdf:type rdf:Property ;
    rdfs:label 'Price Change Reason' ;
    rdfs:comment 'Business explanation for significant price changes (e.g., increased demand from China, mill shutdowns, contamination issues, seasonal demand, transportation cost increases). Supports market intelligence and strategic planning.' ;
    rdfs:domain ind:MarketPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Price Expiration Date' ;
    rdfs:comment 'Date when this market price expires and is no longer applicable. Nullable for open-ended pricing agreements. End of the pricing validity period.' ;
    rdfs:domain ind:MarketPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priceFloorPerTonUsd rdf:type rdf:Property ;
    rdfs:label 'Price Floor Per Ton Usd' ;
    rdfs:comment 'Minimum guaranteed price per ton in contract agreements. Protects seller from extreme market downturns. Nullable if no floor is negotiated.' ;
    rdfs:domain ind:MarketPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricePerTonUsd rdf:type rdf:Property ;
    rdfs:label 'Price Per Ton Usd' ;
    rdfs:comment 'Market price per ton of the commodity in US Dollars. Core pricing metric for MRF commodity sales valuation and revenue forecasting.' ;
    rdfs:domain ind:MarketPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricePublishedDate rdf:type rdf:Property ;
    rdfs:label 'Price Published Date' ;
    rdfs:comment 'Date when this market price was published or announced by the pricing source (OBM, RISI, etc.). May differ from effective date for forward-looking pricing.' ;
    rdfs:domain ind:MarketPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priceRegion rdf:type rdf:Property ;
    rdfs:label 'Price Region' ;
    rdfs:comment 'Geographic scope of the market price. National for US-wide pricing, regional for multi-state areas (northeast, southeast, midwest, southwest, west), or local for specific market areas. Commodity prices vary significantly by region due to transportation costs and local demand. [ENUM-REF-CANDIDATE: national|northeast|southeast|midwest|southwest|west|regional|local — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MarketPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceRegionCode rdf:type rdf:Property ;
    rdfs:label 'Price Region Code' ;
    rdfs:comment 'Abbreviated code for the pricing region (e.g., NE for Northeast, MW for Midwest, SW for Southwest). Used for reporting and system integration.' ;
    rdfs:domain ind:MarketPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceSource rdf:type rdf:Property ;
    rdfs:label 'Price Source' ;
    rdfs:comment 'Source of the market price data. OBM (Official Board Markets) for paper pricing, RISI for pulp and paper market intelligence, internal contract for negotiated customer agreements, spot market for current trading prices, broker quote, exchange index, or customer contract. [ENUM-REF-CANDIDATE: OBM|RISI|internal_contract|spot_market|broker_quote|exchange_index|customer_contract — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MarketPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceStatus rdf:type rdf:Property ;
    rdfs:label 'Price Status' ;
    rdfs:comment 'Current lifecycle status of this market price record. Active for currently applicable prices, expired for past prices, pending for future prices not yet effective, superseded for prices replaced by newer records, cancelled for withdrawn pricing.' ;
    rdfs:domain ind:MarketPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceType rdf:type rdf:Property ;
    rdfs:label 'Price Type' ;
    rdfs:comment 'Classification of the pricing mechanism. Spot for immediate market prices, contract for long-term agreement prices, index-linked for prices tied to a market index, negotiated for custom pricing, published for industry-published rates, average for calculated averages.' ;
    rdfs:domain ind:MarketPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transportationIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Transportation Included Flag' ;
    rdfs:comment 'Indicates whether transportation costs are included in the price per ton. True if price includes delivery (delivered pricing), False if price is FOB (Free On Board) at MRF location.' ;
    rdfs:domain ind:MarketPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:materialCompositionId rdf:type rdf:Property ;
    rdfs:label 'Material Composition Id' ;
    rdfs:comment 'Unique surrogate identifier for each material composition analysis record at the Materials Recovery Facility (MRF). Primary key for this transactional entity.' ;
    rdfs:domain ind:MaterialComposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:customerRouteId rdf:type rdf:Property ;
    rdfs:label 'Customer Route Id' ;
    rdfs:comment 'Reference to the collection route from which the sampled inbound load originated. Enables contamination trending by geographic route or service area, supporting targeted customer education programs and route-level diversion rate analysis.' ;
    rdfs:domain ind:MaterialComposition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Route .

ind:primaryMaterialEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Material Employee Id' ;
    rdfs:comment 'Reference to the Workday HCM workforce record of the technician or analyst who performed the material composition analysis.' ;
    rdfs:domain ind:MaterialComposition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:aluminumPct rdf:type rdf:Property ;
    rdfs:label 'Aluminum Pct' ;
    rdfs:comment 'Percentage by weight of aluminum (primarily UBC — Used Beverage Cans) in the analyzed sample. Aluminum is the highest-value metal commodity recovered at MRFs. Tracked for commodity recovery, diversion rate, and SAP MM inventory valuation.' ;
    rdfs:domain ind:MaterialComposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:analysisMethod rdf:type rdf:Property ;
    rdfs:label 'Analysis Method' ;
    rdfs:comment 'The technique used to perform the material composition analysis. Manual sort audit involves physical hand-sorting of a sample; NIR (Near-Infrared) scan uses optical sensor technology; grab sample is a single-point collection; composite sample aggregates multiple grab samples across a shift or load.' ;
    rdfs:domain ind:MaterialComposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analysisNumber rdf:type rdf:Property ;
    rdfs:label 'Analysis Number' ;
    rdfs:comment 'Externally-visible business identifier for this composition analysis record, formatted as MC-{YYYY}-{NNNNNN}. Used for cross-referencing with EPA recycling reports, audit documentation, and SAP MM commodity inventory records.' ;
    rdfs:domain ind:MaterialComposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analysisStatus rdf:type rdf:Property ;
    rdfs:label 'Analysis Status' ;
    rdfs:comment 'Current lifecycle status of the material composition analysis record. Draft indicates data entry in progress; pending_review awaits QC supervisor sign-off; approved indicates validated and accepted for reporting; rejected indicates failed QC review; voided indicates cancelled or superseded record.' ;
    rdfs:domain ind:MaterialComposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analysisTimestamp rdf:type rdf:Property ;
    rdfs:label 'Analysis Timestamp' ;
    rdfs:comment 'The principal real-world date and time when the material composition analysis was physically performed at the MRF. Distinct from record creation audit timestamp. Used for contamination trending and EPA recycling reporting period alignment.' ;
    rdfs:domain ind:MaterialComposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:clearGlassPct rdf:type rdf:Property ;
    rdfs:label 'Clear Glass Pct' ;
    rdfs:comment 'Percentage by weight of clear (flint) glass in the analyzed sample. Clear glass commands the highest glass commodity price and is tracked separately from colored glass for accurate market valuation and EPA reporting.' ;
    rdfs:domain ind:MaterialComposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coloredGlassPct rdf:type rdf:Property ;
    rdfs:label 'Colored Glass Pct' ;
    rdfs:comment 'Percentage by weight of colored glass (amber, green) in the analyzed sample. Colored glass has lower commodity value than clear glass and is tracked separately for accurate diversion rate and market pricing analysis.' ;
    rdfs:domain ind:MaterialComposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:diversionRateContributionPct rdf:type rdf:Property ;
    rdfs:label 'Diversion Rate Contribution Pct' ;
    rdfs:comment 'The estimated recyclable material percentage from this analysis that contributes to the facility diversion rate calculation (total recyclables recovered / total material received). Equals 100% minus contamination% minus residue%. Used for EPA recycling program reporting and circular economy goal tracking.' ;
    rdfs:domain ind:MaterialComposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hazardousMaterialDescription rdf:type rdf:Property ;
    rdfs:label 'Hazardous Material Description' ;
    rdfs:comment 'Free-text description of any hazardous or household hazardous waste materials identified in the sample. Populated only when hazardous_material_found is True. Supports RCRA incident reporting, Enviance EHS documentation, and DOT compliance.' ;
    rdfs:domain ind:MaterialComposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardousMaterialFound rdf:type rdf:Property ;
    rdfs:label 'Hazardous Material Found' ;
    rdfs:comment 'Indicates whether any hazardous or household hazardous waste (HHW) materials were identified in the sample during analysis. True triggers mandatory incident reporting per RCRA and Enviance EHS protocols. Critical for worker safety (OSHA) and regulatory compliance.' ;
    rdfs:domain ind:MaterialComposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hdpePct rdf:type rdf:Property ;
    rdfs:label 'Hdpe Pct' ;
    rdfs:comment 'Percentage by weight of HDPE (High-Density Polyethylene, Resin Code #2) plastics in the analyzed sample. HDPE includes milk jugs and detergent bottles. Tracked separately as a distinct commodity grade with its own market pricing.' ;
    rdfs:domain ind:MaterialComposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mixedPaperPct rdf:type rdf:Property ;
    rdfs:label 'Mixed Paper Pct' ;
    rdfs:comment 'Percentage by weight of mixed paper (office paper, magazines, junk mail, paperboard) in the analyzed sample. Mixed paper is a lower-grade fiber commodity. Tracked for diversion rate reporting and commodity market pricing.' ;
    rdfs:domain ind:MaterialComposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mixedPlasticsPct rdf:type rdf:Property ;
    rdfs:label 'Mixed Plastics Pct' ;
    rdfs:comment 'Percentage by weight of mixed plastics (Resin Codes #3-#7, excluding PET and HDPE) in the analyzed sample. Mixed plastics have lower commodity value and may be directed to waste-to-energy or residue streams depending on market conditions.' ;
    rdfs:domain ind:MaterialComposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:newspaperPct rdf:type rdf:Property ;
    rdfs:label 'Newspaper Pct' ;
    rdfs:comment 'Percentage by weight of Old Newspaper (ONP) in the analyzed sample. ONP is a distinct fiber grade with its own commodity market pricing. Tracked separately from mixed paper for accurate commodity recovery reporting.' ;
    rdfs:domain ind:MaterialComposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:occPct rdf:type rdf:Property ;
    rdfs:label 'Occ Pct' ;
    rdfs:comment 'Percentage by weight of Old Corrugated Cardboard (OCC) in the analyzed sample. OCC is a high-value fiber commodity recovered at MRFs. Used for commodity recovery tracking, diversion rate calculation, and SAP MM inventory valuation.' ;
    rdfs:domain ind:MaterialComposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:organicsPct rdf:type rdf:Property ;
    rdfs:label 'Organics Pct' ;
    rdfs:comment 'Percentage by weight of organic material (food waste, yard waste, compostable material) in the analyzed sample. High organics content in recyclable streams indicates collection program contamination and reduces commodity quality. Tracked for contamination trending and EPA reporting.' ;
    rdfs:domain ind:MaterialComposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otherRecyclablesPct rdf:type rdf:Property ;
    rdfs:label 'Other Recyclables Pct' ;
    rdfs:comment 'Percentage by weight of other recoverable materials not classified in primary commodity categories (e.g., cartons, electronics, textiles, rigid plastics). Tracked to identify emerging commodity recovery opportunities and support diversion rate accuracy.' ;
    rdfs:domain ind:MaterialComposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pctSumCheck rdf:type rdf:Property ;
    rdfs:label 'Pct Sum Check' ;
    rdfs:comment 'Sum of all material category percentages (fiber + plastics + metals + glass + organics + other recyclables + contamination + residue). Should equal 100.00% for a valid analysis. Used for data quality validation and QC review. Values deviating from 100.00 flag data entry errors.' ;
    rdfs:domain ind:MaterialComposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:petPct rdf:type rdf:Property ;
    rdfs:label 'Pet Pct' ;
    rdfs:comment 'Percentage by weight of PET (Polyethylene Terephthalate, Resin Code #1) plastics in the analyzed sample. PET includes beverage bottles and food containers. High-value plastic commodity tracked for recovery rate and EPA recycling reporting.' ;
    rdfs:domain ind:MaterialComposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qcNotes rdf:type rdf:Property ;
    rdfs:label 'Qc Notes' ;
    rdfs:comment 'Free-text notes entered by the QC reviewer during the review process. Documents reasons for rejection, data corrections made, or observations about sample representativeness. Supports audit trail and continuous improvement.' ;
    rdfs:domain ind:MaterialComposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qcReviewTimestamp rdf:type rdf:Property ;
    rdfs:label 'Qc Review Timestamp' ;
    rdfs:comment 'Date and time when the QC supervisor completed review of this composition analysis record. Null until QC review is performed. Supports audit trail for EPA reporting and ISO 14001 compliance.' ;
    rdfs:domain ind:MaterialComposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:residuePct rdf:type rdf:Property ;
    rdfs:label 'Residue Pct' ;
    rdfs:comment 'Percentage by weight of material directed to residue (landfill disposal) after MRF processing. Distinct from contamination percentage — residue includes unrecoverable fines, broken glass, and process losses. Used to calculate net diversion rate and landfill disposal costs.' ;
    rdfs:domain ind:MaterialComposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sampleSourceType rdf:type rdf:Property ;
    rdfs:label 'Sample Source Type' ;
    rdfs:comment 'Identifies the point in the MRF processing stream from which the sample was collected. Inbound load samples represent pre-processing material; sort line feed samples are taken mid-process; post-sort residue samples assess recovery efficiency; bale samples validate outbound commodity quality.' ;
    rdfs:domain ind:MaterialComposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:steelPct rdf:type rdf:Property ;
    rdfs:label 'Steel Pct' ;
    rdfs:comment 'Percentage by weight of ferrous steel (tin cans, steel containers) in the analyzed sample. Steel is recovered via magnetic separation. Tracked for commodity recovery reporting and SAP MM inventory.' ;
    rdfs:domain ind:MaterialComposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalFiberPct rdf:type rdf:Property ;
    rdfs:label 'Total Fiber Pct' ;
    rdfs:comment 'Aggregate percentage by weight of all fiber materials (OCC + mixed paper + newspaper) in the analyzed sample. Derived field stored for operational convenience and EPA reporting. Supports fiber commodity recovery trending and sort line performance benchmarking.' ;
    rdfs:domain ind:MaterialComposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalGlassPct rdf:type rdf:Property ;
    rdfs:label 'Total Glass Pct' ;
    rdfs:comment 'Aggregate percentage by weight of all glass materials (clear + colored) in the analyzed sample. Stored for operational reporting and EPA recycling program compliance. Supports glass recovery trending.' ;
    rdfs:domain ind:MaterialComposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalMetalsPct rdf:type rdf:Property ;
    rdfs:label 'Total Metals Pct' ;
    rdfs:comment 'Aggregate percentage by weight of all metal materials (aluminum + steel) in the analyzed sample. Stored for operational reporting and EPA recycling program compliance. Supports metals recovery trending and commodity revenue forecasting.' ;
    rdfs:domain ind:MaterialComposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPlasticsPct rdf:type rdf:Property ;
    rdfs:label 'Total Plastics Pct' ;
    rdfs:comment 'Aggregate percentage by weight of all plastic materials (PET + HDPE + mixed plastics) in the analyzed sample. Stored for operational reporting and EPA recycling program compliance. Supports plastics recovery trending.' ;
    rdfs:domain ind:MaterialComposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:equipmentPermitId rdf:type rdf:Property ;
    rdfs:label 'Equipment Permit Id' ;
    rdfs:comment 'Foreign key linking to compliance.permit. Business justification: Equipment like balers, optical sorters, and shredders operate under equipment-specific air quality permits governing particulate emissions and noise levels. Critical for tracking permit conditions dur' ;
    rdfs:domain ind:MrfEquipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Permit .

ind:lastWorkOrderId rdf:type rdf:Property ;
    rdfs:label 'Last Work Order Id' ;
    rdfs:comment 'Foreign key linking to maintenance.work_order. Business justification: Tracks most recent maintenance work order for MRF equipment. Essential for equipment history tracking, MTTR analysis, and maintenance cost allocation. Operations teams need quick access to last servic' ;
    rdfs:domain ind:MrfEquipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkOrder .

ind:oemVendorId rdf:type rdf:Property ;
    rdfs:label 'Oem Vendor Id' ;
    rdfs:comment 'Foreign key linking to procurement.vendor. Business justification: Equipment OEM vendors supply parts and service. Links equipment to vendor master for warranty management, OEM parts sourcing, and service contract administration - eliminates denormalized manufacturer' ;
    rdfs:domain ind:MrfEquipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:sparePartsMaterialId rdf:type rdf:Property ;
    rdfs:label 'Spare Parts Material Id' ;
    rdfs:comment 'Foreign key linking to procurement.material. Business justification: Equipment spare parts are materials in procurement/inventory systems. Links equipment to standard spare parts material master for maintenance planning, inventory management, and equipment lifecycle co' ;
    rdfs:domain ind:MrfEquipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Material .

ind:designThroughputCapacityTph rdf:type rdf:Property ;
    rdfs:label 'Design Throughput Capacity Tph' ;
    rdfs:comment 'Manufacturer-rated processing capacity of the equipment measured in tons per hour. Used for capacity planning, bottleneck analysis, and performance benchmarking.' ;
    rdfs:domain ind:MrfEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:equipmentName rdf:type rdf:Property ;
    rdfs:label 'Equipment Name' ;
    rdfs:comment 'Human-readable name or designation of the MRF equipment asset for operational identification and reporting.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentTag rdf:type rdf:Property ;
    rdfs:label 'Equipment Tag' ;
    rdfs:comment 'Externally-known unique asset tag or equipment number assigned to this MRF processing equipment. Used for physical identification, maintenance tracking, and cross-system reference.' ;
    rdfs:domain ind:MrfEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:floorSpaceSqft rdf:type rdf:Property ;
    rdfs:label 'Floor Space Sqft' ;
    rdfs:comment 'Physical footprint of the equipment in square feet. Used for facility layout planning and space utilization analysis.' ;
    rdfs:domain ind:MrfEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inforEamAssetCode rdf:type rdf:Property ;
    rdfs:label 'Infor Eam Asset Code' ;
    rdfs:comment 'Cross-reference identifier to the corresponding asset record in the Infor EAM system. Enables integration for maintenance work orders, parts inventory, and asset lifecycle management.' ;
    rdfs:domain ind:MrfEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastPmDate rdf:type rdf:Property ;
    rdfs:label 'Last Pm Date' ;
    rdfs:comment 'Date when the most recent preventive maintenance service was completed on this equipment. Used for maintenance compliance tracking and scheduling.' ;
    rdfs:domain ind:MrfEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lockoutTagoutRequired rdf:type rdf:Property ;
    rdfs:label 'Lockout Tagout Required' ;
    rdfs:comment 'Indicates whether this equipment requires lockout/tagout procedures during maintenance or service per OSHA regulations. Critical for worker safety compliance.' ;
    rdfs:domain ind:MrfEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:meanTimeToRepairHours rdf:type rdf:Property ;
    rdfs:label 'Mean Time To Repair Hours' ;
    rdfs:comment 'Average time required to repair the equipment when a failure occurs, measured in hours. Used for downtime planning and maintenance resource allocation.' ;
    rdfs:domain ind:MrfEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:noiseLevelDb rdf:type rdf:Property ;
    rdfs:label 'Noise Level Db' ;
    rdfs:comment 'Operational noise level produced by the equipment measured in decibels. Used for OSHA hearing protection compliance and facility noise management.' ;
    rdfs:domain ind:Recycling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatingHoursMeter rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Meter' ;
    rdfs:comment 'Cumulative operating hours recorded for this equipment since installation or last meter reset. Used for usage-based maintenance scheduling and lifecycle tracking.' ;
    rdfs:domain ind:MrfEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:powerRatingKw rdf:type rdf:Property ;
    rdfs:label 'Power Rating Kw' ;
    rdfs:comment 'Electrical power consumption rating of the equipment in kilowatts. Used for energy cost analysis, electrical capacity planning, and sustainability reporting.' ;
    rdfs:domain ind:MrfEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyCertification rdf:type rdf:Property ;
    rdfs:label 'Safety Certification' ;
    rdfs:comment 'Safety certifications or compliance standards met by the equipment (e.g., UL, CE, OSHA). Used for regulatory compliance and workplace safety verification.' ;
    rdfs:domain ind:MrfEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:voltageRequirement rdf:type rdf:Property ;
    rdfs:label 'Voltage Requirement' ;
    rdfs:comment 'Electrical voltage specification required for equipment operation (e.g., 480V 3-phase). Used for electrical infrastructure planning and safety compliance.' ;
    rdfs:domain ind:MrfEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryVendorId rdf:type rdf:Property ;
    rdfs:label 'Primary Vendor Id' ;
    rdfs:comment 'Foreign key linking to procurement.vendor. Business justification: MRF facilities procure maintenance services, supplies, and equipment parts from vendors. Tracking primary vendor per facility enables vendor performance management, procurement routing, and service co' ;
    rdfs:domain ind:MrfFacility ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:acceptsCdWaste rdf:type rdf:Property ;
    rdfs:label 'Accepts Cd Waste' ;
    rdfs:comment 'Indicates whether the MRF facility is permitted and equipped to process Construction and Demolition (C&D) waste streams including concrete, wood, drywall, and metals. C&D processing requires specialized equipment and separate permit conditions.' ;
    rdfs:domain ind:MrfFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:acceptsCommercial rdf:type rdf:Property ;
    rdfs:label 'Accepts Commercial' ;
    rdfs:comment 'Indicates whether the MRF facility is permitted and equipped to accept commercial and industrial recyclable materials. Drives commercial hauling route assignments in AMCS and contract eligibility in Salesforce CRM.' ;
    rdfs:domain ind:MrfFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:acceptsResidential rdf:type rdf:Property ;
    rdfs:label 'Accepts Residential' ;
    rdfs:comment 'Indicates whether the MRF facility is permitted and equipped to accept residential curbside recyclable materials. Drives routing logic in AMCS and service enrollment eligibility in Waste Logics.' ;
    rdfs:domain ind:MrfFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:balingLineCount rdf:type rdf:Property ;
    rdfs:label 'Baling Line Count' ;
    rdfs:comment 'Number of baling lines (balers) at the MRF facility used to compress and bind recovered commodities (paper, plastics, metals) into marketable bales. Determines bale production capacity and influences commodity sales throughput.' ;
    rdfs:domain ind:MrfFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:commissionedDate rdf:type rdf:Property ;
    rdfs:label 'Commissioned Date' ;
    rdfs:comment 'Date on which the MRF facility was officially commissioned and began commercial operations. Used for asset age calculations, depreciation schedules, permit anniversary tracking, and capital planning.' ;
    rdfs:domain ind:MrfFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maxContaminationRatePct rdf:type rdf:Property ;
    rdfs:label 'Max Contamination Rate Pct' ;
    rdfs:comment 'Maximum allowable contamination rate percentage for outbound commodity bales as specified in commodity offtake contracts and quality standards. Exceeding this threshold may result in load rejection, price penalties, or contract violations. Used in quality control and commodity sales management.' ;
    rdfs:domain ind:Recycling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatingDays rdf:type rdf:Property ;
    rdfs:label 'Operating Days' ;
    rdfs:comment 'Comma-separated list of days of the week the MRF facility operates (e.g., \'MON,TUE,WED,THU,FRI,SAT\'). Used for route scheduling in AMCS, customer service availability, and workforce planning in Workday HCM.' ;
    rdfs:domain ind:MrfFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingHoursEnd rdf:type rdf:Property ;
    rdfs:label 'Operating Hours End' ;
    rdfs:comment 'Standard daily end time for MRF facility operations in HH:MM (24-hour) format. Used for inbound vehicle scheduling, tipping fee window management in Oracle Revenue Management, and AMCS route dispatch timing.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingHoursStart rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Start' ;
    rdfs:comment 'Standard daily start time for MRF facility operations in HH:MM (24-hour) format. Used for inbound vehicle scheduling, tipping fee window management in Oracle Revenue Management, and AMCS route dispatch timing.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opticalSorterCount rdf:type rdf:Property ;
    rdfs:label 'Optical Sorter Count' ;
    rdfs:comment 'Number of optical sorting units (near-infrared or AI-vision sorters) installed at the facility for automated material identification and separation. Indicates automation level, influences contamination rates, and is tracked in Infor EAM for maintenance scheduling.' ;
    rdfs:domain ind:Recycling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sortLineCount rdf:type rdf:Property ;
    rdfs:label 'Sort Line Count' ;
    rdfs:comment 'Number of active sorting lines (conveyor-based manual or automated sort systems) at the MRF facility. Directly determines sorting throughput capacity and staffing requirements. Used in capacity planning and equipment maintenance scheduling in Infor EAM.' ;
    rdfs:domain ind:MrfFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetDiversionRatePct rdf:type rdf:Property ;
    rdfs:label 'Target Diversion Rate Pct' ;
    rdfs:comment 'Facility-level target percentage of inbound material weight that is successfully recovered and diverted from landfill disposal. Expressed as a percentage (0-100). Used as a KPI benchmark for operational performance, EPA recycling reporting, and sustainability goal tracking.' ;
    rdfs:domain ind:MrfFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalFloorAreaSqft rdf:type rdf:Property ;
    rdfs:label 'Total Floor Area Sqft' ;
    rdfs:comment 'Total enclosed floor area of the MRF facility building in square feet, including tipping floor, sort lines, baling area, storage, and office space. Used for property tax assessments, lease calculations, and facility planning.' ;
    rdfs:domain ind:MrfFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outboundShipmentId rdf:type rdf:Property ;
    rdfs:label 'Outbound Shipment Id' ;
    rdfs:comment 'Unique identifier for the outbound commodity shipment from MRF facility to buyer.' ;
    rdfs:domain ind:OutboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualArrivalDate rdf:type rdf:Property ;
    rdfs:label 'Actual Arrival Date' ;
    rdfs:comment 'Actual date when the shipment was received and confirmed at the buyer destination facility.' ;
    rdfs:domain ind:OutboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:carrierScacCode rdf:type rdf:Property ;
    rdfs:label 'Carrier Scac Code' ;
    rdfs:comment 'Four-letter unique identifier assigned by the National Motor Freight Traffic Association to identify the carrier.' ;
    rdfs:domain ind:OutboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryConfirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Delivery Confirmation Number' ;
    rdfs:comment 'Unique confirmation number issued by the buyer upon successful receipt and acceptance of the shipment.' ;
    rdfs:domain ind:OutboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryNotes rdf:type rdf:Property ;
    rdfs:label 'Delivery Notes' ;
    rdfs:comment 'Free-text notes documenting delivery conditions, exceptions, damages, or special instructions recorded at delivery.' ;
    rdfs:domain ind:OutboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationCountry rdf:type rdf:Property ;
    rdfs:label 'Destination Country' ;
    rdfs:comment 'Three-letter ISO country code of the buyer destination facility.' ;
    rdfs:domain ind:OutboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedArrivalDate rdf:type rdf:Property ;
    rdfs:label 'Estimated Arrival Date' ;
    rdfs:comment 'Projected date when the shipment is expected to arrive at the buyer destination.' ;
    rdfs:domain ind:OutboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:freightChargesUsd rdf:type rdf:Property ;
    rdfs:label 'Freight Charges Usd' ;
    rdfs:comment 'Total freight transportation charges for this shipment in US dollars.' ;
    rdfs:domain ind:OutboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceValueUsd rdf:type rdf:Property ;
    rdfs:label 'Insurance Value Usd' ;
    rdfs:comment 'Declared insurance value of the commodity shipment in US dollars for liability coverage.' ;
    rdfs:domain ind:OutboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalBalesShipped rdf:type rdf:Property ;
    rdfs:label 'Total Bales Shipped' ;
    rdfs:comment 'Total count of commodity bales loaded onto this shipment.' ;
    rdfs:domain ind:OutboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:acceptedMaterialsList rdf:type rdf:Property ;
    rdfs:label 'Accepted Materials List' ;
    rdfs:comment 'Comma-delimited list of material categories accepted under this recycling program (e.g., \'OCC,ONP,PET,HDPE,aluminum_cans,steel_cans,glass\'). Drives contamination assessment, MRF sort line configuration, and public education materials. Sourced from Waste Logics container management.' ;
    rdfs:domain ind:RecyclingProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amcsProgramReference rdf:type rdf:Property ;
    rdfs:label 'Amcs Program Reference' ;
    rdfs:comment 'External reference identifier for this recycling program as registered in the AMCS Platform for route optimization and fleet dispatching. Enables end-to-end traceability from collection route to MRF processing.' ;
    rdfs:domain ind:RecyclingProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualTonnageCommitment rdf:type rdf:Property ;
    rdfs:label 'Annual Tonnage Commitment' ;
    rdfs:comment 'Contractually committed annual volume of recyclable material (in short tons) to be collected and processed under this program. Used for MRF capacity planning, commodity revenue forecasting, and contract compliance monitoring.' ;
    rdfs:domain ind:RecyclingProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:co2eDiversionFactor rdf:type rdf:Property ;
    rdfs:label 'Co2e Diversion Factor' ;
    rdfs:comment 'EPA-approved CO2e emission reduction factor (metric tons CO2e per short ton of material diverted) applied to this program for GHG reporting and sustainability disclosures. Varies by material stream type.' ;
    rdfs:domain ind:RecyclingProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:epaProgramCode rdf:type rdf:Property ;
    rdfs:label 'Epa Program Code' ;
    rdfs:comment 'U.S. Environmental Protection Agency assigned identifier for this recycling program, used in federal recycling rate reporting, RCRA compliance submissions, and Solid Waste Information System (SWIS) filings.' ;
    rdfs:domain ind:RecyclingProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iso14001Applicable rdf:type rdf:Property ;
    rdfs:label 'Iso 14001 Applicable' ;
    rdfs:comment 'Indicates whether this recycling program is subject to ISO 14001 Environmental Management System requirements. True for programs operating under ISO 14001 certified facilities. Drives environmental audit scope in Enviance EHS.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leaJurisdictionCode rdf:type rdf:Property ;
    rdfs:label 'Lea Jurisdiction Code' ;
    rdfs:comment 'Code identifying the Local Enforcement Agency (LEA) jurisdiction governing this recycling program. Used for regulatory compliance tracking in Enviance EHS and local solid waste authority reporting.' ;
    rdfs:domain ind:RecyclingProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingPriority rdf:type rdf:Property ;
    rdfs:label 'Processing Priority' ;
    rdfs:comment 'Priority level assigned to inbound loads from this program for MRF sort line scheduling. High priority programs (e.g., municipal contracts with SLA penalties) are processed before standard or low priority commercial loads.' ;
    rdfs:domain ind:RecyclingProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicEducationRequired rdf:type rdf:Property ;
    rdfs:label 'Public Education Required' ;
    rdfs:comment 'Indicates whether the program contract or municipal agreement requires Waste Management to provide public education and outreach materials (e.g., accepted materials guides, contamination reduction campaigns). Drives marketing and communications obligations.' ;
    rdfs:domain ind:RecyclingProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revenueSharePct rdf:type rdf:Property ;
    rdfs:label 'Revenue Share Pct' ;
    rdfs:comment 'Percentage of net commodity sales revenue shared back with the sponsoring municipality or customer account under this program. Expressed as a percentage (0.00–100.00). Null if no revenue-share arrangement exists. Tracked in Oracle Revenue Management.' ;
    rdfs:domain ind:Recycling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceAreaDescription rdf:type rdf:Property ;
    rdfs:label 'Service Area Description' ;
    rdfs:comment 'Textual description of the geographic boundary served by this recycling program (e.g., municipality name, zip code range, district name, or county). Supports service area reporting and route planning in AMCS.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceAreaStateCode rdf:type rdf:Property ;
    rdfs:label 'Service Area State Code' ;
    rdfs:comment 'Two-letter US state code for the primary state in which the recycling program operates. Used for state environmental agency reporting, permit alignment, and regulatory compliance tracking.' ;
    rdfs:domain ind:RecyclingProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalDestinationType rdf:type rdf:Property ;
    rdfs:label 'Disposal Destination Type' ;
    rdfs:comment 'Type of facility receiving the residue material for final disposal or treatment.' ;
    rdfs:domain ind:ResidueDisposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Disposal Timestamp' ;
    rdfs:comment 'Precise date and time when the residue disposal transaction was completed at the receiving facility.' ;
    rdfs:domain ind:ResidueDisposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:haulingCost rdf:type rdf:Property ;
    rdfs:label 'Hauling Cost' ;
    rdfs:comment 'Transportation cost for hauling the residue from MRF to disposal destination.' ;
    rdfs:domain ind:ResidueDisposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:residueCompositionNotes rdf:type rdf:Property ;
    rdfs:label 'Residue Composition Notes' ;
    rdfs:comment 'Free-text description of residue material composition, contamination types, and any notable characteristics observed during disposal.' ;
    rdfs:domain ind:ResidueDisposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residueWeightTons rdf:type rdf:Property ;
    rdfs:label 'Residue Weight Tons' ;
    rdfs:comment 'Total weight of residue material disposed, measured in tons. Used for diversion rate calculation and cost allocation.' ;
    rdfs:domain ind:ResidueDisposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDisposalCost rdf:type rdf:Property ;
    rdfs:label 'Total Disposal Cost' ;
    rdfs:comment 'Total cost incurred for this residue disposal transaction, including tipping fees, hauling, and any surcharges.' ;
    rdfs:domain ind:ResidueDisposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineSupervisorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Line Supervisor Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Sort lines require shift supervisors for real-time operational control, safety compliance, quality assurance, and throughput management. Supervisor assignment is essential for OSHA compliance, contami' ;
    rdfs:domain ind:SortLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:amcsLineReference rdf:type rdf:Property ;
    rdfs:label 'Amcs Line Reference' ;
    rdfs:comment 'Identifier used to reference this sort line within the AMCS Platform for recycling route management and material flow tracking integration. Enables cross-system reconciliation between MRF operations and collection route data.' ;
    rdfs:domain ind:SortLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:balerCount rdf:type rdf:Property ;
    rdfs:label 'Baler Count' ;
    rdfs:comment 'Number of baling machines installed on or directly serving this sort line. Balers compress recovered commodities into bales for outbound commodity sales. Affects throughput capacity and commodity output rates.' ;
    rdfs:domain ind:SortLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:conveyorLengthM rdf:type rdf:Property ;
    rdfs:label 'Conveyor Length M' ;
    rdfs:comment 'Total length of the primary sort conveyor belt in meters. Used for maintenance planning (belt replacement scheduling), throughput modeling, and facility layout documentation.' ;
    rdfs:domain ind:SortLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conveyorSpeedMpm rdf:type rdf:Property ;
    rdfs:label 'Conveyor Speed Mpm' ;
    rdfs:comment 'Rated operating speed of the sort line conveyor belt in meters per minute (MPM). Directly affects sort quality and throughput rate; used in process optimization and OSHA ergonomic compliance for sorter workload assessment.' ;
    rdfs:domain ind:SortLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:designRecoveryRatePct rdf:type rdf:Property ;
    rdfs:label 'Design Recovery Rate Pct' ;
    rdfs:comment 'Engineered target material recovery rate expressed as a percentage of inbound material weight that is successfully recovered as saleable commodity. Used as the baseline for diversion rate reporting and performance benchmarking against EPA recycling goals.' ;
    rdfs:domain ind:SortLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:designThroughputTph rdf:type rdf:Property ;
    rdfs:label 'Design Throughput Tph' ;
    rdfs:comment 'Engineered design capacity of the sort line expressed in tons per hour (TPH). Represents the maximum rated processing rate under optimal conditions as specified by the equipment manufacturer or system integrator. Used for capacity planning and performance benchmarking.' ;
    rdfs:domain ind:SortLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dustSuppressionSystem rdf:type rdf:Property ;
    rdfs:label 'Dust Suppression System' ;
    rdfs:comment 'Indicates whether a dust suppression or dust collection system is installed on this sort line. Required for air quality compliance under the Clean Air Act and OSHA particulate matter exposure limits, particularly on glass and shredder lines.' ;
    rdfs:domain ind:SortLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eddyCurrentSeparatorCount rdf:type rdf:Property ;
    rdfs:label 'Eddy Current Separator Count' ;
    rdfs:comment 'Number of eddy current separator units installed on this sort line. Eddy current separators use magnetic induction to eject non-ferrous metals (aluminum, copper) from the material stream. Critical for aluminum recovery rates.' ;
    rdfs:domain ind:SortLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:equipmentCount rdf:type rdf:Property ;
    rdfs:label 'Equipment Count' ;
    rdfs:comment 'Total number of individual equipment assets installed on this sort line (e.g., balers, optical sorters, conveyors, eddy current separators, magnetic separators, shredders, glass breakers). Used for maintenance planning and asset inventory management.' ;
    rdfs:domain ind:SortLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:floorAreaSqm rdf:type rdf:Property ;
    rdfs:label 'Floor Area Sqm' ;
    rdfs:comment 'Total floor area occupied by the sort line and its associated equipment in square meters. Used for facility layout planning, fire safety compliance, and OSHA egress requirement calculations.' ;
    rdfs:domain ind:SortLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:glassBreakerCount rdf:type rdf:Property ;
    rdfs:label 'Glass Breaker Count' ;
    rdfs:comment 'Number of glass breaking/crushing units installed on this sort line. Glass breakers reduce glass to cullet for downstream processing or disposal. Relevant for container sort lines processing single-stream material.' ;
    rdfs:domain ind:SortLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:magneticSeparatorCount rdf:type rdf:Property ;
    rdfs:label 'Magnetic Separator Count' ;
    rdfs:comment 'Number of magnetic separator (overhead magnet or drum magnet) units installed on this sort line for ferrous metal recovery. Ferrous metal recovery rate is directly dependent on magnetic separator performance.' ;
    rdfs:domain ind:SortLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operatingShiftCount rdf:type rdf:Property ;
    rdfs:label 'Operating Shift Count' ;
    rdfs:comment 'Number of production shifts per day this sort line is designed to operate (typically 1, 2, or 3 shifts). Used for daily throughput capacity calculations, workforce scheduling, and operational cost modeling.' ;
    rdfs:domain ind:SortLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:powerConsumptionKw rdf:type rdf:Property ;
    rdfs:label 'Power Consumption Kw' ;
    rdfs:comment 'Rated electrical power consumption of the sort line in kilowatts (KW) at full operating capacity. Used for energy cost modeling, utility budgeting, and greenhouse gas (GHG) emissions reporting under EPA and ISO 14001 requirements.' ;
    rdfs:domain ind:SortLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:residueRateTargetPct rdf:type rdf:Property ;
    rdfs:label 'Residue Rate Target Pct' ;
    rdfs:comment 'Target percentage of inbound material that is expected to be classified as residue (non-recoverable waste sent to landfill disposal). Lower residue rates indicate higher diversion performance. Used in EPA diversion rate reporting and sustainability KPI tracking.' ;
    rdfs:domain ind:SortLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rfidEnabled rdf:type rdf:Property ;
    rdfs:label 'Rfid Enabled' ;
    rdfs:comment 'Indicates whether RFID (Radio Frequency Identification) technology is installed on this sort line for automated container or material tracking. Supports integration with AMCS Platform for container management and material flow tracking.' ;
    rdfs:domain ind:SortLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sapFunctionalLocation rdf:type rdf:Property ;
    rdfs:label 'Sap Functional Location' ;
    rdfs:comment 'SAP S/4HANA Plant Maintenance (PM) functional location code assigned to this sort line. Used to link maintenance work orders, preventive maintenance plans, and cost center allocations in SAP PM and FI/CO modules.' ;
    rdfs:domain ind:SortLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screenCount rdf:type rdf:Property ;
    rdfs:label 'Screen Count' ;
    rdfs:comment 'Number of disc screen or trommel screen units installed on this sort line for size-based material separation. Screens separate 2D materials (paper, film) from 3D materials (containers, cans) and are a primary separation mechanism in MRF operations.' ;
    rdfs:domain ind:SortLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shiftDurationHours rdf:type rdf:Property ;
    rdfs:label 'Shift Duration Hours' ;
    rdfs:comment 'Standard duration of each operating shift in hours for this sort line. Combined with operating_shift_count and design_throughput_tph to derive design_throughput_tpd. Used in workforce planning and production scheduling.' ;
    rdfs:domain ind:SortLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shredderCount rdf:type rdf:Property ;
    rdfs:label 'Shredder Count' ;
    rdfs:comment 'Number of shredding units installed on this sort line for size reduction of incoming material. Shredders improve downstream sorting efficiency and are common on OCC and residue lines.' ;
    rdfs:domain ind:SortLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stationCount rdf:type rdf:Property ;
    rdfs:label 'Station Count' ;
    rdfs:comment 'Total number of manual sort stations installed along the sort line. Determines labor requirements for staffing the line at full capacity and is used in workforce planning and ergonomic compliance assessments.' ;
    rdfs:domain ind:SortLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:consumableMaterialId rdf:type rdf:Property ;
    rdfs:label 'Consumable Material Id' ;
    rdfs:comment 'Foreign key linking to procurement.material. Business justification: Sort sessions consume materials (baling wire, strapping, labels, supplies). Links sessions to material master for production cost allocation, material consumption tracking, and standard costing - core' ;
    rdfs:domain ind:SortSession ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Material .

ind:downtimeWorkOrderId rdf:type rdf:Property ;
    rdfs:label 'Downtime Work Order Id' ;
    rdfs:comment 'Foreign key linking to maintenance.work_order. Business justification: Links sort session downtime events to the maintenance work order that resolved the equipment failure. Critical for downtime root cause analysis, throughput loss calculation, and maintenance response t' ;
    rdfs:domain ind:SortSession ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkOrder .

ind:abortReason rdf:type rdf:Property ;
    rdfs:label 'Abort Reason' ;
    rdfs:comment 'Free-text description of the reason for premature session termination when session_status is \'aborted\'. Captures operational context not covered by downtime_reason_code. Null for completed or active sessions.' ;
    rdfs:domain ind:SortSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baleCount rdf:type rdf:Property ;
    rdfs:label 'Bale Count' ;
    rdfs:comment 'Total number of commodity bales produced during this sort session across all material types. Used for outbound commodity inventory management in SAP MM and baler productivity tracking.' ;
    rdfs:domain ind:SortSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contaminationInputPct rdf:type rdf:Property ;
    rdfs:label 'Contamination Input Pct' ;
    rdfs:comment 'Estimated percentage of the inbound material stream classified as contamination (non-recyclable materials, food waste, hazardous items) at session start. High contamination rates impact commodity quality grades and residue tonnage. Key metric for EPA recycling diversion rate reporting.' ;
    rdfs:domain ind:SortSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:downtimeReasonCode rdf:type rdf:Property ;
    rdfs:label 'Downtime Reason Code' ;
    rdfs:comment 'Standardized reason code categorizing the primary cause of downtime during this sort session. Used for root cause analysis, maintenance scheduling, and operational improvement initiatives. [ENUM-REF-CANDIDATE: equipment_failure|material_jam|safety_stop|scheduled_maintenance|operator_shortage|power_outage|quality_hold|other — promote to reference product]' ;
    rdfs:domain ind:SortSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentFaultFlag rdf:type rdf:Property ;
    rdfs:label 'Equipment Fault Flag' ;
    rdfs:comment 'Indicates whether a mechanical or electrical equipment fault was recorded during this sort session. When True, triggers a Work Order (WO) in Infor EAM for corrective maintenance. Supports equipment reliability and Overall Equipment Effectiveness (OEE) tracking.' ;
    rdfs:domain ind:SortSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:glassInputPct rdf:type rdf:Property ;
    rdfs:label 'Glass Input Pct' ;
    rdfs:comment 'Estimated percentage of the inbound material stream composed of glass commodities at session start. Used for commodity recovery planning and glass processing equipment configuration.' ;
    rdfs:domain ind:SortSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inputTonnage rdf:type rdf:Property ;
    rdfs:label 'Input Tonnage' ;
    rdfs:comment 'Total weight in short tons of inbound material received and processed during this sort session. Core metric for Tons Per Day (TPD) throughput reporting and EPA recycling diversion rate calculations.' ;
    rdfs:domain ind:SortSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:metalInputPct rdf:type rdf:Property ;
    rdfs:label 'Metal Input Pct' ;
    rdfs:comment 'Estimated percentage of the inbound material stream composed of metal commodities (aluminum, steel, ferrous, non-ferrous) at session start. Used for commodity recovery planning and eddy current separator configuration.' ;
    rdfs:domain ind:SortSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatorCount rdf:type rdf:Property ;
    rdfs:label 'Operator Count' ;
    rdfs:comment 'Number of sort station operators assigned and actively working during this sort session. Used for labor productivity analysis (tons per operator per hour) and staffing optimization.' ;
    rdfs:domain ind:SortSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paperInputPct rdf:type rdf:Property ;
    rdfs:label 'Paper Input Pct' ;
    rdfs:comment 'Estimated percentage of the inbound material stream composed of paper and fiber commodities (OCC, ONP, mixed paper) at session start. Used for commodity recovery planning and sort line configuration.' ;
    rdfs:domain ind:SortSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plasticInputPct rdf:type rdf:Property ;
    rdfs:label 'Plastic Input Pct' ;
    rdfs:comment 'Estimated percentage of the inbound material stream composed of plastic commodities (PET, HDPE, mixed plastics) at session start. Used for commodity recovery planning and sort line configuration.' ;
    rdfs:domain ind:SortSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qcSampleCount rdf:type rdf:Property ;
    rdfs:label 'Qc Sample Count' ;
    rdfs:comment 'Number of quality control samples taken during this sort session to assess commodity purity and contamination levels. Supports statistical validity of contamination rate measurements and MRF quality assurance programs.' ;
    rdfs:domain ind:SortSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualityGrade rdf:type rdf:Property ;
    rdfs:label 'Quality Grade' ;
    rdfs:comment 'Overall quality grade assigned to the commodity output of this sort session based on contamination levels and commodity purity. Drives commodity pricing and market acceptance. \'off_spec\' indicates material outside buyer specifications; \'rejected\' indicates material refused by commodity buyer.' ;
    rdfs:domain ind:Recycling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recoveredTonnage rdf:type rdf:Property ;
    rdfs:label 'Recovered Tonnage' ;
    rdfs:comment 'Total weight in short tons of all recovered recyclable commodities (paper, plastics, metals, glass) produced during this sort session. Used for diversion rate calculation and commodity inventory reconciliation in SAP MM.' ;
    rdfs:domain ind:SortSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:residueTonnage rdf:type rdf:Property ;
    rdfs:label 'Residue Tonnage' ;
    rdfs:comment 'Total weight in short tons of non-recoverable residue (contamination and non-recyclable material) sent to landfill disposal after sorting. Used to calculate the diversion rate and residue rate for EPA reporting.' ;
    rdfs:domain ind:SortSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sessionDate rdf:type rdf:Property ;
    rdfs:label 'Session Date' ;
    rdfs:comment 'Calendar date on which the sort session occurred. Used for daily Tons Per Day (TPD) aggregation, EPA recycling reporting, and operational scheduling alignment.' ;
    rdfs:domain ind:SortSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sessionDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Session Duration Minutes' ;
    rdfs:comment 'Total elapsed time in minutes from session start to session end, including both active processing time and downtime periods. Used for labor cost allocation and shift utilization analysis.' ;
    rdfs:domain ind:SortSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sessionNumber rdf:type rdf:Property ;
    rdfs:label 'Session Number' ;
    rdfs:comment 'Externally-known business identifier for the sort session, used in operational reporting, shift logs, and AMCS platform references. Format: SS-YYYY-MM-DD-NNNN.' ;
    rdfs:domain ind:SortSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionStatus rdf:type rdf:Property ;
    rdfs:label 'Session Status' ;
    rdfs:comment 'Current lifecycle state of the sort session. \'active\' indicates the session is in progress; \'completed\' indicates normal closure; \'aborted\' indicates premature termination due to equipment failure, safety event, or operational decision; \'paused\' indicates a temporary halt; \'pending\' indicates scheduled but not yet started.' ;
    rdfs:domain ind:SortSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionType rdf:type rdf:Property ;
    rdfs:label 'Session Type' ;
    rdfs:comment 'Classification of the sort session by operational purpose. \'standard\' is a normal production run; \'trial\' is a test run for new material streams; \'calibration\' is a quality calibration run; \'training\' is a supervised training session for new operators.' ;
    rdfs:domain ind:SortSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sortLineSpeedFpm rdf:type rdf:Property ;
    rdfs:label 'Sort Line Speed Fpm' ;
    rdfs:comment 'Operational belt conveyor speed in feet per minute (FPM) at which the sort line was configured for this session. Affects throughput rate and operator sorting effectiveness. Used for equipment performance analysis.' ;
    rdfs:domain ind:SortSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceSystemSessionRef rdf:type rdf:Property ;
    rdfs:label 'Source System Session Ref' ;
    rdfs:comment 'The native identifier of this sort session record in the originating operational system (e.g., AMCS session ID, SAP production order number). Used for cross-system reconciliation and data lineage tracing in the Silver Layer.' ;
    rdfs:domain ind:SortSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:throughputRateTph rdf:type rdf:Property ;
    rdfs:label 'Throughput Rate Tph' ;
    rdfs:comment 'Processing throughput rate measured in tons per hour (TPH) for this sort session. Calculated as input tonnage divided by active processing time. Key operational KPI for sort line efficiency and capacity planning.' ;
    rdfs:domain ind:SortSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:auditFindingId rdf:type rdf:Property ;
    rdfs:label 'Audit Finding Id' ;
    rdfs:comment 'Unique identifier for the safety audit finding record. Primary key.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:previousFindingAuditFindingId rdf:type rdf:Property ;
    rdfs:label 'Previous Finding Audit Finding Id' ;
    rdfs:comment 'Reference to the previous audit finding that this finding is a recurrence of, if applicable. Null if this is not a recurrence. Enables tracking of repeat findings and effectiveness of corrective actions.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AuditFinding .

ind:actualClosureDate rdf:type rdf:Property ;
    rdfs:label 'Actual Closure Date' ;
    rdfs:comment 'Actual date when the finding was verified as corrected and closed. Null if finding remains open. Used to calculate corrective action cycle time and overdue metrics.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignedTo rdf:type rdf:Property ;
    rdfs:label 'Assigned To' ;
    rdfs:comment 'Name or identifier of the individual or department responsible for implementing corrective action to address the finding. Typically facility manager, operations supervisor, maintenance supervisor, or safety coordinator.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fallProtectionFlag rdf:type rdf:Property ;
    rdfs:label 'Fall Protection Flag' ;
    rdfs:comment 'Boolean indicator whether the finding involves missing or inadequate fall protection (guardrails, safety nets, personal fall arrest systems) for work at heights greater than 4 feet. True if fall protection violation is present; false otherwise. Leading cause of construction and landfill fatalities.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:findingCategory rdf:type rdf:Property ;
    rdfs:label 'Finding Category' ;
    rdfs:comment 'Classification of the type of safety deficiency identified. Unsafe act refers to employee behavior violations; unsafe condition refers to physical hazards; program gap refers to missing or inadequate safety management system elements; regulatory non-conformance refers to violations of OSHA, EPA, DOT, or RCRA requirements; documentation deficiency refers to missing or incomplete safety records; training deficiency refers to inadequate or missing employee safety training.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingDescription rdf:type rdf:Property ;
    rdfs:label 'Finding Description' ;
    rdfs:comment 'Detailed narrative description of the safety deficiency or non-conformance observed during the audit. Includes specific location, equipment involved, personnel observed, and conditions present at the time of observation. Should be sufficiently detailed to support corrective action planning and regulatory reporting if required.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingStatus rdf:type rdf:Property ;
    rdfs:label 'Finding Status' ;
    rdfs:comment 'Current lifecycle status of the finding. Open indicates newly identified finding awaiting assignment; assigned indicates corrective action has been assigned to responsible party; in progress indicates corrective action is underway; pending verification indicates corrective action completed and awaiting audit verification; closed indicates finding has been verified as corrected and closed; overdue indicates corrective action has exceeded target completion date.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identifiedBy rdf:type rdf:Property ;
    rdfs:label 'Identified By' ;
    rdfs:comment 'Name or identifier of the auditor, safety professional, or inspector who identified the finding. May be internal safety staff, third-party auditor, or regulatory inspector.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identifiedDate rdf:type rdf:Property ;
    rdfs:label 'Identified Date' ;
    rdfs:comment 'Date when the safety finding was identified during the audit or inspection. Used for aging analysis and corrective action timeline tracking.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lockoutTagoutFlag rdf:type rdf:Property ;
    rdfs:label 'Lockout Tagout Flag' ;
    rdfs:comment 'Boolean indicator whether the finding involves failure to follow lockout/tagout procedures for equipment servicing or maintenance. True if LOTO violation is present; false otherwise. Critical for preventing equipment-related injuries and fatalities.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:machineGuardingFlag rdf:type rdf:Property ;
    rdfs:label 'Machine Guarding Flag' ;
    rdfs:comment 'Boolean indicator whether the finding involves missing or inadequate machine guarding on conveyors, balers, compactors, shredders, or other powered equipment with moving parts. True if machine guarding violation is present; false otherwise.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operationArea rdf:type rdf:Property ;
    rdfs:label 'Operation Area' ;
    rdfs:comment 'Specific operational area, zone, or work location within the facility or operation where the finding was identified (e.g., \'Tipping Floor\', \'MRF Sorting Line 2\', \'Landfill Cell 5\', \'Fleet Maintenance Bay 3\', \'Hazmat Storage Building A\'). Enables spatial analysis of safety deficiencies and targeted corrective actions.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ppeDeficiencyFlag rdf:type rdf:Property ;
    rdfs:label 'Ppe Deficiency Flag' ;
    rdfs:comment 'Boolean indicator whether the finding involves missing, inadequate, or improperly used personal protective equipment (hard hat, safety glasses, gloves, respirator, high-visibility vest, steel-toe boots, hearing protection). True if PPE deficiency is present; false otherwise.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetClosureDate rdf:type rdf:Property ;
    rdfs:label 'Target Closure Date' ;
    rdfs:comment 'Target date by which the finding must be corrected and closed. Determined based on severity level and regulatory requirements. Critical findings typically require immediate or same-day closure; major findings within 7-30 days; minor findings within 90 days.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:affectedOfferingId rdf:type rdf:Property ;
    rdfs:label 'Affected Offering Id' ;
    rdfs:comment 'Foreign key linking to service.offering. Business justification: Corrective actions may require service offering modifications (adding PPE requirements, changing collection procedures, restricting service hours). Safety and operations teams coordinate on offering-l' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Offering .

ind:primaryCorrectiveEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Corrective Employee Id' ;
    rdfs:comment 'Foreign key reference to the employee or contractor assigned as the owner responsible for implementing and completing this corrective action.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryCorrectiveLastModifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Corrective Last Modified By Employee Id' ;
    rdfs:comment 'Foreign key reference to the employee who last modified the corrective action record. Provides audit trail for changes to action status, completion, or verification.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quinaryCorrectiveResponsiblePartyEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quinary Corrective Responsible Party Employee Id' ;
    rdfs:comment 'FK to workforce.employee' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryCorrectiveCreatedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Corrective Created By Employee Id' ;
    rdfs:comment 'Foreign key reference to the employee who created the corrective action record. Typically a safety manager, supervisor, or incident investigator.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actionCategory rdf:type rdf:Property ;
    rdfs:label 'Action Category' ;
    rdfs:comment 'Classification of the corrective action based on the hierarchy of controls. Categories include engineering control (physical changes to eliminate hazard), administrative control (policy/procedure changes), PPE (personal protective equipment), training, procedure update, or equipment repair.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionPriority rdf:type rdf:Property ;
    rdfs:label 'Action Priority' ;
    rdfs:comment 'Priority level assigned to the corrective action based on risk severity and potential for recurrence. Critical actions address imminent hazards, high priority addresses serious risks, medium for moderate risks, and low for minor improvements.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivenessRating rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Rating' ;
    rdfs:comment 'Assessment of how effective the corrective action was in preventing recurrence and improving safety. Populated during effectiveness review after sufficient time has elapsed post-implementation.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivenessReviewDate rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Review Date' ;
    rdfs:comment 'Scheduled date for follow-up review to assess long-term effectiveness of the corrective action. Typically 30, 60, or 90 days after closure to ensure sustained improvement.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preventiveActionFlag rdf:type rdf:Property ;
    rdfs:label 'Preventive Action Flag' ;
    rdfs:comment 'Boolean flag indicating whether this action is preventive (true) or corrective (false). Preventive actions address potential hazards before incidents occur, corrective actions address issues after an event.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recurrencePreventionMeasures rdf:type rdf:Property ;
    rdfs:label 'Recurrence Prevention Measures' ;
    rdfs:comment 'Detailed description of measures implemented to prevent recurrence of the safety issue across similar operations, facilities, or equipment. Captures systemic improvements beyond the immediate corrective action.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Requirement Flag' ;
    rdfs:comment 'Boolean flag indicating whether this corrective action is required by OSHA, EPA, DOT, or other regulatory authority. True indicates regulatory mandate, false indicates voluntary safety improvement.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceEventReference rdf:type rdf:Property ;
    rdfs:label 'Source Event Reference' ;
    rdfs:comment 'Business reference number of the originating event (e.g., incident number, observation ID, audit finding number). Provides human-readable traceability to the source event.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceEventType rdf:type rdf:Property ;
    rdfs:label 'Source Event Type' ;
    rdfs:comment 'Type of safety event that triggered this corrective action. Distinguishes whether the action originated from an incident investigation, safety observation, audit finding, regulatory inspection, near miss, or hazard report.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationNotes rdf:type rdf:Property ;
    rdfs:label 'Verification Notes' ;
    rdfs:comment 'Detailed notes documenting the verification process, findings, and confirmation that the corrective action achieved the intended safety improvement.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Emergency Employee Id' ;
    rdfs:comment 'FK to workforce.employee' ;
    rdfs:domain ind:EmergencyActionPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryEmergencyCoordinatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Emergency Coordinator Employee Id' ;
    rdfs:comment 'FK to workforce.employee' ;
    rdfs:domain ind:EmergencyActionPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryEmergencyApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Emergency Approved By Employee Id' ;
    rdfs:comment 'Reference to the employee (typically facility manager, safety manager, or regional operations director) who formally approved this Emergency Action Plan version for implementation.' ;
    rdfs:domain ind:EmergencyActionPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryEmergencyAlternateCoordinatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Emergency Alternate Coordinator Employee Id' ;
    rdfs:comment 'Reference to the employee designated as the alternate or backup Emergency Coordinator who assumes responsibility when the primary coordinator is unavailable.' ;
    rdfs:domain ind:EmergencyActionPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:alarmSystemDescription rdf:type rdf:Property ;
    rdfs:label 'Alarm System Description' ;
    rdfs:comment 'Description of the alarm or notification system used to alert employees of an emergency, including type (audible horn, siren, PA system, text alert), location of alarm devices, and distinctive signals for different emergency types.' ;
    rdfs:domain ind:EmergencyActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalOperationsShutdown rdf:type rdf:Property ;
    rdfs:label 'Critical Operations Shutdown' ;
    rdfs:comment 'Procedures for shutting down critical plant operations and equipment before evacuation to prevent additional hazards, such as securing landfill gas collection systems, shutting down MRF conveyors, isolating hazmat storage, or securing waste-to-energy boilers.' ;
    rdfs:domain ind:EmergencyActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drillFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Drill Frequency Months' ;
    rdfs:comment 'Required frequency for conducting emergency drills at this facility, expressed in months (e.g., 12 for annual, 6 for semi-annual, 3 for quarterly). Driven by regulatory requirements and facility risk profile.' ;
    rdfs:domain ind:EmergencyActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:emergencyContactList rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact List' ;
    rdfs:comment 'Comprehensive list of emergency contacts including local fire department, police, EMS, hospital, poison control, hazmat response team, EPA regional office, state environmental agency, utility companies, and internal corporate emergency response. Includes names, phone numbers, and addresses.' ;
    rdfs:domain ind:EmergencyActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyTypesCovered rdf:type rdf:Property ;
    rdfs:label 'Emergency Types Covered' ;
    rdfs:comment 'Comma-separated list of emergency scenarios addressed in this plan, such as fire, chemical spill, medical emergency, severe weather (tornado, hurricane, flood), active threat, hazardous material release, equipment failure, gas leak, explosion, or natural disaster. Defines the scope of preparedness.' ;
    rdfs:domain ind:EmergencyActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeRolesResponsibilities rdf:type rdf:Property ;
    rdfs:label 'Employee Roles Responsibilities' ;
    rdfs:comment 'Detailed description of roles and responsibilities assigned to employees during an emergency, including floor wardens, evacuation assistants, first aid responders, equipment shutdown personnel, and headcount coordinators. Defines who does what during emergency response.' ;
    rdfs:domain ind:EmergencyActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeTrainingCompletionRate rdf:type rdf:Property ;
    rdfs:label 'Employee Training Completion Rate' ;
    rdfs:comment 'Percentage of employees at the facility who have completed required training on the current version of the Emergency Action Plan. Used to track compliance and readiness. Target is 100 percent.' ;
    rdfs:domain ind:EmergencyActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evacuationProcedures rdf:type rdf:Property ;
    rdfs:label 'Evacuation Procedures' ;
    rdfs:comment 'Detailed description of evacuation procedures including routes, exits, assembly points, accountability processes, and special considerations for different facility areas (e.g., landfill cell, MRF processing floor, hazmat storage area).' ;
    rdfs:domain ind:EmergencyActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityMapUrl rdf:type rdf:Property ;
    rdfs:label 'Facility Map Url' ;
    rdfs:comment 'URL or file path to the facility map showing evacuation routes, exits, assembly points, emergency equipment locations (fire extinguishers, AEDs, eyewash stations), and hazardous material storage areas.' ;
    rdfs:domain ind:EmergencyActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatSpecificProcedures rdf:type rdf:Property ;
    rdfs:label 'Hazmat Specific Procedures' ;
    rdfs:comment 'Special emergency procedures for facilities handling hazardous waste, including spill containment, leak isolation, vapor monitoring, decontamination protocols, and coordination with RCRA-certified hazmat response teams.' ;
    rdfs:domain ind:EmergencyActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastDrillDate rdf:type rdf:Property ;
    rdfs:label 'Last Drill Date' ;
    rdfs:comment 'Date of the most recent emergency evacuation drill or tabletop exercise conducted at the facility to test the Emergency Action Plan and employee preparedness.' ;
    rdfs:domain ind:EmergencyActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:medicalEmergencyProcedures rdf:type rdf:Property ;
    rdfs:label 'Medical Emergency Procedures' ;
    rdfs:comment 'Procedures for responding to medical emergencies including location of first aid kits, AED devices, eyewash stations, safety showers, and protocols for calling EMS and transporting injured employees to medical facilities.' ;
    rdfs:domain ind:EmergencyActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextDrillDate rdf:type rdf:Property ;
    rdfs:label 'Next Drill Date' ;
    rdfs:comment 'Date scheduled for the next emergency evacuation drill or tabletop exercise. OSHA recommends annual drills at minimum; some facilities conduct quarterly drills.' ;
    rdfs:domain ind:EmergencyActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:oshaStandardCitation rdf:type rdf:Property ;
    rdfs:label 'Osha Standard Citation' ;
    rdfs:comment 'Specific OSHA standard citation(s) that this Emergency Action Plan is designed to comply with, typically 29 CFR 1910.38 (Emergency Action Plans) and may include 29 CFR 1910.120 (HAZWOPER) for hazmat facilities.' ;
    rdfs:domain ind:EmergencyActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Plan Document Url' ;
    rdfs:comment 'URL or file path to the complete Emergency Action Plan document stored in the document management system. Provides access to the full plan including maps, diagrams, contact lists, and detailed procedures.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryAssemblyPoint rdf:type rdf:Property ;
    rdfs:label 'Primary Assembly Point' ;
    rdfs:comment 'Designated primary location where all employees must gather after evacuating the facility for headcount and accountability. Typically a safe distance from the facility with clear visibility and access.' ;
    rdfs:domain ind:EmergencyActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rescueNonRescueDuties rdf:type rdf:Property ;
    rdfs:label 'Rescue Non Rescue Duties' ;
    rdfs:comment 'Specification of which employees, if any, are assigned rescue or medical duties during emergencies, and which employees are prohibited from rescue activities and must evacuate immediately. Critical for OSHA compliance and employee safety.' ;
    rdfs:domain ind:EmergencyActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Review Frequency Months' ;
    rdfs:comment 'Required frequency for comprehensive review and update of the Emergency Action Plan, expressed in months. Typically 12 months (annual) but may be more frequent for high-hazard facilities or after significant operational changes.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:secondaryAssemblyPoint rdf:type rdf:Property ;
    rdfs:label 'Secondary Assembly Point' ;
    rdfs:comment 'Alternate assembly location to be used if the primary assembly point is inaccessible or unsafe due to the nature or location of the emergency (e.g., wind direction for chemical release, fire spread).' ;
    rdfs:domain ind:EmergencyActionPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobPositionId rdf:type rdf:Property ;
    rdfs:label 'Job Position Id' ;
    rdfs:comment 'Foreign key linking to workforce.job_position. Business justification: Hazards are identified and assessed for specific job positions. Links hazard exposure to position enables "show all hazards for this position" for JHA development and position-specific training per IS' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JobPosition .

ind:primaryHazardIdentifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Hazard Identified By Employee Id' ;
    rdfs:comment 'Reference to the employee who identified or reported this hazard. Supports worker participation in safety programs.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actionPlanDueDate rdf:type rdf:Property ;
    rdfs:label 'Action Plan Due Date' ;
    rdfs:comment 'Target completion date for implementing additional control measures or improvements identified in the action plan.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actionPlanRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Action Plan Required Flag' ;
    rdfs:comment 'Indicates whether an action plan is required to implement additional controls or improvements. True when residual risk is not accepted or controls are inadequate.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:administrativeControls rdf:type rdf:Property ;
    rdfs:label 'Administrative Controls' ;
    rdfs:comment 'Policies, procedures, training, and work practices implemented to reduce hazard exposure. Examples: job rotation, safety meetings, standard operating procedures, permit systems.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlAdequacyStatus rdf:type rdf:Property ;
    rdfs:label 'Control Adequacy Status' ;
    rdfs:comment 'Assessment of whether current control measures are sufficient to reduce risk to an acceptable level. Drives action planning for additional controls.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlMeasures rdf:type rdf:Property ;
    rdfs:label 'Control Measures' ;
    rdfs:comment 'Detailed description of current control measures in place to mitigate the hazard. Includes engineering controls, administrative controls, and PPE requirements following hierarchy of controls.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engineeringControls rdf:type rdf:Property ;
    rdfs:label 'Engineering Controls' ;
    rdfs:comment 'Physical modifications or equipment designed to eliminate or reduce the hazard. Examples: machine guards, ventilation systems, safety interlocks, backup alarms.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exposureFrequency rdf:type rdf:Property ;
    rdfs:label 'Exposure Frequency' ;
    rdfs:comment 'How often workers are exposed to this hazard. Used in risk assessment calculations.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardCode rdf:type rdf:Property ;
    rdfs:label 'Hazard Code' ;
    rdfs:comment 'Unique business identifier for the hazard. Format: HAZ- followed by alphanumeric code.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardDescription rdf:type rdf:Property ;
    rdfs:label 'Hazard Description' ;
    rdfs:comment 'Detailed description of the workplace hazard including specific conditions, locations, and circumstances under which the hazard is present.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardName rdf:type rdf:Property ;
    rdfs:label 'Hazard Name' ;
    rdfs:comment 'Short descriptive name of the hazard for quick identification and reporting.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardRegisterStatus rdf:type rdf:Property ;
    rdfs:label 'Hazard Register Status' ;
    rdfs:comment 'Current lifecycle status of the hazard in the register. Active: hazard present and managed; Mitigated: controls in place, residual risk accepted; Eliminated: hazard removed; Under Investigation: newly identified, assessment in progress; Archived: no longer applicable.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardSource rdf:type rdf:Property ;
    rdfs:label 'Hazard Source' ;
    rdfs:comment 'Specific source or origin of the hazard. Examples: collection truck hydraulics, landfill working face, MRF sorting line, leachate handling system, compactor equipment.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardSubcategory rdf:type rdf:Property ;
    rdfs:label 'Hazard Subcategory' ;
    rdfs:comment 'Secondary or more specific classification within the primary hazard category. Examples: confined space, vehicle collision, needle stick, heat stress, landfill gas exposure.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identificationDate rdf:type rdf:Property ;
    rdfs:label 'Identification Date' ;
    rdfs:comment 'Date when the hazard was first identified and entered into the register.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:incidentHistoryCount rdf:type rdf:Property ;
    rdfs:label 'Incident History Count' ;
    rdfs:comment 'Number of recorded safety incidents or near-misses associated with this hazard. Used to validate risk ratings and control effectiveness.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inherentLikelihoodRating rdf:type rdf:Property ;
    rdfs:label 'Inherent Likelihood Rating' ;
    rdfs:comment 'Likelihood score of the hazard occurring without any controls in place. Typically scored 1-5 where 1=rare, 5=almost certain. Used to calculate inherent risk.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inherentRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Inherent Risk Level' ;
    rdfs:comment 'Qualitative risk level derived from inherent risk score. Typically: 1-5=low, 6-12=medium, 13-20=high, 21-25=critical.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inherentRiskScore rdf:type rdf:Property ;
    rdfs:label 'Inherent Risk Score' ;
    rdfs:comment 'Calculated inherent risk score (likelihood × severity) before any control measures are applied. Represents the raw risk level.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inherentSeverityRating rdf:type rdf:Property ;
    rdfs:label 'Inherent Severity Rating' ;
    rdfs:comment 'Severity score of potential consequences without any controls in place. Typically scored 1-5 where 1=negligible injury, 5=fatality. Used to calculate inherent risk.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastIncidentDate rdf:type rdf:Property ;
    rdfs:label 'Last Incident Date' ;
    rdfs:comment 'Date of the most recent incident or near-miss related to this hazard. Triggers review of control adequacy.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operationType rdf:type rdf:Property ;
    rdfs:label 'Operation Type' ;
    rdfs:comment 'Type of waste management operation where the hazard is present. Determines applicable safety protocols and regulatory requirements. [ENUM-REF-CANDIDATE: residential_collection|commercial_collection|landfill_operations|mrf_operations|hazmat_handling|fleet_maintenance|wte_operations|transfer_station — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualLikelihoodRating rdf:type rdf:Property ;
    rdfs:label 'Residual Likelihood Rating' ;
    rdfs:comment 'Likelihood score after control measures are applied. Scored 1-5. Represents the reduced probability of occurrence with controls in place.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:residualRiskScore rdf:type rdf:Property ;
    rdfs:label 'Residual Risk Score' ;
    rdfs:comment 'Calculated residual risk score (likelihood × severity) after control measures are applied. Represents the remaining risk level.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:residualSeverityRating rdf:type rdf:Property ;
    rdfs:label 'Residual Severity Rating' ;
    rdfs:comment 'Severity score after control measures are applied. Scored 1-5. Represents the reduced consequence severity with controls in place.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:riskAcceptanceStatus rdf:type rdf:Property ;
    rdfs:label 'Risk Acceptance Status' ;
    rdfs:comment 'Whether the residual risk level has been formally accepted by management or requires further mitigation.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workAreaLocation rdf:type rdf:Property ;
    rdfs:label 'Work Area Location' ;
    rdfs:comment 'Specific work area, zone, or location within the facility where the hazard exists. Examples: Cell 5 working face, tipping floor, maintenance bay 3, sorting line A.' ;
    rdfs:domain ind:HazardRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Incident Employee Id' ;
    rdfs:comment 'Reference to the employee who was injured or involved in the incident.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:incidentInvestigatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Incident Investigator Employee Id' ;
    rdfs:comment 'Reference to the safety professional or manager who led the incident investigation.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:involvedWasteStreamId rdf:type rdf:Property ;
    rdfs:label 'Involved Waste Stream Id' ;
    rdfs:comment 'Foreign key linking to service.service_waste_stream. Business justification: Incidents are categorized by waste stream involved (chemical exposure from industrial waste, sharps injury from medical waste). EPA and OSHA require waste-stream-specific incident reporting; risk team' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WasteStream .

ind:correctiveActionsDescription rdf:type rdf:Property ;
    rdfs:label 'Corrective Actions Description' ;
    rdfs:comment 'Summary of corrective and preventive actions identified and implemented following the incident investigation.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionsRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Corrective Actions Required Flag' ;
    rdfs:comment 'Indicates whether corrective actions were identified as necessary to prevent recurrence.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:employeeJobTitle rdf:type rdf:Property ;
    rdfs:label 'Employee Job Title' ;
    rdfs:comment 'Job title or position of the employee at the time of the incident (e.g., CDL Driver, Equipment Operator, Sorter, Mechanic).' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedCostAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Cost Amount' ;
    rdfs:comment 'Estimated total cost impact of the incident including medical expenses, lost time, equipment damage, and administrative costs in USD.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:illnessType rdf:type rdf:Property ;
    rdfs:label 'Illness Type' ;
    rdfs:comment 'Category of occupational illness if the incident is classified as an illness rather than injury.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oshaRecordabilityDeterminationDate rdf:type rdf:Property ;
    rdfs:label 'Osha Recordability Determination Date' ;
    rdfs:comment 'Date when the formal determination of OSHA recordability was made by qualified safety personnel.' ;
    rdfs:domain ind:Incident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ppeAdequateFlag rdf:type rdf:Property ;
    rdfs:label 'Ppe Adequate Flag' ;
    rdfs:comment 'Indicates whether the PPE in use was adequate and appropriate for the task being performed.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ppeInUse rdf:type rdf:Property ;
    rdfs:label 'Ppe In Use' ;
    rdfs:comment 'Description of personal protective equipment the employee was wearing or using at the time of the incident.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:witnessCount rdf:type rdf:Property ;
    rdfs:label 'Witness Count' ;
    rdfs:comment 'Number of witnesses to the incident who provided statements during the investigation.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:workersCompClaimNumber rdf:type rdf:Property ;
    rdfs:label 'Workers Comp Claim Number' ;
    rdfs:comment 'Workers compensation insurance claim number associated with this incident, if a claim was filed.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentInvestigationId rdf:type rdf:Property ;
    rdfs:label 'Incident Investigation Id' ;
    rdfs:comment 'Unique identifier for the incident investigation record. Primary key.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:investigationReportDocumentId rdf:type rdf:Property ;
    rdfs:label 'Investigation Report Document Id' ;
    rdfs:comment 'Reference identifier for the formal investigation report document stored in the document management system.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Document .

ind:contributingFactors rdf:type rdf:Property ;
    rdfs:label 'Contributing Factors' ;
    rdfs:comment 'Additional factors that contributed to the incident but were not the primary root cause. May include secondary conditions, behaviors, or circumstances.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionCompletionRate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Completion Rate' ;
    rdfs:comment 'Percentage of assigned corrective actions that have been completed and verified. Calculated as (completed actions / total actions) * 100.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:correctiveActionsAssigned rdf:type rdf:Property ;
    rdfs:label 'Corrective Actions Assigned' ;
    rdfs:comment 'Summary of corrective and preventive actions assigned as a result of the investigation findings. Details specific actions, responsible parties, and target completion dates.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalFactorsIdentified rdf:type rdf:Property ;
    rdfs:label 'Environmental Factors Identified' ;
    rdfs:comment 'Environmental conditions that contributed to the incident such as weather, lighting, noise, temperature, or site layout issues.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentFactorsIdentified rdf:type rdf:Property ;
    rdfs:label 'Equipment Factors Identified' ;
    rdfs:comment 'Equipment-related factors such as mechanical failure, design deficiency, maintenance issues, or lack of proper guarding that contributed to the incident.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentInspectionConductedFlag rdf:type rdf:Property ;
    rdfs:label 'Equipment Inspection Conducted Flag' ;
    rdfs:comment 'Indicates whether involved equipment was inspected as part of the investigation to identify mechanical or design deficiencies.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:humanFactorsIdentified rdf:type rdf:Property ;
    rdfs:label 'Human Factors Identified' ;
    rdfs:comment 'Specific human factors contributing to the incident such as fatigue, distraction, inadequate training, communication breakdown, or procedural non-compliance.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:immediateCauses rdf:type rdf:Property ;
    rdfs:label 'Immediate Causes' ;
    rdfs:comment 'Direct, proximate causes that immediately preceded the incident. Typically unsafe acts or unsafe conditions that triggered the event.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationClosureDate rdf:type rdf:Property ;
    rdfs:label 'Investigation Closure Date' ;
    rdfs:comment 'Date when all corrective actions were verified as implemented and the investigation was formally closed.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:investigationCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Investigation Completion Date' ;
    rdfs:comment 'Date when the investigation findings, root cause analysis, and corrective actions were finalized and documented.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:investigationDurationDays rdf:type rdf:Property ;
    rdfs:label 'Investigation Duration Days' ;
    rdfs:comment 'Number of calendar days from investigation start to completion. Used to track investigation cycle time and efficiency.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:investigationFindingsSummary rdf:type rdf:Property ;
    rdfs:label 'Investigation Findings Summary' ;
    rdfs:comment 'Executive summary of the investigation findings, conclusions, and key takeaways. Used for management reporting and lessons learned.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationMethod rdf:type rdf:Property ;
    rdfs:label 'Investigation Method' ;
    rdfs:comment 'Specific investigation methodology or framework used such as 5 Whys, Fishbone Diagram, Fault Tree Analysis, or Bow Tie Analysis.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationNumber rdf:type rdf:Property ;
    rdfs:label 'Investigation Number' ;
    rdfs:comment 'Externally-known unique investigation tracking number assigned to this formal investigation. Format: INV-YYYY-NNNNNN.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationPriority rdf:type rdf:Property ;
    rdfs:label 'Investigation Priority' ;
    rdfs:comment 'Priority level assigned to the investigation based on incident severity, potential for recurrence, and regulatory implications.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationStartDate rdf:type rdf:Property ;
    rdfs:label 'Investigation Start Date' ;
    rdfs:comment 'Date when the formal investigation was initiated. Typically within 24-48 hours of the incident occurrence per OSHA guidelines.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:investigationTeamMembers rdf:type rdf:Property ;
    rdfs:label 'Investigation Team Members' ;
    rdfs:comment 'Comma-separated list of employee names or IDs who participated in the investigation team. Includes subject matter experts, witnesses, and support personnel.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationType rdf:type rdf:Property ;
    rdfs:label 'Investigation Type' ;
    rdfs:comment 'Classification of the investigation depth and methodology. Root Cause Analysis (RCA) is the most comprehensive structured investigation.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadInvestigatorName rdf:type rdf:Property ;
    rdfs:label 'Lead Investigator Name' ;
    rdfs:comment 'Full name of the lead investigator assigned to this investigation.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lessonsLearned rdf:type rdf:Property ;
    rdfs:label 'Lessons Learned' ;
    rdfs:comment 'Key lessons learned from the investigation that should be communicated across the organization to prevent similar incidents.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managementSystemGaps rdf:type rdf:Property ;
    rdfs:label 'Management System Gaps' ;
    rdfs:comment 'Identified deficiencies in management systems, policies, procedures, or oversight that allowed the incident to occur.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:photographicEvidenceCollectedFlag rdf:type rdf:Property ;
    rdfs:label 'Photographic Evidence Collected Flag' ;
    rdfs:comment 'Indicates whether photographs or video evidence of the incident scene were collected and documented.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preventiveMeasuresRecommended rdf:type rdf:Property ;
    rdfs:label 'Preventive Measures Recommended' ;
    rdfs:comment 'Recommended preventive measures to eliminate or control the identified hazards and prevent recurrence of similar incidents.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewedByOperationsManagerFlag rdf:type rdf:Property ;
    rdfs:label 'Reviewed By Operations Manager Flag' ;
    rdfs:comment 'Indicates whether the investigation findings and corrective actions were reviewed and approved by the operations manager.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewedBySafetyManagerFlag rdf:type rdf:Property ;
    rdfs:label 'Reviewed By Safety Manager Flag' ;
    rdfs:comment 'Indicates whether the investigation findings and corrective actions were reviewed and approved by the safety manager.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:siteInspectionConductedFlag rdf:type rdf:Property ;
    rdfs:label 'Site Inspection Conducted Flag' ;
    rdfs:comment 'Indicates whether a physical site inspection was conducted to assess environmental and situational factors.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:witnessStatementsCollectedFlag rdf:type rdf:Property ;
    rdfs:label 'Witness Statements Collected Flag' ;
    rdfs:comment 'Indicates whether witness statements were collected as part of the investigation process.' ;
    rdfs:domain ind:IncidentInvestigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:industrialHygieneSampleId rdf:type rdf:Property ;
    rdfs:label 'Industrial Hygiene Sample Id' ;
    rdfs:comment 'Unique identifier for the industrial hygiene sampling event record.' ;
    rdfs:domain ind:IndustrialHygieneSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryIndustrialEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Industrial Employee Id' ;
    rdfs:comment 'Identifier of the employee being monitored for exposure, if this is a personal sample. Null for area samples.' ;
    rdfs:domain ind:IndustrialHygieneSample ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryIndustrialReviewedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Industrial Reviewed By Employee Id' ;
    rdfs:comment 'Identifier of the certified industrial hygienist (CIH) or EHS manager who reviewed and validated the sampling results.' ;
    rdfs:domain ind:IndustrialHygieneSample ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:acgihTlv rdf:type rdf:Property ;
    rdfs:label 'Acgih Tlv' ;
    rdfs:comment 'The ACGIH Threshold Limit Value for the contaminant, representing recommended exposure guidelines.' ;
    rdfs:domain ind:IndustrialHygieneSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:analysisDate rdf:type rdf:Property ;
    rdfs:label 'Analysis Date' ;
    rdfs:comment 'The date the laboratory completed the analysis of the sample.' ;
    rdfs:domain ind:IndustrialHygieneSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contaminantName rdf:type rdf:Property ;
    rdfs:label 'Contaminant Name' ;
    rdfs:comment 'The specific contaminant, chemical, or hazard being measured (e.g., silica, benzene, hydrogen sulfide, noise, heat index).' ;
    rdfs:domain ind:IndustrialHygieneSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceedancePercentage rdf:type rdf:Property ;
    rdfs:label 'Exceedance Percentage' ;
    rdfs:comment 'The percentage of the exposure limit that was measured, calculated as (measured_result / exposure_limit) * 100.' ;
    rdfs:domain ind:IndustrialHygieneSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exposureLimitType rdf:type rdf:Property ;
    rdfs:label 'Exposure Limit Type' ;
    rdfs:comment 'The type of exposure limit being evaluated: Time-Weighted Average (TWA), Short-Term Exposure Limit (STEL), ceiling limit, or action level.' ;
    rdfs:domain ind:IndustrialHygieneSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobTaskDescription rdf:type rdf:Property ;
    rdfs:label 'Job Task Description' ;
    rdfs:comment 'Description of the work task or activity being performed by the employee during sampling, if this is a personal sample.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laboratoryAccreditation rdf:type rdf:Property ;
    rdfs:label 'Laboratory Accreditation' ;
    rdfs:comment 'The accreditation standard held by the laboratory (e.g., AIHA LAP LLC, ISO/IEC 17025).' ;
    rdfs:domain ind:IndustrialHygieneSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measuredResultValue rdf:type rdf:Property ;
    rdfs:label 'Measured Result Value' ;
    rdfs:comment 'The quantitative result of the exposure measurement (concentration, level, or dose).' ;
    rdfs:domain ind:IndustrialHygieneSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oshaPel rdf:type rdf:Property ;
    rdfs:label 'Osha Pel' ;
    rdfs:comment 'The OSHA Permissible Exposure Limit for the contaminant, representing the maximum allowable exposure level.' ;
    rdfs:domain ind:IndustrialHygieneSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ppeWorn rdf:type rdf:Property ;
    rdfs:label 'Ppe Worn' ;
    rdfs:comment 'Description of personal protective equipment worn by the employee during the sampling period (e.g., respirator type, hearing protection).' ;
    rdfs:domain ind:IndustrialHygieneSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantificationLimit rdf:type rdf:Property ;
    rdfs:label 'Quantification Limit' ;
    rdfs:comment 'The minimum quantifiable concentration or level for the analytical method used.' ;
    rdfs:domain ind:IndustrialHygieneSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recommendedControls rdf:type rdf:Property ;
    rdfs:label 'Recommended Controls' ;
    rdfs:comment 'Industrial hygienist recommendations for exposure controls based on the sampling results (e.g., engineering controls, administrative controls, PPE upgrades).' ;
    rdfs:domain ind:IndustrialHygieneSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resultUnit rdf:type rdf:Property ;
    rdfs:label 'Result Unit' ;
    rdfs:comment 'The unit of measure for the measured result (e.g., mg/m3, ppm, dBA, WBGT, fibers/cc).' ;
    rdfs:domain ind:IndustrialHygieneSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleVolumeLiters rdf:type rdf:Property ;
    rdfs:label 'Sample Volume Liters' ;
    rdfs:comment 'Total volume of air sampled in liters, calculated from flow rate and duration.' ;
    rdfs:domain ind:IndustrialHygieneSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:samplingDate rdf:type rdf:Property ;
    rdfs:label 'Sampling Date' ;
    rdfs:comment 'The date on which the industrial hygiene sample was collected.' ;
    rdfs:domain ind:IndustrialHygieneSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:samplingDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Sampling Duration Minutes' ;
    rdfs:comment 'Total duration of the sampling event in minutes, calculated from start to end timestamp.' ;
    rdfs:domain ind:IndustrialHygieneSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:samplingEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sampling End Timestamp' ;
    rdfs:comment 'The precise date and time when the sampling event concluded.' ;
    rdfs:domain ind:IndustrialHygieneSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:samplingEquipment rdf:type rdf:Property ;
    rdfs:label 'Sampling Equipment' ;
    rdfs:comment 'Description of the sampling equipment used (e.g., personal air sampling pump, noise dosimeter, direct-reading gas detector, heat stress monitor).' ;
    rdfs:domain ind:IndustrialHygieneSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplingLocationDescription rdf:type rdf:Property ;
    rdfs:label 'Sampling Location Description' ;
    rdfs:comment 'Detailed description of the specific location within the facility or operation where the sample was collected (e.g., tipping floor, sorting line, landfill cell 5, truck cab).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplingStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sampling Start Timestamp' ;
    rdfs:comment 'The precise date and time when the sampling event began.' ;
    rdfs:domain ind:IndustrialHygieneSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:jhaApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Jha Approved By Employee Id' ;
    rdfs:comment 'Reference to the employee who approved this JHA document. Typically a safety director or operations manager.' ;
    rdfs:domain ind:Jha ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:jhaCreatedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Jha Created By Employee Id' ;
    rdfs:comment 'Reference to the employee who created this JHA document. Typically a safety manager or supervisor.' ;
    rdfs:domain ind:Jha ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:crewSizeRequired rdf:type rdf:Property ;
    rdfs:label 'Crew Size Required' ;
    rdfs:comment 'Minimum number of workers required to safely perform this job task (e.g., 2 for confined space entry, 1 for standard route collection).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:emergencyProcedures rdf:type rdf:Property ;
    rdfs:label 'Emergency Procedures' ;
    rdfs:comment 'Emergency response procedures specific to hazards identified in this JHA (e.g., evacuation routes, spill response, first aid, emergency contacts).' ;
    rdfs:domain ind:Jha ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalConditions rdf:type rdf:Property ;
    rdfs:label 'Environmental Conditions' ;
    rdfs:comment 'Environmental factors that affect safety during this job task (e.g., extreme heat, cold, rain, wind, noise, dust, confined space, outdoor exposure).' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentRequired rdf:type rdf:Property ;
    rdfs:label 'Equipment Required' ;
    rdfs:comment 'List of equipment and tools required to perform this job task safely (e.g., collection truck, compactor, forklift, gas monitor, fire extinguisher).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frequencyOfTask rdf:type rdf:Property ;
    rdfs:label 'Frequency Of Task' ;
    rdfs:comment 'How often this job task is typically performed. Values: daily, weekly, monthly, quarterly, annual, as_needed.' ;
    rdfs:domain ind:Jha ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jhaNumber rdf:type rdf:Property ;
    rdfs:label 'Jha Number' ;
    rdfs:comment 'Business identifier for the JHA document. Human-readable unique number used for tracking and reference in safety programs.' ;
    rdfs:domain ind:Jha ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jhaStatus rdf:type rdf:Property ;
    rdfs:label 'Jha Status' ;
    rdfs:comment 'Current lifecycle status of the JHA document. Values: draft (initial creation), under_review (submitted for approval), approved (approved but not yet active), active (in use for operations), expired (past review date), archived (retired from use).' ;
    rdfs:domain ind:Jha ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobTaskName rdf:type rdf:Property ;
    rdfs:label 'Job Task Name' ;
    rdfs:comment 'Name of the specific job task or work activity being analyzed for hazards (e.g., Residential Route Collection, Landfill Cell Compaction, MRF Sorting Line Operation).' ;
    rdfs:domain ind:Jha ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preTaskInspectionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Pre Task Inspection Required Flag' ;
    rdfs:comment 'Indicates whether a pre-task safety inspection or checklist must be completed before starting this job task.' ;
    rdfs:domain ind:Jha ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiredPpe rdf:type rdf:Property ;
    rdfs:label 'Required Ppe' ;
    rdfs:comment 'List of required Personal Protective Equipment for the job task. May include: hard hat, safety glasses, gloves, steel-toe boots, high-visibility vest, respirator, hearing protection, fall protection harness, chemical suit.' ;
    rdfs:domain ind:Jha ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionNotes rdf:type rdf:Property ;
    rdfs:label 'Revision Notes' ;
    rdfs:comment 'Notes describing changes made in the current revision of the JHA (e.g., updated PPE requirements, added new hazard controls).' ;
    rdfs:domain ind:Jha ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingRequirements rdf:type rdf:Property ;
    rdfs:label 'Training Requirements' ;
    rdfs:comment 'Specific safety training required before performing this job task (e.g., HAZWOPER, CDL, forklift certification, confined space entry, fall protection).' ;
    rdfs:domain ind:Jha ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jhaStepId rdf:type rdf:Property ;
    rdfs:label 'Jha Step Id' ;
    rdfs:comment 'Unique identifier for the individual job step within a Job Hazard Analysis. Primary key for the JHA step record.' ;
    rdfs:domain ind:JhaStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requiredCertificationId rdf:type rdf:Property ;
    rdfs:label 'Required Certification Id' ;
    rdfs:comment 'Foreign key linking to workforce.certification. Business justification: JHA steps may require specific certifications (confined space, forklift, hazmat). Links step requirements to certification definitions, enabling verification that assigned employees hold required cert' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Certification .

ind:controlHierarchy rdf:type rdf:Property ;
    rdfs:label 'Control Hierarchy' ;
    rdfs:comment 'Classification of the control measure according to the OSHA hierarchy of controls. Elimination (remove hazard) is most effective; PPE (Personal Protective Equipment) is least effective but often necessary as last line of defense.' ;
    rdfs:domain ind:JhaStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlMeasure rdf:type rdf:Property ;
    rdfs:label 'Control Measure' ;
    rdfs:comment 'Specific preventive action, safeguard, or control required to eliminate or reduce the hazard to an acceptable level. Describes the mitigation strategy (e.g., \'Wear high-visibility vest and maintain 10-foot clearance from moving equipment\', \'Use chemical-resistant gloves rated for leachate contact\').' ;
    rdfs:domain ind:JhaStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalCondition rdf:type rdf:Property ;
    rdfs:label 'Environmental Condition' ;
    rdfs:comment 'Relevant environmental or atmospheric conditions that affect hazard exposure during this step. Describes conditions such as temperature extremes, weather exposure, confined atmosphere, noise levels, or presence of hazardous gases (e.g., \'Outdoor work in temperatures exceeding 90°F\', \'Potential methane atmosphere in landfill cell\').' ;
    rdfs:domain ind:JhaStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frequencyPerShift rdf:type rdf:Property ;
    rdfs:label 'Frequency Per Shift' ;
    rdfs:comment 'Number of times this job step is typically performed during a single work shift. Used to calculate cumulative exposure and ergonomic risk factors.' ;
    rdfs:domain ind:JhaStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:incidentHistoryFlag rdf:type rdf:Property ;
    rdfs:label 'Incident History Flag' ;
    rdfs:comment 'Indicates whether past safety incidents or near-misses have been associated with this job step. True if historical incidents exist; False if no incident history. Used to prioritize high-risk steps for enhanced controls.' ;
    rdfs:domain ind:JhaStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:probabilityRating rdf:type rdf:Property ;
    rdfs:label 'Probability Rating' ;
    rdfs:comment 'Likelihood that the hazard will result in an incident during normal operations. Frequent = occurs often; Probable = will occur several times; Occasional = likely to occur sometime; Remote = unlikely but possible; Improbable = so unlikely it can be assumed will not occur.' ;
    rdfs:domain ind:JhaStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryStandard rdf:type rdf:Property ;
    rdfs:label 'Regulatory Standard' ;
    rdfs:comment 'Specific OSHA, EPA, DOT, or other regulatory standard that governs safety requirements for this job step. Provides regulatory traceability (e.g., \'OSHA 1910.178 - Powered Industrial Trucks\', \'RCRA 40 CFR 264 - Hazardous Waste Management\', \'DOT 49 CFR 383 - Commercial Driver Licensing\').' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskScore rdf:type rdf:Property ;
    rdfs:label 'Risk Score' ;
    rdfs:comment 'Calculated risk score derived from severity and probability ratings. Typically uses a risk matrix (e.g., 1-25 scale) to prioritize hazards requiring control measures. Higher scores indicate higher priority for mitigation.' ;
    rdfs:domain ind:JhaStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stepDescription rdf:type rdf:Property ;
    rdfs:label 'Step Description' ;
    rdfs:comment 'Detailed narrative description of the specific work step or task action being performed. Describes what the worker does at this stage of the job (e.g., \'Approach container and position truck\', \'Lift container using automated side loader\').' ;
    rdfs:domain ind:JhaStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stepDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Step Duration Minutes' ;
    rdfs:comment 'Estimated time in minutes required to complete this job step under normal conditions. Used for exposure time calculations and work planning.' ;
    rdfs:domain ind:JhaStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stepSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Step Sequence Number' ;
    rdfs:comment 'Sequential order of this step within the job task breakdown. Defines the chronological position of the step in the work process (e.g., 1, 2, 3).' ;
    rdfs:domain ind:JhaStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stepStatus rdf:type rdf:Property ;
    rdfs:label 'Step Status' ;
    rdfs:comment 'Current lifecycle status of this JHA step record. Active = currently in use; Under Review = being evaluated for changes; Revised = updated version exists; Obsolete = no longer applicable.' ;
    rdfs:domain ind:JhaStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workerCount rdf:type rdf:Property ;
    rdfs:label 'Worker Count' ;
    rdfs:comment 'Number of workers typically involved in performing this job step. Identifies crew size requirements and coordination needs (e.g., 1 for solo driver tasks, 2 for two-person lift operations, 3 for confined space entry with attendants).' ;
    rdfs:domain ind:JhaStep ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryLockoutApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Lockout Approved By Employee Id' ;
    rdfs:comment 'Reference to the employee (typically safety manager or facility manager) who approved this LOTO procedure.' ;
    rdfs:domain ind:LockoutTagoutProcedure ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:authorizedEmployeeRoles rdf:type rdf:Property ;
    rdfs:label 'Authorized Employee Roles' ;
    rdfs:comment 'Comma-separated list of job roles or positions authorized to perform this LOTO procedure (e.g., Maintenance Technician, Electrician, Equipment Operator Level 3).' ;
    rdfs:domain ind:LockoutTagoutProcedure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diagramAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Diagram Available Flag' ;
    rdfs:comment 'Indicates whether a visual diagram or schematic of lockout points is available for this procedure.' ;
    rdfs:domain ind:LockoutTagoutProcedure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:electricalIsolationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Electrical Isolation Required Flag' ;
    rdfs:comment 'Indicates whether electrical energy isolation is required for this equipment.' ;
    rdfs:domain ind:LockoutTagoutProcedure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:energySourcesControlled rdf:type rdf:Property ;
    rdfs:label 'Energy Sources Controlled' ;
    rdfs:comment 'Comma-separated list of all energy sources that must be controlled during lockout: electrical, hydraulic, pneumatic, gravitational, thermal, chemical, mechanical, stored energy.' ;
    rdfs:domain ind:LockoutTagoutProcedure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupLockoutRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Group Lockout Required Flag' ;
    rdfs:comment 'Indicates whether this procedure requires group lockout provisions when multiple employees are working on the same equipment.' ;
    rdfs:domain ind:LockoutTagoutProcedure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hydraulicIsolationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Hydraulic Isolation Required Flag' ;
    rdfs:comment 'Indicates whether hydraulic energy isolation is required for this equipment.' ;
    rdfs:domain ind:LockoutTagoutProcedure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incidentCount rdf:type rdf:Property ;
    rdfs:label 'Incident Count' ;
    rdfs:comment 'Number of safety incidents or near-misses associated with this equipment that involved failure to follow LOTO procedures.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lockoutDeviceCount rdf:type rdf:Property ;
    rdfs:label 'Lockout Device Count' ;
    rdfs:comment 'Total number of lockout devices required to complete the procedure.' ;
    rdfs:domain ind:LockoutTagoutProcedure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lockoutDeviceTypesRequired rdf:type rdf:Property ;
    rdfs:label 'Lockout Device Types Required' ;
    rdfs:comment 'Comma-separated list of lockout device types required for this procedure (e.g., padlock, circuit breaker lockout, valve lockout, cable lockout, hasp).' ;
    rdfs:domain ind:LockoutTagoutProcedure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lockoutStepsSequence rdf:type rdf:Property ;
    rdfs:label 'Lockout Steps Sequence' ;
    rdfs:comment 'Detailed step-by-step sequence of actions required to safely lock out the equipment. Includes preparation, shutdown, isolation, lockout device application, stored energy release, and verification steps.' ;
    rdfs:domain ind:LockoutTagoutProcedure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oshaInspectionReadyFlag rdf:type rdf:Property ;
    rdfs:label 'Osha Inspection Ready Flag' ;
    rdfs:comment 'Indicates whether this LOTO procedure meets all OSHA 29 CFR 1910.147 requirements and is ready for regulatory inspection.' ;
    rdfs:domain ind:LockoutTagoutProcedure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pneumaticIsolationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Pneumatic Isolation Required Flag' ;
    rdfs:comment 'Indicates whether pneumatic energy isolation is required for this equipment.' ;
    rdfs:domain ind:LockoutTagoutProcedure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:procedureDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Procedure Document Url' ;
    rdfs:comment 'URL or file path to the full LOTO procedure document, including diagrams, photos, and detailed instructions.' ;
    rdfs:domain ind:LockoutTagoutProcedure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procedureNotes rdf:type rdf:Property ;
    rdfs:label 'Procedure Notes' ;
    rdfs:comment 'Additional notes, special considerations, or warnings specific to this LOTO procedure.' ;
    rdfs:domain ind:LockoutTagoutProcedure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procedureNumber rdf:type rdf:Property ;
    rdfs:label 'Procedure Number' ;
    rdfs:comment 'Business identifier for the LOTO procedure, typically formatted as LOTO-XXXXXX. Used for external reference and documentation.' ;
    rdfs:domain ind:LockoutTagoutProcedure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procedureStatus rdf:type rdf:Property ;
    rdfs:label 'Procedure Status' ;
    rdfs:comment 'Current lifecycle status of the LOTO procedure. Only active procedures may be used for field operations.' ;
    rdfs:domain ind:LockoutTagoutProcedure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procedureVersion rdf:type rdf:Property ;
    rdfs:label 'Procedure Version' ;
    rdfs:comment 'Version number of the LOTO procedure document, typically in major.minor format (e.g., 2.1).' ;
    rdfs:domain ind:LockoutTagoutProcedure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restorationSteps rdf:type rdf:Property ;
    rdfs:label 'Restoration Steps' ;
    rdfs:comment 'Step-by-step sequence for safely restoring equipment to normal operation after maintenance or servicing is complete, including removal of lockout devices and re-energization.' ;
    rdfs:domain ind:LockoutTagoutProcedure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storedEnergyReleaseMethod rdf:type rdf:Property ;
    rdfs:label 'Stored Energy Release Method' ;
    rdfs:comment 'Detailed instructions for safely releasing or dissipating stored energy (springs, capacitors, elevated components, pressurized lines) before servicing.' ;
    rdfs:domain ind:LockoutTagoutProcedure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tagoutRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Tagout Required Flag' ;
    rdfs:comment 'Indicates whether tagout devices (warning tags) are required in addition to lockout devices.' ;
    rdfs:domain ind:LockoutTagoutProcedure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryLotoAuthorizedEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Loto Authorized Employee Id' ;
    rdfs:comment 'Reference to the OSHA-authorized employee who performed the lockout. This employee must have completed LOTO training and be certified to execute energy isolation procedures.' ;
    rdfs:domain ind:LotoExecution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryLotoDeviationApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Loto Deviation Approved By Employee Id' ;
    rdfs:comment 'Reference to the supervisor or safety manager who approved any deviation from the standard LOTO procedure. Required for accountability when procedures are modified.' ;
    rdfs:domain ind:LotoExecution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quinaryLotoSupervisorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quinary Loto Supervisor Employee Id' ;
    rdfs:comment 'Reference to the supervisor responsible for overseeing this LOTO execution and ensuring compliance with safety procedures.' ;
    rdfs:domain ind:LotoExecution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryLotoEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Loto Employee Id' ;
    rdfs:comment 'Reference to the employee designated as the group lockout coordinator responsible for managing the group LOTO execution and ensuring all workers apply and remove their locks properly.' ;
    rdfs:domain ind:LotoExecution ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:affectedEmployeesCount rdf:type rdf:Property ;
    rdfs:label 'Affected Employees Count' ;
    rdfs:comment 'Number of affected employees who were notified of the LOTO execution. Tracks communication reach for safety compliance.' ;
    rdfs:domain ind:LotoExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedEmployeesNotifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Affected Employees Notified Flag' ;
    rdfs:comment 'Boolean indicator confirming that all affected employees (operators, production workers) in the area were notified before the LOTO procedure was applied.' ;
    rdfs:domain ind:LotoExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deviationDescription rdf:type rdf:Property ;
    rdfs:label 'Deviation Description' ;
    rdfs:comment 'Detailed description of any deviations from the standard LOTO procedure, including reasons for the deviation and compensating controls applied. Required for audit trail when deviations occur.' ;
    rdfs:domain ind:LotoExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviationFromProcedureFlag rdf:type rdf:Property ;
    rdfs:label 'Deviation From Procedure Flag' ;
    rdfs:comment 'Boolean indicator identifying whether any deviations from the standard LOTO procedure occurred during this execution. Triggers additional review and documentation requirements.' ;
    rdfs:domain ind:LotoExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:employeesNotifiedOfRestorationFlag rdf:type rdf:Property ;
    rdfs:label 'Employees Notified Of Restoration Flag' ;
    rdfs:comment 'Boolean indicator confirming that all affected employees were notified that lockout devices are being removed and equipment is being returned to service.' ;
    rdfs:domain ind:LotoExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:energySourcesIsolated rdf:type rdf:Property ;
    rdfs:label 'Energy Sources Isolated' ;
    rdfs:comment 'Comma-separated list of all energy sources that were isolated during this LOTO execution (electrical, hydraulic, pneumatic, mechanical, thermal, chemical, gravitational). Documents all hazardous energy types controlled.' ;
    rdfs:domain ind:LotoExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentInspectionBeforeRestorationFlag rdf:type rdf:Property ;
    rdfs:label 'Equipment Inspection Before Restoration Flag' ;
    rdfs:comment 'Boolean indicator confirming that the authorized employee inspected the equipment and work area to ensure all tools, parts, and personnel are clear before restoring energy.' ;
    rdfs:domain ind:LotoExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:executionNumber rdf:type rdf:Property ;
    rdfs:label 'Execution Number' ;
    rdfs:comment 'Human-readable business identifier for this LOTO execution event. Typically formatted as facility code, date, and sequence number for audit trail purposes.' ;
    rdfs:domain ind:LotoExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupLockoutFlag rdf:type rdf:Property ;
    rdfs:label 'Group Lockout Flag' ;
    rdfs:comment 'Boolean indicator identifying whether this LOTO execution involved multiple authorized employees working simultaneously on the same equipment, requiring group lockout procedures.' ;
    rdfs:domain ind:LotoExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incidentOccurredFlag rdf:type rdf:Property ;
    rdfs:label 'Incident Occurred Flag' ;
    rdfs:comment 'Boolean indicator identifying whether any safety incident, near-miss, or equipment damage occurred during this LOTO execution. Triggers incident investigation procedures.' ;
    rdfs:domain ind:LotoExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isolationPointsCount rdf:type rdf:Property ;
    rdfs:label 'Isolation Points Count' ;
    rdfs:comment 'Total number of energy isolation points (circuit breakers, valves, switches, disconnects) that were locked out during this execution. Used for verification completeness.' ;
    rdfs:domain ind:LotoExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lockSerialNumbers rdf:type rdf:Property ;
    rdfs:label 'Lock Serial Numbers' ;
    rdfs:comment 'Comma-separated list of unique serial numbers for all physical locks applied to energy isolation devices. Enables tracking of individual lock inventory and assignment.' ;
    rdfs:domain ind:LotoExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lockoutCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Lockout Completion Timestamp' ;
    rdfs:comment 'Date and time when all energy isolation devices were successfully applied and locked, and the equipment was confirmed in a zero-energy state.' ;
    rdfs:domain ind:LotoExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lockoutDevicesApplied rdf:type rdf:Property ;
    rdfs:label 'Lockout Devices Applied' ;
    rdfs:comment 'Detailed list of lockout devices applied including lock serial numbers, tag numbers, and isolation point locations. Provides auditable record of physical lockout hardware used.' ;
    rdfs:domain ind:LotoExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lockoutStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Lockout Start Timestamp' ;
    rdfs:comment 'Date and time when the authorized employee initiated the LOTO procedure and began applying lockout devices to energy isolation points. Principal business event timestamp for this transaction.' ;
    rdfs:domain ind:LotoExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:restorationCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Restoration Completion Timestamp' ;
    rdfs:comment 'Date and time when all lockout devices were removed, energy sources were restored, and the equipment was returned to normal operational status.' ;
    rdfs:domain ind:LotoExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:restorationStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Restoration Start Timestamp' ;
    rdfs:comment 'Date and time when the authorized employee began the procedure to restore energy sources and remove lockout devices after work completion.' ;
    rdfs:domain ind:LotoExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shiftChangeFlag rdf:type rdf:Property ;
    rdfs:label 'Shift Change Flag' ;
    rdfs:comment 'Boolean indicator identifying whether this LOTO execution spanned multiple work shifts, requiring special shift-change procedures to maintain continuous protection.' ;
    rdfs:domain ind:LotoExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tagNumbers rdf:type rdf:Property ;
    rdfs:label 'Tag Numbers' ;
    rdfs:comment 'Comma-separated list of unique tag identification numbers affixed to locked-out equipment. Tags provide warning information and identify the authorized employee.' ;
    rdfs:domain ind:LotoExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalLockoutDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Total Lockout Duration Minutes' ;
    rdfs:comment 'Total elapsed time in minutes from lockout initiation to restoration completion. Used for operational efficiency analysis and downtime tracking.' ;
    rdfs:domain ind:LotoExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:workDescription rdf:type rdf:Property ;
    rdfs:label 'Work Description' ;
    rdfs:comment 'Detailed description of the maintenance, repair, cleaning, or servicing work being performed on the equipment under lockout conditions. Explains why energy isolation was required.' ;
    rdfs:domain ind:LotoExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workType rdf:type rdf:Property ;
    rdfs:label 'Work Type' ;
    rdfs:comment 'Classification of the work activity being performed under LOTO protection. Categorizes the nature of the maintenance or servicing task. [ENUM-REF-CANDIDATE: preventive_maintenance|corrective_maintenance|repair|cleaning|inspection|modification|installation|decommissioning — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LotoExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zeroEnergyVerificationMethod rdf:type rdf:Property ;
    rdfs:label 'Zero Energy Verification Method' ;
    rdfs:comment 'Method used to verify that all energy sources have been effectively isolated and the equipment is in a zero-energy or zero-potential state before work begins. [ENUM-REF-CANDIDATE: visual_inspection|meter_reading|test_equipment|operational_test|pressure_gauge|voltage_tester|multimeter|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LotoExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zeroEnergyVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Zero Energy Verified Flag' ;
    rdfs:comment 'Boolean indicator confirming that the authorized employee verified the equipment is in a zero-energy state and safe for work to proceed. Critical safety checkpoint.' ;
    rdfs:domain ind:LotoExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:medicalCaseId rdf:type rdf:Property ;
    rdfs:label 'Medical Case Id' ;
    rdfs:comment 'Unique identifier for the occupational medical case record. Primary key for the medical case management system.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MedicalCase .

ind:medicalManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Medical Manager Employee Id' ;
    rdfs:comment 'Identifier of the internal safety or HR professional assigned to manage this medical case and coordinate return-to-work activities.' ;
    rdfs:domain ind:MedicalCase ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryMedicalEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Medical Employee Id' ;
    rdfs:comment 'Identifier of the Waste Management employee who received medical treatment for the work-related injury or illness.' ;
    rdfs:domain ind:MedicalCase ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:treatingProviderVendorId rdf:type rdf:Property ;
    rdfs:label 'Treating Provider Vendor Id' ;
    rdfs:comment 'Foreign key linking to procurement.vendor. Business justification: Medical treatment providers must link to vendor master for workers\' comp cost allocation, provider network management, payment processing, 1099 reporting, and provider qualification verification. Repl' ;
    rdfs:domain ind:MedicalCase ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:actualMedicalCost rdf:type rdf:Property ;
    rdfs:label 'Actual Medical Cost' ;
    rdfs:comment 'Total actual medical expenses incurred for treatment of this case, including all provider bills, pharmacy, and rehabilitation costs.' ;
    rdfs:domain ind:MedicalCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:caseClosureDate rdf:type rdf:Property ;
    rdfs:label 'Case Closure Date' ;
    rdfs:comment 'Date when the medical case was officially closed after the employee returned to full duty and all medical treatment was completed.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:caseNotes rdf:type rdf:Property ;
    rdfs:label 'Case Notes' ;
    rdfs:comment 'Free-text notes documenting case management activities, physician communications, accommodation discussions, and return-to-work coordination efforts.' ;
    rdfs:domain ind:MedicalCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseStatus rdf:type rdf:Property ;
    rdfs:label 'Case Status' ;
    rdfs:comment 'Current lifecycle status of the medical case indicating whether the case is actively being managed, pending closure, or has been closed.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diagnosisCode rdf:type rdf:Property ;
    rdfs:label 'Diagnosis Code' ;
    rdfs:comment 'ICD-10 or other standardized medical diagnosis code assigned by the treating provider describing the injury or illness.' ;
    rdfs:domain ind:MedicalCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diagnosisDescription rdf:type rdf:Property ;
    rdfs:label 'Diagnosis Description' ;
    rdfs:comment 'Plain language description of the diagnosed injury or illness provided by the medical professional.' ;
    rdfs:domain ind:MedicalCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedMedicalCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Medical Cost' ;
    rdfs:comment 'Projected total medical treatment cost for this case based on initial diagnosis and treatment plan. Used for workers compensation reserve setting.' ;
    rdfs:domain ind:MedicalCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fullDutyReturnDate rdf:type rdf:Property ;
    rdfs:label 'Full Duty Return Date' ;
    rdfs:comment 'Date when the employee was medically cleared to return to full unrestricted duty without limitations.' ;
    rdfs:domain ind:MedicalCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:hospitalizationDurationDays rdf:type rdf:Property ;
    rdfs:label 'Hospitalization Duration Days' ;
    rdfs:comment 'Number of days the employee was hospitalized as an inpatient for treatment of the work-related injury or illness.' ;
    rdfs:domain ind:MedicalCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hospitalizationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Hospitalization Required Flag' ;
    rdfs:comment 'Indicates whether the injury or illness required inpatient hospitalization. Triggers additional OSHA reporting requirements for severe injuries.' ;
    rdfs:domain ind:MedicalCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:initialTreatmentDate rdf:type rdf:Property ;
    rdfs:label 'Initial Treatment Date' ;
    rdfs:comment 'Date when the employee first received medical treatment for the work-related injury or illness. Critical timestamp for OSHA recordkeeping and workers compensation claim initiation.' ;
    rdfs:domain ind:MedicalCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:initialTreatmentTime rdf:type rdf:Property ;
    rdfs:label 'Initial Treatment Time' ;
    rdfs:comment 'Precise timestamp when initial medical treatment was administered, including time of day for emergency response tracking.' ;
    rdfs:domain ind:MedicalCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:injuryNature rdf:type rdf:Property ;
    rdfs:label 'Injury Nature' ;
    rdfs:comment 'Classification of the type of physical harm or illness sustained (e.g., laceration, fracture, strain, chemical exposure, respiratory condition).' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oshaCaseClassification rdf:type rdf:Property ;
    rdfs:label 'Osha Case Classification' ;
    rdfs:comment 'OSHA classification category for the medical case used for OSHA 300 log reporting and regulatory compliance.' ;
    rdfs:domain ind:MedicalCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:physicalTherapyRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Physical Therapy Required Flag' ;
    rdfs:comment 'Indicates whether ongoing physical therapy or rehabilitation was prescribed as part of the treatment plan.' ;
    rdfs:domain ind:MedicalCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:privacyCaseFlag rdf:type rdf:Property ;
    rdfs:label 'Privacy Case Flag' ;
    rdfs:comment 'Indicates whether this case qualifies as a privacy concern case under OSHA rules, requiring special handling of employee identity information on posted logs.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:returnToWorkDate rdf:type rdf:Property ;
    rdfs:label 'Return To Work Date' ;
    rdfs:comment 'Date when the employee returned to any work capacity following the injury or illness. May differ from full duty return date if light duty was assigned.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:surgeryDate rdf:type rdf:Property ;
    rdfs:label 'Surgery Date' ;
    rdfs:comment 'Date when surgical procedure was performed to treat the work-related injury or illness.' ;
    rdfs:domain ind:MedicalCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:surgeryRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Surgery Required Flag' ;
    rdfs:comment 'Indicates whether surgical intervention was required to treat the injury or illness. Impacts case severity classification and cost projections.' ;
    rdfs:domain ind:MedicalCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalDaysAway rdf:type rdf:Property ;
    rdfs:label 'Total Days Away' ;
    rdfs:comment 'Total number of calendar days the employee was unable to work due to the injury or illness. Used for OSHA 300 log column G reporting.' ;
    rdfs:domain ind:MedicalCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalDaysRestricted rdf:type rdf:Property ;
    rdfs:label 'Total Days Restricted' ;
    rdfs:comment 'Total number of calendar days the employee worked under physician-imposed restrictions or modified duty. Used for OSHA 300 log column H and I reporting.' ;
    rdfs:domain ind:MedicalCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:treatingProviderType rdf:type rdf:Property ;
    rdfs:label 'Treating Provider Type' ;
    rdfs:comment 'Classification of the medical facility or provider type that delivered treatment to the employee.' ;
    rdfs:domain ind:MedicalCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatmentType rdf:type rdf:Property ;
    rdfs:label 'Treatment Type' ;
    rdfs:comment 'Classification of the level of medical care provided. Determines OSHA recordability and workers compensation case classification.' ;
    rdfs:domain ind:MedicalCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workRestrictionEndDate rdf:type rdf:Property ;
    rdfs:label 'Work Restriction End Date' ;
    rdfs:comment 'Date when work restrictions were lifted or the employee returned to full duty. Nullable for ongoing restrictions.' ;
    rdfs:domain ind:MedicalCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:workRestrictionStartDate rdf:type rdf:Property ;
    rdfs:label 'Work Restriction Start Date' ;
    rdfs:comment 'Date when physician-imposed work restrictions or days away from work began. Used to calculate total restricted or away days for OSHA reporting.' ;
    rdfs:domain ind:MedicalCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:workRestrictionType rdf:type rdf:Property ;
    rdfs:label 'Work Restriction Type' ;
    rdfs:comment 'Classification of work limitations imposed by the treating physician. Determines OSHA 300 log column classification and return-to-work planning.' ;
    rdfs:domain ind:MedicalCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workersCompClaimStatus rdf:type rdf:Property ;
    rdfs:label 'Workers Comp Claim Status' ;
    rdfs:comment 'Current status of the associated workers compensation insurance claim.' ;
    rdfs:domain ind:MedicalCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryNearReportingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Near Reporting Employee Id' ;
    rdfs:comment 'Identifier of the employee who reported or observed the near-miss event.' ;
    rdfs:domain ind:NearMiss ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryNearCorrectiveActionOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Near Corrective Action Owner Employee Id' ;
    rdfs:comment 'Identifier of the employee responsible for implementing and completing the corrective actions.' ;
    rdfs:domain ind:NearMiss ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:correctiveActionCompleteDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Complete Date' ;
    rdfs:comment 'Actual date when all corrective actions were completed and verified.' ;
    rdfs:domain ind:NearMiss ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:equipmentInvolved rdf:type rdf:Property ;
    rdfs:label 'Equipment Involved' ;
    rdfs:comment 'Description or identifier of equipment, vehicles, or machinery involved in the near-miss event.' ;
    rdfs:domain ind:NearMiss ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:immediateActionTaken rdf:type rdf:Property ;
    rdfs:label 'Immediate Action Taken' ;
    rdfs:comment 'Description of the immediate corrective actions taken at the time of the near-miss to prevent recurrence or mitigate the hazard.' ;
    rdfs:domain ind:NearMiss ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationCompleteDate rdf:type rdf:Property ;
    rdfs:label 'Investigation Complete Date' ;
    rdfs:comment 'The date when the investigation was completed and findings were documented.' ;
    rdfs:domain ind:NearMiss ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nearMissDescription rdf:type rdf:Property ;
    rdfs:label 'Near Miss Description' ;
    rdfs:comment 'Comprehensive narrative description of the near-miss event, including what happened, how it was avoided, and any contributing factors.' ;
    rdfs:domain ind:NearMiss ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nearMissNumber rdf:type rdf:Property ;
    rdfs:label 'Near Miss Number' ;
    rdfs:comment 'Business identifier for the near-miss event, typically formatted as a human-readable tracking number used in safety reports and investigations.' ;
    rdfs:domain ind:NearMiss ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oshaRecordablePotentialFlag rdf:type rdf:Property ;
    rdfs:label 'Osha Recordable Potential Flag' ;
    rdfs:comment 'Indicates whether the near-miss had the potential to result in an OSHA recordable injury or illness if it had escalated. True if recordable potential, False otherwise.' ;
    rdfs:domain ind:NearMiss ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:potentialInjuryType rdf:type rdf:Property ;
    rdfs:label 'Potential Injury Type' ;
    rdfs:comment 'Description of the type of injury that could have occurred if the near-miss had resulted in harm, such as laceration, fracture, burn, or respiratory exposure.' ;
    rdfs:domain ind:NearMiss ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:potentialSeverity rdf:type rdf:Property ;
    rdfs:label 'Potential Severity' ;
    rdfs:comment 'Assessment of the potential severity of injury, illness, or property damage if the near-miss event had resulted in an actual incident, used for risk prioritization.' ;
    rdfs:domain ind:NearMiss ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supervisorNotifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Supervisor Notified Flag' ;
    rdfs:comment 'Indicates whether the immediate supervisor was notified of the near-miss event at the time it occurred. True if notified, False otherwise.' ;
    rdfs:domain ind:NearMiss ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workActivity rdf:type rdf:Property ;
    rdfs:label 'Work Activity' ;
    rdfs:comment 'Detailed description of the specific work activity or task being performed at the time of the near-miss event.' ;
    rdfs:domain ind:NearMiss ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oshaRecordableId rdf:type rdf:Property ;
    rdfs:label 'Osha Recordable Id' ;
    rdfs:comment 'Unique identifier for the OSHA 300 Log recordable case record.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OshaRecordable .

ind:daysOfJobTransferOrRestriction rdf:type rdf:Property ;
    rdfs:label 'Days Of Job Transfer Or Restriction' ;
    rdfs:comment 'Total number of calendar days the employee was on restricted work activity or temporary job transfer due to the injury or illness.' ;
    rdfs:domain ind:OshaRecordable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deathFlag rdf:type rdf:Property ;
    rdfs:label 'Death Flag' ;
    rdfs:comment 'Indicates whether the injury or illness resulted in the death of the employee.' ;
    rdfs:domain ind:OshaRecordable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:establishmentName rdf:type rdf:Property ;
    rdfs:label 'Establishment Name' ;
    rdfs:comment 'The name of the establishment (facility or site) where the injury or illness occurred, as it appears on OSHA reporting.' ;
    rdfs:domain ind:OshaRecordable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventExposureType rdf:type rdf:Property ;
    rdfs:label 'Event Exposure Type' ;
    rdfs:comment 'The event or exposure that directly produced the injury or illness (e.g., struck by object, fall from elevation, overexertion, contact with chemical, repetitive motion).' ;
    rdfs:domain ind:OshaRecordable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:injuryIllnessDate rdf:type rdf:Property ;
    rdfs:label 'Injury Illness Date' ;
    rdfs:comment 'The date the work-related injury occurred or the date the occupational illness was diagnosed or first manifested.' ;
    rdfs:domain ind:OshaRecordable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:injuryIllnessDescription rdf:type rdf:Property ;
    rdfs:label 'Injury Illness Description' ;
    rdfs:comment 'Detailed narrative description of the injury or illness, including the part of body affected and the nature of the injury or illness (e.g., laceration to left hand, chemical burn to forearm, lower back strain).' ;
    rdfs:domain ind:OshaRecordable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:injuryIllnessTime rdf:type rdf:Property ;
    rdfs:label 'Injury Illness Time' ;
    rdfs:comment 'The time of day when the injury occurred or illness symptoms first appeared, in 24-hour HH:MM format.' ;
    rdfs:domain ind:OshaRecordable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:locationWhereEventOccurred rdf:type rdf:Property ;
    rdfs:label 'Location Where Event Occurred' ;
    rdfs:comment 'Specific location or area within the facility where the injury or illness event took place (e.g., loading dock, landfill cell 5, MRF sorting line 2, vehicle cab).' ;
    rdfs:domain ind:OshaRecordable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lossOfConsciousnessFlag rdf:type rdf:Property ;
    rdfs:label 'Loss Of Consciousness Flag' ;
    rdfs:comment 'Indicates whether the employee lost consciousness as a result of the work-related injury or illness.' ;
    rdfs:domain ind:OshaRecordable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:medicalTreatmentBeyondFirstAidFlag rdf:type rdf:Property ;
    rdfs:label 'Medical Treatment Beyond First Aid Flag' ;
    rdfs:comment 'Indicates whether the injury or illness required medical treatment beyond first aid as defined in 29 CFR 1904.7(b)(5).' ;
    rdfs:domain ind:OshaRecordable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:osha300aReportingYear rdf:type rdf:Property ;
    rdfs:label 'Osha 300a Reporting Year' ;
    rdfs:comment 'The calendar year for which this case will be included in the annual OSHA 300A summary report.' ;
    rdfs:domain ind:OshaRecordable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:oshaCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Osha Case Number' ;
    rdfs:comment 'The official OSHA 300 Log case number assigned to this recordable injury or illness, typically formatted as year-sequence (e.g., 2024-0001).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oshaCaseType rdf:type rdf:Property ;
    rdfs:label 'Osha Case Type' ;
    rdfs:comment 'Classification of the recordable case into one of the six OSHA 300 Log categories as defined in 29 CFR 1904.12.' ;
    rdfs:domain ind:OshaRecordable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:physicianRecommendationFlag rdf:type rdf:Property ;
    rdfs:label 'Physician Recommendation Flag' ;
    rdfs:comment 'Indicates whether a physician or licensed health care professional recommended days away from work or work restriction/transfer.' ;
    rdfs:domain ind:OshaRecordable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ppeUsed rdf:type rdf:Property ;
    rdfs:label 'Ppe Used' ;
    rdfs:comment 'Description of the personal protective equipment the employee was wearing or using at the time of the incident.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordableDeterminationBy rdf:type rdf:Property ;
    rdfs:label 'Recordable Determination By' ;
    rdfs:comment 'Name or identifier of the safety professional who made the recordability determination.' ;
    rdfs:domain ind:OshaRecordable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordableDeterminationDate rdf:type rdf:Property ;
    rdfs:label 'Recordable Determination Date' ;
    rdfs:comment 'The date when the safety team determined that the incident met OSHA recordability criteria under 29 CFR 1904.7.' ;
    rdfs:domain ind:OshaRecordable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remainedAtWorkFlag rdf:type rdf:Property ;
    rdfs:label 'Remained At Work Flag' ;
    rdfs:comment 'Indicates whether the employee remained at work and continued their normal duties without any days away or job transfer/restriction.' ;
    rdfs:domain ind:OshaRecordable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceOfInjury rdf:type rdf:Property ;
    rdfs:label 'Source Of Injury' ;
    rdfs:comment 'The object, substance, or equipment that directly produced or inflicted the injury or illness (e.g., waste container, truck tailgate, chemical substance, machinery).' ;
    rdfs:domain ind:OshaRecordable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatingPhysicianName rdf:type rdf:Property ;
    rdfs:label 'Treating Physician Name' ;
    rdfs:comment 'Name of the physician or licensed health care professional who provided treatment for the injury or illness.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workProcessAtTimeOfIncident rdf:type rdf:Property ;
    rdfs:label 'Work Process At Time Of Incident' ;
    rdfs:comment 'The work activity or process the employee was performing when the injury or illness occurred (e.g., residential route collection, landfill compaction, MRF sorting, vehicle maintenance).' ;
    rdfs:domain ind:OshaRecordable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingFacilityId rdf:type rdf:Property ;
    rdfs:label 'Issuing Facility Id' ;
    rdfs:comment 'Identifier of the Waste Management facility, storeroom, or distribution center from which the PPE was issued.' ;
    rdfs:domain ind:PpeIssuance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:primaryPpeEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Ppe Employee Id' ;
    rdfs:comment 'Identifier of the Waste Management employee receiving the PPE items.' ;
    rdfs:domain ind:PpeIssuance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:replacedPpeIssuanceId rdf:type rdf:Property ;
    rdfs:label 'Replaced Ppe Issuance Id' ;
    rdfs:comment 'Reference to the prior PPE issuance record if this issuance is a replacement for worn, damaged, or lost equipment.' ;
    rdfs:domain ind:PpeIssuance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PpeIssuance .

ind:acknowledgmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Timestamp' ;
    rdfs:comment 'Date and time when the employee signed acknowledgment of PPE receipt.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:certificationStandard rdf:type rdf:Property ;
    rdfs:label 'Certification Standard' ;
    rdfs:comment 'Industry or regulatory certification standard met by the PPE item (e.g., ANSI Z87.1 for eye protection, ANSI Z89.1 for hard hats, NIOSH for respirators).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeAcknowledgmentSignature rdf:type rdf:Property ;
    rdfs:label 'Employee Acknowledgment Signature' ;
    rdfs:comment 'Digital or scanned signature of the employee acknowledging receipt of the PPE items.' ;
    rdfs:domain ind:PpeIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedReplacementDate rdf:type rdf:Property ;
    rdfs:label 'Expected Replacement Date' ;
    rdfs:comment 'Anticipated date when the PPE item will need to be replaced based on manufacturer specifications and usage patterns.' ;
    rdfs:domain ind:PpeIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fitTestResult rdf:type rdf:Property ;
    rdfs:label 'Fit Test Result' ;
    rdfs:comment 'Result of the fit test for respiratory protection equipment.' ;
    rdfs:domain ind:PpeIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Inspection Required Flag' ;
    rdfs:comment 'Indicates whether the PPE item requires periodic inspection per manufacturer or regulatory requirements.' ;
    rdfs:domain ind:PpeIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuanceNumber rdf:type rdf:Property ;
    rdfs:label 'Issuance Number' ;
    rdfs:comment 'Business-readable unique identifier for the PPE issuance transaction, formatted as PPE-YYYYMMDD-NNNN.' ;
    rdfs:domain ind:PpeIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuanceReason rdf:type rdf:Property ;
    rdfs:label 'Issuance Reason' ;
    rdfs:comment 'Business reason for issuing the PPE to the employee. [ENUM-REF-CANDIDATE: new_hire|replacement_worn|replacement_damaged|replacement_lost|seasonal|special_project|regulatory_requirement — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PpeIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuanceTimestamp rdf:type rdf:Property ;
    rdfs:label 'Issuance Timestamp' ;
    rdfs:comment 'Precise date and time when the PPE issuance transaction was recorded in the system.' ;
    rdfs:domain ind:PpeIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:issuingLocationName rdf:type rdf:Property ;
    rdfs:label 'Issuing Location Name' ;
    rdfs:comment 'Name of the facility, storeroom, or distribution center from which the PPE was issued.' ;
    rdfs:domain ind:PpeIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnCondition rdf:type rdf:Property ;
    rdfs:label 'Return Condition' ;
    rdfs:comment 'Condition of the PPE item when returned by the employee.' ;
    rdfs:domain ind:PpeIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:size rdf:type rdf:Property ;
    rdfs:label 'Size' ;
    rdfs:comment 'Size specification of the PPE item issued (e.g., S, M, L, XL, 2XL, numeric sizes for gloves/boots).' ;
    rdfs:domain ind:PpeIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Training Completion Date' ;
    rdfs:comment 'Date when the employee completed required PPE usage training for the issued equipment type.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:workLocationType rdf:type rdf:Property ;
    rdfs:label 'Work Location Type' ;
    rdfs:comment 'Type of work location where the employee will use the issued PPE. [ENUM-REF-CANDIDATE: collection_route|landfill|mrf|transfer_station|hazmat_facility|maintenance_shop|office — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertId rdf:type rdf:Property ;
    rdfs:label 'Alert Id' ;
    rdfs:comment 'Unique identifier for the safety alert record. Primary key.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Alert .

ind:affectedWasteStreamId rdf:type rdf:Property ;
    rdfs:label 'Affected Waste Stream Id' ;
    rdfs:comment 'Foreign key linking to service.service_waste_stream. Business justification: Alerts are waste-stream-specific (alert about reactive chemicals in industrial waste stream, alert about infectious materials in medical waste). Safety teams issue stream-specific alerts; operations t' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WasteStream .

ind:alertApprovingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Alert Approving Employee Id' ;
    rdfs:comment 'Senior safety or operations leader who approved the issuance of this safety alert. Required for critical and high-severity alerts.' ;
    rdfs:domain ind:Alert ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:alertIssuingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Alert Issuing Employee Id' ;
    rdfs:comment 'Employee who authored and issued this safety alert. Typically a safety manager, EHS director, or corporate safety officer.' ;
    rdfs:domain ind:Alert ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primarySupersededByAlertId rdf:type rdf:Property ;
    rdfs:label 'Primary Superseded By Alert Id' ;
    rdfs:comment 'Reference to the newer safety alert that replaces this one. Populated when an alert is superseded by updated guidance or corrected information.' ;
    rdfs:domain ind:Alert ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Alert .

ind:acknowledgedCount rdf:type rdf:Property ;
    rdfs:label 'Acknowledged Count' ;
    rdfs:comment 'Number of recipients who have acknowledged the safety alert. Updated as acknowledgments are received. Used to track compliance progress.' ;
    rdfs:domain ind:Alert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:acknowledgmentDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Deadline Date' ;
    rdfs:comment 'Date by which all required recipients must acknowledge the safety alert. Used to track compliance and escalate non-acknowledgments.' ;
    rdfs:domain ind:Alert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:acknowledgmentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Required Flag' ;
    rdfs:comment 'Indicates whether recipients must formally acknowledge receipt and understanding of this safety alert. True for critical and high-severity alerts.' ;
    rdfs:domain ind:Alert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:affectedFacilityTypes rdf:type rdf:Property ;
    rdfs:label 'Affected Facility Types' ;
    rdfs:comment 'Comma-separated list of facility types to which this safety alert applies (e.g., transfer station, landfill, MRF, maintenance shop, hazmat TSDF). Used for targeted distribution.' ;
    rdfs:domain ind:Alert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedOperationTypes rdf:type rdf:Property ;
    rdfs:label 'Affected Operation Types' ;
    rdfs:comment 'Comma-separated list of operation types to which this safety alert applies (e.g., residential collection, commercial hauling, landfill operations, MRF processing, hazmat handling). Determines distribution scope.' ;
    rdfs:domain ind:Alert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertDescription rdf:type rdf:Property ;
    rdfs:label 'Alert Description' ;
    rdfs:comment 'Detailed narrative describing the hazard, incident background, lessons learned, regulatory requirements, or safety directive. Provides full context and guidance for field operations.' ;
    rdfs:domain ind:Alert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertNumber rdf:type rdf:Property ;
    rdfs:label 'Alert Number' ;
    rdfs:comment 'Business identifier for the safety alert, formatted as SA-YYYY-NNNNN where YYYY is the year and NNNNN is a sequential number. Used for external communication and reference.' ;
    rdfs:domain ind:Alert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertStatus rdf:type rdf:Property ;
    rdfs:label 'Alert Status' ;
    rdfs:comment 'Current lifecycle status of the safety alert. Tracks the alert from creation through acknowledgment to closure.' ;
    rdfs:domain ind:Alert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertType rdf:type rdf:Property ;
    rdfs:label 'Alert Type' ;
    rdfs:comment 'Classification of the safety alert indicating the nature of the hazard or communication. Determines the urgency and distribution requirements.' ;
    rdfs:domain ind:Alert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attachmentCount rdf:type rdf:Property ;
    rdfs:label 'Attachment Count' ;
    rdfs:comment 'Number of supporting documents, images, or files attached to this safety alert. Used to indicate availability of supplemental materials.' ;
    rdfs:domain ind:Alert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:correctiveActionsRequired rdf:type rdf:Property ;
    rdfs:label 'Corrective Actions Required' ;
    rdfs:comment 'Description of specific corrective actions, procedural changes, or control measures that must be implemented in response to this alert. Provides actionable guidance.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionDistrictCodes rdf:type rdf:Property ;
    rdfs:label 'Distribution District Codes' ;
    rdfs:comment 'Comma-separated list of district codes where this alert applies. Populated when distribution_scope is district or facility. Enables district-level targeting.' ;
    rdfs:domain ind:Alert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionFacilityCodes rdf:type rdf:Property ;
    rdfs:label 'Distribution Facility Codes' ;
    rdfs:comment 'Comma-separated list of facility codes where this alert applies. Populated when distribution_scope is facility. Enables facility-specific targeting.' ;
    rdfs:domain ind:Alert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionRegionCodes rdf:type rdf:Property ;
    rdfs:label 'Distribution Region Codes' ;
    rdfs:comment 'Comma-separated list of region codes where this alert applies. Populated when distribution_scope is region or narrower. Enables regional targeting.' ;
    rdfs:domain ind:Alert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionScope rdf:type rdf:Property ;
    rdfs:label 'Distribution Scope' ;
    rdfs:comment 'Geographic or organizational scope defining who must receive and acknowledge this safety alert. Determines the audience breadth.' ;
    rdfs:domain ind:Alert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalRecipientsCount rdf:type rdf:Property ;
    rdfs:label 'Total Recipients Count' ;
    rdfs:comment 'Total number of employees or recipients to whom this safety alert was distributed. Used to calculate acknowledgment completion percentage.' ;
    rdfs:domain ind:Alert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:version rdf:type rdf:Property ;
    rdfs:label 'Version' ;
    rdfs:comment 'Version number of the safety alert document. Incremented when the alert is revised or updated. Format: major.minor (e.g., 1.0, 1.1, 2.0).' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertAcknowledgmentId rdf:type rdf:Property ;
    rdfs:label 'Alert Acknowledgment Id' ;
    rdfs:comment 'Unique identifier for the safety alert acknowledgment record. Primary key for tracking individual employee acknowledgments of safety alerts and bulletins.' ;
    rdfs:domain ind:AlertAcknowledgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryAlertEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Alert Employee Id' ;
    rdfs:comment 'Unique identifier of the employee who acknowledged the safety alert. Links to the employee master record to track individual compliance with safety communications.' ;
    rdfs:domain ind:AlertAcknowledgment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:acknowledgmentDate rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Date' ;
    rdfs:comment 'The date on which the employee acknowledged receipt and understanding of the safety alert. Critical for tracking distribution effectiveness and compliance timelines.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:acknowledgmentDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Duration Minutes' ;
    rdfs:comment 'The time in minutes that the employee spent reviewing the safety alert before acknowledging. Helps assess engagement level and comprehension time for safety communications.' ;
    rdfs:domain ind:AlertAcknowledgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:acknowledgmentLocation rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Location' ;
    rdfs:comment 'Specific location or area within the facility where the acknowledgment was collected. Provides context for safety alert distribution and helps track field-based acknowledgments.' ;
    rdfs:domain ind:AlertAcknowledgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acknowledgmentMethod rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Method' ;
    rdfs:comment 'The method or channel through which the employee acknowledged the safety alert. Indicates whether acknowledgment was captured digitally, via paper sign-off, during toolbox talk delivery, or through other communication channels.' ;
    rdfs:domain ind:AlertAcknowledgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acknowledgmentNotes rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Notes' ;
    rdfs:comment 'Free-text notes or comments recorded during the acknowledgment process. May include employee questions, concerns, clarifications, or supervisor observations about the acknowledgment session.' ;
    rdfs:domain ind:AlertAcknowledgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acknowledgmentStatus rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Status' ;
    rdfs:comment 'Current status of the acknowledgment record. Tracks whether the employee has completed acknowledgment, is pending, overdue, or has been waived or exempted from the requirement.' ;
    rdfs:domain ind:AlertAcknowledgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdlHolderFlag rdf:type rdf:Property ;
    rdfs:label 'Cdl Holder Flag' ;
    rdfs:comment 'Indicates whether the employee holds a Commercial Driver License at the time of acknowledgment. True if employee is a CDL holder, false otherwise. Important for tracking DOT-regulated driver safety communications.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:comprehensionVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Comprehension Verified Flag' ;
    rdfs:comment 'Indicates whether employee comprehension of the safety alert content was verified through testing, verbal confirmation, or other assessment method. True if comprehension was verified, false otherwise.' ;
    rdfs:domain ind:AlertAcknowledgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:departmentCode rdf:type rdf:Property ;
    rdfs:label 'Department Code' ;
    rdfs:comment 'Code identifying the department or business unit to which the employee belongs. Enables departmental safety compliance tracking and targeted safety communications.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geolocationLatitude rdf:type rdf:Property ;
    rdfs:label 'Geolocation Latitude' ;
    rdfs:comment 'Latitude coordinate where the acknowledgment was captured, if location services were enabled. Helps verify field-based acknowledgments and track mobile workforce compliance.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geolocationLongitude rdf:type rdf:Property ;
    rdfs:label 'Geolocation Longitude' ;
    rdfs:comment 'Longitude coordinate where the acknowledgment was captured, if location services were enabled. Helps verify field-based acknowledgments and track mobile workforce compliance.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hazmatCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Certified Flag' ;
    rdfs:comment 'Indicates whether the employee holds current hazardous materials handling certification. True if HAZMAT certified, false otherwise. Critical for tracking safety communications to hazmat-qualified personnel.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incidentRelatedFlag rdf:type rdf:Property ;
    rdfs:label 'Incident Related Flag' ;
    rdfs:comment 'Indicates whether this safety alert acknowledgment is related to a specific safety incident or near-miss event. True if incident-related, false if routine safety communication.' ;
    rdfs:domain ind:AlertAcknowledgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ipAddress rdf:type rdf:Property ;
    rdfs:label 'Ip Address' ;
    rdfs:comment 'IP address of the device used to submit the digital acknowledgment. Provides technical audit trail for electronic acknowledgments and helps verify authenticity.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oshaComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Osha Compliance Flag' ;
    rdfs:comment 'Indicates whether this acknowledgment satisfies a specific OSHA training or communication requirement. True if OSHA-mandated, false if internal safety initiative.' ;
    rdfs:domain ind:AlertAcknowledgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:oshaStandardReference rdf:type rdf:Property ;
    rdfs:label 'Osha Standard Reference' ;
    rdfs:comment 'Citation of the specific OSHA standard or regulation that this safety alert addresses. Provides regulatory traceability for compliance audits and documentation.' ;
    rdfs:domain ind:AlertAcknowledgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ppeRequirementsAcknowledged rdf:type rdf:Property ;
    rdfs:label 'Ppe Requirements Acknowledged' ;
    rdfs:comment 'Comma-separated list of Personal Protective Equipment (PPE) requirements that were specifically acknowledged as part of this safety alert. Documents which PPE items the employee confirmed understanding of.' ;
    rdfs:domain ind:AlertAcknowledgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reminderSentCount rdf:type rdf:Property ;
    rdfs:label 'Reminder Sent Count' ;
    rdfs:comment 'Number of reminder notifications sent to the employee before acknowledgment was completed. Tracks follow-up effort required to achieve compliance.' ;
    rdfs:domain ind:AlertAcknowledgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:signatureCapturedFlag rdf:type rdf:Property ;
    rdfs:label 'Signature Captured Flag' ;
    rdfs:comment 'Indicates whether a physical or digital signature was captured as part of the acknowledgment process. True if signature was obtained, false otherwise.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:signatureImageUrl rdf:type rdf:Property ;
    rdfs:label 'Signature Image Url' ;
    rdfs:comment 'URL or file path to the stored signature image or digital signature artifact. Provides access to the signature evidence for audit and compliance verification.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Signature Timestamp' ;
    rdfs:comment 'Precise date and time when the signature or verification was captured. Provides legal audit trail for acknowledgment verification.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:signatureType rdf:type rdf:Property ;
    rdfs:label 'Signature Type' ;
    rdfs:comment 'The type of signature or verification method used to confirm acknowledgment. Indicates whether signature was electronic, wet (physical), biometric, PIN-based, or verbal confirmation.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingCreditHours rdf:type rdf:Property ;
    rdfs:label 'Training Credit Hours' ;
    rdfs:comment 'Number of training credit hours awarded for acknowledging and reviewing the safety alert. Used for tracking employee training compliance and certification requirements.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:verificationScore rdf:type rdf:Property ;
    rdfs:label 'Verification Score' ;
    rdfs:comment 'Numerical score or percentage achieved on comprehension verification assessment. Used to measure effectiveness of safety communication and identify employees requiring additional training.' ;
    rdfs:domain ind:AlertAcknowledgment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:auditClosedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Audit Closed By Employee Id' ;
    rdfs:comment 'Identifier of the employee who reviewed and closed the audit after verifying completion of all corrective actions.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:auditedOfferingId rdf:type rdf:Property ;
    rdfs:label 'Audited Offering Id' ;
    rdfs:comment 'Foreign key linking to service.offering. Business justification: Safety audits evaluate compliance during specific service delivery operations (auditing hazmat collection procedures, compactor operation safety). Auditors document offering-specific findings; operati' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Offering .

ind:auditDate rdf:type rdf:Property ;
    rdfs:label 'Audit Date' ;
    rdfs:comment 'The date on which the safety audit was conducted or scheduled to be conducted.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditNumber rdf:type rdf:Property ;
    rdfs:label 'Audit Number' ;
    rdfs:comment 'Business identifier for the safety audit, formatted as SA-YYYYMMDD or similar pattern for external reference and tracking.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditScope rdf:type rdf:Property ;
    rdfs:label 'Audit Scope' ;
    rdfs:comment 'Detailed description of the audit scope, including specific areas, processes, equipment, or safety programs evaluated during the audit.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditStatus rdf:type rdf:Property ;
    rdfs:label 'Audit Status' ;
    rdfs:comment 'Current lifecycle status of the safety audit: scheduled (planned but not started), in_progress (audit underway), completed (audit finished but findings open), closed (all findings resolved), or cancelled.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentConditionVerified rdf:type rdf:Property ;
    rdfs:label 'Equipment Condition Verified' ;
    rdfs:comment 'Boolean flag indicating whether the condition and safety features of equipment, vehicles, or machinery were verified during the audit (True if verified, False otherwise).' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:followUpAuditDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Audit Date' ;
    rdfs:comment 'Scheduled date for the follow-up audit to verify corrective action effectiveness and sustained compliance.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:followUpAuditRequired rdf:type rdf:Property ;
    rdfs:label 'Follow Up Audit Required' ;
    rdfs:comment 'Boolean flag indicating whether a follow-up audit is required to verify implementation and effectiveness of corrective actions (True if follow-up needed, False otherwise).' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leadAuditorName rdf:type rdf:Property ;
    rdfs:label 'Lead Auditor Name' ;
    rdfs:comment 'Full name of the lead auditor who conducted the safety audit, for reporting and accountability purposes.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallAuditScore rdf:type rdf:Property ;
    rdfs:label 'Overall Audit Score' ;
    rdfs:comment 'Composite numerical score representing the overall safety performance observed during the audit, typically expressed as a percentage (0.00 to 100.00) or weighted score.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:positiveObservationsCount rdf:type rdf:Property ;
    rdfs:label 'Positive Observations Count' ;
    rdfs:comment 'Number of positive safety observations or best practices identified during the audit that should be recognized and replicated.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ppeComplianceVerified rdf:type rdf:Property ;
    rdfs:label 'Ppe Compliance Verified' ;
    rdfs:comment 'Boolean flag indicating whether PPE (Personal Protective Equipment) compliance was verified during the audit (True if verified, False otherwise).' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rating rdf:type rdf:Property ;
    rdfs:label 'Rating' ;
    rdfs:comment 'Qualitative rating assigned to the audit based on the overall score and findings: excellent, satisfactory, needs improvement, unsatisfactory, or critical.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportable rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reportable' ;
    rdfs:comment 'Boolean flag indicating whether findings from this audit must be reported to regulatory agencies such as OSHA, EPA, or state authorities (True if reportable, False otherwise).' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:teamMembers rdf:type rdf:Property ;
    rdfs:label 'Team Members' ;
    rdfs:comment 'Comma-separated list or narrative description of additional team members who participated in the audit alongside the lead auditor.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Total Findings Count' ;
    rdfs:comment 'Total number of safety findings, observations, or non-conformances identified during the audit, regardless of severity.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trainingComplianceVerified rdf:type rdf:Property ;
    rdfs:label 'Training Compliance Verified' ;
    rdfs:comment 'Boolean flag indicating whether employee safety training compliance was verified during the audit (True if verified, False otherwise).' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incentiveId rdf:type rdf:Property ;
    rdfs:label 'Incentive Id' ;
    rdfs:comment 'Unique identifier for the safety incentive program record. Primary key.' ;
    rdfs:domain ind:Incentive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:incentiveApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Incentive Approved By Employee Id' ;
    rdfs:comment 'Identifier of the employee who approved the safety incentive program (typically a senior safety leader or executive).' ;
    rdfs:domain ind:Incentive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:incentiveProgramCoordinatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Incentive Program Coordinator Employee Id' ;
    rdfs:comment 'Identifier of the employee who coordinates day-to-day administration of the safety incentive program.' ;
    rdfs:domain ind:Incentive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:incentiveProgramOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Incentive Program Owner Employee Id' ;
    rdfs:comment 'Identifier of the employee who owns and is accountable for the safety incentive program (typically a safety manager or director).' ;
    rdfs:domain ind:Incentive ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:applicableOperationTypes rdf:type rdf:Property ;
    rdfs:label 'Applicable Operation Types' ;
    rdfs:comment 'Comma-separated list of operation types eligible for this incentive program (e.g., residential collection, commercial collection, landfill, MRF, hazmat, fleet maintenance, WTE).' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awardDescription rdf:type rdf:Property ;
    rdfs:label 'Award Description' ;
    rdfs:comment 'Detailed description of the award or recognition provided (e.g., gift card, plaque, certificate, paid time off, public recognition).' ;
    rdfs:domain ind:Incentive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awardFrequency rdf:type rdf:Property ;
    rdfs:label 'Award Frequency' ;
    rdfs:comment 'Frequency at which awards are distributed under this program (monthly, quarterly, semi-annual, annual, milestone-based, continuous).' ;
    rdfs:domain ind:Incentive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awardValue rdf:type rdf:Property ;
    rdfs:label 'Award Value' ;
    rdfs:comment 'Monetary value of the incentive award in US dollars (USD). Null for non-monetary recognition programs.' ;
    rdfs:domain ind:Incentive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Amount' ;
    rdfs:comment 'Total budget allocated for this safety incentive program in US dollars (USD) for the program period.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daysWithoutInjuryThreshold rdf:type rdf:Property ;
    rdfs:label 'Days Without Injury Threshold' ;
    rdfs:comment 'Minimum number of consecutive days without a recordable injury required to qualify for the incentive award.' ;
    rdfs:domain ind:Incentive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eligibilityCriteria rdf:type rdf:Property ;
    rdfs:label 'Eligibility Criteria' ;
    rdfs:comment 'Detailed description of the criteria employees or teams must meet to qualify for the incentive (e.g., days without recordable injury, observation participation rate, training completion percentage).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incentiveType rdf:type rdf:Property ;
    rdfs:label 'Incentive Type' ;
    rdfs:comment 'Classification of the incentive program type indicating the recognition mechanism (milestone award, peer recognition, safety bonus, team recognition, individual achievement, department award).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:observationParticipationRateThreshold rdf:type rdf:Property ;
    rdfs:label 'Observation Participation Rate Threshold' ;
    rdfs:comment 'Minimum percentage of required safety observations that must be completed to qualify for the incentive (expressed as percentage, e.g., 85.00 for 85%).' ;
    rdfs:domain ind:Incentive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oshaVppAlignedFlag rdf:type rdf:Property ;
    rdfs:label 'Osha Vpp Aligned Flag' ;
    rdfs:comment 'Indicates whether this incentive program is aligned with OSHA Voluntary Protection Programs (VPP) guidelines and best practices.' ;
    rdfs:domain ind:Incentive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:programDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Program Document Url' ;
    rdfs:comment 'URL or file path to the official program documentation, guidelines, and terms and conditions.' ;
    rdfs:domain ind:Incentive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programNotes rdf:type rdf:Property ;
    rdfs:label 'Program Notes' ;
    rdfs:comment 'Additional notes, comments, or special instructions related to the safety incentive program administration or eligibility.' ;
    rdfs:domain ind:Incentive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Program Period End Date' ;
    rdfs:comment 'End date of the incentive program period. Null for ongoing programs without a defined end date.' ;
    rdfs:domain ind:Incentive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:programPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Program Period Start Date' ;
    rdfs:comment 'Start date of the incentive program period during which performance is measured for award eligibility.' ;
    rdfs:domain ind:Incentive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingDiscouragedFlag rdf:type rdf:Property ;
    rdfs:label 'Reporting Discouraged Flag' ;
    rdfs:comment 'Flag indicating whether this program has been reviewed and confirmed NOT to discourage injury or illness reporting, in compliance with OSHA anti-retaliation requirements.' ;
    rdfs:domain ind:Incentive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalAwardsIssued rdf:type rdf:Property ;
    rdfs:label 'Total Awards Issued' ;
    rdfs:comment 'Cumulative count of awards issued under this program since inception.' ;
    rdfs:domain ind:Incentive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalParticipants rdf:type rdf:Property ;
    rdfs:label 'Total Participants' ;
    rdfs:comment 'Total number of employees or teams currently participating in or eligible for this safety incentive program.' ;
    rdfs:domain ind:Incentive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trainingCompletionThreshold rdf:type rdf:Property ;
    rdfs:label 'Training Completion Threshold' ;
    rdfs:comment 'Minimum percentage of required safety training courses that must be completed to qualify for the incentive (expressed as percentage, e.g., 100.00 for 100%).' ;
    rdfs:domain ind:Incentive ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:presenterEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Presenter Employee Id' ;
    rdfs:comment 'Identifier of the employee who conducted or presented the safety meeting (safety manager, supervisor, or designated safety representative).' ;
    rdfs:domain ind:Meeting ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actionItemsIdentified rdf:type rdf:Property ;
    rdfs:label 'Action Items Identified' ;
    rdfs:comment 'List of follow-up actions, corrective measures, or safety improvements identified during the meeting that require further attention or implementation.' ;
    rdfs:domain ind:Meeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attendanceVerified rdf:type rdf:Property ;
    rdfs:label 'Attendance Verified' ;
    rdfs:comment 'Indicates whether employee attendance was formally verified through sign-in sheet, electronic check-in, or other documented method.' ;
    rdfs:domain ind:Meeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:attendeeCount rdf:type rdf:Property ;
    rdfs:label 'Attendee Count' ;
    rdfs:comment 'Total number of employees who attended the safety meeting, used for compliance documentation and participation tracking.' ;
    rdfs:domain ind:Meeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:completionVerifiedBy rdf:type rdf:Property ;
    rdfs:label 'Completion Verified By' ;
    rdfs:comment 'Identifier of the supervisor or safety manager who verified and approved the completion of the safety meeting documentation.' ;
    rdfs:domain ind:Meeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dotTrainingTopic rdf:type rdf:Property ;
    rdfs:label 'Dot Training Topic' ;
    rdfs:comment 'Indicates whether the meeting covered DOT-mandated training topics for commercial drivers or hazardous materials transportation.' ;
    rdfs:domain ind:Meeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazardCategoriesAddressed rdf:type rdf:Property ;
    rdfs:label 'Hazard Categories Addressed' ;
    rdfs:comment 'Categories of workplace hazards addressed in the meeting (e.g., chemical exposure, physical hazards, ergonomic risks, biological hazards, environmental hazards).' ;
    rdfs:domain ind:Meeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentRelated rdf:type rdf:Property ;
    rdfs:label 'Incident Related' ;
    rdfs:comment 'Indicates whether the safety meeting was conducted in response to a specific safety incident, near-miss, or accident investigation.' ;
    rdfs:domain ind:Meeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:materialsDescription rdf:type rdf:Property ;
    rdfs:label 'Materials Description' ;
    rdfs:comment 'Description of training materials, handouts, videos, or other resources used or distributed during the safety meeting.' ;
    rdfs:domain ind:Meeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meetingDate rdf:type rdf:Property ;
    rdfs:label 'Meeting Date' ;
    rdfs:comment 'Calendar date on which the safety meeting was conducted.' ;
    rdfs:domain ind:Meeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:meetingNumber rdf:type rdf:Property ;
    rdfs:label 'Meeting Number' ;
    rdfs:comment 'Business identifier or reference number assigned to the safety meeting for tracking and documentation purposes.' ;
    rdfs:domain ind:Meeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meetingStatus rdf:type rdf:Property ;
    rdfs:label 'Meeting Status' ;
    rdfs:comment 'Current status of the safety meeting in its lifecycle (scheduled, completed, cancelled, or rescheduled).' ;
    rdfs:domain ind:Meeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meetingType rdf:type rdf:Property ;
    rdfs:label 'Meeting Type' ;
    rdfs:comment 'Classification of the safety meeting format and frequency (daily tailgate/toolbox talk, weekly safety meeting, monthly safety committee, quarterly review, annual safety day, incident debrief, or special topic session). [ENUM-REF-CANDIDATE: daily_tailgate|toolbox_talk|weekly_safety_meeting|monthly_safety_committee|quarterly_safety_review|annual_safety_day|incident_debrief|special_topic — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Meeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oshaComplianceTopic rdf:type rdf:Property ;
    rdfs:label 'Osha Compliance Topic' ;
    rdfs:comment 'Indicates whether the meeting covered OSHA-mandated training topics or compliance requirements.' ;
    rdfs:domain ind:Meeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ppeRequirementsDiscussed rdf:type rdf:Property ;
    rdfs:label 'Ppe Requirements Discussed' ;
    rdfs:comment 'Indicates whether personal protective equipment requirements, proper usage, or maintenance were discussed during the meeting.' ;
    rdfs:domain ind:Meeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:presenterName rdf:type rdf:Property ;
    rdfs:label 'Presenter Name' ;
    rdfs:comment 'Full name of the employee who conducted the safety meeting, for documentation and audit purposes.' ;
    rdfs:domain ind:Meeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:presenterTitle rdf:type rdf:Property ;
    rdfs:label 'Presenter Title' ;
    rdfs:comment 'Job title or role of the meeting presenter (e.g., Safety Manager, Operations Supervisor, EHS Coordinator).' ;
    rdfs:domain ind:Meeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:questionsRaised rdf:type rdf:Property ;
    rdfs:label 'Questions Raised' ;
    rdfs:comment 'Summary of questions or concerns raised by attendees during the safety meeting, along with responses or follow-up plans.' ;
    rdfs:domain ind:Meeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rcraTrainingTopic rdf:type rdf:Property ;
    rdfs:label 'Rcra Training Topic' ;
    rdfs:comment 'Indicates whether the meeting covered RCRA-mandated hazardous waste training requirements for personnel handling hazardous materials.' ;
    rdfs:domain ind:Meeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:safetyTopicsCovered rdf:type rdf:Property ;
    rdfs:label 'Safety Topics Covered' ;
    rdfs:comment 'Comma-separated list or detailed description of all safety topics discussed during the meeting (e.g., PPE usage, lockout/tagout procedures, hazard communication, ergonomics, vehicle safety).' ;
    rdfs:domain ind:Meeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:topic rdf:type rdf:Property ;
    rdfs:label 'Topic' ;
    rdfs:comment 'Primary subject or theme of the safety meeting (e.g., \'Proper Lifting Techniques\', \'Hazardous Waste Handling\', \'Winter Driving Safety\', \'PPE Requirements\').' ;
    rdfs:domain ind:Meeting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingMaterialsProvided rdf:type rdf:Property ;
    rdfs:label 'Training Materials Provided' ;
    rdfs:comment 'Indicates whether written training materials, handouts, or reference documents were distributed to attendees.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meetingAttendanceId rdf:type rdf:Property ;
    rdfs:label 'Meeting Attendance Id' ;
    rdfs:comment 'Unique identifier for the safety meeting attendance record.' ;
    rdfs:domain ind:MeetingAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryMeetingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Meeting Employee Id' ;
    rdfs:comment 'Reference to the employee who attended the safety meeting.' ;
    rdfs:domain ind:MeetingAttendance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:acknowledgmentFlag rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Flag' ;
    rdfs:comment 'Boolean indicator of whether the employee acknowledged understanding of the safety topics covered during the meeting.' ;
    rdfs:domain ind:MeetingAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:attendanceDate rdf:type rdf:Property ;
    rdfs:label 'Attendance Date' ;
    rdfs:comment 'The date on which the employee attended the safety meeting.' ;
    rdfs:domain ind:MeetingAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:attendanceDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Attendance Duration Minutes' ;
    rdfs:comment 'The total duration in minutes that the employee was present at the safety meeting.' ;
    rdfs:domain ind:MeetingAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:attendanceMethod rdf:type rdf:Property ;
    rdfs:label 'Attendance Method' ;
    rdfs:comment 'The method by which the employee attended the safety meeting (in-person, virtual/remote, hybrid, or via recorded session).' ;
    rdfs:domain ind:MeetingAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attendanceNotes rdf:type rdf:Property ;
    rdfs:label 'Attendance Notes' ;
    rdfs:comment 'Free-text notes or comments regarding the employee\'s attendance, such as reasons for late arrival, early departure, or special circumstances.' ;
    rdfs:domain ind:MeetingAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attendanceStatus rdf:type rdf:Property ;
    rdfs:label 'Attendance Status' ;
    rdfs:comment 'Status indicating whether the employee was present, absent, excused, or arrived late to the safety meeting.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkInTimestamp rdf:type rdf:Property ;
    rdfs:label 'Check In Timestamp' ;
    rdfs:comment 'The precise date and time when the employee checked in or was marked present at the safety meeting.' ;
    rdfs:domain ind:MeetingAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:jobRoleCode rdf:type rdf:Property ;
    rdfs:label 'Job Role Code' ;
    rdfs:comment 'Code identifying the employee\'s job role or position at the time of the safety meeting, relevant for role-specific training requirements.' ;
    rdfs:domain ind:MeetingAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationCode rdf:type rdf:Property ;
    rdfs:label 'Location Code' ;
    rdfs:comment 'Code identifying the physical location or facility where the employee attended the safety meeting (e.g., landfill site, MRF, district office).' ;
    rdfs:domain ind:MeetingAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordUpdatedBy rdf:type rdf:Property ;
    rdfs:label 'Record Updated By' ;
    rdfs:comment 'The username or identifier of the user or system process that last updated this attendance record.' ;
    rdfs:domain ind:MeetingAttendance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:observationEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Observation Employee Id' ;
    rdfs:comment 'Identifier of the employee or manager assigned responsibility for completing the corrective action. Null if no corrective action is required.' ;
    rdfs:domain ind:Observation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:observationObservedEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Observation Observed Employee Id' ;
    rdfs:comment 'Identifier of the employee whose behavior or work activity was observed. Null if observation is crew-level or condition-based.' ;
    rdfs:domain ind:Observation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:observationObserverEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Observation Observer Employee Id' ;
    rdfs:comment 'Identifier of the employee who conducted the safety observation (supervisor, safety manager, or peer observer).' ;
    rdfs:domain ind:Observation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:observedJobPositionId rdf:type rdf:Property ;
    rdfs:label 'Observed Job Position Id' ;
    rdfs:comment 'Foreign key linking to workforce.job_position. Business justification: Safety observations document behaviors of employees performing specific job positions. Enables "observations by position" analysis to identify high-risk positions requiring targeted training or engine' ;
    rdfs:domain ind:Observation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JobPosition .

ind:observedOfferingId rdf:type rdf:Property ;
    rdfs:label 'Observed Offering Id' ;
    rdfs:comment 'Foreign key linking to service.offering. Business justification: Safety observations document unsafe practices during specific service delivery (improper container handling during residential pickup, unsafe compactor operation). Supervisors tag observations to offe' ;
    rdfs:domain ind:Observation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Offering .

ind:bbsProgramFlag rdf:type rdf:Property ;
    rdfs:label 'Bbs Program Flag' ;
    rdfs:comment 'Indicates whether this observation is part of a formal Behavior-Based Safety (BBS) program initiative (True = BBS observation, False = general observation).' ;
    rdfs:domain ind:Observation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:behaviorDescription rdf:type rdf:Property ;
    rdfs:label 'Behavior Description' ;
    rdfs:comment 'Detailed narrative description of the specific behavior, condition, or activity observed during the safety observation event.' ;
    rdfs:domain ind:Observation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveFeedbackProvided rdf:type rdf:Property ;
    rdfs:label 'Corrective Feedback Provided' ;
    rdfs:comment 'Indicates whether immediate corrective feedback or coaching was provided to the observed employee at the time of observation (True = feedback given, False = no feedback).' ;
    rdfs:domain ind:Observation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:feedbackDescription rdf:type rdf:Property ;
    rdfs:label 'Feedback Description' ;
    rdfs:comment 'Narrative description of the corrective feedback, coaching, or positive recognition provided to the observed employee during the observation.' ;
    rdfs:domain ind:Observation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:observationCategory rdf:type rdf:Property ;
    rdfs:label 'Observation Category' ;
    rdfs:comment 'Primary classification of the observation: safe behavior (positive), at-risk behavior, near-miss event, unsafe condition, positive recognition, or hazard identification.' ;
    rdfs:domain ind:Observation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:observationDate rdf:type rdf:Property ;
    rdfs:label 'Observation Date' ;
    rdfs:comment 'Calendar date when the safety observation was conducted.' ;
    rdfs:domain ind:Observation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:observationNumber rdf:type rdf:Property ;
    rdfs:label 'Observation Number' ;
    rdfs:comment 'Business-facing unique identifier for the safety observation, formatted as OBS-YYYYMMDD-XXXXXX for external reference and tracking.' ;
    rdfs:domain ind:Observation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:observationStatus rdf:type rdf:Property ;
    rdfs:label 'Observation Status' ;
    rdfs:comment 'Current lifecycle status of the safety observation record: open, pending review, action assigned, in progress, closed, or cancelled.' ;
    rdfs:domain ind:Observation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:observationTime rdf:type rdf:Property ;
    rdfs:label 'Observation Time' ;
    rdfs:comment 'Precise timestamp when the safety observation event occurred, including time zone information.' ;
    rdfs:domain ind:Observation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:observationType rdf:type rdf:Property ;
    rdfs:label 'Observation Type' ;
    rdfs:comment 'Secondary classification indicating the nature of the observation: behavioral, environmental condition, equipment-related, procedural compliance, PPE compliance, or ergonomic.' ;
    rdfs:domain ind:Observation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:observerName rdf:type rdf:Property ;
    rdfs:label 'Observer Name' ;
    rdfs:comment 'Full name of the employee who conducted the safety observation.' ;
    rdfs:domain ind:Observation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:observerRole rdf:type rdf:Property ;
    rdfs:label 'Observer Role' ;
    rdfs:comment 'Role or position of the person conducting the observation within the organization.' ;
    rdfs:domain ind:Observation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ppeComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Ppe Compliance Flag' ;
    rdfs:comment 'Indicates whether the observed employee was in full compliance with required PPE for the task being performed (True = compliant, False = non-compliant).' ;
    rdfs:domain ind:Observation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ppeDeficiencyDescription rdf:type rdf:Property ;
    rdfs:label 'Ppe Deficiency Description' ;
    rdfs:comment 'Description of any PPE deficiencies observed (missing equipment, improper use, damaged equipment). Null if PPE compliance flag is True.' ;
    rdfs:domain ind:Observation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primarySafetyCoordinatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Safety Coordinator Employee Id' ;
    rdfs:comment 'Identifier of the employee who coordinates day-to-day program activities, training scheduling, and documentation for this safety program.' ;
    rdfs:domain ind:SafetyProgram ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:auditFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Audit Frequency Months' ;
    rdfs:comment 'The required interval in months between formal compliance audits of this safety program (e.g., 12 for annual audit, 6 for semi-annual audit). Null if no periodic audit is required.' ;
    rdfs:domain ind:SafetyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceScore rdf:type rdf:Property ;
    rdfs:label 'Compliance Score' ;
    rdfs:comment 'Most recent overall compliance score for this safety program based on audits, inspections, and performance metrics, expressed as a percentage (0.00 to 100.00). Null if not yet assessed.' ;
    rdfs:domain ind:SafetyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incidentReportingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Incident Reporting Required Flag' ;
    rdfs:comment 'Indicates whether incidents or near-misses related to this safety program must be formally reported and investigated (True) or not (False).' ;
    rdfs:domain ind:SafetyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:medicalSurveillanceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Medical Surveillance Required Flag' ;
    rdfs:comment 'Indicates whether this safety program requires periodic medical examinations or health monitoring for covered employees (True) or not (False). Common for respiratory protection, hearing conservation, and hazmat programs.' ;
    rdfs:domain ind:SafetyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextAuditDate rdf:type rdf:Property ;
    rdfs:label 'Next Audit Date' ;
    rdfs:comment 'The scheduled date for the next formal compliance audit of this safety program.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nonComplianceCount rdf:type rdf:Property ;
    rdfs:label 'Non Compliance Count' ;
    rdfs:comment 'Total number of non-compliance findings or violations identified for this safety program during the most recent audit or reporting period.' ;
    rdfs:domain ind:SafetyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:objectives rdf:type rdf:Property ;
    rdfs:label 'Objectives' ;
    rdfs:comment 'Specific measurable objectives or goals that this safety program is designed to achieve (e.g., zero lost-time injuries, 100% PPE compliance, reduction in exposure incidents).' ;
    rdfs:domain ind:SafetyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ppeRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Ppe Required Flag' ;
    rdfs:comment 'Indicates whether this safety program mandates the use of specific Personal Protective Equipment (PPE) for covered employees (True) or not (False).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ppeTypesRequired rdf:type rdf:Property ;
    rdfs:label 'Ppe Types Required' ;
    rdfs:comment 'Comma-separated list of PPE types required under this safety program (e.g., Hard Hat, Safety Glasses, Respirator, Gloves, Steel-Toe Boots, High-Visibility Vest, Hearing Protection). Null if no PPE is required.' ;
    rdfs:domain ind:SafetyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programDescription rdf:type rdf:Property ;
    rdfs:label 'Program Description' ;
    rdfs:comment 'Detailed narrative description of the safety program\'s purpose, scope, key requirements, and objectives. Provides context for program implementation and compliance.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programType rdf:type rdf:Property ;
    rdfs:label 'Program Type' ;
    rdfs:comment 'Classification of the safety program based on its regulatory or business origin (OSHA-mandated, internal voluntary initiative, industry best practice, client-required, state-mandated, DOT-required).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordRetentionYears rdf:type rdf:Property ;
    rdfs:label 'Record Retention Years' ;
    rdfs:comment 'The number of years that records related to this safety program must be retained to meet regulatory and legal requirements (e.g., 5 years for OSHA 300 logs, 30 years for exposure records). Null if no specific retention requirement.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recordkeepingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Recordkeeping Required Flag' ;
    rdfs:comment 'Indicates whether this safety program requires formal recordkeeping and documentation to demonstrate compliance (True) or not (False). Most OSHA-mandated programs require recordkeeping.' ;
    rdfs:domain ind:SafetyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trainingFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Training Frequency Months' ;
    rdfs:comment 'The required interval in months between mandatory training sessions for employees covered by this safety program (e.g., 12 for annual refresher training). Null if training is one-time or not required.' ;
    rdfs:domain ind:SafetyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualifiedOfferingId rdf:type rdf:Property ;
    rdfs:label 'Qualified Offering Id' ;
    rdfs:comment 'Foreign key linking to service.offering. Business justification: Training records document employee qualification for specific service offerings (hazmat endorsement for hazmat collection, confined space certification for underground compactor service). Operations m' ;
    rdfs:domain ind:SafetyTrainingRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Offering .

ind:attendanceVerificationMethod rdf:type rdf:Property ;
    rdfs:label 'Attendance Verification Method' ;
    rdfs:comment 'Method used to verify and document employee attendance at the training event (e.g., physical sign-in sheet, electronic badge scan, biometric verification, supervisor confirmation, online learning management system tracking).' ;
    rdfs:domain ind:SafetyTrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Certificate Expiration Date' ;
    rdfs:comment 'Date on which the training certificate or qualification expires and requires renewal or recertification. Null for training that does not expire.' ;
    rdfs:domain ind:SafetyTrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificateNumber rdf:type rdf:Property ;
    rdfs:label 'Certificate Number' ;
    rdfs:comment 'Unique certificate or credential number issued upon successful completion of the safety training, used for verification and audit purposes.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dotRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Dot Required Flag' ;
    rdfs:comment 'Boolean indicator (True/False) denoting whether this training is mandated by DOT regulations for hazardous materials transportation (49 CFR 172.704) or commercial driver licensing.' ;
    rdfs:domain ind:SafetyTrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:epaRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Epa Required Flag' ;
    rdfs:comment 'Boolean indicator (True/False) denoting whether this training is mandated by EPA regulations such as RCRA personnel training requirements (40 CFR 265.16) or CERCLA emergency response.' ;
    rdfs:domain ind:SafetyTrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazardCategoriesCovered rdf:type rdf:Property ;
    rdfs:label 'Hazard Categories Covered' ;
    rdfs:comment 'Categories of workplace hazards addressed in this training (e.g., chemical exposure, confined space, electrical hazards, vehicle operations, ergonomic risks, biological hazards).' ;
    rdfs:domain ind:SafetyTrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextTrainingDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Training Due Date' ;
    rdfs:comment 'Calculated date by which the employee must complete refresher or recertification training to maintain compliance with regulatory or company requirements.' ;
    rdfs:domain ind:SafetyTrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:passingScoreThreshold rdf:type rdf:Property ;
    rdfs:label 'Passing Score Threshold' ;
    rdfs:comment 'Minimum score percentage required to pass the training assessment for this course (e.g., 80.00 for 80% passing threshold).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ppeTopicsCovered rdf:type rdf:Property ;
    rdfs:label 'Ppe Topics Covered' ;
    rdfs:comment 'Description of PPE topics, equipment types, or usage protocols covered in this training (e.g., respirator fit testing, fall protection, chemical-resistant gloves, high-visibility clothing).' ;
    rdfs:domain ind:SafetyTrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainerName rdf:type rdf:Property ;
    rdfs:label 'Trainer Name' ;
    rdfs:comment 'Full name of the instructor, facilitator, or safety professional who delivered the training. May be internal Waste Management safety staff or external certified trainer.' ;
    rdfs:domain ind:SafetyTrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingCostAmount rdf:type rdf:Property ;
    rdfs:label 'Training Cost Amount' ;
    rdfs:comment 'Total cost incurred for this training event, including instructor fees, materials, facility rental, and employee time. Used for training budget tracking and ROI analysis.' ;
    rdfs:domain ind:SafetyTrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingCourseCode rdf:type rdf:Property ;
    rdfs:label 'Training Course Code' ;
    rdfs:comment 'Unique code identifying the specific safety training course or program completed (e.g., HAZWOPER-40, OSHA-10, CDL-HAZMAT, PPE-101).' ;
    rdfs:domain ind:SafetyTrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingCourseName rdf:type rdf:Property ;
    rdfs:label 'Training Course Name' ;
    rdfs:comment 'Full descriptive name of the safety training course completed (e.g., Hazardous Waste Operations and Emergency Response 40-Hour, OSHA 10-Hour General Industry Safety).' ;
    rdfs:domain ind:SafetyTrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingDate rdf:type rdf:Property ;
    rdfs:label 'Training Date' ;
    rdfs:comment 'Date on which the employee successfully completed the safety training course. This is the principal business event timestamp for this transaction.' ;
    rdfs:domain ind:SafetyTrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trainingDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Training Document Url' ;
    rdfs:comment 'URL or file path to the digital repository location where training certificates, attendance records, course materials, and assessment results are stored for audit and compliance purposes.' ;
    rdfs:domain ind:SafetyTrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingDurationHours rdf:type rdf:Property ;
    rdfs:label 'Training Duration Hours' ;
    rdfs:comment 'Total number of hours of instruction completed for this safety training event, required for regulatory compliance documentation (e.g., OSHA 10-hour, 40-hour HAZWOPER).' ;
    rdfs:domain ind:SafetyTrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingStartDate rdf:type rdf:Property ;
    rdfs:label 'Training Start Date' ;
    rdfs:comment 'Date on which the employee began the safety training course, relevant for multi-day or multi-session training programs.' ;
    rdfs:domain ind:SafetyTrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:referenceAssetClassId rdf:type rdf:Property ;
    rdfs:label 'Reference Asset Class Id' ;
    rdfs:comment 'Foreign key linking to asset.asset_class. Business justification: Container types in service catalog map to asset classes for financial tracking (depreciation, capitalization thresholds, GL accounts). Links service catalog specifications to asset accounting rules, e' ;
    rdfs:domain ind:ContainerType ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Class .

ind:certificationStandards rdf:type rdf:Property ;
    rdfs:label 'Certification Standards' ;
    rdfs:comment 'Industry certifications and standards this container type meets (e.g., ANSI Z245.60, ISO 14001, RCRA compliance). Comma-separated list.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorStandard rdf:type rdf:Property ;
    rdfs:label 'Color Standard' ;
    rdfs:comment 'Standard color designation for this container type. Often used for waste stream identification (e.g., blue for recycling, green for organics, black for MSW).' ;
    rdfs:domain ind:ContainerType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commercialUseFlag rdf:type rdf:Property ;
    rdfs:label 'Commercial Use Flag' ;
    rdfs:comment 'Indicates whether this container type is designed and approved for commercial service delivery.' ;
    rdfs:domain ind:ContainerType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:compactionCapableFlag rdf:type rdf:Property ;
    rdfs:label 'Compaction Capable Flag' ;
    rdfs:comment 'Indicates whether this container type includes or supports compaction mechanisms to increase waste density and reduce collection frequency.' ;
    rdfs:domain ind:ContainerType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:containerCategory rdf:type rdf:Property ;
    rdfs:label 'Container Category' ;
    rdfs:comment 'High-level classification of the container type by form factor and use case.' ;
    rdfs:domain ind:ContainerType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerTypeCode rdf:type rdf:Property ;
    rdfs:label 'Container Type Code' ;
    rdfs:comment 'Unique alphanumeric code identifying the container type in operational systems. Used for Container Identification (CID) classification and cross-system reference.' ;
    rdfs:domain ind:ContainerType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerTypeName rdf:type rdf:Property ;
    rdfs:label 'Container Type Name' ;
    rdfs:comment 'Business-friendly name of the container type (e.g., \'10 Yard Roll-Off\', \'96 Gallon Residential Cart\', \'40 Yard Compactor\').' ;
    rdfs:domain ind:ContainerType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerTypeStatus rdf:type rdf:Property ;
    rdfs:label 'Container Type Status' ;
    rdfs:comment 'Current lifecycle status of this container type in the service catalog. Active types are available for new service orders.' ;
    rdfs:domain ind:ContainerType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dotHazmatClass rdf:type rdf:Property ;
    rdfs:label 'Dot Hazmat Class' ;
    rdfs:comment 'DOT hazard class designation if container is certified for hazardous materials (e.g., Class 3 Flammable Liquids, Class 9 Miscellaneous). Null for non-hazmat containers.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedUsefulLifeYears rdf:type rdf:Property ;
    rdfs:label 'Estimated Useful Life Years' ;
    rdfs:comment 'Expected service life of this container type in years under normal operating conditions. Used for depreciation and replacement planning.' ;
    rdfs:domain ind:ContainerType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gpsTrackingCompatibleFlag rdf:type rdf:Property ;
    rdfs:label 'Gps Tracking Compatible Flag' ;
    rdfs:comment 'Indicates whether this container type supports GPS tracking devices for real-time location monitoring.' ;
    rdfs:domain ind:ContainerType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:industrialUseFlag rdf:type rdf:Property ;
    rdfs:label 'Industrial Use Flag' ;
    rdfs:comment 'Indicates whether this container type is designed and approved for industrial facility service delivery.' ;
    rdfs:domain ind:ContainerType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leakProofFlag rdf:type rdf:Property ;
    rdfs:label 'Leak Proof Flag' ;
    rdfs:comment 'Indicates whether the container is designed with leak-proof seals and construction to prevent leachate or liquid waste escape.' ;
    rdfs:domain ind:ContainerType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:liftMechanismCompatibility rdf:type rdf:Property ;
    rdfs:label 'Lift Mechanism Compatibility' ;
    rdfs:comment 'Type of truck lift mechanism compatible with this container. ASL = Automated Side Loader, FEL = Front End Loader, REL = Rear End Loader. Critical for route planning and fleet assignment.' ;
    rdfs:domain ind:ContainerType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceIntervalMonths rdf:type rdf:Property ;
    rdfs:label 'Maintenance Interval Months' ;
    rdfs:comment 'Recommended preventive maintenance interval in months for this container type. Used for asset maintenance scheduling.' ;
    rdfs:domain ind:ContainerType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:materialConstruction rdf:type rdf:Property ;
    rdfs:label 'Material Construction' ;
    rdfs:comment 'Primary material used in container construction. Impacts durability, weight, and lifecycle cost.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Purchase Eligible Flag' ;
    rdfs:comment 'Indicates whether this container type is available for customer purchase rather than rental or service-included provision.' ;
    rdfs:domain ind:ContainerType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rentalEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Rental Eligible Flag' ;
    rdfs:comment 'Indicates whether this container type is available for temporary rental services (e.g., roll-off rentals for construction projects).' ;
    rdfs:domain ind:ContainerType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:residentialUseFlag rdf:type rdf:Property ;
    rdfs:label 'Residential Use Flag' ;
    rdfs:comment 'Indicates whether this container type is designed and approved for residential service delivery.' ;
    rdfs:domain ind:ContainerType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rfidCompatibleFlag rdf:type rdf:Property ;
    rdfs:label 'Rfid Compatible Flag' ;
    rdfs:comment 'Indicates whether this container type is designed to accommodate RFID tags for automated tracking and identification.' ;
    rdfs:domain ind:ContainerType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceFrequencyDefault rdf:type rdf:Property ;
    rdfs:label 'Service Frequency Default' ;
    rdfs:comment 'Default collection frequency typically associated with this container type. Used for service planning and contract setup.' ;
    rdfs:domain ind:ContainerType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardUnitCost rdf:type rdf:Property ;
    rdfs:label 'Standard Unit Cost' ;
    rdfs:comment 'Standard acquisition or replacement cost per unit for this container type. Used for asset valuation and capital planning.' ;
    rdfs:domain ind:ContainerType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unPackagingCode rdf:type rdf:Property ;
    rdfs:label 'Un Packaging Code' ;
    rdfs:comment 'UN packaging identification code for hazmat-certified containers (e.g., 1A1 for steel drums). Null for non-hazmat containers.' ;
    rdfs:domain ind:ContainerType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weatherResistantFlag rdf:type rdf:Property ;
    rdfs:label 'Weather Resistant Flag' ;
    rdfs:comment 'Indicates whether the container is designed to withstand outdoor weather conditions including rain, snow, UV exposure, and temperature extremes.' ;
    rdfs:domain ind:ContainerType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:weightCapacityLbs rdf:type rdf:Property ;
    rdfs:label 'Weight Capacity Lbs' ;
    rdfs:comment 'Maximum safe working load capacity of the container in pounds. Critical for DOT compliance and fleet safety.' ;
    rdfs:domain ind:ContainerType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wheelConfiguration rdf:type rdf:Property ;
    rdfs:label 'Wheel Configuration' ;
    rdfs:comment 'Wheel configuration for container mobility. Relevant for residential carts and smaller commercial bins.' ;
    rdfs:domain ind:ContainerType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibilityRuleId rdf:type rdf:Property ;
    rdfs:label 'Eligibility Rule Id' ;
    rdfs:comment 'Unique identifier for the eligibility rule. Primary key.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryEligibilityOfferingId rdf:type rdf:Property ;
    rdfs:label 'Primary Eligibility Offering Id' ;
    rdfs:comment 'Reference to the service offering to which this eligibility rule applies.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Offering .

ind:requiredJhaId rdf:type rdf:Property ;
    rdfs:label 'Required Jha Id' ;
    rdfs:comment 'Foreign key linking to safety.jha. Business justification: Eligibility rules for high-hazard services (hazmat, confined space work) require documented JHAs before service can be offered. Sales and safety teams verify JHA completion during service qualificatio' ;
    rdfs:domain ind:Service ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Jha .

ind:requiredVendorId rdf:type rdf:Property ;
    rdfs:label 'Required Vendor Id' ;
    rdfs:comment 'Foreign key linking to procurement.vendor. Business justification: Eligibility rules may require specific vendor certifications or capabilities for service delivery. Real business process: vendor qualification, service delivery constraints, and regulatory compliance.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:complianceValidationRule rdf:type rdf:Property ;
    rdfs:label 'Compliance Validation Rule' ;
    rdfs:comment 'Technical expression or business logic used to validate compliance with this eligibility rule, such as SQL expression, decision tree logic, or validation checklist reference.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countyFipsCode rdf:type rdf:Property ;
    rdfs:label 'County Fips Code' ;
    rdfs:comment 'Five-digit FIPS code identifying the county to which this eligibility rule applies, if geographic_scope is county.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicScope rdf:type rdf:Property ;
    rdfs:label 'Geographic Scope' ;
    rdfs:comment 'Geographic boundary level at which this eligibility rule applies: national, state, county, municipality, defined service area, zip code, or custom boundary. [ENUM-REF-CANDIDATE: national|state|county|municipality|service_area|zip_code|custom — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumVolumeCubicYards rdf:type rdf:Property ;
    rdfs:label 'Maximum Volume Cubic Yards' ;
    rdfs:comment 'Maximum waste volume in cubic yards allowed under this eligibility rule, used for operational capacity constraints and facility limits.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumWeightTons rdf:type rdf:Property ;
    rdfs:label 'Maximum Weight Tons' ;
    rdfs:comment 'Maximum waste weight in tons allowed under this eligibility rule, used for facility capacity constraints and regulatory limits.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumVolumeCubicYards rdf:type rdf:Property ;
    rdfs:label 'Minimum Volume Cubic Yards' ;
    rdfs:comment 'Minimum waste volume in cubic yards required for eligibility under this rule, used for operational capacity planning and service viability.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumWeightTons rdf:type rdf:Property ;
    rdfs:label 'Minimum Weight Tons' ;
    rdfs:comment 'Minimum waste weight in tons required for eligibility under this rule, used for Tons Per Day (TPD) capacity planning and service viability.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:notificationMessage rdf:type rdf:Property ;
    rdfs:label 'Notification Message' ;
    rdfs:comment 'Standard message text to be communicated to customers when this eligibility rule applies or restricts their service eligibility.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideApprovalRole rdf:type rdf:Property ;
    rdfs:label 'Override Approval Role' ;
    rdfs:comment 'Job role or position authorized to approve overrides of this eligibility rule (e.g., Regional Manager, Compliance Officer, VP Operations).' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideAuthorizationRequired rdf:type rdf:Property ;
    rdfs:label 'Override Authorization Required' ;
    rdfs:comment 'Indicates whether management authorization is required to override or waive this eligibility rule for exceptional cases.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:permitRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Permit Requirement Flag' ;
    rdfs:comment 'Indicates whether a special permit is required for customers or facilities to be eligible for this service offering under this rule.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ruleCategory rdf:type rdf:Property ;
    rdfs:label 'Rule Category' ;
    rdfs:comment 'Indicates whether the rule defines inclusion criteria (who IS eligible), exclusion criteria (who is NOT eligible), or conditional eligibility (eligible under specific circumstances).' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleType rdf:type rdf:Property ;
    rdfs:label 'Rule Type' ;
    rdfs:comment 'Classification of the eligibility rule by its primary constraint dimension: geographic (service area restrictions), customer_segment (business vs residential), waste_stream (material type restrictions), regulatory (permit or compliance-based), operational (capacity or resource constraints), or contractual (agreement-based restrictions).' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonalEndDate rdf:type rdf:Property ;
    rdfs:label 'Seasonal End Date' ;
    rdfs:comment 'End date for seasonal eligibility rules that recur annually (e.g., yard waste collection eligibility until November 30 each year). Month and day are significant; year may be ignored for recurring rules.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:seasonalStartDate rdf:type rdf:Property ;
    rdfs:label 'Seasonal Start Date' ;
    rdfs:comment 'Start date for seasonal eligibility rules that recur annually (e.g., yard waste collection eligibility from April 1 each year). Month and day are significant; year may be ignored for recurring rules.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:serviceFrequencyRestriction rdf:type rdf:Property ;
    rdfs:label 'Service Frequency Restriction' ;
    rdfs:comment 'Service frequency requirements or restrictions under this eligibility rule (e.g., minimum once per week, maximum twice per week).' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zipCodeList rdf:type rdf:Property ;
    rdfs:label 'Zip Code List' ;
    rdfs:comment 'Comma-separated list of ZIP codes to which this eligibility rule applies, if geographic_scope is zip_code.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:extraPickupAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Extra Pickup Allowed Flag' ;
    rdfs:comment 'Indicates whether customers can request additional pickups beyond the standard frequency under this plan. True if extra pickups are permitted (typically with additional charges), False otherwise.' ;
    rdfs:domain ind:FrequencyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:frequencyPlanStatus rdf:type rdf:Property ;
    rdfs:label 'Frequency Plan Status' ;
    rdfs:comment 'Current lifecycle status of the frequency plan: active (available for new contracts), inactive (not available but existing contracts continue), deprecated (being phased out), pending approval (awaiting management approval), or suspended (temporarily unavailable).' ;
    rdfs:domain ind:FrequencyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fridayServiceFlag rdf:type rdf:Property ;
    rdfs:label 'Friday Service Flag' ;
    rdfs:comment 'Indicates whether this frequency plan includes service pickups on Fridays. True if Friday is an eligible service day, False otherwise.' ;
    rdfs:domain ind:FrequencyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:holidayAdjustmentRule rdf:type rdf:Property ;
    rdfs:label 'Holiday Adjustment Rule' ;
    rdfs:comment 'Defines how service is adjusted when a scheduled pickup falls on a recognized holiday: no service provided, shifted to next business day, shifted to prior business day, service on same day regardless, or customer chooses adjustment method.' ;
    rdfs:domain ind:FrequencyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumCommitmentPeriod rdf:type rdf:Property ;
    rdfs:label 'Maximum Commitment Period' ;
    rdfs:comment 'The maximum number of months a customer can commit to this frequency plan in a single contract term. Null indicates no maximum limit.' ;
    rdfs:domain ind:FrequencyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maximumSkipsPerYear rdf:type rdf:Property ;
    rdfs:label 'Maximum Skips Per Year' ;
    rdfs:comment 'The maximum number of scheduled pickups a customer can skip in a 12-month period under this frequency plan. Null indicates no limit or skip_allowed_flag is False.' ;
    rdfs:domain ind:FrequencyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumCommitmentPeriod rdf:type rdf:Property ;
    rdfs:label 'Minimum Commitment Period' ;
    rdfs:comment 'The minimum number of months a customer must commit to this frequency plan when entering a service contract. Used for contract term enforcement and early termination calculations.' ;
    rdfs:domain ind:FrequencyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mondayServiceFlag rdf:type rdf:Property ;
    rdfs:label 'Monday Service Flag' ;
    rdfs:comment 'Indicates whether this frequency plan includes service pickups on Mondays. True if Monday is an eligible service day, False otherwise.' ;
    rdfs:domain ind:FrequencyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:periodUnit rdf:type rdf:Property ;
    rdfs:label 'Period Unit' ;
    rdfs:comment 'The time unit that defines the frequency period: day, week, month, quarter, or year. Used in conjunction with pickups_per_period to calculate service frequency.' ;
    rdfs:domain ind:FrequencyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickupsPerPeriod rdf:type rdf:Property ;
    rdfs:label 'Pickups Per Period' ;
    rdfs:comment 'The number of pickups scheduled within the defined frequency period. For weekly service this is typically 1, for bi-weekly this is 1 per two-week period, for daily this is 5-7 depending on operating days.' ;
    rdfs:domain ind:FrequencyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:planCode rdf:type rdf:Property ;
    rdfs:label 'Plan Code' ;
    rdfs:comment 'Business identifier code for the frequency plan used in billing, contracts, and operational systems. Externally visible unique code.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planDescription rdf:type rdf:Property ;
    rdfs:label 'Plan Description' ;
    rdfs:comment 'Detailed description of the frequency plan including service scope, pickup schedule details, and any special conditions or restrictions.' ;
    rdfs:domain ind:FrequencyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prorationAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Proration Allowed Flag' ;
    rdfs:comment 'Indicates whether billing can be prorated for partial periods when service starts or ends mid-cycle. True if proration is allowed, False if full-period billing applies.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:saturdayServiceFlag rdf:type rdf:Property ;
    rdfs:label 'Saturday Service Flag' ;
    rdfs:comment 'Indicates whether this frequency plan includes service pickups on Saturdays. True if Saturday is an eligible service day, False otherwise.' ;
    rdfs:domain ind:FrequencyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:skipAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Skip Allowed Flag' ;
    rdfs:comment 'Indicates whether customers can request to skip scheduled pickups under this frequency plan (e.g., for vacation holds). True if skips are permitted, False otherwise.' ;
    rdfs:domain ind:FrequencyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sundayServiceFlag rdf:type rdf:Property ;
    rdfs:label 'Sunday Service Flag' ;
    rdfs:comment 'Indicates whether this frequency plan includes service pickups on Sundays. True if Sunday is an eligible service day, False otherwise.' ;
    rdfs:domain ind:FrequencyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:thursdayServiceFlag rdf:type rdf:Property ;
    rdfs:label 'Thursday Service Flag' ;
    rdfs:comment 'Indicates whether this frequency plan includes service pickups on Thursdays. True if Thursday is an eligible service day, False otherwise.' ;
    rdfs:domain ind:FrequencyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tuesdayServiceFlag rdf:type rdf:Property ;
    rdfs:label 'Tuesday Service Flag' ;
    rdfs:comment 'Indicates whether this frequency plan includes service pickups on Tuesdays. True if Tuesday is an eligible service day, False otherwise.' ;
    rdfs:domain ind:FrequencyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:wednesdayServiceFlag rdf:type rdf:Property ;
    rdfs:label 'Wednesday Service Flag' ;
    rdfs:comment 'Indicates whether this frequency plan includes service pickups on Wednesdays. True if Wednesday is an eligible service day, False otherwise.' ;
    rdfs:domain ind:FrequencyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:codeId rdf:type rdf:Property ;
    rdfs:label 'Code Id' ;
    rdfs:comment 'Foreign key linking to service.service_code. Business justification: Offering should reference the standardized service_code registry for code assignment. The offering table currently has a \'service_code\' STRING attribute that should be replaced with a FK to the servic' ;
    rdfs:domain ind:Service ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Code .

ind:defaultContainerTypeId rdf:type rdf:Property ;
    rdfs:label 'Default Container Type Id' ;
    rdfs:comment 'Foreign key linking to service.container_type. Business justification: Offering references a default container type. The offering table has a STRING column \'default_container_type\' that should be replaced with a proper FK to container_type.container_type_id. This normali' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContainerType .

ind:defaultFrequencyPlanId rdf:type rdf:Property ;
    rdfs:label 'Default Frequency Plan Id' ;
    rdfs:comment 'Foreign key linking to service.frequency_plan. Business justification: Offering references a default frequency plan. The offering table has a STRING column \'default_service_frequency\' that should be replaced with a proper FK to frequency_plan.frequency_plan_id. This norm' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FrequencyPlan .

ind:requiredAssetClassId rdf:type rdf:Property ;
    rdfs:label 'Required Asset Class Id' ;
    rdfs:comment 'Foreign key linking to asset.asset_class. Business justification: Service offerings specify required asset class for delivery (e.g., hazmat service requires hazmat-certified container class, compaction service requires compactor-class assets). Drives asset eligibili' ;
    rdfs:domain ind:Service ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Class .

ind:amcsServiceCode rdf:type rdf:Property ;
    rdfs:label 'Amcs Service Code' ;
    rdfs:comment 'AMCS Platform service code used for route optimization, dispatching, and container tracking integration.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:basePriceAmount rdf:type rdf:Property ;
    rdfs:label 'Base Price Amount' ;
    rdfs:comment 'Standard base price for the service offering before adjustments, surcharges, or discounts. Currency is USD for all operations.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carbonOffsetEligible rdf:type rdf:Property ;
    rdfs:label 'Carbon Offset Eligible' ;
    rdfs:comment 'Indicates whether this service qualifies for carbon offset credits or greenhouse gas (GHG) reduction reporting (e.g., WTE, RNG, landfill gas capture services).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minimumContractTermMonths rdf:type rdf:Property ;
    rdfs:label 'Minimum Contract Term Months' ;
    rdfs:comment 'Minimum contract duration in months required for this service offering. Null for services with no minimum term.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:oracleRateCode rdf:type rdf:Property ;
    rdfs:label 'Oracle Rate Code' ;
    rdfs:comment 'Oracle Revenue Management system rate code identifier used for billing and invoicing.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingUnit rdf:type rdf:Property ;
    rdfs:label 'Pricing Unit' ;
    rdfs:comment 'Unit of measure for pricing calculation (e.g., per month, per pickup, per ton, per yard, per event, per gallon, per container, flat rate). [ENUM-REF-CANDIDATE: per_month|per_pickup|per_ton|per_yard|per_event|per_gallon|per_container|flat_rate — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresCustomerTraining rdf:type rdf:Property ;
    rdfs:label 'Requires Customer Training' ;
    rdfs:comment 'Indicates whether this service requires customer training on proper waste segregation, container usage, or safety procedures.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresManifest rdf:type rdf:Property ;
    rdfs:label 'Requires Manifest' ;
    rdfs:comment 'Indicates whether this service requires hazardous waste tracking manifest documentation per RCRA regulations.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresSiteAssessment rdf:type rdf:Property ;
    rdfs:label 'Requires Site Assessment' ;
    rdfs:comment 'Indicates whether this service requires an on-site assessment before service initiation (common for commercial, industrial, and hazardous waste services).' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresSpecialPermit rdf:type rdf:Property ;
    rdfs:label 'Requires Special Permit' ;
    rdfs:comment 'Indicates whether this service requires special permits or licenses from regulatory authorities (EPA, state, or local).' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:salesforceProductCode rdf:type rdf:Property ;
    rdfs:label 'Salesforce Product Code' ;
    rdfs:comment 'Salesforce CRM product record identifier (18-character Salesforce ID) used in opportunity and contract management.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapSdConditionType rdf:type rdf:Property ;
    rdfs:label 'Sap Sd Condition Type' ;
    rdfs:comment 'SAP S/4HANA SD pricing condition type code used for rate calculation and billing (e.g., ZPR0 for base price, ZFEE for fees, ZSUR for surcharges).' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapSdMaterialNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Sd Material Number' ;
    rdfs:comment 'SAP S/4HANA SD module material master number for this service offering used in sales orders and billing.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceAreaRestriction rdf:type rdf:Property ;
    rdfs:label 'Service Area Restriction' ;
    rdfs:comment 'Geographic or operational restrictions on where this service can be delivered (e.g., specific districts, municipalities, or facility service areas). Null if no restrictions apply.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceCode rdf:type rdf:Property ;
    rdfs:label 'Service Code' ;
    rdfs:comment 'Unique business identifier for the service offering used across operational systems. Externally-known code used in contracts, billing, and customer communications.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceDescription rdf:type rdf:Property ;
    rdfs:label 'Service Description' ;
    rdfs:comment 'Detailed description of the service offering including scope, inclusions, exclusions, and operational details.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceName rdf:type rdf:Property ;
    rdfs:label 'Service Name' ;
    rdfs:comment 'Human-readable name of the waste management service offering (e.g., \'Residential Curbside Pickup - Weekly\', \'Commercial Front-End-Load 8-Yard\', \'Roll-Off 30-Yard Rental\').' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityProgramFlag rdf:type rdf:Property ;
    rdfs:label 'Sustainability Program Flag' ;
    rdfs:comment 'Indicates whether this service is part of a sustainability or environmental stewardship program (e.g., recycling, WTE, RNG, carbon offset programs).' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pricingTierId rdf:type rdf:Property ;
    rdfs:label 'Pricing Tier Id' ;
    rdfs:comment 'Unique identifier for the pricing tier record. Primary key.' ;
    rdfs:domain ind:PricingTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceRateScheduleId rdf:type rdf:Property ;
    rdfs:label 'Service Rate Schedule Id' ;
    rdfs:comment 'Reference to the parent service rate schedule to which this pricing tier belongs.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceRateSchedule .

ind:applicableCustomerSegment rdf:type rdf:Property ;
    rdfs:label 'Applicable Customer Segment' ;
    rdfs:comment 'Customer segment(s) eligible for this pricing tier: residential, commercial, industrial, municipal, institutional, or all segments.' ;
    rdfs:domain ind:PricingTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableServiceAreaCodes rdf:type rdf:Property ;
    rdfs:label 'Applicable Service Area Codes' ;
    rdfs:comment 'Comma-separated list of service area codes where this pricing tier is available. Null if tier applies to all service areas.' ;
    rdfs:domain ind:PricingTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalRole rdf:type rdf:Property ;
    rdfs:label 'Approval Role' ;
    rdfs:comment 'Role or position authorized to approve customer assignment to this tier (e.g., Regional Manager, Pricing Director). Null if no approval required.' ;
    rdfs:domain ind:PricingTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoDowngradeEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Downgrade Enabled Flag' ;
    rdfs:comment 'Indicates whether customers are automatically downgraded from this tier when they no longer meet the qualification criteria (True) or remain at current tier (False).' ;
    rdfs:domain ind:PricingTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:autoUpgradeEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Upgrade Enabled Flag' ;
    rdfs:comment 'Indicates whether customers are automatically upgraded to this tier when they meet the qualification criteria (True) or require manual approval (False).' ;
    rdfs:domain ind:PricingTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:diversionRateRequirementPct rdf:type rdf:Property ;
    rdfs:label 'Diversion Rate Requirement Pct' ;
    rdfs:comment 'Minimum waste diversion rate percentage required to qualify for or maintain this pricing tier. Null if no diversion requirement applies.' ;
    rdfs:domain ind:PricingTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumPickupsPerPeriod rdf:type rdf:Property ;
    rdfs:label 'Maximum Pickups Per Period' ;
    rdfs:comment 'Maximum number of service pickups per billing period for this tier. Null if tier has no upper limit or is not frequency-based.' ;
    rdfs:domain ind:PricingTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maximumVolumeTons rdf:type rdf:Property ;
    rdfs:label 'Maximum Volume Tons' ;
    rdfs:comment 'Maximum waste volume in tons for this pricing tier. Null if tier has no upper limit or is not volume-based.' ;
    rdfs:domain ind:PricingTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumCommitmentMonths rdf:type rdf:Property ;
    rdfs:label 'Minimum Commitment Months' ;
    rdfs:comment 'Minimum contract commitment period in months required to qualify for this pricing tier. Null if tier is not commitment-based.' ;
    rdfs:domain ind:PricingTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumPickupsPerPeriod rdf:type rdf:Property ;
    rdfs:label 'Minimum Pickups Per Period' ;
    rdfs:comment 'Minimum number of service pickups per billing period required to qualify for this tier. Null if tier is not frequency-based.' ;
    rdfs:domain ind:PricingTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumVolumeTons rdf:type rdf:Property ;
    rdfs:label 'Minimum Volume Tons' ;
    rdfs:comment 'Minimum waste volume in tons required to qualify for this pricing tier. Null if tier is not volume-based.' ;
    rdfs:domain ind:PricingTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oracleRateTierCode rdf:type rdf:Property ;
    rdfs:label 'Oracle Rate Tier Code' ;
    rdfs:comment 'Oracle Revenue Management rate tier code for billing system integration.' ;
    rdfs:domain ind:PricingTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionCode rdf:type rdf:Property ;
    rdfs:label 'Promotion Code' ;
    rdfs:comment 'Marketing promotion code associated with this tier if it is promotional. Null for non-promotional tiers.' ;
    rdfs:domain ind:PricingTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionalFlag rdf:type rdf:Property ;
    rdfs:label 'Promotional Flag' ;
    rdfs:comment 'Indicates whether this tier is part of a promotional campaign (True) or a standard ongoing tier (False).' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sustainabilityIncentiveFlag rdf:type rdf:Property ;
    rdfs:label 'Sustainability Incentive Flag' ;
    rdfs:comment 'Indicates whether this tier includes pricing incentives for sustainability goals such as diversion rate targets or Greenhouse Gas (GHG) reduction (True) or is standard pricing (False).' ;
    rdfs:domain ind:PricingTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tierCode rdf:type rdf:Property ;
    rdfs:label 'Tier Code' ;
    rdfs:comment 'Unique business code identifying this pricing tier within the rate schedule. Used for operational reference and system integration.' ;
    rdfs:domain ind:PricingTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierDescription rdf:type rdf:Property ;
    rdfs:label 'Tier Description' ;
    rdfs:comment 'Detailed description of the pricing tier, including eligibility criteria, benefits, and applicable conditions.' ;
    rdfs:domain ind:PricingTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierName rdf:type rdf:Property ;
    rdfs:label 'Tier Name' ;
    rdfs:comment 'Human-readable name of the pricing tier (e.g., Bronze, Silver, Gold, Volume Tier 1, Commitment Tier 3).' ;
    rdfs:domain ind:PricingTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierRateAmount rdf:type rdf:Property ;
    rdfs:label 'Tier Rate Amount' ;
    rdfs:comment 'The pricing rate applicable to this tier. Interpretation depends on rate_unit (e.g., dollars per ton, dollars per pickup, flat monthly fee).' ;
    rdfs:domain ind:PricingTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tierSequence rdf:type rdf:Property ;
    rdfs:label 'Tier Sequence' ;
    rdfs:comment 'Ordinal position of this tier within the rate schedule, used for sorting and display purposes (e.g., 1 for lowest tier, 2 for next tier).' ;
    rdfs:domain ind:PricingTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tierStatus rdf:type rdf:Property ;
    rdfs:label 'Tier Status' ;
    rdfs:comment 'Current lifecycle status of the pricing tier: active (in use), inactive (not available), pending (awaiting approval), expired (past effective date), suspended (temporarily unavailable).' ;
    rdfs:domain ind:PricingTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierType rdf:type rdf:Property ;
    rdfs:label 'Tier Type' ;
    rdfs:comment 'Classification of the pricing tier basis: volume-based (tonnage thresholds), commitment-based (contract term), frequency-based (pickup frequency), hybrid (multiple factors), promotional (temporary offer), or standard (default tier).' ;
    rdfs:domain ind:PricingTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:franchisePermitId rdf:type rdf:Property ;
    rdfs:label 'Franchise Permit Id' ;
    rdfs:comment 'Foreign key linking to compliance.permit. Business justification: Service areas operate under municipal franchise agreements that are formalized as permits. Franchise permit defines service obligations, rate structures, performance standards, and geographic boundari' ;
    rdfs:domain ind:Service ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Permit .

ind:primaryLandfillFacilityId rdf:type rdf:Property ;
    rdfs:label 'Primary Landfill Facility Id' ;
    rdfs:comment 'Identifier of the primary landfill or disposal facility serving this service area. Used for haul routing and tipping fee calculation.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:primaryMrfFacilityId rdf:type rdf:Property ;
    rdfs:label 'Primary Mrf Facility Id' ;
    rdfs:comment 'Identifier of the primary MRF processing recyclable materials from this service area.' ;
    rdfs:domain ind:Area ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:territoryId rdf:type rdf:Property ;
    rdfs:label 'Territory Id' ;
    rdfs:comment 'Foreign key linking to service.service_territory. Business justification: Service_territory and service_area represent a hierarchical geographic relationship. Territories are broader planning zones (franchise boundaries, municipal contracts), while service_areas are operati' ;
    rdfs:domain ind:Service ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Territory .

ind:territoryManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Territory Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Service areas have assigned territory managers for customer escalations, franchise compliance oversight, and performance accountability. Reuses existing territory_manager_name as denormalized data. Es' ;
    rdfs:domain ind:Area ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:areaCode rdf:type rdf:Property ;
    rdfs:label 'Area Code' ;
    rdfs:comment 'Business identifier code for the service area used in operational systems and customer communications. Typically follows a regional or district-based naming convention.' ;
    rdfs:domain ind:Area ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:areaName rdf:type rdf:Property ;
    rdfs:label 'Area Name' ;
    rdfs:comment 'Human-readable name of the service area, typically reflecting the municipality, county, or region served (e.g., \'Downtown Chicago\', \'Orange County North\').' ;
    rdfs:domain ind:Area ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:areaType rdf:type rdf:Property ;
    rdfs:label 'Area Type' ;
    rdfs:comment 'Classification of the service area based on the predominant customer segment and waste generation profile. Determines service offerings, equipment types, and routing strategies.' ;
    rdfs:domain ind:Area ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:censusTractList rdf:type rdf:Property ;
    rdfs:label 'Census Tract List' ;
    rdfs:comment 'Comma-separated list of U.S. Census tract identifiers covered by this service area. Used for demographic analysis and environmental justice reporting.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:franchiseAgreementNumber rdf:type rdf:Property ;
    rdfs:label 'Franchise Agreement Number' ;
    rdfs:comment 'Reference number of the franchise or municipal contract authorizing waste collection services in this area. Links to the master contract repository.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:franchiseExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Franchise Expiration Date' ;
    rdfs:comment 'Date on which the current franchise agreement expires. Critical for contract renewal planning and service continuity.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:geographicBoundaryWkt rdf:type rdf:Property ;
    rdfs:label 'Geographic Boundary Wkt' ;
    rdfs:comment 'Well-Known Text representation of the service area polygon boundary. Used for GIS mapping, route optimization, and spatial eligibility checks.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gpsTrackingRequired rdf:type rdf:Property ;
    rdfs:label 'Gps Tracking Required' ;
    rdfs:comment 'Indicates whether GPS tracking is mandated for all collection vehicles operating in this service area (may be required by franchise agreement).' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazmatCollectionAvailable rdf:type rdf:Property ;
    rdfs:label 'Hazmat Collection Available' ;
    rdfs:comment 'Indicates whether hazardous waste collection events or services are offered in this service area.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:householdCountEstimate rdf:type rdf:Property ;
    rdfs:label 'Household Count Estimate' ;
    rdfs:comment 'Estimated number of residential households in the service area. Key metric for residential service planning and revenue forecasting.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:leaAgencyName rdf:type rdf:Property ;
    rdfs:label 'Lea Agency Name' ;
    rdfs:comment 'Name of the Local Enforcement Agency responsible for solid waste compliance oversight in this service area.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organicsProgramAvailable rdf:type rdf:Property ;
    rdfs:label 'Organics Program Available' ;
    rdfs:comment 'Indicates whether organic waste collection (yard waste, food scraps) is available in this service area.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:populationEstimate rdf:type rdf:Property ;
    rdfs:label 'Population Estimate' ;
    rdfs:comment 'Estimated total population residing within the service area boundaries. Used for capacity planning and market analysis.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recyclingProgramAvailable rdf:type rdf:Property ;
    rdfs:label 'Recycling Program Available' ;
    rdfs:comment 'Indicates whether curbside recycling services are available to customers in this service area.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:routeOptimizationEnabled rdf:type rdf:Property ;
    rdfs:label 'Route Optimization Enabled' ;
    rdfs:comment 'Indicates whether automated route optimization algorithms are applied to collection routes in this service area.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceFrequencyResidential rdf:type rdf:Property ;
    rdfs:label 'Service Frequency Residential' ;
    rdfs:comment 'Standard collection frequency for residential customers in this service area. Determines route scheduling and capacity requirements.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:squareMiles rdf:type rdf:Property ;
    rdfs:label 'Square Miles' ;
    rdfs:comment 'Total geographic area covered by this service area in square miles. Used for density analysis and resource planning.' ;
    rdfs:domain ind:Area ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:updatedByUser rdf:type rdf:Property ;
    rdfs:label 'Updated By User' ;
    rdfs:comment 'Username or identifier of the user who last modified this service area record.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundleId rdf:type rdf:Property ;
    rdfs:label 'Bundle Id' ;
    rdfs:comment 'Unique identifier for the service bundle. Primary key.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Bundle .

ind:basePrice rdf:type rdf:Property ;
    rdfs:label 'Base Price' ;
    rdfs:comment 'Base price of the service bundle before any discounts, surcharges, or taxes. Expressed in USD.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bundleCategory rdf:type rdf:Property ;
    rdfs:label 'Bundle Category' ;
    rdfs:comment 'Primary service category that the bundle addresses (collection-only, recycling-focused, comprehensive waste management, etc.).' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundleCode rdf:type rdf:Property ;
    rdfs:label 'Bundle Code' ;
    rdfs:comment 'Externally-known unique code for the service bundle used in contracts, billing, and customer communications.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundleDescription rdf:type rdf:Property ;
    rdfs:label 'Bundle Description' ;
    rdfs:comment 'Detailed description of the service bundle, including what services are included and the value proposition for customers.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundleName rdf:type rdf:Property ;
    rdfs:label 'Bundle Name' ;
    rdfs:comment 'Human-readable name of the service bundle (e.g., \'Residential Complete Care Package\', \'Commercial Waste & Recycling Bundle\').' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundleType rdf:type rdf:Property ;
    rdfs:label 'Bundle Type' ;
    rdfs:comment 'Classification of the service bundle by customer segment and offering type.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:earlyTerminationFee rdf:type rdf:Property ;
    rdfs:label 'Early Termination Fee' ;
    rdfs:comment 'Fee charged if the customer terminates the bundle contract before the minimum term expires. Null if no early termination fee applies. Expressed in USD.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geographicAvailability rdf:type rdf:Property ;
    rdfs:label 'Geographic Availability' ;
    rdfs:comment 'Geographic regions, service zones, or districts where this bundle is available for sale and fulfillment.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingCampaignCode rdf:type rdf:Property ;
    rdfs:label 'Marketing Campaign Code' ;
    rdfs:comment 'Code identifying the marketing campaign associated with this bundle. Null if not part of a specific campaign.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productManagerName rdf:type rdf:Property ;
    rdfs:label 'Product Manager Name' ;
    rdfs:comment 'Name of the product manager responsible for this service bundle.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionEndDate rdf:type rdf:Property ;
    rdfs:label 'Promotion End Date' ;
    rdfs:comment 'Date when the promotional bundle is no longer available for new sales. Null if not a promotional bundle or if open-ended.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:promotionStartDate rdf:type rdf:Property ;
    rdfs:label 'Promotion Start Date' ;
    rdfs:comment 'Date when the promotional bundle becomes available for sale. Null if not a promotional bundle.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryComplianceNotes rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Notes' ;
    rdfs:comment 'Notes on regulatory compliance requirements or certifications associated with this bundle (e.g., RCRA compliance for hazardous waste components, EPA reporting requirements).' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Sustainability Certified Flag' ;
    rdfs:comment 'Indicates whether this bundle includes sustainability-certified services (e.g., carbon-neutral collection, renewable natural gas fleet, zero-waste-to-landfill programs).' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:channelId rdf:type rdf:Property ;
    rdfs:label 'Channel Id' ;
    rdfs:comment 'Unique identifier for the service delivery channel. Primary key.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:standardFrequencyPlanId rdf:type rdf:Property ;
    rdfs:label 'Standard Frequency Plan Id' ;
    rdfs:comment 'Foreign key linking to service.frequency_plan. Business justification: Service channel has a standard frequency plan. The service_channel table has a STRING column \'service_frequency_standard\' that should be replaced with a proper FK to frequency_plan.frequency_plan_id. ' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FrequencyPlan .

ind:amcsChannelCode rdf:type rdf:Property ;
    rdfs:label 'Amcs Channel Code' ;
    rdfs:comment 'Service channel code used in AMCS Platform for route optimization, dispatching, and operational management.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdlRequirement rdf:type rdf:Property ;
    rdfs:label 'Cdl Requirement' ;
    rdfs:comment 'Minimum Commercial Driver License class required for drivers operating in this service channel under DOT regulations.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelCategory rdf:type rdf:Property ;
    rdfs:label 'Channel Category' ;
    rdfs:comment 'Operational category defining how the service is delivered to the customer (e.g., curbside pickup, on-site container service, customer drop-off).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelCode rdf:type rdf:Property ;
    rdfs:label 'Channel Code' ;
    rdfs:comment 'Unique business code identifying the service delivery channel (e.g., RES_CURBSIDE, COM_ONSITE, MUNICIPAL_CONTRACT).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelDescription rdf:type rdf:Property ;
    rdfs:label 'Channel Description' ;
    rdfs:comment 'Detailed description of the service delivery channel, including operational characteristics and target customer segments.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelName rdf:type rdf:Property ;
    rdfs:label 'Channel Name' ;
    rdfs:comment 'Human-readable name of the service delivery channel (e.g., Residential Curbside, Commercial On-Site, Municipal Contract).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelStatus rdf:type rdf:Property ;
    rdfs:label 'Channel Status' ;
    rdfs:comment 'Current operational status of the service channel (active and available, inactive, temporarily suspended, pilot testing phase, being phased out).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelType rdf:type rdf:Property ;
    rdfs:label 'Channel Type' ;
    rdfs:comment 'Classification of the service delivery channel by primary customer segment and delivery model.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerOwnershipModel rdf:type rdf:Property ;
    rdfs:label 'Container Ownership Model' ;
    rdfs:comment 'Defines who owns the waste containers used in this service channel (company-owned and provided, customer-owned, rental from company, lease agreement, shared municipal containers).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerPortalEnabled rdf:type rdf:Property ;
    rdfs:label 'Customer Portal Enabled' ;
    rdfs:comment 'Indicates whether customers using this channel have access to online self-service portal for scheduling, billing, and service management.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryModel rdf:type rdf:Property ;
    rdfs:label 'Delivery Model' ;
    rdfs:comment 'Defines the temporal pattern of service delivery (scheduled recurring, on-demand request, continuous access, seasonal, temporary project).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dotHazmatEndorsementRequired rdf:type rdf:Property ;
    rdfs:label 'Dot Hazmat Endorsement Required' ;
    rdfs:comment 'Indicates whether drivers must hold a DOT HAZMAT endorsement to operate in this service channel due to hazardous waste handling.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:franchiseAgreementRequired rdf:type rdf:Property ;
    rdfs:label 'Franchise Agreement Required' ;
    rdfs:comment 'Indicates whether a municipal franchise agreement is required to provide services through this channel in specific geographic areas.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minimumServiceCommitmentMonths rdf:type rdf:Property ;
    rdfs:label 'Minimum Service Commitment Months' ;
    rdfs:comment 'Minimum contract term in months required for customers subscribing to services through this channel.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:onlineBookingEnabled rdf:type rdf:Property ;
    rdfs:label 'Online Booking Enabled' ;
    rdfs:comment 'Indicates whether customers can book and schedule services through this channel via online self-service without human interaction.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rfidTrackingEnabled rdf:type rdf:Property ;
    rdfs:label 'Rfid Tracking Enabled' ;
    rdfs:comment 'Indicates whether RFID container tracking is enabled for this service channel to capture container-level service events and waste stream data.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:salesforceChannelCode rdf:type rdf:Property ;
    rdfs:label 'Salesforce Channel Code' ;
    rdfs:comment 'External identifier for this service channel in Salesforce CRM system for sales process and opportunity management integration.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapSdDistributionChannel rdf:type rdf:Property ;
    rdfs:label 'Sap Sd Distribution Channel' ;
    rdfs:comment 'SAP S/4HANA distribution channel code representing this service delivery channel in the ERP system.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapSdSalesOrg rdf:type rdf:Property ;
    rdfs:label 'Sap Sd Sales Org' ;
    rdfs:comment 'SAP S/4HANA Sales and Distribution sales organization code associated with this service channel for order processing and revenue recognition.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cogsAccount rdf:type rdf:Property ;
    rdfs:label 'Cogs Account' ;
    rdfs:comment 'General Ledger account number for Cost of Goods Sold associated with delivering this service.' ;
    rdfs:domain ind:Code ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerPortalVisibleFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Portal Visible Flag' ;
    rdfs:comment 'Indicates whether this service is visible and available for self-service ordering in the customer portal (True) or restricted to internal sales channels only (False).' ;
    rdfs:domain ind:Code ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:diversionCreditEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Diversion Credit Eligible Flag' ;
    rdfs:comment 'Indicates whether tonnage from this service counts toward landfill diversion rate calculations (True) or not (False). True for recycling, composting, and waste-to-energy services.' ;
    rdfs:domain ind:Code ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:epaWasteCategory rdf:type rdf:Property ;
    rdfs:label 'Epa Waste Category' ;
    rdfs:comment 'EPA waste category classification for reporting and compliance purposes (e.g., MSW, C&D, industrial non-hazardous, hazardous).' ;
    rdfs:domain ind:Code ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ghgReductionEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Ghg Reduction Eligible Flag' ;
    rdfs:comment 'Indicates whether this service contributes to greenhouse gas (GHG) emission reductions and is eligible for carbon credit or offset programs (True) or not (False). Applies to recycling, composting, and WTE services.' ;
    rdfs:domain ind:Code ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minimumServiceTermMonths rdf:type rdf:Property ;
    rdfs:label 'Minimum Service Term Months' ;
    rdfs:comment 'Minimum contract term required for this service, expressed in months. Zero indicates no minimum term (month-to-month service).' ;
    rdfs:domain ind:Code ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pickupDaysPerWeek rdf:type rdf:Property ;
    rdfs:label 'Pickup Days Per Week' ;
    rdfs:comment 'Number of scheduled pickup days per week for this service (0-7). Zero indicates on-call or non-recurring services.' ;
    rdfs:domain ind:Code ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceStatus rdf:type rdf:Property ;
    rdfs:label 'Service Status' ;
    rdfs:comment 'Current lifecycle status of the service code: active (available for sale), inactive (temporarily unavailable), suspended (on hold), discontinued (no longer offered), or pending approval (awaiting activation).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentServiceLineId rdf:type rdf:Property ;
    rdfs:label 'Parent Service Line Id' ;
    rdfs:comment 'Reference to a parent service line if this service line is a sub-category or specialization. Enables hierarchical service line taxonomy. Null for top-level service lines.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Line .

ind:standardJobPositionId rdf:type rdf:Property ;
    rdfs:label 'Standard Job Position Id' ;
    rdfs:comment 'Foreign key linking to workforce.job_position. Business justification: Service lines define workforce requirements: residential collection needs CDL-B drivers, industrial hazmat needs certified technicians. Drives headcount planning, job requisition creation, labor cost ' ;
    rdfs:domain ind:Line ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JobPosition .

ind:basePriceUsd rdf:type rdf:Property ;
    rdfs:label 'Base Price Usd' ;
    rdfs:comment 'Standard base price or starting price point for this service line in USD. Actual customer pricing may vary based on contract terms, volume commitments, and market conditions. Used for financial planning and margin analysis.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carbonOffsetEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Carbon Offset Eligible Flag' ;
    rdfs:comment 'Indicates whether this service line generates activities eligible for carbon offset credits or renewable energy certificates. True for LFG-to-energy, RNG production, and WTE operations.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:collectionFrequencyStandard rdf:type rdf:Property ;
    rdfs:label 'Collection Frequency Standard' ;
    rdfs:comment 'Standard or default collection frequency for this service line. Actual customer frequency may vary based on contract terms. On-demand applies to roll-off and specialty services; scheduled event applies to hazardous waste collection events.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerTypeCategory rdf:type rdf:Property ;
    rdfs:label 'Container Type Category' ;
    rdfs:comment 'Primary container or equipment types used to deliver this service line. Examples: carts (residential), dumpsters (commercial front-load), compactors (high-volume commercial), roll-off containers (construction), specialized containers (hazardous waste). Supports operational planning and asset allocation. [ENUM-REF-CANDIDATE: cart|dumpster|compactor|roll_off|specialized_container|bulk_pickup|curbside|drop_off_center — promote to reference product]' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractTemplateCode rdf:type rdf:Property ;
    rdfs:label 'Contract Template Code' ;
    rdfs:comment 'Reference to the standard contract template used for this service line in Salesforce CRM. Supports contract generation and legal compliance.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerPortalEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Portal Enabled Flag' ;
    rdfs:comment 'Indicates whether customers can self-service this service line through the online customer portal (Waste Logics). True for standard services with online scheduling and account management; false for specialized services requiring direct sales engagement.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:diversionRateTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Diversion Rate Target Percent' ;
    rdfs:comment 'Target percentage of waste diverted from landfill for this service line. Applicable to recycling, composting, and WTE programs. Expressed as percentage (e.g., 75.00 for 75% diversion). Null for non-diversion service lines.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:driverCdlRequirement rdf:type rdf:Property ;
    rdfs:label 'Driver Cdl Requirement' ;
    rdfs:comment 'Minimum CDL class and endorsements required for drivers operating this service line. Class A for combination vehicles, Class B for heavy straight trucks, HAZMAT endorsement for hazardous waste transport.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epaWasteCodeCategory rdf:type rdf:Property ;
    rdfs:label 'Epa Waste Code Category' ;
    rdfs:comment 'Primary EPA waste code category or categories applicable to this service line. Examples: D-list (characteristic hazardous), F-list (non-specific source), K-list (specific source), P/U-list (discarded commercial products). Empty for non-hazardous service lines.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fleetTypeRequirement rdf:type rdf:Property ;
    rdfs:label 'Fleet Type Requirement' ;
    rdfs:comment 'Primary fleet vehicle types required to deliver this service line. Examples: ASL (Automated Side Loader) for residential carts, FEL (Front End Loader) for commercial dumpsters, REL (Rear End Loader) for manual collection, roll-off trucks, specialized hazmat vehicles. Supports fleet planning and maintenance scheduling. [ENUM-REF-CANDIDATE: asl|fel|rel|roll_off_truck|hazmat_vehicle|transfer_trailer|specialty_equipment — promote to reference product]' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ghgReductionContributionFlag rdf:type rdf:Property ;
    rdfs:label 'Ghg Reduction Contribution Flag' ;
    rdfs:comment 'Indicates whether this service line contributes to greenhouse gas emission reduction goals. True for WTE, RNG, recycling, and CNG fleet operations.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insuranceRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Insurance Requirement Flag' ;
    rdfs:comment 'Indicates whether this service line requires specialized insurance coverage beyond standard general liability. True for hazardous waste, high-value assets, and environmental liability exposures.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ppeRequirementLevel rdf:type rdf:Property ;
    rdfs:label 'Ppe Requirement Level' ;
    rdfs:comment 'Level of PPE required for workers delivering this service line. Standard for routine collection, enhanced for heavy industrial, HAZMAT for hazardous waste handling, specialized for WTE or TSDF operations.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitMarginTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Profit Margin Target Percent' ;
    rdfs:comment 'Target profit margin percentage for this service line. Used for pricing strategy, contract negotiations, and performance evaluation. Expressed as percentage (e.g., 25.00 for 25%).' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueAccountCode rdf:type rdf:Property ;
    rdfs:label 'Revenue Account Code' ;
    rdfs:comment 'General Ledger (GL) revenue account code for posting revenue from this service line. Supports financial reporting, revenue recognition, and EBITDA analysis.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeOptimizationEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Route Optimization Eligible Flag' ;
    rdfs:comment 'Indicates whether this service line is eligible for automated route optimization and dynamic dispatching. True for scheduled collection services; false for on-demand or event-based services.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceLineCode rdf:type rdf:Property ;
    rdfs:label 'Service Line Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the service line for external reference and system integration. Examples: RES-COL, COM-COL, ROLL-OFF, RECYCLE, HAZ-WASTE, WTE.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceLineDescription rdf:type rdf:Property ;
    rdfs:label 'Service Line Description' ;
    rdfs:comment 'Detailed description of the service line, including scope, target customer segments, and key service characteristics.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceLineName rdf:type rdf:Property ;
    rdfs:label 'Service Line Name' ;
    rdfs:comment 'Full business name of the service line. Examples: Residential Collection, Commercial Collection, Roll-Off Services, Recycling Programs, Hazardous Waste Management, Waste-to-Energy (WTE), Specialty Services.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceLineStatus rdf:type rdf:Property ;
    rdfs:label 'Service Line Status' ;
    rdfs:comment 'Current lifecycle status of the service line. Active lines are available for sale and delivery; inactive lines are discontinued; pilot lines are in testing; sunset lines are being phased out; seasonal lines operate during specific periods.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingCertificationRequired rdf:type rdf:Property ;
    rdfs:label 'Training Certification Required' ;
    rdfs:comment 'Specific training certifications or qualifications required for personnel delivering this service line. Examples: HAZWOPER 40-hour, DOT HAZMAT, OSHA confined space, forklift operator. Empty for services with no specialized training requirements.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByScheduleServiceRateScheduleId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Schedule Service Rate Schedule Id' ;
    rdfs:comment 'Reference to the newer rate schedule that replaces this one. Null if this is the current active version.' ;
    rdfs:domain ind:ServiceRateSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceRateSchedule .

ind:baseRateUnit rdf:type rdf:Property ;
    rdfs:label 'Base Rate Unit' ;
    rdfs:comment 'Unit of measure for the base rate amount. Defines how the service is priced (monthly subscription, per-pickup, tonnage-based, volume-based). [ENUM-REF-CANDIDATE: per_month|per_pickup|per_ton|per_yard|per_gallon|per_event|per_container — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ServiceRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contaminationThresholdPercentage rdf:type rdf:Property ;
    rdfs:label 'Contamination Threshold Percentage' ;
    rdfs:comment 'Maximum allowable contamination percentage in recycling or waste stream before contamination surcharge applies. Typically 5-10% for recycling programs.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalFeeMethod rdf:type rdf:Property ;
    rdfs:label 'Environmental Fee Method' ;
    rdfs:comment 'Method used to calculate environmental recovery fee component. Fixed amount or percentage of base rate.' ;
    rdfs:domain ind:ServiceRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalRecoveryFee rdf:type rdf:Property ;
    rdfs:label 'Environmental Recovery Fee' ;
    rdfs:comment 'Fee charged to recover costs of environmental compliance, monitoring, and sustainability programs. May be fixed or calculated as percentage of base rate.' ;
    rdfs:domain ind:ServiceRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelIndexAdjustmentRate rdf:type rdf:Property ;
    rdfs:label 'Fuel Index Adjustment Rate' ;
    rdfs:comment 'Rate multiplier applied to the difference between current DOE diesel price and threshold to calculate surcharge. Used when fuel_surcharge_method is index_linked.' ;
    rdfs:domain ind:ServiceRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelIndexThreshold rdf:type rdf:Property ;
    rdfs:label 'Fuel Index Threshold' ;
    rdfs:comment 'DOE diesel price per gallon threshold above which index-linked fuel surcharge applies. Used when fuel_surcharge_method is index_linked.' ;
    rdfs:domain ind:ServiceRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelSurchargeBaseAmount rdf:type rdf:Property ;
    rdfs:label 'Fuel Surcharge Base Amount' ;
    rdfs:comment 'Fixed fuel surcharge amount when method is fixed_amount, or base amount for percentage calculation. Null when method is index_linked or none.' ;
    rdfs:domain ind:ServiceRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelSurchargeMethod rdf:type rdf:Property ;
    rdfs:label 'Fuel Surcharge Method' ;
    rdfs:comment 'Method used to calculate fuel surcharge component. Index-linked typically references DOE diesel price index with threshold and adjustment formula.' ;
    rdfs:domain ind:ServiceRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumServiceCharge rdf:type rdf:Property ;
    rdfs:label 'Minimum Service Charge' ;
    rdfs:comment 'Minimum monthly or per-service charge regardless of usage or volume. Ensures cost recovery for low-volume customers.' ;
    rdfs:domain ind:ServiceRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overweightFee rdf:type rdf:Property ;
    rdfs:label 'Overweight Fee' ;
    rdfs:comment 'Fee charged per unit (ton or pound) when container or load weight exceeds the standard weight limit included in base rate.' ;
    rdfs:domain ind:ServiceRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateScheduleCode rdf:type rdf:Property ;
    rdfs:label 'Rate Schedule Code' ;
    rdfs:comment 'Unique business identifier for the rate schedule used in billing systems and customer contracts. Typically follows format SERVICE-SEGMENT-GEO-VERSION.' ;
    rdfs:domain ind:ServiceRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateScheduleName rdf:type rdf:Property ;
    rdfs:label 'Rate Schedule Name' ;
    rdfs:comment 'Human-readable descriptive name of the rate schedule for business user identification and reporting purposes.' ;
    rdfs:domain ind:ServiceRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateScheduleStatus rdf:type rdf:Property ;
    rdfs:label 'Rate Schedule Status' ;
    rdfs:comment 'Current lifecycle status of the rate schedule. Active schedules are available for new contracts; expired or superseded schedules are retained for historical billing.' ;
    rdfs:domain ind:ServiceRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateVersion rdf:type rdf:Property ;
    rdfs:label 'Rate Version' ;
    rdfs:comment 'Version number for this rate schedule. Increments with each revision to support time-bound rate versioning for annual adjustments.' ;
    rdfs:domain ind:ServiceRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryComplianceFee rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Fee' ;
    rdfs:comment 'Fee charged to cover costs of regulatory compliance including RCRA, CERCLA, state and local permit requirements, and reporting obligations.' ;
    rdfs:domain ind:ServiceRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salesTaxRate rdf:type rdf:Property ;
    rdfs:label 'Sales Tax Rate' ;
    rdfs:comment 'Applicable sales tax rate as decimal for this service area and customer segment. Null if tax_inclusive_flag is true or service is tax-exempt.' ;
    rdfs:domain ind:ServiceRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardWeightLimit rdf:type rdf:Property ;
    rdfs:label 'Standard Weight Limit' ;
    rdfs:comment 'Maximum weight in tons or pounds included in the base rate before overweight fees apply. Varies by service type and container size.' ;
    rdfs:domain ind:ServiceRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxInclusiveFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Inclusive Flag' ;
    rdfs:comment 'Indicates whether the base rate and fees include applicable taxes (true) or taxes are calculated separately (false).' ;
    rdfs:domain ind:ServiceRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tippingFeeMethod rdf:type rdf:Property ;
    rdfs:label 'Tipping Fee Method' ;
    rdfs:comment 'Method for calculating and applying tipping fee charges. Fixed per ton, actual cost pass-through, included in base rate, or not applicable.' ;
    rdfs:domain ind:ServiceRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tippingFeePassthrough rdf:type rdf:Property ;
    rdfs:label 'Tipping Fee Passthrough' ;
    rdfs:comment 'Landfill or disposal facility tipping fee per ton passed through to customer. Reflects actual disposal costs at destination facility.' ;
    rdfs:domain ind:ServiceRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:restrictionId rdf:type rdf:Property ;
    rdfs:label 'Restriction Id' ;
    rdfs:comment 'Unique identifier for the service restriction record. Primary key.' ;
    rdfs:domain ind:Restriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedServiceAreaId rdf:type rdf:Property ;
    rdfs:label 'Affected Service Area Id' ;
    rdfs:comment 'Foreign key linking to service.service_area. Business justification: Service restriction applies to a specific service area. The service_restriction table has a STRING column \'affected_service_area\' that should be replaced with a proper FK to service_area.service_area_' ;
    rdfs:domain ind:Restriction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Area .

ind:restrictionAlternativeOfferingId rdf:type rdf:Property ;
    rdfs:label 'Restriction Alternative Offering Id' ;
    rdfs:comment 'Reference to an alternative service offering that customers can use if the primary offering is restricted. Null if no alternative is available.' ;
    rdfs:domain ind:Restriction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Offering .

ind:restrictionOfferingId rdf:type rdf:Property ;
    rdfs:label 'Restriction Offering Id' ;
    rdfs:comment 'Reference to the service offering that is subject to this restriction. Links to the service offering catalog.' ;
    rdfs:domain ind:Restriction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Offering .

ind:triggeringIncidentId rdf:type rdf:Property ;
    rdfs:label 'Triggering Incident Id' ;
    rdfs:comment 'Foreign key linking to safety.incident. Business justification: Service restrictions are often imposed following safety incidents (e.g., suspending hazmat collection after spill incident). Operations teams reference the triggering incident when documenting restric' ;
    rdfs:domain ind:Restriction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Incident .

ind:affectedCustomerSegment rdf:type rdf:Property ;
    rdfs:label 'Affected Customer Segment' ;
    rdfs:comment 'Customer type or segment to which the restriction applies. Null if restriction applies universally.' ;
    rdfs:domain ind:Restriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amcsRestrictionFlag rdf:type rdf:Property ;
    rdfs:label 'Amcs Restriction Flag' ;
    rdfs:comment 'AMCS platform flag or code used to enforce this restriction in route optimization and dispatching. Null if not applicable to AMCS.' ;
    rdfs:domain ind:Restriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frequencyLimit rdf:type rdf:Property ;
    rdfs:label 'Frequency Limit' ;
    rdfs:comment 'Maximum service frequency allowed under the restriction (e.g., once per month, quarterly only). Null if no frequency limit applies.' ;
    rdfs:domain ind:Restriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reason rdf:type rdf:Property ;
    rdfs:label 'Reason' ;
    rdfs:comment 'Detailed business or regulatory rationale for the restriction (e.g., EPA hazardous waste exclusion, franchise agreement moratorium, facility capacity constraint, seasonal road closure).' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictionCode rdf:type rdf:Property ;
    rdfs:label 'Restriction Code' ;
    rdfs:comment 'Unique business code identifying the type of restriction (e.g., HAZ-EXCL-RES, CND-XFER-LIMIT, FRAN-MORATORIUM).' ;
    rdfs:domain ind:Restriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictionName rdf:type rdf:Property ;
    rdfs:label 'Restriction Name' ;
    rdfs:comment 'Human-readable name of the restriction (e.g., Hazardous Waste Exclusion - Residential Curbside, Construction and Demolition Debris Transfer Station Restriction).' ;
    rdfs:domain ind:Restriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictionScope rdf:type rdf:Property ;
    rdfs:label 'Restriction Scope' ;
    rdfs:comment 'Extent of the restriction: full_exclusion (service not available), partial_limitation (service available with conditions), conditional_approval (requires special authorization), volume_cap (quantity limit), frequency_cap (service frequency limit).' ;
    rdfs:domain ind:Restriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictionStatus rdf:type rdf:Property ;
    rdfs:label 'Restriction Status' ;
    rdfs:comment 'Current lifecycle status of the restriction. Active restrictions are enforced in eligibility checks.' ;
    rdfs:domain ind:Restriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictionType rdf:type rdf:Property ;
    rdfs:label 'Restriction Type' ;
    rdfs:comment 'Category of restriction: geographic (area-based), customer_type (residential vs commercial), waste_stream (material-based), regulatory (compliance mandate), operational (capacity or resource constraint), seasonal (time-based).' ;
    rdfs:domain ind:Restriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesforceRestrictionCode rdf:type rdf:Property ;
    rdfs:label 'Salesforce Restriction Code' ;
    rdfs:comment 'Salesforce CRM record ID for this restriction, used to enforce eligibility rules in customer service and contract management workflows. Null if not synced to Salesforce.' ;
    rdfs:domain ind:Restriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapEhsRestrictionCode rdf:type rdf:Property ;
    rdfs:label 'Sap Ehs Restriction Code' ;
    rdfs:comment 'SAP EHS module restriction code or rule identifier used to enforce this restriction in the ERP system. Null if not mapped to SAP.' ;
    rdfs:domain ind:Restriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeLimitTons rdf:type rdf:Property ;
    rdfs:label 'Volume Limit Tons' ;
    rdfs:comment 'Maximum volume or weight limit in tons if the restriction imposes a quantity cap. Null if no volume limit applies.' ;
    rdfs:domain ind:Restriction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:countyName rdf:type rdf:Property ;
    rdfs:label 'County Name' ;
    rdfs:comment 'Name of the county in which the service territory is located.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryCode rdf:type rdf:Property ;
    rdfs:label 'Territory Code' ;
    rdfs:comment 'Business identifier code for the service territory used in operational systems and reporting.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryName rdf:type rdf:Property ;
    rdfs:label 'Territory Name' ;
    rdfs:comment 'Human-readable name of the service territory for identification and reporting purposes.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryType rdf:type rdf:Property ;
    rdfs:label 'Territory Type' ;
    rdfs:comment 'Classification of the territory based on service delivery model and contractual arrangement.' ;
    rdfs:domain ind:Territory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedWteFacilityId rdf:type rdf:Property ;
    rdfs:label 'Approved Wte Facility Id' ;
    rdfs:comment 'Foreign key linking to energy.wte_facility. Business justification: Waste streams must be validated against WTE facility acceptance criteria, permits, and technology capabilities. Critical for automated waste acceptance screening, regulatory compliance, feedstock plan' ;
    rdfs:domain ind:WasteStream ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WteFacility .

ind:acceptedContainerTypes rdf:type rdf:Property ;
    rdfs:label 'Accepted Container Types' ;
    rdfs:comment 'Comma-separated list of container types (Container Identification - CID codes) that are approved for this waste stream (e.g., 96-GAL-CART, 2-YD-DUMPSTER, 20-YD-ROLLOFF, COMPACTOR). References container master data.' ;
    rdfs:domain ind:WasteStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commodityValueFlag rdf:type rdf:Property ;
    rdfs:label 'Commodity Value Flag' ;
    rdfs:comment 'Indicates whether this waste stream has commodity market value (True) or represents a disposal cost (False). Applies to recyclable materials with resale value (paper, metal, plastic).' ;
    rdfs:domain ind:WasteStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:compactionRatioAvg rdf:type rdf:Property ;
    rdfs:label 'Compaction Ratio Avg' ;
    rdfs:comment 'Average compaction ratio (volume reduction factor) for this waste stream when compacted in collection vehicles or at disposal facilities. Used for capacity planning and route optimization.' ;
    rdfs:domain ind:WasteStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compostableFlag rdf:type rdf:Property ;
    rdfs:label 'Compostable Flag' ;
    rdfs:comment 'Indicates whether this waste stream is suitable for composting operations (True) or not (False). Applies to organic waste, food waste, and yard waste streams.' ;
    rdfs:domain ind:WasteStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:densityLbsPerCubicYard rdf:type rdf:Property ;
    rdfs:label 'Density Lbs Per Cubic Yard' ;
    rdfs:comment 'Average density of this waste stream measured in pounds per cubic yard. Used for weight estimation, capacity planning, and tipping fee calculations.' ;
    rdfs:domain ind:WasteStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disposalPathway rdf:type rdf:Property ;
    rdfs:label 'Disposal Pathway' ;
    rdfs:comment 'Primary disposal or processing pathway for this waste stream: Landfill, Materials Recovery Facility (MRF), Waste-to-Energy (WTE), Treatment Storage and Disposal Facility (TSDF), Composting, or Recycling.' ;
    rdfs:domain ind:WasteStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diversionCreditPercentage rdf:type rdf:Property ;
    rdfs:label 'Diversion Credit Percentage' ;
    rdfs:comment 'Percentage of this waste stream that counts toward landfill diversion rate calculations (0-100%). Reflects the portion that is recycled, composted, or converted to energy rather than landfilled.' ;
    rdfs:domain ind:WasteStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ghgEmissionFactorCo2ePerTon rdf:type rdf:Property ;
    rdfs:label 'Ghg Emission Factor Co2e Per Ton' ;
    rdfs:comment 'Greenhouse Gas (GHG) emission factor for this waste stream expressed as kilograms of Carbon Dioxide Equivalent (CO2e) per ton of waste. Used for sustainability reporting and carbon footprint calculations.' ;
    rdfs:domain ind:WasteStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rcraSubtitle rdf:type rdf:Property ;
    rdfs:label 'Rcra Subtitle' ;
    rdfs:comment 'RCRA subtitle classification: C for hazardous waste, D for non-hazardous solid waste, N/A for streams not regulated under RCRA.' ;
    rdfs:domain ind:WasteStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recyclableFlag rdf:type rdf:Property ;
    rdfs:label 'Recyclable Flag' ;
    rdfs:comment 'Indicates whether this waste stream contains recyclable materials (True) or is non-recyclable (False). Drives routing to MRF facilities and recycling programs.' ;
    rdfs:domain ind:WasteStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryNotes rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notes' ;
    rdfs:comment 'Free-text field capturing additional regulatory requirements, restrictions, or compliance notes specific to this waste stream (e.g., state-specific handling requirements, permit conditions, reporting obligations).' ;
    rdfs:domain ind:WasteStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonalVariationFlag rdf:type rdf:Property ;
    rdfs:label 'Seasonal Variation Flag' ;
    rdfs:comment 'Indicates whether this waste stream exhibits significant seasonal volume variations (True) or has consistent year-round volumes (False). Examples include yard waste (seasonal) and MSW (consistent).' ;
    rdfs:domain ind:WasteStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specialHandlingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Special Handling Required Flag' ;
    rdfs:comment 'Indicates whether this waste stream requires special handling procedures, equipment, or certifications (True) or can be handled through standard collection processes (False).' ;
    rdfs:domain ind:WasteStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:wasteStreamCategory rdf:type rdf:Property ;
    rdfs:label 'Waste Stream Category' ;
    rdfs:comment 'High-level classification of the waste stream: Municipal Solid Waste (MSW), Construction and Demolition (C&D), Recyclable, Organic, Hazardous, Universal Waste, or Electronic Waste (E-Waste). [ENUM-REF-CANDIDATE: MSW|C&D|Recyclable|Organic|Hazardous|Universal|E-Waste — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WasteStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteStreamName rdf:type rdf:Property ;
    rdfs:label 'Waste Stream Name' ;
    rdfs:comment 'Full descriptive name of the waste stream (e.g., Municipal Solid Waste, Construction and Demolition Debris, Mixed Recyclables).' ;
    rdfs:domain ind:WasteStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteStreamStatus rdf:type rdf:Property ;
    rdfs:label 'Waste Stream Status' ;
    rdfs:comment 'Current operational status of this waste stream classification: Active (currently accepted), Inactive (temporarily not accepted), Restricted (accepted with limitations), or Phased Out (no longer accepted).' ;
    rdfs:domain ind:WasteStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wteFeedstockFlag rdf:type rdf:Property ;
    rdfs:label 'Wte Feedstock Flag' ;
    rdfs:comment 'Indicates whether this waste stream is acceptable as feedstock for Waste-to-Energy (WTE) or Solid Recovered Fuel (SRF) conversion processes (True) or not (False).' ;
    rdfs:domain ind:WasteStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiredJobPositionId rdf:type rdf:Property ;
    rdfs:label 'Required Job Position Id' ;
    rdfs:comment 'Foreign key linking to workforce.job_position. Business justification: SLA response times drive staffing requirements: 2-hour hazmat response needs on-call certified technicians, 4-hour missed pickup resolution needs route supervisors. Essential for workforce capacity pl' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JobPosition .

ind:autoCreditEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Credit Enabled Flag' ;
    rdfs:comment 'Indicates whether SLA breach credits are automatically applied to customer accounts (true) or require manual approval (false).' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complaintResolutionWindowHours rdf:type rdf:Property ;
    rdfs:label 'Complaint Resolution Window Hours' ;
    rdfs:comment 'Maximum time in hours to resolve a customer complaint or service issue to customer satisfaction.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:containerDeliveryLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Container Delivery Lead Time Days' ;
    rdfs:comment 'Maximum number of business days to deliver a container after order placement (e.g., 2 days for roll-off, 1 day for commercial dumpster).' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:containerPickupLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Container Pickup Lead Time Days' ;
    rdfs:comment 'Maximum number of business days to pick up a container after customer request (e.g., 1 day for standard service, same-day for premium).' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lateDeliveryPenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Late Delivery Penalty Amount' ;
    rdfs:comment 'Fixed dollar amount credited or refunded for late container delivery beyond committed lead time.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lateDeliveryPenaltyPct rdf:type rdf:Property ;
    rdfs:label 'Late Delivery Penalty Pct' ;
    rdfs:comment 'Percentage of service charge credited or refunded for late container delivery beyond committed lead time.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:missedPickupCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Missed Pickup Credit Amount' ;
    rdfs:comment 'Fixed dollar amount credited to customer account for each missed pickup that breaches SLA.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:missedPickupCreditPct rdf:type rdf:Property ;
    rdfs:label 'Missed Pickup Credit Pct' ;
    rdfs:comment 'Percentage of service charge credited to customer account for each missed pickup that breaches SLA (alternative to fixed amount).' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:notificationEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Notification Enabled Flag' ;
    rdfs:comment 'Indicates whether customers receive automated notifications for SLA breaches or service delays (true/false).' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:onTimeServiceRateTargetPct rdf:type rdf:Property ;
    rdfs:label 'On Time Service Rate Target Pct' ;
    rdfs:comment 'Target percentage for on-time service delivery (e.g., 98.5% for premium tier). Measured as percentage of scheduled pickups completed within service window.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resolutionTimeHours rdf:type rdf:Property ;
    rdfs:label 'Resolution Time Hours' ;
    rdfs:comment 'Maximum time in hours to resolve a service issue or complaint (e.g., 48 hours for missed pickup resolution).' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceWindowToleranceMinutes rdf:type rdf:Property ;
    rdfs:label 'Service Window Tolerance Minutes' ;
    rdfs:comment 'Allowable grace period in minutes beyond the service window end time before SLA breach is recorded (e.g., 30 minutes).' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaCode rdf:type rdf:Property ;
    rdfs:label 'Sla Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the SLA definition for system integration and reporting.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaDefinitionDescription rdf:type rdf:Property ;
    rdfs:label 'Sla Definition Description' ;
    rdfs:comment 'Detailed description of the SLA terms, commitments, and conditions. Includes any special provisions or exclusions.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaDefinitionStatus rdf:type rdf:Property ;
    rdfs:label 'Sla Definition Status' ;
    rdfs:comment 'Current lifecycle status of the SLA definition (active, inactive, draft, retired).' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaName rdf:type rdf:Property ;
    rdfs:label 'Sla Name' ;
    rdfs:comment 'Business-friendly name of the SLA definition (e.g., \'Standard Residential Pickup SLA\', \'Premium Commercial Service SLA\').' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaType rdf:type rdf:Property ;
    rdfs:label 'Sla Type' ;
    rdfs:comment 'Classification of the SLA tier (standard, premium, enterprise, custom).' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:srfProductId rdf:type rdf:Property ;
    rdfs:label 'Srf Product Id' ;
    rdfs:comment 'Unique identifier for the SRF product specification. Primary key.' ;
    rdfs:domain ind:SrfProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productionFacilityId rdf:type rdf:Property ;
    rdfs:label 'Production Facility Id' ;
    rdfs:comment 'Identifier of the primary Materials Recovery Facility (MRF) or processing facility where this SRF product is manufactured.' ;
    rdfs:domain ind:SrfProduct ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:productionPermitId rdf:type rdf:Property ;
    rdfs:label 'Production Permit Id' ;
    rdfs:comment 'Foreign key linking to compliance.permit. Business justification: SRF production requires air quality permits (emissions from processing), solid waste processing permits, and potentially RCRA permits depending on feedstock. Product cannot be manufactured or sold wit' ;
    rdfs:domain ind:SrfProduct ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Permit .

ind:qualityStandardRegulatoryRequirementId rdf:type rdf:Property ;
    rdfs:label 'Quality Standard Regulatory Requirement Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_requirement. Business justification: SRF products must meet regulatory quality standards (EN 15359 in EU, state-specific standards in US). Regulatory requirement defines calorific value limits, contaminant thresholds, testing protocols. ' ;
    rdfs:domain ind:SrfProduct ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryRequirement .

ind:sourceWasteStreamId rdf:type rdf:Property ;
    rdfs:label 'Source Waste Stream Id' ;
    rdfs:comment 'Foreign key linking to service.service_waste_stream. Business justification: SRF product is produced from a specific waste stream. The srf_product table has a STRING column \'source_waste_stream\' that should be replaced with a proper FK to service_waste_stream.service_waste_str' ;
    rdfs:domain ind:SrfProduct ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WasteStream .

ind:ashContentMaxPercent rdf:type rdf:Property ;
    rdfs:label 'Ash Content Max Percent' ;
    rdfs:comment 'Maximum allowable ash content for this SRF product grade. Quality control threshold.' ;
    rdfs:domain ind:SrfProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ashContentPercent rdf:type rdf:Property ;
    rdfs:label 'Ash Content Percent' ;
    rdfs:comment 'Target ash content of the SRF product as a percentage of dry mass. Lower ash content reduces disposal costs and improves fuel quality.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bulkDensityKgM3 rdf:type rdf:Property ;
    rdfs:label 'Bulk Density Kg M3' ;
    rdfs:comment 'Target bulk density of the SRF product measured in kilograms per cubic meter. Important for transportation logistics and storage planning.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cadmiumContentMaxMgKg rdf:type rdf:Property ;
    rdfs:label 'Cadmium Content Max Mg Kg' ;
    rdfs:comment 'Maximum allowable cadmium content for this SRF product grade. Regulatory heavy metal limit.' ;
    rdfs:domain ind:SrfProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cadmiumContentMgKg rdf:type rdf:Property ;
    rdfs:label 'Cadmium Content Mg Kg' ;
    rdfs:comment 'Target cadmium content of the SRF product measured in milligrams per kilogram of dry mass. Heavy metal specification for environmental compliance.' ;
    rdfs:domain ind:SrfProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calorificValueMaxMjKg rdf:type rdf:Property ;
    rdfs:label 'Calorific Value Max Mj Kg' ;
    rdfs:comment 'Maximum net calorific value specification for this SRF product grade. Upper bound for quality classification.' ;
    rdfs:domain ind:SrfProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calorificValueMinMjKg rdf:type rdf:Property ;
    rdfs:label 'Calorific Value Min Mj Kg' ;
    rdfs:comment 'Minimum acceptable net calorific value for this SRF product grade. Quality control threshold for product acceptance.' ;
    rdfs:domain ind:SrfProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calorificValueMjKg rdf:type rdf:Property ;
    rdfs:label 'Calorific Value Mj Kg' ;
    rdfs:comment 'Net calorific value (lower heating value) of the SRF product measured in megajoules per kilogram. Critical specification for energy content and pricing.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Certification Expiry Date' ;
    rdfs:comment 'Date when the current certification for this SRF product specification expires and requires renewal.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:chlorineContentMaxPercent rdf:type rdf:Property ;
    rdfs:label 'Chlorine Content Max Percent' ;
    rdfs:comment 'Maximum allowable chlorine content for this SRF product grade. Regulatory and customer specification limit.' ;
    rdfs:domain ind:SrfProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chlorineContentPercent rdf:type rdf:Property ;
    rdfs:label 'Chlorine Content Percent' ;
    rdfs:comment 'Target chlorine content of the SRF product as a percentage of dry mass. Critical for emissions control and boiler corrosion prevention.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:en15359Class rdf:type rdf:Property ;
    rdfs:label 'En 15359 Class' ;
    rdfs:comment 'Three-digit EN 15359 classification code representing net calorific value class, chlorine content class, and mercury content class (e.g., \'1-1-1\' for highest quality).' ;
    rdfs:domain ind:SrfProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadContentMaxMgKg rdf:type rdf:Property ;
    rdfs:label 'Lead Content Max Mg Kg' ;
    rdfs:comment 'Maximum allowable lead content for this SRF product grade. Regulatory heavy metal limit.' ;
    rdfs:domain ind:SrfProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leadContentMgKg rdf:type rdf:Property ;
    rdfs:label 'Lead Content Mg Kg' ;
    rdfs:comment 'Target lead content of the SRF product measured in milligrams per kilogram of dry mass. Heavy metal specification for environmental compliance.' ;
    rdfs:domain ind:SrfProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mercuryContentMaxMgKg rdf:type rdf:Property ;
    rdfs:label 'Mercury Content Max Mg Kg' ;
    rdfs:comment 'Maximum allowable mercury content for this SRF product grade. EPA and Clean Air Act compliance threshold.' ;
    rdfs:domain ind:SrfProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mercuryContentMgKg rdf:type rdf:Property ;
    rdfs:label 'Mercury Content Mg Kg' ;
    rdfs:comment 'Target mercury content of the SRF product measured in milligrams per kilogram of dry mass. Critical heavy metal specification for environmental compliance.' ;
    rdfs:domain ind:SrfProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:moistureContentMaxPercent rdf:type rdf:Property ;
    rdfs:label 'Moisture Content Max Percent' ;
    rdfs:comment 'Maximum allowable moisture content for this SRF product grade. Quality control threshold.' ;
    rdfs:domain ind:SrfProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:particleSizeMaxMm rdf:type rdf:Property ;
    rdfs:label 'Particle Size Max Mm' ;
    rdfs:comment 'Maximum allowable particle size for this SRF product grade. Quality control specification for customer equipment compatibility.' ;
    rdfs:domain ind:SrfProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:particleSizeMm rdf:type rdf:Property ;
    rdfs:label 'Particle Size Mm' ;
    rdfs:comment 'Target particle size of the SRF product measured in millimeters. Affects combustion efficiency and handling characteristics.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productCode rdf:type rdf:Property ;
    rdfs:label 'Product Code' ;
    rdfs:comment 'Externally-known unique business identifier for the SRF product grade. Used in sales orders, contracts, and quality certificates.' ;
    rdfs:domain ind:SrfProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productDescription rdf:type rdf:Property ;
    rdfs:label 'Product Description' ;
    rdfs:comment 'Detailed description of the SRF product including intended use, key characteristics, and differentiating features.' ;
    rdfs:domain ind:SrfProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productGrade rdf:type rdf:Property ;
    rdfs:label 'Product Grade' ;
    rdfs:comment 'Classification tier of the SRF product based on quality specifications and target market segment.' ;
    rdfs:domain ind:SrfProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productName rdf:type rdf:Property ;
    rdfs:label 'Product Name' ;
    rdfs:comment 'Human-readable name of the SRF product grade (e.g., \'Premium Grade SRF\', \'Industrial Grade SRF\', \'Cement Kiln Fuel\').' ;
    rdfs:domain ind:SrfProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productStatus rdf:type rdf:Property ;
    rdfs:label 'Product Status' ;
    rdfs:comment 'Current lifecycle status of the SRF product in the catalog. Active products are available for sale; development products are in testing phase.' ;
    rdfs:domain ind:SrfProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityStandard rdf:type rdf:Property ;
    rdfs:label 'Quality Standard' ;
    rdfs:comment 'Primary quality standard or specification framework that this SRF product conforms to (e.g., EN 15359 European standard, ASTM E2617 US standard).' ;
    rdfs:domain ind:SrfProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyDataSheetUrl rdf:type rdf:Property ;
    rdfs:label 'Safety Data Sheet Url' ;
    rdfs:comment 'URL or document reference to the Safety Data Sheet (SDS) for this SRF product, required for hazardous material handling.' ;
    rdfs:domain ind:SrfProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sulfurContentMaxPercent rdf:type rdf:Property ;
    rdfs:label 'Sulfur Content Max Percent' ;
    rdfs:comment 'Maximum allowable sulfur content for this SRF product grade. Regulatory emissions limit.' ;
    rdfs:domain ind:SrfProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sulfurContentPercent rdf:type rdf:Property ;
    rdfs:label 'Sulfur Content Percent' ;
    rdfs:comment 'Target sulfur content of the SRF product as a percentage of dry mass. Important for emissions compliance and air quality.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetMarket rdf:type rdf:Property ;
    rdfs:label 'Target Market' ;
    rdfs:comment 'Primary market segment or customer type for this SRF product (e.g., \'Cement Kilns\', \'Waste-to-Energy Facilities\', \'Industrial Boilers\', \'Power Generation\').' ;
    rdfs:domain ind:SrfProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalDataSheetUrl rdf:type rdf:Property ;
    rdfs:label 'Technical Data Sheet Url' ;
    rdfs:comment 'URL or document reference to the complete technical data sheet for this SRF product specification.' ;
    rdfs:domain ind:SrfProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surchargeDefinitionId rdf:type rdf:Property ;
    rdfs:label 'Surcharge Definition Id' ;
    rdfs:comment 'Unique identifier for the surcharge definition record. Primary key.' ;
    rdfs:domain ind:SurchargeDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicableContainerTypes rdf:type rdf:Property ;
    rdfs:label 'Applicable Container Types' ;
    rdfs:comment 'Comma-separated list of Container Identification (CID) types or container categories to which this surcharge applies. Null if not container-specific.' ;
    rdfs:domain ind:SurchargeDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableGeographicZones rdf:type rdf:Property ;
    rdfs:label 'Applicable Geographic Zones' ;
    rdfs:comment 'Comma-separated list of geographic zone codes, districts, or service areas where this surcharge is applicable. Null if applies universally.' ;
    rdfs:domain ind:SurchargeDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableServiceLines rdf:type rdf:Property ;
    rdfs:label 'Applicable Service Lines' ;
    rdfs:comment 'Comma-separated list of service line codes or categories to which this surcharge applies (e.g., residential, commercial, roll-off, recycling, hazardous waste). Empty if applies to all services.' ;
    rdfs:domain ind:SurchargeDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerNotificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Required Flag' ;
    rdfs:comment 'Indicates whether customers must be notified in advance when this surcharge is applied (true) or notification is not required (false).' ;
    rdfs:domain ind:SurchargeDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:displayOnInvoiceFlag rdf:type rdf:Property ;
    rdfs:label 'Display On Invoice Flag' ;
    rdfs:comment 'Indicates whether this surcharge should be displayed as a separate line item on customer invoices (true) or rolled into base service charge (false).' ;
    rdfs:domain ind:SurchargeDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:indexFormula rdf:type rdf:Property ;
    rdfs:label 'Index Formula' ;
    rdfs:comment 'Mathematical formula or business rule defining how the index value translates to surcharge amount. Null if not index-linked.' ;
    rdfs:domain ind:SurchargeDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indexSource rdf:type rdf:Property ;
    rdfs:label 'Index Source' ;
    rdfs:comment 'External price index or data source used for index-linked surcharges (e.g., DOE Diesel Price Index, EPA Environmental Index). Null if not index-linked.' ;
    rdfs:domain ind:SurchargeDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:percentageRate rdf:type rdf:Property ;
    rdfs:label 'Percentage Rate' ;
    rdfs:comment 'Percentage rate applied to base service charge when calculation method is percentage-based (e.g., 8.50 for 8.5%). Null if not applicable.' ;
    rdfs:domain ind:SurchargeDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryMandateFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Mandate Flag' ;
    rdfs:comment 'Indicates whether this surcharge is mandated by regulatory or governmental authority (true) or is a business-discretionary fee (false).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:surchargeCategory rdf:type rdf:Property ;
    rdfs:label 'Surcharge Category' ;
    rdfs:comment 'High-level classification of the surcharge type for grouping and reporting purposes. [ENUM-REF-CANDIDATE: fuel|environmental|regulatory|contamination|overweight|extra_service|late_fee — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SurchargeDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surchargeDefinitionStatus rdf:type rdf:Property ;
    rdfs:label 'Surcharge Definition Status' ;
    rdfs:comment 'Current lifecycle status of the surcharge definition record.' ;
    rdfs:domain ind:SurchargeDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surchargeDescription rdf:type rdf:Property ;
    rdfs:label 'Surcharge Description' ;
    rdfs:comment 'Detailed business description explaining the purpose, applicability, and calculation basis of the surcharge.' ;
    rdfs:domain ind:SurchargeDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waivableFlag rdf:type rdf:Property ;
    rdfs:label 'Waivable Flag' ;
    rdfs:comment 'Indicates whether this surcharge can be waived under certain circumstances or customer service discretion (true) or is non-waivable (false).' ;
    rdfs:domain ind:SurchargeDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waiverApprovalLevel rdf:type rdf:Property ;
    rdfs:label 'Waiver Approval Level' ;
    rdfs:comment 'Organizational approval level required to waive this surcharge. Null if surcharge is not waivable.' ;
    rdfs:domain ind:SurchargeDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Sponsor Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Carbon reduction initiatives requiring capital investment need executive sponsorship for budget approval, board reporting, and strategic alignment. Distinct from program_manager role which handles exe' ;
    rdfs:domain ind:CarbonInitiative ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:allocationJustification rdf:type rdf:Property ;
    rdfs:label 'Allocation Justification' ;
    rdfs:comment 'Business justification explaining why this purchase requisition is allocated to this carbon initiative. Captures the operational or strategic rationale for the procurement-to-initiative linkage, supporting audit trails and budget variance analysis.' ;
    rdfs:domain ind:CarbonInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselineCo2eTons rdf:type rdf:Property ;
    rdfs:label 'Baseline Co2e Tons' ;
    rdfs:comment 'Annual greenhouse gas emissions in metric tons of CO2 equivalent measured in the baseline year, representing the starting point for reduction calculations.' ;
    rdfs:domain ind:CarbonInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baselineYear rdf:type rdf:Property ;
    rdfs:label 'Baseline Year' ;
    rdfs:comment 'Reference year used to establish the emissions baseline against which CO2e reduction targets are measured (e.g., 2020).' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:budgetImpactCategory rdf:type rdf:Property ;
    rdfs:label 'Budget Impact Category' ;
    rdfs:comment 'Classification of how this procurement impacts the carbon initiative budget: capital_investment (CAPEX for initiative implementation), operating_cost (ongoing OPEX), maintenance (recurring maintenance), consulting_services (external advisory), equipment (machinery/vehicles), materials (consumables), other.' ;
    rdfs:domain ind:CarbonInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capitalInvestmentAmount rdf:type rdf:Property ;
    rdfs:label 'Capital Investment Amount' ;
    rdfs:comment 'Total capital expenditure budgeted or committed for implementing this carbon initiative, measured in USD.' ;
    rdfs:domain ind:CarbonInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carbonCreditEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Carbon Credit Eligible Flag' ;
    rdfs:comment 'Indicates whether this initiative is eligible to generate carbon credits or offsets that can be traded or used for compliance purposes (True) or not (False).' ;
    rdfs:domain ind:CarbonInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:carbonInitiativeDescription rdf:type rdf:Property ;
    rdfs:label 'Carbon Initiative Description' ;
    rdfs:comment 'Detailed narrative description of the carbon reduction initiative including scope, objectives, and expected environmental benefits.' ;
    rdfs:domain ind:CarbonInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carbonInitiativeStatus rdf:type rdf:Property ;
    rdfs:label 'Carbon Initiative Status' ;
    rdfs:comment 'Current lifecycle status of the carbon initiative: planning (under development), approved (authorized for execution), in_progress (actively being implemented), on_hold (temporarily suspended), completed (fully implemented), or cancelled (terminated before completion).' ;
    rdfs:domain ind:CarbonInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esgReportingFramework rdf:type rdf:Property ;
    rdfs:label 'Esg Reporting Framework' ;
    rdfs:comment 'Primary ESG reporting framework(s) that this initiative supports, such as GRI (Global Reporting Initiative), TCFD (Task Force on Climate-related Financial Disclosures), CDP (Carbon Disclosure Project), SASB (Sustainability Accounting Standards Board), or internal corporate sustainability goals. [ENUM-REF-CANDIDATE: GRI|TCFD|CDP|SASB|DJSI|MSCI|FTSE4Good|Internal — promote to reference product]' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityCount rdf:type rdf:Property ;
    rdfs:label 'Facility Count' ;
    rdfs:comment 'Number of facilities or sites included in this initiative (applicable to solar installations, methane capture expansions, and facility-based programs).' ;
    rdfs:domain ind:CarbonInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:initiativeCode rdf:type rdf:Property ;
    rdfs:label 'Initiative Code' ;
    rdfs:comment 'Unique business identifier code for the initiative used in project tracking and financial systems.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiativeName rdf:type rdf:Property ;
    rdfs:label 'Initiative Name' ;
    rdfs:comment 'Business name of the carbon reduction initiative or sustainability program (e.g., \'Fleet CNG Conversion 2024\', \'Solar Installation Phase 2\').' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiativePhase rdf:type rdf:Property ;
    rdfs:label 'Initiative Phase' ;
    rdfs:comment 'Lifecycle phase of the carbon initiative when this procurement was requested: planning (pre-implementation), implementation (active deployment), operational (post-go-live support), closeout (final expenses). Enables phase-based cost analysis.' ;
    rdfs:domain ind:CarbonInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiativeType rdf:type rdf:Property ;
    rdfs:label 'Initiative Type' ;
    rdfs:comment 'Category of carbon reduction initiative: fleet electrification (electric vehicle adoption), CNG conversion (Compressed Natural Gas vehicle conversion), RNG conversion (Renewable Natural Gas vehicle conversion), LFG-to-RNG (Landfill Gas to Renewable Natural Gas conversion), solar installation (photovoltaic systems at facilities), methane capture (landfill methane capture expansion), operational efficiency (process optimization programs), renewable energy (general renewable energy adoption), or waste diversion (circular economy and recycling programs). [ENUM-REF-CANDIDATE: fleet_electrification|cng_conversion|rng_conversion|lfg_to_rng|solar_installation|methane_capture|operational_efficiency|renewable_energy|waste_diversion — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCriticalPath rdf:type rdf:Property ;
    rdfs:label 'Is Critical Path' ;
    rdfs:comment 'Indicates whether this procurement is on the critical path for initiative delivery. True if delays in this PR would directly impact the initiative\'s planned_completion_date. Used for procurement prioritization and risk management.' ;
    rdfs:domain ind:CarbonInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:linkedDate rdf:type rdf:Property ;
    rdfs:label 'Linked Date' ;
    rdfs:comment 'Date when this purchase requisition was linked to the carbon initiative for cost tracking purposes. May differ from requisition_date if allocation occurs retroactively during budget reconciliation.' ;
    rdfs:domain ind:CarbonInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operatingCostImpactAnnual rdf:type rdf:Property ;
    rdfs:label 'Operating Cost Impact Annual' ;
    rdfs:comment 'Estimated annual change in operating costs resulting from this initiative, measured in USD. Negative values indicate cost savings; positive values indicate cost increases.' ;
    rdfs:domain ind:CarbonInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paybackPeriodYears rdf:type rdf:Property ;
    rdfs:label 'Payback Period Years' ;
    rdfs:comment 'Estimated number of years required to recover the capital investment through cost savings or revenue generation from the initiative.' ;
    rdfs:domain ind:CarbonInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:programManager rdf:type rdf:Property ;
    rdfs:label 'Program Manager' ;
    rdfs:comment 'Name of the individual responsible for overall program management and delivery of the carbon initiative.' ;
    rdfs:domain ind:CarbonInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectedRoiPercent rdf:type rdf:Property ;
    rdfs:label 'Projected Roi Percent' ;
    rdfs:comment 'Expected financial return on investment expressed as a percentage, calculated based on capital investment and projected cost savings or revenue generation over the initiative lifecycle.' ;
    rdfs:domain ind:CarbonInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewableEnergyCapacityMw rdf:type rdf:Property ;
    rdfs:label 'Renewable Energy Capacity Mw' ;
    rdfs:comment 'Total renewable energy generation capacity in megawatts (MW) that will be added through this initiative (applicable to solar, LFG-to-RNG, and other renewable energy projects).' ;
    rdfs:domain ind:CarbonInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responsibleBusinessUnit rdf:type rdf:Property ;
    rdfs:label 'Responsible Business Unit' ;
    rdfs:comment 'Name of the business unit, division, or department accountable for executing and managing this carbon initiative (e.g., \'Fleet Operations\', \'Landfill Operations\', \'Facilities Management\').' ;
    rdfs:domain ind:CarbonInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scope1ReductionTons rdf:type rdf:Property ;
    rdfs:label 'Scope 1 Reduction Tons' ;
    rdfs:comment 'Projected annual reduction in Scope 1 direct GHG emissions (from owned or controlled sources such as fleet vehicles and landfill operations) measured in metric tons of CO2e.' ;
    rdfs:domain ind:CarbonInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scope2ReductionTons rdf:type rdf:Property ;
    rdfs:label 'Scope 2 Reduction Tons' ;
    rdfs:comment 'Projected annual reduction in Scope 2 indirect GHG emissions (from purchased electricity, steam, heating, and cooling) measured in metric tons of CO2e.' ;
    rdfs:domain ind:CarbonInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scope3ReductionTons rdf:type rdf:Property ;
    rdfs:label 'Scope 3 Reduction Tons' ;
    rdfs:comment 'Projected annual reduction in Scope 3 indirect GHG emissions (from value chain activities including upstream and downstream emissions) measured in metric tons of CO2e.' ;
    rdfs:domain ind:CarbonInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sdgAlignment rdf:type rdf:Property ;
    rdfs:label 'Sdg Alignment' ;
    rdfs:comment 'United Nations Sustainable Development Goals that this initiative contributes to (e.g., \'SDG 7: Affordable and Clean Energy\', \'SDG 13: Climate Action\', \'SDG 12: Responsible Consumption and Production\').' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCo2eReductionTons rdf:type rdf:Property ;
    rdfs:label 'Target Co2e Reduction Tons' ;
    rdfs:comment 'Projected annual reduction in greenhouse gas emissions measured in metric tons of CO2 equivalent (CO2e) that this initiative is expected to achieve once fully implemented.' ;
    rdfs:domain ind:CarbonInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vehicleCount rdf:type rdf:Property ;
    rdfs:label 'Vehicle Count' ;
    rdfs:comment 'Number of fleet vehicles included in this initiative (applicable to fleet electrification, CNG conversion, and RNG conversion programs).' ;
    rdfs:domain ind:CarbonInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:verificationStandard rdf:type rdf:Property ;
    rdfs:label 'Verification Standard' ;
    rdfs:comment 'Third-party verification or certification standard applied to validate emissions reductions from this initiative (e.g., \'ISO 14064-3\', \'Verified Carbon Standard\', \'Climate Action Reserve Protocol\'). Null if not third-party verified.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carbonOffsetId rdf:type rdf:Property ;
    rdfs:label 'Carbon Offset Id' ;
    rdfs:comment 'Unique identifier for the carbon offset credit record. Primary key for the carbon offset master data.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CarbonOffset .

ind:carbonRegistryId rdf:type rdf:Property ;
    rdfs:label 'Carbon Registry Id' ;
    rdfs:comment 'Foreign key linking to sustainability.carbon_registry. Business justification: Carbon offsets are registered in carbon credit registries. One offset is registered in one registry (1:N). New FK needed. Removes redundant registry_name string that can be retrieved from carbon_regis' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CarbonRegistry .

ind:projectId rdf:type rdf:Property ;
    rdfs:label 'Project Id' ;
    rdfs:comment 'Unique project identifier assigned by the carbon registry (e.g., VCS project ID, Gold Standard GS number, ACR project code).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WasteManagement .

ind:additionalityVerified rdf:type rdf:Property ;
    rdfs:label 'Additionality Verified' ;
    rdfs:comment 'Indicates whether the offset project has been verified to meet additionality criteria (i.e., emission reductions would not have occurred without the carbon finance incentive). True if verified, False otherwise.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:carbonOffsetStatus rdf:type rdf:Property ;
    rdfs:label 'Carbon Offset Status' ;
    rdfs:comment 'Current lifecycle status of the carbon offset credit. Active: available for retirement; Retired: permanently claimed; Cancelled: invalidated; Expired: past eligibility window.' ;
    rdfs:domain ind:CarbonOffset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coBenefits rdf:type rdf:Property ;
    rdfs:label 'Co Benefits' ;
    rdfs:comment 'Additional environmental or social benefits delivered by the offset project beyond carbon reduction (e.g., \'Biodiversity conservation\', \'Community employment\', \'Water quality improvement\', \'UN SDG alignment\').' ;
    rdfs:domain ind:CarbonOffset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditType rdf:type rdf:Property ;
    rdfs:label 'Credit Type' ;
    rdfs:comment 'Classification of the carbon offset mechanism: Avoidance (preventing emissions that would have occurred), Removal (sequestering CO2 from atmosphere), or Reduction (decreasing emissions from baseline).' ;
    rdfs:domain ind:CarbonOffset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalNotes rdf:type rdf:Property ;
    rdfs:label 'Internal Notes' ;
    rdfs:comment 'Free-text field for internal comments, procurement notes, or strategic rationale for the carbon offset purchase.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permanenceRiskRating rdf:type rdf:Property ;
    rdfs:label 'Permanence Risk Rating' ;
    rdfs:comment 'Assessment of the risk that the carbon sequestration or emission reduction may be reversed (e.g., forest fire, project failure). Particularly relevant for forestry and land-use projects.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectCountryCode rdf:type rdf:Property ;
    rdfs:label 'Project Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code where the carbon offset project is located (e.g., USA, BRA, KEN).' ;
    rdfs:domain ind:CarbonOffset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectRegion rdf:type rdf:Property ;
    rdfs:label 'Project Region' ;
    rdfs:comment 'Geographic region or state/province where the offset project is located (e.g., \'California\', \'Amazon Basin\', \'Sub-Saharan Africa\').' ;
    rdfs:domain ind:CarbonOffset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseDate rdf:type rdf:Property ;
    rdfs:label 'Purchase Date' ;
    rdfs:comment 'Date on which the carbon offset credits were purchased or acquired by Waste Management.' ;
    rdfs:domain ind:CarbonOffset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:purchasePricePerTco2e rdf:type rdf:Property ;
    rdfs:label 'Purchase Price Per Tco2e' ;
    rdfs:comment 'Unit price paid per metric ton of CO2 equivalent for the carbon offset credits. Used for carbon pricing disclosure and internal carbon accounting.' ;
    rdfs:domain ind:CarbonOffset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityTco2e rdf:type rdf:Property ;
    rdfs:label 'Quantity Tco2e' ;
    rdfs:comment 'Total quantity of carbon offset credits in metric tons of CO2 equivalent (tCO2e). Represents the verified greenhouse gas emission reductions or removals.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportingFramework rdf:type rdf:Property ;
    rdfs:label 'Reporting Framework' ;
    rdfs:comment 'Comma-separated list of voluntary or mandatory reporting frameworks for which this offset credit is used (e.g., \'CDP Climate Change\', \'GRI 305\', \'TCFD\', \'SEC Climate Disclosure\', \'EPA GHG Reporting Program\').' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retirementSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Retirement Serial Number' ;
    rdfs:comment 'Unique serial number or certificate identifier issued by the carbon registry upon retirement of the credits. Provides proof of retirement for reporting and verification.' ;
    rdfs:domain ind:CarbonOffset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalPurchaseAmount rdf:type rdf:Property ;
    rdfs:label 'Total Purchase Amount' ;
    rdfs:comment 'Total monetary amount paid for the carbon offset credit purchase (quantity × unit price). Denominated in USD unless otherwise specified.' ;
    rdfs:domain ind:CarbonOffset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:verificationBody rdf:type rdf:Property ;
    rdfs:label 'Verification Body' ;
    rdfs:comment 'Name of the independent third-party organization that verified the emission reductions for the offset project (e.g., \'SCS Global Services\', \'DNV\', \'Bureau Veritas\').' ;
    rdfs:domain ind:CarbonOffset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryCarbonEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Carbon Employee Id' ;
    rdfs:comment 'User identifier of the person who created this carbon registry record.' ;
    rdfs:domain ind:CarbonRegistry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accountActivationDate rdf:type rdf:Property ;
    rdfs:label 'Account Activation Date' ;
    rdfs:comment 'Date when Waste Management\'s account with this carbon credit registry was activated.' ;
    rdfs:domain ind:CarbonRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accountClosureDate rdf:type rdf:Property ;
    rdfs:label 'Account Closure Date' ;
    rdfs:comment 'Date when Waste Management\'s account with this carbon credit registry was closed or deactivated.' ;
    rdfs:domain ind:CarbonRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accreditationDate rdf:type rdf:Property ;
    rdfs:label 'Accreditation Date' ;
    rdfs:comment 'Date when the carbon credit registry received its accreditation or recognition.' ;
    rdfs:domain ind:CarbonRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accreditationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Accreditation Expiry Date' ;
    rdfs:comment 'Date when the registry\'s accreditation expires and requires renewal.' ;
    rdfs:domain ind:CarbonRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:additionalityRequirement rdf:type rdf:Property ;
    rdfs:label 'Additionality Requirement' ;
    rdfs:comment 'Description of the additionality criteria that projects must meet to qualify for carbon credits in this registry.' ;
    rdfs:domain ind:CarbonRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coBenefitsTrackedFlag rdf:type rdf:Property ;
    rdfs:label 'Co Benefits Tracked Flag' ;
    rdfs:comment 'Indicates whether the registry tracks and reports co-benefits beyond carbon reduction (e.g., biodiversity, community development, water quality).' ;
    rdfs:domain ind:CarbonRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditSerialNumberFormat rdf:type rdf:Property ;
    rdfs:label 'Credit Serial Number Format' ;
    rdfs:comment 'Description or pattern of the serial number format used by this registry to uniquely identify carbon credits.' ;
    rdfs:domain ind:CarbonRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doubleCountingPreventionMechanism rdf:type rdf:Property ;
    rdfs:label 'Double Counting Prevention Mechanism' ;
    rdfs:comment 'Description of the registry\'s mechanism to prevent double counting or double claiming of carbon credits.' ;
    rdfs:domain ind:CarbonRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esgFrameworkAlignment rdf:type rdf:Property ;
    rdfs:label 'Esg Framework Alignment' ;
    rdfs:comment 'ESG reporting frameworks that recognize or accept credits from this registry (e.g., GRI, TCFD, CDP, SASB).' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permanenceRequirement rdf:type rdf:Property ;
    rdfs:label 'Permanence Requirement' ;
    rdfs:comment 'Description of permanence or reversal risk management requirements for carbon credits issued by this registry.' ;
    rdfs:domain ind:CarbonRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicRegistryAccessFlag rdf:type rdf:Property ;
    rdfs:label 'Public Registry Access Flag' ;
    rdfs:comment 'Indicates whether the registry provides public online access to credit issuance and retirement records.' ;
    rdfs:domain ind:CarbonRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:registryAccountHolderName rdf:type rdf:Property ;
    rdfs:label 'Registry Account Holder Name' ;
    rdfs:comment 'Legal name of the account holder registered with the carbon credit registry.' ;
    rdfs:domain ind:CarbonRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registryCode rdf:type rdf:Property ;
    rdfs:label 'Registry Code' ;
    rdfs:comment 'Short code or abbreviation for the carbon credit registry (e.g., VCS, GS, ACR, CAR).' ;
    rdfs:domain ind:CarbonRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registryEstablishedDate rdf:type rdf:Property ;
    rdfs:label 'Registry Established Date' ;
    rdfs:comment 'Date when the carbon credit registry was originally established or founded.' ;
    rdfs:domain ind:CarbonRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:registryFeeStructure rdf:type rdf:Property ;
    rdfs:label 'Registry Fee Structure' ;
    rdfs:comment 'Description of fees charged by the registry for account maintenance, credit issuance, transfers, and retirements.' ;
    rdfs:domain ind:CarbonRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registryJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Registry Jurisdiction' ;
    rdfs:comment 'Geographic or regulatory jurisdiction under which the carbon credit registry operates (e.g., USA, EU, Global).' ;
    rdfs:domain ind:CarbonRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registryStatus rdf:type rdf:Property ;
    rdfs:label 'Registry Status' ;
    rdfs:comment 'Current operational status of the carbon credit registry.' ;
    rdfs:domain ind:CarbonRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registryType rdf:type rdf:Property ;
    rdfs:label 'Registry Type' ;
    rdfs:comment 'Classification of the registry as voluntary market, compliance market, or hybrid.' ;
    rdfs:domain ind:CarbonRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registryWebsiteUrl rdf:type rdf:Property ;
    rdfs:label 'Registry Website Url' ;
    rdfs:comment 'Official website URL for the carbon credit registry where credit information can be verified.' ;
    rdfs:domain ind:CarbonRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retirementProcessDescription rdf:type rdf:Property ;
    rdfs:label 'Retirement Process Description' ;
    rdfs:comment 'Description of the process and requirements for retiring carbon credits in this registry.' ;
    rdfs:domain ind:CarbonRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportedMethodologies rdf:type rdf:Property ;
    rdfs:label 'Supported Methodologies' ;
    rdfs:comment 'List of carbon accounting methodologies or protocols accepted by this registry (e.g., VCS VM0024, ACM0001, CDM methodologies).' ;
    rdfs:domain ind:CarbonRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportedProjectTypes rdf:type rdf:Property ;
    rdfs:label 'Supported Project Types' ;
    rdfs:comment 'Comma-separated list of carbon offset project types supported by this registry (e.g., renewable energy, forestry, LFG-to-RNG, methane capture, waste-to-energy).' ;
    rdfs:domain ind:CarbonRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transparencyLevel rdf:type rdf:Property ;
    rdfs:label 'Transparency Level' ;
    rdfs:comment 'Assessment of the registry\'s transparency in publicly disclosing project information, credit issuance, and retirement data.' ;
    rdfs:domain ind:CarbonRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vintageYearRangeEnd rdf:type rdf:Property ;
    rdfs:label 'Vintage Year Range End' ;
    rdfs:comment 'Latest vintage year of carbon credits available in this registry.' ;
    rdfs:domain ind:CarbonRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vintageYearRangeStart rdf:type rdf:Property ;
    rdfs:label 'Vintage Year Range Start' ;
    rdfs:comment 'Earliest vintage year of carbon credits available in this registry.' ;
    rdfs:domain ind:CarbonRegistry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operatingFacilityId rdf:type rdf:Property ;
    rdfs:label 'Operating Facility Id' ;
    rdfs:comment 'Reference to the primary Waste Management facility (MRF, composting facility, TSDF, or transfer station) that operates or coordinates this circular economy program.' ;
    rdfs:domain ind:CircularEconomyProgram ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:primaryCircularEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Circular Employee Id' ;
    rdfs:comment 'The system user identifier of the person who created this program record. Used for audit trail and accountability.' ;
    rdfs:domain ind:CircularEconomyProgram ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:annualDiversionTargetTons rdf:type rdf:Property ;
    rdfs:label 'Annual Diversion Target Tons' ;
    rdfs:comment 'The target volume of material to be diverted from landfill annually through this program, measured in tons. Key performance indicator for program success and GRI 306 reporting.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annualRevenueTargetUsd rdf:type rdf:Property ;
    rdfs:label 'Annual Revenue Target Usd' ;
    rdfs:comment 'The target annual revenue for the program in US dollars. Used for financial performance tracking and ROI analysis.' ;
    rdfs:domain ind:CircularEconomyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:circularEconomyPrincipleAlignment rdf:type rdf:Property ;
    rdfs:label 'Circular Economy Principle Alignment' ;
    rdfs:comment 'Comma-separated list of Ellen MacArthur Foundation circular economy principles that this program supports (e.g., \'design out waste and pollution\', \'keep products and materials in use\', \'regenerate natural systems\'). Used for ESG narrative reporting.' ;
    rdfs:domain ind:CircularEconomyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cumulativeDiversionActualTons rdf:type rdf:Property ;
    rdfs:label 'Cumulative Diversion Actual Tons' ;
    rdfs:comment 'The total volume of material actually diverted from landfill since program inception, measured in tons. Updated periodically based on operational data.' ;
    rdfs:domain ind:CircularEconomyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:esgReportingFrameworkAlignment rdf:type rdf:Property ;
    rdfs:label 'Esg Reporting Framework Alignment' ;
    rdfs:comment 'Comma-separated list of ESG reporting frameworks that this program supports (e.g., \'GRI 306\', \'TCFD\', \'CDP Climate\', \'SASB Waste Management Standard\'). Ensures data collection meets disclosure requirements.' ;
    rdfs:domain ind:CircularEconomyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ghgEmissionsAvoidedCo2eTonsAnnual rdf:type rdf:Property ;
    rdfs:label 'Ghg Emissions Avoided Co2e Tons Annual' ;
    rdfs:comment 'Estimated annual greenhouse gas emissions avoided through material diversion and circular economy activities, measured in metric tons of CO2 equivalent. Supports EPA GHG reporting and Clean Air Act compliance.' ;
    rdfs:domain ind:CircularEconomyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastPerformanceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Performance Review Date' ;
    rdfs:comment 'The date of the most recent formal performance review of the program against its targets and KPIs. Used for governance and continuous improvement tracking.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:marketingDescription rdf:type rdf:Property ;
    rdfs:label 'Marketing Description' ;
    rdfs:comment 'Customer-facing description of the program used in marketing materials, customer portals, and sustainability reports. Communicates program value proposition and participation instructions.' ;
    rdfs:domain ind:CircularEconomyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:participatingCustomerSegments rdf:type rdf:Property ;
    rdfs:label 'Participating Customer Segments' ;
    rdfs:comment 'Comma-separated list of customer segments eligible to participate in the program (e.g., \'residential\', \'commercial\', \'industrial\', \'municipal\', \'institutional\'). Defines program scope and market reach.' ;
    rdfs:domain ind:CircularEconomyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:participationEligibilityCriteria rdf:type rdf:Property ;
    rdfs:label 'Participation Eligibility Criteria' ;
    rdfs:comment 'Detailed description of the requirements for customers or partners to participate in the program (e.g., minimum volume commitments, material quality standards, geographic location, contract terms).' ;
    rdfs:domain ind:CircularEconomyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnershipModel rdf:type rdf:Property ;
    rdfs:label 'Partnership Model' ;
    rdfs:comment 'The business and operational structure of the program indicating ownership and partnership arrangements. Critical for financial and legal reporting.' ;
    rdfs:domain ind:CircularEconomyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programEndDate rdf:type rdf:Property ;
    rdfs:label 'Program End Date' ;
    rdfs:comment 'The planned or actual date when the program concluded or is scheduled to conclude. Null for ongoing programs.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:programStartDate rdf:type rdf:Property ;
    rdfs:label 'Program Start Date' ;
    rdfs:comment 'The date when the circular economy program officially commenced operations. Used for program maturity analysis and performance trending.' ;
    rdfs:domain ind:CircularEconomyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:programWebsiteUrl rdf:type rdf:Property ;
    rdfs:label 'Program Website Url' ;
    rdfs:comment 'The public-facing website URL for the program where customers and stakeholders can learn more and access participation information.' ;
    rdfs:domain ind:CircularEconomyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryComplianceRequirements rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Requirements' ;
    rdfs:comment 'Comma-separated list of regulatory requirements that the program must comply with (e.g., \'RCRA Subtitle D\', \'State EPR Law\', \'Local Organics Diversion Mandate\'). Ensures program design meets legal obligations.' ;
    rdfs:domain ind:CircularEconomyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueModel rdf:type rdf:Property ;
    rdfs:label 'Revenue Model' ;
    rdfs:comment 'The primary revenue generation mechanism for the program. Used for financial planning and program sustainability assessment.' ;
    rdfs:domain ind:CircularEconomyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetMaterialStreams rdf:type rdf:Property ;
    rdfs:label 'Target Material Streams' ;
    rdfs:comment 'Comma-separated list of material types targeted by this program (e.g., \'electronics, batteries, appliances\' or \'food waste, yard waste, biosolids\' or \'concrete, asphalt, wood, metal\'). Supports GRI 306 waste disclosure requirements.' ;
    rdfs:domain ind:CircularEconomyProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerContractId rdf:type rdf:Property ;
    rdfs:label 'Customer Contract Id' ;
    rdfs:comment 'Identifier of the customer contract or municipal agreement under which diversion performance is tracked and reported. Links to contractual SLA commitments.' ;
    rdfs:domain ind:DiversionRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contract .

ind:primaryDiversionEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Diversion Employee Id' ;
    rdfs:comment 'Identifier of the user or system account that submitted the diversion record for approval.' ;
    rdfs:domain ind:DiversionRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:auditVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Audit Verification Date' ;
    rdfs:comment 'Date when the diversion record was verified by third-party auditor or internal compliance team for accuracy and regulatory compliance.' ;
    rdfs:domain ind:DiversionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contaminationRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Contamination Rate Percentage' ;
    rdfs:comment 'Percentage of received recyclable material that was contaminated and could not be processed for diversion. Indicates quality of incoming waste stream.' ;
    rdfs:domain ind:DiversionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:diversionPathway rdf:type rdf:Property ;
    rdfs:label 'Diversion Pathway' ;
    rdfs:comment 'Primary pathway through which waste was diverted from landfill: recycling, composting, RNG (Renewable Natural Gas) conversion, SRF (Solid Recovered Fuel) production, WTE (Waste-to-Energy), or beneficial reuse.' ;
    rdfs:domain ind:DiversionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esgReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Esg Reporting Flag' ;
    rdfs:comment 'Indicates whether this diversion record is included in corporate ESG reporting and sustainability disclosures (GRI, TCFD, CDP). True if included, False otherwise.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:processingCostUsd rdf:type rdf:Property ;
    rdfs:label 'Processing Cost Usd' ;
    rdfs:comment 'Total cost incurred to process and divert waste during the reporting period, including labor, equipment, and facility operating costs, in US dollars.' ;
    rdfs:domain ind:DiversionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueGeneratedUsd rdf:type rdf:Property ;
    rdfs:label 'Revenue Generated Usd' ;
    rdfs:comment 'Revenue generated from the sale of diverted materials (recyclables, compost, RNG, SRF) during the reporting period, in US dollars.' ;
    rdfs:domain ind:DiversionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalWasteReceivedTons rdf:type rdf:Property ;
    rdfs:label 'Total Waste Received Tons' ;
    rdfs:comment 'Total tonnage of waste received at the facility during the reporting period, measured in tons.' ;
    rdfs:domain ind:DiversionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wasteDivertedTons rdf:type rdf:Property ;
    rdfs:label 'Waste Diverted Tons' ;
    rdfs:comment 'Tonnage of waste diverted from landfill disposal through recycling, composting, energy recovery, or other beneficial use pathways, measured in tons.' ;
    rdfs:domain ind:DiversionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wasteToLandfillTons rdf:type rdf:Property ;
    rdfs:label 'Waste To Landfill Tons' ;
    rdfs:comment 'Tonnage of waste sent to landfill disposal during the reporting period, measured in tons.' ;
    rdfs:domain ind:DiversionRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supersededByFactorEmissionFactorId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Factor Emission Factor Id' ;
    rdfs:comment 'Reference to the emission_factor_id that replaces this factor when status is superseded. Null if not superseded. Maintains version lineage for audit and compliance.' ;
    rdfs:domain ind:EmissionFactor ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EmissionFactor .

ind:emissionFactorStatus rdf:type rdf:Property ;
    rdfs:label 'Emission Factor Status' ;
    rdfs:comment 'Current lifecycle status of the emission factor: active (currently in use), superseded (replaced by newer version), deprecated (no longer recommended), draft (pending approval), or under_review (being validated).' ;
    rdfs:domain ind:EmissionFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emissionScope rdf:type rdf:Property ;
    rdfs:label 'Emission Scope' ;
    rdfs:comment 'GHG Protocol emission scope classification: Scope 1 (direct emissions from owned/controlled sources), Scope 2 (indirect emissions from purchased energy), or Scope 3 (other indirect emissions in value chain).' ;
    rdfs:domain ind:EmissionFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:factorSource rdf:type rdf:Property ;
    rdfs:label 'Factor Source' ;
    rdfs:comment 'Authoritative source or organization that published the emission factor (e.g., EPA, IPCC, CARB, EIA, DEFRA, GHG Protocol). Ensures traceability and regulatory compliance.' ;
    rdfs:domain ind:EmissionFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:factorSourceDocument rdf:type rdf:Property ;
    rdfs:label 'Factor Source Document' ;
    rdfs:comment 'Specific document, publication, or database from which the emission factor was obtained (e.g., EPA Emission Factors for Greenhouse Gas Inventories 2023, IPCC 2006 Guidelines Volume 2 Chapter 3). Supports audit trail and version control.' ;
    rdfs:domain ind:EmissionFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:factorSourceUrl rdf:type rdf:Property ;
    rdfs:label 'Factor Source Url' ;
    rdfs:comment 'Web URL or digital reference to the source document for verification and audit purposes. Null if no digital reference is available.' ;
    rdfs:domain ind:EmissionFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:factorUnit rdf:type rdf:Property ;
    rdfs:label 'Factor Unit' ;
    rdfs:comment 'Unit of measure for the emission factor (e.g., kg CO2e per gallon, kg CO2e per kWh, kg CO2e per ton, kg CO2e per mile, kg CO2e per MMBtu). Defines the denominator for emission calculations.' ;
    rdfs:domain ind:EmissionFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:factorValue rdf:type rdf:Property ;
    rdfs:label 'Factor Value' ;
    rdfs:comment 'Numeric value of the emission factor used in CO2e calculations. Precision to six decimal places to support accurate scientific calculations.' ;
    rdfs:domain ind:EmissionFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gwpBasis rdf:type rdf:Property ;
    rdfs:label 'Gwp Basis' ;
    rdfs:comment 'IPCC Assessment Report used for Global Warming Potential values: Second Assessment Report (SAR), Fourth Assessment Report (AR4), Fifth Assessment Report (AR5), or Sixth Assessment Report (AR6). Determines the conversion factors for non-CO2 gases to CO2 equivalents.' ;
    rdfs:domain ind:EmissionFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gwpTimeframeYears rdf:type rdf:Property ;
    rdfs:label 'Gwp Timeframe Years' ;
    rdfs:comment 'Time horizon in years over which the Global Warming Potential is calculated (typically 20, 100, or 500 years). Most regulatory frameworks use 100-year GWP.' ;
    rdfs:domain ind:EmissionFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceCategory rdf:type rdf:Property ;
    rdfs:label 'Source Category' ;
    rdfs:comment 'Category of emission source: mobile combustion (fleet vehicles), stationary combustion (boilers, generators), fugitive emissions (leaks, venting), process emissions (chemical reactions), waste disposal (landfill decomposition), or purchased electricity (grid consumption).' ;
    rdfs:domain ind:EmissionFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uncertaintyPercentage rdf:type rdf:Property ;
    rdfs:label 'Uncertainty Percentage' ;
    rdfs:comment 'Estimated uncertainty or margin of error associated with the emission factor, expressed as a percentage. Used for sensitivity analysis and data quality assessment in GHG inventories.' ;
    rdfs:domain ind:EmissionFactor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:controlDeviceType rdf:type rdf:Property ;
    rdfs:label 'Control Device Type' ;
    rdfs:comment 'Type of emission control technology installed on this source (e.g., \'enclosed_flare\', \'catalytic_converter\', \'scrubber\', \'none\'). Impacts emission factor adjustments and compliance.' ;
    rdfs:domain ind:EmissionSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlEfficiencyPercent rdf:type rdf:Property ;
    rdfs:label 'Control Efficiency Percent' ;
    rdfs:comment 'Percentage reduction in emissions achieved by the control device. Used to adjust gross emissions to net emissions for regulatory reporting.' ;
    rdfs:domain ind:EmissionSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emissionFactorMethodology rdf:type rdf:Property ;
    rdfs:label 'Emission Factor Methodology' ;
    rdfs:comment 'The calculation methodology and tier used to quantify emissions from this source. Higher tiers indicate greater measurement precision and site-specific data. [ENUM-REF-CANDIDATE: epa_tier_1|epa_tier_2|epa_tier_3|epa_tier_4|ipcc_default|custom_site_specific|cems — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:EmissionSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epaSourceCode rdf:type rdf:Property ;
    rdfs:label 'Epa Source Code' ;
    rdfs:comment 'Official EPA-assigned identifier for the emission source used in regulatory reporting and compliance tracking.' ;
    rdfs:domain ind:EmissionSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicLatitude rdf:type rdf:Property ;
    rdfs:label 'Geographic Latitude' ;
    rdfs:comment 'Latitude coordinate of the emission source location in decimal degrees. Used for spatial analysis, proximity reporting, and environmental justice assessments.' ;
    rdfs:domain ind:EmissionSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:geographicLongitude rdf:type rdf:Property ;
    rdfs:label 'Geographic Longitude' ;
    rdfs:comment 'Longitude coordinate of the emission source location in decimal degrees. Used for spatial analysis, proximity reporting, and environmental justice assessments.' ;
    rdfs:domain ind:EmissionSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ghgProtocolCategory rdf:type rdf:Property ;
    rdfs:label 'Ghg Protocol Category' ;
    rdfs:comment 'Detailed GHG Protocol emission category within the assigned scope. Used for inventory segmentation and reporting granularity. [ENUM-REF-CANDIDATE: stationary_combustion|mobile_combustion|fugitive_emissions|process_emissions|purchased_electricity|purchased_heat_steam|upstream_transportation|waste_disposal|business_travel — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:EmissionSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ghgProtocolScope rdf:type rdf:Property ;
    rdfs:label 'Ghg Protocol Scope' ;
    rdfs:comment 'GHG Protocol categorization: Scope 1 (direct emissions from owned/controlled sources), Scope 2 (indirect emissions from purchased energy), Scope 3 (other indirect emissions in value chain).' ;
    rdfs:domain ind:EmissionSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isSubjectToCaa rdf:type rdf:Property ;
    rdfs:label 'Is Subject To Caa' ;
    rdfs:comment 'Indicates whether this emission source is regulated under Clean Air Act provisions including Title V operating permits, NSPS, or NESHAP standards.' ;
    rdfs:domain ind:EmissionSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSubjectToGhgrp rdf:type rdf:Property ;
    rdfs:label 'Is Subject To Ghgrp' ;
    rdfs:comment 'Indicates whether this emission source is subject to mandatory EPA Greenhouse Gas Reporting Program requirements. True if emissions exceed regulatory thresholds.' ;
    rdfs:domain ind:EmissionSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lfgToRngConversion rdf:type rdf:Property ;
    rdfs:label 'Lfg To Rng Conversion' ;
    rdfs:comment 'Indicates whether this source is part of a landfill gas to renewable natural gas conversion project. Supports circular economy and sustainability reporting.' ;
    rdfs:domain ind:EmissionSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ratedCapacity rdf:type rdf:Property ;
    rdfs:label 'Rated Capacity' ;
    rdfs:comment 'Maximum design capacity of the emission source (e.g., engine horsepower, boiler MMBtu/hr, compactor tons per hour). Used for capacity-based emission estimates.' ;
    rdfs:domain ind:EmissionSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewableEnergyFlag rdf:type rdf:Property ;
    rdfs:label 'Renewable Energy Flag' ;
    rdfs:comment 'Indicates whether this source uses renewable energy (e.g., RNG, biogas, solar, wind). True for sources contributing to renewable energy adoption KPIs.' ;
    rdfs:domain ind:EmissionSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportingThresholdTpy rdf:type rdf:Property ;
    rdfs:label 'Reporting Threshold Tpy' ;
    rdfs:comment 'Annual emission threshold in metric tons CO2e that triggers mandatory EPA GHGRP reporting for this source. Typically 25,000 TPY for facilities.' ;
    rdfs:domain ind:EmissionSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceName rdf:type rdf:Property ;
    rdfs:label 'Source Name' ;
    rdfs:comment 'Human-readable name or designation of the emission source (e.g., \'Fleet Truck 1234\', \'Landfill Flare Station A\', \'WTE Boiler Unit 2\').' ;
    rdfs:domain ind:EmissionSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceType rdf:type rdf:Property ;
    rdfs:label 'Source Type' ;
    rdfs:comment 'Classification of the emission source by operational category. Determines applicable emission factor methodology and reporting requirements. [ENUM-REF-CANDIDATE: fleet_vehicle|landfill_gas_vent|landfill_gas_flare|wte_combustion_unit|mrf_equipment|transfer_station_compactor|stationary_combustion|mobile_combustion|fugitive_emission|process_emission — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:EmissionSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateProvinceCode rdf:type rdf:Property ;
    rdfs:label 'State Province Code' ;
    rdfs:comment 'Two-letter state or province code where the emission source is located. Used for state-level emission inventory rollups and compliance with state regulations.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteToEnergyFlag rdf:type rdf:Property ;
    rdfs:label 'Waste To Energy Flag' ;
    rdfs:comment 'Indicates whether this source is a waste-to-energy combustion unit generating electricity or heat from waste. Supports WTE program tracking and energy recovery metrics.' ;
    rdfs:domain ind:EmissionSource ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preparerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Preparer Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: ESG disclosure preparation for CDP, GRI, TCFD requires designated staff for data compilation, assurance coordination, and submission. Replaces denormalized disclosure_preparer_name with proper FK.' ;
    rdfs:domain ind:EsgDisclosure ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assuranceCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Assurance Completion Date' ;
    rdfs:comment 'The date on which the external assurance engagement was completed and the assurance opinion was issued.' ;
    rdfs:domain ind:EsgDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assuranceLevel rdf:type rdf:Property ;
    rdfs:label 'Assurance Level' ;
    rdfs:comment 'The level of external assurance obtained for this ESG disclosure. None = no third-party assurance, Limited = limited assurance engagement, Reasonable = reasonable assurance engagement (highest level).' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assuranceProvider rdf:type rdf:Property ;
    rdfs:label 'Assurance Provider' ;
    rdfs:comment 'The name of the third-party assurance provider or auditor who verified the ESG disclosure data and statements.' ;
    rdfs:domain ind:EsgDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boardDiversityPercentage rdf:type rdf:Property ;
    rdfs:label 'Board Diversity Percentage' ;
    rdfs:comment 'Percentage of board members representing diverse backgrounds (gender, ethnicity, age, experience). Key governance metric for ESG disclosure.' ;
    rdfs:domain ind:EsgDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carbonOffsetCreditsPurchasedMetricTons rdf:type rdf:Property ;
    rdfs:label 'Carbon Offset Credits Purchased Metric Tons' ;
    rdfs:comment 'Total volume of carbon offset credits purchased during the reporting period to compensate for residual GHG emissions, measured in metric tons of CO2 equivalent.' ;
    rdfs:domain ind:EsgDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:communityInvestmentAmountUsd rdf:type rdf:Property ;
    rdfs:label 'Community Investment Amount Usd' ;
    rdfs:comment 'Total monetary value of community investments, charitable contributions, and social programs funded during the reporting period, measured in US dollars. Key social performance metric.' ;
    rdfs:domain ind:EsgDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disclosureApproverName rdf:type rdf:Property ;
    rdfs:label 'Disclosure Approver Name' ;
    rdfs:comment 'Full name of the executive or officer who formally approved this ESG disclosure for submission.' ;
    rdfs:domain ind:EsgDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disclosureDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Disclosure Document Reference' ;
    rdfs:comment 'Reference identifier or URI to the formal ESG disclosure document, report, or filing submitted to the external framework body.' ;
    rdfs:domain ind:EsgDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disclosureNumber rdf:type rdf:Property ;
    rdfs:label 'Disclosure Number' ;
    rdfs:comment 'Externally-known unique reference number assigned to this ESG disclosure submission for tracking and audit purposes.' ;
    rdfs:domain ind:EsgDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeSafetyIncidentRate rdf:type rdf:Property ;
    rdfs:label 'Employee Safety Incident Rate' ;
    rdfs:comment 'Total Recordable Incident Rate (TRIR) for employee safety during the reporting period, calculated per OSHA standards as incidents per 100 full-time employees. Key social performance metric.' ;
    rdfs:domain ind:EsgDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:esgScore rdf:type rdf:Property ;
    rdfs:label 'Esg Score' ;
    rdfs:comment 'Composite ESG performance score assigned by external rating agencies or internal assessment frameworks. Typically scaled 0-100, with higher scores indicating stronger ESG performance.' ;
    rdfs:domain ind:EsgDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:frameworkType rdf:type rdf:Property ;
    rdfs:label 'Framework Type' ;
    rdfs:comment 'The ESG disclosure framework or standard to which this submission conforms. GRI = Global Reporting Initiative, TCFD = Task Force on Climate-related Financial Disclosures, CDP = Carbon Disclosure Project, SASB = Sustainability Accounting Standards Board, SEC_CLIMATE = SEC Climate Rule, ISSB = International Sustainability Standards Board.' ;
    rdfs:domain ind:EsgDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardousWasteManagedMetricTons rdf:type rdf:Property ;
    rdfs:label 'Hazardous Waste Managed Metric Tons' ;
    rdfs:comment 'Total volume of hazardous waste managed during the reporting period, measured in metric tons. Includes RCRA-regulated hazardous waste handled, treated, stored, and disposed.' ;
    rdfs:domain ind:EsgDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lfgToRngConversionVolumeMmbtu rdf:type rdf:Property ;
    rdfs:label 'Lfg To Rng Conversion Volume Mmbtu' ;
    rdfs:comment 'Total volume of landfill gas converted to renewable natural gas during the reporting period, measured in million British thermal units. Represents circular economy and waste-to-energy performance.' ;
    rdfs:domain ind:EsgDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:materialTopicsCovered rdf:type rdf:Property ;
    rdfs:label 'Material Topics Covered' ;
    rdfs:comment 'Comma-separated list or summary of the material ESG topics addressed in this disclosure (e.g., GHG emissions, waste diversion, water usage, employee safety, community engagement).' ;
    rdfs:domain ind:EsgDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicationUrl rdf:type rdf:Property ;
    rdfs:label 'Publication Url' ;
    rdfs:comment 'The public URL where this ESG disclosure report or filing is published and accessible to stakeholders.' ;
    rdfs:domain ind:EsgDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewableEnergyConsumptionMwh rdf:type rdf:Property ;
    rdfs:label 'Renewable Energy Consumption Mwh' ;
    rdfs:comment 'Total renewable energy consumed during the reporting period, measured in megawatt hours. Includes energy from CNG, RNG, solar, wind, and other renewable sources.' ;
    rdfs:domain ind:EsgDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewableEnergyPercentage rdf:type rdf:Property ;
    rdfs:label 'Renewable Energy Percentage' ;
    rdfs:comment 'Percentage of total energy consumption derived from renewable sources. Key sustainability KPI for tracking progress toward renewable energy adoption goals.' ;
    rdfs:domain ind:EsgDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:restatementFlag rdf:type rdf:Property ;
    rdfs:label 'Restatement Flag' ;
    rdfs:comment 'Boolean flag indicating whether this disclosure includes restated data from prior reporting periods due to corrections, methodology changes, or improved data quality.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:restatementReason rdf:type rdf:Property ;
    rdfs:label 'Restatement Reason' ;
    rdfs:comment 'Detailed explanation of the reason for any data restatements included in this disclosure, including methodology changes, data corrections, or scope adjustments.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scope1EmissionsCo2eMetricTons rdf:type rdf:Property ;
    rdfs:label 'Scope 1 Emissions Co2e Metric Tons' ;
    rdfs:comment 'Total Scope 1 direct GHG emissions reported in this disclosure, measured in metric tons of CO2 equivalent. Includes emissions from owned or controlled sources such as fleet vehicles and landfill gas.' ;
    rdfs:domain ind:EsgDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scope2EmissionsCo2eMetricTons rdf:type rdf:Property ;
    rdfs:label 'Scope 2 Emissions Co2e Metric Tons' ;
    rdfs:comment 'Total Scope 2 indirect GHG emissions from purchased electricity, steam, heating, and cooling reported in this disclosure, measured in metric tons of CO2 equivalent.' ;
    rdfs:domain ind:EsgDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scope3EmissionsCo2eMetricTons rdf:type rdf:Property ;
    rdfs:label 'Scope 3 Emissions Co2e Metric Tons' ;
    rdfs:comment 'Total Scope 3 indirect GHG emissions from value chain activities reported in this disclosure, measured in metric tons of CO2 equivalent. Includes upstream and downstream emissions outside direct control.' ;
    rdfs:domain ind:EsgDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalWasteDivertedMetricTons rdf:type rdf:Property ;
    rdfs:label 'Total Waste Diverted Metric Tons' ;
    rdfs:comment 'Total volume of waste diverted from landfill disposal through recycling, composting, waste-to-energy, and other recovery methods during the reporting period, measured in metric tons.' ;
    rdfs:domain ind:EsgDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wasteDiversionRatePercent rdf:type rdf:Property ;
    rdfs:label 'Waste Diversion Rate Percent' ;
    rdfs:comment 'Percentage of total waste diverted from landfill disposal, calculated as diverted waste divided by total waste managed. Key sustainability KPI.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waterConsumptionCubicMeters rdf:type rdf:Property ;
    rdfs:label 'Water Consumption Cubic Meters' ;
    rdfs:comment 'Total volume of water consumed by operations during the reporting period, measured in cubic meters. Includes water used in facilities, fleet maintenance, and operational processes.' ;
    rdfs:domain ind:EsgDisclosure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelCardHolderEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Fuel Card Holder Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Fleet fuel transactions require linking to fuel card holders for cost allocation, carbon accounting, and fraud prevention. Distinct from driver_id which tracks route assignment.' ;
    rdfs:domain ind:FleetFuelConsumption ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:co2eEmissionsMetricTons rdf:type rdf:Property ;
    rdfs:label 'Co2e Emissions Metric Tons' ;
    rdfs:comment 'Total greenhouse gas emissions in metric tons of CO2 equivalent calculated from fuel consumption using EPA emission factors. Primary metric for Scope 1 mobile combustion emissions inventory.' ;
    rdfs:domain ind:FleetFuelConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consumptionRecordNumber rdf:type rdf:Property ;
    rdfs:label 'Consumption Record Number' ;
    rdfs:comment 'Business identifier for the fuel consumption transaction, typically generated by the telematics system or fuel management system.' ;
    rdfs:domain ind:FleetFuelConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emissionFactorKgCo2ePerUnit rdf:type rdf:Property ;
    rdfs:label 'Emission Factor Kg Co2e Per Unit' ;
    rdfs:comment 'Emission factor applied to calculate CO2e emissions, expressed in kilograms of CO2 equivalent per fuel unit (gallon, GGE, kWh, or MMBtu). Source-specific factor based on fuel type.' ;
    rdfs:domain ind:FleetFuelConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:energyQuantityKwh rdf:type rdf:Property ;
    rdfs:label 'Energy Quantity Kwh' ;
    rdfs:comment 'Electrical energy consumed in kilowatt-hours. Applicable to electric and hybrid electric vehicles.' ;
    rdfs:domain ind:FleetFuelConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:energyQuantityMmbtu rdf:type rdf:Property ;
    rdfs:label 'Energy Quantity Mmbtu' ;
    rdfs:comment 'Total energy content consumed in Million British Thermal Units. Normalized energy measure across all fuel types for consistent emissions calculations.' ;
    rdfs:domain ind:FleetFuelConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelCostUsd rdf:type rdf:Property ;
    rdfs:label 'Fuel Cost Usd' ;
    rdfs:comment 'Total cost of fuel consumed in US dollars. Used for fleet operating cost analysis and sustainability ROI calculations.' ;
    rdfs:domain ind:FleetFuelConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelEfficiencyMpge rdf:type rdf:Property ;
    rdfs:label 'Fuel Efficiency Mpge' ;
    rdfs:comment 'Fuel efficiency in miles per gallon equivalent for gaseous and electric fuels. Enables efficiency comparison across fuel types.' ;
    rdfs:domain ind:FleetFuelConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelQuantityGallons rdf:type rdf:Property ;
    rdfs:label 'Fuel Quantity Gallons' ;
    rdfs:comment 'Volume of liquid fuel consumed in gallons. Applicable to diesel, gasoline, and biodiesel. Null for gaseous and electric fuels.' ;
    rdfs:domain ind:FleetFuelConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelQuantityGge rdf:type rdf:Property ;
    rdfs:label 'Fuel Quantity Gge' ;
    rdfs:comment 'Volume of gaseous fuel consumed in Gasoline Gallon Equivalent units. Used for CNG and RNG to normalize energy content comparisons.' ;
    rdfs:domain ind:FleetFuelConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelingLocationCity rdf:type rdf:Property ;
    rdfs:label 'Fueling Location City' ;
    rdfs:comment 'City where the fueling event occurred. Used for geographic emissions reporting and regional sustainability analysis.' ;
    rdfs:domain ind:FleetFuelConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelingLocationCountry rdf:type rdf:Property ;
    rdfs:label 'Fueling Location Country' ;
    rdfs:comment 'Country where the fueling event occurred, using ISO 3166-1 alpha-3 country codes. Supports multinational fleet emissions reporting.' ;
    rdfs:domain ind:FleetFuelConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelingLocationState rdf:type rdf:Property ;
    rdfs:label 'Fueling Location State' ;
    rdfs:comment 'State or province where the fueling event occurred. Required for state-level GHG reporting and Clean Air Act compliance.' ;
    rdfs:domain ind:FleetFuelConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ghgInventoryCategory rdf:type rdf:Property ;
    rdfs:label 'Ghg Inventory Category' ;
    rdfs:comment 'GHG Protocol inventory category to which this consumption record is allocated. Primarily Scope 1 mobile combustion for direct vehicle fuel use.' ;
    rdfs:domain ind:FleetFuelConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:idleTimeHours rdf:type rdf:Property ;
    rdfs:label 'Idle Time Hours' ;
    rdfs:comment 'Total hours the vehicle engine was idling during the consumption period. Key metric for fuel waste reduction and emissions optimization.' ;
    rdfs:domain ind:FleetFuelConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lcfsCreditsGenerated rdf:type rdf:Property ;
    rdfs:label 'Lcfs Credits Generated' ;
    rdfs:comment 'Number of LCFS credits generated from low-carbon fuel consumption. Applicable in California and other jurisdictions with carbon credit programs.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rinCreditsGenerated rdf:type rdf:Property ;
    rdfs:label 'Rin Credits Generated' ;
    rdfs:comment 'Number of Renewable Identification Number credits generated from renewable fuel consumption. Applicable to RNG and biodiesel usage under EPA Renewable Fuel Standard.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryGhgFacilityId rdf:type rdf:Property ;
    rdfs:label 'Primary Ghg Facility Id' ;
    rdfs:comment 'Identifier of the facility where the emission occurred (landfill, MRF, transfer station, WTE plant, fleet depot).' ;
    rdfs:domain ind:GhgEmission ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:biogenicCo2Quantity rdf:type rdf:Property ;
    rdfs:label 'Biogenic Co2 Quantity' ;
    rdfs:comment 'Quantity of biogenic CO2 emissions (from biomass, biogas, RNG, biodiesel). Reported separately per GHG Protocol and EPA guidance; not included in Scope 1 totals.' ;
    rdfs:domain ind:GhgEmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carbonOffsetAppliedFlag rdf:type rdf:Property ;
    rdfs:label 'Carbon Offset Applied Flag' ;
    rdfs:comment 'Indicates whether carbon offsets or renewable energy certificates (RECs) have been applied to neutralize this emission for net carbon accounting. True if offset applied.' ;
    rdfs:domain ind:GhgEmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:carbonOffsetQuantity rdf:type rdf:Property ;
    rdfs:label 'Carbon Offset Quantity' ;
    rdfs:comment 'Quantity of carbon offsets or RECs applied to this emission record in metric tons CO2e. Used for net carbon footprint calculation.' ;
    rdfs:domain ind:GhgEmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:co2eQuantity rdf:type rdf:Property ;
    rdfs:label 'Co2e Quantity' ;
    rdfs:comment 'Total greenhouse gas emissions converted to carbon dioxide equivalent using global warming potential (GWP) factors. Primary metric for regulatory reporting and sustainability KPIs.' ;
    rdfs:domain ind:GhgEmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:co2eUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Co2e Unit Of Measure' ;
    rdfs:comment 'Unit of measure for CO2 equivalent emissions. Standardized to metric tons CO2e for EPA reporting and voluntary frameworks.' ;
    rdfs:domain ind:GhgEmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emissionEventTimestamp rdf:type rdf:Property ;
    rdfs:label 'Emission Event Timestamp' ;
    rdfs:comment 'Precise timestamp when the emission event occurred or was measured. Used for real-time monitoring and continuous emissions tracking.' ;
    rdfs:domain ind:GhgEmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:emissionQuantity rdf:type rdf:Property ;
    rdfs:label 'Emission Quantity' ;
    rdfs:comment 'Quantity of the specific greenhouse gas emitted in native units (metric tons of CO2, CH4, N2O, etc.) before conversion to CO2 equivalent.' ;
    rdfs:domain ind:GhgEmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emissionStatus rdf:type rdf:Property ;
    rdfs:label 'Emission Status' ;
    rdfs:comment 'Current lifecycle status of the emission record. Tracks workflow from data entry through regulatory submission and archival.' ;
    rdfs:domain ind:GhgEmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emissionUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Emission Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the emission quantity. Typically metric tons for regulatory reporting, but may vary by source and measurement method.' ;
    rdfs:domain ind:GhgEmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epaSubpartCode rdf:type rdf:Property ;
    rdfs:label 'Epa Subpart Code' ;
    rdfs:comment 'EPA GHG Reporting Rule subpart code applicable to this emission source (e.g., Subpart C for stationary combustion, Subpart HH for landfills, Subpart TT for waste-to-energy).' ;
    rdfs:domain ind:GhgEmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gwpFactor rdf:type rdf:Property ;
    rdfs:label 'Gwp Factor' ;
    rdfs:comment 'Global warming potential factor used to convert the specific GHG to CO2 equivalent. Based on IPCC assessment reports (AR4, AR5, or AR6) as specified by reporting framework.' ;
    rdfs:domain ind:GhgEmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gwpReferenceStandard rdf:type rdf:Property ;
    rdfs:label 'Gwp Reference Standard' ;
    rdfs:comment 'IPCC assessment report used for GWP factors. EPA requires AR4 for mandatory reporting; voluntary frameworks may use AR5 or AR6.' ;
    rdfs:domain ind:GhgEmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeCategory rdf:type rdf:Property ;
    rdfs:label 'Scope Category' ;
    rdfs:comment 'GHG Protocol scope classification: Scope 1 (direct emissions from owned/controlled sources), Scope 2 (indirect emissions from purchased electricity/steam/heating/cooling), Scope 3 (all other indirect emissions in value chain).' ;
    rdfs:domain ind:GhgEmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:voluntaryReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Voluntary Reporting Flag' ;
    rdfs:comment 'Indicates whether this emission record is included in voluntary sustainability reporting frameworks (CDP, GRI, TCFD, SASB). True if disclosed in ESG reports.' ;
    rdfs:domain ind:GhgEmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:baseYear rdf:type rdf:Property ;
    rdfs:label 'Base Year' ;
    rdfs:comment 'Historical year against which the organization\'s GHG emissions are tracked and reduction targets are measured (e.g., 2020).' ;
    rdfs:domain ind:GhgInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:baseYearCo2eMetricTons rdf:type rdf:Property ;
    rdfs:label 'Base Year Co2e Metric Tons' ;
    rdfs:comment 'Total GHG emissions in the base year, used as the reference point for tracking emissions reductions over time, expressed in metric tons of CO2 equivalent.' ;
    rdfs:domain ind:GhgInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:biogenicCo2MetricTons rdf:type rdf:Property ;
    rdfs:label 'Biogenic Co2 Metric Tons' ;
    rdfs:comment 'Total CO2 emissions from combustion or decomposition of biomass (e.g., landfill gas methane oxidation, biofuel combustion), reported separately from fossil-based emissions per GHG Protocol guidance, expressed in metric tons.' ;
    rdfs:domain ind:GhgInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataQualityAssessment rdf:type rdf:Property ;
    rdfs:label 'Data Quality Assessment' ;
    rdfs:comment 'Overall assessment of the quality, completeness, and reliability of the data used to compile this GHG inventory: high (primary data, direct measurement, high confidence), medium (mix of primary and secondary data, some estimation), low (significant use of estimates, proxies, or incomplete data).' ;
    rdfs:domain ind:GhgInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emissionsIntensityRatio rdf:type rdf:Property ;
    rdfs:label 'Emissions Intensity Ratio' ;
    rdfs:comment 'GHG emissions per unit of business activity (e.g., metric tons CO2e per ton of waste processed, per million USD revenue, per employee), used to normalize emissions for comparison across time periods or peer organizations.' ;
    rdfs:domain ind:GhgInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:epaSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Epa Submission Date' ;
    rdfs:comment 'Date on which this GHG inventory was submitted to the U.S. EPA under the GHG Reporting Rule (40 CFR Part 98), if applicable.' ;
    rdfs:domain ind:GhgInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:intensityMetric rdf:type rdf:Property ;
    rdfs:label 'Intensity Metric' ;
    rdfs:comment 'Unit of business activity used to calculate the emissions intensity ratio (e.g., tons_waste_processed, revenue_usd, employee_count, vehicle_miles_traveled).' ;
    rdfs:domain ind:GhgInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryNumber rdf:type rdf:Property ;
    rdfs:label 'Inventory Number' ;
    rdfs:comment 'Business-facing unique identifier or reference number for the GHG inventory compilation (e.g., INV-2023-001).' ;
    rdfs:domain ind:GhgInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organizationalBoundaryApproach rdf:type rdf:Property ;
    rdfs:label 'Organizational Boundary Approach' ;
    rdfs:comment 'Method used to define organizational boundaries for GHG accounting: operational control (company has full authority over operations), financial control (company directs financial and operating policies), or equity share (proportional to ownership percentage).' ;
    rdfs:domain ind:GhgInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preparerName rdf:type rdf:Property ;
    rdfs:label 'Preparer Name' ;
    rdfs:comment 'Name of the individual or team responsible for compiling and preparing this GHG inventory.' ;
    rdfs:domain ind:GhgInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scope1Co2eMetricTons rdf:type rdf:Property ;
    rdfs:label 'Scope 1 Co2e Metric Tons' ;
    rdfs:comment 'Total direct GHG emissions from sources owned or controlled by the organization (e.g., fleet fuel combustion, landfill gas emissions, stationary combustion), expressed in metric tons of CO2 equivalent.' ;
    rdfs:domain ind:GhgInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scope2LocationBasedCo2eMetricTons rdf:type rdf:Property ;
    rdfs:label 'Scope 2 Location Based Co2e Metric Tons' ;
    rdfs:comment 'Total indirect GHG emissions from purchased electricity, steam, heating, and cooling, calculated using average emission factors for the regional grid, expressed in metric tons of CO2 equivalent.' ;
    rdfs:domain ind:GhgInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scope2MarketBasedCo2eMetricTons rdf:type rdf:Property ;
    rdfs:label 'Scope 2 Market Based Co2e Metric Tons' ;
    rdfs:comment 'Total indirect GHG emissions from purchased electricity, steam, heating, and cooling, calculated using emission factors from contractual instruments (e.g., renewable energy certificates, power purchase agreements), expressed in metric tons of CO2 equivalent.' ;
    rdfs:domain ind:GhgInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scope3Category12Co2eMetricTons rdf:type rdf:Property ;
    rdfs:label 'Scope 3 Category 12 Co2e Metric Tons' ;
    rdfs:comment 'Scope 3 emissions from waste disposal and treatment of products sold by the organization at the end of their life, expressed in metric tons of CO2 equivalent.' ;
    rdfs:domain ind:GhgInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scope3Category1Co2eMetricTons rdf:type rdf:Property ;
    rdfs:label 'Scope 3 Category 1 Co2e Metric Tons' ;
    rdfs:comment 'Scope 3 emissions from extraction, production, and transportation of goods and services purchased by the organization, expressed in metric tons of CO2 equivalent.' ;
    rdfs:domain ind:GhgInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scope3Category2Co2eMetricTons rdf:type rdf:Property ;
    rdfs:label 'Scope 3 Category 2 Co2e Metric Tons' ;
    rdfs:comment 'Scope 3 emissions from extraction, production, and transportation of capital goods purchased by the organization (e.g., equipment, vehicles, buildings), expressed in metric tons of CO2 equivalent.' ;
    rdfs:domain ind:GhgInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scope3Category3Co2eMetricTons rdf:type rdf:Property ;
    rdfs:label 'Scope 3 Category 3 Co2e Metric Tons' ;
    rdfs:comment 'Scope 3 emissions from extraction, production, and transportation of fuels and energy purchased by the organization, not included in Scope 1 or Scope 2 (e.g., upstream emissions of purchased fuels, transmission and distribution losses), expressed in metric tons of CO2 equivalent.' ;
    rdfs:domain ind:GhgInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scope3Category4Co2eMetricTons rdf:type rdf:Property ;
    rdfs:label 'Scope 3 Category 4 Co2e Metric Tons' ;
    rdfs:comment 'Scope 3 emissions from transportation and distribution of products purchased by the organization between tier 1 suppliers and the organization\'s facilities, expressed in metric tons of CO2 equivalent.' ;
    rdfs:domain ind:GhgInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scope3Category5Co2eMetricTons rdf:type rdf:Property ;
    rdfs:label 'Scope 3 Category 5 Co2e Metric Tons' ;
    rdfs:comment 'Scope 3 emissions from third-party disposal and treatment of waste generated in the organization\'s owned or controlled operations, expressed in metric tons of CO2 equivalent.' ;
    rdfs:domain ind:GhgInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scope3Category6Co2eMetricTons rdf:type rdf:Property ;
    rdfs:label 'Scope 3 Category 6 Co2e Metric Tons' ;
    rdfs:comment 'Scope 3 emissions from transportation of employees for business-related activities in vehicles not owned or operated by the organization, expressed in metric tons of CO2 equivalent.' ;
    rdfs:domain ind:GhgInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scope3Category7Co2eMetricTons rdf:type rdf:Property ;
    rdfs:label 'Scope 3 Category 7 Co2e Metric Tons' ;
    rdfs:comment 'Scope 3 emissions from transportation of employees between their homes and worksites, expressed in metric tons of CO2 equivalent.' ;
    rdfs:domain ind:GhgInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scope3Category9Co2eMetricTons rdf:type rdf:Property ;
    rdfs:label 'Scope 3 Category 9 Co2e Metric Tons' ;
    rdfs:comment 'Scope 3 emissions from transportation and distribution of products sold by the organization between the organization\'s operations and the end consumer, expressed in metric tons of CO2 equivalent.' ;
    rdfs:domain ind:GhgInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scope3Co2eMetricTons rdf:type rdf:Property ;
    rdfs:label 'Scope 3 Co2e Metric Tons' ;
    rdfs:comment 'Total indirect GHG emissions from value chain activities not owned or controlled by the organization (e.g., purchased goods and services, business travel, employee commuting, waste disposal, downstream transportation), expressed in metric tons of CO2 equivalent.' ;
    rdfs:domain ind:GhgInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCo2eMetricTons rdf:type rdf:Property ;
    rdfs:label 'Total Co2e Metric Tons' ;
    rdfs:comment 'Sum of Scope 1, Scope 2 (location-based or market-based as selected), and Scope 3 emissions, representing the organization\'s total GHG footprint for the reporting period, expressed in metric tons of CO2 equivalent.' ;
    rdfs:domain ind:GhgInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:verificationCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Verification Completion Date' ;
    rdfs:comment 'Date on which the third-party verification or assurance process was completed and the verification statement was issued.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verificationStatementReference rdf:type rdf:Property ;
    rdfs:label 'Verification Statement Reference' ;
    rdfs:comment 'Document reference, file path, or URL to the verification statement or assurance report issued by the third-party verifier.' ;
    rdfs:domain ind:GhgInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiativeMilestoneId rdf:type rdf:Property ;
    rdfs:label 'Initiative Milestone Id' ;
    rdfs:comment 'Unique identifier for the sustainability initiative milestone record. Primary key.' ;
    rdfs:domain ind:InitiativeMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryInitiativeResponsibleOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Initiative Responsible Owner Employee Id' ;
    rdfs:comment 'Employee identifier of the individual accountable for delivering this milestone. Links to workforce management system for accountability tracking.' ;
    rdfs:domain ind:InitiativeMilestone ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryInitiativeLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Initiative Last Modified By User Employee Id' ;
    rdfs:comment 'User identifier of the individual who last modified this milestone record. Used for audit trail and accountability.' ;
    rdfs:domain ind:InitiativeMilestone ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryInitiativeEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Initiative Employee Id' ;
    rdfs:comment 'User identifier of the individual who created this milestone record. Used for audit trail and accountability.' ;
    rdfs:domain ind:InitiativeMilestone ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:budgetAllocatedUsd rdf:type rdf:Property ;
    rdfs:label 'Budget Allocated Usd' ;
    rdfs:comment 'Total budget allocated to this milestone in US dollars. Used for financial tracking and return on investment (ROI) analysis of carbon reduction initiatives.' ;
    rdfs:domain ind:InitiativeMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:co2eReductionAchievedTons rdf:type rdf:Property ;
    rdfs:label 'Co2e Reduction Achieved Tons' ;
    rdfs:comment 'Cumulative greenhouse gas emissions reduction achieved by this milestone to date, measured in metric tons of CO2 equivalent. Supports EPA GHG reporting and voluntary disclosure frameworks (CDP, GRI, TCFD).' ;
    rdfs:domain ind:InitiativeMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:co2eReductionTargetTons rdf:type rdf:Property ;
    rdfs:label 'Co2e Reduction Target Tons' ;
    rdfs:comment 'Target greenhouse gas emissions reduction committed for this milestone, measured in metric tons of CO2 equivalent. Used to track progress against initiative commitments.' ;
    rdfs:domain ind:InitiativeMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dependencies rdf:type rdf:Property ;
    rdfs:label 'Dependencies' ;
    rdfs:comment 'Description of upstream dependencies or prerequisites required before this milestone can be completed (e.g., \'Requires completion of vendor selection milestone\', \'Dependent on EPA permit approval\', \'Awaiting budget approval\').' ;
    rdfs:domain ind:InitiativeMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneDescription rdf:type rdf:Property ;
    rdfs:label 'Milestone Description' ;
    rdfs:comment 'Detailed description of the milestone scope, deliverables, and success criteria. Provides context for program managers and ESG stakeholders.' ;
    rdfs:domain ind:InitiativeMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneName rdf:type rdf:Property ;
    rdfs:label 'Milestone Name' ;
    rdfs:comment 'Business name of the milestone or deliverable within the initiative (e.g., \'Fleet CNG Conversion Phase 1\', \'LFG Capture System Installation\', \'Renewable Natural Gas Procurement Agreement\').' ;
    rdfs:domain ind:InitiativeMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneStatus rdf:type rdf:Property ;
    rdfs:label 'Milestone Status' ;
    rdfs:comment 'Current lifecycle status of the milestone: not_started (planned but not yet begun), in_progress (active execution), on_hold (temporarily paused), completed (delivered and verified), cancelled (discontinued), delayed (behind schedule).' ;
    rdfs:domain ind:InitiativeMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milestoneType rdf:type rdf:Property ;
    rdfs:label 'Milestone Type' ;
    rdfs:comment 'Classification of the milestone by phase in the initiative lifecycle: planning (design and approval), procurement (vendor selection and contracting), implementation (execution and deployment), verification (measurement and validation), reporting (disclosure and communication), closure (final assessment and handover).' ;
    rdfs:domain ind:InitiativeMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:percentComplete rdf:type rdf:Property ;
    rdfs:label 'Percent Complete' ;
    rdfs:comment 'Estimated percentage of milestone work completed (0.00 to 100.00). Used for earned value management and progress reporting to ESG stakeholders.' ;
    rdfs:domain ind:InitiativeMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:riskDescription rdf:type rdf:Property ;
    rdfs:label 'Risk Description' ;
    rdfs:comment 'Description of identified risks, issues, or impediments affecting milestone delivery. Used for risk management and escalation to program governance.' ;
    rdfs:domain ind:InitiativeMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationEvidenceReference rdf:type rdf:Property ;
    rdfs:label 'Verification Evidence Reference' ;
    rdfs:comment 'Reference to supporting documentation or evidence that validates milestone completion and emissions reduction (e.g., audit report ID, EPA submission confirmation number, measurement report file path, third-party certificate number).' ;
    rdfs:domain ind:InitiativeMilestone ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:captureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Capture Timestamp' ;
    rdfs:comment 'Date and time when the LFG capture measurement was recorded.' ;
    rdfs:domain ind:LfgCapture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:carbonCreditsGenerated rdf:type rdf:Property ;
    rdfs:label 'Carbon Credits Generated' ;
    rdfs:comment 'Number of carbon credits or offsets generated from LFG capture and utilization activities during the reporting period.' ;
    rdfs:domain ind:LfgCapture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:co2eEmissionsAvoidedMetricTons rdf:type rdf:Property ;
    rdfs:label 'Co2e Emissions Avoided Metric Tons' ;
    rdfs:comment 'Total greenhouse gas emissions avoided through LFG capture and utilization, expressed in metric tons of carbon dioxide equivalent (CO2e). Calculated based on methane capture and conversion.' ;
    rdfs:domain ind:LfgCapture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:collectionSystemEfficiencyPercent rdf:type rdf:Property ;
    rdfs:label 'Collection System Efficiency Percent' ;
    rdfs:comment 'Efficiency of the landfill gas collection system, calculated as the percentage of generated LFG that is successfully captured. Typical values range from 75% to 95%.' ;
    rdfs:domain ind:LfgCapture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:collectionWellCount rdf:type rdf:Property ;
    rdfs:label 'Collection Well Count' ;
    rdfs:comment 'Number of active LFG collection wells at the facility during the reporting period.' ;
    rdfs:domain ind:LfgCapture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:electricityGeneratedMwh rdf:type rdf:Property ;
    rdfs:label 'Electricity Generated Mwh' ;
    rdfs:comment 'Total electricity generated from landfill gas during the reporting period, measured in megawatt-hours (MWh).' ;
    rdfs:domain ind:LfgCapture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:epaPermitNumber rdf:type rdf:Property ;
    rdfs:label 'Epa Permit Number' ;
    rdfs:comment 'EPA permit number authorizing LFG collection and utilization activities at the facility.' ;
    rdfs:domain ind:LfgCapture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lelMonitoringReadingPercent rdf:type rdf:Property ;
    rdfs:label 'Lel Monitoring Reading Percent' ;
    rdfs:comment 'Lower explosive limit monitoring reading as a percentage, used to ensure safe operation of LFG collection systems. Readings above 25% LEL trigger safety protocols.' ;
    rdfs:domain ind:LfgCapture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lfgFlaredVolumeMmbtu rdf:type rdf:Property ;
    rdfs:label 'Lfg Flared Volume Mmbtu' ;
    rdfs:comment 'Volume of landfill gas that was flared (combusted without energy recovery) during the reporting period, measured in MMBtu.' ;
    rdfs:domain ind:LfgCapture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lfgFlaredVolumeMmscf rdf:type rdf:Property ;
    rdfs:label 'Lfg Flared Volume Mmscf' ;
    rdfs:comment 'Volume of landfill gas that was flared (combusted without energy recovery) during the reporting period, measured in MMSCF.' ;
    rdfs:domain ind:LfgCapture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lfgUtilizedRngVolumeMmbtu rdf:type rdf:Property ;
    rdfs:label 'Lfg Utilized Rng Volume Mmbtu' ;
    rdfs:comment 'Volume of landfill gas utilized for renewable natural gas (RNG) production during the reporting period, measured in MMBtu.' ;
    rdfs:domain ind:LfgCapture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lfgUtilizedRngVolumeMmscf rdf:type rdf:Property ;
    rdfs:label 'Lfg Utilized Rng Volume Mmscf' ;
    rdfs:comment 'Volume of landfill gas utilized for renewable natural gas (RNG) production during the reporting period, measured in MMSCF.' ;
    rdfs:domain ind:LfgCapture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lfgUtilizedWteVolumeMmbtu rdf:type rdf:Property ;
    rdfs:label 'Lfg Utilized Wte Volume Mmbtu' ;
    rdfs:comment 'Volume of landfill gas utilized for waste-to-energy conversion (electricity or heat generation) during the reporting period, measured in MMBtu.' ;
    rdfs:domain ind:LfgCapture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lfgUtilizedWteVolumeMmscf rdf:type rdf:Property ;
    rdfs:label 'Lfg Utilized Wte Volume Mmscf' ;
    rdfs:comment 'Volume of landfill gas utilized for waste-to-energy conversion (electricity or heat generation) during the reporting period, measured in MMSCF.' ;
    rdfs:domain ind:LfgCapture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:methaneConcentrationPercent rdf:type rdf:Property ;
    rdfs:label 'Methane Concentration Percent' ;
    rdfs:comment 'Percentage of methane (CH4) in the collected landfill gas, typically ranging from 40% to 60%.' ;
    rdfs:domain ind:LfgCapture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nonComplianceReason rdf:type rdf:Property ;
    rdfs:label 'Non Compliance Reason' ;
    rdfs:comment 'Explanation of any non-compliance issues identified during the reporting period.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalLfgVolumeCollectedMmbtu rdf:type rdf:Property ;
    rdfs:label 'Total Lfg Volume Collected Mmbtu' ;
    rdfs:comment 'Total volume of landfill gas collected during the reporting period, measured in million British thermal units (MMBtu).' ;
    rdfs:domain ind:LfgCapture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalLfgVolumeCollectedMmscf rdf:type rdf:Property ;
    rdfs:label 'Total Lfg Volume Collected Mmscf' ;
    rdfs:comment 'Total volume of landfill gas collected during the reporting period, measured in million standard cubic feet (MMSCF).' ;
    rdfs:domain ind:LfgCapture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:offsetTransactionId rdf:type rdf:Property ;
    rdfs:label 'Offset Transaction Id' ;
    rdfs:comment 'Unique identifier for the carbon offset transaction record. Primary key for the offset transaction entity.' ;
    rdfs:domain ind:OffsetTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceProgram rdf:type rdf:Property ;
    rdfs:label 'Compliance Program' ;
    rdfs:comment 'Name of regulatory or voluntary compliance program for which these offsets are eligible (e.g., California Cap-and-Trade, RGGI, voluntary CDP commitment).' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registryConfirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Registry Confirmation Number' ;
    rdfs:comment 'Unique confirmation or serial number issued by the carbon offset registry to verify and track this transaction. Critical for third-party audit trails.' ;
    rdfs:domain ind:OffsetTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeAllocation rdf:type rdf:Property ;
    rdfs:label 'Scope Allocation' ;
    rdfs:comment 'GHG Protocol emissions scope that this offset transaction is intended to address (Scope 1 direct emissions, Scope 2 indirect energy, Scope 3 value chain, or voluntary beyond compliance).' ;
    rdfs:domain ind:OffsetTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionFee rdf:type rdf:Property ;
    rdfs:label 'Transaction Fee' ;
    rdfs:comment 'Registry or broker fees charged for processing the offset transaction.' ;
    rdfs:domain ind:OffsetTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sustainabilityProgramEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Sustainability Program Enrollment Id' ;
    rdfs:comment 'Unique identifier for the program enrollment record. Primary key for the program enrollment entity.' ;
    rdfs:domain ind:SustainabilityProgramEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primarySustainabilityEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Sustainability Employee Id' ;
    rdfs:comment 'Reference to the employee serving as the primary account manager or program coordinator for this enrollment. Responsible for customer relationship and program performance.' ;
    rdfs:domain ind:SustainabilityProgramEnrollment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:enrolledEntityType rdf:type rdf:Property ;
    rdfs:label 'Enrolled Entity Type' ;
    rdfs:comment 'Classification of the entity enrolled in the sustainability program. Distinguishes between customer types and facility types for program participation tracking.' ;
    rdfs:domain ind:SustainabilityProgramEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentChannel rdf:type rdf:Property ;
    rdfs:label 'Enrollment Channel' ;
    rdfs:comment 'Channel through which the entity enrolled in the sustainability program. Supports marketing effectiveness analysis and customer acquisition tracking.' ;
    rdfs:domain ind:SustainabilityProgramEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment Date' ;
    rdfs:comment 'Date when the entity was officially enrolled in the sustainability program. Represents the start of program participation for tracking and reporting purposes.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enrollmentSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Enrollment Source System' ;
    rdfs:comment 'Source system from which the enrollment record originated. Supports data lineage tracking and system integration management.' ;
    rdfs:domain ind:SustainabilityProgramEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedAnnualCo2eReductionTons rdf:type rdf:Property ;
    rdfs:label 'Estimated Annual Co2e Reduction Tons' ;
    rdfs:comment 'Projected annual reduction in Greenhouse Gas (GHG) emissions measured in Carbon Dioxide Equivalent (CO2e) metric tons resulting from this program enrollment. Supports Clean Air Act compliance and voluntary carbon reporting frameworks.' ;
    rdfs:domain ind:SustainabilityProgramEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedAnnualDiversionVolumeTons rdf:type rdf:Property ;
    rdfs:label 'Estimated Annual Diversion Volume Tons' ;
    rdfs:comment 'Projected annual volume of waste diverted from landfill through this program enrollment, measured in tons. Used for program planning and Environmental, Social, and Governance (ESG) impact forecasting.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exitReason rdf:type rdf:Property ;
    rdfs:label 'Exit Reason' ;
    rdfs:comment 'Reason for the entity exiting the sustainability program. Supports analysis of program retention and customer satisfaction.' ;
    rdfs:domain ind:SustainabilityProgramEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incentiveValueUsd rdf:type rdf:Property ;
    rdfs:label 'Incentive Value Usd' ;
    rdfs:comment 'Monetary value of the incentive provided to the enrolled entity, expressed in United States Dollars (USD). Used for program cost tracking and Return on Investment (ROI) analysis.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:materialStreamsIncluded rdf:type rdf:Property ;
    rdfs:label 'Material Streams Included' ;
    rdfs:comment 'Comma-separated list of waste material streams included in the program enrollment. Examples include paper, cardboard, plastics, metals, glass, organics, Municipal Solid Waste (MSW), Construction and Demolition (C&D) waste, and hazardous materials.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:participationTier rdf:type rdf:Property ;
    rdfs:label 'Participation Tier' ;
    rdfs:comment 'Tiered classification of program participation level based on volume, performance, or commitment. Supports differentiated service levels and recognition programs.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programExitDate rdf:type rdf:Property ;
    rdfs:label 'Program Exit Date' ;
    rdfs:comment 'Actual date when the entity exited or withdrew from the sustainability program. Populated when enrollment status transitions to completed or cancelled.' ;
    rdfs:domain ind:SustainabilityProgramEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:executiveSponsorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Executive Sponsor Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Corporate GHG reduction targets require C-suite sponsorship for board approval, SBTi validation, public disclosure commitments, and investor relations communications.' ;
    rdfs:domain ind:ReductionTarget ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:achievementDate rdf:type rdf:Property ;
    rdfs:label 'Achievement Date' ;
    rdfs:comment 'Date when the target was officially achieved and verified. Null if not yet achieved.' ;
    rdfs:domain ind:ReductionTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:boardApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Board Approval Date' ;
    rdfs:comment 'Date when the target was formally approved by the Board of Directors or equivalent governance body. Critical for demonstrating executive commitment.' ;
    rdfs:domain ind:ReductionTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:businessUnitScope rdf:type rdf:Property ;
    rdfs:label 'Business Unit Scope' ;
    rdfs:comment 'Identifies which business units or divisions this target applies to (e.g., \'Fleet Operations\', \'Landfill Operations\', \'Corporate-wide\'). May be hierarchical or multi-select.' ;
    rdfs:domain ind:ReductionTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusionsNotes rdf:type rdf:Property ;
    rdfs:label 'Exclusions Notes' ;
    rdfs:comment 'Documents any exclusions from the target scope (e.g., specific facilities, acquired entities, divested operations). Required for transparency and comparability.' ;
    rdfs:domain ind:ReductionTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frameworkAlignment rdf:type rdf:Property ;
    rdfs:label 'Framework Alignment' ;
    rdfs:comment 'Indicates alignment with external sustainability frameworks and standards (e.g., SBTi, GRI, TCFD, CDP, RE100). Multiple frameworks may be listed. [ENUM-REF-CANDIDATE: sbti|gri|tcfd|cdp|re100|ungc|sasb|iso14001 — promote to reference product]' ;
    rdfs:domain ind:ReductionTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interimMilestoneValue rdf:type rdf:Property ;
    rdfs:label 'Interim Milestone Value' ;
    rdfs:comment 'Quantitative goal for the interim milestone year. Enables tracking of progress toward the final target.' ;
    rdfs:domain ind:ReductionTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interimMilestoneYear rdf:type rdf:Property ;
    rdfs:label 'Interim Milestone Year' ;
    rdfs:comment 'Optional intermediate year for progress checkpoints between baseline and target year (e.g., 2025 milestone for a 2030 target).' ;
    rdfs:domain ind:ReductionTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:linkedInitiativeIds rdf:type rdf:Property ;
    rdfs:label 'Linked Initiative Ids' ;
    rdfs:comment 'Comma-separated list of initiative or project IDs that contribute to achieving this target (e.g., fleet electrification projects, renewable energy installations, waste diversion programs).' ;
    rdfs:domain ind:ReductionTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:methodologyDescription rdf:type rdf:Property ;
    rdfs:label 'Methodology Description' ;
    rdfs:comment 'Detailed description of the calculation methodology, assumptions, and data sources used to establish baseline and target values. Critical for audit and verification.' ;
    rdfs:domain ind:ReductionTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerDepartment rdf:type rdf:Property ;
    rdfs:label 'Owner Department' ;
    rdfs:comment 'Department or functional area responsible for target execution and reporting (e.g., \'Sustainability\', \'Fleet Management\', \'Operations\').' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicAnnouncementDate rdf:type rdf:Property ;
    rdfs:label 'Public Announcement Date' ;
    rdfs:comment 'Date when the target was publicly announced or disclosed in sustainability reports, press releases, or regulatory filings.' ;
    rdfs:domain ind:ReductionTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reductionPercentage rdf:type rdf:Property ;
    rdfs:label 'Reduction Percentage' ;
    rdfs:comment 'The percentage reduction from baseline to target (calculated as ((baseline_value - target_value) / baseline_value) * 100). Used for reporting and tracking progress.' ;
    rdfs:domain ind:ReductionTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sbtiValidatedFlag rdf:type rdf:Property ;
    rdfs:label 'Sbti Validated Flag' ;
    rdfs:comment 'Indicates whether this target has been validated and approved by the Science Based Targets initiative as aligned with climate science.' ;
    rdfs:domain ind:ReductionTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scope rdf:type rdf:Property ;
    rdfs:label 'Scope' ;
    rdfs:comment 'For GHG reduction targets, indicates the emissions scope covered (Scope 1: direct emissions, Scope 2: purchased energy, Scope 3: value chain). May be combined (e.g., \'Scope 1+2\'). Null for non-GHG targets.' ;
    rdfs:domain ind:ReductionTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCategory rdf:type rdf:Property ;
    rdfs:label 'Target Category' ;
    rdfs:comment 'Classification of the sustainability target type. Aligns with corporate sustainability pillars and ESG reporting frameworks.' ;
    rdfs:domain ind:ReductionTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCode rdf:type rdf:Property ;
    rdfs:label 'Target Code' ;
    rdfs:comment 'Unique business identifier or code for the target used in external reporting and internal tracking systems.' ;
    rdfs:domain ind:ReductionTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetName rdf:type rdf:Property ;
    rdfs:label 'Target Name' ;
    rdfs:comment 'Business-friendly name of the sustainability target (e.g., \'2030 Net Zero Commitment\', \'Fleet Electrification Goal\').' ;
    rdfs:domain ind:ReductionTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetType rdf:type rdf:Property ;
    rdfs:label 'Target Type' ;
    rdfs:comment 'Indicates whether the target is measured as an absolute reduction (total emissions/waste) or intensity-based (per unit of activity, e.g., CO2e per ton processed).' ;
    rdfs:domain ind:ReductionTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetYear rdf:type rdf:Property ;
    rdfs:label 'Target Year' ;
    rdfs:comment 'The year by which the target is committed to be achieved (e.g., 2030, 2050 for net-zero commitments).' ;
    rdfs:domain ind:ReductionTarget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:portfolioManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Portfolio Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: REC portfolio management requires designated staff for acquisition strategy, retirement timing, compliance program tracking (RPS, voluntary), and ESG disclosure coordination.' ;
    rdfs:domain ind:RenewableEnergyCredit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryRenewableGeneratingFacilityId rdf:type rdf:Property ;
    rdfs:label 'Primary Renewable Generating Facility Id' ;
    rdfs:comment 'Reference to the facility that generated the renewable energy. Links to the facility master record (landfill, WTE plant, solar installation, etc.).' ;
    rdfs:domain ind:RenewableEnergyCredit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:certificateSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Certificate Serial Number' ;
    rdfs:comment 'Unique serial number assigned by the issuing registry to this renewable energy certificate. This is the externally-known business identifier used for tracking and verification across registries.' ;
    rdfs:domain ind:RenewableEnergyCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateStatus rdf:type rdf:Property ;
    rdfs:label 'Certificate Status' ;
    rdfs:comment 'Current lifecycle status of the renewable energy certificate. Active = available for use, Retired = applied to sustainability target, Transferred = sold or moved to another entity.' ;
    rdfs:domain ind:RenewableEnergyCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateType rdf:type rdf:Property ;
    rdfs:label 'Certificate Type' ;
    rdfs:comment 'Type of renewable energy certificate. REC = Renewable Energy Certificate, RIN = Renewable Identification Number, LCFS = Low Carbon Fuel Standard credit.' ;
    rdfs:domain ind:RenewableEnergyCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:co2eOffsetMetricTons rdf:type rdf:Property ;
    rdfs:label 'Co2e Offset Metric Tons' ;
    rdfs:comment 'Estimated greenhouse gas emissions offset by this renewable energy certificate, measured in metric tons of CO2 equivalent. Calculated using EPA emission factors.' ;
    rdfs:domain ind:RenewableEnergyCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eiaPlantCode rdf:type rdf:Property ;
    rdfs:label 'Eia Plant Code' ;
    rdfs:comment 'EIA-assigned plant code for the generating facility. Used for federal energy reporting and cross-referencing with EIA databases.' ;
    rdfs:domain ind:RenewableEnergyCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibilityFlags rdf:type rdf:Property ;
    rdfs:label 'Eligibility Flags' ;
    rdfs:comment 'Comma-separated list of eligibility attributes for this certificate (e.g., \'Green-e Certified\', \'EPA Verified\', \'California Eligible\'). Used for compliance matching and customer claims.' ;
    rdfs:domain ind:RenewableEnergyCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:energySource rdf:type rdf:Property ;
    rdfs:label 'Energy Source' ;
    rdfs:comment 'Type of renewable energy source. LFG = Landfill Gas, RNG = Renewable Natural Gas, WTE = Waste-to-Energy. [ENUM-REF-CANDIDATE: LFG|RNG|WTE|Solar|Wind|Biomass|Biogas|Other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RenewableEnergyCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityState rdf:type rdf:Property ;
    rdfs:label 'Facility State' ;
    rdfs:comment 'Two-letter US state code where the generating facility is located. Used for state-level compliance and reporting.' ;
    rdfs:domain ind:RenewableEnergyCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:generationEndDate rdf:type rdf:Property ;
    rdfs:label 'Generation End Date' ;
    rdfs:comment 'End date of the generation period for this certificate. Defines the end of the time window during which the renewable energy was produced.' ;
    rdfs:domain ind:RenewableEnergyCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:generationStartDate rdf:type rdf:Property ;
    rdfs:label 'Generation Start Date' ;
    rdfs:comment 'Start date of the generation period for this certificate. Defines the beginning of the time window during which the renewable energy was produced.' ;
    rdfs:domain ind:RenewableEnergyCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quantityGge rdf:type rdf:Property ;
    rdfs:label 'Quantity Gge' ;
    rdfs:comment 'Quantity of renewable fuel represented by this certificate, measured in gasoline gallon equivalents. Used for RIN certificates from RNG and biofuel production.' ;
    rdfs:domain ind:RenewableEnergyCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityMmbtu rdf:type rdf:Property ;
    rdfs:label 'Quantity Mmbtu' ;
    rdfs:comment 'Quantity of renewable thermal energy represented by this certificate, measured in million British thermal units. Used for thermal energy credits and RNG certificates.' ;
    rdfs:domain ind:RenewableEnergyCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityMwh rdf:type rdf:Property ;
    rdfs:label 'Quantity Mwh' ;
    rdfs:comment 'Quantity of renewable electricity represented by this certificate, measured in megawatt-hours. Used for REC certificates from solar, wind, and WTE facilities.' ;
    rdfs:domain ind:RenewableEnergyCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transferRecipient rdf:type rdf:Property ;
    rdfs:label 'Transfer Recipient' ;
    rdfs:comment 'Name of the entity to which the certificate was transferred. Used for audit trail and transaction history.' ;
    rdfs:domain ind:RenewableEnergyCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vintageMonth rdf:type rdf:Property ;
    rdfs:label 'Vintage Month' ;
    rdfs:comment 'Month (1-12) in which the renewable energy was generated. Provides granular tracking for quarterly and monthly reporting.' ;
    rdfs:domain ind:RenewableEnergyCredit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryReportEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Report Employee Id' ;
    rdfs:comment 'Identifier of the user or system account that created this reporting period record.' ;
    rdfs:domain ind:ReportPeriod ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Submission Date' ;
    rdfs:comment 'The actual date when the sustainability report or disclosure was submitted for this period.' ;
    rdfs:domain ind:ReportPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:baselinePeriodFlag rdf:type rdf:Property ;
    rdfs:label 'Baseline Period Flag' ;
    rdfs:comment 'Indicates whether this period serves as a baseline year for carbon reduction targets or sustainability goals.' ;
    rdfs:domain ind:ReportPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:calendarMonth rdf:type rdf:Property ;
    rdfs:label 'Calendar Month' ;
    rdfs:comment 'The calendar month number (1-12) if this is a monthly reporting period, otherwise null.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calendarQuarter rdf:type rdf:Property ;
    rdfs:label 'Calendar Quarter' ;
    rdfs:comment 'The calendar quarter number (1-4) if this is a quarterly reporting period, otherwise null.' ;
    rdfs:domain ind:ReportPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calendarYear rdf:type rdf:Property ;
    rdfs:label 'Calendar Year' ;
    rdfs:comment 'The calendar year to which this reporting period belongs (e.g., 2024).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cdpReportingApplicable rdf:type rdf:Property ;
    rdfs:label 'Cdp Reporting Applicable' ;
    rdfs:comment 'Indicates whether this period is used for voluntary CDP climate change disclosure.' ;
    rdfs:domain ind:ReportPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataFreezeDate rdf:type rdf:Property ;
    rdfs:label 'Data Freeze Date' ;
    rdfs:comment 'The date after which no further data changes are allowed for this reporting period. Used to ensure data integrity for regulatory and ESG reporting.' ;
    rdfs:domain ind:ReportPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:epaGhgReportingApplicable rdf:type rdf:Property ;
    rdfs:label 'Epa Ghg Reporting Applicable' ;
    rdfs:comment 'Indicates whether this period is used for EPA GHG mandatory reporting under 40 CFR Part 98.' ;
    rdfs:domain ind:ReportPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fiscalMonth rdf:type rdf:Property ;
    rdfs:label 'Fiscal Month' ;
    rdfs:comment 'The fiscal month number (1-12) if this is a monthly reporting period, otherwise null.' ;
    rdfs:domain ind:ReportPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fiscalQuarter rdf:type rdf:Property ;
    rdfs:label 'Fiscal Quarter' ;
    rdfs:comment 'The fiscal quarter number (1-4) if this is a quarterly reporting period, otherwise null.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:griReportingApplicable rdf:type rdf:Property ;
    rdfs:label 'Gri Reporting Applicable' ;
    rdfs:comment 'Indicates whether this period is used for GRI sustainability reporting standards.' ;
    rdfs:domain ind:ReportPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:periodCode rdf:type rdf:Property ;
    rdfs:label 'Period Code' ;
    rdfs:comment 'Standardized short code for the reporting period used across systems (e.g., \'2024Q1\', \'FY24\', \'202401\').' ;
    rdfs:domain ind:ReportPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodName rdf:type rdf:Property ;
    rdfs:label 'Period Name' ;
    rdfs:comment 'Human-readable name for the reporting period (e.g., \'FY2024 Q1\', \'2024 Annual Report\', \'January 2024\').' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodStatus rdf:type rdf:Property ;
    rdfs:label 'Period Status' ;
    rdfs:comment 'Current lifecycle status of the reporting period: open (data collection in progress), closed (data collection complete), verified (third-party assurance complete), draft (period defined but not yet active), archived (historical period).' ;
    rdfs:domain ind:ReportPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:periodType rdf:type rdf:Property ;
    rdfs:label 'Period Type' ;
    rdfs:comment 'Classification of the reporting period frequency (annual, quarterly, monthly, semi-annual, or custom).' ;
    rdfs:domain ind:ReportPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sasbReportingApplicable rdf:type rdf:Property ;
    rdfs:label 'Sasb Reporting Applicable' ;
    rdfs:comment 'Indicates whether this period is used for SASB industry-specific sustainability accounting standards.' ;
    rdfs:domain ind:ReportPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tcfdReportingApplicable rdf:type rdf:Property ;
    rdfs:label 'Tcfd Reporting Applicable' ;
    rdfs:comment 'Indicates whether this period is used for TCFD climate-related financial disclosures.' ;
    rdfs:domain ind:ReportPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:verificationProvider rdf:type rdf:Property ;
    rdfs:label 'Verification Provider' ;
    rdfs:comment 'Name of the third-party organization providing assurance or verification services for this period.' ;
    rdfs:domain ind:ReportPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rngProductionId rdf:type rdf:Property ;
    rdfs:label 'Rng Production Id' ;
    rdfs:comment 'Unique identifier for the RNG production record. Primary key for the RNG production transaction.' ;
    rdfs:domain ind:RngProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:carbonCreditRegistry rdf:type rdf:Property ;
    rdfs:label 'Carbon Credit Registry' ;
    rdfs:comment 'Name of the voluntary carbon credit registry where carbon offset credits for this RNG production are registered and tracked.' ;
    rdfs:domain ind:RngProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:co2eAvoidedMetricTons rdf:type rdf:Property ;
    rdfs:label 'Co2e Avoided Metric Tons' ;
    rdfs:comment 'Estimated greenhouse gas emissions avoided by converting landfill methane to RNG instead of flaring or venting, measured in metric tons of CO2 equivalent.' ;
    rdfs:domain ind:RngProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:downtimeReason rdf:type rdf:Property ;
    rdfs:label 'Downtime Reason' ;
    rdfs:comment 'Primary reason for facility downtime during this production period. Used for root cause analysis and maintenance planning.' ;
    rdfs:domain ind:RngProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lfgInputVolumeScf rdf:type rdf:Property ;
    rdfs:label 'Lfg Input Volume Scf' ;
    rdfs:comment 'Total volume of raw landfill gas fed into the conversion facility during this production run, measured in standard cubic feet (SCF).' ;
    rdfs:domain ind:RngProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lfgMethaneContentPercent rdf:type rdf:Property ;
    rdfs:label 'Lfg Methane Content Percent' ;
    rdfs:comment 'Percentage of methane (CH4) in the raw landfill gas input stream. Typical range is 45-60% for landfill gas.' ;
    rdfs:domain ind:RngProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pipelineInjectionVolumeScf rdf:type rdf:Property ;
    rdfs:label 'Pipeline Injection Volume Scf' ;
    rdfs:comment 'Volume of RNG injected into the natural gas pipeline distribution system during this production period, measured in standard cubic feet (SCF).' ;
    rdfs:domain ind:RngProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productionBatchNumber rdf:type rdf:Property ;
    rdfs:label 'Production Batch Number' ;
    rdfs:comment 'Unique batch identifier assigned to this RNG production run for traceability and quality control purposes.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionDate rdf:type rdf:Property ;
    rdfs:label 'Production Date' ;
    rdfs:comment 'Calendar date when the RNG production occurred. Used for daily production reporting and trend analysis.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:productionEfficiencyPercent rdf:type rdf:Property ;
    rdfs:label 'Production Efficiency Percent' ;
    rdfs:comment 'Ratio of RNG energy output to LFG energy input, expressed as a percentage. Measures the conversion efficiency of the LFG-to-RNG facility.' ;
    rdfs:domain ind:RngProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productionEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Production End Timestamp' ;
    rdfs:comment 'Precise date and time when the RNG production batch processing completed.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:productionStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Production Start Timestamp' ;
    rdfs:comment 'Precise date and time when the RNG production batch processing began.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:productionStatus rdf:type rdf:Property ;
    rdfs:label 'Production Status' ;
    rdfs:comment 'Current lifecycle status of this RNG production batch. Tracks the batch from initiation through quality certification and final disposition.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityTestDate rdf:type rdf:Property ;
    rdfs:label 'Quality Test Date' ;
    rdfs:comment 'Date when quality testing and certification of the RNG output was performed.' ;
    rdfs:domain ind:Sustainability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualityTestPassedFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Test Passed Flag' ;
    rdfs:comment 'Indicates whether the RNG output met all pipeline quality specifications and purity requirements. True = passed, False = failed.' ;
    rdfs:domain ind:RngProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewableFuelPathwayCode rdf:type rdf:Property ;
    rdfs:label 'Renewable Fuel Pathway Code' ;
    rdfs:comment 'EPA-assigned pathway code identifying the specific renewable fuel production process and feedstock combination used for this RNG production.' ;
    rdfs:domain ind:RngProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rinDCode rdf:type rdf:Property ;
    rdfs:label 'Rin D Code' ;
    rdfs:comment 'EPA RIN D-code classification for the renewable fuel pathway. D3 = cellulosic biofuel (landfill gas), D5 = advanced biofuel.' ;
    rdfs:domain ind:RngProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rngMethanePurityPercent rdf:type rdf:Property ;
    rdfs:label 'Rng Methane Purity Percent' ;
    rdfs:comment 'Percentage of methane (CH4) in the purified RNG output. Pipeline-quality RNG typically requires 95-98% methane purity.' ;
    rdfs:domain ind:RngProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rngOutputEnergyMmbtu rdf:type rdf:Property ;
    rdfs:label 'Rng Output Energy Mmbtu' ;
    rdfs:comment 'Energy content of the RNG produced, measured in million British thermal units (MMBtu). Used for energy accounting and RIN credit calculation.' ;
    rdfs:domain ind:RngProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rngOutputVolumeScf rdf:type rdf:Property ;
    rdfs:label 'Rng Output Volume Scf' ;
    rdfs:comment 'Total volume of purified renewable natural gas produced during this production run, measured in standard cubic feet (SCF).' ;
    rdfs:domain ind:RngProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:uptimeHours rdf:type rdf:Property ;
    rdfs:label 'Uptime Hours' ;
    rdfs:comment 'Number of hours the RNG production facility was operational during this production period. Used for availability and reliability metrics.' ;
    rdfs:domain ind:RngProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vehicleFuelDispensedGge rdf:type rdf:Property ;
    rdfs:label 'Vehicle Fuel Dispensed Gge' ;
    rdfs:comment 'Volume of RNG dispensed as vehicle fuel (CNG/RNG) during this production period, measured in gasoline gallon equivalents (GGE) for energy comparison purposes.' ;
    rdfs:domain ind:RngProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:voluntaryCarbonCreditsIssued rdf:type rdf:Property ;
    rdfs:label 'Voluntary Carbon Credits Issued' ;
    rdfs:comment 'Number of voluntary carbon offset credits issued for this RNG production under voluntary carbon market programs (e.g., Verra VCS, Gold Standard).' ;
    rdfs:domain ind:RngProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:srfProductionId rdf:type rdf:Property ;
    rdfs:label 'Srf Production Id' ;
    rdfs:comment 'Unique identifier for the SRF production record. Primary key for tracking individual production batches at MRF and processing facilities.' ;
    rdfs:domain ind:SrfProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:co2eEmissionsAvoidedTons rdf:type rdf:Property ;
    rdfs:label 'Co2e Emissions Avoided Tons' ;
    rdfs:comment 'Estimated tons of CO2 equivalent greenhouse gas emissions avoided by using SRF instead of fossil fuels. Critical for carbon offset program reporting and ESG disclosures.' ;
    rdfs:domain ind:SrfProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conversionEfficiencyPercent rdf:type rdf:Property ;
    rdfs:label 'Conversion Efficiency Percent' ;
    rdfs:comment 'Percentage of input waste successfully converted to SRF, calculated as (SRF output / input volume) * 100. Key performance indicator for production optimization.' ;
    rdfs:domain ind:SrfProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:destinationFacilityName rdf:type rdf:Property ;
    rdfs:label 'Destination Facility Name' ;
    rdfs:comment 'Name of the specific facility or customer receiving the SRF for energy recovery purposes. Used for supply chain tracking and revenue allocation.' ;
    rdfs:domain ind:SrfProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diversionRateContributionPercent rdf:type rdf:Property ;
    rdfs:label 'Diversion Rate Contribution Percent' ;
    rdfs:comment 'Percentage of waste diverted from landfill through this SRF production batch. Key sustainability metric for GRI 306 waste diversion reporting.' ;
    rdfs:domain ind:SrfProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:endUseDestinationType rdf:type rdf:Property ;
    rdfs:label 'End Use Destination Type' ;
    rdfs:comment 'Category of facility where the SRF will be utilized for energy recovery. WTE = Waste-to-Energy facility. Critical for circular economy tracking.' ;
    rdfs:domain ind:SrfProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:heavyMetalsPpm rdf:type rdf:Property ;
    rdfs:label 'Heavy Metals Ppm' ;
    rdfs:comment 'Concentration of heavy metals (mercury, cadmium, lead) in parts per million. Critical for environmental compliance and end-user acceptance criteria.' ;
    rdfs:domain ind:SrfProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inputVolumeTons rdf:type rdf:Property ;
    rdfs:label 'Input Volume Tons' ;
    rdfs:comment 'Total weight in tons of input waste material processed to produce the SRF batch. Critical for diversion rate calculations.' ;
    rdfs:domain ind:SrfProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inputWasteStreamType rdf:type rdf:Property ;
    rdfs:label 'Input Waste Stream Type' ;
    rdfs:comment 'Classification of the waste stream used as feedstock for SRF production. MSW = Municipal Solid Waste, C&D = Construction and Demolition Waste.' ;
    rdfs:domain ind:SrfProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionCostPerTon rdf:type rdf:Property ;
    rdfs:label 'Production Cost Per Ton' ;
    rdfs:comment 'Total cost per ton to produce the SRF including labor, energy, and processing costs. Used for margin analysis and EBITDA calculations.' ;
    rdfs:domain ind:SrfProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Quality Certification Number' ;
    rdfs:comment 'Unique certification identifier issued by the testing laboratory confirming SRF quality parameters meet specified standards.' ;
    rdfs:domain ind:SrfProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityClassification rdf:type rdf:Property ;
    rdfs:label 'Quality Classification' ;
    rdfs:comment 'SRF quality grade per EN 15359 standard based on calorific value, chlorine content, and mercury content. Class 1 represents highest quality. [ENUM-REF-CANDIDATE: class_1|class_2|class_3|class_4|class_5|non_compliant|pending_analysis — promote to reference product]' ;
    rdfs:domain ind:SrfProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewableEnergyCreditEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Renewable Energy Credit Eligible Flag' ;
    rdfs:comment 'Indicates whether this SRF batch qualifies for renewable energy credits or carbon offset programs based on feedstock composition and quality standards.' ;
    rdfs:domain ind:SrfProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:srfOutputTonnage rdf:type rdf:Property ;
    rdfs:label 'Srf Output Tonnage' ;
    rdfs:comment 'Total weight in tons of SRF produced from the input waste stream. Used for yield calculations and revenue reporting.' ;
    rdfs:domain ind:SrfProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitPricePerTon rdf:type rdf:Property ;
    rdfs:label 'Unit Price Per Ton' ;
    rdfs:comment 'Price per ton charged for the SRF batch in USD. Varies based on quality classification and market conditions.' ;
    rdfs:domain ind:SrfProduction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetProgressId rdf:type rdf:Property ;
    rdfs:label 'Target Progress Id' ;
    rdfs:comment 'Unique identifier for the target progress record. Primary key.' ;
    rdfs:domain ind:TargetProgress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reportingAnalystEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Reporting Analyst Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Target progress reporting requires designated analysts for data aggregation across facilities, verification against baselines, variance analysis, and ESG framework alignment (CDP, GRI, TCFD).' ;
    rdfs:domain ind:TargetProgress ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualValue rdf:type rdf:Property ;
    rdfs:label 'Actual Value' ;
    rdfs:comment 'The actual measured performance value achieved during the reporting period. Represents raw metric value before percentage calculation (e.g., tons CO2e emitted, percentage waste diverted, gallons RNG produced).' ;
    rdfs:domain ind:TargetProgress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adjustmentReason rdf:type rdf:Property ;
    rdfs:label 'Adjustment Reason' ;
    rdfs:comment 'Explanation for any adjustments or restatements made to previously reported progress values. Required for transparency when historical data is revised due to methodology changes, data corrections, or acquisitions/divestitures.' ;
    rdfs:domain ind:TargetProgress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselineComparisonValue rdf:type rdf:Property ;
    rdfs:label 'Baseline Comparison Value' ;
    rdfs:comment 'The baseline value against which progress is measured. Typically the performance value from the baseline year (e.g., 2020 emissions for a 2030 reduction target). Enables percentage reduction calculation.' ;
    rdfs:domain ind:TargetProgress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commentary rdf:type rdf:Property ;
    rdfs:label 'Commentary' ;
    rdfs:comment 'Narrative commentary explaining the progress results, including context for variances, operational factors affecting performance, corrective actions taken, and qualitative insights. Used in CDP, GRI, and TCFD narrative disclosures.' ;
    rdfs:domain ind:TargetProgress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contributingInitiativeIds rdf:type rdf:Property ;
    rdfs:label 'Contributing Initiative Ids' ;
    rdfs:comment 'Comma-separated list of sustainability initiative IDs that contributed to this progress result. Enables attribution of performance to specific programs (e.g., CNG fleet conversion, LFG-to-RNG project, MRF efficiency upgrade).' ;
    rdfs:domain ind:TargetProgress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cumulativeProgressToDate rdf:type rdf:Property ;
    rdfs:label 'Cumulative Progress To Date' ;
    rdfs:comment 'Cumulative progress value from target baseline date through the end of this reporting period. Provides year-over-year trend visibility for multi-year targets (e.g., 2030 carbon neutrality goal).' ;
    rdfs:domain ind:TargetProgress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emissionCategory rdf:type rdf:Property ;
    rdfs:label 'Emission Category' ;
    rdfs:comment 'EPA emission category classification for GHG targets. Aligns with 40 CFR Part 98 subpart categories. Not applicable for non-emissions targets. [ENUM-REF-CANDIDATE: stationary_combustion|mobile_combustion|fugitive_emissions|purchased_electricity|waste_disposal|transportation|not_applicable — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TargetProgress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ghgScope rdf:type rdf:Property ;
    rdfs:label 'Ghg Scope' ;
    rdfs:comment 'GHG Protocol scope classification for emissions-related targets. Scope 1 = direct emissions from owned sources, Scope 2 = indirect emissions from purchased energy, Scope 3 = value chain emissions. Not applicable for non-emissions targets.' ;
    rdfs:domain ind:TargetProgress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRestated rdf:type rdf:Property ;
    rdfs:label 'Is Restated' ;
    rdfs:comment 'Flag indicating whether this progress record represents a restatement of previously reported data. True if restated, False if original reporting.' ;
    rdfs:domain ind:TargetProgress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:previousReportedValue rdf:type rdf:Property ;
    rdfs:label 'Previous Reported Value' ;
    rdfs:comment 'The previously reported actual value before restatement. Populated only when is_restated is True. Enables transparency in year-over-year comparisons when historical data is revised.' ;
    rdfs:domain ind:TargetProgress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:publicationDate rdf:type rdf:Property ;
    rdfs:label 'Publication Date' ;
    rdfs:comment 'Date on which this progress data was published in an external report. Null if not yet published. Used for version control and public disclosure tracking.' ;
    rdfs:domain ind:TargetProgress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:publishedInReport rdf:type rdf:Property ;
    rdfs:label 'Published In Report' ;
    rdfs:comment 'Flag indicating whether this progress data has been published in an external sustainability report (annual ESG report, CDP submission, TCFD disclosure). True if published, False if internal only.' ;
    rdfs:domain ind:TargetProgress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportingScope rdf:type rdf:Property ;
    rdfs:label 'Reporting Scope' ;
    rdfs:comment 'Organizational scope for which this progress is reported. Enables roll-up from facility-level to enterprise-level reporting for consolidated ESG disclosures. [ENUM-REF-CANDIDATE: enterprise_wide|business_unit|facility|fleet|landfill|mrf|region|division — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TargetProgress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetAchievementPercentage rdf:type rdf:Property ;
    rdfs:label 'Target Achievement Percentage' ;
    rdfs:comment 'Percentage of the target achieved during this reporting period, calculated as (actual_value / target_value) * 100. Values over 100% indicate target exceeded. Critical KPI for ESG dashboards and executive reporting.' ;
    rdfs:domain ind:TargetProgress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceFromTrajectory rdf:type rdf:Property ;
    rdfs:label 'Variance From Trajectory' ;
    rdfs:comment 'Variance between actual performance and the planned trajectory for this period. Positive values indicate ahead of plan, negative values indicate behind plan. Enables early identification of off-track targets requiring corrective action.' ;
    rdfs:domain ind:TargetProgress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryTrackedEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Tracked Employee Id' ;
    rdfs:comment 'User identifier of the person who created this tracked site record.' ;
    rdfs:domain ind:TrackedSite ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:annualWasteCapacityTons rdf:type rdf:Property ;
    rdfs:label 'Annual Waste Capacity Tons' ;
    rdfs:comment 'Maximum annual waste processing or disposal capacity of the site measured in tons per year. Applicable to landfills, MRFs, WTE plants, and transfer stations.' ;
    rdfs:domain ind:TrackedSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carbonOffsetProjectFlag rdf:type rdf:Property ;
    rdfs:label 'Carbon Offset Project Flag' ;
    rdfs:comment 'Indicates whether this site participates in carbon offset or carbon credit generation projects (e.g., landfill methane capture for carbon credits).' ;
    rdfs:domain ind:TrackedSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dailyWasteCapacityTpd rdf:type rdf:Property ;
    rdfs:label 'Daily Waste Capacity Tpd' ;
    rdfs:comment 'Maximum daily waste processing or disposal capacity measured in tons per day. TPD = Tons Per Day, a standard industry metric.' ;
    rdfs:domain ind:TrackedSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emissionSourceCategories rdf:type rdf:Property ;
    rdfs:label 'Emission Source Categories' ;
    rdfs:comment 'Comma-separated list of applicable emission source categories present at this site (e.g., \'stationary_combustion\', \'landfill_gas\', \'mobile_combustion\', \'fugitive_emissions\', \'purchased_electricity\'). [ENUM-REF-CANDIDATE: stationary_combustion|landfill_gas|mobile_combustion|fugitive_emissions|purchased_electricity|wastewater_treatment|refrigerants — promote to reference product]' ;
    rdfs:domain ind:TrackedSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ghgScope1SourceFlag rdf:type rdf:Property ;
    rdfs:label 'Ghg Scope 1 Source Flag' ;
    rdfs:comment 'Indicates whether this site contains direct GHG emission sources owned or controlled by the organization (e.g., landfill methane, on-site combustion).' ;
    rdfs:domain ind:TrackedSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ghgScope2SourceFlag rdf:type rdf:Property ;
    rdfs:label 'Ghg Scope 2 Source Flag' ;
    rdfs:comment 'Indicates whether this site has indirect GHG emissions from purchased electricity, steam, heating, or cooling.' ;
    rdfs:domain ind:TrackedSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewableEnergyGenerationFlag rdf:type rdf:Property ;
    rdfs:label 'Renewable Energy Generation Flag' ;
    rdfs:comment 'Indicates whether this site generates renewable energy through LFG-to-RNG conversion, WTE operations, or other renewable energy systems.' ;
    rdfs:domain ind:TrackedSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportingBoundaryInclusionFlag rdf:type rdf:Property ;
    rdfs:label 'Reporting Boundary Inclusion Flag' ;
    rdfs:comment 'Indicates whether this site is included within the organizational boundary for corporate sustainability and greenhouse gas emissions reporting (True = included, False = excluded).' ;
    rdfs:domain ind:TrackedSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:siteActivationDate rdf:type rdf:Property ;
    rdfs:label 'Site Activation Date' ;
    rdfs:comment 'Date when the site was first activated or commissioned for operations.' ;
    rdfs:domain ind:TrackedSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:siteClosureDate rdf:type rdf:Property ;
    rdfs:label 'Site Closure Date' ;
    rdfs:comment 'Date when the site was permanently closed or decommissioned. Null if the site is still active.' ;
    rdfs:domain ind:TrackedSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:siteType rdf:type rdf:Property ;
    rdfs:label 'Site Type' ;
    rdfs:comment 'Classification of the site based on its primary operational function. MRF = Materials Recovery Facility, WTE = Waste-to-Energy, LFG = Landfill Gas, RNG = Renewable Natural Gas, TSDF = Treatment Storage and Disposal Facility. [ENUM-REF-CANDIDATE: landfill|mrf|wte_plant|transfer_station|lfg_to_rng_facility|fleet_maintenance_yard|composting_facility|hazmat_tsdf|administrative_office|other — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TrackedSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityProgramEnrollmentDate rdf:type rdf:Property ;
    rdfs:label 'Sustainability Program Enrollment Date' ;
    rdfs:comment 'Date when the site was formally enrolled in the corporate sustainability tracking and reporting program.' ;
    rdfs:domain ind:TrackedSite ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:benefitEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Benefit Enrollment Id' ;
    rdfs:comment 'Unique identifier for the benefit enrollment record.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:benefitPlanId rdf:type rdf:Property ;
    rdfs:label 'Benefit Plan Id' ;
    rdfs:comment 'Unique identifier for the benefit plan in which the employee is enrolled. References the benefit plan catalog.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BenefitPlan .

ind:unionAgreementId rdf:type rdf:Property ;
    rdfs:label 'Union Agreement Id' ;
    rdfs:comment 'Foreign key linking to workforce.union_agreement. Business justification: Union benefit plans are governed by collective bargaining agreements. The union_local_number on benefit_enrollment should link to the authoritative union_agreement record to ensure benefit plan rules,' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UnionAgreement .

ind:annualEmployeeContribution rdf:type rdf:Property ;
    rdfs:label 'Annual Employee Contribution' ;
    rdfs:comment 'Total annual employee contribution amount for this benefit plan in USD. Calculated based on per-period contribution and frequency.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annualEmployerContribution rdf:type rdf:Property ;
    rdfs:label 'Annual Employer Contribution' ;
    rdfs:comment 'Total annual employer contribution amount for this benefit plan in USD. Calculated based on per-period contribution and frequency. Used for financial reporting and compliance.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:beneficiaryName rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Name' ;
    rdfs:comment 'Full legal name of the primary beneficiary designated by the employee for life insurance or retirement benefits. Required for life insurance and 401(k) plans.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficiaryRelationship rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Relationship' ;
    rdfs:comment 'Relationship of the designated beneficiary to the employee. Used for life insurance and retirement plan beneficiary designation.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierConfirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Carrier Confirmation Number' ;
    rdfs:comment 'Confirmation or policy number provided by the insurance carrier or benefit provider upon successful enrollment. Used for reconciliation and member services.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cobraElectionDate rdf:type rdf:Property ;
    rdfs:label 'Cobra Election Date' ;
    rdfs:comment 'Date on which the employee elected COBRA continuation coverage after a qualifying event. Nullable if COBRA was not elected.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cobraEligibleIndicator rdf:type rdf:Property ;
    rdfs:label 'Cobra Eligible Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this enrollment is eligible for COBRA continuation coverage upon termination of employment. True if the plan qualifies for COBRA; false otherwise.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cobraEndDate rdf:type rdf:Property ;
    rdfs:label 'Cobra End Date' ;
    rdfs:comment 'Date on which COBRA continuation coverage ends. Typically 18 or 36 months after the qualifying event, depending on the event type. Nullable if COBRA is ongoing or was not elected.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contributionFrequency rdf:type rdf:Property ;
    rdfs:label 'Contribution Frequency' ;
    rdfs:comment 'The frequency at which employee and employer contributions are deducted or paid. Aligns with the payroll cycle for the employee\'s position.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageTier rdf:type rdf:Property ;
    rdfs:label 'Coverage Tier' ;
    rdfs:comment 'Level of coverage elected by the employee, determining who is covered under the benefit plan (employee only, employee plus spouse, employee plus children, full family, or employee plus domestic partner).' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dependentCount rdf:type rdf:Property ;
    rdfs:label 'Dependent Count' ;
    rdfs:comment 'Number of dependents covered under this benefit enrollment. Applicable for family coverage tiers. Used for premium calculation and ACA reporting.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:employeeContributionAmount rdf:type rdf:Property ;
    rdfs:label 'Employee Contribution Amount' ;
    rdfs:comment 'The monetary amount deducted from the employee\'s paycheck per pay period for this benefit plan. Represents the employee\'s share of the premium or contribution cost in USD.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:employerContributionAmount rdf:type rdf:Property ;
    rdfs:label 'Employer Contribution Amount' ;
    rdfs:comment 'The monetary amount contributed by Waste Management per pay period for this benefit plan on behalf of the employee. Represents the employer\'s share of the premium or contribution cost in USD.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:enrollmentConfirmationSentDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment Confirmation Sent Date' ;
    rdfs:comment 'Date on which the enrollment confirmation communication was sent to the employee. Used for audit trail and compliance with ERISA disclosure requirements.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enrollmentEventType rdf:type rdf:Property ;
    rdfs:label 'Enrollment Event Type' ;
    rdfs:comment 'The triggering event that allowed or required the benefit enrollment. New hire indicates initial enrollment upon employment; annual open enrollment is the yearly election period; qualifying life event (QLE) includes marriage, birth, adoption, or other IRS-defined events; benefit change indicates mid-year plan modification; rehire indicates re-enrollment after returning to employment; leave of absence indicates enrollment during approved leave.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentMethod rdf:type rdf:Property ;
    rdfs:label 'Enrollment Method' ;
    rdfs:comment 'Channel or method through which the employee completed the benefit enrollment. Online portal indicates self-service through Workday; paper form indicates manual submission; phone indicates telephonic enrollment; HR representative indicates assisted enrollment; automatic indicates system-generated enrollment; default indicates passive enrollment into default plan.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceOfInsurabilityRequired rdf:type rdf:Property ;
    rdfs:label 'Evidence Of Insurability Required' ;
    rdfs:comment 'Boolean flag indicating whether the employee must provide evidence of insurability (medical underwriting) for this enrollment. Typically required for supplemental life insurance above guaranteed issue amounts. True if EOI is required; false otherwise.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:evidenceOfInsurabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Evidence Of Insurability Status' ;
    rdfs:comment 'Current status of the evidence of insurability review process. Not required if EOI is not needed; pending if submitted and under review; approved if underwriting accepted; denied if underwriting rejected; incomplete if additional information is needed.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planYear rdf:type rdf:Property ;
    rdfs:label 'Plan Year' ;
    rdfs:comment 'Calendar year or fiscal year for which this benefit enrollment is effective. Used for annual reporting, open enrollment tracking, and compliance (e.g., ACA 1095-C reporting).' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unionLocalNumber rdf:type rdf:Property ;
    rdfs:label 'Union Local Number' ;
    rdfs:comment 'Identifier for the union local chapter governing this benefit plan, if applicable. Populated only when union_plan_indicator is true. Used for union reporting and compliance.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unionPlanIndicator rdf:type rdf:Property ;
    rdfs:label 'Union Plan Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this enrollment is for a union-negotiated benefit plan. True if the plan is governed by collective bargaining agreement; false otherwise. Relevant for drivers and facility operators covered by union contracts.' ;
    rdfs:domain ind:BenefitEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cdlLicenseId rdf:type rdf:Property ;
    rdfs:label 'Cdl License Id' ;
    rdfs:comment 'Unique identifier for the CDL license record in the Waste Management system.' ;
    rdfs:domain ind:CdlLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clearinghouseQueryDate rdf:type rdf:Property ;
    rdfs:label 'Clearinghouse Query Date' ;
    rdfs:comment 'The date of the most recent query to the FMCSA Drug and Alcohol Clearinghouse for this driver. Employers must query the clearinghouse annually and before hiring to check for drug and alcohol violations.' ;
    rdfs:domain ind:CdlLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clearinghouseStatus rdf:type rdf:Property ;
    rdfs:label 'Clearinghouse Status' ;
    rdfs:comment 'The driver\'s status in the FMCSA Drug and Alcohol Clearinghouse. Clear indicates no violations; violation_pending indicates unresolved violation; violation_resolved indicates completed return-to-duty process; prohibited indicates driver is not eligible to operate CMV.' ;
    rdfs:domain ind:CdlLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dotMedicalCertificateExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Dot Medical Certificate Expiration Date' ;
    rdfs:comment 'The expiration date of the driver\'s DOT medical examiner certificate. Drivers must maintain a valid medical certificate to operate commercial vehicles. Typically valid for 12-24 months depending on health conditions.' ;
    rdfs:domain ind:CdlLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:driverQualificationFileComplete rdf:type rdf:Property ;
    rdfs:label 'Driver Qualification File Complete' ;
    rdfs:comment 'Boolean flag indicating whether the driver\'s qualification file contains all required documents per FMCSA regulations (application, MVR, medical certificate, road test, etc.). True indicates complete; False indicates missing documentation.' ;
    rdfs:domain ind:CdlLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:endorsements rdf:type rdf:Property ;
    rdfs:label 'Endorsements' ;
    rdfs:comment 'Comma-separated list of CDL endorsements held by the driver. Common endorsements include H (Hazardous Materials), N (Tank Vehicle), T (Double/Triple Trailers), P (Passenger), S (School Bus). Critical for determining which routes and vehicles the driver is qualified to operate.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fmcsaRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Fmcsa Registration Number' ;
    rdfs:comment 'The driver\'s FMCSA registration number used for tracking in the FMCSA Motor Carrier Management Information System (MCMIS). Used for compliance monitoring and safety performance tracking.' ;
    rdfs:domain ind:CdlLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatEndorsementExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Hazmat Endorsement Expiration Date' ;
    rdfs:comment 'The expiration date of the HAZMAT endorsement (H endorsement). HAZMAT endorsements require TSA background checks and must be renewed every 5 years. Critical for drivers transporting hazardous waste.' ;
    rdfs:domain ind:CdlLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastMvrCheckDate rdf:type rdf:Property ;
    rdfs:label 'Last Mvr Check Date' ;
    rdfs:comment 'The date of the most recent Motor Vehicle Record check performed for this driver. FMCSA requires annual MVR checks for all CDL holders to monitor driving violations and license status.' ;
    rdfs:domain ind:CdlLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastRoadTestDate rdf:type rdf:Property ;
    rdfs:label 'Last Road Test Date' ;
    rdfs:comment 'The date of the driver\'s most recent road test or skills evaluation. Required for initial CDL qualification and may be repeated for new vehicle types or after extended absence from driving.' ;
    rdfs:domain ind:CdlLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastRoadTestResult rdf:type rdf:Property ;
    rdfs:label 'Last Road Test Result' ;
    rdfs:comment 'The result of the driver\'s most recent road test. Passed indicates successful completion; failed indicates did not meet standards; waived indicates test was waived due to prior experience or equivalent certification.' ;
    rdfs:domain ind:CdlLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseNumber rdf:type rdf:Property ;
    rdfs:label 'License Number' ;
    rdfs:comment 'The unique CDL license number issued by the state Department of Motor Vehicles (DMV). This is the primary identifier on the physical license card and is used for DOT compliance verification.' ;
    rdfs:domain ind:CdlLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:randomDrugTestPoolStatus rdf:type rdf:Property ;
    rdfs:label 'Random Drug Test Pool Status' ;
    rdfs:comment 'Indicates whether the driver is currently enrolled in the DOT-mandated random drug and alcohol testing pool. All CDL holders performing safety-sensitive functions must be enrolled.' ;
    rdfs:domain ind:CdlLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictions rdf:type rdf:Property ;
    rdfs:label 'Restrictions' ;
    rdfs:comment 'Comma-separated list of restrictions on the CDL license (e.g., E - No Manual Transmission, L - No Air Brake Equipped Vehicles, O - No Tractor-Trailer, Z - No Full Air Brake). Defines operational limitations for the driver.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:selfCertificationType rdf:type rdf:Property ;
    rdfs:label 'Self Certification Type' ;
    rdfs:comment 'The type of driving the CDL holder has self-certified to perform. Non-excepted interstate is the most common for waste management drivers operating across state lines and subject to full FMCSA regulations.' ;
    rdfs:domain ind:CdlLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seriousViolationsCount rdf:type rdf:Property ;
    rdfs:label 'Serious Violations Count' ;
    rdfs:comment 'The number of serious traffic violations (DUI, reckless driving, leaving the scene of an accident, etc.) recorded on the driver\'s MVR within the past 3 years. Two or more serious violations may result in disqualification.' ;
    rdfs:domain ind:CdlLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalViolationsCount rdf:type rdf:Property ;
    rdfs:label 'Total Violations Count' ;
    rdfs:comment 'The total number of traffic violations recorded on the driver\'s MVR within the past 3 years. Used for safety performance evaluation and driver qualification decisions.' ;
    rdfs:domain ind:CdlLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trainingProviderRegistryNumber rdf:type rdf:Property ;
    rdfs:label 'Training Provider Registry Number' ;
    rdfs:comment 'The FMCSA registry number of the training provider that delivered the driver\'s Entry-Level Driver Training. Used to verify training was completed by an approved provider.' ;
    rdfs:domain ind:CdlLicense ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationId rdf:type rdf:Property ;
    rdfs:label 'Certification Id' ;
    rdfs:comment 'Unique identifier for the certification record. Primary key.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Certification .

ind:backgroundCheckRequired rdf:type rdf:Property ;
    rdfs:label 'Background Check Required' ;
    rdfs:comment 'Indicates whether a background check or security clearance is required to obtain this certification (true for TSA hazmat endorsement, TWIC card) or not (false).' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cdlEndorsement rdf:type rdf:Property ;
    rdfs:label 'Cdl Endorsement' ;
    rdfs:comment 'For CDL endorsements, specifies the endorsement code (H=Hazmat, N=Tank, P=Passenger, S=School Bus, T=Double/Triple Trailers, X=Hazmat+Tank). Null for non-endorsement certifications.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationCode rdf:type rdf:Property ;
    rdfs:label 'Certification Code' ;
    rdfs:comment 'Unique alphanumeric code identifying the certification type (e.g., OSHA10, HAZWOPER40, CDL-A).' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationDescription rdf:type rdf:Property ;
    rdfs:label 'Certification Description' ;
    rdfs:comment 'Detailed description of the certification including its purpose, scope, competencies covered, and business value to Waste Management operations.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationName rdf:type rdf:Property ;
    rdfs:label 'Certification Name' ;
    rdfs:comment 'Full official name of the certification (e.g., OSHA 10-Hour General Industry, HAZWOPER 40-Hour Initial Training, Commercial Driver License Class A).' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:continuingEducationHours rdf:type rdf:Property ;
    rdfs:label 'Continuing Education Hours' ;
    rdfs:comment 'Number of continuing education or refresher training hours required per renewal period to maintain this certification. Null if no continuing education is required.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:epaProgram rdf:type rdf:Property ;
    rdfs:label 'Epa Program' ;
    rdfs:comment 'For EPA certifications, specifies the relevant EPA program or regulation (e.g., RCRAInfo, Section 608 Refrigerant Handling, Asbestos Abatement). Null for non-EPA certifications.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentAuthorization rdf:type rdf:Property ;
    rdfs:label 'Equipment Authorization' ;
    rdfs:comment 'Comma-separated list of equipment types or asset classes that this certification authorizes the holder to operate (e.g., Forklift, Front End Loader, Automated Side Loader, MRF Sorting Line). Null if not equipment-specific.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:examRequired rdf:type rdf:Property ;
    rdfs:label 'Exam Required' ;
    rdfs:comment 'Indicates whether an examination is required to obtain this certification (true) or if completion of training is sufficient (false).' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:facilityTypeAuthorization rdf:type rdf:Property ;
    rdfs:label 'Facility Type Authorization' ;
    rdfs:comment 'Comma-separated list of facility types this certification authorizes work at (e.g., Landfill, MRF, Transfer Station, TSDF, WTE Facility). Null if not facility-specific.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatCategory rdf:type rdf:Property ;
    rdfs:label 'Hazmat Category' ;
    rdfs:comment 'For hazardous materials certifications, specifies the category or class of hazmat covered (e.g., RCRA Hazardous Waste, DOT Hazmat Transportation, EPA Universal Waste). Null for non-hazmat certifications.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingBodyType rdf:type rdf:Property ;
    rdfs:label 'Issuing Body Type' ;
    rdfs:comment 'Classification of the issuing authority level (federal agency, state agency, local authority, industry association, or internal company certification).' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobFamily rdf:type rdf:Property ;
    rdfs:label 'Job Family' ;
    rdfs:comment 'Primary job family or role category for which this certification is relevant (e.g., Driver, Technician, MRF Sorter, Facility Operator, Environmental Engineer, Safety Officer).' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalExamRequired rdf:type rdf:Property ;
    rdfs:label 'Medical Exam Required' ;
    rdfs:comment 'Indicates whether a medical examination is required to obtain or maintain this certification (true for DOT medical cards, respirator fit testing) or not (false).' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minimumPassingScore rdf:type rdf:Property ;
    rdfs:label 'Minimum Passing Score' ;
    rdfs:comment 'Minimum score or percentage required to pass the certification exam. Null if no exam is required or no minimum score is specified.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onlineTrainingAvailable rdf:type rdf:Property ;
    rdfs:label 'Online Training Available' ;
    rdfs:comment 'Indicates whether this certification can be obtained through online or remote training (true) or requires in-person attendance (false).' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:oshaStandard rdf:type rdf:Property ;
    rdfs:label 'Osha Standard' ;
    rdfs:comment 'For OSHA certifications, specifies the relevant OSHA standard or regulation (e.g., 29 CFR 1910.120 for HAZWOPER, 29 CFR 1910.146 for Confined Space). Null for non-OSHA certifications.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prerequisiteCertifications rdf:type rdf:Property ;
    rdfs:label 'Prerequisite Certifications' ;
    rdfs:comment 'Comma-separated list of certification codes that must be held before this certification can be obtained. Null if no prerequisites exist.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryMandate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Mandate' ;
    rdfs:comment 'Identifies the primary regulatory framework that mandates this certification (DOT for commercial driving, OSHA for safety, EPA/RCRA for environmental, state for local requirements, or none if voluntary).' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalMethod rdf:type rdf:Property ;
    rdfs:label 'Renewal Method' ;
    rdfs:comment 'Method required to renew the certification: retraining course, examination, continuing education credits, application submission, or automatic renewal.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingHoursRequired rdf:type rdf:Property ;
    rdfs:label 'Training Hours Required' ;
    rdfs:comment 'Number of training hours required to obtain this certification initially (e.g., 10 for OSHA 10-Hour, 40 for HAZWOPER 40-Hour). Null if no formal training hours are specified.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingProvider rdf:type rdf:Property ;
    rdfs:label 'Training Provider' ;
    rdfs:comment 'Name of the typical or preferred training provider or vendor for this certification (e.g., internal training department, external training company, community college). Null if multiple providers exist.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validityPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Validity Period Months' ;
    rdfs:comment 'Standard duration in months that this certification remains valid from the date of issuance before renewal is required. Null if certification does not expire.' ;
    rdfs:domain ind:Certification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:disciplinaryActionId rdf:type rdf:Property ;
    rdfs:label 'Disciplinary Action Id' ;
    rdfs:comment 'Unique identifier for the disciplinary action record. Primary key for the disciplinary action entity.' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryDisciplinaryEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Disciplinary Employee Id' ;
    rdfs:comment 'Identifier of the employee who is the subject of the disciplinary action. Links to the employee master record in Workday HCM.' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryDisciplinaryApprovingManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Disciplinary Approving Manager Employee Id' ;
    rdfs:comment 'Employee identifier of the higher-level manager or HR representative who approved the disciplinary action. Required for suspensions and terminations.' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:appealResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Appeal Resolution Date' ;
    rdfs:comment 'The date on which the appeal or grievance was resolved. Null if appeal is still pending or no appeal was filed.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionPlan rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Plan' ;
    rdfs:comment 'Description of the corrective actions or performance improvement plan required of the employee to avoid further discipline. May include training, counseling, or behavioral expectations.' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disciplinaryActionStatus rdf:type rdf:Property ;
    rdfs:label 'Disciplinary Action Status' ;
    rdfs:comment 'Current lifecycle status of the disciplinary action record. Active actions count toward progressive discipline; expired or overturned actions do not.' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibleForRehireFlag rdf:type rdf:Property ;
    rdfs:label 'Eligible For Rehire Flag' ;
    rdfs:comment 'Indicates whether the terminated employee is eligible for future rehire. False for terminations involving serious violations (substance abuse, safety, theft). Checked during applicant screening.' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:employeeAcknowledgmentFlag rdf:type rdf:Property ;
    rdfs:label 'Employee Acknowledgment Flag' ;
    rdfs:comment 'Indicates whether the employee has acknowledged receipt and review of the disciplinary action documentation. Required for progressive discipline documentation.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:employeeStatement rdf:type rdf:Property ;
    rdfs:label 'Employee Statement' ;
    rdfs:comment 'Written statement or comments provided by the employee regarding the incident or disciplinary action. Captured for due process and appeal documentation.' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Date' ;
    rdfs:comment 'Scheduled date for follow-up review of employee performance or behavior following the disciplinary action. Used to track corrective action plan compliance.' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:jobClassification rdf:type rdf:Property ;
    rdfs:label 'Job Classification' ;
    rdfs:comment 'The employees job classification or title at the time of the incident (e.g., CDL Driver, MRF Sorter, Equipment Operator, Environmental Engineer). Relevant for role-specific violation patterns.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paidSuspensionFlag rdf:type rdf:Property ;
    rdfs:label 'Paid Suspension Flag' ;
    rdfs:comment 'Indicates whether the suspension is paid or unpaid. True for paid suspension (typically during investigation), false for unpaid disciplinary suspension.' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:suspensionDays rdf:type rdf:Property ;
    rdfs:label 'Suspension Days' ;
    rdfs:comment 'Total number of calendar days of suspension. Null for non-suspension actions. Used for progressive discipline tracking and payroll deduction calculation.' ;
    rdfs:domain ind:DisciplinaryAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:violationType rdf:type rdf:Property ;
    rdfs:label 'Violation Type' ;
    rdfs:comment 'Specific type of violation within the category (e.g., HOS violation, PPE non-compliance, unauthorized absence, insubordination, failed drug test). Provides granular detail for root cause analysis.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dotDrugTestId rdf:type rdf:Property ;
    rdfs:label 'Dot Drug Test Id' ;
    rdfs:comment 'Unique identifier for the DOT-mandated drug and alcohol test event. Primary key for the dot_drug_test product.' ;
    rdfs:domain ind:DotDrugTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cdlLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Cdl License Number' ;
    rdfs:comment 'The CDL license number of the employee at the time of the test. Required for all DOT-regulated drivers.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionSiteName rdf:type rdf:Property ;
    rdfs:label 'Collection Site Name' ;
    rdfs:comment 'Name of the facility or clinic where the specimen was collected.' ;
    rdfs:domain ind:DotDrugTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:concentrationLevel rdf:type rdf:Property ;
    rdfs:label 'Concentration Level' ;
    rdfs:comment 'Measured concentration of detected substances in the specimen, typically expressed in ng/mL for drugs or BAC percentage for alcohol.' ;
    rdfs:domain ind:DotDrugTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpTestingPlanFlag rdf:type rdf:Property ;
    rdfs:label 'Follow Up Testing Plan Flag' ;
    rdfs:comment 'Indicates whether the employee is subject to a follow-up testing plan as prescribed by the SAP. True if follow-up plan is active; False otherwise.' ;
    rdfs:domain ind:DotDrugTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mroContactPhone rdf:type rdf:Property ;
    rdfs:label 'Mro Contact Phone' ;
    rdfs:comment 'Phone number of the MRO for follow-up or verification inquiries.' ;
    rdfs:domain ind:DotDrugTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mroReviewDate rdf:type rdf:Property ;
    rdfs:label 'Mro Review Date' ;
    rdfs:comment 'Date on which the MRO completed the review and verification of the test result.' ;
    rdfs:domain ind:DotDrugTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mroVerificationStatus rdf:type rdf:Property ;
    rdfs:label 'Mro Verification Status' ;
    rdfs:comment 'Status of the MRO review process. Verified positive confirms a positive result after medical review; verified negative confirms no prohibited substances; verified refusal confirms employee refusal; pending indicates review in progress; cancelled by MRO indicates the MRO invalidated the test.' ;
    rdfs:domain ind:DotDrugTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:randomPoolSelectionDate rdf:type rdf:Property ;
    rdfs:label 'Random Pool Selection Date' ;
    rdfs:comment 'Date on which the employee was selected from the random testing pool, if the test type is random. Null for non-random tests.' ;
    rdfs:domain ind:DotDrugTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:safetySensitivePositionFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Sensitive Position Flag' ;
    rdfs:comment 'Indicates whether the employee holds a DOT-defined safety-sensitive position at the time of the test. True if safety-sensitive; False otherwise.' ;
    rdfs:domain ind:DotDrugTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sapEvaluationStatus rdf:type rdf:Property ;
    rdfs:label 'Sap Evaluation Status' ;
    rdfs:comment 'Status of the SAP evaluation and treatment process. Not required if no violation occurred; pending if referral made but evaluation not started; in progress if employee is undergoing treatment; completed if SAP has cleared the employee for return-to-duty; not completed if employee has not fulfilled SAP requirements.' ;
    rdfs:domain ind:DotDrugTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Sap Reference Code' ;
    rdfs:comment 'Reference identifier linking this drug test record to the corresponding HR event or personnel action in SAP S/4HANA for payroll and labor cost allocation.' ;
    rdfs:domain ind:DotDrugTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapReferralDate rdf:type rdf:Property ;
    rdfs:label 'Sap Referral Date' ;
    rdfs:comment 'Date on which the employee was referred to a Substance Abuse Professional following a violation. Null if no referral was made.' ;
    rdfs:domain ind:DotDrugTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sapReferralRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Sap Referral Required Flag' ;
    rdfs:comment 'Indicates whether the employee must be referred to a Substance Abuse Professional (SAP) as a result of the test outcome. True if SAP referral is required; False otherwise.' ;
    rdfs:domain ind:DotDrugTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specimenCode rdf:type rdf:Property ;
    rdfs:label 'Specimen Code' ;
    rdfs:comment 'Unique identifier assigned to the specimen by the collection site or laboratory to maintain chain of custody and traceability.' ;
    rdfs:domain ind:DotDrugTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specimenType rdf:type rdf:Property ;
    rdfs:label 'Specimen Type' ;
    rdfs:comment 'Type of biological specimen collected for the test. Urine is standard for drug tests; breath is standard for alcohol tests; blood, saliva, and hair may be used in specific circumstances.' ;
    rdfs:domain ind:DotDrugTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:splitSpecimenRequestedFlag rdf:type rdf:Property ;
    rdfs:label 'Split Specimen Requested Flag' ;
    rdfs:comment 'Indicates whether the employee requested analysis of the split specimen (Bottle B) after a positive result on the primary specimen (Bottle A). True if requested; False if not requested.' ;
    rdfs:domain ind:DotDrugTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:splitSpecimenResult rdf:type rdf:Property ;
    rdfs:label 'Split Specimen Result' ;
    rdfs:comment 'Result of the split specimen analysis if requested. Confirmed means the split specimen also tested positive; not confirmed means the split specimen did not confirm the original positive; not tested means no split specimen test was performed; unavailable means the split specimen was not available for testing.' ;
    rdfs:domain ind:DotDrugTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substancesDetected rdf:type rdf:Property ;
    rdfs:label 'Substances Detected' ;
    rdfs:comment 'List of specific controlled substances or alcohol detected in the specimen if the test result was positive. May include marijuana, cocaine, opiates, amphetamines, PCP, or alcohol.' ;
    rdfs:domain ind:DotDrugTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testReasonCode rdf:type rdf:Property ;
    rdfs:label 'Test Reason Code' ;
    rdfs:comment 'Internal code representing the specific reason or trigger for the test (e.g., annual random pool selection, post-accident protocol, supervisor observation).' ;
    rdfs:domain ind:DotDrugTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationFlag rdf:type rdf:Property ;
    rdfs:label 'Violation Flag' ;
    rdfs:comment 'Indicates whether the test result constitutes a DOT drug and alcohol program violation (positive result, refusal, or adulteration). True if violation occurred; False otherwise.' ;
    rdfs:domain ind:DotDrugTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workdayReferenceCode rdf:type rdf:Property ;
    rdfs:label 'Workday Reference Code' ;
    rdfs:comment 'Reference identifier linking this drug test record to the corresponding event or case in Workday HCM for HR tracking and compliance reporting.' ;
    rdfs:domain ind:DotDrugTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dateOfBirth rdf:type rdf:Property ;
    rdfs:label 'Date Of Birth' ;
    rdfs:comment 'Date of birth of the employee. Used for age verification, benefits eligibility, retirement planning, and compliance with age-related labor regulations.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dotMedicalCardExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Dot Medical Card Expiration Date' ;
    rdfs:comment 'Expiration date of the DOT medical examiner\'s certificate. Required for all CDL drivers. Drivers cannot operate commercial vehicles without valid medical certification. Null for non-CDL employees.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eeoClassification rdf:type rdf:Property ;
    rdfs:label 'Eeo Classification' ;
    rdfs:comment 'EEO-1 job category classification for federal reporting. Used for diversity analytics and compliance with EEOC reporting requirements. Examples include Officials and Managers, Professionals, Technicians, Service Workers, Laborers.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employmentStatus rdf:type rdf:Property ;
    rdfs:label 'Employment Status' ;
    rdfs:comment 'Current employment status of the employee. Determines access rights, payroll processing, benefits eligibility, and workforce planning calculations.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employmentType rdf:type rdf:Property ;
    rdfs:label 'Employment Type' ;
    rdfs:comment 'Classification of employment arrangement. Determines benefits eligibility, labor cost allocation, scheduling rules, and compliance with labor regulations.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flsaStatus rdf:type rdf:Property ;
    rdfs:label 'Flsa Status' ;
    rdfs:comment 'Classification of employee as exempt or non-exempt under FLSA. Determines overtime eligibility, minimum wage requirements, and timekeeping obligations.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazwoperCertificationDate rdf:type rdf:Property ;
    rdfs:label 'Hazwoper Certification Date' ;
    rdfs:comment 'Date the employee completed HAZWOPER certification training. Used for tracking recertification requirements and compliance audits. Null if not HAZWOPER certified.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:hazwoperCertified rdf:type rdf:Property ;
    rdfs:label 'Hazwoper Certified' ;
    rdfs:comment 'Indicates whether the employee holds valid HAZWOPER certification for handling hazardous waste. Required for employees working at TSDF facilities or handling hazmat materials.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobCode rdf:type rdf:Property ;
    rdfs:label 'Job Code' ;
    rdfs:comment 'Standardized job classification code used for workforce planning, compensation analysis, and labor cost allocation. Maps to job families and career progression frameworks.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mobileNumber rdf:type rdf:Property ;
    rdfs:label 'Mobile Number' ;
    rdfs:comment 'Mobile phone number for the employee. Critical for field workforce (drivers, technicians, operators) for real-time dispatch, route communication, and emergency contact.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:osha10Certified rdf:type rdf:Property ;
    rdfs:label 'Osha 10 Certified' ;
    rdfs:comment 'Indicates whether the employee has completed OSHA 10-hour safety training. Common baseline safety certification for operational employees.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:osha30Certified rdf:type rdf:Property ;
    rdfs:label 'Osha 30 Certified' ;
    rdfs:comment 'Indicates whether the employee has completed OSHA 30-hour safety training. Typically required for supervisors, managers, and safety personnel.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:payGrade rdf:type rdf:Property ;
    rdfs:label 'Pay Grade' ;
    rdfs:comment 'Compensation grade or band assigned to the employee. Used for salary administration, compensation planning, and internal equity analysis. Confidential business data.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredName rdf:type rdf:Property ;
    rdfs:label 'Preferred Name' ;
    rdfs:comment 'Preferred or commonly used name for the employee in day-to-day business operations, communications, and system displays. May differ from legal name.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapPersonnelNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Personnel Number' ;
    rdfs:comment 'Employee personnel number in SAP S/4HANA system. Used for labor cost allocation, time management, and payroll integration across FI/CO modules.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seniorityDate rdf:type rdf:Property ;
    rdfs:label 'Seniority Date' ;
    rdfs:comment 'Date used for calculating seniority for union contracts, layoff protection, vacation accrual, and other seniority-based benefits. May differ from hire date due to breaks in service or transfers.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:socialSecurityNumber rdf:type rdf:Property ;
    rdfs:label 'Social Security Number' ;
    rdfs:comment 'U.S. Social Security Number for the employee. Used for tax reporting, payroll processing, benefits administration, and government compliance. Highly sensitive and subject to strict access controls.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unionMember rdf:type rdf:Property ;
    rdfs:label 'Union Member' ;
    rdfs:comment 'Indicates whether the employee is a member of a labor union. Affects labor relations, collective bargaining agreement applicability, dues deduction, and grievance procedures.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workLocation rdf:type rdf:Property ;
    rdfs:label 'Work Location' ;
    rdfs:comment 'Primary work location or facility where the employee is based. May be a landfill, MRF, transfer station, fleet maintenance facility, or administrative office.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workdayEmployeeCode rdf:type rdf:Property ;
    rdfs:label 'Workday Employee Code' ;
    rdfs:comment 'External employee identifier from Workday HCM system. Used for integration and cross-system reconciliation with the system of record for HR, payroll, and talent management.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Employee Assignment Id' ;
    rdfs:comment 'Unique identifier for the employee assignment record. Primary key.' ;
    rdfs:domain ind:EmployeeAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Employee Id' ;
    rdfs:comment 'Unique identifier for the employee being assigned. Links to the employee master record in Workday HCM.' ;
    rdfs:domain ind:EmployeeAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:fteEquivalent rdf:type rdf:Property ;
    rdfs:label 'Fte Equivalent' ;
    rdfs:comment 'The Full-Time Equivalent value for this assignment, typically 1.00 for full-time, 0.50 for half-time, etc. Used for workforce planning and headcount reporting.' ;
    rdfs:domain ind:EmployeeAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hazmatEndorsementRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Endorsement Required Flag' ;
    rdfs:comment 'Boolean indicator of whether a HAZMAT endorsement on the CDL is required for this assignment. True for drivers transporting hazardous waste or materials requiring placarding.' ;
    rdfs:domain ind:EmployeeAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laborAllocationPercentage rdf:type rdf:Property ;
    rdfs:label 'Labor Allocation Percentage' ;
    rdfs:comment 'The percentage of the employee\'s time allocated to this assignment, expressed as a decimal (e.g., 100.00 for full-time, 50.00 for half-time). Used for split assignments and labor cost allocation to multiple cost centers.' ;
    rdfs:domain ind:EmployeeAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onCallFlag rdf:type rdf:Property ;
    rdfs:label 'On Call Flag' ;
    rdfs:comment 'Boolean indicator of whether the employee is designated as on-call for this assignment. True indicates the employee must be available for emergency response outside regular shift hours.' ;
    rdfs:domain ind:EmployeeAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:oshaTrainingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Osha Training Required Flag' ;
    rdfs:comment 'Boolean indicator of whether specific OSHA safety training is required for this assignment. True for positions requiring OSHA 10-hour, 30-hour, or specialized training such as HAZWOPER (Hazardous Waste Operations and Emergency Response).' ;
    rdfs:domain ind:EmployeeAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ppeAssignmentCode rdf:type rdf:Property ;
    rdfs:label 'Ppe Assignment Code' ;
    rdfs:comment 'Code identifying the standard Personal Protective Equipment package assigned to this position. Examples include codes for basic PPE (hard hat, safety vest, gloves), respiratory protection, fall protection, or specialized hazmat suits.' ;
    rdfs:domain ind:EmployeeAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rotationType rdf:type rdf:Property ;
    rdfs:label 'Rotation Type' ;
    rdfs:comment 'Indicates the frequency at which the employee\'s shift pattern rotates. None for fixed schedules, weekly/biweekly/monthly for standard rotations, custom for non-standard rotation patterns. Common in 24/7 landfill and WTE operations.' ;
    rdfs:domain ind:EmployeeAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unionCode rdf:type rdf:Property ;
    rdfs:label 'Union Code' ;
    rdfs:comment 'Code identifying the labor union to which the employee belongs for this assignment. Null for non-union positions. Used for collective bargaining agreement compliance and labor relations reporting.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workAreaCode rdf:type rdf:Property ;
    rdfs:label 'Work Area Code' ;
    rdfs:comment 'Code identifying the specific work area or zone within a facility where the employee is assigned. Examples include landfill cell designation, MRF sorting line, maintenance bay, or administrative wing.' ;
    rdfs:domain ind:EmployeeAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeCertificationId rdf:type rdf:Property ;
    rdfs:label 'Employee Certification Id' ;
    rdfs:comment 'Unique identifier for the employee certification record. Primary key.' ;
    rdfs:domain ind:EmployeeCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceTrainingRequirementId rdf:type rdf:Property ;
    rdfs:label 'Compliance Training Requirement Id' ;
    rdfs:comment 'Foreign key linking to compliance.training_requirement. Business justification: Employee certifications fulfill compliance training requirements. Linking enables automated compliance verification, audit support demonstrating regulatory training completion, and alerts for expiring' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TrainingRequirement .

ind:certificationLevel rdf:type rdf:Property ;
    rdfs:label 'Certification Level' ;
    rdfs:comment 'Level or grade of the certification (e.g., Class A CDL, OSHA 10-Hour vs 30-Hour, HAZWOPER 24-Hour vs 40-Hour, Forklift Operator Level 1). Indicates scope of authorization.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentAttachmentPath rdf:type rdf:Property ;
    rdfs:label 'Document Attachment Path' ;
    rdfs:comment 'File path or URI to the scanned copy of the physical certification document, certificate, or license. Used for audit documentation and regulatory inspections.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:examScore rdf:type rdf:Property ;
    rdfs:label 'Exam Score' ;
    rdfs:comment 'Score or percentage achieved on the certification examination, if applicable. Used to document competency and meet regulatory requirements.' ;
    rdfs:domain ind:EmployeeCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:jobRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Job Requirement Flag' ;
    rdfs:comment 'Indicates whether this certification is a mandatory requirement for the employees current job role (True) or optional/supplemental (False).' ;
    rdfs:domain ind:EmployeeCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextRenewalDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Renewal Due Date' ;
    rdfs:comment 'Date by which the certification must be renewed to maintain continuous compliance. Used for proactive scheduling of refresher training.' ;
    rdfs:domain ind:EmployeeCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:passingScoreRequired rdf:type rdf:Property ;
    rdfs:label 'Passing Score Required' ;
    rdfs:comment 'Minimum score or percentage required to pass the certification examination.' ;
    rdfs:domain ind:EmployeeCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grievanceId rdf:type rdf:Property ;
    rdfs:label 'Grievance Id' ;
    rdfs:comment 'Unique identifier for the labor grievance record. Primary key.' ;
    rdfs:domain ind:Grievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:grievanceEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Grievance Employee Id' ;
    rdfs:comment 'Identifier of the grievant employee who filed the grievance.' ;
    rdfs:domain ind:Grievance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:grievanceModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Grievance Modified By User Employee Id' ;
    rdfs:comment 'User identifier of the person who last modified the grievance record.' ;
    rdfs:domain ind:Grievance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:grievanceSupervisorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Grievance Supervisor Employee Id' ;
    rdfs:comment 'Employee identifier of the supervisor or manager involved in or responding to the grievance.' ;
    rdfs:domain ind:Grievance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:grievanceUnionStewardEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Grievance Union Steward Employee Id' ;
    rdfs:comment 'Employee identifier of the union steward representing the grievant.' ;
    rdfs:domain ind:Grievance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:relatedGrievanceId rdf:type rdf:Property ;
    rdfs:label 'Related Grievance Id' ;
    rdfs:comment 'Identifier of another grievance that is related to or consolidated with this grievance.' ;
    rdfs:domain ind:Grievance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Grievance .

ind:arbitrationDate rdf:type rdf:Property ;
    rdfs:label 'Arbitration Date' ;
    rdfs:comment 'Date the arbitration hearing was conducted.' ;
    rdfs:domain ind:Grievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:arbitrationDecision rdf:type rdf:Property ;
    rdfs:label 'Arbitration Decision' ;
    rdfs:comment 'Written decision issued by the arbitrator, including findings and remedies.' ;
    rdfs:domain ind:Grievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arbitrationFlag rdf:type rdf:Property ;
    rdfs:label 'Arbitration Flag' ;
    rdfs:comment 'Indicates whether the grievance proceeded to binding arbitration.' ;
    rdfs:domain ind:Grievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:arbitratorName rdf:type rdf:Property ;
    rdfs:label 'Arbitrator Name' ;
    rdfs:comment 'Name of the neutral arbitrator assigned to hear the grievance if it proceeded to arbitration.' ;
    rdfs:domain ind:Grievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backPayAmount rdf:type rdf:Property ;
    rdfs:label 'Back Pay Amount' ;
    rdfs:comment 'Monetary amount of back pay awarded to the grievant as part of the grievance resolution.' ;
    rdfs:domain ind:Grievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cbaArticleCited rdf:type rdf:Property ;
    rdfs:label 'Cba Article Cited' ;
    rdfs:comment 'Specific article or section of the collective bargaining agreement cited as the basis for the grievance.' ;
    rdfs:domain ind:Grievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialFlag rdf:type rdf:Property ;
    rdfs:label 'Confidential Flag' ;
    rdfs:comment 'Indicates whether the grievance contains confidential or sensitive information requiring restricted access.' ;
    rdfs:domain ind:Grievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:filingDate rdf:type rdf:Property ;
    rdfs:label 'Filing Date' ;
    rdfs:comment 'Date the grievance was formally filed by the employee or union representative.' ;
    rdfs:domain ind:Grievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:grievanceNumber rdf:type rdf:Property ;
    rdfs:label 'Grievance Number' ;
    rdfs:comment 'Externally-known unique grievance tracking number assigned by labor relations or union steward.' ;
    rdfs:domain ind:Grievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grievanceStatus rdf:type rdf:Property ;
    rdfs:label 'Grievance Status' ;
    rdfs:comment 'Current lifecycle status of the grievance in the resolution process.' ;
    rdfs:domain ind:Grievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grievanceType rdf:type rdf:Property ;
    rdfs:label 'Grievance Type' ;
    rdfs:comment 'Category of the grievance indicating the nature of the complaint.' ;
    rdfs:domain ind:Grievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managementResponse rdf:type rdf:Property ;
    rdfs:label 'Management Response' ;
    rdfs:comment 'Detailed written response from management addressing the grievance claims and proposed resolution.' ;
    rdfs:domain ind:Grievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managementResponseDate rdf:type rdf:Property ;
    rdfs:label 'Management Response Date' ;
    rdfs:comment 'Date management formally responded to the grievance.' ;
    rdfs:domain ind:Grievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remedyDescription rdf:type rdf:Property ;
    rdfs:label 'Remedy Description' ;
    rdfs:comment 'Description of any remedies awarded to the grievant, such as back pay, reinstatement, or policy changes.' ;
    rdfs:domain ind:Grievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionDescription rdf:type rdf:Property ;
    rdfs:label 'Resolution Description' ;
    rdfs:comment 'Detailed narrative of the final resolution, including any remedies, corrective actions, or settlements agreed upon.' ;
    rdfs:domain ind:Grievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:step rdf:type rdf:Property ;
    rdfs:label 'Step' ;
    rdfs:comment 'Current step in the multi-step grievance resolution procedure as defined in the CBA.' ;
    rdfs:domain ind:Grievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportsToPositionId rdf:type rdf:Property ;
    rdfs:label 'Reports To Position Id' ;
    rdfs:comment 'Reference to the position that this position reports to in the organizational hierarchy. Null for top-level executive positions.' ;
    rdfs:domain ind:JobPosition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JobPosition .

ind:backgroundCheckLevel rdf:type rdf:Property ;
    rdfs:label 'Background Check Level' ;
    rdfs:comment 'Level of pre-employment background screening required for the position. Basic includes criminal history, standard adds employment verification, enhanced adds credit and driving record checks.' ;
    rdfs:domain ind:JobPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:directReportsCount rdf:type rdf:Property ;
    rdfs:label 'Direct Reports Count' ;
    rdfs:comment 'Number of employees who directly report to this position. Zero for individual contributor roles.' ;
    rdfs:domain ind:JobPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dotRegulatedFlag rdf:type rdf:Property ;
    rdfs:label 'Dot Regulated Flag' ;
    rdfs:comment 'Indicates whether the position is subject to DOT safety regulations including drug and alcohol testing, medical certification, and hours of service requirements.' ;
    rdfs:domain ind:JobPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:epaCertificationRequired rdf:type rdf:Property ;
    rdfs:label 'Epa Certification Required' ;
    rdfs:comment 'Comma-separated list of required EPA certifications (e.g., EPA Section 608 Refrigerant Handling, EPA Lead-Safe Certified, EPA Asbestos Abatement). Empty if no EPA certifications required.' ;
    rdfs:domain ind:JobPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flsaClassification rdf:type rdf:Property ;
    rdfs:label 'Flsa Classification' ;
    rdfs:comment 'Classification under the Fair Labor Standards Act determining overtime eligibility. Exempt positions are salaried and not eligible for overtime; non-exempt positions are hourly and eligible for overtime pay.' ;
    rdfs:domain ind:JobPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazwoperCertificationRequired rdf:type rdf:Property ;
    rdfs:label 'Hazwoper Certification Required' ;
    rdfs:comment 'Level of HAZWOPER training required under OSHA 29 CFR 1910.120 for positions handling hazardous waste. 8-hour for refresher, 24-hour for occasional site workers, 40-hour for regular hazardous waste operations.' ;
    rdfs:domain ind:JobPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headcountAuthorization rdf:type rdf:Property ;
    rdfs:label 'Headcount Authorization' ;
    rdfs:comment 'Number of authorized full-time equivalent (FTE) employees for this position. Used for workforce planning and budget management.' ;
    rdfs:domain ind:JobPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:jobLevel rdf:type rdf:Property ;
    rdfs:label 'Job Level' ;
    rdfs:comment 'Hierarchical level of the position within the organization structure, used for career progression and compensation planning. [ENUM-REF-CANDIDATE: entry|intermediate|senior|lead|manager|director|executive — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:JobPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumEducationLevel rdf:type rdf:Property ;
    rdfs:label 'Minimum Education Level' ;
    rdfs:comment 'Minimum educational qualification required for the position. Used for recruiting and candidate screening.' ;
    rdfs:domain ind:JobPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumExperienceYears rdf:type rdf:Property ;
    rdfs:label 'Minimum Experience Years' ;
    rdfs:comment 'Minimum number of years of relevant work experience required for the position. Zero for entry-level positions.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:oshaCertificationRequired rdf:type rdf:Property ;
    rdfs:label 'Osha Certification Required' ;
    rdfs:comment 'Comma-separated list of required OSHA certifications (e.g., OSHA 10-Hour, OSHA 30-Hour, Confined Space Entry, Lockout/Tagout, Fall Protection). Empty if no OSHA certifications required.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:physicalRequirements rdf:type rdf:Property ;
    rdfs:label 'Physical Requirements' ;
    rdfs:comment 'Description of physical demands of the position including lifting requirements, standing/walking duration, exposure to weather, and other physical capabilities needed (e.g., ability to lift 50 lbs, stand for 8+ hours, work in extreme temperatures).' ;
    rdfs:domain ind:JobPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionCode rdf:type rdf:Property ;
    rdfs:label 'Position Code' ;
    rdfs:comment 'Unique business identifier for the position as defined in Workday HCM. Used for external reporting and integration with SAP.' ;
    rdfs:domain ind:JobPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionDescription rdf:type rdf:Property ;
    rdfs:label 'Position Description' ;
    rdfs:comment 'Detailed description of the position including key responsibilities, essential functions, and performance expectations. Used for job postings and performance management.' ;
    rdfs:domain ind:JobPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionStatus rdf:type rdf:Property ;
    rdfs:label 'Position Status' ;
    rdfs:comment 'Current lifecycle status of the position. Active positions are authorized for hiring; frozen positions are temporarily on hold; closed positions are eliminated; pending approval positions await budget authorization.' ;
    rdfs:domain ind:JobPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionTitle rdf:type rdf:Property ;
    rdfs:label 'Position Title' ;
    rdfs:comment 'Official job title for the position (e.g., Commercial Driver License (CDL) Driver - Automated Side Loader (ASL), Materials Recovery Facility (MRF) Sorter, Landfill Equipment Operator, Environmental Compliance Engineer).' ;
    rdfs:domain ind:JobPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rcraTrainingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Rcra Training Required Flag' ;
    rdfs:comment 'Indicates whether the position requires RCRA hazardous waste management training for Treatment, Storage, and Disposal Facility (TSDF) operations.' ;
    rdfs:domain ind:JobPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:safetySensitiveFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Sensitive Flag' ;
    rdfs:comment 'Indicates whether the position is classified as safety-sensitive requiring enhanced drug and alcohol testing under DOT or company policy. Includes all CDL drivers, equipment operators, and hazardous waste handlers.' ;
    rdfs:domain ind:JobPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supervisoryFlag rdf:type rdf:Property ;
    rdfs:label 'Supervisory Flag' ;
    rdfs:comment 'Indicates whether the position has direct supervisory responsibility for other employees including hiring, performance management, and disciplinary authority.' ;
    rdfs:domain ind:JobPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:travelRequirementPercentage rdf:type rdf:Property ;
    rdfs:label 'Travel Requirement Percentage' ;
    rdfs:comment 'Percentage of time the position requires travel away from primary work location. 0 for no travel, 100 for full-time travel positions.' ;
    rdfs:domain ind:JobPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unionPositionFlag rdf:type rdf:Property ;
    rdfs:label 'Union Position Flag' ;
    rdfs:comment 'Indicates whether the position is covered by a collective bargaining agreement with a labor union.' ;
    rdfs:domain ind:JobPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workEnvironment rdf:type rdf:Property ;
    rdfs:label 'Work Environment' ;
    rdfs:comment 'Primary work environment for the position. Office for administrative roles, field for route drivers and technicians, facility for MRF and landfill operations, mixed for roles with both office and field responsibilities.' ;
    rdfs:domain ind:JobPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobRequisitionId rdf:type rdf:Property ;
    rdfs:label 'Job Requisition Id' ;
    rdfs:comment 'Unique identifier for the job requisition record. Primary key.' ;
    rdfs:domain ind:JobRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryJobHiringManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Job Hiring Manager Employee Id' ;
    rdfs:comment 'Reference to the employee who is the hiring manager responsible for this requisition.' ;
    rdfs:domain ind:JobRequisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryJobApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Job Approved By Employee Id' ;
    rdfs:comment 'Reference to the employee who approved the requisition (typically senior manager or HR director).' ;
    rdfs:domain ind:JobRequisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:approvedHeadcount rdf:type rdf:Property ;
    rdfs:label 'Approved Headcount' ;
    rdfs:comment 'Number of positions approved for hire under this requisition.' ;
    rdfs:domain ind:JobRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:educationLevelRequired rdf:type rdf:Property ;
    rdfs:label 'Education Level Required' ;
    rdfs:comment 'Minimum education level required for the position (high school, associate degree, bachelor degree, master degree, doctorate, or none).' ;
    rdfs:domain ind:JobRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filledHeadcount rdf:type rdf:Property ;
    rdfs:label 'Filled Headcount' ;
    rdfs:comment 'Number of positions that have been filled to date under this requisition.' ;
    rdfs:domain ind:JobRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:jobDescription rdf:type rdf:Property ;
    rdfs:label 'Job Description' ;
    rdfs:comment 'Detailed description of the job responsibilities, duties, and requirements.' ;
    rdfs:domain ind:JobRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingChannel rdf:type rdf:Property ;
    rdfs:label 'Posting Channel' ;
    rdfs:comment 'Channels where the job requisition is posted (e.g., company website, Indeed, LinkedIn, internal job board).' ;
    rdfs:domain ind:JobRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requisitionCloseDate rdf:type rdf:Property ;
    rdfs:label 'Requisition Close Date' ;
    rdfs:comment 'Date when the requisition was closed (filled, cancelled, or otherwise finalized).' ;
    rdfs:domain ind:JobRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requisitionNumber rdf:type rdf:Property ;
    rdfs:label 'Requisition Number' ;
    rdfs:comment 'Business identifier for the job requisition, externally visible and used in recruiting workflows and communications.' ;
    rdfs:domain ind:JobRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requisitionOpenDate rdf:type rdf:Property ;
    rdfs:label 'Requisition Open Date' ;
    rdfs:comment 'Date when the requisition was officially opened and made available for recruiting.' ;
    rdfs:domain ind:JobRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requisitionStatus rdf:type rdf:Property ;
    rdfs:label 'Requisition Status' ;
    rdfs:comment 'Current lifecycle status of the job requisition (draft, open, on-hold, in-review, filled, cancelled, closed). [ENUM-REF-CANDIDATE: draft|open|on_hold|in_review|filled|cancelled|closed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:JobRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requisitionType rdf:type rdf:Property ;
    rdfs:label 'Requisition Type' ;
    rdfs:comment 'Type of requisition indicating the reason for the hire (backfill for departure, new headcount expansion, seasonal demand, temporary project, contractor conversion, internal transfer).' ;
    rdfs:domain ind:JobRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salaryRangeMax rdf:type rdf:Property ;
    rdfs:label 'Salary Range Max' ;
    rdfs:comment 'Maximum salary or hourly rate for the position.' ;
    rdfs:domain ind:JobRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salaryRangeMin rdf:type rdf:Property ;
    rdfs:label 'Salary Range Min' ;
    rdfs:comment 'Minimum salary or hourly rate for the position.' ;
    rdfs:domain ind:JobRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetStartDate rdf:type rdf:Property ;
    rdfs:label 'Target Start Date' ;
    rdfs:comment 'Desired start date for the new hire(s) to begin employment.' ;
    rdfs:domain ind:JobRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:laborCostAllocationId rdf:type rdf:Property ;
    rdfs:label 'Labor Cost Allocation Id' ;
    rdfs:comment 'Unique identifier for the labor cost allocation record.' ;
    rdfs:domain ind:LaborCostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryLaborEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Labor Employee Id' ;
    rdfs:comment 'Identifier of the employee whose labor cost is being allocated.' ;
    rdfs:domain ind:LaborCostAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:activityTypeCode rdf:type rdf:Property ;
    rdfs:label 'Activity Type Code' ;
    rdfs:comment 'SAP CO activity type code representing the type of work performed, such as collection, sorting, landfill operations, or maintenance.' ;
    rdfs:domain ind:LaborCostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationDate rdf:type rdf:Property ;
    rdfs:label 'Allocation Date' ;
    rdfs:comment 'Date when the labor cost allocation was processed and recorded in the financial system.' ;
    rdfs:domain ind:LaborCostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:hazardPayAmount rdf:type rdf:Property ;
    rdfs:label 'Hazard Pay Amount' ;
    rdfs:comment 'Additional pay amount for working in hazardous conditions such as handling hazardous waste or working in confined spaces.' ;
    rdfs:domain ind:LaborCostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hoursWorked rdf:type rdf:Property ;
    rdfs:label 'Hours Worked' ;
    rdfs:comment 'Total hours worked by the employee during the pay period that are being allocated to the cost object.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overtimePayAmount rdf:type rdf:Property ;
    rdfs:label 'Overtime Pay Amount' ;
    rdfs:comment 'Labor cost amount for overtime hours worked.' ;
    rdfs:domain ind:LaborCostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Pay Period End Date' ;
    rdfs:comment 'End date of the pay period for which labor costs are allocated.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:payPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Pay Period Start Date' ;
    rdfs:comment 'Start date of the pay period for which labor costs are allocated.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regularHours rdf:type rdf:Property ;
    rdfs:label 'Regular Hours' ;
    rdfs:comment 'Number of regular hours worked during the pay period, excluding overtime.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regularPayAmount rdf:type rdf:Property ;
    rdfs:label 'Regular Pay Amount' ;
    rdfs:comment 'Labor cost amount for regular hours worked, excluding overtime and premium pay.' ;
    rdfs:domain ind:LaborCostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sapPostingReference rdf:type rdf:Property ;
    rdfs:label 'Sap Posting Reference' ;
    rdfs:comment 'SAP FI/CO document number or posting reference generated when the labor cost allocation is posted to the financial system.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftDifferentialAmount rdf:type rdf:Property ;
    rdfs:label 'Shift Differential Amount' ;
    rdfs:comment 'Additional pay amount for working non-standard shifts such as night, weekend, or holiday shifts.' ;
    rdfs:domain ind:LaborCostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalLaborCost rdf:type rdf:Property ;
    rdfs:label 'Total Labor Cost' ;
    rdfs:comment 'Total labor cost allocated to the cost object, calculated as hours worked multiplied by labor rate.' ;
    rdfs:domain ind:LaborCostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentOrgUnitId rdf:type rdf:Property ;
    rdfs:label 'Parent Org Unit Id' ;
    rdfs:comment 'Reference to the parent organizational unit in the hierarchy, enabling multi-level organizational structure representation from corporate down to facility level.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:budgetAmountAnnual rdf:type rdf:Property ;
    rdfs:label 'Budget Amount Annual' ;
    rdfs:comment 'Total annual operating budget allocated to this organizational unit in USD. Used for financial planning, cost control, and performance management. Includes labor, materials, and overhead costs.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currentHeadcount rdf:type rdf:Property ;
    rdfs:label 'Current Headcount' ;
    rdfs:comment 'Current number of active employees assigned to this organizational unit. Updated based on employee assignments and used for utilization analysis and staffing gap identification.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dotFacilityNumber rdf:type rdf:Property ;
    rdfs:label 'Dot Facility Number' ;
    rdfs:comment 'Department of Transportation facility registration number for organizational units operating commercial motor vehicles. Required for fleet operations and CDL driver management. Null for non-fleet units.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicRegion rdf:type rdf:Property ;
    rdfs:label 'Geographic Region' ;
    rdfs:comment 'Primary geographic region where the organizational unit operates. Used for regional workforce planning, labor market analysis, and geographic performance reporting. [ENUM-REF-CANDIDATE: northeast|southeast|midwest|southwest|west|northwest|central|national — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headcountCapacity rdf:type rdf:Property ;
    rdfs:label 'Headcount Capacity' ;
    rdfs:comment 'Maximum number of employees that can be assigned to this organizational unit based on operational requirements, facility capacity, or budget constraints. Used for workforce planning and resource allocation.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isDeleted rdf:type rdf:Property ;
    rdfs:label 'Is Deleted' ;
    rdfs:comment 'Soft delete indicator. True if this organizational unit record has been logically deleted but retained for historical reference, false for active records. Used for data retention and historical reporting.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operatesHolidays rdf:type rdf:Property ;
    rdfs:label 'Operates Holidays' ;
    rdfs:comment 'Indicates whether this organizational unit operates on recognized company holidays. True for essential operations (e.g., landfills, emergency response), false for units that close on holidays.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operatesWeekends rdf:type rdf:Property ;
    rdfs:label 'Operates Weekends' ;
    rdfs:comment 'Indicates whether this organizational unit operates on Saturdays and Sundays. True for units with weekend operations (e.g., collection routes, 24/7 facilities), false for standard Monday-Friday operations.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orgUnitStatus rdf:type rdf:Property ;
    rdfs:label 'Org Unit Status' ;
    rdfs:comment 'Current operational status of the organizational unit. Active units are fully operational, inactive units are temporarily non-operational, planned units are approved but not yet operational, closed units are permanently shut down, and suspended units are temporarily halted pending review.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyZoneClassification rdf:type rdf:Property ;
    rdfs:label 'Safety Zone Classification' ;
    rdfs:comment 'OSHA-based safety risk classification for the organizational unit. Low risk for administrative offices, moderate risk for transfer stations, high risk for MRF and collection operations, hazardous for landfills and hazardous waste facilities. Determines PPE requirements, training protocols, and safety inspection frequency.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapCostCenterCode rdf:type rdf:Property ;
    rdfs:label 'Sap Cost Center Code' ;
    rdfs:comment 'SAP FI/CO cost center code associated with this organizational unit for labor cost allocation, financial reporting, and budget tracking. Enables integration between workforce management and financial systems.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapProfitCenterCode rdf:type rdf:Property ;
    rdfs:label 'Sap Profit Center Code' ;
    rdfs:comment 'SAP FI/CO profit center code for revenue and profitability reporting at the organizational unit level. Used for P&L analysis and performance management.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unionRepresentation rdf:type rdf:Property ;
    rdfs:label 'Union Representation' ;
    rdfs:comment 'Indicates whether employees in this organizational unit are represented by a labor union. True for unionized units, false for non-union units. Used for labor relations, collective bargaining, and compliance with union agreements.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workdayOrgCode rdf:type rdf:Property ;
    rdfs:label 'Workday Org Code' ;
    rdfs:comment 'Unique identifier for this organizational unit in the Workday HCM system. Used for integration between lakehouse and source HCM system for employee assignments, payroll, and workforce planning.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payrollRecordId rdf:type rdf:Property ;
    rdfs:label 'Payroll Record Id' ;
    rdfs:comment 'Unique identifier for the payroll record. Primary key.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryPayrollEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Payroll Employee Id' ;
    rdfs:comment 'Unique identifier for the employee receiving payroll. Links to employee master data in Workday HCM.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryPayrollApprovedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Payroll Approved By User Employee Id' ;
    rdfs:comment 'User ID of the manager or payroll supervisor who approved this payroll record. 8-character alphanumeric identifier.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:bonusAmount rdf:type rdf:Property ;
    rdfs:label 'Bonus Amount' ;
    rdfs:comment 'One-time or periodic bonus payments including performance bonuses, safety bonuses, and retention bonuses.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commissionAmount rdf:type rdf:Property ;
    rdfs:label 'Commission Amount' ;
    rdfs:comment 'Commission earnings for sales or business development roles.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dentalInsuranceDeduction rdf:type rdf:Property ;
    rdfs:label 'Dental Insurance Deduction' ;
    rdfs:comment 'Employee contribution for dental insurance coverage deducted from gross pay.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disabilityInsuranceDeduction rdf:type rdf:Property ;
    rdfs:label 'Disability Insurance Deduction' ;
    rdfs:comment 'Employee contribution for short-term or long-term disability insurance deducted from gross pay.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:federalIncomeTax rdf:type rdf:Property ;
    rdfs:label 'Federal Income Tax' ;
    rdfs:comment 'Federal income tax withheld from gross pay based on employee W-4 elections.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:garnishmentDeduction rdf:type rdf:Property ;
    rdfs:label 'Garnishment Deduction' ;
    rdfs:comment 'Court-ordered wage garnishments for child support, tax levies, or other legal obligations.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossPay rdf:type rdf:Property ;
    rdfs:label 'Gross Pay' ;
    rdfs:comment 'Total earnings before any deductions, including regular pay, overtime, hazard pay, shift differential, bonuses, and commissions.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hazardPay rdf:type rdf:Property ;
    rdfs:label 'Hazard Pay' ;
    rdfs:comment 'Additional compensation for employees working in hazardous conditions, including HAZWOPER-certified roles and CDL hazmat operations.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lifeInsuranceDeduction rdf:type rdf:Property ;
    rdfs:label 'Life Insurance Deduction' ;
    rdfs:comment 'Employee contribution for life insurance coverage deducted from gross pay.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:medicalInsuranceDeduction rdf:type rdf:Property ;
    rdfs:label 'Medical Insurance Deduction' ;
    rdfs:comment 'Employee contribution for medical insurance coverage deducted from gross pay.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:medicareTax rdf:type rdf:Property ;
    rdfs:label 'Medicare Tax' ;
    rdfs:comment 'Medicare tax withheld at 1.45% of gross wages with no wage base limit.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netPay rdf:type rdf:Property ;
    rdfs:label 'Net Pay' ;
    rdfs:comment 'Take-home pay after all deductions, the amount deposited or paid to the employee.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overtimePay rdf:type rdf:Property ;
    rdfs:label 'Overtime Pay' ;
    rdfs:comment 'Gross earnings from overtime hours, typically calculated at 1.5x the regular rate.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payDate rdf:type rdf:Property ;
    rdfs:label 'Pay Date' ;
    rdfs:comment 'The date on which payment is issued to the employee.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:payrollStatus rdf:type rdf:Property ;
    rdfs:label 'Payroll Status' ;
    rdfs:comment 'Current processing status of the payroll record: draft (not yet processed), processed (calculated), posted (recorded in GL), paid (funds disbursed), voided (cancelled before payment), reversed (corrected after payment).' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regularPay rdf:type rdf:Property ;
    rdfs:label 'Regular Pay' ;
    rdfs:comment 'Gross earnings from regular hours worked at the employee\'s base rate.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retirement401kDeduction rdf:type rdf:Property ;
    rdfs:label 'Retirement 401k Deduction' ;
    rdfs:comment 'Employee pre-tax or Roth contribution to 401(k) retirement plan deducted from gross pay.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retirement401kEmployerMatch rdf:type rdf:Property ;
    rdfs:label 'Retirement 401k Employer Match' ;
    rdfs:comment 'Employer matching contribution to employee 401(k) retirement plan.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shiftDifferential rdf:type rdf:Property ;
    rdfs:label 'Shift Differential' ;
    rdfs:comment 'Additional compensation for employees working non-standard shifts (evening, night, weekend).' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:socialSecurityTax rdf:type rdf:Property ;
    rdfs:label 'Social Security Tax' ;
    rdfs:comment 'Social Security tax withheld at 6.2% of gross wages up to the annual wage base limit.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stateIncomeTax rdf:type rdf:Property ;
    rdfs:label 'State Income Tax' ;
    rdfs:comment 'State income tax withheld from gross pay based on state tax regulations and employee elections.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDeductions rdf:type rdf:Property ;
    rdfs:label 'Total Deductions' ;
    rdfs:comment 'Sum of all deductions including taxes, benefits, union dues, and garnishments.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unionDuesDeduction rdf:type rdf:Property ;
    rdfs:label 'Union Dues Deduction' ;
    rdfs:comment 'Union membership dues deducted from gross pay for employees covered by collective bargaining agreements.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:visionInsuranceDeduction rdf:type rdf:Property ;
    rdfs:label 'Vision Insurance Deduction' ;
    rdfs:comment 'Employee contribution for vision insurance coverage deducted from gross pay.' ;
    rdfs:domain ind:PayrollRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceReviewId rdf:type rdf:Property ;
    rdfs:label 'Performance Review Id' ;
    rdfs:comment 'Unique identifier for the performance review or disciplinary action record.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryPerformanceEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Performance Employee Id' ;
    rdfs:comment 'Identifier of the employee being reviewed or subject to disciplinary action.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryPerformanceHrRepresentativeEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Performance Hr Representative Employee Id' ;
    rdfs:comment 'Identifier of the HR representative who reviewed or approved the performance review or disciplinary action.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:attendanceScore rdf:type rdf:Property ;
    rdfs:label 'Attendance Score' ;
    rdfs:comment 'Score reflecting the employee\'s attendance and punctuality during the review period.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerServiceScore rdf:type rdf:Property ;
    rdfs:label 'Customer Service Score' ;
    rdfs:comment 'Score reflecting the employee\'s customer service performance, including customer feedback and complaint resolution.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:employeeAcknowledgmentDate rdf:type rdf:Property ;
    rdfs:label 'Employee Acknowledgment Date' ;
    rdfs:comment 'Date the employee acknowledged the performance review or disciplinary action.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:employeeComments rdf:type rdf:Property ;
    rdfs:label 'Employee Comments' ;
    rdfs:comment 'Comments or feedback provided by the employee in response to the performance review or disciplinary action.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meritIncreasePercentage rdf:type rdf:Property ;
    rdfs:label 'Merit Increase Percentage' ;
    rdfs:comment 'Recommended percentage increase for merit-based salary adjustment.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:meritIncreaseRecommendedFlag rdf:type rdf:Property ;
    rdfs:label 'Merit Increase Recommended Flag' ;
    rdfs:comment 'Indicates whether a merit-based salary increase is recommended based on the performance review.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nearMissReportsCount rdf:type rdf:Property ;
    rdfs:label 'Near Miss Reports Count' ;
    rdfs:comment 'Number of near-miss safety incidents reported by the employee during the review period, demonstrating proactive safety awareness.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:oshaRecordableIncidentsCount rdf:type rdf:Property ;
    rdfs:label 'Osha Recordable Incidents Count' ;
    rdfs:comment 'Number of OSHA recordable incidents involving the employee during the review period.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overallRating rdf:type rdf:Property ;
    rdfs:label 'Overall Rating' ;
    rdfs:comment 'Overall performance rating assigned during the review: exceeds expectations, meets expectations, needs improvement, unsatisfactory, or not rated.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallRatingScore rdf:type rdf:Property ;
    rdfs:label 'Overall Rating Score' ;
    rdfs:comment 'Numeric score representing the overall performance rating, typically on a scale (e.g., 1.0 to 5.0).' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productivityMetricUnit rdf:type rdf:Property ;
    rdfs:label 'Productivity Metric Unit' ;
    rdfs:comment 'Unit of measure for the productivity metric: stops per hour, tons per day, work orders per day, calls per hour, or other role-specific unit.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productivityMetricValue rdf:type rdf:Property ;
    rdfs:label 'Productivity Metric Value' ;
    rdfs:comment 'Quantitative productivity metric for the employee\'s role: stops per hour for drivers, Tons Per Day (TPD) for Materials Recovery Facility (MRF) sorters, work orders completed for technicians, or other role-specific measures.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:promotionRecommendedFlag rdf:type rdf:Property ;
    rdfs:label 'Promotion Recommended Flag' ;
    rdfs:comment 'Indicates whether a promotion is recommended based on the performance review.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityOfWorkScore rdf:type rdf:Property ;
    rdfs:label 'Quality Of Work Score' ;
    rdfs:comment 'Score reflecting the quality and accuracy of the employee\'s work output.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reviewPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Review Period End Date' ;
    rdfs:comment 'End date of the performance period being evaluated.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Review Period Start Date' ;
    rdfs:comment 'Start date of the performance period being evaluated.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewStatus rdf:type rdf:Property ;
    rdfs:label 'Review Status' ;
    rdfs:comment 'Current status of the performance review or disciplinary action record: draft, submitted, approved, completed, appealed, or archived.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewType rdf:type rdf:Property ;
    rdfs:label 'Review Type' ;
    rdfs:comment 'Type of performance review or action: annual review, mid-year review, probationary evaluation, project-based review, disciplinary action, or termination review.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyPerformanceScore rdf:type rdf:Property ;
    rdfs:label 'Safety Performance Score' ;
    rdfs:comment 'Score reflecting the employee\'s safety performance including Occupational Safety and Health Administration (OSHA) recordable incidents, near-miss reporting, Personal Protective Equipment (PPE) compliance, and adherence to safety protocols.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:teamworkCollaborationScore rdf:type rdf:Property ;
    rdfs:label 'Teamwork Collaboration Score' ;
    rdfs:comment 'Score reflecting the employee\'s ability to work effectively with team members and contribute to a collaborative work environment.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:breakDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Break Duration Minutes' ;
    rdfs:comment 'Total scheduled break time in minutes (lunch, rest breaks) as required by labor regulations and collective bargaining agreements.' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:daysOfWeek rdf:type rdf:Property ;
    rdfs:label 'Days Of Week' ;
    rdfs:comment 'Comma-separated list of days when this shift schedule is active (Mon, Tue, Wed, Thu, Fri, Sat, Sun). Supports 24/7 landfill and WTE operations as well as standard weekday collection schedules.' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationHours rdf:type rdf:Property ;
    rdfs:label 'Duration Hours' ;
    rdfs:comment 'Total scheduled duration of the shift in hours, including any paid breaks. Used for labor cost allocation and Department of Transportation (DOT) hours-of-service compliance.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hazwoperRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Hazwoper Required Flag' ;
    rdfs:comment 'Indicates whether HAZWOPER certification is required for this shift, typically for hazardous waste handling operations and emergency response teams.' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minimumStaffingLevel rdf:type rdf:Property ;
    rdfs:label 'Minimum Staffing Level' ;
    rdfs:comment 'Minimum number of employees required to operate this shift safely and meet service level agreements (SLAs). Critical for 24/7 landfill and WTE operations.' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overtimeEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Overtime Eligible Flag' ;
    rdfs:comment 'Indicates whether employees on this shift are eligible for overtime pay under Fair Labor Standards Act (FLSA) regulations.' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rotationPattern rdf:type rdf:Property ;
    rdfs:label 'Rotation Pattern' ;
    rdfs:comment 'Description of the rotation pattern for rotating shifts (e.g., 2 weeks day / 2 weeks night, 4 on / 3 off). Null for fixed shifts.' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftDifferentialRate rdf:type rdf:Property ;
    rdfs:label 'Shift Differential Rate' ;
    rdfs:comment 'Additional hourly pay rate for non-standard shifts (swing, night, weekend). Used for payroll calculation and labor cost allocation.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shiftName rdf:type rdf:Property ;
    rdfs:label 'Shift Name' ;
    rdfs:comment 'Descriptive name of the shift pattern (Day, Swing, Night, Split, Rotating, On-Call).' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftPriority rdf:type rdf:Property ;
    rdfs:label 'Shift Priority' ;
    rdfs:comment 'Priority ranking for shift assignment when multiple shifts are available (1 = highest priority). Used in automated scheduling and employee preference matching.' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shiftScheduleStatus rdf:type rdf:Property ;
    rdfs:label 'Shift Schedule Status' ;
    rdfs:comment 'Current lifecycle status of the shift schedule: Active (in use), Inactive (temporarily not used), Suspended (on hold), Seasonal (used during specific periods), or Archived (historical record).' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weatherDependentFlag rdf:type rdf:Property ;
    rdfs:label 'Weather Dependent Flag' ;
    rdfs:comment 'Indicates whether this shift schedule is subject to weather-related cancellations or modifications (e.g., landfill cover operations, outdoor collection routes).' ;
    rdfs:domain ind:ShiftSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:timeEntryId rdf:type rdf:Property ;
    rdfs:label 'Time Entry Id' ;
    rdfs:comment 'Unique identifier for the time entry record. Primary key for the time entry data product.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:payPeriodId rdf:type rdf:Property ;
    rdfs:label 'Pay Period Id' ;
    rdfs:comment 'Identifier for the pay period to which this time entry belongs. Used for payroll processing and labor cost allocation.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PayPeriod .

ind:payrollRunId rdf:type rdf:Property ;
    rdfs:label 'Payroll Run Id' ;
    rdfs:comment 'Identifier for the payroll run in which this time entry was processed. Used for payroll audit and reconciliation.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Run .

ind:primaryTimeEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Time Employee Id' ;
    rdfs:comment 'Unique identifier for the employee who recorded this time entry. Links to employee master data in Workday HCM.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:absenceCode rdf:type rdf:Property ;
    rdfs:label 'Absence Code' ;
    rdfs:comment 'Code indicating the reason for absence if the employee did not work. Examples include sick leave, vacation, personal time, FMLA, or unpaid leave.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breakTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Break Time Minutes' ;
    rdfs:comment 'Total break time in minutes taken during the shift. Includes meal breaks and rest periods as required by labor regulations and DOT HOS rules.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cdlHosCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Cdl Hos Compliant Flag' ;
    rdfs:comment 'Boolean flag indicating whether this time entry complies with DOT Hours of Service regulations for CDL drivers. Critical for regulatory compliance and driver safety.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clockInTimestamp rdf:type rdf:Property ;
    rdfs:label 'Clock In Timestamp' ;
    rdfs:comment 'The exact date and time when the employee clocked in or started their shift. Critical for DOT Hours of Service (HOS) compliance for CDL drivers.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:clockOutTimestamp rdf:type rdf:Property ;
    rdfs:label 'Clock Out Timestamp' ;
    rdfs:comment 'The exact date and time when the employee clocked out or ended their shift. Used to calculate total hours worked and ensure DOT HOS compliance.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:hosViolationCode rdf:type rdf:Property ;
    rdfs:label 'Hos Violation Code' ;
    rdfs:comment 'Code indicating the specific DOT HOS violation if the time entry is non-compliant. Used for corrective action and regulatory reporting.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laborCostAmount rdf:type rdf:Property ;
    rdfs:label 'Labor Cost Amount' ;
    rdfs:comment 'Total labor cost for this time entry including base pay, overtime premium, shift differential, and benefits burden. Used for cost allocation to routes, facilities, and work orders.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:offDutyHours rdf:type rdf:Property ;
    rdfs:label 'Off Duty Hours' ;
    rdfs:comment 'Total hours the employee was off duty during the 24-hour period. Used for DOT HOS compliance to ensure adequate rest periods.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onDutyNotDrivingHours rdf:type rdf:Property ;
    rdfs:label 'On Duty Not Driving Hours' ;
    rdfs:comment 'Total hours the employee was on duty but not driving. Includes pre-trip inspections, loading, unloading, and administrative tasks. Counts toward DOT HOS on-duty limits.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payrollProcessedFlag rdf:type rdf:Property ;
    rdfs:label 'Payroll Processed Flag' ;
    rdfs:comment 'Boolean flag indicating whether this time entry has been processed in payroll. Prevents duplicate payment and enables payroll reconciliation.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ppeIssuedFlag rdf:type rdf:Property ;
    rdfs:label 'Ppe Issued Flag' ;
    rdfs:comment 'Boolean flag indicating whether required PPE was issued and confirmed for this work shift. Critical for OSHA safety compliance.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sleeperBerthHours rdf:type rdf:Property ;
    rdfs:label 'Sleeper Berth Hours' ;
    rdfs:comment 'Total hours spent in sleeper berth during this time entry. Applicable for long-haul CDL drivers and used for DOT HOS compliance calculations.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:timeEntrySource rdf:type rdf:Property ;
    rdfs:label 'Time Entry Source' ;
    rdfs:comment 'Source system or method by which the time entry was captured. Used for data quality assessment and audit purposes.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeEntryStatus rdf:type rdf:Property ;
    rdfs:label 'Time Entry Status' ;
    rdfs:comment 'Current workflow status of the time entry record. Tracks approval lifecycle from employee submission through payroll processing.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeEntryType rdf:type rdf:Property ;
    rdfs:label 'Time Entry Type' ;
    rdfs:comment 'Classification of the time entry indicating the nature of time worked or absence. Used for payroll, benefits administration, and labor cost reporting. [ENUM-REF-CANDIDATE: regular|overtime|holiday|sick|vacation|bereavement|jury_duty|training — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workDate rdf:type rdf:Property ;
    rdfs:label 'Work Date' ;
    rdfs:comment 'The calendar date on which the work was performed. Used for daily time tracking and attendance reporting.' ;
    rdfs:domain ind:TimeEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trainingCourseId rdf:type rdf:Property ;
    rdfs:label 'Training Course Id' ;
    rdfs:comment 'Unique identifier for the training course. Primary key.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TrainingCourse .

ind:courseOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Course Owner Employee Id' ;
    rdfs:comment 'Identifier of the employee responsible for maintaining and updating this training course. Typically a subject matter expert, training manager, or department head.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assessmentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Assessment Required Flag' ;
    rdfs:comment 'Indicates whether the training course requires a formal assessment, test, or examination for completion. True if assessment is mandatory; false if attendance or participation is sufficient.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:continuingEducationCredits rdf:type rdf:Property ;
    rdfs:label 'Continuing Education Credits' ;
    rdfs:comment 'Number of continuing education units (CEUs) or professional development hours awarded upon course completion. Used for professional license maintenance and career development tracking.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costPerEmployee rdf:type rdf:Property ;
    rdfs:label 'Cost Per Employee' ;
    rdfs:comment 'Direct cost to train one employee in this course, including instructor fees, materials, facility rental, and external vendor charges. Used for training budget planning and cost allocation.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:courseCategory rdf:type rdf:Property ;
    rdfs:label 'Course Category' ;
    rdfs:comment 'High-level classification of the training course type. Safety includes OSHA and HAZWOPER; compliance includes DOT and EPA; technical includes equipment operation; operational includes route management and MRF processes; leadership includes management development; administrative includes software and business processes.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courseCode rdf:type rdf:Property ;
    rdfs:label 'Course Code' ;
    rdfs:comment 'Unique alphanumeric code identifying the training course in the learning management system. Used for registration, scheduling, and transcript tracking.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courseDescription rdf:type rdf:Property ;
    rdfs:label 'Course Description' ;
    rdfs:comment 'Detailed description of the training course content, learning objectives, and outcomes. Used for course selection and compliance documentation.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courseMaterialsDescription rdf:type rdf:Property ;
    rdfs:label 'Course Materials Description' ;
    rdfs:comment 'Description of training materials, resources, and equipment required for course delivery. Examples: student workbook, safety manual, PPE kit, equipment simulator, online learning platform access.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courseName rdf:type rdf:Property ;
    rdfs:label 'Course Name' ;
    rdfs:comment 'Full descriptive name of the training course as displayed in catalogs and employee portals.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courseStatus rdf:type rdf:Property ;
    rdfs:label 'Course Status' ;
    rdfs:comment 'Current lifecycle status of the training course. Active courses are available for enrollment; inactive courses are temporarily unavailable; under development courses are being created; retired courses are no longer offered; suspended courses are on hold pending review.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courseSubcategory rdf:type rdf:Property ;
    rdfs:label 'Course Subcategory' ;
    rdfs:comment 'Detailed classification within the course category. Examples: OSHA 10-Hour, HAZWOPER 40-Hour, CDL Class A, Defensive Driving, MRF Equipment Operation, Landfill Cell Management, Environmental Monitoring, Leadership Development.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationDays rdf:type rdf:Property ;
    rdfs:label 'Duration Days' ;
    rdfs:comment 'Total calendar days required to complete the training course. Used for multi-day courses and scheduling employee availability.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:instructorQualificationRequired rdf:type rdf:Property ;
    rdfs:label 'Instructor Qualification Required' ;
    rdfs:comment 'Qualifications, certifications, or credentials required for instructors who deliver this training course. Examples: Certified Safety Professional, OSHA Authorized Trainer, Subject Matter Expert with 5+ years experience.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageOffered rdf:type rdf:Property ;
    rdfs:label 'Language Offered' ;
    rdfs:comment 'Languages in which the training course is available. Comma-separated list of ISO 639-1 language codes. Examples: EN (English), ES (Spanish), FR (French). Used for multilingual workforce training compliance.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastContentReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Content Review Date' ;
    rdfs:comment 'Date when the training course content was last reviewed for accuracy, regulatory compliance, and relevance. Used for quality assurance and continuous improvement.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maximumClassSize rdf:type rdf:Property ;
    rdfs:label 'Maximum Class Size' ;
    rdfs:comment 'Maximum number of employees that can be enrolled in a single session of this training course. Used for scheduling, resource planning, and regulatory compliance (e.g., OSHA trainer-to-student ratios).' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextContentReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Content Review Date' ;
    rdfs:comment 'Scheduled date for the next review of training course content. Used for proactive course maintenance and regulatory compliance validation.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:onlineLearningPlatformUrl rdf:type rdf:Property ;
    rdfs:label 'Online Learning Platform Url' ;
    rdfs:comment 'Web address or link to the online learning platform where the course is hosted. Used for online and self-paced courses. Null for classroom-only courses.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prerequisiteCourses rdf:type rdf:Property ;
    rdfs:label 'Prerequisite Courses' ;
    rdfs:comment 'Comma-separated list of course codes that must be completed before an employee can enroll in this course. Used for learning path sequencing and compliance validation.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recertificationFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Recertification Frequency Months' ;
    rdfs:comment 'Number of months between required recertification or refresher training. Common values: 12 (annual), 24 (biennial), 36 (triennial). Null if recertification is not required.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recertificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Recertification Required Flag' ;
    rdfs:comment 'Indicates whether the training course requires periodic recertification or renewal. True if recertification is mandatory; false if one-time completion is sufficient.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetJobRoles rdf:type rdf:Property ;
    rdfs:label 'Target Job Roles' ;
    rdfs:comment 'Comma-separated list of job roles or positions for which this training course is designed or required. Examples: CDL Driver, MRF Sorter, Landfill Operator, Environmental Engineer, Facility Manager, Technician.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorProviderName rdf:type rdf:Property ;
    rdfs:label 'Vendor Provider Name' ;
    rdfs:comment 'Name of the external training vendor or provider if the course is delivered by a third party. Null if training is delivered internally by Waste Management staff.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arbitrationProvisionFlag rdf:type rdf:Property ;
    rdfs:label 'Arbitration Provision Flag' ;
    rdfs:comment 'Indicates whether the collective bargaining agreement includes binding arbitration as the final step in the grievance resolution process.' ;
    rdfs:domain ind:UnionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bargainingUnitSize rdf:type rdf:Property ;
    rdfs:label 'Bargaining Unit Size' ;
    rdfs:comment 'Total number of employees represented by this collective bargaining agreement at the time of ratification or most recent count.' ;
    rdfs:domain ind:UnionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:baseWageRateMaximum rdf:type rdf:Property ;
    rdfs:label 'Base Wage Rate Maximum' ;
    rdfs:comment 'Maximum hourly base wage rate in US dollars (USD) for the highest tier or most senior position covered under this agreement.' ;
    rdfs:domain ind:UnionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseWageRateMinimum rdf:type rdf:Property ;
    rdfs:label 'Base Wage Rate Minimum' ;
    rdfs:comment 'Minimum hourly base wage rate in US dollars (USD) for the lowest tier or entry-level position covered under this agreement.' ;
    rdfs:domain ind:UnionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cdlPremiumRate rdf:type rdf:Property ;
    rdfs:label 'Cdl Premium Rate' ;
    rdfs:comment 'Additional hourly pay rate in US dollars (USD) for employees holding a valid Commercial Driver License (CDL) as defined in the collective bargaining agreement.' ;
    rdfs:domain ind:UnionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coveredJobClassifications rdf:type rdf:Property ;
    rdfs:label 'Covered Job Classifications' ;
    rdfs:comment 'Comma-separated list or description of job classifications, titles, and positions covered under this collective bargaining agreement (e.g., Commercial Driver License (CDL) drivers, Material Recovery Facility (MRF) sorters, equipment operators, facility workers).' ;
    rdfs:domain ind:UnionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doubleTimeThresholdHours rdf:type rdf:Property ;
    rdfs:label 'Double Time Threshold Hours' ;
    rdfs:comment 'Number of hours worked per day or per week after which double-time rates apply according to the collective bargaining agreement provisions.' ;
    rdfs:domain ind:UnionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grievanceFilingDeadlineDays rdf:type rdf:Property ;
    rdfs:label 'Grievance Filing Deadline Days' ;
    rdfs:comment 'Maximum number of calendar days after an alleged contract violation within which an employee or union must file a formal grievance to preserve their rights under the collective bargaining agreement.' ;
    rdfs:domain ind:UnionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:grievanceProcedureSteps rdf:type rdf:Property ;
    rdfs:label 'Grievance Procedure Steps' ;
    rdfs:comment 'Total number of formal steps defined in the grievance resolution procedure outlined in the collective bargaining agreement before arbitration.' ;
    rdfs:domain ind:UnionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hazardPayRate rdf:type rdf:Property ;
    rdfs:label 'Hazard Pay Rate' ;
    rdfs:comment 'Additional hourly pay rate in US dollars (USD) for employees working in hazardous conditions or handling hazardous materials as defined in the collective bargaining agreement.' ;
    rdfs:domain ind:UnionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:healthInsuranceEmployerContributionPct rdf:type rdf:Property ;
    rdfs:label 'Health Insurance Employer Contribution Pct' ;
    rdfs:comment 'Percentage of health insurance premium costs that the employer agrees to contribute for covered employees under the collective bargaining agreement.' ;
    rdfs:domain ind:UnionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leadNegotiatorName rdf:type rdf:Property ;
    rdfs:label 'Lead Negotiator Name' ;
    rdfs:comment 'Full name of the primary management representative who led negotiations for this collective bargaining agreement.' ;
    rdfs:domain ind:UnionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managementRightsClauseFlag rdf:type rdf:Property ;
    rdfs:label 'Management Rights Clause Flag' ;
    rdfs:comment 'Indicates whether the collective bargaining agreement includes a management rights clause reserving certain operational decisions to management discretion.' ;
    rdfs:domain ind:UnionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:negotiationCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Negotiation Completion Date' ;
    rdfs:comment 'Date on which negotiations concluded and a tentative agreement was reached between management and union representatives.' ;
    rdfs:domain ind:UnionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:negotiationStartDate rdf:type rdf:Property ;
    rdfs:label 'Negotiation Start Date' ;
    rdfs:comment 'Date on which formal negotiations for this collective bargaining agreement commenced between management and union representatives.' ;
    rdfs:domain ind:UnionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:noStrikeClauseFlag rdf:type rdf:Property ;
    rdfs:label 'No Strike Clause Flag' ;
    rdfs:comment 'Indicates whether the collective bargaining agreement includes a no-strike clause prohibiting work stoppages during the term of the agreement.' ;
    rdfs:domain ind:UnionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overtimeMultiplier rdf:type rdf:Property ;
    rdfs:label 'Overtime Multiplier' ;
    rdfs:comment 'Multiplier applied to base wage rate for overtime hours worked (e.g., 1.5 for time-and-a-half, 2.0 for double-time) as defined in the collective bargaining agreement.' ;
    rdfs:domain ind:UnionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overtimeThresholdHours rdf:type rdf:Property ;
    rdfs:label 'Overtime Threshold Hours' ;
    rdfs:comment 'Number of hours worked per day or per week after which overtime rates apply according to the collective bargaining agreement provisions.' ;
    rdfs:domain ind:UnionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paidHolidaysCount rdf:type rdf:Property ;
    rdfs:label 'Paid Holidays Count' ;
    rdfs:comment 'Number of paid holidays per year guaranteed to covered employees under the collective bargaining agreement.' ;
    rdfs:domain ind:UnionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paidTimeOffAccrualRate rdf:type rdf:Property ;
    rdfs:label 'Paid Time Off Accrual Rate' ;
    rdfs:comment 'Rate at which covered employees accrue paid time off hours per hour worked or per pay period as defined in the collective bargaining agreement.' ;
    rdfs:domain ind:UnionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pensionEmployerContributionPct rdf:type rdf:Property ;
    rdfs:label 'Pension Employer Contribution Pct' ;
    rdfs:comment 'Percentage of employee wages or fixed dollar amount per hour that the employer contributes to the pension plan for covered employees.' ;
    rdfs:domain ind:UnionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pensionPlanType rdf:type rdf:Property ;
    rdfs:label 'Pension Plan Type' ;
    rdfs:comment 'Type of retirement pension plan provided to covered employees under the collective bargaining agreement.' ;
    rdfs:domain ind:UnionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:probationaryPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Probationary Period Days' ;
    rdfs:comment 'Number of calendar days that a newly hired employee must complete before gaining full union membership rights and seniority accrual under the collective bargaining agreement.' ;
    rdfs:domain ind:UnionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ratificationDate rdf:type rdf:Property ;
    rdfs:label 'Ratification Date' ;
    rdfs:comment 'Date on which the union membership voted to approve and ratify the collective bargaining agreement.' ;
    rdfs:domain ind:UnionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:senioritySystemType rdf:type rdf:Property ;
    rdfs:label 'Seniority System Type' ;
    rdfs:comment 'Type of seniority system defined in the collective bargaining agreement that governs bidding rights, layoff order, recall rights, and shift preferences.' ;
    rdfs:domain ind:UnionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unionDuesDeductionAmount rdf:type rdf:Property ;
    rdfs:label 'Union Dues Deduction Amount' ;
    rdfs:comment 'Fixed dollar amount or percentage of wages deducted from covered employee paychecks for union membership dues as authorized in the collective bargaining agreement.' ;
    rdfs:domain ind:UnionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unionDuesDeductionFrequency rdf:type rdf:Property ;
    rdfs:label 'Union Dues Deduction Frequency' ;
    rdfs:comment 'Frequency at which union dues are deducted from covered employee paychecks as specified in the collective bargaining agreement.' ;
    rdfs:domain ind:UnionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unionName rdf:type rdf:Property ;
    rdfs:label 'Union Name' ;
    rdfs:comment 'Full legal name of the labor union or labor organization representing the employees (e.g., International Brotherhood of Teamsters, Service Employees International Union, International Union of Operating Engineers).' ;
    rdfs:domain ind:UnionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unionRepresentativeName rdf:type rdf:Property ;
    rdfs:label 'Union Representative Name' ;
    rdfs:comment 'Full name of the primary union representative or business agent who led negotiations for this collective bargaining agreement on behalf of the union membership.' ;
    rdfs:domain ind:UnionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wageScaleTierCount rdf:type rdf:Property ;
    rdfs:label 'Wage Scale Tier Count' ;
    rdfs:comment 'Number of distinct wage scale tiers or pay steps defined in the collective bargaining agreement for covered positions.' ;
    rdfs:domain ind:UnionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:workersCompClaimId rdf:type rdf:Property ;
    rdfs:label 'Workers Comp Claim Id' ;
    rdfs:comment 'Unique identifier for the workers compensation claim record. Primary key.' ;
    rdfs:domain ind:WorkersCompClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryWorkersEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Workers Employee Id' ;
    rdfs:comment 'Identifier of the employee who filed the workers compensation claim.' ;
    rdfs:domain ind:WorkersCompClaim ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:adjusterName rdf:type rdf:Property ;
    rdfs:label 'Adjuster Name' ;
    rdfs:comment 'Name of the insurance claims adjuster assigned to evaluate and process the claim.' ;
    rdfs:domain ind:WorkersCompClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjusterPhone rdf:type rdf:Property ;
    rdfs:label 'Adjuster Phone' ;
    rdfs:comment 'Contact phone number for the insurance claims adjuster handling the claim.' ;
    rdfs:domain ind:WorkersCompClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimFiledDate rdf:type rdf:Property ;
    rdfs:label 'Claim Filed Date' ;
    rdfs:comment 'Date when the formal workers compensation claim was filed with the insurer or state authority.' ;
    rdfs:domain ind:WorkersCompClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:claimReserveAmount rdf:type rdf:Property ;
    rdfs:label 'Claim Reserve Amount' ;
    rdfs:comment 'Financial reserve amount set aside by the insurer to cover anticipated future costs for this claim.' ;
    rdfs:domain ind:WorkersCompClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incidentLocation rdf:type rdf:Property ;
    rdfs:label 'Incident Location' ;
    rdfs:comment 'Specific location where the injury or illness occurred, such as facility name, route number, or work site address.' ;
    rdfs:domain ind:WorkersCompClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indemnityCost rdf:type rdf:Property ;
    rdfs:label 'Indemnity Cost' ;
    rdfs:comment 'Total indemnity or wage replacement payments made to the employee for lost time due to the injury or illness.' ;
    rdfs:domain ind:WorkersCompClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:injuryDate rdf:type rdf:Property ;
    rdfs:label 'Injury Date' ;
    rdfs:comment 'Date when the occupational injury or illness occurred. This is the principal business event timestamp for the claim.' ;
    rdfs:domain ind:WorkersCompClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:injuryDescription rdf:type rdf:Property ;
    rdfs:label 'Injury Description' ;
    rdfs:comment 'Detailed narrative description of how the injury or illness occurred, including circumstances, location, and contributing factors.' ;
    rdfs:domain ind:WorkersCompClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:injurySeverity rdf:type rdf:Property ;
    rdfs:label 'Injury Severity' ;
    rdfs:comment 'Classification of the severity level of the injury or illness based on medical assessment and impact.' ;
    rdfs:domain ind:WorkersCompClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insurerClaimReference rdf:type rdf:Property ;
    rdfs:label 'Insurer Claim Reference' ;
    rdfs:comment 'Reference number or identifier assigned by the insurance carrier for their internal claim tracking.' ;
    rdfs:domain ind:WorkersCompClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lostTimeDays rdf:type rdf:Property ;
    rdfs:label 'Lost Time Days' ;
    rdfs:comment 'Total number of calendar days the employee was unable to work due to the injury or illness, excluding the day of injury.' ;
    rdfs:domain ind:WorkersCompClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lostTimeFlag rdf:type rdf:Property ;
    rdfs:label 'Lost Time Flag' ;
    rdfs:comment 'Indicates whether the injury resulted in lost work time beyond the day of injury.' ;
    rdfs:domain ind:WorkersCompClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:medicalCost rdf:type rdf:Property ;
    rdfs:label 'Medical Cost' ;
    rdfs:comment 'Total medical expenses incurred for treatment of the injury or illness, including hospital, physician, therapy, and medication costs.' ;
    rdfs:domain ind:WorkersCompClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:medicalFacilityName rdf:type rdf:Property ;
    rdfs:label 'Medical Facility Name' ;
    rdfs:comment 'Name of the hospital, clinic, or medical facility where treatment was provided.' ;
    rdfs:domain ind:WorkersCompClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalTreatmentType rdf:type rdf:Property ;
    rdfs:label 'Medical Treatment Type' ;
    rdfs:comment 'Classification of the level of medical treatment provided for the injury or illness.' ;
    rdfs:domain ind:WorkersCompClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictedDutyDays rdf:type rdf:Property ;
    rdfs:label 'Restricted Duty Days' ;
    rdfs:comment 'Total number of calendar days the employee worked on restricted or light duty due to the injury or illness.' ;
    rdfs:domain ind:WorkersCompClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:restrictedDutyFlag rdf:type rdf:Property ;
    rdfs:label 'Restricted Duty Flag' ;
    rdfs:comment 'Indicates whether the employee was placed on restricted or light duty as a result of the injury.' ;
    rdfs:domain ind:WorkersCompClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:returnToWorkStatus rdf:type rdf:Property ;
    rdfs:label 'Return To Work Status' ;
    rdfs:comment 'Status of the employees return to work, indicating whether they resumed full duties, modified duties, or have not yet returned.' ;
    rdfs:domain ind:WorkersCompClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalIncurredCost rdf:type rdf:Property ;
    rdfs:label 'Total Incurred Cost' ;
    rdfs:comment 'Total cost incurred for the workers compensation claim, including medical expenses, indemnity payments, and administrative costs.' ;
    rdfs:domain ind:WorkersCompClaim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workforceTrainingRecordId rdf:type rdf:Property ;
    rdfs:label 'Workforce Training Record Id' ;
    rdfs:comment 'Unique identifier for each training event completion record. Primary key for the workforce training record entity.' ;
    rdfs:domain ind:WorkforceTrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:attemptsCount rdf:type rdf:Property ;
    rdfs:label 'Attempts Count' ;
    rdfs:comment 'Number of attempts the employee made to pass the training assessment. Supports identification of training effectiveness issues.' ;
    rdfs:domain ind:WorkforceTrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certificationExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Certification Expiration Date' ;
    rdfs:comment 'Date on which the certification or credential expires and requires renewal or refresher training. Null for non-expiring certifications.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationIssued rdf:type rdf:Property ;
    rdfs:label 'Certification Issued' ;
    rdfs:comment 'Indicates whether a formal certification or credential was issued upon successful completion of the training (True/False).' ;
    rdfs:domain ind:WorkforceTrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ceuCredits rdf:type rdf:Property ;
    rdfs:label 'Ceu Credits' ;
    rdfs:comment 'Number of Continuing Education Unit credits earned for professional certification maintenance. Null if the course does not award CEU credits.' ;
    rdfs:domain ind:WorkforceTrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recordSource rdf:type rdf:Property ;
    rdfs:label 'Record Source' ;
    rdfs:comment 'Source system or platform from which this training record originated (e.g., Workday HCM, external LMS, manual entry). Supports data lineage and integration troubleshooting.' ;
    rdfs:domain ind:WorkforceTrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recurrenceFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Recurrence Frequency Months' ;
    rdfs:comment 'Number of months between required training repetitions for recurring courses (e.g., 12 for annual, 24 for biennial). Null for non-recurring training.' ;
    rdfs:domain ind:WorkforceTrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trainingDurationDays rdf:type rdf:Property ;
    rdfs:label 'Training Duration Days' ;
    rdfs:comment 'Total number of calendar days over which the training was conducted (e.g., 5 for a week-long course, 1 for a single-day session).' ;
    rdfs:domain ind:WorkforceTrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:customerProgramEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Customer Program Enrollment Id' ;
    rdfs:comment 'Primary key for customer_program_enrollment' ;
    rdfs:domain ind:CustomerProgramEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:programEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Program Enrollment Id' ;
    rdfs:comment 'Unique identifier for this enrollment record. Primary key for the association.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SustainabilityProgramEnrollment .

ind:customerProgramEnrollmentDate rdf:type rdf:Property ;
    rdfs:label 'Customer Program Enrollment Date' ;
    rdfs:comment 'The date when the customer account was enrolled in the circular economy program. Tracks when participation commenced.' ;
    rdfs:domain ind:CustomerProgramEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customerProgramEnrollmentStatus rdf:type rdf:Property ;
    rdfs:label 'Customer Program Enrollment Status' ;
    rdfs:comment 'Current lifecycle status of this enrollment. Active = currently participating, Suspended = temporarily paused, Completed = program term ended successfully, Cancelled = customer withdrew.' ;
    rdfs:domain ind:CustomerProgramEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:haulerAuthorizationId rdf:type rdf:Property ;
    rdfs:label 'Hauler Authorization Id' ;
    rdfs:comment 'Unique identifier for this hauler-station authorization record. Primary key for the association.' ;
    rdfs:domain ind:HaulerAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:authorizationDate rdf:type rdf:Property ;
    rdfs:label 'Authorization Date' ;
    rdfs:comment 'Date when the hauler was authorized to deliver waste to this specific transfer station. Marks the start of the authorization relationship.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authorizationExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Authorization Expiration Date' ;
    rdfs:comment 'Date when this station-specific authorization expires and requires renewal. Null indicates no expiration (evergreen authorization subject to ongoing compliance).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authorizationStatus rdf:type rdf:Property ;
    rdfs:label 'Authorization Status' ;
    rdfs:comment 'Current lifecycle status of this station-specific authorization. Pending: application submitted. Active: authorized to deliver. Suspended: temporarily blocked. Revoked: permanently terminated. Expired: authorization period ended.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedTransferStations rdf:type rdf:Property ;
    rdfs:label 'Authorized Transfer Stations' ;
    rdfs:comment 'Comma-separated list of transfer station facility IDs where this hauler is authorized to deliver waste. Used for gate access control and vehicle pre-authorization. [Moved from hauler_account: This denormalized STRING field in hauler_account contains a comma-separated list of transfer station IDs. It should be replaced by the proper hauler_authorization association table, which provides full relationship lifecycle management, station-specific attributes, and historical tracking. The denormalized field cannot capture authorization dates, statuses, station-specific rates, or suspension reasons.]' ;
    rdfs:domain ind:HaulerAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Last Delivery Date' ;
    rdfs:comment 'Date of the most recent waste delivery by this hauler to this specific transfer station. Used for monitoring active vs. dormant authorizations and compliance tracking.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preAuthorizationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Pre Authorization Required Flag' ;
    rdfs:comment 'Indicates whether this hauler must pre-register each vehicle delivery in AMCS before arriving at THIS specific transfer station. Station-specific operational requirement.' ;
    rdfs:domain ind:HaulerAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revocationReason rdf:type rdf:Property ;
    rdfs:label 'Revocation Reason' ;
    rdfs:comment 'Reason code or description if this station-specific authorization status is revoked (e.g., repeated violations at this station, contract termination for this station, regulatory prohibition).' ;
    rdfs:domain ind:HaulerAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfidTransponderRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Rfid Transponder Required Flag' ;
    rdfs:comment 'Indicates whether this hauler\'s vehicles must have RFID transponders for automated gate entry at THIS specific transfer station. Station-specific requirement that may differ from hauler\'s global RFID settings.' ;
    rdfs:domain ind:HaulerAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stationSpecificTippingRateTier rdf:type rdf:Property ;
    rdfs:label 'Station Specific Tipping Rate Tier' ;
    rdfs:comment 'Rate tier classification determining the per-ton tipping fee charged to this hauler at THIS specific transfer station. May differ from the hauler\'s global rate tier based on station-specific contracts or volume commitments.' ;
    rdfs:domain ind:HaulerAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stationSpecificWasteStreamsAllowed rdf:type rdf:Property ;
    rdfs:label 'Station Specific Waste Streams Allowed' ;
    rdfs:comment 'Comma-separated list of waste stream types this hauler is authorized to deliver to THIS specific transfer station. May be more restrictive than the hauler\'s global approved_waste_streams based on station capabilities and hauler-station agreement.' ;
    rdfs:domain ind:HaulerAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ytdTonnageDelivered rdf:type rdf:Property ;
    rdfs:label 'Ytd Tonnage Delivered' ;
    rdfs:comment 'Total tons of waste delivered by this hauler to this specific transfer station in the current calendar year. Used for volume-based rate tier adjustments and contract compliance monitoring.' ;
    rdfs:domain ind:HaulerAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:facilityAuditId rdf:type rdf:Property ;
    rdfs:label 'Facility Audit Id' ;
    rdfs:comment 'Unique identifier for this facility audit record. Primary key.' ;
    rdfs:domain ind:FacilityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Audit Completion Date' ;
    rdfs:comment 'Date on which the audit was completed and findings were finalized.' ;
    rdfs:domain ind:FacilityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditReportReference rdf:type rdf:Property ;
    rdfs:label 'Audit Report Reference' ;
    rdfs:comment 'Reference number or document identifier for the audit report generated from this facility audit.' ;
    rdfs:domain ind:FacilityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditResult rdf:type rdf:Property ;
    rdfs:label 'Audit Result' ;
    rdfs:comment 'Overall result or outcome of the facility audit. Explicitly identified in detection phase.' ;
    rdfs:domain ind:FacilityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditorAssigned rdf:type rdf:Property ;
    rdfs:label 'Auditor Assigned' ;
    rdfs:comment 'Name or identifier of the auditor assigned to conduct this specific facility audit. Explicitly identified in detection phase.' ;
    rdfs:domain ind:FacilityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationOutcome rdf:type rdf:Property ;
    rdfs:label 'Certification Outcome' ;
    rdfs:comment 'Certification status resulting from this facility audit, if applicable to external certification programs. Explicitly identified in detection phase.' ;
    rdfs:domain ind:FacilityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingsCount rdf:type rdf:Property ;
    rdfs:label 'Findings Count' ;
    rdfs:comment 'Total number of findings identified during this facility audit. Explicitly identified in detection phase.' ;
    rdfs:domain ind:FacilityAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:permitRequirementId rdf:type rdf:Property ;
    rdfs:label 'Permit Requirement Id' ;
    rdfs:comment 'Unique identifier for this permit-requirement mapping record. Primary key.' ;
    rdfs:domain ind:PermitRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicabilityDetermination rdf:type rdf:Property ;
    rdfs:label 'Applicability Determination' ;
    rdfs:comment 'Documented determination of how and why this regulatory requirement applies to this specific permit. Captures the legal and operational reasoning for the mapping.' ;
    rdfs:domain ind:PermitRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:citationReference rdf:type rdf:Property ;
    rdfs:label 'Citation Reference' ;
    rdfs:comment 'Specific citation or section reference from the regulatory requirement that applies to this permit. Allows for granular tracking when only portions of a requirement apply.' ;
    rdfs:domain ind:PermitRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exemptionClaimed rdf:type rdf:Property ;
    rdfs:label 'Exemption Claimed' ;
    rdfs:comment 'Indicates whether an exemption from this regulatory requirement has been claimed for this permit. If true, exemption documentation should be maintained.' ;
    rdfs:domain ind:PermitRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastComplianceVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Last Compliance Verification Date' ;
    rdfs:comment 'Date on which compliance with this requirement was last verified for this permit through inspection, audit, or self-assessment.' ;
    rdfs:domain ind:PermitRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastUpdatedDate rdf:type rdf:Property ;
    rdfs:label 'Last Updated Date' ;
    rdfs:comment 'Timestamp when this permit-requirement mapping was last modified.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:monitoringFrequencyOverride rdf:type rdf:Property ;
    rdfs:label 'Monitoring Frequency Override' ;
    rdfs:comment 'Permit-specific monitoring frequency that overrides the default monitoring requirement. Captures permit conditions that impose more or less frequent monitoring than the base requirement.' ;
    rdfs:domain ind:PermitRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextComplianceVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Next Compliance Verification Date' ;
    rdfs:comment 'Scheduled date for the next compliance verification activity for this permit-requirement combination.' ;
    rdfs:domain ind:PermitRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingFrequencyOverride rdf:type rdf:Property ;
    rdfs:label 'Reporting Frequency Override' ;
    rdfs:comment 'Permit-specific reporting frequency that overrides the default reporting requirement. Captures permit conditions that impose different reporting schedules than the base requirement.' ;
    rdfs:domain ind:PermitRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleOfficerName rdf:type rdf:Property ;
    rdfs:label 'Responsible Officer Name' ;
    rdfs:comment 'Name of the compliance officer or facility manager responsible for ensuring this specific permit meets this specific requirement.' ;
    rdfs:domain ind:PermitRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceEventId rdf:type rdf:Property ;
    rdfs:label 'Service Event Id' ;
    rdfs:comment 'Unique system-generated identifier for each service event record. Primary key.' ;
    rdfs:domain ind:ServiceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:containerCountServiced rdf:type rdf:Property ;
    rdfs:label 'Container Count Serviced' ;
    rdfs:comment 'Number of waste containers (bins, carts, dumpsters) actually serviced during this event. May differ from the total container count at the address. Identified in detection phase as relationship data.' ;
    rdfs:domain ind:ServiceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Service End Timestamp' ;
    rdfs:comment 'Timestamp when the vehicle completed service and departed the service address. Used for precise route timing and productivity calculation.' ;
    rdfs:domain ind:ServiceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:serviceStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Service Start Timestamp' ;
    rdfs:comment 'Timestamp when the vehicle arrived at the service address and began service operations. Used for precise route timing and GPS validation.' ;
    rdfs:domain ind:ServiceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:tonnageCollected rdf:type rdf:Property ;
    rdfs:label 'Tonnage Collected' ;
    rdfs:comment 'Weight of waste collected during this service event measured in tons. Critical operational metric for vehicle payload tracking and billing. Identified in detection phase as relationship data.' ;
    rdfs:domain ind:ServiceEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:purchasingInfoRecordId rdf:type rdf:Property ;
    rdfs:label 'Purchasing Info Record Id' ;
    rdfs:comment 'Primary key for purchasing_info_record' ;
    rdfs:domain ind:PurchasingInfoRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:initiativeSafetyAnalysisId rdf:type rdf:Property ;
    rdfs:label 'Initiative Safety Analysis Id' ;
    rdfs:comment 'Unique identifier for this initiative-JHA association record' ;
    rdfs:domain ind:InitiativeSafetyAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Assigned By Employee Id' ;
    rdfs:comment 'Reference to the employee (typically initiative project manager or safety coordinator) who assigned this JHA to the initiative' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:crewSizeAssigned rdf:type rdf:Property ;
    rdfs:label 'Crew Size Assigned' ;
    rdfs:comment 'Number of crew members assigned to perform this JHA-covered task for this specific initiative (may differ from standard JHA crew size based on initiative scope)' ;
    rdfs:domain ind:InitiativeSafetyAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:initiativeSpecificControls rdf:type rdf:Property ;
    rdfs:label 'Initiative Specific Controls' ;
    rdfs:comment 'Additional safety controls or modifications to standard JHA procedures required for this specific initiative (e.g., enhanced PPE for RNG facility work, additional monitoring for methane capture expansion)' ;
    rdfs:domain ind:InitiativeSafetyAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jhaApplicabilityPhase rdf:type rdf:Property ;
    rdfs:label 'Jha Applicability Phase' ;
    rdfs:comment 'Project phase during which this JHA applies to the initiative (e.g., construction phase for RNG facility build requires excavation JHA, electrical work JHA; operations phase requires different JHAs)' ;
    rdfs:domain ind:InitiativeSafetyAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jhaReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Jha Review Status' ;
    rdfs:comment 'Status of JHA review and approval specific to this initiative (JHA may require initiative-specific review even if generally approved)' ;
    rdfs:domain ind:InitiativeSafetyAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastRevisionDate rdf:type rdf:Property ;
    rdfs:label 'Last Revision Date' ;
    rdfs:comment 'Date when this initiative-JHA association was last reviewed or revised (tracks initiative-specific updates separate from master JHA revisions)' ;
    rdfs:domain ind:InitiativeSafetyAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:taskFrequencyDuringInitiative rdf:type rdf:Property ;
    rdfs:label 'Task Frequency During Initiative' ;
    rdfs:comment 'How often this JHA-covered task is performed during the initiative implementation (frequency varies by initiative phase and type)' ;
    rdfs:domain ind:InitiativeSafetyAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingCompletionRequiredDate rdf:type rdf:Property ;
    rdfs:label 'Training Completion Required Date' ;
    rdfs:comment 'Deadline by which all crew members must complete JHA-specific training before performing tasks on this initiative' ;
    rdfs:domain ind:InitiativeSafetyAnalysis ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:programTaskSafetyRequirementId rdf:type rdf:Property ;
    rdfs:label 'Program Task Safety Requirement Id' ;
    rdfs:comment 'Unique identifier for this program-JHA association record. Primary key.' ;
    rdfs:domain ind:ProgramTaskSafetyRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicabilityStartDate rdf:type rdf:Property ;
    rdfs:label 'Applicability Start Date' ;
    rdfs:comment 'The date when this JHA became applicable to this specific circular economy program. Tracks when the safety requirement was activated for program operations.' ;
    rdfs:domain ind:ProgramTaskSafetyRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:programPhaseApplicability rdf:type rdf:Property ;
    rdfs:label 'Program Phase Applicability' ;
    rdfs:comment 'The operational phase(s) of the circular economy program during which this JHA applies (e.g., collection, sorting, processing, distribution). A single JHA may apply to multiple phases or be phase-specific.' ;
    rdfs:domain ind:ProgramTaskSafetyRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programSpecificPpeRequirements rdf:type rdf:Property ;
    rdfs:label 'Program Specific Ppe Requirements' ;
    rdfs:comment 'Additional or modified Personal Protective Equipment requirements specific to this program beyond the base JHA requirements. May include specialized PPE for handling specific material streams (e.g., chemical-resistant gloves for e-waste battery handling).' ;
    rdfs:domain ind:ProgramTaskSafetyRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskFrequencyInProgram rdf:type rdf:Property ;
    rdfs:label 'Task Frequency In Program' ;
    rdfs:comment 'How often this job task is performed within the context of this specific program. May differ from the general JHA frequency based on program operational intensity.' ;
    rdfs:domain ind:ProgramTaskSafetyRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingCompletionStatus rdf:type rdf:Property ;
    rdfs:label 'Training Completion Status' ;
    rdfs:comment 'Current status of required safety training completion for program staff performing this job task. Tracks program-level training compliance.' ;
    rdfs:domain ind:ProgramTaskSafetyRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:haulerSiteAuthorizationId rdf:type rdf:Property ;
    rdfs:label 'Hauler Site Authorization Id' ;
    rdfs:comment 'Unique identifier for this hauler-site authorization record. Primary key.' ;
    rdfs:domain ind:HaulerSiteAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:siteSpecificInstructions rdf:type rdf:Property ;
    rdfs:label 'Site Specific Instructions' ;
    rdfs:comment 'Free-text notes for site operators regarding special requirements, restrictions, or handling procedures for this hauler at this specific site (e.g., designated unloading area, inspection requirements, prohibited materials).' ;
    rdfs:domain ind:HaulerSiteAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeCommitmentTons rdf:type rdf:Property ;
    rdfs:label 'Volume Commitment Tons' ;
    rdfs:comment 'Contractual volume commitment in tons that the hauler has agreed to deliver to this specific site within the contract period. Used for rate negotiation and capacity planning.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mrfTsdfDisposalAgreementId rdf:type rdf:Property ;
    rdfs:label 'Mrf Tsdf Disposal Agreement Id' ;
    rdfs:comment 'Unique system-generated identifier for each MRF-TSDF disposal agreement record. Primary key for the association.' ;
    rdfs:domain ind:MrfTsdfDisposalAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:annualVolumeCommitmentTons rdf:type rdf:Property ;
    rdfs:label 'Annual Volume Commitment Tons' ;
    rdfs:comment 'Minimum annual tonnage of waste that the MRF commits to ship to this TSDF under this agreement. Volume commitments typically secure favorable pricing and capacity guarantees.' ;
    rdfs:domain ind:MrfTsdfDisposalAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvedWasteCodes rdf:type rdf:Property ;
    rdfs:label 'Approved Waste Codes' ;
    rdfs:comment 'Comma-separated list of EPA hazardous waste codes (D, F, K, P, U series) that this specific MRF is authorized to ship to this specific TSDF under this agreement. Subset of the TSDF\'s overall permitted_waste_codes, tailored to the MRF\'s waste streams.' ;
    rdfs:domain ind:MrfTsdfDisposalAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastShipmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Shipment Date' ;
    rdfs:comment 'Date of the most recent waste shipment from this MRF to this TSDF under this agreement. Used to monitor active vs. dormant disposal relationships and contract utilization.' ;
    rdfs:domain ind:MrfTsdfDisposalAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pricingPerTon rdf:type rdf:Property ;
    rdfs:label 'Pricing Per Ton' ;
    rdfs:comment 'Contracted disposal fee in dollars per ton that the MRF pays to the TSDF for accepting and processing waste under this agreement. Pricing varies by MRF-TSDF relationship based on volume commitments, waste types, and distance.' ;
    rdfs:domain ind:MrfTsdfDisposalAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryWasteStreamType rdf:type rdf:Property ;
    rdfs:label 'Primary Waste Stream Type' ;
    rdfs:comment 'Classification of the primary waste stream that this MRF ships to this TSDF (e.g., contaminated residue, rejected bales, hazmat-contaminated materials, process water treatment sludge). MRFs may have multiple agreements with different TSDFs for different waste streams.' ;
    rdfs:domain ind:MrfTsdfDisposalAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalShipmentsYtd rdf:type rdf:Property ;
    rdfs:label 'Total Shipments Ytd' ;
    rdfs:comment 'Count of waste shipments from this MRF to this TSDF in the current calendar year. Used to track contract activity and compare against volume commitments.' ;
    rdfs:domain ind:MrfTsdfDisposalAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:siteAuthorizationId rdf:type rdf:Property ;
    rdfs:label 'Site Authorization Id' ;
    rdfs:comment 'Unique identifier for this service offering-landfill site authorization record. Primary key.' ;
    rdfs:domain ind:SiteAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedWasteTypes rdf:type rdf:Property ;
    rdfs:label 'Approved Waste Types' ;
    rdfs:comment 'Comma-separated list or JSON array of specific waste type codes from this service offering that are permitted for disposal at this site (e.g., MSW, C&D, yard_waste). Subset of offering\'s waste types filtered by site\'s permit restrictions.' ;
    rdfs:domain ind:SiteAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageHaulDistanceMiles rdf:type rdf:Property ;
    rdfs:label 'Average Haul Distance Miles' ;
    rdfs:comment 'Average one-way haul distance in miles from the service offering\'s typical service area centroid to this landfill site. Used for route planning and environmental impact reporting.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumDailyTonnage rdf:type rdf:Property ;
    rdfs:label 'Maximum Daily Tonnage' ;
    rdfs:comment 'Maximum tons per day that can be disposed from this service offering at this landfill site. Used for capacity planning and route optimization to prevent site overload.' ;
    rdfs:domain ind:SiteAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorityRank rdf:type rdf:Property ;
    rdfs:label 'Priority Rank' ;
    rdfs:comment 'Numeric priority ranking for this site when routing waste from this service offering (1=highest priority). Used by route optimization algorithms to prefer certain sites based on cost, distance, or capacity.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requiresSpecialHandling rdf:type rdf:Property ;
    rdfs:label 'Requires Special Handling' ;
    rdfs:comment 'Indicates whether waste from this service offering requires special handling procedures at this site (e.g., separate cell, additional inspection, manifest verification)' ;
    rdfs:domain ind:SiteAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transportationCostPerTon rdf:type rdf:Property ;
    rdfs:label 'Transportation Cost Per Ton' ;
    rdfs:comment 'Average transportation cost in USD per ton to haul waste from this service offering\'s service area to this landfill site. Used for cost modeling and profitability analysis.' ;
    rdfs:domain ind:SiteAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:routeDriverQualificationId rdf:type rdf:Property ;
    rdfs:label 'Route Driver Qualification Id' ;
    rdfs:comment 'Unique identifier for this route-driver qualification record. Primary key.' ;
    rdfs:domain ind:RouteDriverQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualificationVerifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Qualification Verified By Employee Id' ;
    rdfs:comment 'Employee ID of the supervisor or training coordinator who verified this driver\'s qualification for this route. Foreign key to workforce.employee.' ;
    rdfs:domain ind:RouteDriverQualification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:lastAssignmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Assignment Date' ;
    rdfs:comment 'Most recent date this driver was actually assigned to execute this route. Used for rotation scheduling and ensuring drivers maintain route familiarity.' ;
    rdfs:domain ind:RouteDriverQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:primaryBackupFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Backup Flag' ;
    rdfs:comment 'Indicates whether this driver is the primary assigned driver or a backup driver for this route. Used by dispatch to prioritize driver assignments.' ;
    rdfs:domain ind:RouteDriverQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationVerifiedDate rdf:type rdf:Property ;
    rdfs:label 'Qualification Verified Date' ;
    rdfs:comment 'Date when the driver\'s qualification for this route was verified by a supervisor or training coordinator. Used for compliance tracking and audit purposes.' ;
    rdfs:domain ind:RouteDriverQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualificationVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Qualification Verified Flag' ;
    rdfs:comment 'Indicates whether the driver\'s qualifications (CDL class, endorsements, truck type experience) have been verified as meeting the requirements for this specific route. Set to true after supervisor ride-along or qualification check.' ;
    rdfs:domain ind:RouteDriverQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalAssignmentsCount rdf:type rdf:Property ;
    rdfs:label 'Total Assignments Count' ;
    rdfs:comment 'Total number of times this driver has been assigned to execute this route. Used for experience tracking and performance analysis.' ;
    rdfs:domain ind:RouteDriverQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vendorWasteStreamApprovalId rdf:type rdf:Property ;
    rdfs:label 'Vendor Waste Stream Approval Id' ;
    rdfs:comment 'Unique identifier for this vendor-waste stream approval record. Primary key.' ;
    rdfs:domain ind:VendorWasteStreamApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capacityTonsPerMonth rdf:type rdf:Property ;
    rdfs:label 'Capacity Tons Per Month' ;
    rdfs:comment 'Maximum monthly tonnage capacity this vendor can accept for this specific waste stream. Used for vendor selection and load balancing.' ;
    rdfs:domain ind:VendorWasteStreamApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextRecertificationDate rdf:type rdf:Property ;
    rdfs:label 'Next Recertification Date' ;
    rdfs:comment 'Date when this vendor must recertify or renew their approval to continue handling this waste stream.' ;
    rdfs:domain ind:VendorWasteStreamApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preferredVendorFlag rdf:type rdf:Property ;
    rdfs:label 'Preferred Vendor Flag' ;
    rdfs:comment 'Indicates whether this vendor is the preferred/primary vendor for this waste stream based on pricing, capacity, or service quality.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disposalRoutingId rdf:type rdf:Property ;
    rdfs:label 'Disposal Routing Id' ;
    rdfs:comment 'Unique identifier for this transfer station to landfill disposal routing relationship. Primary key.' ;
    rdfs:domain ind:DisposalRouting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractedCapacityTpd rdf:type rdf:Property ;
    rdfs:label 'Contracted Capacity Tpd' ;
    rdfs:comment 'Contracted or allocated daily disposal capacity in tons per day reserved for this transfer station at this landfill site. Used for capacity planning and load balancing across disposal sites.' ;
    rdfs:domain ind:DisposalRouting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preferredDisposalFlag rdf:type rdf:Property ;
    rdfs:label 'Preferred Disposal Flag' ;
    rdfs:comment 'Indicates whether this landfill site is the preferred/primary disposal destination for this transfer station. Used for routing optimization and load balancing decisions.' ;
    rdfs:domain ind:DisposalRouting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:routingStatus rdf:type rdf:Property ;
    rdfs:label 'Routing Status' ;
    rdfs:comment 'Current operational status of this disposal routing agreement. active = currently in use, suspended = temporarily inactive, expired = past expiration date, pending = approved but not yet effective.' ;
    rdfs:domain ind:DisposalRouting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteStreamRoutingRules rdf:type rdf:Property ;
    rdfs:label 'Waste Stream Routing Rules' ;
    rdfs:comment 'Business rules defining which waste streams from the transfer station are routed to this landfill site. May specify MSW only, C&D only, mixed streams, or conditional routing based on waste classification and site permits.' ;
    rdfs:domain ind:DisposalRouting ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buyerTsdfReturnAgreementId rdf:type rdf:Property ;
    rdfs:label 'Buyer Tsdf Return Agreement Id' ;
    rdfs:comment 'Unique identifier for this buyer-TSDF return agreement record. Primary key.' ;
    rdfs:domain ind:BuyerTsdfReturnAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contaminationThresholdPct rdf:type rdf:Property ;
    rdfs:label 'Contamination Threshold Pct' ;
    rdfs:comment 'Maximum allowable contamination percentage in recovered material bales before rejection and TSDF disposition is triggered under this agreement. Varies by buyer quality standards and commodity type.' ;
    rdfs:domain ind:Recycling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disposalCostResponsibility rdf:type rdf:Property ;
    rdfs:label 'Disposal Cost Responsibility' ;
    rdfs:comment 'Defines which party bears the financial responsibility for TSDF disposal costs for contaminated returns. Values: BUYER (buyer pays all costs), WM (Waste Management absorbs costs), SHARED (split per agreement terms), NEGOTIATED (case-by-case determination).' ;
    rdfs:domain ind:BuyerTsdfReturnAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxAnnualVolumeTons rdf:type rdf:Property ;
    rdfs:label 'Max Annual Volume Tons' ;
    rdfs:comment 'Maximum tonnage of contaminated material that can be sent to this TSDF facility under this agreement within a calendar year. Used for capacity planning and agreement compliance monitoring.' ;
    rdfs:domain ind:BuyerTsdfReturnAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:notificationProtocol rdf:type rdf:Property ;
    rdfs:label 'Notification Protocol' ;
    rdfs:comment 'Describes the required communication and notification procedures when contaminated material is identified and routed to the TSDF under this agreement. May include contact sequences, documentation requirements, and timeline expectations.' ;
    rdfs:domain ind:BuyerTsdfReturnAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredWasteCodes rdf:type rdf:Property ;
    rdfs:label 'Preferred Waste Codes' ;
    rdfs:comment 'Comma-separated list of EPA hazardous waste codes that this buyer-TSDF agreement is specifically designed to handle. Subset of the TSDF facility\'s permitted waste codes, tailored to the buyer\'s typical contamination profile.' ;
    rdfs:domain ind:BuyerTsdfReturnAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnAuthorizationRequired rdf:type rdf:Property ;
    rdfs:label 'Return Authorization Required' ;
    rdfs:comment 'Indicates whether the commodity buyer must provide explicit written authorization before contaminated material can be sent to this TSDF facility. Affects operational workflow and liability.' ;
    rdfs:domain ind:BuyerTsdfReturnAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transporterAuthorizationId rdf:type rdf:Property ;
    rdfs:label 'Transporter Authorization Id' ;
    rdfs:comment 'Unique surrogate identifier for this customer-transporter authorization record. Primary key for the association.' ;
    rdfs:domain ind:TransporterAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:authorizedByName rdf:type rdf:Property ;
    rdfs:label 'Authorized By Name' ;
    rdfs:comment 'Full name of the Waste Management employee or customer representative who approved this transporter authorization. Required for audit trail and regulatory compliance.' ;
    rdfs:domain ind:TransporterAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Insurance Verification Date' ;
    rdfs:comment 'Date when the customer last verified that this transporter\'s liability insurance meets the customer\'s requirements for this authorization. Customers may have insurance requirements beyond EPA minimums.' ;
    rdfs:domain ind:TransporterAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preferredTransporterFlag rdf:type rdf:Property ;
    rdfs:label 'Preferred Transporter Flag' ;
    rdfs:comment 'Indicates whether this transporter is a preferred carrier for this customer account. Preferred transporters receive priority consideration during manifest generation and route optimization. Each customer may have multiple preferred transporters for different waste types or geographic regions.' ;
    rdfs:domain ind:TransporterAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rateAgreementReference rdf:type rdf:Property ;
    rdfs:label 'Rate Agreement Reference' ;
    rdfs:comment 'Reference identifier to the negotiated rate agreement or contract between this customer and this transporter. Links to contract management system or pricing tables for customer-specific transportation rates.' ;
    rdfs:domain ind:TransporterAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriptionId rdf:type rdf:Property ;
    rdfs:label 'Subscription Id' ;
    rdfs:comment 'Unique surrogate identifier for this service subscription record. Primary key.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountCustomerAccountId rdf:type rdf:Property ;
    rdfs:label 'Account Customer Account Id' ;
    rdfs:comment 'Foreign key linking to the customer account that holds this service subscription' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerAccount .

ind:cancellationReasonCode rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason Code' ;
    rdfs:comment 'Reason code for subscription cancellation. Null for active subscriptions. Used for churn analysis and retention strategy.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractTermMonths rdf:type rdf:Property ;
    rdfs:label 'Contract Term Months' ;
    rdfs:comment 'Duration in months of the contract term for this specific subscription. May differ from the offerings default minimum term due to negotiated agreements. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:monthlyRate rdf:type rdf:Property ;
    rdfs:label 'Monthly Rate' ;
    rdfs:comment 'Contracted monthly rate for this customer-offering subscription, which may differ from the base price due to negotiated discounts, volume pricing, or promotional rates. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricingTierOverride rdf:type rdf:Property ;
    rdfs:label 'Pricing Tier Override' ;
    rdfs:comment 'Optional pricing tier override for this specific subscription if the customer negotiated special pricing that differs from their account-level tier.' ;
    rdfs:domain ind:Subscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityAccessAuthorizationId rdf:type rdf:Property ;
    rdfs:label 'Facility Access Authorization Id' ;
    rdfs:comment 'Unique identifier for this customer-facility access authorization record. Primary key.' ;
    rdfs:domain ind:FacilityAccessAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryCount rdf:type rdf:Property ;
    rdfs:label 'Delivery Count' ;
    rdfs:comment 'Total number of waste deliveries from this customer account to this facility since authorization. Incremented by delivery transaction systems. Used for customer-facility relationship analytics.' ;
    rdfs:domain ind:FacilityAccessAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preferredFacilityRank rdf:type rdf:Property ;
    rdfs:label 'Preferred Facility Rank' ;
    rdfs:comment 'Ranking of this facility in the customer\'s preference order (1 = most preferred). Used by routing systems to optimize delivery assignments when multiple authorized facilities are available.' ;
    rdfs:domain ind:FacilityAccessAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tippingFeeOverride rdf:type rdf:Property ;
    rdfs:label 'Tipping Fee Override' ;
    rdfs:comment 'Customer-specific tipping fee per ton for deliveries to this facility, overriding the facility\'s standard rate. Null if standard facility rate applies. Used for negotiated pricing agreements with large commercial/industrial customers.' ;
    rdfs:domain ind:FacilityAccessAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerBuyerContractId rdf:type rdf:Property ;
    rdfs:label 'Customer Buyer Contract Id' ;
    rdfs:comment 'Primary key for customer_buyer_contract' ;
    rdfs:domain ind:CustomerBuyerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:buyerContractId rdf:type rdf:Property ;
    rdfs:label 'Buyer Contract Id' ;
    rdfs:comment 'Unique identifier for this buyer contract record. Primary key for the association.' ;
    rdfs:domain ind:CustomerBuyerContract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contract .

ind:qualityGradeRequirement rdf:type rdf:Property ;
    rdfs:label 'Quality Grade Requirement' ;
    rdfs:comment 'Quality specification or grade standard required by this buyer for materials supplied under this contract (e.g., ISRI specs, contamination thresholds). Explicitly identified in detection phase as relationship data.' ;
    rdfs:domain ind:CustomerBuyerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:districtProgramParticipationId rdf:type rdf:Property ;
    rdfs:label 'District Program Participation Id' ;
    rdfs:comment 'Unique identifier for this district-program participation record. Primary key.' ;
    rdfs:domain ind:DistrictProgramParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:collectionDistrictId rdf:type rdf:Property ;
    rdfs:label 'Collection District Id' ;
    rdfs:comment 'Foreign key linking to the collection district participating in the circular economy program' ;
    rdfs:domain ind:DistrictProgramParticipation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:District .

ind:districtProgramManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'District Program Manager Employee Id' ;
    rdfs:comment 'Reference to the employee responsible for managing this program\'s operations in this specific district. May be the district operations manager or a dedicated program coordinator.' ;
    rdfs:domain ind:DistrictProgramParticipation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualDiversionTons rdf:type rdf:Property ;
    rdfs:label 'Actual Diversion Tons' ;
    rdfs:comment 'The actual volume of material diverted from landfill through this program in this district. Explicitly identified in detection phase relationship data. Used for performance tracking and ESG reporting.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerEnrollmentCount rdf:type rdf:Property ;
    rdfs:label 'Customer Enrollment Count' ;
    rdfs:comment 'The number of customers in this district who are enrolled in this circular economy program. Explicitly identified in detection phase relationship data. Used to calculate participation rate and track program adoption.' ;
    rdfs:domain ind:DistrictProgramParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:participationRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Participation Rate Percentage' ;
    rdfs:comment 'The percentage of eligible customers in this district who are actively participating in this program. Explicitly identified in detection phase relationship data. Used for program performance measurement.' ;
    rdfs:domain ind:DistrictProgramParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:programLaunchDate rdf:type rdf:Property ;
    rdfs:label 'Program Launch Date' ;
    rdfs:comment 'The date when this circular economy program was launched in this specific collection district. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:DistrictProgramParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:driverInitiativeParticipationId rdf:type rdf:Property ;
    rdfs:label 'Driver Initiative Participation Id' ;
    rdfs:comment 'Unique identifier for this driver-initiative participation record. Primary key for the association.' ;
    rdfs:domain ind:DriverInitiativeParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:behaviorScoreBaseline rdf:type rdf:Property ;
    rdfs:label 'Behavior Score Baseline' ;
    rdfs:comment 'Driver\'s baseline eco-driving behavior score measured before participation in this initiative. Used to calculate improvement and initiative effectiveness. Scale typically 0-100.' ;
    rdfs:domain ind:DriverInitiativeParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:behaviorScoreCurrent rdf:type rdf:Property ;
    rdfs:label 'Behavior Score Current' ;
    rdfs:comment 'Driver\'s current eco-driving behavior score while participating in this initiative. Updated periodically based on telematics data. Scale typically 0-100.' ;
    rdfs:domain ind:DriverInitiativeParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:co2eReductionContributionTons rdf:type rdf:Property ;
    rdfs:label 'Co2e Reduction Contribution Tons' ;
    rdfs:comment 'Estimated metric tons of CO2 equivalent emissions reduced by this specific driver\'s participation in this initiative. Aggregated across all drivers to measure total initiative impact.' ;
    rdfs:domain ind:DriverInitiativeParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelEfficiencyImprovementPercent rdf:type rdf:Property ;
    rdfs:label 'Fuel Efficiency Improvement Percent' ;
    rdfs:comment 'Percentage improvement in fuel efficiency achieved by this driver through participation in this initiative, calculated as (current_mpg - baseline_mpg) / baseline_mpg * 100. Used for ROI calculation and driver performance tracking.' ;
    rdfs:domain ind:DriverInitiativeParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:idleTimeReductionPercent rdf:type rdf:Property ;
    rdfs:label 'Idle Time Reduction Percent' ;
    rdfs:comment 'Percentage reduction in vehicle idle time achieved by this driver through participation in idle reduction initiatives. Calculated from telematics data comparing baseline to current period.' ;
    rdfs:domain ind:DriverInitiativeParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incentiveEarnedAmount rdf:type rdf:Property ;
    rdfs:label 'Incentive Earned Amount' ;
    rdfs:comment 'Total monetary incentive or bonus earned by this driver for achieving performance targets in this carbon initiative. Used for driver engagement and program ROI tracking.' ;
    rdfs:domain ind:DriverInitiativeParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextPerformanceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Performance Review Date' ;
    rdfs:comment 'Scheduled date for the next performance review of this driver\'s participation in this initiative.' ;
    rdfs:domain ind:DriverInitiativeParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:participationStatus rdf:type rdf:Property ;
    rdfs:label 'Participation Status' ;
    rdfs:comment 'Current status of the driver\'s participation in this initiative: enrolled (registered but not started), active (currently participating), completed (finished program), withdrawn (voluntarily left), suspended (temporarily inactive).' ;
    rdfs:domain ind:DriverInitiativeParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityInitiativeParticipationId rdf:type rdf:Property ;
    rdfs:label 'Facility Initiative Participation Id' ;
    rdfs:comment 'Unique system-generated identifier for each facility-initiative participation record' ;
    rdfs:domain ind:FacilityInitiativeParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualReductionTons rdf:type rdf:Property ;
    rdfs:label 'Actual Reduction Tons' ;
    rdfs:comment 'Actual measured annual CO2e reduction in metric tons achieved at this facility after initiative implementation. Null until post-implementation measurement is completed.' ;
    rdfs:domain ind:FacilityInitiativeParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baselineEmissionsTons rdf:type rdf:Property ;
    rdfs:label 'Baseline Emissions Tons' ;
    rdfs:comment 'Facility-specific baseline annual emissions in metric tons CO2e measured prior to initiative implementation, used to calculate actual reduction achieved at this facility.' ;
    rdfs:domain ind:FacilityInitiativeParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:facilityContributionCo2eTons rdf:type rdf:Property ;
    rdfs:label 'Facility Contribution Co2e Tons' ;
    rdfs:comment 'Projected or actual annual CO2e reduction in metric tons attributable to this specific facility\'s participation in this initiative. Facility-level contribution that rolls up to the initiative\'s total target_co2e_reduction_tons.' ;
    rdfs:domain ind:FacilityInitiativeParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:facilityInvestmentAmount rdf:type rdf:Property ;
    rdfs:label 'Facility Investment Amount' ;
    rdfs:comment 'Capital investment allocated to this specific facility for implementing this carbon initiative. Facility-level investment that rolls up to the initiative\'s total capital_investment_amount.' ;
    rdfs:domain ind:FacilityInitiativeParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:facilityProjectManager rdf:type rdf:Property ;
    rdfs:label 'Facility Project Manager' ;
    rdfs:comment 'Name of the facility-level project manager or site lead responsible for implementing this initiative at this specific MRF facility.' ;
    rdfs:domain ind:FacilityInitiativeParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityRoleInInitiative rdf:type rdf:Property ;
    rdfs:label 'Facility Role In Initiative' ;
    rdfs:comment 'Role or phase designation for this facility within the initiative. Values include: pilot (testing/proof-of-concept site), full_implementation (standard rollout), phase_1/phase_2 (staged deployment), control_group (baseline comparison facility).' ;
    rdfs:domain ind:FacilityInitiativeParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implementationNotes rdf:type rdf:Property ;
    rdfs:label 'Implementation Notes' ;
    rdfs:comment 'Free-text notes capturing facility-specific implementation details, challenges, lessons learned, or deviations from standard initiative approach.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:participationEndDate rdf:type rdf:Property ;
    rdfs:label 'Participation End Date' ;
    rdfs:comment 'Date when this specific MRF facility completed implementation of this carbon initiative or ceased participation. Null if participation is ongoing.' ;
    rdfs:domain ind:FacilityInitiativeParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:participationStartDate rdf:type rdf:Property ;
    rdfs:label 'Participation Start Date' ;
    rdfs:comment 'Date when this specific MRF facility began participating in or implementing this carbon initiative. May differ from the initiative\'s overall planned_start_date due to phased rollout across facilities.' ;
    rdfs:domain ind:FacilityInitiativeParticipation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:offeringComplianceId rdf:type rdf:Property ;
    rdfs:label 'Offering Compliance Id' ;
    rdfs:comment 'Unique identifier for this offering-requirement compliance record. Primary key.' ;
    rdfs:domain ind:OfferingCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicabilityNotes rdf:type rdf:Property ;
    rdfs:label 'Applicability Notes' ;
    rdfs:comment 'Free-text notes explaining how and why this regulatory requirement applies to this specific service offering, including any special conditions, exemptions, or interpretations relevant to this pairing.' ;
    rdfs:domain ind:OfferingCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentationReference rdf:type rdf:Property ;
    rdfs:label 'Documentation Reference' ;
    rdfs:comment 'Reference to compliance documentation, evidence, or records demonstrating how this service offering meets this regulatory requirement (e.g., permit numbers, certification IDs, document management system references, audit report IDs).' ;
    rdfs:domain ind:OfferingCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonComplianceRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Non Compliance Risk Level' ;
    rdfs:comment 'Risk severity classification for non-compliance with this requirement for this offering (Critical, High, Medium, Low), considering potential penalties, operational impact, and reputational risk.' ;
    rdfs:domain ind:OfferingCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentId rdf:type rdf:Property ;
    rdfs:label 'Assignment Id' ;
    rdfs:comment 'Unique identifier for the employee-to-service-offering assignment record. Primary key.' ;
    rdfs:domain ind:Assignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Flag' ;
    rdfs:comment 'Indicates whether this service offering is the employee\'s primary assignment or specialty. Used for workforce planning and scheduling prioritization.' ;
    rdfs:domain ind:Assignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:proficiencyLevel rdf:type rdf:Property ;
    rdfs:label 'Proficiency Level' ;
    rdfs:comment 'Employee\'s proficiency or skill level for delivering this specific service offering. Used for route assignment optimization, quality assurance, and training needs assessment. Values: Trainee, Qualified, Proficient, Expert, Master.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offeringSafetyComplianceId rdf:type rdf:Property ;
    rdfs:label 'Offering Safety Compliance Id' ;
    rdfs:comment 'Unique identifier for this offering-safety program compliance record. Primary key.' ;
    rdfs:domain ind:OfferingSafetyCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditFrequencyOverride rdf:type rdf:Property ;
    rdfs:label 'Audit Frequency Override' ;
    rdfs:comment 'Override value in months for audit frequency specific to this offering-program combination. When set, overrides the default audit_frequency_months from the safety_program. Used when certain high-risk offerings require more frequent audits for specific programs.' ;
    rdfs:domain ind:OfferingSafetyCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastComplianceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Compliance Review Date' ;
    rdfs:comment 'Most recent date when compliance of this service offering with this safety program was formally reviewed by EHS staff or auditors. Used to track review currency.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextComplianceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Compliance Review Date' ;
    rdfs:comment 'Scheduled date for the next formal compliance review of this offering-program combination. Calculated based on last review date and audit frequency.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trainingCompletionRate rdf:type rdf:Property ;
    rdfs:label 'Training Completion Rate' ;
    rdfs:comment 'Percentage of employees working on this service offering who have completed the required training for this safety program. Calculated as (trained_employees / total_employees_on_offering) * 100.' ;
    rdfs:domain ind:OfferingSafetyCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplyAgreementId rdf:type rdf:Property ;
    rdfs:label 'Supply Agreement Id' ;
    rdfs:comment 'Unique surrogate identifier for each supply agreement record' ;
    rdfs:domain ind:SupplyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastPurchaseCost rdf:type rdf:Property ;
    rdfs:label 'Last Purchase Cost' ;
    rdfs:comment 'Most recent actual purchase price per unit paid to a supplier. Used for cost trend analysis, standard cost updates, and procurement benchmarking. Expressed in USD. [Moved from parts_catalog: This attribute captures the most recent purchase price, but it doesn\'t indicate which vendor that price came from. In a multi-vendor sourcing model, procurement needs to track the current price from EACH vendor, not just the last price paid. This should move to supply_agreement as unit_price, allowing procurement to compare vendor pricing.]' ;
    rdfs:domain ind:SupplyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastPurchaseDate rdf:type rdf:Property ;
    rdfs:label 'Last Purchase Date' ;
    rdfs:comment 'Most recent date when this part was purchased from this specific vendor. Used to track active supply relationships and identify stale source list entries.' ;
    rdfs:domain ind:SupplyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preferredSupplierFlag rdf:type rdf:Property ;
    rdfs:label 'Preferred Supplier Flag' ;
    rdfs:comment 'Indicates whether this vendor is the preferred/primary supplier for this part. Used by procurement to prioritize vendor selection when multiple sources are available. Only one vendor per part should be marked preferred.' ;
    rdfs:domain ind:SupplyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supplierPartNumber rdf:type rdf:Property ;
    rdfs:label 'Supplier Part Number' ;
    rdfs:comment 'The part number used by the preferred supplier in their catalog. Required for accurate purchase order line items and supplier communication. Corresponds to the Info Record in SAP MM. [Moved from parts_catalog: This attribute stores the part number used by the preferred supplier, but each vendor may use a different part number for the same part in their catalog. This is vendor-specific data that belongs in the supply_agreement association, not in the parts_catalog master record.]' ;
    rdfs:domain ind:SupplyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programTargetContributionId rdf:type rdf:Property ;
    rdfs:label 'Program Target Contribution Id' ;
    rdfs:comment 'Unique surrogate identifier for the program-target contribution record. Primary key.' ;
    rdfs:domain ind:ProgramTargetContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualContributionValue rdf:type rdf:Property ;
    rdfs:label 'Actual Contribution Value' ;
    rdfs:comment 'The actual measured contribution value that this program has delivered toward the target, expressed in the target\'s unit of measure. Updated periodically based on operational data from the recycling program.' ;
    rdfs:domain ind:ProgramTargetContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:alignmentEndDate rdf:type rdf:Property ;
    rdfs:label 'Alignment End Date' ;
    rdfs:comment 'The date when this recycling program stopped or is scheduled to stop contributing toward this sustainability target. Null for ongoing contributions. Used when programs are retired or removed from target scope.' ;
    rdfs:domain ind:ProgramTargetContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:alignmentStartDate rdf:type rdf:Property ;
    rdfs:label 'Alignment Start Date' ;
    rdfs:comment 'The date when this recycling program began contributing toward this specific sustainability target. May differ from program start date if target was established later or program was added to target scope after launch.' ;
    rdfs:domain ind:ProgramTargetContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contributionMethodology rdf:type rdf:Property ;
    rdfs:label 'Contribution Methodology' ;
    rdfs:comment 'Description of the calculation methodology used to determine this program\'s contribution to the target. May reference specific formulas, data sources, or allocation methods used for this program-target combination.' ;
    rdfs:domain ind:ProgramTargetContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contributionPercentage rdf:type rdf:Property ;
    rdfs:label 'Contribution Percentage' ;
    rdfs:comment 'The percentage of the overall target achievement that this specific recycling program is expected to contribute. Used for proportional allocation of target responsibility across multiple programs.' ;
    rdfs:domain ind:ProgramTargetContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastMeasurementDate rdf:type rdf:Property ;
    rdfs:label 'Last Measurement Date' ;
    rdfs:comment 'The date when the actual contribution value was last calculated and updated. Used to track data freshness for sustainability reporting and to schedule next measurement cycle.' ;
    rdfs:domain ind:ProgramTargetContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingStatus rdf:type rdf:Property ;
    rdfs:label 'Reporting Status' ;
    rdfs:comment 'Current status of this program\'s contribution reporting for this target. Active indicates ongoing tracking and reporting. Pending indicates contribution not yet started. Suspended indicates temporary exclusion. Completed indicates target achieved or program contribution ended. Excluded indicates program removed from target scope.' ;
    rdfs:domain ind:ProgramTargetContribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatServiceScheduleId rdf:type rdf:Property ;
    rdfs:label 'Hazmat Service Schedule Id' ;
    rdfs:comment 'Unique identifier for this route-generator service schedule record. Primary key.' ;
    rdfs:domain ind:HazmatServiceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedPickupTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Estimated Pickup Time Minutes' ;
    rdfs:comment 'Estimated time in minutes required to complete pickup at this generator location, including container handling, manifest completion, and safety procedures. Used for route time planning.' ;
    rdfs:domain ind:HazmatServiceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextServiceDate rdf:type rdf:Property ;
    rdfs:label 'Next Service Date' ;
    rdfs:comment 'The next planned service date for this generator on this route. Calculated based on service frequency and last service date, adjusted for regulatory accumulation limits.' ;
    rdfs:domain ind:HazmatServiceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customerServiceCommitmentId rdf:type rdf:Property ;
    rdfs:label 'Customer Service Commitment Id' ;
    rdfs:comment 'Primary key for customer_service_commitment' ;
    rdfs:domain ind:CustomerServiceCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceCommitmentId rdf:type rdf:Property ;
    rdfs:label 'Service Commitment Id' ;
    rdfs:comment 'Unique system-generated identifier for each service commitment record linking a service address to a contract' ;
    rdfs:domain ind:CustomerServiceCommitment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContractServiceCommitment .

ind:billingAccountOverride rdf:type rdf:Property ;
    rdfs:label 'Billing Account Override' ;
    rdfs:comment 'Optional override billing account for this specific service commitment. Used when a multi-site contract requires individual addresses to bill to different cost centers or subsidiaries. Nullable if contract customer_account_id applies.' ;
    rdfs:domain ind:CustomerServiceCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:containerAllocation rdf:type rdf:Property ;
    rdfs:label 'Container Allocation' ;
    rdfs:comment 'Comma-delimited list of container types and quantities allocated to this address under this specific contract (e.g., \'2x96gal-carts,1x8yd-dumpster\'). Tracks which containers are deployed under which contractual agreement when an address has multiple concurrent contracts for different waste streams.' ;
    rdfs:domain ind:CustomerServiceCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateOverride rdf:type rdf:Property ;
    rdfs:label 'Rate Override' ;
    rdfs:comment 'Location-specific service rate that overrides the contract base_service_rate. Used when individual addresses within a master contract have negotiated different pricing based on volume, accessibility, or service complexity. Nullable if contract base rate applies.' ;
    rdfs:domain ind:CustomerServiceCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerStopId rdf:type rdf:Property ;
    rdfs:label 'Customer Stop Id' ;
    rdfs:comment 'Primary key for customer_stop' ;
    rdfs:domain ind:CustomerStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stopId rdf:type rdf:Property ;
    rdfs:label 'Stop Id' ;
    rdfs:comment 'Unique identifier for this route stop assignment. Primary key.' ;
    rdfs:domain ind:CustomerStop ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CollectionStop .

ind:estimatedServiceTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Estimated Service Time Minutes' ;
    rdfs:comment 'Expected time in minutes to complete service at this stop, used for route duration planning and optimization.' ;
    rdfs:domain ind:CustomerStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:routeZoneCode rdf:type rdf:Property ;
    rdfs:label 'Route Zone Code' ;
    rdfs:comment 'Operational route zone identifier assigned to this service address by the AMCS Platform or Locus Dispatch system. Determines which collection route and crew services this location. Critical for route optimization, driver assignment, and service scheduling. [Moved from service_address: This attribute currently exists on service_address but represents the operational assignment to a route zone, which is a collection planning concept. It should be derived from the stop-route relationship rather than stored redundantly on the address.]' ;
    rdfs:domain ind:CustomerStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceDay rdf:type rdf:Property ;
    rdfs:label 'Service Day' ;
    rdfs:comment 'Day of the week on which waste collection or environmental services are regularly scheduled at this address. Used by AMCS Platform and Locus Dispatch for route planning and customer communication. [Moved from service_address: This attribute currently exists on service_address but represents when collection occurs, which depends on which route services the address. Since an address can be serviced by multiple routes (different waste streams, seasonal routes), this belongs on the stop association as service_day_of_week.] [ENUM-REF-CANDIDATE: monday|tuesday|wednesday|thursday|friday|saturday|sunday — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CustomerStop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalNetworkId rdf:type rdf:Property ;
    rdfs:label 'Disposal Network Id' ;
    rdfs:comment 'Unique identifier for this service area to landfill site disposal network configuration record. Primary key.' ;
    rdfs:domain ind:DisposalNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:configurationStatus rdf:type rdf:Property ;
    rdfs:label 'Configuration Status' ;
    rdfs:comment 'Current operational status of this disposal network configuration. Active configurations are in use for routing decisions. Suspended configurations are temporarily inactive but may be reactivated. Planned configurations are approved but not yet effective. Retired configurations are historical records.' ;
    rdfs:domain ind:DisposalNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designationType rdf:type rdf:Property ;
    rdfs:label 'Designation Type' ;
    rdfs:comment 'Classification of the site\'s role in serving this service area. Primary sites receive the majority of tonnage under normal operations. Secondary sites provide overflow capacity. Backup sites are used when primary is unavailable. Seasonal sites handle peak volume periods. Emergency sites are contingency options.' ;
    rdfs:domain ind:DisposalNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedAnnualTonnage rdf:type rdf:Property ;
    rdfs:label 'Estimated Annual Tonnage' ;
    rdfs:comment 'Projected annual tonnage in short tons expected to be disposed from this service area to this site under normal operating conditions. Used for site capacity planning, host community agreement compliance, and financial forecasting. Updated annually during budget planning cycles.' ;
    rdfs:domain ind:DisposalNetwork ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:areaRegulatoryComplianceId rdf:type rdf:Property ;
    rdfs:label 'Area Regulatory Compliance Id' ;
    rdfs:comment 'Primary key for the area_regulatory_compliance association' ;
    rdfs:domain ind:AreaRegulatoryCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:enforcementAuthority rdf:type rdf:Property ;
    rdfs:label 'Enforcement Authority' ;
    rdfs:comment 'The name of the specific regulatory agency or local enforcement authority responsible for enforcing this requirement in this service area. May be the LEA (Local Enforcement Agency), county health department, state environmental agency, or EPA regional office depending on jurisdiction.' ;
    rdfs:domain ind:AreaRegulatoryCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionLevel rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Level' ;
    rdfs:comment 'The specific jurisdictional level at which this requirement applies to this service area (Federal, State, County, Municipal, Local). A service area may be subject to the same requirement at multiple jurisdictional levels with different enforcement authorities.' ;
    rdfs:domain ind:AreaRegulatoryCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingDeadline rdf:type rdf:Property ;
    rdfs:label 'Reporting Deadline' ;
    rdfs:comment 'The specific reporting deadline or schedule for compliance reporting to the enforcement authority for this service area. May be expressed as a date, day-of-month, or relative deadline (e.g., \'30 days after quarter end\').' ;
    rdfs:domain ind:AreaRegulatoryCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundleCompositionId rdf:type rdf:Property ;
    rdfs:label 'Bundle Composition Id' ;
    rdfs:comment 'Unique identifier for this bundle composition record. Primary key.' ;
    rdfs:domain ind:BundleComposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceBundleId rdf:type rdf:Property ;
    rdfs:label 'Service Bundle Id' ;
    rdfs:comment 'Foreign key to service_bundle. Identifies which bundle this composition record belongs to.' ;
    rdfs:domain ind:BundleComposition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Bundle .

ind:bundlePriceOverride rdf:type rdf:Property ;
    rdfs:label 'Bundle Price Override' ;
    rdfs:comment 'Bundle-specific price override for this offering component. Null if standard offering price applies. Allows bundle-specific pricing that differs from standalone offering price. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:BundleComposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inclusionType rdf:type rdf:Property ;
    rdfs:label 'Inclusion Type' ;
    rdfs:comment 'Classification of how this offering is included in the bundle: included (part of base bundle), add-on (additional charge), optional (customer choice), discounted (reduced price). Derived from service_bundle.bundle_description mention of \'included, add-on, discounted\'.' ;
    rdfs:domain ind:BundleComposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPrimaryServiceFlag rdf:type rdf:Property ;
    rdfs:label 'Is Primary Service Flag' ;
    rdfs:comment 'Indicates whether this offering is the primary/anchor service in the bundle versus an add-on or supplementary service. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:BundleComposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incidentResponseAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Incident Response Assignment Id' ;
    rdfs:comment 'Unique surrogate identifier for each incident response assignment record linking a technician to an emergency incident' ;
    rdfs:domain ind:IncidentResponseAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certificationVerified rdf:type rdf:Property ;
    rdfs:label 'Certification Verified' ;
    rdfs:comment 'Indicates whether the technician\'s HAZWOPER certification was verified as current and valid before deployment to this emergency incident, required for regulatory compliance' ;
    rdfs:domain ind:IncidentResponseAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exposureLevel rdf:type rdf:Property ;
    rdfs:label 'Exposure Level' ;
    rdfs:comment 'Classification of the technician\'s exposure level to hazardous materials during this incident response (none, minimal, moderate, significant), used for medical monitoring requirements and workers compensation documentation' ;
    rdfs:domain ind:IncidentResponseAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentReportSubmitted rdf:type rdf:Property ;
    rdfs:label 'Incident Report Submitted' ;
    rdfs:comment 'Indicates whether this technician submitted their individual incident response report documenting actions taken and observations made during the emergency response' ;
    rdfs:domain ind:IncidentResponseAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:medicalClearanceVerified rdf:type rdf:Property ;
    rdfs:label 'Medical Clearance Verified' ;
    rdfs:comment 'Indicates whether the technician\'s medical clearance for hazmat response work was verified as current before deployment to this incident' ;
    rdfs:domain ind:IncidentResponseAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responseRole rdf:type rdf:Property ;
    rdfs:label 'Response Role' ;
    rdfs:comment 'The specific role this technician performed during the emergency response incident (e.g., incident commander, hazmat specialist, equipment operator, decontamination technician, safety officer, support crew)' ;
    rdfs:domain ind:IncidentResponseAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stationWasteCodePermitId rdf:type rdf:Property ;
    rdfs:label 'Station Waste Code Permit Id' ;
    rdfs:comment 'Unique identifier for this transfer station waste code permit authorization record. Primary key.' ;
    rdfs:domain ind:StationWasteCodePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:handlingRestrictions rdf:type rdf:Property ;
    rdfs:label 'Handling Restrictions' ;
    rdfs:comment 'Specific operational restrictions or handling requirements for this waste code at this transfer station (e.g., \'segregated storage required\', \'no mixing with other waste streams\', \'trained personnel only\').' ;
    rdfs:domain ind:StationWasteCodePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumDailyQuantity rdf:type rdf:Property ;
    rdfs:label 'Maximum Daily Quantity' ;
    rdfs:comment 'Maximum quantity in tons per day of this specific waste code that this transfer station is permitted to accept under regulatory limits.' ;
    rdfs:domain ind:StationWasteCodePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:permitReference rdf:type rdf:Property ;
    rdfs:label 'Permit Reference' ;
    rdfs:comment 'Specific permit amendment, condition number, or regulatory reference that authorizes acceptance of this waste code at this facility.' ;
    rdfs:domain ind:StationWasteCodePermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityStaffingAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Facility Staffing Assignment Id' ;
    rdfs:comment 'Unique identifier for the facility staffing assignment record. Primary key for the association.' ;
    rdfs:domain ind:FacilityStaffingAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignmentEndDate rdf:type rdf:Property ;
    rdfs:label 'Assignment End Date' ;
    rdfs:comment 'Date when the employee assignment to this transfer station facility ended. Null for active assignments. Used for historical tracking and rotation analysis.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assignmentStartDate rdf:type rdf:Property ;
    rdfs:label 'Assignment Start Date' ;
    rdfs:comment 'Date when the employee assignment to this transfer station facility became effective. Critical for tracking assignment history and coverage periods.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationRequired rdf:type rdf:Property ;
    rdfs:label 'Certification Required' ;
    rdfs:comment 'Facility-specific certification or training required for this role at this transfer station. May vary by facility type (MSW vs C&D vs hazmat-permitted facilities). Examples: \'Hazmat Handler Certification\', \'Scale Operator Certification\', \'Facility-Specific Safety Training\'.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationVerifiedDate rdf:type rdf:Property ;
    rdfs:label 'Certification Verified Date' ;
    rdfs:comment 'Date when the required facility-specific certification was verified for this employee at this facility. Used for compliance audits and assignment eligibility validation.' ;
    rdfs:domain ind:FacilityStaffingAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:primaryFacilityFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Facility Flag' ;
    rdfs:comment 'Indicates whether this transfer station is the employee\'s primary/home facility. An employee may be assigned to multiple facilities for cross-training or coverage, but typically has one primary facility. Used for reporting and scheduling prioritization.' ;
    rdfs:domain ind:FacilityStaffingAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:role rdf:type rdf:Property ;
    rdfs:label 'Role' ;
    rdfs:comment 'Specific operational role the employee performs at this transfer station facility. Same employee may have different roles at different facilities. Examples: WEIGHMASTER (operates truck scales), TIPPING_FLOOR_OPERATOR (manages waste unloading), FACILITY_SUPERVISOR (oversees operations), SCALE_OPERATOR, EQUIPMENT_OPERATOR (loader/compactor), SPOTTER (directs truck traffic), SAFETY_COORDINATOR.' ;
    rdfs:domain ind:FacilityStaffingAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftPattern rdf:type rdf:Property ;
    rdfs:label 'Shift Pattern' ;
    rdfs:comment 'Standard shift pattern for this employee at this facility. Used for scheduling and coverage planning. Values: DAY_SHIFT (typically 6am-2pm), NIGHT_SHIFT (2pm-10pm), SWING_SHIFT (10pm-6am), ROTATING (alternates between shifts), WEEKEND_ONLY, ON_CALL (backup coverage).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transporterServiceAuthorizationId rdf:type rdf:Property ;
    rdfs:label 'Transporter Service Authorization Id' ;
    rdfs:comment 'Unique identifier for the transporter service authorization record. Primary key.' ;
    rdfs:domain ind:TransporterServiceAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastUsedDate rdf:type rdf:Property ;
    rdfs:label 'Last Used Date' ;
    rdfs:comment 'Date when this transporter was last used for a shipment originating in this service area. Used for performance tracking and vendor relationship management.' ;
    rdfs:domain ind:TransporterServiceAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rateScheduleReference rdf:type rdf:Property ;
    rdfs:label 'Rate Schedule Reference' ;
    rdfs:comment 'Reference to the rate schedule or pricing agreement applicable to this transporter in this service area. Rates may vary by geography due to distance, regulatory complexity, or competitive factors.' ;
    rdfs:domain ind:TransporterServiceAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingProgramEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Billing Program Enrollment Id' ;
    rdfs:comment 'Primary key for billing_program_enrollment' ;
    rdfs:domain ind:BillingProgramEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountBillingAccountId rdf:type rdf:Property ;
    rdfs:label 'Account Billing Account Id' ;
    rdfs:comment 'Foreign key linking to the billing account enrolled in the program' ;
    rdfs:domain ind:BillingProgramEnrollment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BillingAccount .

ind:incentiveAmount rdf:type rdf:Property ;
    rdfs:label 'Incentive Amount' ;
    rdfs:comment 'The financial incentive amount (in USD) provided to the customer for participation in this program. May be a rebate, credit, or performance-based payment.' ;
    rdfs:domain ind:BillingProgramEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceTarget rdf:type rdf:Property ;
    rdfs:label 'Performance Target' ;
    rdfs:comment 'The customer-specific diversion or participation target (in tons) for this enrollment. Used to measure customer performance against commitments.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cellEquipmentAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Cell Equipment Assignment Id' ;
    rdfs:comment 'Unique identifier for each cell-equipment assignment record. Primary key for the association.' ;
    rdfs:domain ind:CellEquipmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:costCenterOverride rdf:type rdf:Property ;
    rdfs:label 'Cost Center Override' ;
    rdfs:comment 'Optional cost center override for this specific cell-equipment assignment. When populated, overrides the equipment\'s default cost center for expenses incurred during this assignment period. Used for project-specific cost tracking.' ;
    rdfs:domain ind:CellEquipmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationalRole rdf:type rdf:Property ;
    rdfs:label 'Operational Role' ;
    rdfs:comment 'The specific operational function this equipment performs in this cell assignment. Examples: compaction (waste compactors), dozing (bulldozers for spreading), grading (final surface preparation), water_truck (dust control), support (auxiliary equipment). Same equipment may have different roles in different cells.' ;
    rdfs:domain ind:CellEquipmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryEquipmentFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Equipment Flag' ;
    rdfs:comment 'Indicates whether this equipment is designated as the primary unit for this cell (true) or backup/supplemental equipment (false). Used for capacity planning and operational scheduling.' ;
    rdfs:domain ind:CellEquipmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:utilizationHours rdf:type rdf:Property ;
    rdfs:label 'Utilization Hours' ;
    rdfs:comment 'Total operational hours the equipment has been utilized in this specific cell during the assignment period. Used for cell-specific cost allocation, equipment performance analysis, and maintenance scheduling.' ;
    rdfs:domain ind:CellEquipmentAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cellPermitAuthorizationId rdf:type rdf:Property ;
    rdfs:label 'Cell Permit Authorization Id' ;
    rdfs:comment 'Unique identifier for this cell-permit authorization record. Primary key for the association.' ;
    rdfs:domain ind:CellPermitAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:authorizationNotes rdf:type rdf:Property ;
    rdfs:label 'Authorization Notes' ;
    rdfs:comment 'Free-text notes documenting special circumstances, modifications, or clarifications related to this cell-permit authorization. Used by compliance officers to track authorization history, regulatory correspondence, or operational considerations.' ;
    rdfs:domain ind:CellPermitAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizationType rdf:type rdf:Property ;
    rdfs:label 'Authorization Type' ;
    rdfs:comment 'Classification of what phase or activity this permit authorizes for the cell. Distinguishes between construction permits (authorizing cell construction), operation permits (authorizing waste placement), expansion permits (authorizing cell expansion), closure permits (authorizing final closure activities), and post-closure permits (authorizing post-closure monitoring and maintenance).' ;
    rdfs:domain ind:CellPermitAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedWasteTypes rdf:type rdf:Property ;
    rdfs:label 'Authorized Waste Types' ;
    rdfs:comment 'Comma-separated list of waste types that this specific permit authorizes for placement in this specific cell. May be a subset of both the cell\'s permitted_waste_types and the permit\'s overall scope, representing the intersection of what the cell can accept and what this permit authorizes.' ;
    rdfs:domain ind:CellPermitAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityLimit rdf:type rdf:Property ;
    rdfs:label 'Capacity Limit' ;
    rdfs:comment 'Maximum waste capacity (in cubic yards or tons) authorized for this cell under this specific permit. Tracks permit-specific capacity allocations when multiple permits authorize the same cell with different capacity limits or when a permit authorizes only a portion of the cell\'s total design capacity.' ;
    rdfs:domain ind:CellPermitAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:permitIssueDate rdf:type rdf:Property ;
    rdfs:label 'Permit Issue Date' ;
    rdfs:comment 'Date the regulatory permit for this cell was issued by the governing authority. [Moved from cell: This attribute in the cell product appears to reference a single permit\'s issue date, which is inappropriate for a cell that can be authorized under multiple permits. The issue date belongs to the permit product itself (already exists as permit.issue_date), not to the cell. This attribute should be removed from cell as it creates ambiguity about which permit\'s issue date is being referenced.]' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryConditions rdf:type rdf:Property ;
    rdfs:label 'Regulatory Conditions' ;
    rdfs:comment 'Specific conditions, restrictions, or operational requirements imposed by this permit for this cell. May include cell-specific monitoring requirements, operational constraints, reporting obligations, or special conditions that apply to this cell-permit combination but not to other cells under the same permit.' ;
    rdfs:domain ind:CellPermitAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Program Assignment Id' ;
    rdfs:comment 'Unique identifier for the program assignment record. Primary key.' ;
    rdfs:domain ind:ProgramAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:territoryAssignment rdf:type rdf:Property ;
    rdfs:label 'Territory Assignment' ;
    rdfs:comment 'The specific geographic territory or customer segment the employee is responsible for within this program. Used for sales territory management and customer coverage.' ;
    rdfs:domain ind:ProgramAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commodityAcceptanceId rdf:type rdf:Property ;
    rdfs:label 'Commodity Acceptance Id' ;
    rdfs:comment 'Unique system-generated surrogate identifier for each commodity-offering acceptance specification' ;
    rdfs:domain ind:CommodityAcceptance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:acceptedGradeList rdf:type rdf:Property ;
    rdfs:label 'Accepted Grade List' ;
    rdfs:comment 'Comma-separated or JSON list of ISRI grade codes accepted for this commodity under this specific service offering. Allows service offerings to restrict which grades are acceptable (e.g., residential service may only accept Grade A OCC, while commercial accepts Grades A and B).' ;
    rdfs:domain ind:CommodityAcceptance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumVolumeLbs rdf:type rdf:Property ;
    rdfs:label 'Minimum Volume Lbs' ;
    rdfs:comment 'Minimum volume in pounds of this commodity required per pickup or billing period for this service offering. Null if no minimum applies. Used for commercial/industrial programs with volume commitments.' ;
    rdfs:domain ind:CommodityAcceptance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commoditySupplyAgreementId rdf:type rdf:Property ;
    rdfs:label 'Commodity Supply Agreement Id' ;
    rdfs:comment 'Unique system-generated surrogate identifier for each commodity-vendor supply agreement record' ;
    rdfs:domain ind:CommoditySupplyAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:commodityRegulatoryApplicabilityId rdf:type rdf:Property ;
    rdfs:label 'Commodity Regulatory Applicability Id' ;
    rdfs:comment 'Unique system-generated surrogate identifier for each commodity-regulation applicability mapping record. Primary key.' ;
    rdfs:domain ind:CommodityRegulatoryApplicability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:commodityRegulatoryApplicabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Commodity Regulatory Applicability Status' ;
    rdfs:comment 'Current lifecycle status of this applicability mapping record. Active mappings drive compliance workflows; inactive mappings are historical.' ;
    rdfs:domain ind:CommodityRegulatoryApplicability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceThreshold rdf:type rdf:Property ;
    rdfs:label 'Compliance Threshold' ;
    rdfs:comment 'Commodity-specific compliance threshold or trigger value that determines when this regulatory requirement applies (e.g., \'contamination >5%\', \'bale weight >1000 lbs\', \'hazardous material present\'). Thresholds vary by commodity type even for the same regulation.' ;
    rdfs:domain ind:CommodityRegulatoryApplicability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentationStandard rdf:type rdf:Property ;
    rdfs:label 'Documentation Standard' ;
    rdfs:comment 'Specific documentation or record-keeping standard required for this commodity under this regulation (e.g., \'EPA Form 8700-22 for hazardous waste\', \'Bill of Lading with ISRI grade certification\', \'Chain of Custody documentation\'). Documentation requirements vary by commodity type.' ;
    rdfs:domain ind:CommodityRegulatoryApplicability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exemptionReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Exemption Reference Number' ;
    rdfs:comment 'Official reference number or citation for any exemption granted for this commodity under this regulation (e.g., EPA exemption letter number, state variance approval number).' ;
    rdfs:domain ind:CommodityRegulatoryApplicability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exemptionStatus rdf:type rdf:Property ;
    rdfs:label 'Exemption Status' ;
    rdfs:comment 'Indicates whether an exemption from this regulatory requirement has been requested or granted for this commodity. Tracks exemption lifecycle.' ;
    rdfs:domain ind:CommodityRegulatoryApplicability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requirementApplicability rdf:type rdf:Property ;
    rdfs:label 'Requirement Applicability' ;
    rdfs:comment 'Indicates whether this regulatory requirement is mandatory, conditional (applies only under certain circumstances), recommended, or not applicable for this specific commodity. Drives compliance workflow routing.' ;
    rdfs:domain ind:CommodityRegulatoryApplicability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleComplianceOfficer rdf:type rdf:Property ;
    rdfs:label 'Responsible Compliance Officer' ;
    rdfs:comment 'Name or employee ID of the compliance officer responsible for managing this commodity\'s compliance with this specific regulation. Enables accountability and contact routing.' ;
    rdfs:domain ind:CommodityRegulatoryApplicability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testingFrequency rdf:type rdf:Property ;
    rdfs:label 'Testing Frequency' ;
    rdfs:comment 'Required frequency of compliance testing or sampling for this commodity under this regulation (e.g., TCLP testing frequency for hazardous commodities, contamination testing for recyclables). Frequency varies by commodity-regulation combination.' ;
    rdfs:domain ind:CommodityRegulatoryApplicability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactContractRoleId rdf:type rdf:Property ;
    rdfs:label 'Contact Contract Role Id' ;
    rdfs:comment 'Unique surrogate identifier for each contact-contract role assignment record' ;
    rdfs:domain ind:ContactContractRole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contactRole rdf:type rdf:Property ;
    rdfs:label 'Contact Role' ;
    rdfs:comment 'Functional role this contact plays for this specific contract. Determines routing of notifications, approval authority, and communication workflows. Values: billing (receives invoices), service (operational issues), signatory (contract execution authority), emergency (incident notifications), legal (compliance/disputes), operations (day-to-day coordination), primary (main point of contact)' ;
    rdfs:domain ind:ContactContractRole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationPreference rdf:type rdf:Property ;
    rdfs:label 'Notification Preference' ;
    rdfs:comment 'Preferred communication channel for contract-specific notifications to this contact in this role. Overrides the contacts global preferred_contact_method for this contract context. Values: email, sms, phone, portal, none' ;
    rdfs:domain ind:ContactContractRole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Flag' ;
    rdfs:comment 'Indicates whether this contact is the primary point of contact for this specific contract. Used for escalation routing and default communication recipient. Only one contact per contract should have this flag set to true at any time' ;
    rdfs:domain ind:ContactContractRole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:roleStatus rdf:type rdf:Property ;
    rdfs:label 'Role Status' ;
    rdfs:comment 'Current lifecycle status of this role assignment. Active assignments receive notifications and appear in operational workflows. Inactive assignments are historical. Suspended assignments are temporarily disabled. Values: active, inactive, suspended' ;
    rdfs:domain ind:ContactContractRole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatureAuthority rdf:type rdf:Property ;
    rdfs:label 'Signature Authority' ;
    rdfs:comment 'Indicates whether this contact has legal authority to execute amendments, renewals, or terminations for this contract. Used in approval workflows and contract change management processes' ;
    rdfs:domain ind:ContactContractRole ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceAreaId rdf:type rdf:Property ;
    rdfs:label 'Service Area Id' ;
    rdfs:comment 'Unique identifier for this contract-service area coverage record. Primary key.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceArea .

ind:franchiseFeeRate rdf:type rdf:Property ;
    rdfs:label 'Franchise Fee Rate' ;
    rdfs:comment 'Percentage of gross revenues from this service area that must be paid to the municipality or franchise authority as a franchise fee. Expressed as decimal (e.g., 0.0750 for 7.5%).' ;
    rdfs:domain ind:ServiceArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceLevelCommitment rdf:type rdf:Property ;
    rdfs:label 'Service Level Commitment' ;
    rdfs:comment 'Description of the service performance obligations specific to this service area under this contract. May include collection frequency guarantees, response time commitments, or service quality standards that vary by territory.' ;
    rdfs:domain ind:ServiceArea ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityAllocationAgreementId rdf:type rdf:Property ;
    rdfs:label 'Facility Allocation Agreement Id' ;
    rdfs:comment 'Unique identifier for the facility allocation agreement record. Primary key for the association.' ;
    rdfs:domain ind:FacilityAllocationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumMonthlyTonnage rdf:type rdf:Property ;
    rdfs:label 'Minimum Monthly Tonnage' ;
    rdfs:comment 'Minimum tonnage the customer must deliver monthly to avoid contract penalties or minimum billing charges. Null if no minimum commitment exists.' ;
    rdfs:domain ind:FacilityAllocationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wasteStreamAllocationPercent rdf:type rdf:Property ;
    rdfs:label 'Waste Stream Allocation Percent' ;
    rdfs:comment 'Percentage of the customer\'s total waste stream committed to this specific WTE facility under the agreement. Used for routing decisions when customer has agreements with multiple facilities.' ;
    rdfs:domain ind:FacilityAllocationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wasteTypeRestrictions rdf:type rdf:Property ;
    rdfs:label 'Waste Type Restrictions' ;
    rdfs:comment 'Description of waste stream types permitted or prohibited under this agreement based on facility capabilities and permit restrictions (e.g., \'MSW only, no hazardous\', \'Commercial waste, no medical\').' ;
    rdfs:domain ind:FacilityAllocationAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilitySafetyProgramImplementationId rdf:type rdf:Property ;
    rdfs:label 'Facility Safety Program Implementation Id' ;
    rdfs:comment 'Unique identifier for this facility-program implementation record. Primary key.' ;
    rdfs:domain ind:FacilitySafetyProgramImplementation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:programCoordinatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Program Coordinator Employee Id' ;
    rdfs:comment 'Identifier of the employee who coordinates this specific safety program at this facility (facility-level coordinator, distinct from the enterprise program owner). Responsible for local training, compliance, and recordkeeping.' ;
    rdfs:domain ind:FacilitySafetyProgramImplementation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:programSafetyProgramId rdf:type rdf:Property ;
    rdfs:label 'Program Safety Program Id' ;
    rdfs:comment 'Foreign key linking to the safety program being implemented at the facility' ;
    rdfs:domain ind:FacilitySafetyProgramImplementation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SafetyProgram .

ind:exemptionFlag rdf:type rdf:Property ;
    rdfs:label 'Exemption Flag' ;
    rdfs:comment 'Indicates whether this facility has been granted an exemption from this safety program due to operational characteristics (e.g., administrative office exempt from confined space program).' ;
    rdfs:domain ind:FacilitySafetyProgramImplementation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exemptionReason rdf:type rdf:Property ;
    rdfs:label 'Exemption Reason' ;
    rdfs:comment 'Explanation of why this facility is exempt from this safety program, if exemption_flag is true. Documents regulatory or operational justification.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentCountYtd rdf:type rdf:Property ;
    rdfs:label 'Incident Count Ytd' ;
    rdfs:comment 'Number of safety incidents related to this program at this facility in the current calendar year. Key performance indicator for program effectiveness.' ;
    rdfs:domain ind:FacilitySafetyProgramImplementation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trainingCompletionPercentage rdf:type rdf:Property ;
    rdfs:label 'Training Completion Percentage' ;
    rdfs:comment 'Percentage of required employees at this facility who have completed training for this safety program. Used to track training compliance at the facility level.' ;
    rdfs:domain ind:FacilitySafetyProgramImplementation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyComplianceId rdf:type rdf:Property ;
    rdfs:label 'Safety Compliance Id' ;
    rdfs:comment 'Unique identifier for this asset-safety program compliance record. Primary key.' ;
    rdfs:domain ind:SafetyCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastInspectionByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Last Inspection By Employee Id' ;
    rdfs:comment 'Identifier of the employee who performed the most recent compliance inspection or audit for this asset-program combination.' ;
    rdfs:domain ind:SafetyCompliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:franchiseRequirementComplianceId rdf:type rdf:Property ;
    rdfs:label 'Franchise Requirement Compliance Id' ;
    rdfs:comment 'Unique identifier for this franchise-requirement compliance record. Primary key.' ;
    rdfs:domain ind:FranchiseRequirementCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:penaltyProvision rdf:type rdf:Property ;
    rdfs:label 'Penalty Provision' ;
    rdfs:comment 'The specific penalty, fine structure, or enforcement action that applies if this franchise agreement fails to meet this regulatory requirement. May include franchise-specific liquidated damages or termination clauses.' ;
    rdfs:domain ind:FranchiseRequirementCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentCertificationId rdf:type rdf:Property ;
    rdfs:label 'Equipment Certification Id' ;
    rdfs:comment 'Unique identifier for this equipment certification record. Primary key for the association.' ;
    rdfs:domain ind:EquipmentCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certifyingInstructorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Certifying Instructor Employee Id' ;
    rdfs:comment 'Employee ID of the instructor or supervisor who certified this employee on this equipment. Used for audit trail and training program management.' ;
    rdfs:domain ind:EquipmentCertification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:lastProficiencyAssessmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Proficiency Assessment Date' ;
    rdfs:comment 'Date of the most recent proficiency assessment for this employee on this equipment. Used to track ongoing competency verification.' ;
    rdfs:domain ind:EquipmentCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextProficiencyAssessmentDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Proficiency Assessment Due Date' ;
    rdfs:comment 'Scheduled date for the next proficiency assessment. Used for compliance scheduling and training program management.' ;
    rdfs:domain ind:EquipmentCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalOperatingHours rdf:type rdf:Property ;
    rdfs:label 'Total Operating Hours' ;
    rdfs:comment 'Cumulative hours this employee has operated this specific equipment. Used for experience tracking and proficiency advancement decisions.' ;
    rdfs:domain ind:EquipmentCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceOfficerAssigned rdf:type rdf:Property ;
    rdfs:label 'Compliance Officer Assigned' ;
    rdfs:comment 'Name of the Waste Management compliance officer specifically assigned to manage this permit at this facility. May differ from the general permit compliance officer if facility-level assignments exist.' ;
    rdfs:domain ind:FacilityPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilitySpecificConditions rdf:type rdf:Property ;
    rdfs:label 'Facility Specific Conditions' ;
    rdfs:comment 'Additional conditions, limitations, or requirements specific to this facility\'s use of this permit. Supplements the general permit conditions with facility-specific operational constraints.' ;
    rdfs:domain ind:FacilityPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastComplianceReportDate rdf:type rdf:Property ;
    rdfs:label 'Last Compliance Report Date' ;
    rdfs:comment 'Date on which the most recent compliance report for this permit at this facility was submitted to the regulatory agency. Used to track reporting frequency adherence.' ;
    rdfs:domain ind:FacilityPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextComplianceReportDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Compliance Report Due Date' ;
    rdfs:comment 'Date by which the next compliance report for this permit at this facility must be submitted to the regulatory agency. Critical for avoiding reporting violations.' ;
    rdfs:domain ind:FacilityPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:permitRole rdf:type rdf:Property ;
    rdfs:label 'Permit Role' ;
    rdfs:comment 'The functional role or purpose this permit serves at this specific facility. A facility may hold multiple permits serving different regulatory purposes (e.g., one for air emissions, one for water discharge, one for waste handling).' ;
    rdfs:domain ind:FacilityPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionChecklistId rdf:type rdf:Property ;
    rdfs:label 'Inspection Checklist Id' ;
    rdfs:comment 'Primary key for inspection_checklist' ;
    rdfs:domain ind:InspectionChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicableRegions rdf:type rdf:Property ;
    rdfs:label 'Applicable Regions' ;
    rdfs:comment 'Comma-separated list of geographic regions, states, or jurisdictions where this inspection checklist is applicable.' ;
    rdfs:domain ind:InspectionChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetSubtype rdf:type rdf:Property ;
    rdfs:label 'Asset Subtype' ;
    rdfs:comment 'Specific subtype or category of asset within the asset type classification (e.g., roll-off, front-load, compactor for containers).' ;
    rdfs:domain ind:InspectionChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checklistCode rdf:type rdf:Property ;
    rdfs:label 'Checklist Code' ;
    rdfs:comment 'Unique business identifier code for the inspection checklist used across systems and documentation.' ;
    rdfs:domain ind:InspectionChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checklistDescription rdf:type rdf:Property ;
    rdfs:label 'Checklist Description' ;
    rdfs:comment 'Detailed description of the inspection checklist including its objectives, scope, and application context.' ;
    rdfs:domain ind:InspectionChecklist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checklistName rdf:type rdf:Property ;
    rdfs:label 'Checklist Name' ;
    rdfs:comment 'Human-readable name of the inspection checklist describing its purpose and scope.' ;
