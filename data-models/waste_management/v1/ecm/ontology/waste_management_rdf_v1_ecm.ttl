    rdfs:comment 'Indicates whether this payment method is processed electronically (true) or requires manual handling (false).' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maximumAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Amount' ;
    rdfs:comment 'Maximum transaction amount allowed for this payment method, in USD. Null if no maximum applies.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
