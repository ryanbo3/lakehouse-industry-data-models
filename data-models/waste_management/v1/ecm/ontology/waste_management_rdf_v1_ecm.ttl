    rdfs:comment 'Indicates whether the laboratory has been designated as a preferred vendor based on performance, pricing, or strategic relationship.' ;
    rdfs:domain ind:Laboratory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityAssuranceProgram rdf:type rdf:Property ;
