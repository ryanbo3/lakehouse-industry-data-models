    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:availableForResidential rdf:type rdf:Property ;
    rdfs:label 'Available For Residential' ;
    rdfs:comment 'Indicates whether this payment method is available for residential customer accounts.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:chargebackEligible rdf:type rdf:Property ;
