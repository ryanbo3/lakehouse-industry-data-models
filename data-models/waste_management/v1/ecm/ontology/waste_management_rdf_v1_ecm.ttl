    rdfs:comment 'Indicates whether payments made with this method are subject to chargeback disputes.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerFacingDescription rdf:type rdf:Property ;
    rdfs:label 'Customer Facing Description' ;
    rdfs:comment 'Customer-friendly description of the payment method displayed during checkout and billing.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iconUrl rdf:type rdf:Property ;
