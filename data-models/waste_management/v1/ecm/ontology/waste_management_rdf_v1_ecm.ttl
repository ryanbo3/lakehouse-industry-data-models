    rdfs:comment 'Broader business category grouping payment methods by processing characteristics.' ;
    rdfs:domain ind:PaymentMethod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:methodCode rdf:type rdf:Property ;
