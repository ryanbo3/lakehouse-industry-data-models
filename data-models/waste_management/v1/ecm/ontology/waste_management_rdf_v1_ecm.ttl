    rdfs:range xsd:boolean .

ind:stepIntervalDays rdf:type rdf:Property ;
    rdfs:label 'Step Interval Days' ;
    rdfs:comment 'Standard number of days between consecutive dunning steps in the escalation sequence.' ;
    rdfs:domain ind:DunningSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalSteps rdf:type rdf:Property ;
    rdfs:label 'Total Steps' ;
    rdfs:comment 'Total number of escalation steps defined in this dunning sequence from initial reminder to final collection action.' ;
    rdfs:domain ind:DunningSequence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountId rdf:type rdf:Property ;
    rdfs:label 'Account Id' ;
    rdfs:comment 'Reference to the billing account to which this credit memo applies.' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BillingAccount .

ind:containerId rdf:type rdf:Property ;
    rdfs:label 'Container Id' ;
    rdfs:comment 'Reference to the specific container associated with the credit memo, if applicable (e.g., rental credit).' ;
    rdfs:domain ind:CreditMemo ;
    rdf:type owl:ObjectProperty ;
