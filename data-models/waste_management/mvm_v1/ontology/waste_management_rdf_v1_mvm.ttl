ind:actionLevelUnit rdf:type rdf:Property ;
    rdfs:label 'Action Level Unit' ;
    rdfs:comment 'Unit of measure for the action level threshold (e.g., ppm, mg/L, percent, cfm).' ;
    rdfs:domain ind:CollectionPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calibrationDueDate rdf:type rdf:Property ;
    rdfs:label 'Calibration Due Date' ;
    rdfs:comment 'Next scheduled date for equipment calibration at this collection point.' ;
    rdfs:domain ind:CollectionPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:depthFt rdf:type rdf:Property ;
    rdfs:label 'Depth Ft' ;
    rdfs:comment 'Depth of the collection point below ground surface measured in feet, applicable for wells and subsurface monitoring points.' ;
    rdfs:domain ind:CollectionPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:envianceIntegrationFlag rdf:type rdf:Property ;
    rdfs:label 'Enviance Integration Flag' ;
    rdfs:comment 'Indicates whether this collection point is integrated with the Enviance EHS system for automated compliance reporting.' ;
    rdfs:domain ind:CollectionPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:flowCapacityGpm rdf:type rdf:Property ;
    rdfs:label 'Flow Capacity Gpm' ;
    rdfs:comment 'Maximum flow capacity of the collection point measured in gallons per minute, applicable for leachate and stormwater collection.' ;
    rdfs:domain ind:CollectionPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lelThresholdPercent rdf:type rdf:Property ;
    rdfs:label 'Lel Threshold Percent' ;
    rdfs:comment 'Lower explosive limit threshold percentage for landfill gas monitoring points, triggering alerts when exceeded.' ;
    rdfs:domain ind:CollectionPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:linerType rdf:type rdf:Property ;
    rdfs:label 'Liner Type' ;
    rdfs:comment 'Type of liner system associated with this collection point, relevant for leachate collection systems.' ;
    rdfs:domain ind:CollectionPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pointCode rdf:type rdf:Property ;
    rdfs:label 'Point Code' ;
    rdfs:comment 'Externally-known unique business identifier for the collection point, used in operational systems and reporting.' ;
    rdfs:domain ind:Landfill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pointName rdf:type rdf:Property ;
    rdfs:label 'Point Name' ;
    rdfs:comment 'Human-readable name or designation of the collection point within the landfill site.' ;
    rdfs:domain ind:Landfill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pointType rdf:type rdf:Property ;
    rdfs:label 'Point Type' ;
    rdfs:comment 'Classification of the collection point based on its primary environmental monitoring or collection function.' ;
    rdfs:domain ind:CollectionPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleMethod rdf:type rdf:Property ;
    rdfs:label 'Sample Method' ;
    rdfs:comment 'Standard method or protocol used for collecting samples or readings at this collection point.' ;
    rdfs:domain ind:CollectionPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatmentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Treatment Required Flag' ;
    rdfs:comment 'Indicates whether collected material from this point requires treatment before discharge or disposal.' ;
    rdfs:domain ind:CollectionPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentMonitoringPointId rdf:type rdf:Property ;
    rdfs:label 'Parent Monitoring Point Id' ;
    rdfs:comment 'Self-referencing FK on monitoring_point (parent_monitoring_point_id)' ;
    rdfs:domain ind:MonitoringPoint ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MonitoringPoint .

ind:backgroundMonitoringFlag rdf:type rdf:Property ;
    rdfs:label 'Background Monitoring Flag' ;
    rdfs:comment 'Indicates whether this point serves as a background or upgradient reference location (true) for comparison with downgradient monitoring results.' ;
    rdfs:domain ind:MonitoringPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:detectionMonitoringFlag rdf:type rdf:Property ;
    rdfs:label 'Detection Monitoring Flag' ;
    rdfs:comment 'Indicates whether this point is part of the RCRA Subtitle D detection monitoring program (true) or assessment/corrective action monitoring (false).' ;
    rdfs:domain ind:MonitoringPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lelAlarmThresholdPct rdf:type rdf:Property ;
    rdfs:label 'Lel Alarm Threshold Pct' ;
    rdfs:comment 'Percentage of Lower Explosive Limit (LEL) at which an alarm or action is triggered for landfill gas monitoring points. Typically set at 25% LEL per OSHA and EPA guidance.' ;
    rdfs:domain ind:MonitoringPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:methaneThresholdPct rdf:type rdf:Property ;
    rdfs:label 'Methane Threshold Pct' ;
    rdfs:comment 'Methane concentration threshold (volume percent) for landfill gas monitoring compliance. Regulatory limit is typically 5% by volume at the facility boundary or 1.25% in structures.' ;
    rdfs:domain ind:MonitoringPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:monitoringPointStatus rdf:type rdf:Property ;
    rdfs:label 'Monitoring Point Status' ;
    rdfs:comment 'Current operational lifecycle state of the monitoring point: active (in service), inactive (temporarily not monitored), abandoned (permanently closed), suspended (on hold), planned (not yet installed), or decommissioned (formally retired).' ;
    rdfs:domain ind:MonitoringPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringSubtype rdf:type rdf:Property ;
    rdfs:label 'Monitoring Subtype' ;
    rdfs:comment 'Secondary classification providing additional detail on the monitoring point purpose (e.g., compliance well, detection well, extraction well, perimeter probe, interior probe, background station). [ENUM-REF-CANDIDATE: compliance_well|detection_well|extraction_well|perimeter_probe|interior_probe|background_station|boundary_station|meteorological_tower — promote to reference product]' ;
    rdfs:domain ind:MonitoringPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringType rdf:type rdf:Property ;
    rdfs:label 'Monitoring Type' ;
    rdfs:comment 'Primary category of environmental monitoring performed at this point: groundwater quality, landfill gas (LFG) emissions, ambient air quality, leachate characteristics, surface water quality, or meteorological conditions.' ;
    rdfs:domain ind:MonitoringPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parameterList rdf:type rdf:Property ;
    rdfs:label 'Parameter List' ;
    rdfs:comment 'Comma-separated list of environmental parameters or analytes measured at this monitoring point (e.g., pH, conductivity, VOCs, methane, benzene, dissolved oxygen, temperature).' ;
    rdfs:domain ind:MonitoringPoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundleCompositionId rdf:type rdf:Property ;
    rdfs:label 'Bundle Composition Id' ;
    rdfs:comment 'Primary key for the bundle_composition association' ;
    rdfs:domain ind:BundleComposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isPrimaryOfferingFlag rdf:type rdf:Property ;
    rdfs:label 'Is Primary Offering Flag' ;
    rdfs:comment 'Indicates whether this offering is the anchor or lead service within the bundle (e.g., the core collection service in a residential bundle). Used for fulfillment prioritization and marketing display.' ;
    rdfs:domain ind:BundleComposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pricingContributionAmount rdf:type rdf:Property ;
    rdfs:label 'Pricing Contribution Amount' ;
    rdfs:comment 'The dollar amount this offering contributes to the bundle\'s total price. Distinct from the offering\'s standalone base_price_amount and the bundle\'s aggregate base_price. Enables bundle pricing decomposition and margin analysis.' ;
    rdfs:domain ind:BundleComposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sequenceOrder rdf:type rdf:Property ;
    rdfs:label 'Sequence Order' ;
    rdfs:comment 'Ordinal position of this offering within the bundle for display, fulfillment sequencing, and contract line ordering. Lower values appear first.' ;
    rdfs:domain ind:BundleComposition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:programFacilityAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Program Facility Assignment Id' ;
    rdfs:comment 'Primary key for the program_facility_assignment association' ;
    rdfs:domain ind:ProgramFacilityAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:facilityRegulatoryApplicabilityId rdf:type rdf:Property ;
    rdfs:label 'Facility Regulatory Applicability Id' ;
    rdfs:comment 'Primary key for the facility_regulatory_applicability association' ;
    rdfs:domain ind:FacilityRegulatoryApplicability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicabilityDeterminationDate rdf:type rdf:Property ;
    rdfs:label 'Applicability Determination Date' ;
    rdfs:comment 'The date on which the formal determination was made that this regulatory requirement applies (or is exempt) to this facility. Required for regulatory defense and audit trail.' ;
    rdfs:domain ind:FacilityRegulatoryApplicability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exemptionFlag rdf:type rdf:Property ;
    rdfs:label 'Exemption Flag' ;
    rdfs:comment 'Indicates whether this facility has been formally determined to be exempt from this regulatory requirement. When true, exemption_reason must be populated.' ;
    rdfs:domain ind:FacilityRegulatoryApplicability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exemptionReason rdf:type rdf:Property ;
    rdfs:label 'Exemption Reason' ;
    rdfs:comment 'The documented legal or operational basis for the exemption from this regulatory requirement at this facility. Null when exemption_flag is false.' ;
    rdfs:domain ind:FacilityRegulatoryApplicability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleComplianceOfficer rdf:type rdf:Property ;
    rdfs:label 'Responsible Compliance Officer' ;
    rdfs:comment 'The name or identifier of the compliance officer accountable for managing and demonstrating compliance with this requirement at this facility.' ;
    rdfs:domain ind:FacilityRegulatoryApplicability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteProfileCodeListingId rdf:type rdf:Property ;
    rdfs:label 'Waste Profile Code Listing Id' ;
    rdfs:comment 'Primary key for the waste_profile_code_listing association' ;
    rdfs:domain ind:WasteProfileCodeListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:basisForListing rdf:type rdf:Property ;
    rdfs:label 'Basis For Listing' ;
    rdfs:comment 'The specific reason or measured property that caused this waste code to apply to this waste profile. For characteristic codes (D-codes), this captures the measured property (e.g., flash point, pH, TCLP result). For listed codes (F/K/P/U), this captures the process or source that qualifies the waste. Belongs to the profile-code pairing, not to either entity alone.' ;
    rdfs:domain ind:WasteProfileCodeListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:concentrationThresholdMgL rdf:type rdf:Property ;
    rdfs:label 'Concentration Threshold Mg L' ;
    rdfs:comment 'The measured TCLP extract concentration in mg/L for this specific waste stream that triggered a toxicity characteristic waste code (D004–D043). This value is specific to the waste profile and the code pairing — the same waste code may be triggered at different concentrations across different profiles.' ;
    rdfs:domain ind:WasteProfileCodeListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryFlag rdf:type rdf:Property ;
    rdfs:label 'Primary Flag' ;
    rdfs:comment 'Indicates whether this waste code is the primary (most significant) code for the waste profile. Replaces the denormalized primary_waste_code_id FK on waste_profile. Exactly one record per waste_profile should have this set to TRUE.' ;
    rdfs:domain ind:WasteProfileCodeListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryCitationOverride rdf:type rdf:Property ;
    rdfs:label 'Regulatory Citation Override' ;
    rdfs:comment 'State-specific or site-specific regulatory citation that supersedes the standard federal citation for this waste code as applied to this particular waste profile. Null when the standard federal citation from waste_code applies without modification.' ;
    rdfs:domain ind:WasteProfileCodeListing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageAuthorizationId rdf:type rdf:Property ;
    rdfs:label 'Storage Authorization Id' ;
    rdfs:comment 'Primary key for the storage_authorization association' ;
    rdfs:domain ind:StorageAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedQuantityLimitLbs rdf:type rdf:Property ;
    rdfs:label 'Approved Quantity Limit Lbs' ;
    rdfs:comment 'Maximum quantity in pounds of this waste profile that may be stored in this unit at any one time under this authorization. Belongs to the pairing, not to either entity alone. Sourced from the detection phase relationship data.' ;
    rdfs:domain ind:StorageAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:authorizationStatus rdf:type rdf:Property ;
    rdfs:label 'Authorization Status' ;
    rdfs:comment 'Current status of this storage authorization. Tracks the lifecycle of the approval from active use through expiration or revocation.' ;
    rdfs:domain ind:StorageAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compatibilityVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Compatibility Verified Flag' ;
    rdfs:comment 'Indicates whether a formal chemical and physical compatibility assessment was completed for this waste profile and storage unit pairing prior to authorization. Sourced from the detection phase relationship data.' ;
    rdfs:domain ind:StorageAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .
