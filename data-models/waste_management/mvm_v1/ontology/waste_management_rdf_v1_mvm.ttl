    rdfs:range xsd:integer .

ind:ptoEquippedFlag rdf:type rdf:Property ;
    rdfs:label 'Pto Equipped Flag' ;
    rdfs:comment 'Indicates whether vehicles in this class are equipped with Power Take-Off systems for hydraulic operations. True if PTO-equipped, False if not.' ;
