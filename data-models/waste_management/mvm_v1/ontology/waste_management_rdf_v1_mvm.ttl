# RDFS Schema for Business: Waste Management

@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix ind: <http://datamodel.lakehouse.org/business/waste_management#> .

# --- Root Business Class ---
ind:Business rdf:type rdfs:Class ;
    rdfs:label 'Business' ;
    rdfs:comment 'Root class for all business entities' .

# --- Specific Business: Waste Management ---
ind:WasteManagement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Business ;
    rdfs:label 'Waste Management' ;
    rdfs:comment 'Waste Management is an environmental services industry providing residential and commercial waste collection, recycling, landfill operations, hazardous waste handling, and sustainable waste-to-energy solutions.' .

# --- Domain Classes ---
ind:Customer rdf:type rdfs:Class ;
    rdfs:subClassOf ind:WasteManagement ;
    rdfs:label 'Customer' ;
    rdfs:comment 'Single source of truth for all customer identities including residential households, commercial accounts, industrial clients, and municipal contracts. Manages customer profiles, service addresses, account hierarchies, contact information, customer segments (B2C residential, B2B commercial, government), NPS/satisfaction data, and customer lifecycle from prospect to active to inactive. Supports both one-time service requests and recurring service agreements. Integrates with Salesforce CRM and Waste Logics customer portal.' .

ind:Collection rdf:type rdfs:Class ;
    rdfs:subClassOf ind:WasteManagement ;
    rdfs:label 'Collection' ;
    rdfs:comment 'Core operational domain managing all waste collection, hauling, and transfer operations including residential/commercial pickup routes, transfer station consolidation, driver assignments, container placements, weight tickets, and outbound haul dispatch to disposal facilities.' .

ind:Fleet rdf:type rdfs:Class ;
    rdfs:subClassOf ind:WasteManagement ;
    rdfs:label 'Fleet' ;
    rdfs:comment 'Management of all mobile assets including collection trucks (ASL, FEL, REL), transfer vehicles, roll-off trucks, CNG/RNG-fueled units, and support vehicles. Tracks vehicle inventory, specifications, fuel types (diesel, CNG, RNG), telematics data (GPS, fuel consumption, idle time), driver behavior, DOT compliance, CDL driver assignments, vehicle registration, and utilization metrics. Integrates with Geotab Fleet Telematics and Infor EAM. Supports DOT/FMCSA regulatory compliance and fleet KPI reporting.' .

ind:Maintenance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:WasteManagement ;
    rdfs:label 'Maintenance' ;
    rdfs:comment 'Preventive and corrective maintenance for fleet and facility assets. Manages work orders (WO), maintenance schedules (PM cycles), repair history, parts inventory (BOM), technician assignments, downtime tracking, and maintenance costs. Ensures equipment reliability, regulatory compliance (DOT inspections), and asset lifecycle optimization. Integrates with Infor EAM for CMMS functionality and SAP PM for work order execution.' .

ind:Recycling rdf:type rdfs:Class ;
    rdfs:subClassOf ind:WasteManagement ;
    rdfs:label 'Recycling' ;
    rdfs:comment 'Materials Recovery Facility (MRF) operations including inbound material receiving, sorting processes, contamination tracking, commodity recovery (paper, plastics, metals, glass), bale production, quality control, outbound commodity sales, and market pricing for recovered materials. Tracks diversion rates, processing throughput (TPD), equipment performance, and commodity grades. Supports EPA recycling reporting and circular economy goals. Integrates with AMCS for recycling route management and SAP MM for commodity inventory.' .

ind:Landfill rdf:type rdfs:Class ;
    rdfs:subClassOf ind:WasteManagement ;
    rdfs:label 'Landfill' ;
    rdfs:comment 'Landfill site operations including cell management, waste placement, compaction ratios, daily cover application, leachate collection and treatment, landfill gas (LFG) monitoring (LEL readings), liner integrity, environmental monitoring (groundwater, air quality), airspace consumption tracking, capacity planning, and closure/cap plans. Manages tipping fees, tonnage received (TPD), and regulatory compliance for RCRA Subtitle D facilities. Supports EPA SWIS reporting and CERCLA/Superfund obligations. Integrates with Enviance EHS.' .

ind:Hazmat rdf:type rdfs:Class ;
    rdfs:subClassOf ind:WasteManagement ;
    rdfs:label 'Hazmat' ;
    rdfs:comment 'Hazardous waste handling, treatment, storage, and disposal operations under RCRA Subtitle C. Manages hazardous waste manifests (cradle-to-grave tracking), TSDF facility operations, waste characterization (TCLP testing), container tracking, EPA ID numbers, waste codes, chain-of-custody, transportation compliance (DOT HMR), BOL documents, emergency response (HAZWOPER), and regulatory reporting. Ensures safe handling of industrial, medical, and special wastes. Integrates with Enviance EHS and SAP EHS modules.' .

ind:Contract rdf:type rdfs:Class ;
    rdfs:subClassOf ind:WasteManagement ;
    rdfs:label 'Contract' ;
    rdfs:comment 'Service agreements and contracts with customers including municipal solid waste contracts, commercial service agreements, hauling contracts, disposal agreements, and franchise agreements. Manages contract terms, service levels (SLA), pricing structures, rate escalation clauses, renewal dates, performance obligations, contract amendments, and lifecycle events (origination, renewal, amendment, termination). Links customers to service commitments and billing terms. Integrates with Salesforce CRM and SAP SD.' .

ind:Billing rdf:type rdfs:Class ;
    rdfs:subClassOf ind:WasteManagement ;
    rdfs:label 'Billing' ;
    rdfs:comment 'Revenue cycle management including invoice generation, usage-based billing (tonnage, pickups, container rentals), tipping fee schedules, rate management, payment processing, accounts receivable (AR), collections, payment plans, billing disputes, adjustments, and revenue recognition. Supports multiple billing models (subscription, transactional, tipping fees) for both residential and commercial accounts. Integrates with Oracle Revenue Management and SAP FI/CO. Supports GAAP/IFRS revenue recognition and SOX compliance.' .

ind:Service rdf:type rdfs:Class ;
    rdfs:subClassOf ind:WasteManagement ;
    rdfs:label 'Service' ;
    rdfs:comment 'Defines the complete catalog of waste management service offerings — residential pickup plans, commercial dumpster services, roll-off container rentals, recycling programs, hazardous waste collection events, WTE programs, and specialty services. Owns service codes, pricing tiers, service frequency definitions, container types (CID), and SRF/WTE product definitions. Acts as the SSOT for what the business offers, referenced by billing, contract, and collection domains.' .

ind:Compliance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:WasteManagement ;
    rdfs:label 'Compliance' ;
    rdfs:comment 'Environmental, health, and safety (EHS) compliance management. Tracks permits (air, water, waste), regulatory inspections, incident reporting, corrective actions, environmental monitoring data, audit trails, training certifications (CDL, HAZWOPER), violation notices, and regulatory submissions (SWIS, CERCLA, state reports). Ensures adherence to EPA, OSHA, DOT, Clean Air Act, Clean Water Act, and state/local regulations. Supports ISO 14001 and ISO 45001 frameworks. Integrates with Enviance EHS and SAP EHS.' .

ind:Asset rdf:type rdfs:Class ;
    rdfs:subClassOf ind:WasteManagement ;
    rdfs:label 'Asset' ;
    rdfs:comment 'Fixed asset and infrastructure management including containers (dumpsters, roll-offs, carts identified by CID/RFID), landfill sites, MRF facilities, transfer stations, WTE plants, maintenance shops, stationary equipment (compactors, balers, scales), and administrative buildings. Tracks asset master records, acquisition, depreciation, location, condition, utilization, BOM, RFID/GPS tracking, and lifecycle. Distinct from fleet (rolling stock) which has its own DOT compliance requirements. Integrates with Infor EAM and SAP PM.' .

# --- Data Product Classes (Tables) ---
ind:CustomerAccount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Customer Account' ;
    rdfs:comment 'Single source of truth for all customer accounts served by Waste Management, encompassing residential households, commercial businesses, industrial clients, and municipal/government entities. Stores account identity, classification (B2C residential, B2B commercial, government), account status (prospect, active, suspended, inactive, closed), credit standing, account tier, NPS score, customer since date, preferred language, and integration keys to Salesforce CRM and Waste Logics portal. This is the master entity for the customer domain.' .

ind:Contact rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Contact' ;
    rdfs:comment 'Individual persons associated with a customer account — primary account holders, billing contacts, service contacts, authorized representatives, and emergency contacts. Captures full name, title, role type (billing, service, primary, emergency), phone numbers, email addresses, preferred contact method, communication opt-in/opt-out flags, and portal login linkage. Supports both residential single-contact households and commercial multi-contact accounts. Sourced from Salesforce CRM Contact object and Waste Logics portal user records.' .

ind:ServiceAddress rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Service Address' ;
    rdfs:comment 'Physical locations where waste collection, recycling, or other environmental services are rendered. Each address is a distinct service point with its own geolocation (latitude/longitude), route zone assignment, municipality jurisdiction, zoning classification (residential, commercial, industrial), accessibility notes (gate codes, weight restrictions, placement instructions), and address validation status. A single account may have multiple service addresses (e.g., a commercial chain with multiple sites). Distinct from billing address stored on the account.' .

ind:AccountHierarchy rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Account Hierarchy' ;
    rdfs:comment 'Defines parent-child relationships between customer accounts to support corporate hierarchies, franchise groups, municipal umbrella contracts, and multi-site commercial customers. Captures hierarchy level (ultimate parent, intermediate parent, child site), relationship type (corporate subsidiary, franchise, municipal district), effective dates, and consolidated billing flag. Enables enterprise-level reporting across all sites under a parent account and supports national account management for large commercial clients.' .

ind:Segment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Segment' ;
    rdfs:comment 'Reference classification taxonomy defining the market segments used to categorize Waste Management customers. Segments include B2C Residential (single-family, multi-family), B2B Commercial (small business, mid-market, enterprise, national account), Industrial, Government/Municipal, and Non-Profit. Each segment carries SLA tiers, pricing tier eligibility, service eligibility rules, sales channel assignments, and NPS benchmark targets. Used for targeted service offerings, rate scheduling, and operational routing prioritization.' .

ind:AccountStatusHistory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Account Status History' ;
    rdfs:comment 'Immutable audit trail of all account lifecycle status transitions — from prospect creation through active service, suspension, reactivation, and final closure. Each record captures the prior status, new status, effective timestamp, reason code (non-payment, service cancellation, relocation, deceased, business closure), the initiating user or system, and any associated case or work order reference. Critical for churn analysis, regulatory compliance, and customer lifecycle management.' .

ind:ServiceEnrollment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Service Enrollment' ;
    rdfs:comment 'Records the active enrollment of a customer account at a specific service address for a defined waste management service (e.g., residential MSW cart pickup, commercial FEL dumpster service, roll-off container rental, recycling curbside). Captures enrollment start and end dates, service frequency (weekly, bi-weekly, on-call), container type and size, service day(s), enrollment status, and the originating contract or service agreement reference. This is the operational link between a customer account and the services they receive — distinct from the contract (owned by the contract domain).' .

ind:ServiceRequest rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Service Request' ;
    rdfs:comment 'Customer-initiated requests for service actions outside of scheduled recurring collection — including bulk item pickup, extra pickup requests, missed pickup complaints, container swap/exchange, container repair, start/stop service requests, and billing inquiries. Each request has a type code, priority level, requested service date, fulfillment status (open, scheduled, completed, cancelled), resolution notes, SLA due date, and linked service address. Sourced from Salesforce CRM Cases and Waste Logics portal submissions. Distinct from recurring service enrollments.' .

ind:ContainerAssignment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Container Assignment' ;
    rdfs:comment 'Tracks the assignment of physical waste containers (carts, dumpsters, roll-offs, compactors) identified by CID/RFID to specific customer service addresses. Records container type, size (gallons/cubic yards), material stream (MSW, recycling, organics, C&D), delivery date, pickup/removal date, current assignment status (active, pending removal, lost, damaged), and container condition at assignment. Bridges the customer domain with the asset domain\'s container inventory. Enables container utilization tracking and customer-level container audits.' .

ind:CommunicationPreference rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Communication Preference' ;
    rdfs:comment 'Stores each customer contact\'s communication channel preferences and consent records for regulatory compliance (TCPA, CAN-SPAM). Captures preferred channels (email, SMS, phone, mail, portal), notification types opted in/out (billing alerts, service reminders, outage notifications, promotional offers, NPS surveys), language preference, do-not-contact flags, and consent timestamps with source of consent. Supports omnichannel customer engagement and ensures compliant outreach across all Waste Management customer communications.' .

ind:WasteGeneratorProfile rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Waste Generator Profile' ;
    rdfs:comment 'Regulatory classification profile for commercial, industrial, and hazardous waste generating customers as required under RCRA and state environmental regulations. Captures EPA Generator ID, generator category (Very Small Quantity Generator VSQG, Small Quantity Generator SQG, Large Quantity Generator LQG), primary waste streams generated (MSW, C&D, hazardous, universal waste), estimated monthly waste volume (TPD), state permit numbers, and regulatory notification dates. Required for RCRA compliance and hazardous waste manifest management.' .

ind:Complaint rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Customer ;
    rdfs:label 'Complaint' ;
    rdfs:comment 'Formal customer complaints requiring structured resolution workflows, distinct from general service requests. Captures complaint type (missed pickup, billing dispute, driver behavior, odor/noise, environmental concern, container damage), severity level, regulatory escalation flag (EPA/OSHA reportable), complaint source (phone, portal, social media, regulatory agency, legal), assigned resolution owner, resolution status, root cause code, and resolution timestamp. Supports regulatory response obligations, operational quality improvement, and customer retention management.' .

ind:WorkOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Maintenance ;
    rdfs:label 'Work Order' ;
    rdfs:comment 'Core transactional entity representing a maintenance work order (WO) for fleet vehicles or facility assets. Captures WO type (preventive/corrective/emergency), priority, status lifecycle (open, in-progress, on-hold, closed), originating system (SAP PM or Infor EAM), estimated vs. actual labor hours, estimated vs. actual cost, downtime start/end, failure description, root cause, corrective action taken, safety clearance flags (LOTO), DOT inspection linkage, and regulatory compliance indicators. SSOT for all maintenance execution records.' .

ind:PmSchedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Maintenance ;
    rdfs:label 'Pm Schedule' ;
    rdfs:comment 'Preventive Maintenance (PM) schedule master defining recurring maintenance cycles for fleet and facility assets. Stores PM plan type (time-based, meter-based, condition-based), frequency interval (days, miles, engine hours), last performed date/meter reading, next due date/meter reading, estimated duration, assigned crew or technician role, associated task list, DOT inspection cycle flags, and active/inactive status. Sourced from Infor EAM PM module and SAP PM maintenance plans.' .

ind:WoTask rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Maintenance ;
    rdfs:label 'Wo Task' ;
    rdfs:comment 'Individual task or operation line within a work order, representing a discrete step in the maintenance execution workflow. Captures task sequence number, task description, standard task code, estimated labor hours, actual labor hours, assigned technician, task status (pending, in-progress, complete, skipped), required skill/certification (e.g., CDL, ASE), safety instructions, and completion timestamp. Enables granular tracking of multi-step maintenance procedures and technician productivity.' .

ind:PartsUsage rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Maintenance ;
    rdfs:label 'Parts Usage' ;
    rdfs:comment 'Transactional record of parts and materials consumed against a work order. Captures part number, part description, quantity requested, quantity issued, unit of measure, unit cost, total cost, issuing warehouse/storeroom, reservation number, actual issue date, and return quantity. Links to BOM and parts catalog for traceability. Supports COGS allocation, parts consumption analysis, and reorder triggering. Sourced from Infor EAM parts issuance and SAP MM goods issue.' .

ind:RepairHistory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Maintenance ;
    rdfs:label 'Repair History' ;
    rdfs:comment 'Historical record of completed maintenance and repair events for each asset, providing a longitudinal view of asset health and reliability. Captures asset identifier, WO reference, repair type, failure mode, failure code, component repaired, repair description, labor hours, parts cost, total repair cost, technician, completion date, and mileage/hours at repair. Enables MTBF (Mean Time Between Failures), MTTR (Mean Time To Repair), and lifecycle cost analysis. Distinct from the active work_order as it represents the closed/archived maintenance record.' .

ind:DowntimeEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Maintenance ;
    rdfs:label 'Downtime Event' ;
    rdfs:comment 'Captures discrete asset downtime events resulting from maintenance activities or unplanned failures. Records asset identifier, downtime start timestamp, downtime end timestamp, total downtime duration (hours), downtime category (planned PM, unplanned breakdown, awaiting parts, awaiting technician, DOT hold), impact on operations (route cancellation, service disruption), associated work order, and cost of downtime. Critical for fleet availability KPI tracking and operational impact assessment.' .

ind:TechnicianAssignment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Maintenance ;
    rdfs:label 'Technician Assignment' ;
    rdfs:comment 'Association entity linking maintenance technicians to work orders and tasks, capturing the labor execution record. Stores technician employee reference, work order reference, assigned task, assignment type (primary, secondary, supervisor), scheduled start/end datetime, actual start/end datetime, labor hours logged, overtime hours, skill/certification used, and assignment status. Enables labor cost allocation, technician utilization tracking, and crew scheduling. Distinct from workforce employee master — this domain owns the maintenance-specific assignment record.' .

ind:PartsCatalog rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Maintenance ;
    rdfs:label 'Parts Catalog' ;
    rdfs:comment 'Master catalog of all parts, components, and materials used in fleet and facility maintenance operations. Stores part number, part description, manufacturer, OEM part number, part category (engine, hydraulic, electrical, body, tire, filter, fluid), unit of measure, standard cost, reorder point, reorder quantity, lead time days, preferred supplier reference, hazardous material flag, and active/obsolete status. Serves as the BOM (Bill of Materials) reference for work order parts planning. Owned by maintenance domain; procurement domain references for purchasing.' .

ind:Storeroom rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Maintenance ;
    rdfs:label 'Storeroom' ;
    rdfs:comment 'Master record for maintenance storerooms and parts warehouses that hold spare parts inventory for fleet and facility maintenance. Captures storeroom code, storeroom name, location (facility/yard), storeroom type (central, satellite, mobile), responsible manager, physical address, storage capacity, climate-controlled flag, hazmat storage certified flag, and active status. Enables multi-location parts inventory management and storeroom replenishment planning across the fleet maintenance network.' .

ind:PartsInventory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Maintenance ;
    rdfs:label 'Parts Inventory' ;
    rdfs:comment 'Current on-hand inventory levels for parts and materials across all maintenance storerooms. Captures part reference, storeroom reference, bin location, quantity on hand, quantity reserved (allocated to open WOs), quantity on order, minimum stock level, maximum stock level, last physical count date, last count quantity, and inventory valuation. Enables parts availability checks during WO planning, stockout prevention, and inventory carrying cost management. Distinct from parts_catalog (definition) — this is the live inventory position.' .

ind:FailureMode rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Maintenance ;
    rdfs:label 'Failure Mode' ;
    rdfs:comment 'Reference catalog of standardized failure modes and failure codes used to classify asset breakdowns and defects in work orders and repair history. Captures failure mode code, failure mode description, failure category (mechanical, electrical, hydraulic, structural, operator-induced), affected component system, typical root cause, recommended corrective action, and industry standard code mapping (e.g., VMRS codes for fleet). Enables consistent failure classification, trend analysis, and FMEA (Failure Mode and Effects Analysis) support.' .

ind:Type rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Maintenance ;
    rdfs:label 'Type' ;
    rdfs:comment 'Reference classification of maintenance activity types used across work orders and PM schedules. Captures maintenance type code, maintenance type name (Preventive, Corrective, Predictive, Emergency, Condition-Based, DOT Inspection, Warranty, Rebuild), description, planning lead time standard, priority default, cost category mapping, and regulatory reporting flag. Provides standardized taxonomy for maintenance classification across fleet and facility assets.' .

ind:MrfFacility rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Recycling ;
    rdfs:label 'Mrf Facility' ;
    rdfs:comment 'Master record for each Materials Recovery Facility (MRF) operated by Waste Management. Captures facility identity, physical address, permitted capacity (TPD), facility type (single-stream, dual-stream, mixed-waste MRF), operational status, EPA permit number, state permit number, licensed processing capacity, tipping floor area (sq ft), baling line count, sort line count, ownership type, and commissioning date. SSOT for MRF facility identity across the recycling domain.' .

ind:InboundLoad rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Recycling ;
    rdfs:label 'Inbound Load' ;
    rdfs:comment 'Transactional record of each inbound material load received at a MRF. Captures load receipt timestamp, originating route or transfer station, hauling vehicle ID, gross weight (tons), tare weight, net weight, material stream type (single-stream residential, commercial, C&D, drop-off), contamination flag, initial visual contamination estimate (%), tipping fee applied, scale ticket number, driver ID, and receiving dock assignment. Integrates with AMCS for route-to-MRF load reconciliation and SAP MM for material receipt posting.' .

ind:SortLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Recycling ;
    rdfs:label 'Sort Line' ;
    rdfs:comment 'Master record for each sort line (conveyor-based sorting system) and its installed equipment within a MRF facility. Captures sort line identity, facility reference, line type (pre-sort, OCC, fiber, container, residue), design throughput (TPH), station count, automation level, and operational status. Includes equipment inventory: individual equipment assets (balers, optical sorters, conveyors, eddy current separators, magnetic separators, shredders, glass breakers) with manufacturer, model, serial number, installation date, design capacity, maintenance schedule references, and Infor EAM asset references. Supports equipment performance tracking, throughput capacity planning, and maintenance coordination.' .

ind:Commodity rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Recycling ;
    rdfs:label 'Commodity' ;
    rdfs:comment 'Reference master for all recovered commodity types and their quality grade specifications processed and sold from MRF operations. Captures commodity identity (code, name, category), ISRI grade codes, grade-level quality specifications (max contamination %, moisture threshold, bale density requirements, prohibited materials), market classification (positive-value vs residue), unit of measure, and recyclability tier. Grade specifications define acceptance/rejection criteria and drive sales pricing premiums or discounts. SSOT for commodity identity and quality standards across recycling and billing domains.' .

ind:CommodityGrade rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Recycling ;
    rdfs:label 'Commodity Grade' ;
    rdfs:comment 'Reference table defining quality grade specifications for each commodity type processed at MRF facilities. Captures grade code, commodity reference, grade name (e.g., Grade A, Premium, Standard, Off-Grade), maximum allowable contamination percentage, moisture content threshold, minimum bale density (lbs/cubic ft), prohibited materials list, ISRI specification reference, and grade-specific market premium or discount factor. Used for quality control acceptance/rejection decisions and commodity sales pricing.' .

ind:SortSession rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Recycling ;
    rdfs:label 'Sort Session' ;
    rdfs:comment 'Transactional record of a discrete sorting production session on a MRF sort line. Captures session start and end timestamps, sort line reference, shift reference, supervisor ID, total input tonnage processed, throughput rate (TPH), downtime minutes, downtime reason codes, number of sort station operators, material stream composition at input, and session status (active, completed, aborted). Supports operational throughput (TPD) reporting and labor productivity analysis.' .

ind:ContaminationEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Recycling ;
    rdfs:label 'Contamination Event' ;
    rdfs:comment 'Transactional record capturing material quality analysis events during MRF operations — including contamination detection and full material composition audits. Captures event timestamp, inbound load or sort session reference, analysis type (contamination check, full composition audit, NIR scan), material breakdown by category (fiber, plastics, metals, glass, organics, contaminants) as weight percentages, contamination level and type classification, detection method, disposition action, inspector/analyst ID, photographic evidence, and source attribution for generator feedback. Supports contamination trending, diversion rate accuracy, EPA material-specific reporting, and customer education programs.' .

ind:Bale rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Recycling ;
    rdfs:label 'Bale' ;
    rdfs:comment 'Master record for each commodity bale produced at a MRF facility, including production details and quality inspection history. Captures bale identity (barcode/RFID), commodity type, grade assignment, production timestamp, sort line and baler reference, physical measurements (weight, dimensions, density), operator ID, storage location, and bale lifecycle status (in-storage, allocated, shipped, rejected). Includes quality inspection records: inspection type (production QC, pre-shipment, buyer-requested), measured contamination and moisture percentages, pass/fail result, rejection reasons, and re-inspection flags. SSOT for bale identity, traceability from production through shipment, and quality certification.' .

ind:CommodityInventory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Recycling ;
    rdfs:label 'Commodity Inventory' ;
    rdfs:comment 'Operational inventory snapshot of recovered commodity bales held in MRF storage at any point in time. Captures facility reference, commodity reference, commodity grade, total bales on hand, total weight on hand (tons), storage location summary, oldest bale production date, average bale age (days), allocated quantity (committed to pending sales orders), available quantity, and last physical count date. Integrates with SAP MM material inventory for commodity stock management and financial valuation.' .

ind:CommodityBuyer rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Recycling ;
    rdfs:label 'Commodity Buyer' ;
    rdfs:comment 'Master record for commodity buyers and end-market purchasers of recovered materials sold from MRF operations. Captures buyer company name, buyer type (domestic mill, export broker, reprocessor, direct end-user), primary contact name, contact phone, contact email, billing address, shipping address, preferred commodities list, buyer credit status, payment terms, preferred delivery method (FOB MRF, delivered), active/inactive status, and SAP vendor/customer account reference. SSOT for commodity buyer identity within the recycling domain.' .

ind:MarketPrice rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Recycling ;
    rdfs:label 'Market Price' ;
    rdfs:comment 'Reference record capturing current and historical commodity market prices used for MRF commodity sales valuation and revenue forecasting. Captures commodity reference, price effective date, price expiration date, price source (OBM — Official Board Markets, RISI, internal contract, spot market), price per ton (USD), price region (national, regional, local), currency code, and price type (spot, contract, index-linked). Supports commodity revenue management and diversion rate financial reporting.' .

ind:CommoditySale rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Recycling ;
    rdfs:label 'Commodity Sale' ;
    rdfs:comment 'Transactional record of commodity sale transactions from a MRF to commodity buyers, including line-item detail for multi-commodity or multi-grade orders. Captures sale order number, sale date, facility reference, buyer reference, shipment method, sale status, payment terms, BOL number, and SAP SD reference. Line items capture commodity type, grade, bale count, net weight (tons), unit price (USD/ton), line total value, and bale ID references. Supports single-commodity and multi-commodity sale orders with full commodity-level revenue tracking, pricing reconciliation against market indices, and integration with billing domain for invoicing.' .

ind:OutboundShipment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Recycling ;
    rdfs:label 'Outbound Shipment' ;
    rdfs:comment 'Transactional record of a physical outbound commodity shipment from a MRF facility to a buyer. Captures shipment date, MRF facility reference, commodity sale reference, commodity buyer reference, carrier name, vehicle/container ID, BOL number, total bales shipped, gross weight (tons), tare weight, net weight (tons), departure timestamp, estimated arrival date, actual arrival date, shipment status (scheduled, loaded, in-transit, delivered, confirmed), and driver name. Supports commodity logistics traceability and buyer delivery confirmation.' .

ind:ResidueDisposal rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Recycling ;
    rdfs:label 'Residue Disposal' ;
    rdfs:comment 'Transactional record capturing the disposal of MRF residue (non-recoverable material) sent to landfill or alternative disposal. Captures disposal date, MRF facility reference, residue weight (tons), disposal destination (landfill site ID, WTE facility ID), disposal method (landfill, WTE, alternative), tipping fee per ton, total disposal cost, BOL or manifest number, hauling vehicle ID, and residue composition notes. Supports residue cost management, diversion rate calculation, and landfill domain integration.' .

ind:MrfEquipment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Recycling ;
    rdfs:label 'Mrf Equipment' ;
    rdfs:comment 'Master record for MRF-specific processing equipment assets including balers, optical sorters, conveyors, eddy current separators, magnetic separators, shredders, and glass breakers. Captures equipment ID, equipment name, equipment type, manufacturer, model number, serial number, MRF facility reference, sort line assignment, installation date, design throughput capacity (TPH), operational status, last PM date, next PM due date, and Infor EAM asset reference. Distinct from fleet vehicles — covers fixed MRF processing plant equipment only.' .

ind:BuyerContract rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Recycling ;
    rdfs:label 'Buyer Contract' ;
    rdfs:comment 'Master record for commodity offtake agreements and sales contracts between Waste Management MRF operations and commodity buyers. Captures contract number, commodity buyer reference, commodity reference, contract type (spot, short-term, long-term offtake), contract start date, contract end date, committed volume (tons/month), price mechanism (fixed, index-linked, floor-and-ceiling), price index reference, minimum quality grade required, penalty clauses for contamination, contract status (draft, active, expired, terminated), and SAP SD contract reference. Distinct from the contract domain — this is the MRF-specific commodity sales agreement.' .

ind:Program rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Recycling ;
    rdfs:label 'Program' ;
    rdfs:comment 'Master record defining recycling collection programs served by MRF facilities, including municipal curbside programs, commercial recycling programs, drop-off center programs, and special collection events. Captures program name, program type, sponsoring municipality or customer account reference, service area (geographic boundary), accepted materials list, program start date, program end date, diversion rate target (%), annual tonnage commitment, program status, and AMCS program reference. Links collection operations to MRF processing for end-to-end diversion tracking.' .

ind:Site rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Landfill ;
    rdfs:label 'Site' ;
    rdfs:comment 'Master record for each landfill facility. Captures site identity, physical location (GPS coordinates, address, county, state), permitted acreage, total design capacity (cubic yards and tons), current operational status (active/closed/post-closure), RCRA Subtitle D permit number, EPA facility ID, state SWIS registration number, liner system type, leachate management system type, LFG collection system presence, host community agreement reference, regulatory jurisdiction, and site classification (MSW, C&D, monofill). Top-level anchor for all landfill operational, environmental, and compliance data.' .

ind:Cell rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Landfill ;
    rdfs:label 'Cell' ;
    rdfs:comment 'Master record for each discrete waste placement cell within a landfill site. Tracks cell identifier (CID), cell phase (active, filled, closed), design volume (cubic yards), permitted waste types (MSW, C&D, special waste), liner system specifications (single, double, composite), leachate collection system tie-in, cell opening date, projected fill date, actual closure date, base elevation, top elevation, and cell geometry coordinates. Supports airspace consumption tracking and cell sequencing for capacity planning. Sourced from AMCS Platform and Enviance EHS.' .

ind:TonnageReceipt rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Landfill ;
    rdfs:label 'Tonnage Receipt' ;
    rdfs:comment 'Transactional record of each waste load received at the landfill scale house. Captures ticket number, inbound vehicle ID, hauler/carrier identity, waste origin (route, transfer station, or direct customer), waste type classification (MSW, C&D, special waste, sludge), gross weight, tare weight, net tonnage, moisture content estimate, load rejection flag, rejection reason, assigned disposal cell, tipping fee rate applied, tipping fee amount charged, scale operator ID, and receipt timestamp. Primary source for TPD (Tons Per Day) reporting and tipping fee revenue recognition. Sourced from Oracle Revenue Management and AMCS Platform.' .

ind:AirspaceConsumption rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Landfill ;
    rdfs:label 'Airspace Consumption' ;
    rdfs:comment 'Periodic transactional record tracking cumulative and incremental airspace consumed within each landfill cell and across the entire site. Captures measurement date, survey method (drone photogrammetry, GPS survey, LiDAR), volume consumed in the period (cubic yards), cumulative volume consumed, remaining permitted airspace, compaction ratio achieved (in-place density vs. design density), waste tonnage placed in period, and surveyor certification reference. Feeds capacity planning and regulatory airspace reporting. Sourced from Enviance EHS and field survey data.' .

ind:DailyCover rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Landfill ;
    rdfs:label 'Daily Cover' ;
    rdfs:comment 'Transactional record of daily cover application events at the active face of each landfill cell. Tracks cover date, cell reference, cover material type (soil, alternative daily cover/ADC, tarps, foam), volume of cover material applied (cubic yards), thickness achieved (inches), working face area covered (square feet), operator ID, equipment used, weather conditions, and regulatory compliance flag (meets 6-inch soil or approved ADC standard per RCRA Subtitle D). Supports regulatory compliance documentation and cover material inventory management. Sourced from Enviance EHS.' .

ind:LeachateCollection rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Landfill ;
    rdfs:label 'Leachate Collection' ;
    rdfs:comment 'Transactional record of leachate generation, collection, and management events at each landfill site. Captures collection date, collection point (sump ID, pipe segment), volume collected (gallons), leachate head level (inches above liner), pH, conductivity, chemical oxygen demand (COD), and other key quality parameters. Records disposal method (on-site treatment, off-site TSDF, municipal sewer discharge under permit), disposal volume, disposal cost, and permit limit compliance flags. Critical for Clean Water Act compliance and liner integrity monitoring. Sourced from Enviance EHS.' .

ind:LfgMonitoring rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Landfill ;
    rdfs:label 'Lfg Monitoring' ;
    rdfs:comment 'Transactional record of landfill gas (LFG) monitoring readings across the site perimeter, extraction wells, and interior probes. Captures monitoring date and time, probe or well ID, location coordinates, methane concentration (% by volume), CO2 concentration, LEL (Lower Explosive Limit) percentage, oxygen level, nitrogen level, LFG flow rate (SCFM), static pressure, temperature, and exceedance flag (LEL > 25% triggers regulatory action). Supports EPA Clean Air Act surface emissions monitoring and NSPS Subpart WWW compliance. Sourced from Enviance EHS.' .

ind:LfgExtractionWell rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Landfill ;
    rdfs:label 'Lfg Extraction Well' ;
    rdfs:comment 'Master record for each LFG extraction well installed within the landfill. Tracks well ID, cell reference, installation date, well depth (feet), well casing material, screen interval, wellhead equipment type, current operational status (active, idle, abandoned), connected header pipe segment, and design extraction rate (SCFM). Supports LFG collection system management, RNG (Renewable Natural Gas) production planning, and EPA compliance. Sourced from Enviance EHS and Infor EAM.' .

ind:GroundwaterMonitoringWell rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Landfill ;
    rdfs:label 'Groundwater Monitoring Well' ;
    rdfs:comment 'Master record for each groundwater monitoring well at a landfill site. Captures well ID, site reference, well designation (upgradient, downgradient, compliance), installation date, total depth (feet), screened interval, aquifer zone monitored, GPS coordinates, sampling frequency (quarterly, semi-annual, annual), regulatory permit reference, and current operational status. Anchors all groundwater sampling events and is required for RCRA Subtitle D detection monitoring programs. Sourced from Enviance EHS.' .

ind:GroundwaterSample rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Landfill ;
    rdfs:label 'Groundwater Sample' ;
    rdfs:comment 'Transactional record of each groundwater sampling event conducted at a monitoring well. Captures sample date, well reference, sampling technician, field parameters (pH, temperature, conductivity, dissolved oxygen, turbidity), laboratory sample IDs, chain-of-custody number, analytical parameters tested (VOCs, metals, indicator parameters per EPA Method 8260/6010), detected concentrations, applicable groundwater protection standard (GWPS) limits, exceedance flags, and required regulatory notification status. Supports RCRA Subtitle D detection and assessment monitoring compliance. Sourced from Enviance EHS.' .

ind:CapacityPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Landfill ;
    rdfs:label 'Capacity Plan' ;
    rdfs:comment 'Versioned master record for the site-level airspace capacity planning model. Tracks plan version, effective date, total permitted capacity (cubic yards and tons), capacity consumed to date, remaining airspace, projected site life (years), annual waste acceptance rate assumption (TPD), compaction ratio assumption, cover factors (daily/intermediate/final), projected closure year, vertical expansion assumptions, and plan approval status. Drives long-range capital planning, permit renewal timing, and executive site-life reporting.' .

ind:LandfillTippingFeeSchedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Landfill ;
    rdfs:label 'Landfill Tipping Fee Schedule' ;
    rdfs:comment 'Reference master defining tipping fee rates charged to customers and haulers for waste disposal at each landfill site. Captures fee schedule version, effective date range, site reference, waste type (MSW, C&D, special waste, sludge, tires), customer segment (municipal, commercial, self-haul), unit of measure (per ton, per cubic yard, per load), base rate, surcharges (fuel, environmental, regulatory), minimum charge, and approval status. Drives tipping fee calculation on tonnage receipts and integrates with Oracle Revenue Management for billing. Sourced from Oracle Revenue Management.' .

ind:DisposalPermit rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Landfill ;
    rdfs:label 'Disposal Permit' ;
    rdfs:comment 'Master record for each regulatory permit governing landfill operations at a site. Captures permit number, issuing regulatory agency (EPA, state environmental agency, LEA), permit type (solid waste facility permit, air permit, water discharge permit, stormwater NPDES), permitted waste types, permitted daily tonnage limit, permitted total capacity, permit issuance date, expiration date, renewal application due date, permit conditions summary, and current compliance status. Anchors all regulatory compliance activities and reporting obligations. Sourced from Enviance EHS.' .

ind:RegulatoryInspection rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Landfill ;
    rdfs:label 'Regulatory Inspection' ;
    rdfs:comment 'Transactional record of regulatory agency inspections conducted at a landfill site. Captures inspection date, inspecting agency (EPA, state, LEA), inspector name and credentials, inspection type (routine, complaint-driven, follow-up), areas inspected (active face, leachate system, LFG system, groundwater monitoring), findings and violations cited (with regulatory citation), corrective action required, corrective action due date, and inspection closure status. Supports RCRA Subtitle D compliance tracking and CERCLA/Superfund obligation management. Sourced from Enviance EHS.' .

ind:ClosurePlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Landfill ;
    rdfs:label 'Closure Plan' ;
    rdfs:comment 'Master record for the closure and post-closure care plan for each landfill site or cell, including the 30-year post-closure monitoring program. Captures plan version, regulatory approval status, planned closure date, final cap system design (cap layers, materials, thickness), post-closure care period and monitoring schedule, estimated closure and post-closure costs, financial assurance mechanism (trust fund, surety bond, letter of credit, insurance), financial assurance amount, post-closure monitoring activities (cap inspection, settlement survey, LFG monitoring, groundwater sampling, leachate check, vegetation assessment), and plan revision history. Required under RCRA Subtitle D for all permitted MSW landfills.' .

ind:StormwaterEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Landfill ;
    rdfs:label 'Stormwater Event' ;
    rdfs:comment 'Transactional record of stormwater management events at a landfill site including discharge monitoring, best management practice (BMP) inspections, and NPDES permit compliance checks. Captures event date, event type (discharge monitoring, BMP inspection, spill response), monitoring location, precipitation amount (inches), discharge volume (gallons), discharge point (outfall ID), analytical results (TSS, pH, BOD, metals), NPDES permit limit comparison, exceedance flag, and corrective action taken. Supports Clean Water Act NPDES stormwater permit compliance. Sourced from Enviance EHS.' .

ind:SpecialWasteApproval rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Landfill ;
    rdfs:label 'Special Waste Approval' ;
    rdfs:comment 'Transactional record of pre-approval decisions for non-standard or special waste streams proposed for disposal at a landfill. Captures approval request date, requesting customer or hauler, waste description, waste origin, estimated volume (tons or cubic yards), proposed disposal cell, waste characterization data (TCLP results, analytical profile), regulatory classification determination, approval or rejection decision, approved disposal conditions, approval expiration date, and approving authority. Ensures only permitted waste types are accepted and supports RCRA Subtitle D waste acceptance criteria compliance. Sourced from Enviance EHS and Waste Logics.' .

ind:Route rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Collection ;
    rdfs:label 'Route' ;
    rdfs:comment 'Master record for a defined waste collection route, representing a named geographic sequence of stops assigned to a specific truck type (ASL, FEL, REL) and service line (MSW, C&D, bulk). Captures route code, district, zone, day-of-week schedule, estimated duration, total stops, total mileage, truck type requirement, service frequency, capacity constraints, and active status. Sourced from AMCS Platform route master. This is the canonical route definition — the template from which daily route executions are generated. One route may produce multiple executions per week depending on service frequency.' .

ind:RouteExecution rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Collection ;
    rdfs:label 'Route Execution' ;
    rdfs:comment 'Transactional record capturing a single day\'s actual execution of a route. Represents the operational instance of a route on a specific date, including assigned driver, assigned truck, planned vs. actual start/end times, total stops completed, total stops missed, total tonnage collected (TPD), route completion percentage, fuel consumed, and execution status (in-progress, completed, incomplete, cancelled). Sourced from AMCS Platform and Locus Dispatch. One record per route per service date.' .

ind:Stop rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Collection ;
    rdfs:label 'Stop' ;
    rdfs:comment 'Master record for an individual service stop on a route, representing a physical service location (residential address or commercial site) with a defined sequence position. Captures stop sequence number, planned arrival window, estimated service duration, service address, customer account reference, container count, service type (curbside, alley, drive-in), access notes, CID/RFID tag identifiers for containers at this stop, special instructions (gate codes, back-up required), and stop status. Sourced from AMCS Platform and Waste Logics. SSOT for the stop-level service assignment and sequencing within a route.' .

ind:PickupEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Collection ;
    rdfs:label 'Pickup Event' ;
    rdfs:comment 'Transactional record capturing the actual execution of a single waste pickup at a stop during a route execution, including container-level proof of service via RFID. Records timestamp of arrival, timestamp of service completion, driver ID, truck ID, container(s) serviced (by CID/RFID), RFID scan result (successful read, no read, damaged tag), lift confirmation from PTO sensor, waste stream type (MSW, recycling, C&D, bulk), estimated weight or lift count, GPS coordinates at time of service, compaction ratio recorded, and service outcome (completed, skipped, contaminated). Sourced from Locus Dispatch, Geotab telemetry, and AMCS Platform RFID readers. Core operational event of the collection domain — SSOT for both service execution and container-level proof-of-service.' .

ind:ServiceException rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Collection ;
    rdfs:label 'Service Exception' ;
    rdfs:comment 'Transactional record for any non-standard service event during collection operations including missed pickups, contamination events, blocked access, overweight containers, and other exceptions requiring documentation and potential customer follow-up' .

ind:ContainerPlacement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Collection ;
    rdfs:label 'Container Placement' ;
    rdfs:comment 'Master record tracking the physical placement and assignment of a container (dumpster, cart, roll-off box) at a customer service location. Captures container CID (Container Identification number), RFID tag ID, container type (2-yd dumpster, 4-yd, 6-yd, 8-yd, 96-gal cart, roll-off), size, material stream (MSW, recycling, organics, C&D), placement date, removal date, service address, customer account reference, placement status (active, pending removal, removed), and GPS coordinates of placement. Sourced from AMCS Platform and Waste Logics. SSOT for container-to-location assignment.' .

ind:DriverAssignment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Collection ;
    rdfs:label 'Driver Assignment' ;
    rdfs:comment 'Transactional record capturing the assignment of a CDL-licensed driver to a specific route execution on a given service date. Records driver ID, route execution reference, truck ID, assignment type (primary, relief, trainee), shift start time, shift end time, pre-trip inspection status, DOT hours-of-service compliance flag, and assignment status (scheduled, active, completed, absent). Sourced from Locus Dispatch and Workday HCM. Enables driver performance tracking, DOT compliance, and route coverage management.' .

ind:TruckAssignment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Collection ;
    rdfs:label 'Truck Assignment' ;
    rdfs:comment 'Transactional record capturing the assignment of a specific collection vehicle (ASL, FEL, REL, roll-off, CNG/RNG unit) to a route execution on a given service date. Records vehicle ID, route execution reference, truck type, fuel type (diesel, CNG, RNG), odometer at assignment, pre-trip inspection pass/fail, assigned capacity (cubic yards), and assignment status. Sourced from AMCS Platform and Geotab Fleet Telematics. Distinct from driver_assignment — a truck and driver are assigned independently and may change mid-route.' .

ind:ServiceSchedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Collection ;
    rdfs:label 'Service Schedule' ;
    rdfs:comment 'Master record defining the recurring service schedule for a customer stop — the days of week, frequency (weekly, bi-weekly, monthly, on-call), effective date range, and service windows. Captures customer account reference, stop reference, service frequency code, scheduled days of week, start date, end date, holiday handling rule, and schedule status. Sourced from Waste Logics and AMCS Platform. SSOT for when a customer is supposed to receive service — distinct from route_stop_sequence which defines the order within a route.' .

ind:RouteOptimizationRun rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Collection ;
    rdfs:label 'Route Optimization Run' ;
    rdfs:comment 'Transactional record capturing each execution of the route optimization algorithm in AMCS Platform, including the optimization scenario (daily re-optimization, seasonal rebalancing, new customer onboarding), input parameters (number of stops, truck count, time windows, vehicle capacities), optimization objectives (minimize miles, minimize time, maximize compaction), output metrics (total route miles, total route hours, stops per truck), and whether the optimized plan was accepted or rejected. Sourced from AMCS Platform. Enables optimization performance tracking and scenario comparison.' .

ind:District rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Collection ;
    rdfs:label 'District' ;
    rdfs:comment 'Master reference entity defining the geographic collection districts and zones used to organize route planning and operational management. Captures district code, district name, zone code, municipality or jurisdiction, geographic boundary description, service type supported (residential, commercial, C&D), assigned operations manager, and active status. Sourced from AMCS Platform geographic configuration. Enables geographic reporting, district-level performance management, and regulatory jurisdiction alignment.' .

ind:OnDemandRequest rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Collection ;
    rdfs:label 'On Demand Request' ;
    rdfs:comment 'Transactional record for customer-initiated on-demand or special collection requests outside the standard recurring schedule — including bulk item pickup, extra bag/sticker service, special event cleanup, and on-call commercial pickups (excludes roll-off orders which have their own lifecycle). Captures request type, customer account reference, service address, requested service date, container type if applicable, waste stream, priority level, fulfillment status (pending, scheduled, completed, cancelled), assigned route or driver, and completion timestamp. Sourced from Waste Logics customer portal and Salesforce CRM service requests.' .

ind:RolloffOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Collection ;
    rdfs:label 'Rolloff Order' ;
    rdfs:comment 'Transactional record managing the full lifecycle of a roll-off container order for C&D, commercial, or industrial customers. Captures order number, customer account reference, service address, container size (10-yd, 20-yd, 30-yd, 40-yd), waste stream (C&D, MSW, clean fill, metal), delivery date, swap date(s), pull date, rental duration, weight limit, overage terms, permit required flag, permit number, assigned truck and driver, and order status (pending, delivered, on-site, swapped, pulled, invoiced). Sourced from Waste Logics and AMCS Platform. Distinct from standard recurring pickup — roll-off has its own delivery/swap/pull workflow.' .

ind:WeightTicket rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Collection ;
    rdfs:label 'Weight Ticket' ;
    rdfs:comment 'Transactional record capturing the official weight measurement of a collection vehicle at a disposal or transfer facility upon completion of a route or partial load. Records truck ID, route execution reference, facility received at (landfill, transfer station, MRF, WTE), gross weight, tare weight, net weight (tons), waste stream, ticket number, scale operator ID, timestamp, and disposal authorization number. Sourced from facility scale systems and SAP SD. SSOT for tonnage data used in billing (tipping fees), regulatory reporting (TPD), and route performance measurement.' .

ind:HazardousWasteGenerator rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Hazmat ;
    rdfs:label 'Hazardous Waste Generator' ;
    rdfs:comment 'Master record for each EPA-registered hazardous waste generator (large quantity, small quantity, or very small quantity). Captures EPA ID number, generator category (LQG/SQG/VSQG), site address, RCRA permit status, emergency contact, contingency plan reference, accumulation time limits, and regulatory notification history. Serves as the authoritative identity record for all waste-generating sites managed under RCRA Subtitle C.' .

ind:WasteProfile rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Hazmat ;
    rdfs:label 'Waste Profile' ;
    rdfs:comment 'Waste characterization profile defining the physical and chemical properties of a specific hazardous waste stream. Captures waste code(s) (EPA D/F/K/P/U codes), TCLP test results, physical state, pH, ignitability, corrosivity, reactivity, toxicity characteristics, DOT hazard class, UN/NA number, proper shipping name, and approval status. Each profile is approved before waste is accepted for treatment or disposal. Sourced from SAP EHS and Enviance EHS.' .

ind:Manifest rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Hazmat ;
    rdfs:label 'Manifest' ;
    rdfs:comment 'Uniform Hazardous Waste Manifest (EPA Form 8700-22) tracking cradle-to-grave movement of hazardous waste from generator to TSDF. Captures manifest number, generator EPA ID, transporter EPA ID(s), designated TSDF EPA ID, waste descriptions, container types and counts, total quantity, DOT shipping information, emergency response phone, special handling instructions, and all required signatures (generator, transporter, TSDF). Supports e-Manifest (EPA RCRAInfo) integration.' .

ind:ManifestLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Hazmat ;
    rdfs:label 'Manifest Line' ;
    rdfs:comment 'Individual waste stream line item on a hazardous waste manifest. Captures line number, waste description, EPA waste codes, DOT hazard class, UN/NA number, container type (drum, tote, tank), container count, unit of measure, total quantity (lbs/gallons), physical state, and special handling notes. Each manifest may carry multiple waste streams requiring separate line entries per DOT HMR and RCRA requirements.' .

ind:HazmatContainer rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Hazmat ;
    rdfs:label 'Hazmat Container' ;
    rdfs:comment 'Master record for individual hazardous waste containers (drums, totes, IBCs, lab packs, roll-offs) tracked by CID/RFID. Captures container type, capacity, material of construction, UN performance rating, current waste profile assignment, fill level, tare weight, gross weight, accumulation start date, storage location (satellite, 90-day, permitted storage), container condition, and chain-of-custody status. Integrates with AMCS container tracking and SAP EHS.' .

ind:TsdfFacility rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Hazmat ;
    rdfs:label 'Tsdf Facility' ;
    rdfs:comment 'Master record for Treatment, Storage, and Disposal Facilities (TSDFs) authorized to receive hazardous waste. Captures EPA ID number, facility name, address, RCRA permit number and expiration, permitted waste codes, treatment/storage/disposal methods (TSDF type codes), emergency coordinator, insurance certificate status, financial assurance mechanism, and approval status for use as a designated facility on manifests. Sourced from Enviance EHS vendor/facility registry.' .

ind:WasteShipment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Hazmat ;
    rdfs:label 'Waste Shipment' ;
    rdfs:comment 'Operational record of a hazardous waste pickup and transport event from a generator site to a TSDF or transfer facility. Captures shipment date, originating generator site, destination TSDF, assigned transporter, vehicle and driver details, manifest number reference, BOL number, total weight (lbs), container count, DOT placard requirements, route restrictions, actual departure and arrival timestamps, and shipment status (scheduled, in-transit, delivered, exception). Integrates with Locus Dispatch and Geotab telematics.' .

ind:ChainOfCustody rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Hazmat ;
    rdfs:label 'Chain Of Custody' ;
    rdfs:comment 'Immutable chain-of-custody record documenting every transfer of possession for hazardous waste containers from generation through final disposal. Captures transfer event type (generator handoff, transporter receipt, TSDF acceptance, treatment completion, disposal confirmation), transferring party EPA ID, receiving party EPA ID, transfer timestamp, container IDs transferred, witness/signature information, and discrepancy notes. Supports RCRA cradle-to-grave accountability and CERCLA liability documentation.' .

ind:TreatmentRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Hazmat ;
    rdfs:label 'Treatment Record' ;
    rdfs:comment 'Record of hazardous waste treatment operations performed at a TSDF or permitted on-site treatment unit. Captures treatment date, treatment unit ID, treatment technology code (incineration, neutralization, stabilization, fuel blending, solvent recovery), input waste stream and quantity, treatment parameters (temperature, pH, residence time), output residual characterization, emission control data, operator certification, and regulatory unit code per RCRA land disposal restrictions (LDR). Sourced from SAP EHS treatment logs.' .

ind:DisposalRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Hazmat ;
    rdfs:label 'Disposal Record' ;
    rdfs:comment 'Final disposal confirmation record documenting the ultimate fate of hazardous waste at a permitted TSDF. Captures disposal date, TSDF facility ID, disposal method (landfill cell, deep well injection, incineration ash disposal), disposal unit ID, waste quantity disposed (lbs/tons), manifest number, certificate of disposal number, land disposal restriction (LDR) compliance certification, and TSDF signature. Closes the cradle-to-grave tracking loop required by RCRA Subtitle C.' .

ind:ServiceOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Hazmat ;
    rdfs:label 'Service Order' ;
    rdfs:comment 'Service order for hazardous waste collection, packaging, transportation, or treatment services requested by a customer. Captures order date, customer account reference, service type (drum pickup, lab pack, bulk liquid, emergency response), requested service date, site address, estimated waste quantity and type, assigned crew and vehicle, special handling requirements, safety briefing requirements, pricing basis (per drum, per lb, per trip), and order status lifecycle (quoted, confirmed, scheduled, completed, invoiced). Integrates with Salesforce CRM and Oracle Revenue Management.' .

ind:EpaIdRegistration rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Hazmat ;
    rdfs:label 'Epa Id Registration' ;
    rdfs:comment 'EPA Identification Number registration record for each regulated site (generators, transporters, TSDFs). Captures EPA ID number, site name, site address, regulated activity types (generator, transporter, TSDF), RCRA notification form submission date, notification type (initial, subsequent, withdrawal), handler status, large/small/very small quantity generator classification, and state agency notification status. Serves as the regulatory identity anchor for all RCRA compliance activities. Sourced from EPA RCRAInfo and Enviance EHS.' .

ind:RcraBiennialReport rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Hazmat ;
    rdfs:label 'Rcra Biennial Report' ;
    rdfs:comment 'RCRA Biennial Report submission record required of large quantity generators (LQGs) every even-numbered year per 40 CFR Part 262 Subpart D. Captures reporting year, EPA ID, total waste generated by waste code (lbs), waste minimization activities, treatment/disposal methods used, TSDF destinations, on-site management quantities, and submission status (draft, submitted, acknowledged by state agency). Sourced from Enviance EHS regulatory reporting module and SAP EHS.' .

ind:WasteCode rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Hazmat ;
    rdfs:label 'Waste Code' ;
    rdfs:comment 'Reference table of EPA and state hazardous waste codes used to classify hazardous waste streams. Captures waste code (D001–D043, F-listed, K-listed, P-listed, U-listed), waste code description, hazard basis (ignitability, corrosivity, reactivity, toxicity, listed), regulatory citation (40 CFR Part 261 subpart), applicable treatment standards, state-specific code flag, and active status. Used across waste profiles, manifests, and regulatory reports for standardized waste classification.' .

ind:DotHazmatClassification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Hazmat ;
    rdfs:label 'Dot Hazmat Classification' ;
    rdfs:comment 'Reference table of DOT Hazardous Materials classifications per 49 CFR Parts 171–180 (HMR). Captures hazard class/division (1–9), UN/NA number, proper shipping name, packing group (I/II/III), label requirements, placard requirements, special provisions, packaging authorizations, quantity limits for passenger/cargo aircraft, and marine pollutant flag. Used to populate manifest shipping descriptions and ensure DOT HMR compliance for all hazardous waste transport.' .

ind:StorageUnit rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Hazmat ;
    rdfs:label 'Storage Unit' ;
    rdfs:comment 'Master record for permitted hazardous waste storage units at generator sites or TSDFs. Captures unit ID, unit type (satellite accumulation area, 90-day accumulation area, permitted storage tank, container storage building, drip pad, containment building), physical location, maximum permitted capacity (gallons/lbs), secondary containment type, inspection frequency requirement, permit or exemption basis, current inventory quantity, and unit status (active, closed, under inspection). Supports RCRA storage time limit tracking.' .

ind:TransporterRegistration rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Hazmat ;
    rdfs:label 'Transporter Registration' ;
    rdfs:comment 'Master record for EPA-registered hazardous waste transporters authorized to transport waste on behalf of Waste Management. Captures transporter EPA ID, company name, DOT operating authority number, state transporter permits, insurance certificate details, vehicle types authorized, waste types authorized, HAZMAT employee training compliance status, and approval status for use on manifests. Distinct from the fleet domain\'s vehicle records — this is the regulatory transporter entity identity.' .

ind:Vehicle rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fleet ;
    rdfs:label 'Vehicle' ;
    rdfs:comment 'Master record for every mobile asset in the Waste Management fleet including ASL (Automated Side Loader), FEL (Front End Loader), REL (Rear End Loader), roll-off trucks, transfer tractors, CNG/RNG-fueled units, and support vehicles. Captures vehicle identification (VIN, unit number, license plate), make, model, year, body type, fuel type, GVWR, axle configuration, DOT registration number, acquisition date and cost, current odometer and engine hours, operational status, assigned district/division, home yard, and detailed technical specifications (engine, transmission, hydraulic system, compaction type, lift mechanism, body capacity, payload capacity, fuel tank capacity, emissions certification). This is the SSOT for vehicle identity and specifications in the fleet domain.' .

ind:VehicleRegistration rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fleet ;
    rdfs:label 'Vehicle Registration' ;
    rdfs:comment 'DOT and state motor vehicle registration records for each fleet unit. Tracks registration number, issuing state, registration class, expiration date, renewal date, IRP (International Registration Plan) apportionment details, IFTA (International Fuel Tax Agreement) decal number, UCR (Unified Carrier Registration) status, DOT number, MC number (if applicable), annual inspection due date, and cab card storage location. Critical for DOT/FMCSA regulatory compliance and roadside inspection readiness.' .

ind:Driver rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fleet ;
    rdfs:label 'Driver' ;
    rdfs:comment 'Master record for all CDL (Commercial Driver License) holders and non-CDL operators assigned to fleet vehicles. Captures driver employee ID (FK to workforce domain), CDL number, class (A/B/C), state of issuance, expiration date, endorsements (Hazmat, Tanker, Doubles/Triples), medical examiner certificate details, DOT physical due date, MVR status, HazMat clearance, drug/alcohol program enrollment, current qualification status, last qualification review date, next review due date, and operational status. SSOT for driver identity and qualification records within the fleet domain.' .

ind:VehicleAssignment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fleet ;
    rdfs:label 'Vehicle Assignment' ;
    rdfs:comment 'Transactional record of driver-to-vehicle assignments for each operational shift or day. Captures assigned driver, assigned vehicle unit, assignment date, shift start time, shift end time, route or run assignment reference, pre-trip inspection completion flag, post-trip inspection completion flag, odometer at assignment start, odometer at assignment end, engine hours at start, engine hours at end, and assignment status. Supports HOS (Hours of Service) tracking, vehicle utilization reporting, and driver accountability.' .

ind:TelematicsEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fleet ;
    rdfs:label 'Telematics Event' ;
    rdfs:comment 'High-frequency GPS and telematics event records sourced from Geotab Fleet Telematics for each vehicle. Captures event timestamp, vehicle unit, GPS latitude, GPS longitude, vehicle speed, posted speed limit, heading, ignition status, engine RPM, engine load percentage, coolant temperature, battery voltage, odometer reading at event, fuel level, idle duration flag, harsh braking event flag, harsh acceleration event flag, seatbelt status, PTO (Power Take-Off) status, and geofence zone identifier. Foundational for route compliance, driver behavior scoring, and fuel consumption analysis.' .

ind:FuelTransaction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fleet ;
    rdfs:label 'Fuel Transaction' ;
    rdfs:comment 'Individual fuel dispensing transaction records for all fleet vehicles covering diesel, CNG (Compressed Natural Gas), and RNG (Renewable Natural Gas) fueling events. Captures transaction date and time, vehicle unit, driver, fuel type, quantity dispensed (gallons or GGE), unit cost, total cost, fuel card number, fueling station identifier (company yard or public station), odometer at fueling, engine hours at fueling, DEF quantity dispensed, and transaction source (fleet card, yard pump, CNG station). Integrates with SAP MM for cost allocation and supports IFTA fuel tax reporting.' .

ind:DotInspection rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fleet ;
    rdfs:label 'Dot Inspection' ;
    rdfs:comment 'Records of DOT roadside inspections and annual vehicle inspections (CVSA — Commercial Vehicle Safety Alliance) for fleet units. Captures inspection date, inspection type (Level I–VI CVSA, Annual DOT, State Patrol), inspection location, inspector name and badge number, inspection result (pass, out-of-service, warning), number of violations cited, violation codes (FMCSA OOS criteria), corrective action required flag, corrective action completion date, and inspection report number. Critical for FMCSA compliance tracking and CSA (Compliance Safety Accountability) score management.' .

ind:PrePostTripInspection rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fleet ;
    rdfs:label 'Pre Post Trip Inspection' ;
    rdfs:comment 'Driver-completed pre-trip and post-trip vehicle inspection records as required by FMCSA 49 CFR Part 396.11. Captures inspection date, inspection type (pre-trip or post-trip), driver, vehicle unit, trailer unit (if applicable), odometer reading, each inspection item result (brakes, lights, tires, mirrors, horn, wipers, coupling devices, emergency equipment, body/frame), defect reported flag, defect description, defect severity, driver signature timestamp, and mechanic acknowledgment timestamp. Feeds directly into maintenance work order generation for reported defects.' .

ind:HosLog rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fleet ;
    rdfs:label 'Hos Log' ;
    rdfs:comment 'Hours of Service (HOS) log records for CDL drivers as mandated by FMCSA ELD (Electronic Logging Device) rules under 49 CFR Part 395. Captures log date, driver, vehicle unit, duty status (off duty, sleeper berth, driving, on-duty not driving), duty status start timestamp, duty status end timestamp, duration in status, cumulative driving hours in 8-day window, cumulative on-duty hours in 8-day window, 30-minute break compliance flag, ELD device identifier, co-driver identifier, shipping document reference, and HOS violation flag with violation type code. Supports FMCSA compliance and driver safety management.' .

ind:AccidentReport rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fleet ;
    rdfs:label 'Accident Report' ;
    rdfs:comment 'DOT-reportable and non-reportable vehicle accident and incident records for fleet units. Captures incident date and time, vehicle unit, driver, incident location (address, GPS coordinates), incident type (collision, rollover, backing incident, pedestrian, property damage), DOT reportability flag (fatality, injury, tow-away), number of injuries, number of fatalities, estimated property damage amount, police report number, citation issued flag, citation description, drug and alcohol post-accident test required flag, test completion status, insurance claim number, and incident investigation status. Required for FMCSA accident register (49 CFR 390.15) and CSA score management.' .

ind:FixedAsset rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Asset ;
    rdfs:label 'Fixed Asset' ;
    rdfs:comment 'Master record for all fixed assets owned or leased by Waste Management, including containers (dumpsters, roll-offs, carts identified by CID/RFID), stationary equipment (compactors, balers, scales), facility infrastructure, and administrative buildings. Tracks asset number, description, asset class, acquisition date, capitalization date, useful life, salvage value, current book value, depreciation method, cost center, plant/location, serial number, manufacturer, model, condition rating, and operational status. Sourced from SAP S/4HANA Asset Accounting (FI-AA) and Infor EAM as the authoritative SSOT for all fixed asset master data.' .

ind:Class rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Asset ;
    rdfs:label 'Class' ;
    rdfs:comment 'Reference classification hierarchy for fixed assets aligned with SAP asset class configuration and GAAP/IFRS capitalization policies. Defines asset categories such as containers, compactors, balers, weighing scales, landfill infrastructure, MRF equipment, WTE plant equipment, transfer station equipment, and buildings. Each class carries depreciation method defaults, useful life ranges, capitalization thresholds, GL account assignments, and RCRA/EPA reporting flags. Enables consistent depreciation calculation and regulatory asset reporting across all Waste Management facilities.' .

ind:AssetContainer rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Asset ;
    rdfs:label 'Asset Container' ;
    rdfs:comment 'Master record for all waste containers deployed in the field, including front-load dumpsters, rear-load dumpsters, roll-off boxes, residential carts, and compactor units. Each container is identified by a unique CID (Container Identification) and optionally an RFID tag or GPS device. Tracks container type, size (cubic yards), material, color, lid type, ownership (owned/leased/customer-owned), deployment status, current service address, last inspection date, condition grade, tare weight, and AMCS container tracking reference. Distinct from fleet (rolling stock) — containers are stationary assets placed at customer sites.' .

ind:Facility rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Asset ;
    rdfs:label 'Facility' ;
    rdfs:comment 'Master record for all Waste Management fixed facilities including landfill sites, MRF (Materials Recovery Facility) plants, WTE (Waste-to-Energy) plants, transfer stations, hazardous waste TSDFs (Treatment Storage and Disposal Facilities), maintenance shops, and administrative offices. Tracks facility name, type, physical address, GPS coordinates, permitted capacity (TPD), operating hours, regulatory permit numbers (air, water, solid waste), LEA (Local Enforcement Agency) jurisdiction, SWIS number, EPA facility ID, operational status, and owning business unit. Serves as the geographic and operational anchor for all site-level asset and compliance data.' .

ind:Location rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Asset ;
    rdfs:label 'Location' ;
    rdfs:comment 'Tracks the current and historical physical location of each asset within the Waste Management network. For containers, records the service address, GPS coordinates, and customer site. For stationary equipment, records the facility, building, bay, or pad location. Captures location type (customer site, facility, yard, in-transit), effective date, and the business reason for the location assignment. Enables real-time asset location visibility, utilization analysis, and lost/missing container investigations. Integrates with AMCS container tracking and Geotab GPS telemetry.' .

ind:Acquisition rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Asset ;
    rdfs:label 'Acquisition' ;
    rdfs:comment 'Records the procurement and capitalization events for fixed assets, capturing how each asset was acquired (purchase, lease, construction, donation, transfer). Tracks acquisition date, vendor/supplier reference, purchase order number, invoice number, acquisition cost, freight and installation costs, total capitalized cost, funding source, approval authority, and SAP asset acquisition document number. Links to the fixed_asset master upon capitalization. Supports GAAP/IFRS asset capitalization policy compliance and capital expenditure (CapEx) tracking against approved budgets.' .

ind:Retirement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Asset ;
    rdfs:label 'Retirement' ;
    rdfs:comment 'Records the retirement, disposal, or write-off of fixed assets from the Waste Management asset register. Captures retirement date, retirement reason (sale, scrapping, theft, damage, end-of-life), proceeds from sale (if any), gain/loss on disposal, retirement document number in SAP FI-AA, approving authority, and environmental disposal certification (for assets containing hazardous materials such as compactors with hydraulic fluid). Ensures complete asset lifecycle closure and supports GAAP/IFRS derecognition accounting and EPA/RCRA disposal compliance.' .

ind:Transfer rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Asset ;
    rdfs:label 'Transfer' ;
    rdfs:comment 'Records the inter-company, inter-plant, or inter-location transfer of fixed assets within the Waste Management network. Captures transfer date, sending facility, receiving facility, transfer reason (redeployment, consolidation, disposal routing), transfer document number, asset condition at transfer, and approving authority. For containers, tracks redeployment from one customer site or yard to another. Supports asset utilization optimization, intercompany accounting entries in SAP FI-AA, and container inventory balancing across districts.' .

ind:AssetInspection rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Asset ;
    rdfs:label 'Asset Inspection' ;
    rdfs:comment 'Records physical condition inspections performed on fixed assets including containers, compactors, balers, scales, and facility infrastructure. Captures inspection date, inspector ID, inspection type (routine, pre-deployment, post-incident, regulatory), overall condition grade (1-5 scale), specific defect findings (dents, cracks, leaks, graffiti, missing lids), pass/fail determination, corrective action required flag, and next scheduled inspection date. Integrates with Infor EAM inspection management and supports OSHA, DOT, and EPA regulatory inspection documentation requirements.' .

ind:Valuation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Asset ;
    rdfs:label 'Valuation' ;
    rdfs:comment 'Stores point-in-time valuation snapshots for fixed assets beyond standard depreciation, including insurance appraisals, fair market value assessments, impairment testing results, and replacement cost estimates. Captures valuation date, valuation type (insurance, impairment, fair value, replacement cost), appraised value, valuation methodology, appraiser reference, and whether an impairment write-down was triggered. Supports GAAP ASC 360 impairment testing, insurance renewal negotiations, and capital planning for asset replacement programs.' .

ind:Bom rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Asset ;
    rdfs:label 'Bom' ;
    rdfs:comment 'Bill of Materials (BOM) for complex fixed assets and stationary equipment, defining the component parts and sub-assemblies that make up each asset. Tracks parent asset, component part number, component description, quantity, unit of measure, manufacturer part number, criticality rating, lead time for replacement, and whether the component is a consumable or capital spare. Sourced from Infor EAM BOM management and SAP PM equipment BOM. Enables preventive maintenance planning, spare parts inventory management, and total cost of ownership analysis for compactors, balers, WTE boilers, and MRF sorting equipment.' .

ind:RfidTag rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Asset ;
    rdfs:label 'Rfid Tag' ;
    rdfs:comment 'Master record for RFID tags assigned to containers and other trackable assets. Captures RFID tag ID (EPC code), tag type (passive UHF, active), tag manufacturer, tag status (active, damaged, replaced, retired), assignment date, asset it is attached to, and last read timestamp. Enables automated container identification during collection events, yard inventory counts, and customer billing verification. Integrates with AMCS Platform container tracking and Waste Logics customer portal for container-level service confirmation.' .

ind:Lease rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Asset ;
    rdfs:label 'Lease' ;
    rdfs:comment 'Master record for operating and finance leases on assets used by Waste Management, including leased containers, compactors, balers, and facility equipment. Captures lessor name, lease type (operating/finance per ASC 842/IFRS 16), lease start and end dates, monthly lease payment, right-of-use (ROU) asset value, lease liability balance, implicit interest rate, renewal options, purchase options, and SAP lease contract reference. Supports IFRS 16/ASC 842 lease accounting compliance, lease vs. buy analysis, and lease portfolio management.' .

ind:Warranty rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Asset ;
    rdfs:label 'Warranty' ;
    rdfs:comment 'Warranty records for fixed assets and equipment, tracking manufacturer and extended warranty coverage. Captures warranty provider, warranty type (parts, labor, comprehensive), coverage start and end dates, warranty terms and conditions, claim limit, deductible amount, warranty contact information, and number of claims filed. Enables proactive warranty utilization before expiration, warranty claim tracking, and vendor performance assessment. Particularly relevant for high-value MRF sorting equipment, WTE boilers, compactors, and balers.' .

ind:CapitalProject rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Asset ;
    rdfs:label 'Capital Project' ;
    rdfs:comment 'Tracks capital expenditure (CapEx) projects for asset construction, major improvements, and infrastructure expansion at Waste Management facilities. Captures project name, project type (new construction, expansion, rehabilitation, technology upgrade), sponsoring facility, approved budget, actual spend to date, project manager, start date, expected completion date, project status, and SAP internal order or WBS element reference. Manages the lifecycle from CapEx approval through asset capitalization, including landfill cell construction, MRF equipment upgrades, and WTE plant expansions.' .

ind:CapitalProjectExpenditure rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Asset ;
    rdfs:label 'Capital Project Expenditure' ;
    rdfs:comment 'Line-level expenditure records posted against capital projects, capturing individual cost transactions that accumulate toward asset capitalization. Records expenditure date, cost element, vendor or internal cost center, amount, purchase order reference, goods receipt reference, and capitalization eligibility flag. Supports project cost tracking, budget variance analysis, and the determination of total capitalized cost when the asset is placed in service. Integrates with SAP FI-CO project accounting and the procurement domain PO/GR process.' .

ind:ContainerInventory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Asset ;
    rdfs:label 'Container Inventory' ;
    rdfs:comment 'Snapshot inventory records of container stock held at Waste Management yards, maintenance shops, and staging areas. Tracks yard location, container type, container size, quantity on hand, quantity reserved for deployment, quantity awaiting repair, quantity condemned, and last physical count date. Enables container inventory management, reorder planning, and deployment scheduling. Supports the AMCS Platform container pool management and Waste Logics container availability queries for customer service representatives.' .

ind:TransferStation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Collection ;
    rdfs:label 'Transfer Station' ;
    rdfs:comment 'Master record for each transfer station facility operated by Waste Management. Captures facility identity, physical address, geographic coordinates, permitted capacity (TPD), operating hours, facility type (MSW, C&D, mixed), regulatory permit numbers, EPA/state facility ID, LEA jurisdiction, scale configuration, tipping floor dimensions, and operational status. This is the SSOT for transfer station facility master data and serves as the anchor entity for all inbound/outbound operations at the facility.' .

ind:LoadTicket rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Collection ;
    rdfs:label 'Load Ticket' ;
    rdfs:comment 'Inbound load ticket (tipping ticket) generated at the transfer station scale house for each vehicle delivering waste. Captures ticket number, originating route or hauler, vehicle/truck ID, driver ID and CDL number, waste stream type (MSW, C&D, recyclables, organics), waste characterization method, contamination level, gross/tare/net weight (tons), tipping fee rate applied, customer or municipal account reference, waste origin jurisdiction, time-in/time-out at scale, gate entry/exit timestamps, pre-entry inspection result, scale operator ID, acceptance/rejection decision with reason code, rejection disposition instructions, and RFID/transponder scan reference. Primary transactional record for all inbound activity at the transfer station — from gate check-in through weighing to acceptance or rejection. Integrates with AMCS and SAP SD for tipping fee billing.' .

ind:ScaleTransaction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Collection ;
    rdfs:label 'Scale Transaction' ;
    rdfs:comment 'Detailed scale house weighing transaction record capturing each individual scale event at the transfer station. Records scale ID, transaction timestamp, vehicle plate/CID, gross weight, tare weight, net weight (tons), scale operator, weighmaster certification reference, scale calibration record reference, transaction type (inbound, outbound, tare-only), and associated load ticket ID. Supports regulatory weighmaster compliance and audit trail for tipping fee disputes. Sourced from AMCS Platform scale integration.' .

ind:TippingFeeRate rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Collection ;
    rdfs:label 'Tipping Fee Rate' ;
    rdfs:comment 'Reference table defining tipping fee rate schedules applied at each transfer station. Captures rate ID, transfer station reference, waste stream type (MSW, C&D, special waste, hazardous), customer segment (residential, commercial, municipal, self-haul), rate per ton, minimum charge, effective date, expiration date, rate basis (per ton, per load, per yard), regulatory rate cap reference, and approval status. Used by SAP SD and Oracle Revenue Management for tipping fee invoice generation. Distinct from billing domain rate schedules — this is the operational rate reference owned by transfer operations.' .

ind:OutboundHaul rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Collection ;
    rdfs:label 'Outbound Haul' ;
    rdfs:comment 'Outbound haul assignment and manifest record dispatching consolidated waste loads from the transfer station to a destination facility (landfill, MRF, WTE, TSDF). Captures haul ID, transfer station origin, destination facility type and ID, assigned transfer trailer/vehicle, driver assignment, scheduled and actual departure datetimes, estimated arrival, waste stream type, estimated tonnage, BOL number, manifest number (if hazardous), waste classification codes (EPA/RCRA), seal numbers, carrier DOT number, chain-of-custody signatures, haul contractor reference, and haul status (scheduled, in-transit, delivered, rejected). Core operational record bridging transfer to landfill/recycling/energy domains. Supports DOT compliance on all outbound loads and RCRA manifest requirements for special/hazardous waste streams.' .

ind:HaulManifest rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Collection ;
    rdfs:label 'Haul Manifest' ;
    rdfs:comment 'Shipping and tracking manifest accompanying each outbound haul from the transfer station. Captures manifest number, BOL reference, outbound haul ID, origin transfer station, destination facility, waste description, waste classification codes (EPA/RCRA), total net weight (tons), number of containers/trailers, seal numbers, driver signature, carrier DOT number, departure timestamp, and chain-of-custody signatures. Required for DOT compliance on all outbound loads and RCRA manifest requirements for special/hazardous waste streams.' .

ind:FacilityCapacity rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Collection ;
    rdfs:label 'Facility Capacity' ;
    rdfs:comment 'Daily and period-level capacity and throughput tracking record for each transfer station. Captures capacity record ID, transfer station, record date/period, permitted daily capacity (TPD), actual inbound tonnage by waste stream, actual outbound tonnage by destination type, floor storage tonnage at end of day, capacity utilization percentage, number of inbound loads, number of outbound hauls, peak hour/day throughput, diversion rate (percentage diverted from landfill), average daily tonnage, capacity status (normal, near-capacity, over-capacity), regulatory capacity exceedance flags, and reporting submission reference. Enables proactive capacity management, regulatory compliance reporting, state solid waste reporting, and internal KPI tracking.' .

ind:DestinationFacility rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Collection ;
    rdfs:label 'Destination Facility' ;
    rdfs:comment 'Reference master for all downstream destination facilities that receive outbound hauls from transfer stations. Captures facility ID, facility name, facility type (landfill, MRF, WTE, TSDF, composting), physical address, GPS coordinates, operating company, accepted waste streams, permitted capacity, tipping fee at destination, haul distance (miles), travel time estimate, permit number, regulatory jurisdiction, facility contact, and operational status. Enables routing optimization and disposal cost management for outbound haul planning.' .

ind:Invoice rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Invoice' ;
    rdfs:comment 'Core billing document representing a charge issued to a residential or commercial customer for waste collection, recycling, container rental, tipping fees, or other environmental services. Captures invoice number, billing period, due date, total amount, tax, invoice status (draft, issued, paid, void, disputed), billing model type (subscription, transactional, tipping fee), service address, invoice source system (Oracle Revenue Management / SAP SD), and revenue recognition period. SSOT for all customer-facing billing documents.' .

ind:InvoiceLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Invoice Line' ;
    rdfs:comment 'Individual line-item detail on a customer invoice representing a specific charge component — e.g., MSW pickup charge, container rental fee, fuel surcharge, environmental levy, tonnage-based tipping fee, or recycling processing fee. Captures service type, unit of measure (pickup, ton, day, month), quantity, unit rate, extended amount, tax code, GL account code, and revenue category. Supports itemized billing for both residential and commercial accounts.' .

ind:Payment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Payment' ;
    rdfs:comment 'Record of a payment or prepayment received from a customer against one or more invoices or as an advance deposit. Captures payment date, payment method (check, ACH, credit card, EFT, lockbox, wire), payment amount, applied amount, unapplied amount, payment reference number, bank deposit batch, payment status (received, cleared, returned, reversed, held), payment type (standard, prepayment, deposit, retainer), prepayment expiry date, refund status, and source system (Oracle AR, SAP FI). SSOT for all customer payment transactions including advance deposits for roll-off rentals and new commercial account mobilizations.' .

ind:PaymentApplication rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Payment Application' ;
    rdfs:comment 'Association record linking a payment to one or more invoices, capturing how payment funds are allocated across open AR balances. Tracks applied amount per invoice, application date, application type (standard, prepayment, credit memo offset, dispute settlement), and application status. Supports partial payments, overpayments, and multi-invoice payment scenarios common in commercial waste hauling accounts.' .

ind:ArAccount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Ar Account' ;
    rdfs:comment 'Accounts receivable sub-ledger account representing the outstanding balance owed by a customer for environmental services. Tracks current balance, aging buckets (0-30, 31-60, 61-90, 90+ days), credit limit, credit hold status, last payment date, last invoice date, dunning level, collection status, and SAP FI AR account number. Distinct from the customer master (owned by customer domain) — this is the financial AR view of the customer relationship.' .

ind:BillingRateSchedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Billing Rate Schedule' ;
    rdfs:comment 'Master rate schedule defining the complete pricing structure for waste management services, including individual rate components and tipping fee configurations. Header captures rate schedule name, effective date range, service type (residential MSW, commercial dumpster, roll-off, tipping fee, recycling processing), billing model (flat rate, per-pickup, per-ton, per-yard, container rental), applicable customer segment, geographic zone, facility (for tipping fees), waste stream type, and approval status. Component detail captures charge elements (base fee, fuel surcharge, environmental fee, overage, disposal surcharge) with calculation method (fixed, percentage, per-unit), unit of measure, rate value, min/max charges, taxability, and GL mapping. Supports both external customer billing and internal transfer pricing. Managed in Oracle Revenue Management and SAP SD condition records.' .

ind:RateComponent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Rate Component' ;
    rdfs:comment 'Individual pricing component within a rate schedule, defining a specific charge element such as base service fee, fuel surcharge, environmental fee, container rental, overage charge, or disposal surcharge. Captures component code, component type, calculation method (fixed, percentage, per-unit), unit of measure, rate value, minimum charge, maximum charge, taxability flag, and GL revenue account mapping. Enables granular rate construction for complex commercial billing.' .

ind:BillingTippingFeeSchedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Billing Tipping Fee Schedule' ;
    rdfs:comment 'Reference schedule of tipping fees charged per ton (or per load) for waste disposal at landfill, transfer station, or WTE facility. Captures facility ID, waste stream type (MSW, C&D, special waste, hazardous), fee per ton (TPD-based pricing), minimum load fee, effective date range, customer tier (municipal, commercial, self-haul), and regulatory surcharge components. Supports both external customer billing and internal transfer pricing between operational units.' .

ind:Cycle rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Cycle' ;
    rdfs:comment 'Configuration entity defining the recurring billing schedule for customer accounts. Captures cycle code, frequency (monthly, bi-monthly, quarterly, per-haul for roll-off), billing run date, invoice generation date, payment terms (net 30, net 15, net 45), grace period days, late fee trigger rules, and applicable customer segments. Each billing account is assigned to one billing cycle that governs when invoices are generated and when payments are due. Drives the automated billing run schedule in Oracle Revenue Management and determines AR aging calculations.' .

ind:Run rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Run' ;
    rdfs:comment 'Operational record of a batch billing execution that generates invoices for a defined set of customer accounts within a billing cycle. Captures run date, billing cycle reference, run type (scheduled, manual, correction), total accounts processed, total invoices generated, total billed amount, run status (pending, in-progress, completed, failed), and operator ID. Provides audit trail for SOX compliance and billing operations management.' .

ind:Adjustment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Adjustment' ;
    rdfs:comment 'Credit or debit adjustment applied to a customer account or invoice to correct billing errors, honor service credits, apply promotional discounts, settle disputes, or write off uncollectible balances. Captures adjustment type (credit memo, debit memo, service credit, write-off, bad debt, rate correction, small balance write-off), adjustment reason code, original invoice reference, adjustment amount, approval status, approver ID, GL impact (revenue reversal or bad debt expense), recovery status for write-off types, and approval workflow audit trail. Supports GAAP revenue recognition adjustments, SOX-controlled approval workflows, and bad debt management per ASC 326 (CECL).' .

ind:Dispute rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Dispute' ;
    rdfs:comment 'Formal billing dispute raised by a customer contesting charges on an invoice. Captures dispute date, disputed invoice reference, disputed amount, dispute reason (incorrect rate, missed pickup, container size error, duplicate charge, tipping fee discrepancy), dispute status (open, under review, resolved, escalated), resolution type (credit issued, charge upheld, partial credit), resolution date, and assigned billing analyst. Integrates with Salesforce CRM case management.' .

ind:PaymentPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Payment Plan' ;
    rdfs:comment 'Structured installment arrangement established for customers unable to pay their full outstanding AR balance, including individual scheduled installment records. Header captures plan start/end dates, total balance enrolled, number of installments, installment amount, frequency, down payment, plan status (active, completed, defaulted, cancelled), and collection agent ID. Each installment detail captures sequence number, scheduled due date, scheduled amount, actual payment date, actual amount paid, installment status (scheduled, paid, missed, waived), and days past due. Supports residential hardship programs, commercial account workout agreements, and enables collections teams to track compliance and trigger dunning on missed installments.' .

ind:Surcharge rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Surcharge' ;
    rdfs:comment 'Master definition of surcharges and fees that can be applied to customer invoices beyond base service rates. Captures surcharge code, surcharge name (fuel surcharge, environmental fee, regulatory recovery fee, administrative fee, late payment fee), calculation basis (percentage of base, flat fee, per-ton), current rate, effective date range, applicability rules (customer type, service type, geography), and regulatory mandate flag. Managed centrally to ensure consistent application across all billing runs.' .

ind:RatedUsage rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Rated Usage' ;
    rdfs:comment 'Priced and rated version of a usage event, representing the output of the rating engine that applies the appropriate rate schedule to a raw usage event to produce a billable charge amount. Captures rated date, applied rate schedule, applied rate component, rated quantity, unit rate, calculated charge amount, applicable surcharges, tax amount, and rating status (rated, pending, error, override). Bridges raw operational usage data and the invoice generation process.' .

ind:TaxRule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Tax Rule' ;
    rdfs:comment 'Reference configuration defining tax applicability rules for waste management services by jurisdiction. Captures tax authority (state, county, municipality), tax type (sales tax, excise tax, solid waste tax, environmental surcharge tax), applicable service types, tax rate, effective date range, exemption categories, and tax account GL mapping. Supports multi-jurisdiction tax compliance for Waste Management\'s nationwide operations.' .

ind:BillingAccount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Billing ;
    rdfs:label 'Billing Account' ;
    rdfs:comment 'Billing-specific account entity representing the financial relationship between Waste Management and a customer for invoicing and payment purposes. Distinct from the customer master (owned by customer domain) — this entity captures billing address, billing contact, preferred payment method, autopay enrollment, paperless billing flag, billing currency, tax exemption status, tax exemption certificate number, credit rating, and Oracle Revenue Management account number. A single customer may have multiple billing accounts (e.g., separate accounts per service location or business unit).' .

ind:Contract rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Contract' ;
    rdfs:comment 'Master record for all service agreements and contracts between Waste Management and its customers. Covers MSW municipal contracts, commercial service agreements, hauling contracts, disposal agreements, and franchise agreements. Stores contract number, type, status, effective/expiration dates, auto-renewal flags, governing jurisdiction, and Salesforce CRM opportunity reference. Single source of truth for contract identity and lifecycle stage (origination, active, amended, renewed, terminated). Integrates with Salesforce CRM and SAP SD.' .

ind:AgreementType rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Agreement Type' ;
    rdfs:comment 'Reference classification of contract and agreement types used across Waste Management\'s commercial and municipal operations. Includes types such as MSW Municipal Franchise, Commercial Hauling, Roll-Off Disposal, Residential Service, Hazardous Waste Disposal, and Intermodal Transfer. Drives contract workflow routing, SLA assignment, and billing rule selection.' .

ind:ServiceCommitment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Service Commitment' ;
    rdfs:comment 'Defines specific service obligations committed under a contract, representing distinct service lines a customer is entitled to receive. Captures service type (residential curbside, commercial FEL/ASL/REL, roll-off temporary/permanent, recycling, organics, hazmat), service frequency (1x/week, 2x/week, on-call), container specification (size, type, count), collection schedule pattern, and geographic service zone or route assignment. Each agreement may have multiple service commitments. Links customers to contracted service entitlements and drives operational scheduling in AMCS route planning. References the applicable rate schedule for billing calculation.' .

ind:Pricing rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Pricing' ;
    rdfs:comment 'Defines the pricing structure and rate tables associated with a contract, including base service rates, tipping fees (per-ton disposal charges), container rental fees, fuel surcharges, environmental recovery fees, and regulatory cost recovery charges. Stores rate effective dates, rate basis (per-lift, per-ton, per-yard, flat monthly), and currency. Supports complex commercial pricing models including tiered tonnage rates and volume discounts. Sourced from Oracle Revenue Management and SAP SD.' .

ind:RateLine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Rate Line' ;
    rdfs:comment 'Individual line-item pricing components within a rate schedule. Each rate line captures a specific charge element: base collection rate, tipping fee, fuel surcharge, environmental fee, container rental, overage charge, or special handling fee. Stores unit of measure (per-ton, per-lift, per-yard, per-month), unit price, minimum charge, and applicable service type. Enables granular billing calculation and rate transparency for commercial and municipal customers.' .

ind:EscalationClause rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Escalation Clause' ;
    rdfs:comment 'Captures rate escalation provisions embedded in contracts, including CPI (Consumer Price Index) escalation, fuel index escalation, fixed annual percentage increases, and disposal cost pass-through clauses. Stores escalation type, index reference (CPI-U, PPI), escalation cap percentage, floor percentage, review frequency (annual, semi-annual), and next escalation review date. Critical for revenue forecasting and proactive customer rate notifications. Sourced from Salesforce CRM contract terms.' .

ind:SlaTerm rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Sla Term' ;
    rdfs:comment 'Service Level Agreement terms defined within a contract, specifying performance obligations such as on-time collection rate, missed pickup response time, container delivery lead time, complaint resolution SLA, and contamination notification requirements. Stores SLA metric name, target threshold, measurement frequency, penalty provisions for non-compliance, and reporting requirements. Supports SLA monitoring and customer performance reporting. Aligns with Salesforce CRM SLA tracking.' .

ind:Amendment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Amendment' ;
    rdfs:comment 'Records all formal modifications to an existing contract including scope changes, rate adjustments, service additions or removals, term extensions, and SLA revisions. Each amendment captures amendment number, effective date, amendment type, description of changes, approval status, approving authority, and reference to the original agreement. Maintains a complete audit trail of contract evolution from origination through termination. Sourced from Salesforce CRM and SAP SD change orders.' .

ind:Renewal rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Renewal' ;
    rdfs:comment 'Tracks contract renewal events and renewal pipeline management. Captures renewal type (auto-renewal, negotiated renewal, evergreen), renewal notice date, renewal offer date, customer response date, new term start/end dates, rate changes applied at renewal, and renewal outcome (accepted, declined, renegotiated, lapsed). Supports proactive renewal management workflows and revenue retention tracking. Integrates with Salesforce CRM opportunity pipeline.' .

ind:Termination rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Termination' ;
    rdfs:comment 'Records contract termination events including voluntary cancellations, non-renewal expirations, breach-based terminations, and regulatory-driven contract endings. Captures termination reason code, notice date, effective termination date, early termination penalty amount, equipment retrieval requirements, final billing instructions, and customer churn classification. Supports revenue loss analysis and customer win-back programs. Sourced from Salesforce CRM and SAP SD.' .

ind:FranchiseAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Franchise Agreement' ;
    rdfs:comment 'Specialized master record for municipal franchise agreements granting Waste Management exclusive or non-exclusive rights to provide waste collection services within a defined geographic jurisdiction. Captures franchise territory boundaries, exclusivity terms, franchise fee structure (percentage of gross revenue), diversion rate requirements, reporting obligations to the municipality, LEA (Local Enforcement Agency) references, and SWIS compliance requirements. Distinct from commercial service agreements due to regulatory and public-service obligations.' .

ind:DisposalAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Disposal Agreement' ;
    rdfs:comment 'Master record for disposal and tipping agreements with landfill sites, transfer stations, MRFs, WTE facilities, and TSDFs (Treatment, Storage, and Disposal Facilities). Captures disposal facility reference, accepted waste streams (MSW, C&D, hazmat, recyclables), contracted tonnage volumes (TPD or annual tons), tipping fee rates, minimum tonnage guarantees, and RCRA compliance requirements. Governs where and how collected waste is disposed or processed. Integrates with SAP SD and landfill/transfer domain.' .

ind:HaulingAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Hauling Agreement' ;
    rdfs:comment 'Master record for third-party hauling and subcontractor agreements where Waste Management engages or is engaged as a hauler for waste transport between collection points, transfer stations, landfills, and processing facilities. Captures hauler identity, route or lane definition, waste stream type, contracted rate per ton-mile or per load, BOL (Bill of Lading) requirements, DOT compliance obligations, insurance requirements, and performance standards. Supports subcontracted collection and intermodal transport operations.' .

ind:PerformanceObligation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Performance Obligation' ;
    rdfs:comment 'Defines discrete performance obligations within a contract as required under ASC 606 revenue recognition standards. Each obligation represents a distinct service promise (e.g., weekly residential collection, monthly roll-off swap, annual container maintenance) with its standalone selling price, satisfaction method (over time vs. point in time), and revenue recognition pattern. Supports GAAP/IFRS-compliant revenue recognition and SOX financial reporting. Sourced from SAP SD revenue recognition module.' .

ind:BillingTerm rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Billing Term' ;
    rdfs:comment 'Defines the billing and payment terms embedded in a contract, including billing frequency (monthly, quarterly, per-service-event), invoice delivery method (paper, email, EDI, portal), payment terms (Net 30, Net 45, prepaid), accepted payment methods, late payment penalty rate, security deposit requirements, and credit limit. Links contract commitments to Oracle Revenue Management billing configuration. Ensures billing setup accurately reflects negotiated contract terms.' .

ind:Offering rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Service ;
    rdfs:label 'Offering' ;
    rdfs:comment 'Master catalog of all waste management service offerings available for sale or subscription. Each record represents a distinct, sellable service identified by a unique service code — including residential curbside pickup plans, commercial front-end-load (FEL) dumpster services, roll-off container rentals, recycling programs, hazardous waste collection, WTE feedstock acceptance, and specialty/on-demand services. Attributes include service code, description, service category, service line classification, default container type, default frequency, regulatory classification (RCRA-regulated, non-regulated), lifecycle status, and system cross-references (SAP SD condition type, Oracle Revenue Management rate code). This is the SSOT for what the business offers — referenced by billing, contract, collection, and compliance domains.' .

ind:Line rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Service ;
    rdfs:label 'Line' ;
    rdfs:comment 'Defines the high-level service lines or business lines under which individual offerings are grouped. Examples include Residential Collection, Commercial Collection, Roll-Off, Recycling, Hazardous Waste, WTE, and Specialty Services. Acts as the top-level classification hierarchy for the service catalog, enabling reporting and pricing segmentation by line of business. Owned by the service domain as the SSOT for service line taxonomy.' .

ind:Code rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Service ;
    rdfs:label 'Code' ;
    rdfs:comment 'Standardized service code registry that assigns unique alphanumeric codes to every service offering. Serves as the universal identifier used across billing, collection, contract, and compliance systems to reference a specific service type. Includes the code value, description, effective date range, regulatory classification (e.g., RCRA-regulated, non-regulated), and mapping to SAP SD condition types and Oracle Revenue Management rate codes. This is the SSOT for service code definitions.' .

ind:ContainerType rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Service ;
    rdfs:label 'Container Type' ;
    rdfs:comment 'Master reference for all container types (CID-classified) used in service delivery. Defines dumpsters, roll-off containers, residential carts, recycling bins, compactors, and specialty containers by size (cubic yards), material, lift compatibility (ASL, FEL, REL), weight capacity, and intended waste stream (MSW, C&D, recyclables, hazmat). This is the SSOT for container type definitions referenced by collection, asset, and contract domains. Distinct from individual container asset instances tracked in the asset domain.' .

ind:FrequencyPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Service ;
    rdfs:label 'Frequency Plan' ;
    rdfs:comment 'Defines all service frequency configurations available for waste collection services. Captures pickup frequency (daily, weekly, bi-weekly, monthly, on-call, event-based), number of pickups per period, applicable days of week, holiday adjustment rules, and minimum service commitment periods. Used by collection routing, billing rate calculation, and contract terms. This is the SSOT for service frequency definitions referenced across billing and collection domains.' .

ind:ServiceRateSchedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Service ;
    rdfs:label 'Service Rate Schedule' ;
    rdfs:comment 'Master rate schedule defining the complete pricing structure for each service offering by customer segment, geography, and effective period. Captures base rates, fuel surcharges (indexed to DOE diesel price), environmental recovery fees, regulatory compliance fees, contamination surcharges, overweight fees, tipping fee pass-throughs, and applicable taxes. Each surcharge/fee component includes calculation method (flat fee, percentage, index-linked) and effective date range. Supports time-bound rate versioning for annual adjustments. This is the SSOT for service pricing referenced by billing, contract, and sales domains.' .

ind:Bundle rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Service ;
    rdfs:label 'Bundle' ;
    rdfs:comment 'Defines packaged combinations of individual service offerings sold together as a bundle (e.g., residential collection + recycling cart + yard waste pickup). Captures bundle name, component offerings with quantity and pricing contribution (included, add-on, discounted), bundle pricing logic (flat rate vs. component sum discount), eligibility rules, and promotional period. Each bundle has its own lifecycle independent of component offerings. Referenced by contract and billing domains for bundle-level pricing and fulfillment.' .

ind:WasteStream rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Service ;
    rdfs:label 'Waste Stream' ;
    rdfs:comment 'Reference catalog of waste stream classifications managed by the business. Defines MSW, C&D, recyclables (paper, plastic, metal, glass), organic/food waste, yard waste, hazardous waste (RCRA Subtitle C), universal waste, e-waste, and SRF/WTE feedstock streams. Each record includes the waste stream code, regulatory classification (EPA/RCRA/state), accepted container types, disposal pathway (landfill, MRF, WTE, TSDF), and diversion eligibility. This is the SSOT for waste stream taxonomy referenced across collection, recycling, landfill, and hazmat domains.' .

ind:Area rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Service ;
    rdfs:label 'Area' ;
    rdfs:comment 'Defines the geographic territories in which the business is authorized to provide waste management services. Each service area represents a distinct operational territory identified by geographic boundaries (ZIP codes, census tracts, municipality codes, county FIPS), applicable franchise agreement, regulatory jurisdiction, and operational district assignment. Supports service eligibility validation at the customer address level — determining which offerings are available at a given location. Referenced by collection (route planning), contract (franchise compliance), and billing (geographic rate differentiation) domains.' .

ind:SlaDefinition rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Service ;
    rdfs:label 'Sla Definition' ;
    rdfs:comment 'Defines Service Level Agreement (SLA) standards associated with each service offering. Captures SLA name, service offering reference, response time commitments (e.g., missed pickup resolution within 24 hours), on-time service rate targets, container delivery lead times, complaint resolution windows, and penalty/credit terms for SLA breaches. This is the SSOT for SLA definitions referenced by contract, billing, and customer service domains. Sourced from Salesforce CRM contract SLA configurations.' .

ind:Permit rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Permit' ;
    rdfs:comment 'Master record for all environmental and operational permits held by Waste Management facilities and operations. Covers air quality permits (Title V, NSR), water discharge permits (NPDES), solid waste facility permits, RCRA hazardous waste permits, stormwater permits, and land use permits. Tracks permit number, issuing regulatory agency (EPA, state DEQ, LEA), permit type, facility/site association, effective and expiration dates, permitted limits and conditions, renewal status, and permit tier classification. Authoritative SSOT for all regulatory permit identities. Sourced from Enviance EHS and SAP EHS modules.' .

ind:PermitCondition rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Permit Condition' ;
    rdfs:comment 'Individual enforceable conditions and limitations attached to a specific permit. Each permit may carry dozens of conditions specifying emission limits, discharge thresholds, operational restrictions, monitoring frequencies, reporting deadlines, and compliance schedules. Tracks condition number, regulatory citation, limit value and unit of measure, monitoring method, deviation threshold, and whether the condition is currently active. Enables condition-level compliance tracking and violation detection. Child entity of permit.' .

ind:RegulatoryRequirement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Regulatory Requirement' ;
    rdfs:comment 'Reference catalog of applicable federal, state, and local regulatory requirements governing Waste Management operations. Covers EPA regulations (RCRA, CERCLA, CAA, CWA), OSHA standards (29 CFR 1910, 1926), DOT hazmat transport rules (49 CFR), state solid waste codes, and ISO 14001/45001 framework clauses. Each record captures the regulation citation, regulatory body, applicability scope (facility type, waste stream, operation type), effective date, and compliance obligation type. Used to map permits, inspections, and corrective actions to specific regulatory drivers.' .

ind:ComplianceInspection rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Compliance Inspection' ;
    rdfs:comment 'Records of regulatory inspections and internal compliance audits conducted at Waste Management facilities and operations. Covers EPA/state agency inspections, OSHA workplace safety inspections, DOT vehicle and driver inspections, LEA solid waste inspections, and internal EHS audits. Tracks inspection ID, inspection type, inspecting authority or internal auditor, facility/site inspected, scheduled and actual inspection date, inspection scope, overall result (pass/fail/conditional), number of findings, and follow-up due date. Sourced from Enviance EHS. Central operational record for all compliance verification activities.' .

ind:InspectionFinding rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Inspection Finding' ;
    rdfs:comment 'Individual findings, deficiencies, and observations identified during a regulatory inspection or internal audit. Each finding is linked to a parent inspection record and captures the finding type (violation, observation, recommendation), regulatory citation violated, description of the deficiency, severity classification, responsible facility area, and whether a corrective action has been initiated. Enables granular tracking of inspection outcomes and drives the corrective action workflow. Child entity of inspection.' .

ind:ViolationNotice rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Violation Notice' ;
    rdfs:comment 'Formal notices of violation (NOV) and enforcement actions received from regulatory agencies including EPA, state environmental agencies, OSHA, and DOT. Tracks notice number, issuing agency, violation date, regulatory citation, facility and operation involved, violation description, penalty amount assessed, response deadline, settlement status, and final resolution. Distinct from inspection findings in that it represents an official agency-issued enforcement document with legal standing and potential financial liability. Sourced from Enviance EHS and SAP EHS.' .

ind:RegulatoryCorrectiveAction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Regulatory Corrective Action' ;
    rdfs:comment 'Corrective and preventive actions (CAPA) initiated in response to inspection findings, violation notices, incidents, or internal audit observations. Tracks action ID, triggering event reference, action type (corrective/preventive), description of required action, responsible party, target completion date, actual completion date, verification method, and closure status. Supports the full CAPA lifecycle from identification through verification and closure. Integrates with Enviance EHS CAPA module and SAP EHS. Supports ISO 14001 and ISO 45001 continual improvement requirements.' .

ind:EhsIncident rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Ehs Incident' ;
    rdfs:comment 'Environmental, health, and safety incident records capturing workplace injuries, near-misses, environmental releases, spills, fires, and property damage events. Tracks incident ID, incident type (OSHA recordable, first aid, near-miss, environmental release, property damage), date/time and location, description, injured party or affected media, immediate cause, root cause classification, OSHA recordability determination, days away from work, regulatory reporting obligation triggered, and notification status. Sourced from Enviance EHS. Distinct from violation_notice (agency-issued) — this is the internal incident record. Supports OSHA 300 log, EPA emergency notification, and DOT accident reporting.' .

ind:EnvironmentalMonitoring rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Environmental Monitoring' ;
    rdfs:comment 'Environmental monitoring measurement records capturing air emissions, water quality, groundwater, leachate, landfill gas (LFG), and soil monitoring data collected at Waste Management facilities. Tracks monitoring event ID, monitoring program type (ambient air, stack emissions, NPDES effluent, groundwater well, LFG LEL/methane), monitoring location/station, sample date and time, parameter measured (CO2e, methane, BOD, pH, VOCs), measured value, unit of measure, detection limit, regulatory limit for comparison, exceedance flag, sampling method, and laboratory reference. Supports permit condition compliance verification and regulatory reporting (SWIS, state air reports). Sourced from Enviance EHS.' .

ind:MonitoringStation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Monitoring Station' ;
    rdfs:comment 'Master record for fixed environmental monitoring stations and sampling locations at Waste Management facilities. Covers groundwater monitoring wells, LFG extraction and monitoring probes, air quality monitoring stations, stormwater outfalls, leachate collection points, and NPDES discharge points. Tracks station ID, station type, facility association, geographic coordinates (lat/long), installation date, regulatory designation (e.g., NPDES outfall number, well ID per permit), active status, and associated permit. Provides the spatial and regulatory context for all environmental_monitoring measurement records.' .

ind:RegulatorySubmission rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Regulatory Submission' ;
    rdfs:comment 'Records of formal regulatory reports and submissions filed with government agencies by Waste Management. Covers annual RCRA biennial reports, SWIS solid waste reports, NPDES discharge monitoring reports (DMR), Title V annual compliance certifications, CERCLA/EPCRA Tier II chemical inventory reports, OSHA 300A annual summaries, GHG emissions reports (EPA Subpart HH/TT), and state-specific environmental reports. Tracks submission ID, report type, regulatory program, filing agency, reporting period, submission date, submission method (electronic/paper), confirmation number, and submission status. Sourced from Enviance EHS and SAP EHS. Provides the audit trail for all external regulatory filings.' .

ind:TrainingCertification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Training Certification' ;
    rdfs:comment 'Records of compliance-required training completions and professional certifications held by Waste Management employees. Covers CDL (Commercial Driver License) endorsements, HAZWOPER 40-hour and 8-hour refresher certifications, DOT hazmat transport training, OSHA 10/30-hour safety training, confined space entry certification, forklift operator certification, EPA RMP training, and ISO 14001/45001 internal auditor certification. Tracks certification ID, employee reference, certification type, issuing body, completion date, expiration date, training hours, pass/fail status, and renewal requirement. Distinct from workforce domain employee records — this is the compliance-specific training obligation and certification record. Sourced from Enviance EHS and Workday HCM.' .

ind:TrainingRequirement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Training Requirement' ;
    rdfs:comment 'Reference catalog defining mandatory compliance training obligations applicable to specific job roles, facility types, and regulatory programs at Waste Management. Maps training type to the regulatory citation requiring it (e.g., HAZWOPER required by 29 CFR 1910.120 for hazmat workers), required frequency (initial, annual, triennial), minimum training hours, applicable employee roles (CDL driver, hazmat handler, MRF sorter, landfill operator), and whether a third-party certification is required. Used to identify training gaps by comparing requirements against training_certification records. Supports ISO 45001 competence management.' .

ind:RegulatedFacility rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Regulated Facility' ;
    rdfs:comment 'Compliance-specific master record for each regulated facility or operational site within Waste Management\'s portfolio, capturing the regulatory identity and classification attributes needed for EHS compliance management. Tracks facility ID, facility name, physical address, EPA facility ID (FRS ID), state facility ID, facility type (landfill, MRF, transfer station, WTE plant, TSDF, hauling depot), RCRA generator status (LQG/SQG/VSQG), Title V major/minor source designation, applicable regulatory programs, primary regulatory contact, and compliance status. Distinct from the asset domain\'s facility master — this record owns the regulatory classification and agency-facing identity of each site. Sourced from Enviance EHS and SAP EHS.' .

ind:Party rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Party' ;
    rdfs:comment 'Identifies all parties and their roles associated with a contract including the customer legal entity, WM contracting entity, guarantors, municipal authorities, subcontractors, and insurance providers. Captures party role (customer, provider, guarantor, regulator), party reference (link to customer or vendor master), contact information for contract administration, and authority level. Supports multi-party contracts common in municipal franchise agreements and subcontracted hauling arrangements.' .

ind:VehicleClass rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fleet ;
    rdfs:label 'Vehicle Class' ;
    rdfs:comment 'Reference classification of fleet vehicle types and body configurations (ASL, FEL, REL, roll-off, CNG, RNG, electric) with capacity specs, weight ratings, and operational parameters' .

ind:MaintenanceSchedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fleet ;
    rdfs:label 'Maintenance Schedule' ;
    rdfs:comment 'Fleet-specific preventive maintenance schedule linking vehicles to PM intervals based on mileage, engine hours, and calendar triggers per FMCSA requirements' .

ind:Territory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Service ;
    rdfs:label 'Territory' ;
    rdfs:comment 'Defines geographic territories and zones for service delivery planning, franchise boundaries, and municipal contract coverage areas with GIS polygon references' .

ind:InspectionChecklist rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Asset ;
    rdfs:label 'Inspection Checklist' ;
    rdfs:comment 'Master reference table for inspection_checklist. Referenced by checklist_id.' .

ind:MonitoringProgram rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Monitoring Program' ;
    rdfs:comment 'Master reference table for monitoring_program. Referenced by monitoring_program_id.' .

ind:Municipality rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Contract ;
    rdfs:label 'Municipality' ;
    rdfs:comment 'Master reference table for municipality. Referenced by municipality_id.' .

ind:CollectionPoint rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Landfill ;
    rdfs:label 'Collection Point' ;
    rdfs:comment 'Master reference table for collection_point. Referenced by collection_point_id.' .

ind:MonitoringPoint rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Landfill ;
    rdfs:label 'Monitoring Point' ;
    rdfs:comment 'Master reference table for monitoring_point. Referenced by monitoring_point_id.' .

ind:BundleComposition rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Service ;
    rdfs:label 'Bundle Composition' ;
    rdfs:comment 'This association product represents the Composition relationship between a service bundle and its constituent service offerings. It captures which offerings are included in each bundle, in what quantity, at what pricing contribution, and in what sequence — data that exists only in the context of a specific bundle-offering membership. Each record defines one offering\'s role within one bundle, supporting catalog governance, bundle pricing calculation, fulfillment orchestration, and versioned bundle lifecycle management.. Existence Justification: In waste management product catalog operations, a service bundle is explicitly defined as a packaged combination of multiple individual service offerings (e.g., residential collection + recycling cart + yard waste pickup). A single bundle contains many offerings, and a single offering (e.g., curbside recycling) can appear in multiple bundles (e.g., Residential Basic Pack, Residential Complete Care Pack, Commercial Eco Bundle). This is a textbook product composition M:N — the business actively creates, manages, and prices these bundle-offering memberships as part of catalog governance.' .

ind:ProgramFacilityAssignment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Recycling ;
    rdfs:label 'Program Facility Assignment' ;
    rdfs:comment 'This association product represents the operational Contract/Assignment between a recycling_program and an mrf_facility. It captures the specific terms and operational parameters governing how a given recycling program\'s inbound recyclable loads are processed at a specific MRF facility. Each record links one recycling_program to one mrf_facility and carries attributes — processing priority, tonnage allocation, diversion target, and tipping fee rate — that exist only in the context of this specific program-facility pairing and cannot be correctly stored on either the program or the facility alone.. Existence Justification: In Waste Management\'s recycling operations, a single recycling program (e.g., a regional municipal curbside program) can be processed across multiple MRF facilities — particularly for large regional programs that span service areas served by different MRFs. Conversely, each MRF facility processes inbound recyclables from multiple distinct recycling programs simultaneously (municipal, commercial, drop-off, special events). The business actively manages these program-facility assignments with operational attributes such as processing priority, tonnage allocation, and diversion targets that are specific to each program-facility pairing, not to either entity alone.' .

ind:FacilityRegulatoryApplicability rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Compliance ;
    rdfs:label 'Facility Regulatory Applicability' ;
    rdfs:comment 'This association product represents the formal Applicability Determination between a regulated_facility and a regulatory_requirement. It captures the documented compliance determination that a specific regulatory requirement applies (or is exempt) to a specific facility, including the determination date, current compliance status, exemption basis, review schedule, and responsible compliance officer. Each record links one regulated_facility to one regulatory_requirement and carries attributes that exist only in the context of this facility-requirement pairing. Managed in Enviance EHS as a core compliance business object used for regulatory defense, audit response, and compliance program management.. Existence Justification: In environmental compliance management, determining which regulatory requirements apply to which facilities is a formal, documented business process called \'applicability determination.\' A single regulated facility (e.g., a RCRA TSDF landfill) is subject to dozens of simultaneous regulatory requirements (RCRA, CAA Title V, CWA NPDES, OSHA 1910, DOT 49 CFR, state solid waste codes), and a single regulatory requirement (e.g., 40 CFR 258 Subpart D) applies to hundreds of facilities across Waste Management\'s portfolio. This relationship is actively managed in Enviance EHS as a distinct business object — compliance officers create, update, and close applicability determinations with their own lifecycle data including determination dates, compliance status, exemption flags, and responsible officers.' .

ind:WasteProfileCodeListing rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Hazmat ;
    rdfs:label 'Waste Profile Code Listing' ;
    rdfs:comment 'This association product represents the Waste Code Listing between waste_profile and waste_code. It captures the regulatory assignment of each applicable EPA or state hazardous waste code to a specific waste characterization profile, as required by RCRA and documented on the EPA Uniform Hazardous Waste Manifest (Box 13). Each record links one waste_profile to one waste_code with attributes that exist only in the context of this specific profile-code pairing, including the measured concentration that triggered the code, the basis for listing, and whether this is the primary code for the profile.. Existence Justification: Under RCRA regulations, a single hazardous waste stream (waste_profile) must be characterized by ALL applicable EPA waste codes simultaneously — a drum of solvent waste may carry D001 (ignitability), D018 (benzene toxicity), and F005 (spent solvent) concurrently. Conversely, a single waste code (e.g., D001) applies to thousands of different waste profiles across different generators. This is a genuine operational M:N: the EPA manifest form (Box 13) explicitly lists multiple waste codes per waste stream, and the business actively manages which codes apply to each profile during the approval process.' .

ind:StorageAuthorization rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Hazmat ;
    rdfs:label 'Storage Authorization' ;
    rdfs:comment 'This association product represents the Contract between waste_profile and storage_unit. It captures the formal RCRA-required authorization that permits a specific hazardous waste profile to be stored in a specific storage unit. Each record documents that a named waste stream has been evaluated for compatibility with a named unit, approved by the responsible compliance officer, and assigned a quantity limit and expiration date. Records are created during the waste profile approval workflow, updated when permit conditions change, and revoked when incompatibilities are identified or permits lapse.. Existence Justification: In RCRA-regulated hazardous waste operations, a waste profile must be explicitly approved for storage in specific units before waste can be placed there — a single waste profile may be authorized for multiple compatible storage units (e.g., a corrosive liquid approved for both a satellite accumulation area and a permitted storage tank), and a single storage unit may hold multiple approved waste profiles simultaneously. This compatibility authorization is an active, managed operational record: facility managers create it during the profile approval process, update it when permits change, and revoke it when incompatibilities are discovered. The relationship carries its own data (approval date, quantity limits, compatibility verification, expiration) that belongs to neither the profile nor the unit alone.' .

# --- Attribute Properties ---
ind:customerAccountId rdf:type rdf:Property ;
    rdfs:label 'Customer Account Id' ;
    rdfs:comment 'Unique surrogate identifier for the customer account record in the Waste Management data platform. Primary key for the customer domain master entity.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerAccount .

ind:areaId rdf:type rdf:Property ;
    rdfs:label 'Area Id' ;
    rdfs:comment 'Foreign key linking to service.area. Business justification: Customer accounts are assigned to a service area for territory-based pricing, franchise compliance, and regulatory jurisdiction. WM billing and CRM systems require this link to apply correct rate sche' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Area .

ind:regulatedFacilityId rdf:type rdf:Property ;
    rdfs:label 'Regulated Facility Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulated_facility. Business justification: Large industrial/commercial customers are often themselves regulated facility operators (transfer stations, treatment facilities). WM account managers need to link the customer account to its EPA/stat' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatedFacility .

ind:segmentId rdf:type rdf:Property ;
    rdfs:label 'Segment Id' ;
    rdfs:comment 'Foreign key linking to customer.customer_segment. Business justification: Normalize denormalized account_segment STRING field to FK reference to customer_segment table. This is the primary segment classification for customer accounts and should reference the authoritative s' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:wasteGeneratorClassWasteStreamId rdf:type rdf:Property ;
    rdfs:label 'Waste Generator Class Waste Stream Id' ;
    rdfs:comment 'Foreign key linking to service.service_waste_stream. Business justification: Customer accounts are classified by EPA waste generator class (LQG/SQG/CESQG) which directly determines eligible waste streams for regulatory compliance, service offerings, manifest requirements, and ' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WasteStream .

ind:accountName rdf:type rdf:Property ;
    rdfs:label 'Account Name' ;
    rdfs:comment 'Legal or trade name of the customer account. For residential accounts this is the householder full name; for commercial and municipal accounts this is the registered business or entity name. Used for billing, contracts, and correspondence.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountNumber rdf:type rdf:Property ;
    rdfs:label 'Account Number' ;
    rdfs:comment 'Externally-known, human-readable account number assigned to the customer by Waste Management. Used on invoices, service agreements, and customer communications. Sourced from Oracle Revenue Management and Salesforce CRM.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountStatus rdf:type rdf:Property ;
    rdfs:label 'Account Status' ;
    rdfs:comment 'Current lifecycle state of the customer account. Prospect = pre-service onboarding; Active = services being rendered; Suspended = temporarily halted (e.g., non-payment, seasonal hold); Inactive = no current services but record retained; Closed = account permanently terminated and archived.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountTier rdf:type rdf:Property ;
    rdfs:label 'Account Tier' ;
    rdfs:comment 'Customer value tier assigned by Waste Management based on revenue contribution, contract size, and strategic importance. Drives service priority, dedicated account management assignment, and pricing concessions. Strategic tier typically reserved for large municipal contracts and national commercial accounts.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountType rdf:type rdf:Property ;
    rdfs:label 'Account Type' ;
    rdfs:comment 'High-level classification of the customer account indicating the nature of the customer relationship. Drives service offerings, pricing tiers, regulatory requirements, and reporting segmentation. Residential = B2C households; Commercial = B2B businesses; Industrial = large-volume generators; Municipal/Government = public sector contracts.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autopayEnrolled rdf:type rdf:Property ;
    rdfs:label 'Autopay Enrolled' ;
    rdfs:comment 'Indicates whether the customer account is enrolled in automatic payment processing. When True, invoices are automatically charged to the customer\'s payment instrument on the due date via Oracle Revenue Management.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:billingAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Billing Address Line1' ;
    rdfs:comment 'Primary street address line for invoice and billing correspondence delivery. Populated only when billing address differs from service address. Used by Oracle Revenue Management for invoice generation and AR collections.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingAddressSameAsService rdf:type rdf:Property ;
    rdfs:label 'Billing Address Same As Service' ;
    rdfs:comment 'Indicates whether the customer\'s billing address is identical to the service address. When True, billing correspondence is sent to the service address. When False, a separate billing address is maintained in the billing system.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:billingCity rdf:type rdf:Property ;
    rdfs:label 'Billing City' ;
    rdfs:comment 'City for the customer\'s billing address. Used for invoice delivery and accounts receivable (AR) correspondence when billing address differs from service address.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingPostalCode rdf:type rdf:Property ;
    rdfs:label 'Billing Postal Code' ;
    rdfs:comment 'US ZIP or ZIP+4 postal code for the customer\'s billing address. Used for invoice delivery and tax rate determination in Oracle Revenue Management.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingState rdf:type rdf:Property ;
    rdfs:label 'Billing State' ;
    rdfs:comment 'Two-letter US state code for the customer\'s billing address. Used for tax jurisdiction determination and AR correspondence routing.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedDate rdf:type rdf:Property ;
    rdfs:label 'Closed Date' ;
    rdfs:comment 'Date on which the customer account was permanently closed and all services terminated. Null for active accounts. Used for churn analysis, win-back campaigns, and regulatory record retention compliance.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:createdTimestamp rdf:type rdf:Property ;
    rdfs:label 'Created Timestamp' ;
    rdfs:comment 'Timestamp when the customer account record was first created in the Waste Management data platform. Represents the record audit trail creation event. Stored in ISO 8601 format with timezone offset.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:creditLimit rdf:type rdf:Property ;
    rdfs:label 'Credit Limit' ;
    rdfs:comment 'Maximum outstanding accounts receivable (AR) balance permitted for this customer account before service suspension is triggered. Expressed in USD. Set by the credit management team in Oracle Revenue Management based on payment history and account tier.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditStatus rdf:type rdf:Property ;
    rdfs:label 'Credit Status' ;
    rdfs:comment 'Current credit standing of the customer account as assessed by Waste Management\'s accounts receivable (AR) and collections team. Good = no outstanding issues; Watch = elevated risk monitoring; Hold = service may be suspended pending payment; Collections = account referred to collections; Write_off = balance deemed uncollectable. Sourced from Oracle Revenue Management.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerSinceDate rdf:type rdf:Property ;
    rdfs:label 'Customer Since Date' ;
    rdfs:comment 'Date on which the customer account was first activated and services commenced. Represents the start of the customer relationship lifecycle. Used for tenure analysis, loyalty programs, and contract renewal planning.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:industryCode rdf:type rdf:Property ;
    rdfs:label 'Industry Code' ;
    rdfs:comment 'North American Industry Classification System (NAICS) or Standard Industrial Classification (SIC) code identifying the primary industry of the commercial or industrial customer. Used for waste stream profiling, regulatory compliance determination (e.g., RCRA hazardous waste generator status), and market analytics.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Modified Timestamp' ;
    rdfs:comment 'Timestamp of the most recent update to the customer account record in the data platform. Used for change data capture (CDC), data synchronization with source systems, and audit trail compliance.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:marketingOptIn rdf:type rdf:Property ;
    rdfs:label 'Marketing Opt In' ;
    rdfs:comment 'Indicates whether the customer has consented to receive marketing and promotional communications from Waste Management, including service upgrade offers, sustainability program invitations, and recycling education materials. Managed per CAN-SPAM and CCPA consent requirements.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:npsScore rdf:type rdf:Property ;
    rdfs:label 'Nps Score' ;
    rdfs:comment 'Most recent Net Promoter Score (NPS) survey response from the customer, ranging from 0 (extremely unlikely to recommend) to 10 (extremely likely to recommend). Promoters = 9-10; Passives = 7-8; Detractors = 0-6. Used for customer satisfaction analytics and service quality improvement initiatives.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:npsSurveyDate rdf:type rdf:Property ;
    rdfs:label 'Nps Survey Date' ;
    rdfs:comment 'Date on which the most recent NPS survey response was recorded for this customer account. Used to determine survey recency and schedule follow-up surveys per the customer satisfaction program cadence.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paperlessBilling rdf:type rdf:Property ;
    rdfs:label 'Paperless Billing' ;
    rdfs:comment 'Indicates whether the customer has opted into electronic (paperless) billing. When True, invoices are delivered via email or the Waste Logics customer portal rather than physical mail. Supports Waste Management\'s sustainability initiatives.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentTerms rdf:type rdf:Property ;
    rdfs:label 'Payment Terms' ;
    rdfs:comment 'Contractual payment terms governing when invoices are due for this customer account. Net_15/30/45/60 = days from invoice date; Prepaid = payment required before service; COD = cash on delivery. Sourced from Oracle Revenue Management and SAP S/4HANA SD module.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portalAccessEnabled rdf:type rdf:Property ;
    rdfs:label 'Portal Access Enabled' ;
    rdfs:comment 'Indicates whether the customer account has active access to the Waste Logics self-service customer portal for online service scheduling, container management, invoice viewing, and service history review.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferredLanguage rdf:type rdf:Property ;
    rdfs:label 'Preferred Language' ;
    rdfs:comment 'Customer\'s preferred language for communications, invoices, and service notifications. Stored as IETF BCP 47 language tag (e.g., en-US, es-MX). Used to route multilingual customer service interactions and generate localized documents.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredPaymentMethod rdf:type rdf:Property ;
    rdfs:label 'Preferred Payment Method' ;
    rdfs:comment 'Customer\'s preferred method for remitting payment on invoices. ACH = automated clearing house bank transfer; Autopay = recurring automatic charge; Invoice = paper or electronic invoice with manual payment. Stored in Oracle Revenue Management. Actual payment instrument details are NOT stored here per PCI DSS compliance.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactName rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Name' ;
    rdfs:comment 'Full name of the primary point of contact for the customer account. For residential accounts this is the account holder; for commercial accounts this is the designated account manager or facility contact. Used for service communications, billing inquiries, and contract management.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Email' ;
    rdfs:comment 'Primary email address for the customer account used for billing notifications, service alerts, and marketing communications. Sourced from Salesforce CRM and Waste Logics customer portal. Subject to opt-in/opt-out preferences.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Phone' ;
    rdfs:comment 'Primary telephone number for the customer account used for service scheduling, driver communication, and customer service interactions. Stored in E.164 international format. Sourced from Salesforce CRM and Waste Logics.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesforceAccountReference rdf:type rdf:Property ;
    rdfs:label 'Salesforce Account Reference' ;
    rdfs:comment 'Integration key linking this customer account to the corresponding Account record in Salesforce CRM. Used for bi-directional synchronization of customer profile, service requests, and contract data between the data platform and Salesforce.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapCustomerNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Customer Number' ;
    rdfs:comment 'Customer master number assigned in SAP S/4HANA (SD and FI/CO modules). Used for order-to-cash processing, accounts receivable management, and financial reporting. Links this customer account to SAP billing documents and general ledger (GL) postings.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suspensionDate rdf:type rdf:Property ;
    rdfs:label 'Suspension Date' ;
    rdfs:comment 'Date on which the customer account was most recently placed in suspended status, typically due to non-payment or service dispute. Null for accounts not currently or previously suspended. Used for AR collections workflow and service reinstatement tracking.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:suspensionReason rdf:type rdf:Property ;
    rdfs:label 'Suspension Reason' ;
    rdfs:comment 'Reason code for the most recent account suspension. Non_payment = outstanding AR balance; Customer_request = voluntary hold; Regulatory_hold = compliance investigation; Dispute = service or billing dispute; Seasonal = temporary seasonal service pause.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExempt rdf:type rdf:Property ;
    rdfs:label 'Tax Exempt' ;
    rdfs:comment 'Indicates whether the customer account holds a valid tax exemption certificate, exempting them from applicable sales or service taxes on waste management invoices. Typically applies to government, non-profit, and certain municipal accounts. Validated against exemption certificate records in SAP S/4HANA FI.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxExemptionNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Exemption Number' ;
    rdfs:comment 'Official tax exemption certificate number issued by the relevant tax authority for accounts with tax_exempt = True. Used to substantiate tax-exempt billing treatment during audits. Null for non-exempt accounts.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteGeneratorClass rdf:type rdf:Property ;
    rdfs:label 'Waste Generator Class' ;
    rdfs:comment 'EPA Resource Conservation and Recovery Act (RCRA) hazardous waste generator classification for the customer account. LQG = Large Quantity Generator (>1,000 kg/month); SQG = Small Quantity Generator (100-1,000 kg/month); VSQG = Very Small Quantity Generator (<100 kg/month); Non_generator = no regulated hazardous waste. Determines regulatory compliance obligations and service requirements.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteLogicsCustomerReference rdf:type rdf:Property ;
    rdfs:label 'Waste Logics Customer Reference' ;
    rdfs:comment 'Integration key linking this customer account to the corresponding customer record in the Waste Logics customer portal. Enables self-service scheduling, container management, and service history access for the customer.' ;
    rdfs:domain ind:CustomerAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactId rdf:type rdf:Property ;
    rdfs:label 'Contact Id' ;
    rdfs:comment 'Unique surrogate identifier for each contact record in the Waste Management customer domain. Primary key for the contact data product.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:contactStatus rdf:type rdf:Property ;
    rdfs:label 'Contact Status' ;
    rdfs:comment 'Current lifecycle status of the contact record. Active contacts receive communications and can authorize service changes. Inactive contacts are retained for historical reference. Do_not_contact enforces opt-out compliance. Deceased and unverified statuses support data quality management.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:department rdf:type rdf:Property ;
    rdfs:label 'Department' ;
    rdfs:comment 'Organizational department or business unit the contact belongs to within their company (e.g., Facilities, Finance, Operations, Environmental Health & Safety). Supports routing of service and billing inquiries to the correct team.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doNotCall rdf:type rdf:Property ;
    rdfs:label 'Do Not Call' ;
    rdfs:comment 'Indicates whether the contact is registered on the National Do Not Call Registry or has explicitly requested no outbound telemarketing calls. True = do not call for marketing purposes. Enforced by the Oracle Revenue Management and Salesforce CRM outbound dialing workflows.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:emailOptIn rdf:type rdf:Property ;
    rdfs:label 'Email Opt In' ;
    rdfs:comment 'Indicates whether the contact has consented to receive marketing and promotional email communications from Waste Management. True = opted in; False = opted out or never consented. Distinct from transactional/service emails which are sent regardless of this flag.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:faxNumber rdf:type rdf:Property ;
    rdfs:label 'Fax Number' ;
    rdfs:comment 'Fax number for the contact. Used for transmission of formal documents such as service agreements, hazardous waste manifests, and regulatory compliance correspondence where fax remains a legally accepted delivery method.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstName rdf:type rdf:Property ;
    rdfs:label 'First Name' ;
    rdfs:comment 'Given (first) name of the individual contact person. Used for personalized communications, billing correspondence, and service notifications.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBillingContact rdf:type rdf:Property ;
    rdfs:label 'Is Billing Contact' ;
    rdfs:comment 'Indicates whether this contact is designated to receive billing-related communications including invoices, payment reminders, Accounts Receivable (AR) notices, and rate change notifications. Supports Oracle Revenue Management billing workflow routing.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isEmergencyContact rdf:type rdf:Property ;
    rdfs:label 'Is Emergency Contact' ;
    rdfs:comment 'Indicates whether this contact should be notified in emergency situations such as hazardous waste spills, service safety incidents, or after-hours urgent service needs. Emergency contacts are prioritized in incident escalation workflows managed through Enviance EHS.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimaryContact rdf:type rdf:Property ;
    rdfs:label 'Is Primary Contact' ;
    rdfs:comment 'Indicates whether this contact is designated as the primary point of contact for the customer account. Each customer account should have exactly one primary contact. Used to determine the default recipient for account-level communications when no specific role routing applies.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isServiceContact rdf:type rdf:Property ;
    rdfs:label 'Is Service Contact' ;
    rdfs:comment 'Indicates whether this contact is designated to receive service-related communications including collection schedule notifications, service disruption alerts, Work Order (WO) confirmations, and container delivery/pickup notices.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobTitle rdf:type rdf:Property ;
    rdfs:label 'Job Title' ;
    rdfs:comment 'Professional title or position of the contact within their organization (e.g., Facilities Manager, Environmental Compliance Officer, Accounts Payable Specialist). Particularly relevant for commercial and municipal accounts.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastName rdf:type rdf:Property ;
    rdfs:label 'Last Name' ;
    rdfs:comment 'Family (last) name of the individual contact person. Combined with first_name to form the full display name for correspondence and account management.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Mailing Address Line1' ;
    rdfs:comment 'First line of the contact\'s mailing address for physical correspondence including paper billing statements, regulatory notices, and formal contract documents. May differ from the service address on the customer account.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Mailing Address Line2' ;
    rdfs:comment 'Second line of the contact\'s mailing address (suite, apartment, floor, unit number, or care-of designation). Supplements mailing_address_line1 for complete address formatting.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingCity rdf:type rdf:Property ;
    rdfs:label 'Mailing City' ;
    rdfs:comment 'City component of the contact\'s mailing address. Used for physical mail delivery and geographic segmentation of contact communications.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingCountry rdf:type rdf:Property ;
    rdfs:label 'Mailing Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 three-letter country code for the contact\'s mailing address (e.g., USA, CAN, MEX). Supports international commercial and industrial accounts and determines applicable privacy regulation framework.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingPostalCode rdf:type rdf:Property ;
    rdfs:label 'Mailing Postal Code' ;
    rdfs:comment 'ZIP or ZIP+4 postal code for the contact\'s mailing address. Used for mail delivery, geographic market analysis, and routing of state-specific regulatory communications.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingState rdf:type rdf:Property ;
    rdfs:label 'Mailing State' ;
    rdfs:comment 'Two-letter US state or territory abbreviation for the contact\'s mailing address (e.g., TX, CA, FL). Follows USPS state code standards. Used for state-level regulatory compliance routing and tax jurisdiction determination.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mobilePhone rdf:type rdf:Property ;
    rdfs:label 'Mobile Phone' ;
    rdfs:comment 'Mobile/cell phone number for the contact. Supports SMS/text message notifications for service day reminders, route change alerts, and two-factor authentication for portal access. Formatted per E.164 standard.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:portalLastLoginTimestamp rdf:type rdf:Property ;
    rdfs:label 'Portal Last Login Timestamp' ;
    rdfs:comment 'Date and time of the contact\'s most recent login to the Waste Logics customer portal. Used to identify inactive portal users, drive re-engagement campaigns, and support portal access audits. Null if the contact has never logged in.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:preferredContactMethod rdf:type rdf:Property ;
    rdfs:label 'Preferred Contact Method' ;
    rdfs:comment 'Contact\'s stated preference for how Waste Management should reach them. Drives communication channel selection for service notifications, billing statements, and marketing communications. Supports Customer Relationship Management (CRM) personalization and compliance with communication preferences.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredContactTime rdf:type rdf:Property ;
    rdfs:label 'Preferred Contact Time' ;
    rdfs:comment 'Contact\'s preferred time window for receiving outbound calls or communications from Waste Management. Supports compliance with TCPA restrictions and improves customer satisfaction by respecting contact preferences.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:roleType rdf:type rdf:Property ;
    rdfs:label 'Role Type' ;
    rdfs:comment 'Functional role this contact plays on the customer account. Determines routing of communications and authorizations: primary (main account holder), billing (receives invoices and AR communications), service (receives service notifications and scheduling), emergency (after-hours escalation), authorized_representative (can act on behalf of account holder).' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesforceContactReference rdf:type rdf:Property ;
    rdfs:label 'Salesforce Contact Reference' ;
    rdfs:comment 'External system identifier for this contact record in Salesforce CRM. Used for cross-system reconciliation and data lineage tracing between the Silver layer and the Salesforce Contact object.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:smsOptIn rdf:type rdf:Property ;
    rdfs:label 'Sms Opt In' ;
    rdfs:comment 'Indicates whether the contact has provided express written consent to receive SMS/text message communications from Waste Management, including service reminders, route change alerts, and promotional messages. Required for TCPA compliance.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceSystem rdf:type rdf:Property ;
    rdfs:label 'Source System' ;
    rdfs:comment 'Originating operational system from which this contact record was sourced. Supports data lineage tracking, conflict resolution during master data management, and audit traceability. Salesforce CRM is the primary source for commercial contacts; Waste Logics for portal-registered residential contacts.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:title rdf:type rdf:Property ;
    rdfs:label 'Title' ;
    rdfs:comment 'Honorific or salutation prefix for the contact (e.g., Mr., Ms., Dr.). Used in formal written communications and billing correspondence.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Updated Timestamp' ;
    rdfs:comment 'Date and time when the contact record was most recently modified in the Waste Management data platform. Tracks the latest change for change data capture (CDC), data freshness monitoring, and audit trail compliance. Formatted as yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:verificationDate rdf:type rdf:Property ;
    rdfs:label 'Verification Date' ;
    rdfs:comment 'Date on which the contact\'s identity and contact information was most recently verified. Used to enforce re-verification schedules and identify stale contact records requiring data quality remediation.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verificationStatus rdf:type rdf:Property ;
    rdfs:label 'Verification Status' ;
    rdfs:comment 'Identity and contact information verification status for this contact record. Verified = contact details confirmed via outbound validation or portal registration. Unverified = data entered but not yet confirmed. Pending = verification in progress. Failed = verification attempt unsuccessful. Supports data quality management and fraud prevention.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteLogicsUserReference rdf:type rdf:Property ;
    rdfs:label 'Waste Logics User Reference' ;
    rdfs:comment 'Identifier for the corresponding user account in the Waste Logics customer portal. Populated when the contact has registered for self-service portal access. Null if no portal account exists.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workPhone rdf:type rdf:Property ;
    rdfs:label 'Work Phone' ;
    rdfs:comment 'Business/office telephone number for the contact, including extension if applicable. Primarily used for commercial and municipal account contacts where direct-dial office numbers differ from mobile numbers.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workPhoneExtension rdf:type rdf:Property ;
    rdfs:label 'Work Phone Extension' ;
    rdfs:comment 'Telephone extension number associated with the work phone for the contact. Required for large commercial and municipal accounts where contacts are reached via a main switchboard.' ;
    rdfs:domain ind:Contact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceAddressId rdf:type rdf:Property ;
    rdfs:label 'Service Address Id' ;
    rdfs:comment 'Unique system-generated identifier for each physical service address where waste collection or environmental services are rendered. Primary key for the service_address entity.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceAddress .

ind:designatedFacilityId rdf:type rdf:Property ;
    rdfs:label 'Designated Facility Id' ;
    rdfs:comment 'Foreign key linking to asset.facility. Business justification: Service addresses are assigned a designated disposal facility (landfill, MRF, transfer station) where collected waste is delivered. Route planning, tipping fee calculation, and logistics optimization ' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:districtId rdf:type rdf:Property ;
    rdfs:label 'District Id' ;
    rdfs:comment 'Foreign key linking to collection.district. Business justification: Every service address belongs to a collection district for routing, scheduling, and operational planning. District assignment drives route optimization, service day scheduling, and municipal reporting' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:District .

ind:franchiseAgreementId rdf:type rdf:Property ;
    rdfs:label 'Franchise Agreement Id' ;
    rdfs:comment 'Foreign key linking to contract.franchise_agreement. Business justification: Franchise agreements govern service delivery at specific addresses within a municipality territory. Compliance reporting (diversion rates, SWIS reporting) and rate regulation require knowing which fra' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FranchiseAgreement .

ind:hazardousWasteGeneratorId rdf:type rdf:Property ;
    rdfs:label 'Hazardous Waste Generator Id' ;
    rdfs:comment 'Foreign key linking to hazmat.hazardous_waste_generator. Business justification: Service addresses are physical generator sites requiring EPA ID registration, site-specific RCRA permits, accumulation area compliance, and emergency response planning. Critical for site-level regulat' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HazardousWasteGenerator .

ind:mrfFacilityId rdf:type rdf:Property ;
    rdfs:label 'Mrf Facility Id' ;
    rdfs:comment 'Foreign key linking to recycling.mrf_facility. Business justification: Each recycling service address is assigned to a designated MRF for material processing. Route planners and operations teams use this assignment for load routing, contamination tracking by service area' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MrfFacility .

ind:permitId rdf:type rdf:Property ;
    rdfs:label 'Permit Id' ;
    rdfs:comment 'Foreign key linking to compliance.permit. Business justification: Site-specific permits (on-site treatment, storage facilities, transfer stations) are issued to physical locations, not accounts. Service authorization, route planning, and regulatory inspections requi' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Permit .

ind:primaryWasteStreamId rdf:type rdf:Property ;
    rdfs:label 'Primary Waste Stream Id' ;
    rdfs:comment 'Foreign key linking to service.service_waste_stream. Business justification: Service addresses must track primary waste stream for route planning, container type assignment, vehicle equipment requirements, and regulatory compliance. Drives operational decisions on collection f' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WasteStream .

ind:programId rdf:type rdf:Property ;
    rdfs:label 'Program Id' ;
    rdfs:comment 'Foreign key linking to recycling.recycling_program. Business justification: Service addresses participate in specific recycling programs based on municipality, franchise agreement, and service area. Required for routing, material acceptance rules, and municipal contract compl' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Program .

ind:vehicleClassId rdf:type rdf:Property ;
    rdfs:label 'Vehicle Class Id' ;
    rdfs:comment 'Foreign key linking to fleet.vehicle_class. Business justification: Service addresses have physical constraints (weight limits, clearance, gated access) that restrict which vehicle classes can service them. Route planners and dispatchers use this to assign compliant v' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VehicleClass .

ind:accessCode rdf:type rdf:Property ;
    rdfs:label 'Access Code' ;
    rdfs:comment 'Gate code, keypad entry code, or access credential required to enter the service location (e.g., gated community code, commercial facility access PIN). Classified as confidential due to security sensitivity. Stored in Waste Logics and AMCS Platform for driver dispatch.' ;
    rdfs:domain ind:ServiceAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line1' ;
    rdfs:comment 'Primary street address line for the physical service location, including street number and street name (e.g., \'1234 Industrial Blvd\'). Used for route planning, driver navigation, and service dispatch.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line2' ;
    rdfs:comment 'Secondary address line for the service location, capturing suite numbers, building identifiers, unit numbers, or additional location descriptors (e.g., \'Suite 200\', \'Building C\', \'Dock 4\').' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressStatus rdf:type rdf:Property ;
    rdfs:label 'Address Status' ;
    rdfs:comment 'Current lifecycle status of the service address. \'active\' indicates services are currently rendered; \'inactive\' indicates no current services; \'pending_validation\' indicates address requires verification; \'suspended\' indicates temporarily halted; \'demolished\' indicates physical location no longer exists.' ;
    rdfs:domain ind:ServiceAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressValidationStatus rdf:type rdf:Property ;
    rdfs:label 'Address Validation Status' ;
    rdfs:comment 'Result of postal address validation against USPS or third-party address verification service. \'validated\' confirms the address is deliverable and standardized; \'failed\' indicates the address could not be verified; \'overridden\' indicates a manual override was applied by an authorized user.' ;
    rdfs:domain ind:ServiceAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressVerifiedDate rdf:type rdf:Property ;
    rdfs:label 'Address Verified Date' ;
    rdfs:comment 'Date on which the service address was last verified against USPS or third-party address validation service. Used to track address data quality and trigger re-validation workflows when addresses become stale.' ;
    rdfs:domain ind:ServiceAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:city rdf:type rdf:Property ;
    rdfs:label 'City' ;
    rdfs:comment 'City or municipality name of the physical service location. Used for jurisdiction assignment, municipal contract billing, and regulatory reporting to Local Solid Waste Authorities.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerCount rdf:type rdf:Property ;
    rdfs:label 'Container Count' ;
    rdfs:comment 'Total number of waste containers (bins, carts, dumpsters, compactors) currently assigned and active at this service address. Used for container inventory management in Waste Logics and AMCS Platform, and for capacity planning.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:countryCode rdf:type rdf:Property ;
    rdfs:label 'Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 three-letter country code for the service location (e.g., \'USA\', \'CAN\'). Supports international operations and regulatory compliance determination.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Data Source System' ;
    rdfs:comment 'Identifies the operational system of record from which this service address record originated (e.g., Salesforce CRM, Waste Logics, AMCS Platform, SAP S/4HANA). Used for data lineage tracking, conflict resolution during integration, and Silver Layer provenance auditing.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diversionProgramEnrolled rdf:type rdf:Property ;
    rdfs:label 'Diversion Program Enrolled' ;
    rdfs:comment 'Indicates whether this service address is enrolled in a waste diversion program (recycling, composting, organics collection). Diversion Rate = percentage of waste diverted from landfill. Used for sustainability reporting, EPA diversion rate calculations, and GHG (Greenhouse Gas) emissions tracking.' ;
    rdfs:domain ind:ServiceAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:elevationFt rdf:type rdf:Property ;
    rdfs:label 'Elevation Ft' ;
    rdfs:comment 'Elevation of the service address above sea level in feet. Used for route planning in hilly or mountainous terrain to optimize vehicle fuel consumption and assess CNG (Compressed Natural Gas) vehicle suitability for the route.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:externalAddressReference rdf:type rdf:Property ;
    rdfs:label 'External Address Reference' ;
    rdfs:comment 'The externally-known unique identifier for this service address as assigned by the source system of record (e.g., Waste Logics site ID, AMCS location code, or SAP SD ship-to party number). Used for cross-system reconciliation and integration.' ;
    rdfs:domain ind:ServiceAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geocodeAccuracy rdf:type rdf:Property ;
    rdfs:label 'Geocode Accuracy' ;
    rdfs:comment 'Precision level of the latitude/longitude geocoding result for this service address. \'rooftop\' indicates exact parcel-level match; \'range_interpolated\' indicates interpolated from street range; \'approximate\' indicates centroid-level. Drives confidence in route optimization and dispatch accuracy.' ;
    rdfs:domain ind:ServiceAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isGated rdf:type rdf:Property ;
    rdfs:label 'Is Gated' ;
    rdfs:comment 'Indicates whether the service address requires gate or controlled access entry. When true, drivers must use the access_code or follow special entry procedures. Used for route planning and driver briefing in AMCS Platform and Locus Dispatch.' ;
    rdfs:domain ind:ServiceAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHazardousWasteSite rdf:type rdf:Property ;
    rdfs:label 'Is Hazardous Waste Site' ;
    rdfs:comment 'Indicates whether this service address is designated for hazardous waste collection or handling services. When true, requires RCRA-compliant manifest tracking, specialized vehicle assignment, and Enviance EHS compliance workflows. Triggers additional regulatory reporting obligations.' ;
    rdfs:domain ind:ServiceAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastServiceDate rdf:type rdf:Property ;
    rdfs:label 'Last Service Date' ;
    rdfs:comment 'Most recent date on which a waste collection or environmental service was successfully completed at this address. Used for SLA compliance monitoring, missed pickup detection, and customer service inquiries.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:latitude rdf:type rdf:Property ;
    rdfs:label 'Latitude' ;
    rdfs:comment 'Geographic latitude coordinate of the service address in decimal degrees (WGS84 datum). Used by AMCS Platform and Locus Dispatch for route optimization, GPS-based driver navigation, and geospatial analytics.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:longitude rdf:type rdf:Property ;
    rdfs:label 'Longitude' ;
    rdfs:comment 'Geographic longitude coordinate of the service address in decimal degrees (WGS84 datum). Used by AMCS Platform and Locus Dispatch for route optimization, GPS-based driver navigation, and geospatial analytics.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Modified Timestamp' ;
    rdfs:comment 'Timestamp when this service address record was most recently updated, in ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX). Used for change data capture (CDC) in the Databricks Silver Layer pipeline and audit trail compliance.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:municipalityCode rdf:type rdf:Property ;
    rdfs:label 'Municipality Code' ;
    rdfs:comment 'Standardized code identifying the municipality or local enforcement agency (LEA) jurisdiction for this service address. Used for franchise agreement billing, regulatory reporting to State Environmental Quality Departments, and SWIS reporting.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:municipalityName rdf:type rdf:Property ;
    rdfs:label 'Municipality Name' ;
    rdfs:comment 'Name of the local municipality or jurisdiction governing waste collection services at this address (e.g., \'City of Houston\', \'Harris County\'). Determines applicable franchise agreements, tipping fee structures, and regulatory reporting obligations to Local Solid Waste Authorities.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:placementInstructions rdf:type rdf:Property ;
    rdfs:label 'Placement Instructions' ;
    rdfs:comment 'Free-text operational instructions for drivers and collection crews regarding where containers should be placed or retrieved at this service address (e.g., \'Place cart at end of driveway\', \'Containers behind gate on north side\', \'Use rear alley access\'). Sourced from Waste Logics and AMCS Platform driver notes.' ;
    rdfs:domain ind:ServiceAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postalCode rdf:type rdf:Property ;
    rdfs:label 'Postal Code' ;
    rdfs:comment 'US ZIP code or ZIP+4 code for the service location. Used for route zone assignment, tax jurisdiction determination, and geographic analytics.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContainerSizeYards rdf:type rdf:Property ;
    rdfs:label 'Primary Container Size Yards' ;
    rdfs:comment 'Size of the primary waste container at this service address measured in cubic yards (e.g., 2.0, 4.0, 6.0, 8.0, 96-gallon cart = 0.42 yards). Used for capacity planning, tipping fee estimation, and route load calculations. Sourced from Waste Logics container assignment.' ;
    rdfs:domain ind:ServiceAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recyclingProgramType rdf:type rdf:Property ;
    rdfs:label 'Recycling Program Type' ;
    rdfs:comment 'Type of recycling collection program active at this service address. \'single_stream\' = all recyclables commingled; \'dual_stream\' = paper separated from containers; \'source_separated\' = individual material streams. Determines MRF (Materials Recovery Facility) processing requirements and diversion rate calculations.' ;
    rdfs:domain ind:ServiceAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceEndDate rdf:type rdf:Property ;
    rdfs:label 'Service End Date' ;
    rdfs:comment 'Date on which waste collection or environmental services were terminated or are scheduled to end at this service address. Null for currently active addresses. Used for churn analysis, final billing, and container retrieval scheduling.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:serviceFrequency rdf:type rdf:Property ;
    rdfs:label 'Service Frequency' ;
    rdfs:comment 'Frequency at which waste collection or environmental services are performed at this address (e.g., weekly residential pickup, daily commercial collection). Drives route scheduling, container sizing recommendations, and SLA compliance monitoring.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceSegment rdf:type rdf:Property ;
    rdfs:label 'Service Segment' ;
    rdfs:comment 'Business segment classification for the service address indicating the customer type served at this location. Aligns with B2C residential, B2B commercial, industrial, and government/municipal contract categories. Used for pricing, routing, and regulatory reporting.' ;
    rdfs:domain ind:ServiceAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceStartDate rdf:type rdf:Property ;
    rdfs:label 'Service Start Date' ;
    rdfs:comment 'Date on which waste collection or environmental services first commenced at this service address. Used for customer tenure analysis, contract billing start, and service history reporting.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:specialHandlingNotes rdf:type rdf:Property ;
    rdfs:label 'Special Handling Notes' ;
    rdfs:comment 'Free-text field capturing any special operational, safety, or regulatory handling requirements for this service address beyond standard placement instructions (e.g., \'Requires PPE due to chemical storage on site\', \'OSHA confined space entry required\', \'Coordinate with site safety officer before entry\').' ;
    rdfs:domain ind:ServiceAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateProvince rdf:type rdf:Property ;
    rdfs:label 'State Province' ;
    rdfs:comment 'Two-letter US state or Canadian province code for the service location (e.g., \'TX\', \'CA\'). Used for state-level environmental compliance reporting to State Environmental Quality Departments and regulatory fee calculations.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxJurisdictionCode rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction Code' ;
    rdfs:comment 'Tax jurisdiction identifier for this service address used by Oracle Revenue Management to apply correct state, county, and municipal tax rates to service charges. Determined by address geocoding and jurisdiction boundary mapping.' ;
    rdfs:domain ind:ServiceAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteStreamTypes rdf:type rdf:Property ;
    rdfs:label 'Waste Stream Types' ;
    rdfs:comment 'Comma-delimited list of waste stream types collected at this service address (e.g., \'MSW,recycling,organics\', \'C&D,hazardous\'). MSW = Municipal Solid Waste; C&D = Construction and Demolition Waste. Drives container assignment, route type, and regulatory classification. [ENUM-REF-CANDIDATE: msw|recycling|organics|c_and_d|hazardous|electronic|bulky|yard_waste — promote to reference product]' ;
    rdfs:domain ind:ServiceAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightRestrictionTons rdf:type rdf:Property ;
    rdfs:label 'Weight Restriction Tons' ;
    rdfs:comment 'Maximum allowable vehicle weight in tons for vehicles accessing this service address, as posted by local road authority or property owner. Constrains which collection vehicle types (ASL, FEL, REL) can service this location. Critical for fleet dispatch and DOT compliance.' ;
    rdfs:domain ind:ServiceAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:zoningClassification rdf:type rdf:Property ;
    rdfs:label 'Zoning Classification' ;
    rdfs:comment 'Land use zoning classification of the service address as defined by local municipal zoning ordinances. Determines applicable service types, container sizes, collection frequency, and regulatory requirements. Drives segmentation between B2C residential, B2B commercial, and government accounts.' ;
    rdfs:domain ind:ServiceAddress ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountHierarchyId rdf:type rdf:Property ;
    rdfs:label 'Account Hierarchy Id' ;
    rdfs:comment 'Unique surrogate identifier for each account hierarchy relationship record in the Waste Management customer account structure. Primary key for this entity.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:billingAccountId rdf:type rdf:Property ;
    rdfs:label 'Billing Account Id' ;
    rdfs:comment 'Identifier of the billing account to which consolidated invoices are directed when consolidated_billing_flag is true. May reference the parent account or a designated payer account within the hierarchy.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BillingAccount .

ind:childAccountCustomerAccountId rdf:type rdf:Property ;
    rdfs:label 'Child Account Customer Account Id' ;
    rdfs:comment 'Identifier of the child (subordinate) account in this hierarchy relationship. Represents the site, subsidiary, or district that rolls up to the parent account for consolidated reporting and billing.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerAccount .

ind:contractId rdf:type rdf:Property ;
    rdfs:label 'Contract Id' ;
    rdfs:comment 'Identifier of the master service agreement or umbrella contract governing this hierarchy relationship. Links the hierarchy to the contractual terms, SLA commitments, and pricing schedules applicable across all child sites.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contract .

ind:parentEpaIdRegistrationId rdf:type rdf:Property ;
    rdfs:label 'Parent Epa Id Registration Id' ;
    rdfs:comment 'Foreign key linking to hazmat.epa_id_registration. Business justification: Corporate hierarchies with multiple EPA IDs require tracking parent-subsidiary generator relationships for consolidated biennial reporting, liability allocation, and multi-site permit management. Supp' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EpaIdRegistration .

ind:primaryCustomerAccountId rdf:type rdf:Property ;
    rdfs:label 'Primary Customer Account Id' ;
    rdfs:comment 'Identifier of the parent account in this hierarchy relationship. References the customer account that sits above the child in the corporate, franchise, or municipal umbrella structure.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CustomerAccount .

ind:approvalStatus rdf:type rdf:Property ;
    rdfs:label 'Approval Status' ;
    rdfs:comment 'Workflow approval status for this hierarchy relationship record. New or modified hierarchy relationships require approval before becoming operationally active. Supports governance and audit trail requirements for account structure changes.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedBy rdf:type rdf:Property ;
    rdfs:label 'Approved By' ;
    rdfs:comment 'Name or user identifier of the Waste Management manager or executive who approved this hierarchy relationship. Required for SOX compliance and internal audit trails for account structure governance.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedDate rdf:type rdf:Property ;
    rdfs:label 'Approved Date' ;
    rdfs:comment 'Date on which this hierarchy relationship was formally approved by the designated authority. Supports SOX compliance audit trails and account governance reporting.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consolidatedBillingFlag rdf:type rdf:Property ;
    rdfs:label 'Consolidated Billing Flag' ;
    rdfs:comment 'Indicates whether invoices for the child account are consolidated and issued at the parent account level rather than individually at the child site level. True enables enterprise-level consolidated billing for national accounts and municipal umbrella contracts.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consolidatedReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Consolidated Reporting Flag' ;
    rdfs:comment 'Indicates whether operational and environmental compliance reports (e.g., diversion rates, tonnage, GHG emissions) for the child account are aggregated and reported at the parent account level. Supports enterprise sustainability reporting and national account KPI dashboards.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:effectiveEndDate rdf:type rdf:Property ;
    rdfs:label 'Effective End Date' ;
    rdfs:comment 'The date on which this parent-child account hierarchy relationship expires or is terminated. Null for open-ended relationships with no planned end date. Supports historical hierarchy reporting and contract lifecycle management.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveStartDate rdf:type rdf:Property ;
    rdfs:label 'Effective Start Date' ;
    rdfs:comment 'The date on which this parent-child account hierarchy relationship became or becomes effective and binding. Used for time-based reporting and to determine which hierarchy was active during a given service period.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:hierarchyCode rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this hierarchy relationship, used in cross-system references and national account management communications. Sourced from Salesforce CRM account hierarchy records.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyDepth rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Depth' ;
    rdfs:comment 'Numeric depth of the child account within the hierarchy tree, where 1 represents a direct child of the ultimate parent. Supports tree traversal queries and enterprise reporting roll-ups for national account management.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hierarchyLevel rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Level' ;
    rdfs:comment 'Designates the positional level of the child account within the hierarchy structure. \'ultimate_parent\' is the root enterprise account, \'intermediate_parent\' is a mid-tier grouping (e.g., regional division), and \'child_site\' is the leaf-level service location.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyName rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Name' ;
    rdfs:comment 'Human-readable name for this hierarchy relationship or grouping, typically reflecting the corporate group, franchise network, or municipal contract name (e.g., \'Acme Corp National Account\', \'City of Houston Municipal District\'). Used in reporting and account management interfaces.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyPath rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Path' ;
    rdfs:comment 'Materialized path string representing the full ancestry chain from the ultimate parent to the child account (e.g., \'/10001/10045/10089\'). Enables efficient subtree queries and hierarchy traversal without recursive joins in the Databricks lakehouse.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyStatus rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Status' ;
    rdfs:comment 'Current lifecycle state of this hierarchy relationship. \'active\' indicates the relationship is in force, \'pending\' indicates awaiting approval or activation, \'suspended\' indicates temporarily paused, \'terminated\' indicates the relationship has ended, and \'inactive\' indicates administratively deactivated.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyType rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Type' ;
    rdfs:comment 'Classifies the structural purpose of this hierarchy. \'corporate\' reflects legal ownership structures, \'franchise\' reflects franchised operator networks, \'municipal\' reflects government contract groupings, \'geographic\' reflects territory-based groupings, and \'billing\' reflects consolidated billing arrangements independent of ownership.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nationalAccountFlag rdf:type rdf:Property ;
    rdfs:label 'National Account Flag' ;
    rdfs:comment 'Indicates whether this hierarchy relationship is part of a national account program, where a single corporate parent has service agreements spanning multiple geographic markets. Drives national account management workflows and pricing tier eligibility.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notes rdf:type rdf:Property ;
    rdfs:label 'Notes' ;
    rdfs:comment 'Free-text field for account managers and data stewards to capture contextual notes about this hierarchy relationship, such as special contractual arrangements, pending restructuring events, or franchise agreement nuances not captured in structured fields.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingTier rdf:type rdf:Property ;
    rdfs:label 'Pricing Tier' ;
    rdfs:comment 'Pricing tier classification assigned to this hierarchy relationship, reflecting volume-based or contract-negotiated rate schedules applicable across all child sites. Confidential commercial information used by revenue management and sales teams.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipType rdf:type rdf:Property ;
    rdfs:label 'Relationship Type' ;
    rdfs:comment 'Classifies the nature of the parent-child relationship. \'corporate_subsidiary\' applies to owned business entities, \'franchise\' to franchised operators, \'municipal_district\' to government umbrella contracts, \'multi_site_commercial\' to commercial customers with multiple service locations, and \'joint_venture\' to shared-ownership arrangements. [ENUM-REF-CANDIDATE: corporate_subsidiary|franchise|municipal_district|multi_site_commercial|joint_venture|other — promote to reference product]' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceRegionCode rdf:type rdf:Property ;
    rdfs:label 'Service Region Code' ;
    rdfs:comment 'Alphanumeric code identifying the Waste Management operational service region or district in which this hierarchy relationship is primarily managed. Supports regional performance reporting and operational territory alignment.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTier rdf:type rdf:Property ;
    rdfs:label 'Sla Tier' ;
    rdfs:comment 'Service Level Agreement tier applicable to this hierarchy relationship, determining response time commitments, service frequency guarantees, and escalation priorities across all child sites. \'enterprise\' and \'government\' tiers carry enhanced SLA obligations.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemHierarchyReference rdf:type rdf:Property ;
    rdfs:label 'Source System Hierarchy Reference' ;
    rdfs:comment 'The native identifier of this hierarchy relationship in the originating source system (e.g., Salesforce Account Hierarchy ID, SAP Customer Hierarchy Node ID). Enables traceability back to the system of record for reconciliation and audit purposes.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalChildSiteCount rdf:type rdf:Property ;
    rdfs:label 'Total Child Site Count' ;
    rdfs:comment 'Total number of active child service sites or accounts directly or indirectly subordinate to the parent account in this hierarchy. Maintained as a denormalized count to support national account management dashboards and contract scope validation without recursive queries.' ;
    rdfs:domain ind:AccountHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentSegmentId rdf:type rdf:Property ;
    rdfs:label 'Parent Segment Id' ;
    rdfs:comment 'Self-referencing FK on segment (parent_segment_id)' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:approvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approved Timestamp' ;
    rdfs:comment 'Timestamp when this customer segment definition was formally approved by the designated business owner or data steward. Required for governance compliance and SOX audit trail on reference data changes.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:billingFrequency rdf:type rdf:Property ;
    rdfs:label 'Billing Frequency' ;
    rdfs:comment 'Default billing cycle frequency for customers in this segment as configured in Oracle Revenue Management. Residential segments are typically billed monthly or quarterly; commercial segments monthly; government contracts may be quarterly or annual.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractRequired rdf:type rdf:Property ;
    rdfs:label 'Contract Required' ;
    rdfs:comment 'Indicates whether customers in this segment must have a formal service contract (as opposed to month-to-month or on-demand service). Commercial, Industrial, and Government segments typically require contracts; standard residential may be month-to-month.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditCheckRequired rdf:type rdf:Property ;
    rdfs:label 'Credit Check Required' ;
    rdfs:comment 'Indicates whether a credit check is required during customer onboarding for this segment. Typically required for commercial and industrial segments; waived for government/municipal accounts and standard residential prepay accounts.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crmSegmentCode rdf:type rdf:Property ;
    rdfs:label 'Crm Segment Code' ;
    rdfs:comment 'Corresponding segment identifier code as configured in Salesforce CRM account records. Used for bi-directional synchronization between the Databricks Silver Layer and Salesforce CRM to ensure consistent segment classification across systems.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depositRequired rdf:type rdf:Property ;
    rdfs:label 'Deposit Required' ;
    rdfs:comment 'Indicates whether a security deposit is required from customers in this segment at account activation. Deposit requirements are managed in Oracle Revenue Management and SAP S/4HANA FI module.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:diversionRateTargetPct rdf:type rdf:Property ;
    rdfs:label 'Diversion Rate Target Pct' ;
    rdfs:comment 'Target waste diversion rate percentage (waste diverted from landfill through recycling, composting, or WTE) for customers in this segment. Used for sustainability program goal-setting, MRF throughput planning, and EPA/state environmental compliance reporting. Expressed as a percentage (0.00–100.00).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dotRegulated rdf:type rdf:Property ;
    rdfs:label 'Dot Regulated' ;
    rdfs:comment 'Indicates whether waste collection services for customers in this segment are subject to DOT hazardous materials transportation regulations (49 CFR). Applies to segments generating regulated hazardous waste requiring special vehicle placarding and CDL driver certification.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:effectiveFrom rdf:type rdf:Property ;
    rdfs:label 'Effective From' ;
    rdfs:comment 'Date from which this customer segment definition is effective and available for customer assignment. Supports temporal validity tracking for segment taxonomy changes and ensures historical accuracy in customer lifecycle reporting.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveUntil rdf:type rdf:Property ;
    rdfs:label 'Effective Until' ;
    rdfs:comment 'Date after which this customer segment definition is no longer active for new customer assignments. Null indicates the segment is open-ended with no planned expiration. Deprecated segments retain this date for historical reference.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:epaGeneratorClass rdf:type rdf:Property ;
    rdfs:label 'Epa Generator Class' ;
    rdfs:comment 'EPA hazardous waste generator classification applicable to customers in this segment under RCRA regulations: VSQG (Very Small Quantity Generator), SQG (Small Quantity Generator), LQG (Large Quantity Generator), or Not Applicable for non-hazardous segments. Drives compliance reporting requirements in Enviance EHS.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ghgReportingRequired rdf:type rdf:Property ;
    rdfs:label 'Ghg Reporting Required' ;
    rdfs:comment 'Indicates whether customers in this segment require Greenhouse Gas (GHG) emissions reporting as part of their service agreement or regulatory obligation. Applies to large commercial, industrial, and government segments subject to EPA GHG Reporting Program (40 CFR Part 98). Managed in Enviance EHS.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDefaultSegment rdf:type rdf:Property ;
    rdfs:label 'Is Default Segment' ;
    rdfs:comment 'Indicates whether this segment is the system default assigned to new customer accounts when no explicit segment classification has been determined during onboarding. Only one segment should carry this flag as True at any given time.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lifecycleStatus rdf:type rdf:Property ;
    rdfs:label 'Lifecycle Status' ;
    rdfs:comment 'Current operational status of the customer segment definition within the classification taxonomy. \'active\' segments are available for customer assignment; \'deprecated\' segments are retained for historical reference only; \'draft\' segments are pending approval before activation.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manifestRequired rdf:type rdf:Property ;
    rdfs:label 'Manifest Required' ;
    rdfs:comment 'Indicates whether a Uniform Hazardous Waste Manifest (EPA Form 8700-22) is required for waste pickups from customers in this segment. Mandatory for LQG and SQG hazardous waste generators under RCRA. Tracked in Enviance EHS and SAP EHS module.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketCategory rdf:type rdf:Property ;
    rdfs:label 'Market Category' ;
    rdfs:comment 'High-level market category grouping for the segment: B2C (Business-to-Consumer residential), B2B (Business-to-Business commercial), Government, Industrial, or Non-Profit. Drives sales channel assignment, pricing strategy, and regulatory reporting classification.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxAnnualRevenueUsd rdf:type rdf:Property ;
    rdfs:label 'Max Annual Revenue Usd' ;
    rdfs:comment 'Maximum annual revenue threshold in US dollars for customer accounts in this segment. Accounts exceeding this threshold are eligible for promotion to a higher segment. Null indicates no upper revenue cap for the segment.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minAnnualRevenueUsd rdf:type rdf:Property ;
    rdfs:label 'Min Annual Revenue Usd' ;
    rdfs:comment 'Minimum annual revenue threshold in US dollars that a customer account must meet to qualify for this segment. Used in Salesforce CRM for automated segment assignment and in Oracle Revenue Management for rate eligibility validation. Null indicates no minimum revenue requirement.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minContractTermMonths rdf:type rdf:Property ;
    rdfs:label 'Min Contract Term Months' ;
    rdfs:comment 'Minimum contract duration in months required for customers in this segment. Null or zero indicates no minimum contract term (e.g., residential month-to-month). Enterprise and National Account segments typically require 12–60 month minimum terms.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:npsBenchmarkTarget rdf:type rdf:Property ;
    rdfs:label 'Nps Benchmark Target' ;
    rdfs:comment 'Target Net Promoter Score (NPS) benchmark for customers in this segment, used to set performance expectations for customer satisfaction programs. NPS ranges from -100 to +100. Residential segments typically target 40+; National Account segments target 60+.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentTermsDays rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Days' ;
    rdfs:comment 'Standard number of days from invoice date within which payment is due for customers in this segment (e.g., Net 30, Net 60). Configured in Oracle Revenue Management and SAP S/4HANA AR module. Government segments may have Net 45 or Net 60 terms.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:routingPriority rdf:type rdf:Property ;
    rdfs:label 'Routing Priority' ;
    rdfs:comment 'Numeric priority rank (1 = highest priority) used by AMCS Platform and Locus Dispatch to sequence collection routes when capacity constraints require prioritization. Government and medical waste segments typically carry the highest routing priority.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:salesChannel rdf:type rdf:Property ;
    rdfs:label 'Sales Channel' ;
    rdfs:comment 'Primary sales channel through which customers in this segment are acquired and managed. Drives Salesforce CRM lead routing and opportunity assignment rules. Municipal Bid applies to government/municipal contracts won through competitive procurement.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentCode rdf:type rdf:Property ;
    rdfs:label 'Segment Code' ;
    rdfs:comment 'Short, externally-known alphanumeric code uniquely identifying the customer segment (e.g., RES_SFH, COM_SMB, GOV_MUN). Used as the business key in Salesforce CRM account records, AMCS routing configurations, and Oracle Revenue Management rate schedules.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentDescription rdf:type rdf:Property ;
    rdfs:label 'Segment Description' ;
    rdfs:comment 'Detailed narrative description of the customer segment, including the types of customers it encompasses, qualifying criteria, and intended use in service delivery and sales targeting.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentName rdf:type rdf:Property ;
    rdfs:label 'Segment Name' ;
    rdfs:comment 'Human-readable name of the customer segment (e.g., \'Residential Single-Family\', \'Commercial Small Business\', \'Government/Municipal\'). Displayed in Salesforce CRM, Waste Logics customer portal, and all operational and executive reporting.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentType rdf:type rdf:Property ;
    rdfs:label 'Segment Type' ;
    rdfs:comment 'Operational classification of the segment type used for service eligibility rules, route planning in AMCS, and container management in Waste Logics. Residential covers single-family and multi-family; Commercial covers small business through national accounts; Industrial covers large-scale waste generators.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceEligibilityCommercial rdf:type rdf:Property ;
    rdfs:label 'Service Eligibility Commercial' ;
    rdfs:comment 'Indicates whether customers in this segment are eligible for commercial waste collection services (dumpster/container service, compactor service, FEL/REL/ASL truck service). Used by AMCS Platform for service configuration.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceEligibilityHazardous rdf:type rdf:Property ;
    rdfs:label 'Service Eligibility Hazardous' ;
    rdfs:comment 'Indicates whether customers in this segment are eligible for hazardous waste handling and disposal services under RCRA regulations. Typically restricted to Industrial, Commercial, and Government segments with appropriate EPA generator registration.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceEligibilityRecycling rdf:type rdf:Property ;
    rdfs:label 'Service Eligibility Recycling' ;
    rdfs:comment 'Indicates whether customers in this segment are eligible for recycling collection and Materials Recovery Facility (MRF) processing services. Drives diversion rate reporting and sustainability program enrollment.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceEligibilityResidential rdf:type rdf:Property ;
    rdfs:label 'Service Eligibility Residential' ;
    rdfs:comment 'Indicates whether customers in this segment are eligible for residential waste collection services (curbside pickup, recycling bins, yard waste). Used by Waste Logics to filter available service offerings during customer onboarding.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceEligibilityWte rdf:type rdf:Property ;
    rdfs:label 'Service Eligibility Wte' ;
    rdfs:comment 'Indicates whether customers in this segment are eligible for Waste-to-Energy (WTE) conversion services. Eligibility is typically limited to large commercial, industrial, and municipal segments generating sufficient MSW volume to support WTE processing economics.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sortOrder rdf:type rdf:Property ;
    rdfs:label 'Sort Order' ;
    rdfs:comment 'Numeric sort order for displaying customer segments in UI dropdowns, reports, and dashboards across Salesforce CRM, Waste Logics portal, and internal analytics tools. Lower numbers appear first.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:subSegmentType rdf:type rdf:Property ;
    rdfs:label 'Sub Segment Type' ;
    rdfs:comment 'Granular sub-classification within the segment type (e.g., Single-Family, Multi-Family under Residential; Small Business, Mid-Market, Enterprise, National Account under Commercial). Used for targeted service offerings and NPS benchmark differentiation. [ENUM-REF-CANDIDATE: Single-Family|Multi-Family|Small Business|Mid-Market|Enterprise|National Account|Municipal|County|State Agency|Federal Agency|Light Industrial|Heavy Industrial|Non-Profit — promote to reference product]' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityProgramEligible rdf:type rdf:Property ;
    rdfs:label 'Sustainability Program Eligible' ;
    rdfs:comment 'Indicates whether customers in this segment are eligible to enroll in Waste Management sustainability programs (e.g., zero-waste consulting, RNG offset credits, SRF programs, carbon footprint reporting). Typically available to commercial, industrial, and government segments.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:versionNumber rdf:type rdf:Property ;
    rdfs:label 'Version Number' ;
    rdfs:comment 'Monotonically incrementing version number tracking revisions to the customer segment definition. Incremented each time segment attributes (SLA tier, pricing tier, eligibility rules) are modified. Supports audit trail and rollback capabilities.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteLogicsSegmentCode rdf:type rdf:Property ;
    rdfs:label 'Waste Logics Segment Code' ;
    rdfs:comment 'Corresponding segment identifier code as configured in the Waste Logics customer portal and service scheduling system. Enables accurate service eligibility filtering and container management rules for customers accessing the self-service portal.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountStatusHistoryId rdf:type rdf:Property ;
    rdfs:label 'Account Status History Id' ;
    rdfs:comment 'Unique surrogate identifier for each account status history record. Serves as the primary key for this immutable audit trail table.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complaintId rdf:type rdf:Property ;
    rdfs:label 'Complaint Id' ;
    rdfs:comment 'Reference to the Salesforce CRM service case or customer service ticket that initiated or is associated with this status transition (e.g., a cancellation request case, a dispute case leading to suspension). Nullable when the transition is system-initiated.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Complaint .

ind:finalInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Final Invoice Id' ;
    rdfs:comment 'Reference to the final invoice generated upon account closure or suspension. Links to the Oracle Revenue Management billing system for final billing reconciliation, credit memo processing, and AR write-off procedures.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:initiatedByContactId rdf:type rdf:Property ;
    rdfs:label 'Initiated By Contact Id' ;
    rdfs:comment 'Foreign key linking to customer.contact. Business justification: An account status transition (e.g., suspension, reactivation, closure) is initiated by a specific contact — either the customer contact requesting cancellation or an internal contact processing the ch' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:manifestId rdf:type rdf:Property ;
    rdfs:label 'Manifest Id' ;
    rdfs:comment 'Foreign key linking to hazmat.manifest. Business justification: account_status_history has manifest_closure_required flag — when a hazardous waste account is closed or suspended, open manifests must be identified and formally closed per RCRA requirements. Direct m' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Manifest .

ind:regulatoryRequirementId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Requirement Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_requirement. Business justification: Account status transitions (suspension, closure, reactivation) are sometimes mandated by regulatory requirements (e.g., generator status change requiring service modification). account_status_history ' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryRequirement .

ind:violationNoticeId rdf:type rdf:Property ;
    rdfs:label 'Violation Notice Id' ;
    rdfs:comment 'Foreign key linking to compliance.violation_notice. Business justification: Account suspensions or closures triggered by regulatory violation notices (e.g., EPA enforcement action requiring service termination) must be traceable to the specific NOV. account_status_history has' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ViolationNotice .

ind:workOrderId rdf:type rdf:Property ;
    rdfs:label 'Work Order Id' ;
    rdfs:comment 'Reference to the Work Order (WO) associated with this status transition, such as a final service pickup work order generated upon account closure or a reactivation service order. Nullable when no WO is linked.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkOrder .

ind:approvalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approval Timestamp' ;
    rdfs:comment 'The date and time at which supervisory approval was granted for this status transition. Distinct from effective_timestamp (when the change took effect) and created_timestamp (when the record was written). Supports SOX audit trail completeness.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:arBalanceAtTransition rdf:type rdf:Property ;
    rdfs:label 'Ar Balance At Transition' ;
    rdfs:comment 'The outstanding Accounts Receivable (AR) balance on the customer account at the exact moment of this status transition. Critical for non-payment suspension and closure analysis, collections prioritization, and bad debt provisioning under GAAP.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:churnClassification rdf:type rdf:Property ;
    rdfs:label 'Churn Classification' ;
    rdfs:comment 'Classifies the nature of account churn when the transition represents a closure or deactivation: voluntary (customer-initiated cancellation), involuntary (non-payment or collections-driven), regulatory (compliance-mandated), or seasonal (temporary suspension with planned reactivation). Supports churn analytics and retention strategy development.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionsReferralDate rdf:type rdf:Property ;
    rdfs:label 'Collections Referral Date' ;
    rdfs:comment 'The date on which the account was referred to the collections process following a non-payment suspension or closure. Applicable only for financially-driven status transitions. Supports AR aging analysis and bad debt provisioning under GAAP.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:comments rdf:type rdf:Property ;
    rdfs:label 'Comments' ;
    rdfs:comment 'Additional free-text comments or notes entered by the initiating user or system regarding this status transition. May include escalation notes, customer communication summaries, or operational context not captured in structured fields.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerRetrievalRequired rdf:type rdf:Property ;
    rdfs:label 'Container Retrieval Required' ;
    rdfs:comment 'Indicates whether Waste Management-owned containers (bins, dumpsters, roll-off containers) must be retrieved from the service address following this status transition. Triggers container retrieval work order creation in AMCS Platform.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:daysInPriorStatus rdf:type rdf:Property ;
    rdfs:label 'Days In Prior Status' ;
    rdfs:comment 'The number of calendar days the account remained in the prior status before this transition occurred. Supports customer lifecycle duration analysis, churn prediction modeling, and SLA compliance measurement.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:effectiveTimestamp rdf:type rdf:Property ;
    rdfs:label 'Effective Timestamp' ;
    rdfs:comment 'The precise date and time at which the new account status became operationally effective. This is the business event timestamp — distinct from the record audit timestamp — and is the authoritative time used for churn analysis, SLA measurement, and regulatory compliance reporting.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:finalServiceDate rdf:type rdf:Property ;
    rdfs:label 'Final Service Date' ;
    rdfs:comment 'The date of the last scheduled or completed waste collection service for the account, captured at the time of closure or suspension. Used for final billing reconciliation, container retrieval scheduling, and service completion verification.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:hazardousWasteAccount rdf:type rdf:Property ;
    rdfs:label 'Hazardous Waste Account' ;
    rdfs:comment 'Indicates whether this account involves hazardous waste services subject to RCRA, DOT, and EPA regulatory requirements. Status transitions for hazardous waste accounts require additional regulatory documentation and notification procedures.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:initiatingSystem rdf:type rdf:Property ;
    rdfs:label 'Initiating System' ;
    rdfs:comment 'The operational system of record that originated or triggered this status transition event. Supports data lineage, integration audit trails, and root-cause analysis for unexpected status changes.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manifestClosureRequired rdf:type rdf:Property ;
    rdfs:label 'Manifest Closure Required' ;
    rdfs:comment 'Indicates whether a hazardous waste Manifest (the regulatory tracking document) must be formally closed or reconciled as part of this account status transition. Applicable only for hazardous waste accounts. Supports RCRA compliance and EPA enforcement documentation.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:newStatus rdf:type rdf:Property ;
    rdfs:label 'New Status' ;
    rdfs:comment 'The account lifecycle status immediately after this transition. Captures the \'to\' state in the status change event. Valid values mirror prior_status enumeration. [ENUM-REF-CANDIDATE: prospect|active|suspended|inactive|closed|pending_activation|pending_closure — promote to reference product]' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationChannel rdf:type rdf:Property ;
    rdfs:label 'Notification Channel' ;
    rdfs:comment 'The communication channel used to notify the customer of this status transition. Supports multi-channel communication audit trails and regulatory compliance with required notification method standards.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationSent rdf:type rdf:Property ;
    rdfs:label 'Notification Sent' ;
    rdfs:comment 'Indicates whether a customer notification (email, letter, or portal message) was sent to the customer regarding this status transition. Supports compliance with state consumer protection notification requirements and customer communication audit trails.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Notification Timestamp' ;
    rdfs:comment 'The date and time at which the customer notification for this status transition was sent. Supports regulatory compliance documentation for required advance notice periods (e.g., service termination notice requirements under state utility regulations).' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:priorStatus rdf:type rdf:Property ;
    rdfs:label 'Prior Status' ;
    rdfs:comment 'The account lifecycle status immediately before this transition occurred. Captures the \'from\' state in the status change event. Valid values: prospect (pre-service lead), active (receiving service), suspended (temporarily halted), inactive (service ended but record retained), closed (permanently terminated). [ENUM-REF-CANDIDATE: prospect|active|suspended|inactive|closed|pending_activation|pending_closure — promote to reference product]' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorStatusEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Prior Status Effective Date' ;
    rdfs:comment 'The date on which the prior status originally became effective. Combined with effective_timestamp, enables precise calculation of duration in prior status for lifecycle analytics and SLA compliance measurement.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reactivationEligible rdf:type rdf:Property ;
    rdfs:label 'Reactivation Eligible' ;
    rdfs:comment 'Indicates whether the account is eligible for reactivation following this status transition. Set to False for deceased customers, regulatory closures, or fraud-related closures. Supports win-back campaign targeting and collections recovery workflows.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reasonCode rdf:type rdf:Property ;
    rdfs:label 'Reason Code' ;
    rdfs:comment 'Standardized reason code explaining why the account status transition occurred. Supports churn analysis, regulatory reporting, and customer lifecycle management. [ENUM-REF-CANDIDATE: non_payment|service_cancellation|relocation|deceased|business_closure|reactivation|contract_expiry|regulatory_action|merger_acquisition|seasonal_suspension — promote to reference product]' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonDescription rdf:type rdf:Property ;
    rdfs:label 'Reason Description' ;
    rdfs:comment 'Free-text narrative providing additional context or detail about the reason for the status transition, supplementing the structured reason_code. May include customer-stated reasons, agent notes, or system-generated explanations.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryActionReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Action Reference' ;
    rdfs:comment 'Reference number or identifier for any regulatory enforcement action, permit violation notice, or compliance order that directly caused this status transition. Applicable for regulatory-driven account closures or suspensions. Supports RCRA, EPA, and state environmental agency compliance documentation.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceTerritoryCode rdf:type rdf:Property ;
    rdfs:label 'Service Territory Code' ;
    rdfs:comment 'The Waste Management service territory or district code associated with the account at the time of this status transition. Supports geographic churn analysis, route optimization impact assessment, and regional regulatory compliance reporting.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaBreach rdf:type rdf:Property ;
    rdfs:label 'Sla Breach' ;
    rdfs:comment 'Indicates whether this status transition occurred in breach of a contractual Service Level Agreement (SLA), such as a failure to reactivate service within the committed timeframe or a suspension applied without required advance notice. Supports SLA compliance monitoring and contract penalty calculations.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceRecordReference rdf:type rdf:Property ;
    rdfs:label 'Source Record Reference' ;
    rdfs:comment 'The native record identifier from the originating system of record (e.g., Salesforce CRM Account History ID, Oracle Revenue Management event ID, Waste Logics status log ID). Supports data lineage tracing, reconciliation between source systems and the lakehouse, and duplicate detection.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suspensionReasonCategory rdf:type rdf:Property ;
    rdfs:label 'Suspension Reason Category' ;
    rdfs:comment 'High-level category for suspension-specific transitions, providing a structured classification above the detailed reason_code. Applicable only when new_status is \'suspended\'. Supports regulatory reporting and collections workflow routing.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transitionType rdf:type rdf:Property ;
    rdfs:label 'Transition Type' ;
    rdfs:comment 'Categorizes how the status transition was initiated: manual (agent or user action), system_automated (triggered by billing engine, collections workflow, or scheduled job), bulk_update (mass data migration or batch operation), or regulatory (mandated by a regulatory authority or compliance requirement).' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:winBackEligibleDate rdf:type rdf:Property ;
    rdfs:label 'Win Back Eligible Date' ;
    rdfs:comment 'The earliest date on which a closed or inactive account becomes eligible for win-back outreach campaigns. May be set based on cooling-off periods, debt clearance timelines, or business rules. Supports Salesforce CRM marketing campaign targeting.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:writeOffAmount rdf:type rdf:Property ;
    rdfs:label 'Write Off Amount' ;
    rdfs:comment 'The dollar amount of outstanding AR balance written off as uncollectable at the time of account closure. Applicable only for closure transitions with unrecoverable debt. Supports GAAP bad debt expense recognition and SOX financial controls.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Service Enrollment Id' ;
    rdfs:comment 'Unique surrogate identifier for each service enrollment record in the Waste Management lakehouse. Primary key for the service_enrollment data product.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceEnrollment .

ind:assetContainerId rdf:type rdf:Property ;
    rdfs:label 'Asset Container Id' ;
    rdfs:comment 'Reference to the specific physical container asset assigned to this enrollment, identified by the Container Identification (CID) number tracked in AMCS Platform and Infor EAM. Nullable when a specific container has not yet been assigned or for bag-based services.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AssetContainer .

ind:billingRateScheduleId rdf:type rdf:Property ;
    rdfs:label 'Billing Rate Schedule Id' ;
    rdfs:comment 'Foreign key linking to billing.billing_rate_schedule. Business justification: Each service enrollment is priced against a specific rate schedule. In waste management, rate schedules define base rates, fuel surcharges, and container fees per service type. monthly_rate_usd and ra' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BillingRateSchedule .

ind:billingTermId rdf:type rdf:Property ;
    rdfs:label 'Billing Term Id' ;
    rdfs:comment 'Foreign key linking to contract.billing_term. Business justification: Each service enrollment is billed under specific billing terms (cycle day, payment method, invoice delivery). Invoice generation and accounts receivable processes require resolving the exact billing t' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BillingTerm .

ind:bundleId rdf:type rdf:Property ;
    rdfs:label 'Bundle Id' ;
    rdfs:comment 'Foreign key linking to service.bundle. Business justification: Customers enroll in bundled service packages. The enrollment must reference the bundle to support bundle-level discount application, auto-renewal management, and promotional tracking. WM sales and bil' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Bundle .

ind:cycleId rdf:type rdf:Property ;
    rdfs:label 'Cycle Id' ;
    rdfs:comment 'Foreign key linking to billing.cycle. Business justification: Billing cycle assignment at enrollment determines invoice generation timing (monthly, quarterly, etc.). Waste management billing runs are cycle-driven; the enrollment must reference its cycle to be in' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Cycle .

ind:fixedAssetId rdf:type rdf:Property ;
    rdfs:label 'Fixed Asset Id' ;
    rdfs:comment 'Foreign key linking to asset.fixed_asset. Business justification: Compactor and baler service enrollments reference the specific installed fixed asset at the customer site. WM operations track which fixed asset (compactor/baler) is covered under each service agreeme' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FixedAsset .

ind:frequencyPlanId rdf:type rdf:Property ;
    rdfs:label 'Frequency Plan Id' ;
    rdfs:comment 'Foreign key linking to service.frequency_plan. Business justification: Service enrollments are scheduled per a frequency plan driving route optimization and billing proration. service_enrollment.service_frequency is a plain text denormalization of service.frequency_plan.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FrequencyPlan .

ind:landfillSiteId rdf:type rdf:Property ;
    rdfs:label 'Landfill Site Id' ;
    rdfs:comment 'Foreign key linking to landfill.site. Business justification: Disposal service enrollments are contractually tied to a designated landfill site for tipping fee rate application and capacity planning. Operations need to know which landfill site a service enrollme' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Site .

ind:offeringId rdf:type rdf:Property ;
    rdfs:label 'Offering Id' ;
    rdfs:comment 'Foreign key linking to service.offering. Business justification: Customer service enrollments should link directly to the service catalog offering to ensure customers are enrolled in valid, current service offerings. This provides a single source of truth for servi' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Offering .

ind:pricingId rdf:type rdf:Property ;
    rdfs:label 'Pricing Id' ;
    rdfs:comment 'Foreign key linking to contract.pricing. Business justification: Each service enrollment is priced under a specific pricing record defining base rates, escalation schedules, and surcharges. Revenue recognition and billing accuracy require direct enrollment-to-prici' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Pricing .

ind:routeId rdf:type rdf:Property ;
    rdfs:label 'Route Id' ;
    rdfs:comment 'Reference to the collection route to which this service enrollment is assigned for scheduled pickup. Managed in AMCS Platform and Locus Dispatch. Drives driver dispatch, vehicle assignment, and stop sequencing.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Route .

ind:slaDefinitionId rdf:type rdf:Property ;
    rdfs:label 'Sla Definition Id' ;
    rdfs:comment 'Foreign key linking to service.sla_definition. Business justification: Each service enrollment is governed by a specific SLA definition determining response times, missed pickup credits, and escalation thresholds. WM operations and customer service teams need this link t' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SlaDefinition .

ind:slaTermId rdf:type rdf:Property ;
    rdfs:label 'Sla Term Id' ;
    rdfs:comment 'Foreign key linking to contract.sla_term. Business justification: Each service enrollment is subject to specific SLA terms governing response times and service frequency guarantees. Real-time SLA breach monitoring and penalty calculation require direct enrollment-to' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SlaTerm .

ind:stopId rdf:type rdf:Property ;
    rdfs:label 'Stop Id' ;
    rdfs:comment 'Foreign key linking to collection.stop. Business justification: Service enrollments define ongoing service commitments that map to specific recurring stops on routes. This link enables operational execution, capacity planning, and route optimization by connecting ' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Stop .

ind:trainingRequirementId rdf:type rdf:Property ;
    rdfs:label 'Training Requirement Id' ;
    rdfs:comment 'Foreign key linking to compliance.training_requirement. Business justification: Hazardous waste service enrollments require customer personnel to meet specific training requirements (RCRA personnel training, DOT hazmat training). Linking service_enrollment to training_requirement' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TrainingRequirement .

ind:wasteProfileId rdf:type rdf:Property ;
    rdfs:label 'Waste Profile Id' ;
    rdfs:comment 'Foreign key linking to hazmat.waste_profile. Business justification: Recurring hazmat service enrollments specify approved waste profiles defining authorized waste codes, treatment requirements, TSDF destinations, and handling procedures. Essential for service authoriz' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WasteProfile .

ind:accessRestrictionFlag rdf:type rdf:Property ;
    rdfs:label 'Access Restriction Flag' ;
    rdfs:comment 'Indicates whether the service address for this enrollment has access restrictions (e.g., gated community, locked enclosure, restricted hours, weight-limited road). True = driver must follow special access procedures documented in special_instructions. Used for route planning and driver briefing.' ;
    rdfs:domain ind:ServiceEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:autoRenewalFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Flag' ;
    rdfs:comment 'Indicates whether this service enrollment is configured to automatically renew upon reaching the enrollment end date. True = auto-renews per contract terms; False = requires explicit renewal action. Relevant for commercial and municipal contract management.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cancellationDate rdf:type rdf:Property ;
    rdfs:label 'Cancellation Date' ;
    rdfs:comment 'The date on which the service enrollment was formally cancelled. Distinct from enrollment_end_date, which may reflect a scheduled end; cancellation_date records the actual date the cancellation was processed. Used for churn reporting and final billing cutoff.' ;
    rdfs:domain ind:ServiceEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cancellationReason rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason' ;
    rdfs:comment 'The stated reason for cancellation or termination of the service enrollment. Populated when enrollment_status transitions to \'cancelled\'. Common reasons include customer relocation, competitor switch, non-payment, service dissatisfaction, or contract expiry. Used for churn analysis and customer retention reporting.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerSizeGallons rdf:type rdf:Property ;
    rdfs:label 'Container Size Gallons' ;
    rdfs:comment 'The volumetric capacity of the assigned container in US gallons. Standard residential cart sizes include 32, 64, and 96 gallons. Commercial dumpsters range from 96 gallons to several cubic yards (converted). Used for capacity planning, route load calculations, and billing rate determination.' ;
    rdfs:domain ind:ServiceEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:containerType rdf:type rdf:Property ;
    rdfs:label 'Container Type' ;
    rdfs:comment 'The type of waste container assigned to this service enrollment. Cart = residential wheeled bin; dumpster = commercial front-end loader (FEL) or rear-end loader (REL) container; roll_off = open-top roll-off box; compactor = stationary or portable compactor unit; toter = smaller wheeled bin; bag = bag-based service. Aligns with Container Identification (CID) in AMCS Platform.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diversionTargetPct rdf:type rdf:Property ;
    rdfs:label 'Diversion Target Pct' ;
    rdfs:comment 'The contractually or operationally agreed target diversion rate (percentage of waste diverted from landfill) for this service enrollment. Applicable primarily to recycling and organics enrollments. Used for sustainability reporting and customer-facing environmental impact dashboards.' ;
    rdfs:domain ind:ServiceEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:enrollmentEndDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment End Date' ;
    rdfs:comment 'The date on which the service enrollment is scheduled to end or was terminated. Null for open-ended recurring service agreements. Populated upon cancellation, contract expiry, or service completion.' ;
    rdfs:domain ind:ServiceEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enrollmentNumber rdf:type rdf:Property ;
    rdfs:label 'Enrollment Number' ;
    rdfs:comment 'Externally-known, human-readable business identifier for the service enrollment, used in customer communications, Waste Logics portal, and Salesforce CRM service records. Format: SE- followed by 8–12 digits.' ;
    rdfs:domain ind:ServiceEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentStartDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment Start Date' ;
    rdfs:comment 'The date on which the service enrollment becomes effective and service delivery begins. Used for billing cycle initiation, route assignment, and SLA tracking.' ;
    rdfs:domain ind:ServiceEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enrollmentStatus rdf:type rdf:Property ;
    rdfs:label 'Enrollment Status' ;
    rdfs:comment 'Current lifecycle state of the service enrollment. \'active\' = service is being delivered; \'pending\' = enrollment initiated but not yet started; \'suspended\' = temporarily halted (e.g., customer request, non-payment); \'cancelled\' = terminated before or during service; \'completed\' = service period ended normally.' ;
    rdfs:domain ind:ServiceEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardousWasteFlag rdf:type rdf:Property ;
    rdfs:label 'Hazardous Waste Flag' ;
    rdfs:comment 'Indicates whether this service enrollment involves the handling, collection, or disposal of RCRA-regulated hazardous waste materials. True = hazardous waste service requiring EPA manifest tracking, TSDF routing, and DOT compliance. Triggers additional regulatory workflows in Enviance EHS.' ;
    rdfs:domain ind:ServiceEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextScheduledServiceDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Service Date' ;
    rdfs:comment 'The date on which the next service event is scheduled for this enrollment based on the service frequency and route schedule. Derived from the route schedule but stored here for operational convenience and customer-facing portal display in Waste Logics.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originationChannel rdf:type rdf:Property ;
    rdfs:label 'Origination Channel' ;
    rdfs:comment 'The channel through which this service enrollment was initiated. web_portal = customer self-service via Waste Logics portal; call_center = inbound customer service call; field_sales = direct sales representative; crm = Salesforce CRM workflow; edi = electronic data interchange from commercial account; municipal_contract = government contract award.' ;
    rdfs:domain ind:ServiceEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Permit Required Flag' ;
    rdfs:comment 'Indicates whether a regulatory permit (e.g., EPA, state environmental agency, local solid waste authority) is required to perform the service under this enrollment. True = permit must be on file and valid before service commences. Tracked in Enviance EHS permit management module.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:salesforceEnrollmentRef rdf:type rdf:Property ;
    rdfs:label 'Salesforce Enrollment Ref' ;
    rdfs:comment 'The Salesforce CRM record ID corresponding to this service enrollment, enabling cross-system traceability between the Databricks lakehouse silver layer and the Salesforce CRM system of record. Standard Salesforce IDs are 15 or 18 alphanumeric characters.' ;
    rdfs:domain ind:ServiceEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceDayOfWeek rdf:type rdf:Property ;
    rdfs:label 'Service Day Of Week' ;
    rdfs:comment 'The scheduled day(s) of the week on which service is performed for this enrollment. For multi-day schedules, stores the primary service day; additional days captured in the route schedule. Used by AMCS Platform and Locus Dispatch for route planning. [ENUM-REF-CANDIDATE: Monday|Tuesday|Wednesday|Thursday|Friday|Saturday|Sunday — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceLevel rdf:type rdf:Property ;
    rdfs:label 'Service Level' ;
    rdfs:comment 'The tier of service provided under this enrollment, defining the Service Level Agreement (SLA) commitments such as response time for missed pickups, customer support priority, and on-call availability. Standard = baseline SLA; Premium = enhanced SLA with guaranteed response windows; Basic = minimal SLA.' ;
    rdfs:domain ind:ServiceEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaResponseHours rdf:type rdf:Property ;
    rdfs:label 'Sla Response Hours' ;
    rdfs:comment 'The maximum number of hours within which a missed pickup or service failure must be remediated per the Service Level Agreement (SLA) for this enrollment. Drives customer service escalation workflows and compliance reporting.' ;
    rdfs:domain ind:ServiceEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:specialInstructions rdf:type rdf:Property ;
    rdfs:label 'Special Instructions' ;
    rdfs:comment 'Free-text field capturing any special handling, access, or placement instructions for the service address associated with this enrollment. Examples: gate codes, locked enclosure access, placement at curb vs. alley, fragile materials, or driver safety notes. Displayed to drivers in Locus Dispatch.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suspensionEndDate rdf:type rdf:Property ;
    rdfs:label 'Suspension End Date' ;
    rdfs:comment 'The date on which a suspended service enrollment is scheduled to resume or was reactivated. Null when enrollment is not suspended or suspension is indefinite. Used for route reinstatement and billing resumption.' ;
    rdfs:domain ind:ServiceEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:suspensionStartDate rdf:type rdf:Property ;
    rdfs:label 'Suspension Start Date' ;
    rdfs:comment 'The date on which the service enrollment was placed in a suspended state (e.g., seasonal hold, customer-requested pause, non-payment hold). Null when enrollment is not suspended. Used for billing adjustments and route management.' ;
    rdfs:domain ind:ServiceEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:wasteLogicsEnrollmentRef rdf:type rdf:Property ;
    rdfs:label 'Waste Logics Enrollment Ref' ;
    rdfs:comment 'The enrollment or service record identifier from the Waste Logics customer portal and service scheduling system. Enables cross-system reconciliation between the lakehouse and the Waste Logics operational system of record for container management and service scheduling.' ;
    rdfs:domain ind:ServiceEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceRequestId rdf:type rdf:Property ;
    rdfs:label 'Service Request Id' ;
    rdfs:comment 'Unique system-generated identifier for each customer service request record in the Waste Management platform. Primary key for the service_request data product.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceRequest .

ind:assignedRouteId rdf:type rdf:Property ;
    rdfs:label 'Assigned Route Id' ;
    rdfs:comment 'Reference to the collection route to which this service request has been assigned for fulfillment. Populated when the request requires a field dispatch (e.g., bulk pickup, extra pickup, missed pickup). Sourced from AMCS Platform or Locus Dispatch.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Route .

ind:driverId rdf:type rdf:Property ;
    rdfs:label 'Driver Id' ;
    rdfs:comment 'Foreign key linking to fleet.driver. Business justification: Dispatch operations assign a specific driver to fulfill each service request. Driver accountability for missed pickups, service quality, and regulatory compliance requires knowing which driver execute' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Driver .

ind:ehsIncidentId rdf:type rdf:Property ;
    rdfs:label 'Ehs Incident Id' ;
    rdfs:comment 'Foreign key linking to compliance.ehs_incident. Business justification: Service requests for spill cleanup, emergency waste removal, or incident response are generated from EHS incidents. Linking service_request to ehs_incident enables incident response time tracking, reg' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EhsIncident .

ind:hazmatServiceOrderId rdf:type rdf:Property ;
    rdfs:label 'Hazmat Service Order Id' ;
    rdfs:comment 'Foreign key linking to hazmat.service_order. Business justification: A customer hazmat service_request is fulfilled by creating a hazmat service_order. Linking request to fulfilling order enables end-to-end request-to-fulfillment tracking, SLA measurement, and billing ' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceOrder .

ind:inboundLoadId rdf:type rdf:Property ;
    rdfs:label 'Inbound Load Id' ;
    rdfs:comment 'Foreign key linking to recycling.inbound_load. Business justification: Customer service requests for missed pickups or contamination complaints reference specific MRF inbound loads when material quality issues are discovered during processing. Essential for root cause an' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InboundLoad .

ind:invoiceId rdf:type rdf:Property ;
    rdfs:label 'Invoice Id' ;
    rdfs:comment 'Reference to the invoice generated for any additional charges associated with this service request. Nullable when no additional charges apply or billing is pending. Links to the billing data product.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:pickupEventId rdf:type rdf:Property ;
    rdfs:label 'Pickup Event Id' ;
    rdfs:comment 'Foreign key linking to collection.pickup_event. Business justification: Service requests often reference specific pickup events ("my container wasn\'t serviced on Tuesday"). Linking to the actual pickup event provides proof-of-service or proof-of-exception with RFID scan d' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PickupEvent .

ind:routeExecutionId rdf:type rdf:Property ;
    rdfs:label 'Route Execution Id' ;
    rdfs:comment 'Foreign key linking to collection.route_execution. Business justification: Service requests for missed pickups, service complaints, or quality issues reference specific service dates. Linking to the actual route execution enables operational root cause analysis, driver accou' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RouteExecution .

ind:vehicleId rdf:type rdf:Property ;
    rdfs:label 'Vehicle Id' ;
    rdfs:comment 'Foreign key linking to fleet.vehicle. Business justification: Service requests frequently involve vehicle-specific issues: missed pickups due to vehicle breakdown, property damage from collection vehicle, container damage during collection. Essential for fleet p' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vehicle .

ind:wasteStreamId rdf:type rdf:Property ;
    rdfs:label 'Waste Stream Id' ;
    rdfs:comment 'Foreign key linking to service.service_waste_stream. Business justification: Service requests specify waste stream to determine proper handling procedures, required equipment, routing to appropriate facility, manifest requirements, and pricing. Essential for work order generat' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WasteStream .

ind:billingStatus rdf:type rdf:Property ;
    rdfs:label 'Billing Status' ;
    rdfs:comment 'Indicates the billing lifecycle status for any additional charges associated with this service request. Not applicable for requests with no additional charges. Pending when charges are identified but not yet invoiced. Sourced from Oracle Revenue Management.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancelledTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cancelled Timestamp' ;
    rdfs:comment 'The date and time when the service request was cancelled, either by the customer or by operations. Nullable for non-cancelled requests. Used for cancellation rate analysis and customer churn indicators.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:caseNumber rdf:type rdf:Property ;
    rdfs:label 'Case Number' ;
    rdfs:comment 'Externally visible, human-readable case number assigned to the service request, used in customer communications and cross-system tracking. Sourced from Salesforce CRM Case Number or Waste Logics ticket reference.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelSource rdf:type rdf:Property ;
    rdfs:label 'Channel Source' ;
    rdfs:comment 'The intake channel through which the customer submitted the service request. Used for channel analytics, staffing optimization, and digital adoption tracking. Sourced from Salesforce CRM Case Origin or Waste Logics submission metadata.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Completed Timestamp' ;
    rdfs:comment 'The date and time when the service request was marked as fully completed and fulfilled. Used to calculate actual resolution time, SLA adherence, and operational performance metrics.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:containerCid rdf:type rdf:Property ;
    rdfs:label 'Container Cid' ;
    rdfs:comment 'The physical Container Identification (CID) number or RFID tag identifier printed on or embedded in the waste container. Used for field verification and container tracking without requiring a system lookup.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerSatisfactionScore rdf:type rdf:Property ;
    rdfs:label 'Customer Satisfaction Score' ;
    rdfs:comment 'Post-resolution customer satisfaction rating provided by the customer via survey or feedback mechanism. Typically on a 1-5 or 1-10 scale. Contributes to Net Promoter Score (NPS) and service quality analytics.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:escalationFlag rdf:type rdf:Property ;
    rdfs:label 'Escalation Flag' ;
    rdfs:comment 'Indicates whether this service request has been escalated to a supervisor, manager, or specialized team due to complexity, customer dissatisfaction, regulatory concern, or SLA breach risk. Used for escalation rate KPI reporting.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escalationReason rdf:type rdf:Property ;
    rdfs:label 'Escalation Reason' ;
    rdfs:comment 'Free-text or coded reason explaining why the service request was escalated. Populated only when escalation_flag is True. Examples include repeated missed pickups, regulatory compliance concern, or high-value customer complaint.' ;
    rdfs:domain ind:Customer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedWeightTons rdf:type rdf:Property ;
    rdfs:label 'Estimated Weight Tons' ;
    rdfs:comment 'Estimated weight in tons of the waste material associated with the service request, as provided by the customer or estimated by the intake agent. Relevant for bulk pickup, extra pickup, and C&D requests. Used for route load planning and tipping fee estimation.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:itemCount rdf:type rdf:Property ;
    rdfs:label 'Item Count' ;
    rdfs:comment 'Number of individual bulk items or containers included in the service request. Applicable for bulk item pickup requests where discrete item counts drive truck capacity planning and labor estimation.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priorityLevel rdf:type rdf:Property ;
    rdfs:label 'Priority Level' ;
    rdfs:comment 'Business priority assigned to the service request, used to determine SLA tier, dispatch urgency, and resource allocation. Critical priority is reserved for health/safety or regulatory compliance situations (e.g., hazardous waste spill, missed medical waste pickup).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Flag' ;
    rdfs:comment 'Indicates whether this service request has regulatory compliance implications, such as hazardous waste handling, RCRA-regulated material pickup, or EPA-reportable incident. When True, triggers compliance workflow and Enviance EHS notification.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requestStatus rdf:type rdf:Property ;
    rdfs:label 'Request Status' ;
    rdfs:comment 'Current fulfillment lifecycle status of the service request. Tracks progression from initial submission through scheduling, active fulfillment, and final resolution or cancellation.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestSubtypeCode rdf:type rdf:Property ;
    rdfs:label 'Request Subtype Code' ;
    rdfs:comment 'Secondary classification providing additional granularity within the request type. For example, under CONTAINER_SWAP: UPSIZE, DOWNSIZE, DAMAGE_REPLACEMENT. Sourced from Salesforce CRM Case Sub-Type.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestTypeCode rdf:type rdf:Property ;
    rdfs:label 'Request Type Code' ;
    rdfs:comment 'Categorical code identifying the nature of the customer service request. Drives workflow routing, SLA assignment, and fulfillment process. [ENUM-REF-CANDIDATE: BULK_PICKUP|EXTRA_PICKUP|MISSED_PICKUP|CONTAINER_SWAP|CONTAINER_REPAIR|START_SERVICE|STOP_SERVICE|BILLING_INQUIRY|HAZMAT_INQUIRY|RECYCLING_INQUIRY|SCHEDULE_CHANGE|OTHER — promote to reference product]' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedServiceDate rdf:type rdf:Property ;
    rdfs:label 'Requested Service Date' ;
    rdfs:comment 'The date on which the customer has requested the service action to be performed. May differ from the scheduled or actual fulfillment date. Used for scheduling and customer expectation management.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:resolutionNotes rdf:type rdf:Property ;
    rdfs:label 'Resolution Notes' ;
    rdfs:comment 'Operational notes documenting how the service request was resolved, including actions taken, exceptions encountered, and any follow-up required. Entered by the field crew, dispatcher, or customer service agent upon completion.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Date' ;
    rdfs:comment 'The date on which the service request has been formally scheduled for fulfillment by the operations team. May differ from the customer-requested date based on route availability and resource constraints.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Timestamp' ;
    rdfs:comment 'The precise date and time when the service request was formally scheduled in the dispatch system. Captures the scheduling event for audit trail and SLA milestone tracking.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:serviceFrequencyType rdf:type rdf:Property ;
    rdfs:label 'Service Frequency Type' ;
    rdfs:comment 'Indicates whether this service request represents a one-time ad hoc service action or a recurring add-on to an existing service schedule. Distinguishes episodic requests from schedule modifications.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceRequestDescription rdf:type rdf:Property ;
    rdfs:label 'Service Request Description' ;
    rdfs:comment 'Full narrative description of the service request as provided by the customer or intake agent. Contains details about the specific issue, location, container, or service need. Sourced from Salesforce CRM Case Description or Waste Logics portal notes.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaBreachFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Flag' ;
    rdfs:comment 'Indicates whether the service request was not fulfilled within the defined SLA due date. True when the completion timestamp exceeds the sla_due_date or the request remains open past the due date. Used for SLA compliance reporting and KPI tracking.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaDueDate rdf:type rdf:Property ;
    rdfs:label 'Sla Due Date' ;
    rdfs:comment 'The contractual or policy-defined deadline by which the service request must be fulfilled to meet the applicable Service Level Agreement (SLA). Calculated from submitted_timestamp based on request type and priority tier.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceSystemCaseReference rdf:type rdf:Property ;
    rdfs:label 'Source System Case Reference' ;
    rdfs:comment 'The native case or ticket identifier from the originating source system (e.g., Salesforce CRM Case ID or Waste Logics Ticket ID). Enables traceability back to the system of record for reconciliation and audit purposes.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subject rdf:type rdf:Property ;
    rdfs:label 'Subject' ;
    rdfs:comment 'Short, descriptive title or subject line summarizing the nature of the service request, as entered by the customer or agent. Sourced from Salesforce CRM Case Subject field.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submittedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submitted Timestamp' ;
    rdfs:comment 'The exact date and time when the customer submitted the service request. This is the principal business event timestamp representing when the request entered the system. Used as the baseline for SLA calculation.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:tippingFeeApplicable rdf:type rdf:Property ;
    rdfs:label 'Tipping Fee Applicable' ;
    rdfs:comment 'Indicates whether a tipping fee (charge per ton for waste disposal at a landfill or transfer station) applies to this service request. True for requests involving disposal charges beyond standard service contract terms.' ;
    rdfs:domain ind:ServiceRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:wasteStreamType rdf:type rdf:Property ;
    rdfs:label 'Waste Stream Type' ;
    rdfs:comment 'Classification of the waste stream associated with the service request. Municipal Solid Waste (MSW), recycling, organics, Construction and Demolition (C&D), hazardous, bulk items, or yard waste. Drives routing, compliance requirements, and disposal method. [ENUM-REF-CANDIDATE: msw|recycling|organics|c_and_d|hazardous|bulk|yard_waste — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Container Assignment Id' ;
    rdfs:comment 'Unique surrogate identifier for each container assignment record in the Waste Management lakehouse silver layer. Serves as the primary key for this entity.' ;
    rdfs:domain ind:ContainerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:containerTypeId rdf:type rdf:Property ;
    rdfs:label 'Container Type Id' ;
    rdfs:comment 'Foreign key linking to service.container_type. Business justification: Container assignments reference a specific container type for equipment provisioning, maintenance scheduling, and rental billing. container_assignment.container_type is a plain text denormalization of' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContainerType .

ind:materialStreamWasteStreamId rdf:type rdf:Property ;
    rdfs:label 'Material Stream Waste Stream Id' ;
    rdfs:comment 'Foreign key linking to service.service_waste_stream. Business justification: Container assignments designate which waste stream the container accepts for contamination tracking, diversion rate calculation, proper disposal routing, and regulatory reporting. Critical for recycli' ;
    rdfs:domain ind:ContainerAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WasteStream .

ind:pmScheduleId rdf:type rdf:Property ;
    rdfs:label 'Pm Schedule Id' ;
    rdfs:comment 'Foreign key linking to maintenance.pm_schedule. Business justification: Containers assigned to customers require preventive maintenance schedules for cleaning, repair, and regulatory inspections. Real business process: container PM programs track maintenance cycles based ' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PmSchedule .

ind:primaryContainerDeliveryWorkOrderId rdf:type rdf:Property ;
    rdfs:label 'Primary Container Delivery Work Order Id' ;
    rdfs:comment 'Reference to the Work Order (WO) created in AMCS Platform or SAP PM module to execute the container delivery. Enables traceability from the assignment record back to the field service event.' ;
    rdfs:domain ind:ContainerAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkOrder .

ind:priorAssignmentContainerAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Prior Assignment Container Assignment Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the previous container assignment at this service address that this record replaces (e.g., after a swap or upgrade). Null for original assignments. Enables container assignment history chain reconstruction.' ;
    rdfs:domain ind:ContainerAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContainerAssignment .

ind:assignmentNumber rdf:type rdf:Property ;
    rdfs:label 'Assignment Number' ;
    rdfs:comment 'Externally visible, human-readable business identifier for this container assignment. Used in customer communications, work orders, and field operations. Format: CA- followed by 8-12 digits.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentStatus rdf:type rdf:Property ;
    rdfs:label 'Assignment Status' ;
    rdfs:comment 'Current lifecycle status of the container assignment. \'active\' = container is at the service address and in service; \'pending_delivery\' = scheduled for delivery; \'pending_removal\' = scheduled for pickup; \'lost\' = container cannot be located; \'damaged\' = container reported damaged; \'swapped\' = replaced by another container. [ENUM-REF-CANDIDATE: active|pending_delivery|pending_removal|lost|damaged|swapped|suspended|expired — promote to reference product]' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cid rdf:type rdf:Property ;
    rdfs:label 'Cid' ;
    rdfs:comment 'Container Identification (CID) number — the industry-standard physical identifier stamped or affixed to the container asset. Used for field identification, route scanning, and container audits. Sourced from AMCS Platform container tracking.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionDayOfWeek rdf:type rdf:Property ;
    rdfs:label 'Collection Day Of Week' ;
    rdfs:comment 'Scheduled day(s) of the week on which the container is collected. For multi-day schedules, stores the primary collection day. Drives route assignment in AMCS Platform and Locus Dispatch. Sunday collection is not standard in most markets.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionFrequency rdf:type rdf:Property ;
    rdfs:label 'Collection Frequency' ;
    rdfs:comment 'Scheduled frequency at which the container is serviced (emptied) under this assignment. Drives route scheduling in AMCS Platform and Locus Dispatch. \'on_call\' = customer requests pickup as needed (common for roll-offs).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionAtDelivery rdf:type rdf:Property ;
    rdfs:label 'Condition At Delivery' ;
    rdfs:comment 'Physical condition of the container at the time it was delivered to the service address. Recorded by the driver or dispatcher at delivery. Used for warranty tracking, asset lifecycle management, and customer dispute resolution.' ;
    rdfs:domain ind:ContainerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionAtRemoval rdf:type rdf:Property ;
    rdfs:label 'Condition At Removal' ;
    rdfs:comment 'Physical condition of the container at the time it was removed from the service address. Recorded by the driver or dispatcher at pickup. Supports damage assessment, customer liability determination, and asset refurbishment decisions.' ;
    rdfs:domain ind:ContainerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerSegment rdf:type rdf:Property ;
    rdfs:label 'Customer Segment' ;
    rdfs:comment 'Business-to-consumer or business-to-business segment classification of the customer receiving this container assignment. \'residential\' = B2C household; \'commercial\' = B2B business account; \'industrial\' = large-volume industrial client; \'municipal\' = government/municipal contract.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:damageDescription rdf:type rdf:Property ;
    rdfs:label 'Damage Description' ;
    rdfs:comment 'Free-text description of any damage observed on the container at delivery or during the assignment period. Populated when condition_at_delivery or condition_at_removal indicates damage. Supports insurance claims and customer billing for damage charges.' ;
    rdfs:domain ind:ContainerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryDate rdf:type rdf:Property ;
    rdfs:label 'Delivery Date' ;
    rdfs:comment 'Calendar date on which the container was physically delivered to the service address and the assignment became active. Sourced from the completed delivery work order in AMCS Platform or Waste Logics.' ;
    rdfs:domain ind:ContainerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enclosureRequired rdf:type rdf:Property ;
    rdfs:label 'Enclosure Required' ;
    rdfs:comment 'Indicates whether the container must be placed within a screened enclosure or enclosure structure per local municipal ordinance, HOA requirements, or customer contract terms. True = enclosure required; False = open placement permitted.' ;
    rdfs:domain ind:ContainerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastServicedDate rdf:type rdf:Property ;
    rdfs:label 'Last Serviced Date' ;
    rdfs:comment 'Most recent calendar date on which the container was collected/emptied under this assignment. Updated after each successful collection event. Used for service verification, missed pickup detection, and customer service inquiries.' ;
    rdfs:domain ind:ContainerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lockRequired rdf:type rdf:Property ;
    rdfs:label 'Lock Required' ;
    rdfs:comment 'Indicates whether the container requires a lock mechanism for security or regulatory compliance (e.g., hazardous waste containers, high-theft areas, or customer-requested security). True = lock required; False = no lock required.' ;
    rdfs:domain ind:ContainerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:materialStream rdf:type rdf:Property ;
    rdfs:label 'Material Stream' ;
    rdfs:comment 'Waste material stream designated for this container assignment. \'msw\' = Municipal Solid Waste (MSW) general refuse; \'recycling\' = commingled recyclables for Materials Recovery Facility (MRF) processing; \'organics\' = food/organic waste; \'cd_waste\' = Construction and Demolition (C&D) debris; \'hazardous\' = regulated hazardous waste; \'yard_waste\' = landscaping and green waste.' ;
    rdfs:domain ind:ContainerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:missedPickupCount rdf:type rdf:Property ;
    rdfs:label 'Missed Pickup Count' ;
    rdfs:comment 'Cumulative count of missed or skipped scheduled collection events for this container assignment since delivery. Used for SLA compliance monitoring, customer satisfaction tracking, and NPS correlation analysis.' ;
    rdfs:domain ind:ContainerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overageAllowed rdf:type rdf:Property ;
    rdfs:label 'Overage Allowed' ;
    rdfs:comment 'Indicates whether the customer\'s service agreement permits overage (excess waste placed beside or on top of the container beyond its rated capacity). True = overage collection is permitted and may trigger additional charges; False = overage is not collected.' ;
    rdfs:domain ind:ContainerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:placementLatitude rdf:type rdf:Property ;
    rdfs:label 'Placement Latitude' ;
    rdfs:comment 'GPS latitude coordinate of the container\'s physical placement location at the service address. Enables precise geolocation for driver navigation, container audits, and lost container recovery. Sourced from Geotab Fleet Telematics or AMCS Platform.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:placementLocation rdf:type rdf:Property ;
    rdfs:label 'Placement Location' ;
    rdfs:comment 'Descriptive text indicating the specific placement location of the container at the service address (e.g., \'curbside\', \'back alley\', \'loading dock bay 3\', \'inside gate\'). Used by drivers for accurate container location during collection.' ;
    rdfs:domain ind:ContainerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:placementLongitude rdf:type rdf:Property ;
    rdfs:label 'Placement Longitude' ;
    rdfs:comment 'GPS longitude coordinate of the container\'s physical placement location at the service address. Enables precise geolocation for driver navigation, container audits, and lost container recovery. Sourced from Geotab Fleet Telematics or AMCS Platform.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryManifestRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Manifest Required' ;
    rdfs:comment 'Indicates whether a Hazardous Waste Manifest (tracking document) is required for the material stream in this container assignment per RCRA regulations. True = manifest required (hazardous waste); False = standard MSW/recycling, no manifest required.' ;
    rdfs:domain ind:ContainerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:removalDate rdf:type rdf:Property ;
    rdfs:label 'Removal Date' ;
    rdfs:comment 'Calendar date on which the container was physically removed from the service address, ending the active assignment. Null if the assignment is still active. Used for container utilization duration calculations and billing period closure.' ;
    rdfs:domain ind:ContainerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rfidTag rdf:type rdf:Property ;
    rdfs:label 'Rfid Tag' ;
    rdfs:comment 'Radio Frequency Identification (RFID) tag identifier embedded in or affixed to the container. Enables automated container scanning during collection events without manual barcode scanning. Null if container is not RFID-equipped.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Delivery Date' ;
    rdfs:comment 'Originally planned calendar date for container delivery to the service address. Compared against actual delivery_date to measure delivery SLA compliance and route scheduling accuracy.' ;
    rdfs:domain ind:ContainerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledRemovalDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Removal Date' ;
    rdfs:comment 'Originally planned calendar date for container removal from the service address. Compared against actual removal_date to measure removal SLA compliance. Populated when a removal work order is created.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:serviceType rdf:type rdf:Property ;
    rdfs:label 'Service Type' ;
    rdfs:comment 'Indicates whether the container assignment supports a recurring scheduled service, an on-call demand service, a temporary placement (e.g., event or construction project), or a one-time service request.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sizeCubicYards rdf:type rdf:Property ;
    rdfs:label 'Size Cubic Yards' ;
    rdfs:comment 'Nominal capacity of the container expressed in cubic yards. Used for commercial dumpsters, roll-offs, and compactors (e.g., 2, 4, 6, 8, 10, 20, 30, 40 cubic yards). Null for containers measured in gallons. Supports billing, route planning, and capacity management.' ;
    rdfs:domain ind:ContainerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sizeGallons rdf:type rdf:Property ;
    rdfs:label 'Size Gallons' ;
    rdfs:comment 'Nominal capacity of the container expressed in US gallons. Used for residential carts and toters (e.g., 32, 64, 96 gallons). Null for containers measured in cubic yards. Supports container utilization analysis and route weight estimation.' ;
    rdfs:domain ind:ContainerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:swapReason rdf:type rdf:Property ;
    rdfs:label 'Swap Reason' ;
    rdfs:comment 'Reason code explaining why this container assignment was created as a replacement for a prior assignment. Null if this is an original assignment (not a swap). Supports container lifecycle analysis and operational efficiency reporting.' ;
    rdfs:domain ind:ContainerAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communicationPreferenceId rdf:type rdf:Property ;
    rdfs:label 'Communication Preference Id' ;
    rdfs:comment 'Unique surrogate identifier for each communication preference record. Primary key for the communication_preference data product in the customer domain.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:billingAlertOptIn rdf:type rdf:Property ;
    rdfs:label 'Billing Alert Opt In' ;
    rdfs:comment 'Indicates whether the customer has opted in to receive billing-related alerts such as invoice generation, payment due reminders, and payment confirmation notifications. Supports Oracle Revenue Management billing communication workflows.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:channel rdf:type rdf:Property ;
    rdfs:label 'Channel' ;
    rdfs:comment 'The preferred communication channel through which the customer or contact wishes to receive outreach. Supports omnichannel engagement across email, SMS, phone, physical mail, the Waste Logics customer portal, and mobile push notifications.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Consent Document Reference' ;
    rdfs:comment 'Reference identifier for the consent document, contract clause, or recorded call that evidences the consent. For paper forms, this is the document scan ID; for contracts, this is the contract number and clause reference; for recorded calls, this is the call recording ID.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Consent Expiry Date' ;
    rdfs:comment 'The date on which the recorded consent expires and must be re-obtained. Applicable where regulatory or business policy requires periodic consent renewal. Null indicates consent does not expire under current policy.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consentIpAddress rdf:type rdf:Property ;
    rdfs:label 'Consent Ip Address' ;
    rdfs:comment 'The IP address from which the customer submitted their consent (e.g., via the Waste Logics customer portal or email signup form). Provides technical evidence of consent origin for regulatory audit purposes. Classified as confidential PII as IP addresses may identify individuals in some jurisdictions.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentMethod rdf:type rdf:Property ;
    rdfs:label 'Consent Method' ;
    rdfs:comment 'The legal mechanism by which consent was obtained. \'express_written\' is required for TCPA-regulated SMS and autodialed calls. \'double_opt_in\' provides the strongest evidence of consent for email marketing. Drives compliance reporting and legal defensibility.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentSource rdf:type rdf:Property ;
    rdfs:label 'Consent Source' ;
    rdfs:comment 'The system or touchpoint through which consent was captured. [ENUM-REF-CANDIDATE: customer_portal|salesforce_crm|paper_form|ivr|mobile_app|service_call|email_signup|contract_signature|third_party — promote to reference product]' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentStatus rdf:type rdf:Property ;
    rdfs:label 'Consent Status' ;
    rdfs:comment 'Current regulatory consent status for the specified channel and notification type. \'granted\' indicates valid consent is on file; \'revoked\' indicates consent was withdrawn; \'pending\' indicates awaiting confirmation (double opt-in); \'expired\' indicates consent has lapsed per retention policy; \'not_required\' applies to transactional communications exempt from consent requirements.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Consent Timestamp' ;
    rdfs:comment 'The exact date and time when the customer or contact granted, revoked, or updated consent for this channel and notification type. Critical audit field for TCPA and CAN-SPAM compliance. Stored in ISO 8601 format with timezone offset.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:contactFrequency rdf:type rdf:Property ;
    rdfs:label 'Contact Frequency' ;
    rdfs:comment 'The customer or contact\'s preferred frequency for non-transactional outreach (e.g., promotional offers, NPS surveys, service updates). Transactional and compliance-driven communications (e.g., billing alerts, regulatory notices) are not subject to this frequency cap.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doNotContact rdf:type rdf:Property ;
    rdfs:label 'Do Not Contact' ;
    rdfs:comment 'Master suppression flag indicating the customer or contact must not be contacted through any channel. Overrides all individual channel and notification preferences. Must be honored across all outbound communication systems including Salesforce CRM, Oracle Revenue Management, and Waste Logics portal.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:doNotEmail rdf:type rdf:Property ;
    rdfs:label 'Do Not Email' ;
    rdfs:comment 'Specific suppression flag for email-based outreach. Distinct from the master do_not_contact flag to allow granular channel-level suppression. Compliance with CAN-SPAM Act unsubscribe requirements.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:doNotMail rdf:type rdf:Property ;
    rdfs:label 'Do Not Mail' ;
    rdfs:comment 'Specific suppression flag for physical postal mail outreach. Allows customers to opt out of paper-based communications such as billing statements, promotional mailers, and service notices.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:doNotSms rdf:type rdf:Property ;
    rdfs:label 'Do Not Sms' ;
    rdfs:comment 'Specific suppression flag for SMS/text message outreach. Required for TCPA compliance as SMS requires prior express written consent. Distinct from the master do_not_contact flag.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isActive rdf:type rdf:Property ;
    rdfs:label 'Is Active' ;
    rdfs:comment 'Indicates whether this communication preference record is currently active and in effect. Set to False when a preference is superseded by a newer record or when the contact is deactivated, enabling soft-delete and historical audit without data loss.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:languagePreference rdf:type rdf:Property ;
    rdfs:label 'Language Preference' ;
    rdfs:comment 'The customer or contact\'s preferred language for all communications, stored as an IETF BCP 47 language tag (e.g., \'en\', \'es\', \'zh-CN\', \'fr\'). Drives language selection in templated outbound communications across email, SMS, IVR, and portal notifications.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastUpdatedBy rdf:type rdf:Property ;
    rdfs:label 'Last Updated By' ;
    rdfs:comment 'The identifier of the user, system, or agent that last modified this preference record. May be a Salesforce CRM user ID, a Waste Logics portal session identifier, or a system process name (e.g., \'BULK_IMPORT\', \'IVR_SYSTEM\'). Supports audit trail and compliance investigation.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationType rdf:type rdf:Property ;
    rdfs:label 'Notification Type' ;
    rdfs:comment 'The category of notification for which this preference record captures opt-in or opt-out status. [ENUM-REF-CANDIDATE: billing_alert|service_reminder|outage_notification|promotional_offer|nps_survey|collection_schedule|account_update|regulatory_notice|payment_confirmation|route_change — promote to reference product]' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:npsSurveyOptIn rdf:type rdf:Property ;
    rdfs:label 'Nps Survey Opt In' ;
    rdfs:comment 'Indicates whether the customer has opted in to receive Net Promoter Score (NPS) and customer satisfaction surveys. Supports the customer experience measurement program and drives service improvement analytics.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optInStatus rdf:type rdf:Property ;
    rdfs:label 'Opt In Status' ;
    rdfs:comment 'Current opt-in or opt-out status of the customer or contact for the specified channel and notification type combination. \'pending\' indicates consent has been requested but not yet confirmed (e.g., double opt-in flow). \'not_set\' indicates no preference has been recorded.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optOutChannel rdf:type rdf:Property ;
    rdfs:label 'Opt Out Channel' ;
    rdfs:comment 'The channel or mechanism through which the customer submitted their opt-out request. Supports compliance audit trails and process improvement analysis (e.g., identifying which unsubscribe mechanisms are most used). [ENUM-REF-CANDIDATE: email_unsubscribe|sms_stop|ivr|customer_portal|agent_request|written_request|regulatory_order — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optOutReason rdf:type rdf:Property ;
    rdfs:label 'Opt Out Reason' ;
    rdfs:comment 'The reason provided by the customer or contact for opting out of a communication channel or notification type. [ENUM-REF-CANDIDATE: too_frequent|not_relevant|prefer_other_channel|unsubscribe_link|customer_request|complaint|regulatory_request|deceased — promote to reference product]' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optOutTimestamp rdf:type rdf:Property ;
    rdfs:label 'Opt Out Timestamp' ;
    rdfs:comment 'The exact date and time when the customer or contact submitted an opt-out request for this channel or notification type. CAN-SPAM requires opt-out requests to be honored within 10 business days; this timestamp is the compliance clock start.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:outageNotificationOptIn rdf:type rdf:Property ;
    rdfs:label 'Outage Notification Opt In' ;
    rdfs:comment 'Indicates whether the customer has opted in to receive service disruption and outage notifications such as missed collection alerts, route delays, weather-related service suspensions, and facility closures.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:portalNotificationEnabled rdf:type rdf:Property ;
    rdfs:label 'Portal Notification Enabled' ;
    rdfs:comment 'Indicates whether the customer has enabled in-portal notifications within the Waste Logics customer portal. When True, notifications are surfaced within the portal dashboard in addition to or instead of external channels.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferenceType rdf:type rdf:Property ;
    rdfs:label 'Preference Type' ;
    rdfs:comment 'Categorizes the nature of this preference record: channel (preferred delivery channel), notification (opt-in/out for a notification category), language (preferred language), frequency (preferred contact cadence), or do_not_contact (suppression flag). Enables structured querying of preference records.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredContactTimeEnd rdf:type rdf:Property ;
    rdfs:label 'Preferred Contact Time End' ;
    rdfs:comment 'The end of the customer\'s preferred time window for receiving phone or SMS outreach, stored in HH:MM 24-hour format in the customer\'s local time zone. TCPA restricts calls to 8 AM–9 PM local time; this field captures the customer\'s narrower preference within that window.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredContactTimeStart rdf:type rdf:Property ;
    rdfs:label 'Preferred Contact Time Start' ;
    rdfs:comment 'The start of the customer\'s preferred time window for receiving phone or SMS outreach, stored in HH:MM 24-hour format in the customer\'s local time zone. Used by outbound dialer and SMS scheduling systems to respect contact time preferences.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionalOptIn rdf:type rdf:Property ;
    rdfs:label 'Promotional Opt In' ;
    rdfs:comment 'Indicates whether the customer has opted in to receive promotional communications including new service offers, recycling program promotions, and sustainability initiative campaigns. Subject to CAN-SPAM and TCPA consent requirements.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryNoticeOptIn rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notice Opt In' ;
    rdfs:comment 'Indicates whether the customer has opted in to receive regulatory and compliance-related notices such as EPA-mandated service change notifications, RCRA hazardous waste handling updates, and local solid waste authority announcements. Note: some regulatory notices may be mandatory regardless of opt-in status.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceReminderOptIn rdf:type rdf:Property ;
    rdfs:label 'Service Reminder Opt In' ;
    rdfs:comment 'Indicates whether the customer has opted in to receive service reminders such as upcoming collection day notifications, container set-out reminders, and scheduled service confirmations. Supports AMCS Platform and Locus Dispatch customer notification workflows.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:suppressionListFlag rdf:type rdf:Property ;
    rdfs:label 'Suppression List Flag' ;
    rdfs:comment 'Indicates whether this contact has been added to a global suppression list, preventing all marketing and non-transactional outreach regardless of individual channel preferences. Populated from CAN-SPAM unsubscribe lists, TCPA litigation holds, or internal suppression decisions.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:suppressionReason rdf:type rdf:Property ;
    rdfs:label 'Suppression Reason' ;
    rdfs:comment 'The reason this contact was added to the suppression list. \'bounce\' indicates a hard email bounce; \'complaint\' indicates a spam complaint; \'litigation_hold\' indicates legal proceedings; \'regulatory\' indicates a government-mandated suppression order. [ENUM-REF-CANDIDATE: unsubscribe|complaint|bounce|litigation_hold|regulatory|deceased|fraud — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeZone rdf:type rdf:Property ;
    rdfs:label 'Time Zone' ;
    rdfs:comment 'The IANA time zone identifier for the customer\'s or contact\'s local time zone (e.g., \'America/Chicago\', \'America/Los_Angeles\'). Used in conjunction with preferred_contact_time_start and preferred_contact_time_end to schedule compliant outreach.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteGeneratorProfileId rdf:type rdf:Property ;
    rdfs:label 'Waste Generator Profile Id' ;
    rdfs:comment 'Unique surrogate identifier for the waste generator regulatory profile record in the Databricks Silver Layer. Primary key for this entity.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WasteGeneratorProfile .

ind:complianceInspectionId rdf:type rdf:Property ;
    rdfs:label 'Compliance Inspection Id' ;
    rdfs:comment 'Foreign key linking to compliance.compliance_inspection. Business justification: Generator sites are subject to EPA/state RCRA compliance inspections. The waste_generator_profile tracks last_inspection_date and inspection_result as plain fields — a proper FK to the compliance_insp' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ComplianceInspection .

ind:designatedLandfillSiteId rdf:type rdf:Property ;
    rdfs:label 'Designated Landfill Site Id' ;
    rdfs:comment 'Foreign key linking to landfill.site. Business justification: Waste generator profiles for non-hazardous and special waste generators designate a specific landfill site for disposal per franchise agreement or contract. Operations and compliance staff need this l' ;
    rdfs:domain ind:WasteGeneratorProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Site .

ind:disposalAgreementId rdf:type rdf:Property ;
    rdfs:label 'Disposal Agreement Id' ;
    rdfs:comment 'Foreign key linking to contract.disposal_agreement. Business justification: RCRA compliance requires each hazardous waste generator profile to be linked to an approved disposal agreement specifying the designated TSDF, waste codes, and tipping fee terms. Manifest preparation ' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DisposalAgreement .

ind:epaIdRegistrationId rdf:type rdf:Property ;
    rdfs:label 'Epa Id Registration Id' ;
    rdfs:comment 'Foreign key linking to hazmat.epa_id_registration. Business justification: Generator profiles require formal EPA ID registration for manifest signing authority, RCRAInfo synchronization, biennial reporting, and handler classification. Replaces denormalized epa_generator_id w' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EpaIdRegistration .

ind:haulingAgreementId rdf:type rdf:Property ;
    rdfs:label 'Hauling Agreement Id' ;
    rdfs:comment 'Foreign key linking to contract.hauling_agreement. Business justification: DOT and RCRA regulations require each hazardous waste generator to use only authorized haulers under a valid hauling agreement. Generator profiles must reference the governing hauling agreement for ma' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HaulingAgreement .

ind:monitoringProgramId rdf:type rdf:Property ;
    rdfs:label 'Monitoring Program Id' ;
    rdfs:comment 'Foreign key linking to compliance.monitoring_program. Business justification: Generator sites subject to post-closure or corrective action monitoring are enrolled in monitoring programs. Linking the generator profile to its monitoring program enables compliance status tracking,' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MonitoringProgram .

ind:primaryWasteProfileId rdf:type rdf:Property ;
    rdfs:label 'Primary Waste Profile Id' ;
    rdfs:comment 'Foreign key linking to hazmat.waste_profile. Business justification: A generator profile must reference its primary approved waste profile for service scheduling, container authorization, and LDR compliance verification. Role-prefix \'primary_\' used because a generator ' ;
    rdfs:domain ind:WasteGeneratorProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WasteProfile .

ind:regulatoryCorrectiveActionId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Corrective Action Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_corrective_action. Business justification: Corrective actions arising from generator-site inspections or NOVs are tracked against the generator profile. Environmental services compliance teams need to link the generator profile to its active c' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryCorrectiveAction .

ind:regulatorySubmissionId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_submission. Business justification: Biennial reports and RCRA notifications are regulatory submissions made on behalf of specific generator profiles. The waste_generator_profile has biennial_report_due_date and last_biennial_report_date' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatorySubmission .

ind:transferStationId rdf:type rdf:Property ;
    rdfs:label 'Transfer Station Id' ;
    rdfs:comment 'Foreign key linking to collection.transfer_station. Business justification: Hazardous waste generators must be associated with permitted transfer stations for regulatory compliance, EPA manifest routing, RCRA reporting, and TSDF facility coordination. This link enables proper' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TransferStation .

ind:tsdfFacilityId rdf:type rdf:Property ;
    rdfs:label 'Tsdf Facility Id' ;
    rdfs:comment 'Reference to the primary designated Treatment, Storage, and Disposal Facility (TSDF) used by this generator for hazardous waste disposal. The TSDF must hold a valid RCRA permit. Links to the facility/asset master in the Asset Management domain.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TsdfFacility .

ind:accumulationAreaType rdf:type rdf:Property ;
    rdfs:label 'Accumulation Area Type' ;
    rdfs:comment 'Classification of the on-site hazardous waste accumulation area based on RCRA generator category and applicable time limits. LQGs may accumulate up to 90 days; SQGs up to 180 days (or 270 days in rural areas); VSQGs have no time limit but volume limits apply. Satellite areas are small accumulation points feeding a central accumulation area.' ;
    rdfs:domain ind:WasteGeneratorProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:biennialReportDueDate rdf:type rdf:Property ;
    rdfs:label 'Biennial Report Due Date' ;
    rdfs:comment 'Due date for the next EPA Biennial Hazardous Waste Report submission. Required for LQGs in even-numbered years under RCRA 40 CFR Part 262.41. Tracks compliance calendar obligations for large quantity generators.' ;
    rdfs:domain ind:WasteGeneratorProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contingencyPlanOnFile rdf:type rdf:Property ;
    rdfs:label 'Contingency Plan On File' ;
    rdfs:comment 'Indicates whether a RCRA-compliant emergency contingency plan is on file for this generator. LQGs are required to maintain a formal contingency plan under 40 CFR Part 262.261; SQGs must have an emergency plan. Critical for compliance verification and emergency response readiness.' ;
    rdfs:domain ind:WasteGeneratorProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eManifestRegisteredFlag rdf:type rdf:Property ;
    rdfs:label 'E Manifest Registered Flag' ;
    rdfs:comment 'Indicates whether this generator is registered in the EPA\'s national e-Manifest system for electronic hazardous waste tracking. The e-Manifest system replaced paper manifests and is operated by the EPA under RCRA authority.' ;
    rdfs:domain ind:WasteGeneratorProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:emergencyCoordinatorName rdf:type rdf:Property ;
    rdfs:label 'Emergency Coordinator Name' ;
    rdfs:comment 'Full name of the designated emergency coordinator responsible for implementing the contingency plan and coordinating emergency response at the generator site. Required to be listed in the contingency plan and available to local emergency responders under RCRA.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyCoordinatorPhone rdf:type rdf:Property ;
    rdfs:label 'Emergency Coordinator Phone' ;
    rdfs:comment '24-hour contact phone number for the designated emergency coordinator at the generator site. Must be posted at the facility and provided to local emergency response agencies as required under RCRA contingency plan regulations.' ;
    rdfs:domain ind:WasteGeneratorProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedHazardousVolumeKgPerMonth rdf:type rdf:Property ;
    rdfs:label 'Estimated Hazardous Volume Kg Per Month' ;
    rdfs:comment 'Estimated monthly generation quantity of RCRA-regulated hazardous waste in kilograms. This is the primary metric used to classify the generator into VSQG (≤100 kg), SQG (100–999 kg), or LQG (≥1,000 kg) categories and must be re-evaluated whenever operations change.' ;
    rdfs:domain ind:WasteGeneratorProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedMonthlyVolumeTons rdf:type rdf:Property ;
    rdfs:label 'Estimated Monthly Volume Tons' ;
    rdfs:comment 'Estimated total waste generation volume per month expressed in short tons. Used to determine and validate RCRA generator category (VSQG/SQG/LQG), plan collection frequency, and support TPD (Tons Per Day) capacity planning for routing and disposal.' ;
    rdfs:domain ind:WasteGeneratorProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hazardousWasteCodes rdf:type rdf:Property ;
    rdfs:label 'Hazardous Waste Codes' ;
    rdfs:comment 'Comma-delimited list of EPA hazardous waste codes (e.g., D001, F003, U080) applicable to the waste streams generated at this site as determined by TCLP (Toxicity Characteristic Leaching Procedure) testing or listed waste classification. Required for manifest preparation and RCRA compliance reporting.' ;
    rdfs:domain ind:WasteGeneratorProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionResult rdf:type rdf:Property ;
    rdfs:label 'Inspection Result' ;
    rdfs:comment 'Outcome of the most recent regulatory inspection at this generator site. Significant violations may trigger enforcement actions, fines, or mandatory corrective measures under RCRA or CERCLA authority.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastBiennialReportDate rdf:type rdf:Property ;
    rdfs:label 'Last Biennial Report Date' ;
    rdfs:comment 'Date on which the most recent EPA Biennial Hazardous Waste Report was submitted for this generator. Used to verify compliance with LQG biennial reporting obligations and to support audit documentation.' ;
    rdfs:domain ind:WasteGeneratorProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Last Inspection Date' ;
    rdfs:comment 'Date of the most recent regulatory compliance inspection conducted at this generator site by the EPA, state environmental agency, or Local Enforcement Agency (LEA). Used to track inspection history and assess compliance standing.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Last Notification Date' ;
    rdfs:comment 'Date of the most recent RCRA Site ID notification update submitted to the EPA or authorized state agency. Generators must re-notify when their generator category changes, when they begin generating new hazardous waste streams, or when site information changes.' ;
    rdfs:domain ind:WasteGeneratorProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:manifestRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Manifest Required Flag' ;
    rdfs:comment 'Indicates whether this generator is required to use a Uniform Hazardous Waste Manifest (EPA Form 8700-22) for off-site shipments of hazardous waste. Mandatory for SQGs and LQGs; VSQGs are exempt from manifest requirements under 40 CFR Part 262.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxAccumulationDays rdf:type rdf:Property ;
    rdfs:label 'Max Accumulation Days' ;
    rdfs:comment 'Maximum number of days this generator is permitted to accumulate hazardous waste on-site before it must be shipped to a TSDF, as determined by generator category and applicable RCRA regulations. Exceeding this limit triggers LQG-level requirements or potential RCRA violation.' ;
    rdfs:domain ind:WasteGeneratorProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:naicsCode rdf:type rdf:Property ;
    rdfs:label 'Naics Code' ;
    rdfs:comment 'Six-digit NAICS code representing the primary industry classification of the waste-generating facility. Used by EPA and state agencies to categorize generator type, assess typical waste streams, and benchmark regulatory compliance requirements.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextNotificationDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Notification Due Date' ;
    rdfs:comment 'Scheduled due date for the next required RCRA notification or re-notification. LQGs must notify every four years under the 2016 Generator Improvements Rule. Used by compliance teams to proactively manage regulatory deadlines.' ;
    rdfs:domain ind:WasteGeneratorProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:openViolationFlag rdf:type rdf:Property ;
    rdfs:label 'Open Violation Flag' ;
    rdfs:comment 'Indicates whether this generator currently has one or more open, unresolved regulatory violations on record with the EPA or state environmental agency. Triggers enhanced compliance monitoring and may affect service agreements and manifest acceptance.' ;
    rdfs:domain ind:WasteGeneratorProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:personnelTrainingCurrentFlag rdf:type rdf:Property ;
    rdfs:label 'Personnel Training Current Flag' ;
    rdfs:comment 'Indicates whether all relevant facility personnel have completed current RCRA hazardous waste management training as required for the generator\'s category. LQGs must provide formal classroom or on-the-job training; SQGs must ensure familiarity with emergency procedures.' ;
    rdfs:domain ind:WasteGeneratorProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:profileEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Profile Effective Date' ;
    rdfs:comment 'Date from which this waste generator regulatory profile is considered valid and active. Represents the start of the current regulatory classification period, which may be triggered by initial registration, a generator category change, or a site re-notification.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:profileExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Profile Expiration Date' ;
    rdfs:comment 'Date on which this waste generator regulatory profile expires or must be renewed. Applicable when state permits or generator registrations have fixed validity periods. Null for open-ended federal EPA registrations.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rcraNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Rcra Notification Date' ;
    rdfs:comment 'Date on which the generator submitted the initial RCRA Site Identification (Site ID) notification to the EPA or authorized state agency, establishing the generator\'s regulatory identity and obligations. Required under 40 CFR Part 262.18.' ;
    rdfs:domain ind:WasteGeneratorProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:siteName rdf:type rdf:Property ;
    rdfs:label 'Site Name' ;
    rdfs:comment 'Legal or operating name of the waste-generating facility or site as registered with the EPA and state environmental agency. May differ from the customer account name if the customer operates multiple sites.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemProfileReference rdf:type rdf:Property ;
    rdfs:label 'Source System Profile Reference' ;
    rdfs:comment 'The native identifier for this waste generator profile record in the originating operational system (e.g., Enviance EHS record ID, SAP EHS business partner number, or RCRAInfo handler ID). Enables cross-system reconciliation and traceability.' ;
    rdfs:domain ind:WasteGeneratorProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statePermitNumber rdf:type rdf:Property ;
    rdfs:label 'State Permit Number' ;
    rdfs:comment 'State-issued environmental permit or registration number for the waste-generating facility, assigned by the applicable State Environmental Quality Department. Required for state-level RCRA-authorized program compliance and may differ from the federal EPA Generator ID.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateProgramCode rdf:type rdf:Property ;
    rdfs:label 'State Program Code' ;
    rdfs:comment 'Two-letter state code identifying the RCRA-authorized state program under which this generator is regulated. In RCRA-authorized states, the state program operates in lieu of the federal program; in non-authorized states, the EPA directly administers RCRA.' ;
    rdfs:domain ind:WasteGeneratorProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:universalWasteHandlerFlag rdf:type rdf:Property ;
    rdfs:label 'Universal Waste Handler Flag' ;
    rdfs:comment 'Indicates whether this generator is registered as a universal waste handler under 40 CFR Part 273, managing batteries, pesticides, mercury-containing equipment, or lamps under the streamlined universal waste rules rather than full RCRA hazardous waste requirements.' ;
    rdfs:domain ind:WasteGeneratorProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contaminationEventId rdf:type rdf:Property ;
    rdfs:label 'Contamination Event Id' ;
    rdfs:comment 'Foreign key linking to recycling.contamination_event. Business justification: Customer complaints about rejected loads or contamination surcharges directly reference documented contamination events at MRF. Required for billing dispute resolution and customer education on materi' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContaminationEvent .

ind:facilityId rdf:type rdf:Property ;
    rdfs:label 'Facility Id' ;
    rdfs:comment 'Foreign key linking to asset.facility. Business justification: Complaints about odor, noise, dust, or environmental violations are often facility-specific (e.g., landfill odor complaints, MRF noise complaints). Regulatory agencies require facility attribution for' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:onDemandRequestId rdf:type rdf:Property ;
    rdfs:label 'On Demand Request Id' ;
    rdfs:comment 'Foreign key linking to collection.on_demand_request. Business justification: Complaints frequently arise from failed or unsatisfactory on-demand service requests (late arrival, wrong container, no-show). Linking complaint to on_demand_request enables root cause analysis, SLA b' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OnDemandRequest .

ind:priorComplaintId rdf:type rdf:Property ;
    rdfs:label 'Prior Complaint Id' ;
    rdfs:comment 'Reference to the previous complaint record when repeat_complaint_flag is true, enabling complaint recurrence chain analysis and chronic service failure identification.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Complaint .

ind:rolloffOrderId rdf:type rdf:Property ;
    rdfs:label 'Rolloff Order Id' ;
    rdfs:comment 'Foreign key linking to collection.rolloff_order. Business justification: Complaints arise from rolloff order issues (late delivery, container damage, unauthorized overage charges). Linking complaint to rolloff_order enables dispute resolution, credit processing, and operat' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RolloffOrder .

ind:wasteShipmentId rdf:type rdf:Property ;
    rdfs:label 'Waste Shipment Id' ;
    rdfs:comment 'Foreign key linking to hazmat.waste_shipment. Business justification: Customer complaints about hazardous waste transport incidents (spills, delays, chain-of-custody breaks) must reference the specific waste_shipment for DOT incident investigation and chain-of-custody a' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WasteShipment .

ind:assignedTeam rdf:type rdf:Property ;
    rdfs:label 'Assigned Team' ;
    rdfs:comment 'Functional team responsible for complaint resolution. Environmental compliance team handles EPA/OSHA-reportable complaints; legal team handles complaints with litigation potential.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingDisputeAmountUsd rdf:type rdf:Property ;
    rdfs:label 'Billing Dispute Amount Usd' ;
    rdfs:comment 'Dollar amount in dispute for billing-related complaints. Populated only when complaint_type is billing_dispute. Used for accounts receivable (AR) adjustment tracking and revenue impact analysis.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:closedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Closed Timestamp' ;
    rdfs:comment 'Date and time when the complaint was formally closed after customer confirmation or timeout period. Distinct from resolved_timestamp as closure may follow resolution after a customer satisfaction confirmation window.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:complaintDescription rdf:type rdf:Property ;
    rdfs:label 'Complaint Description' ;
    rdfs:comment 'Free-text narrative describing the complaint in detail as reported by the customer or regulatory agency. Captures the full context of the issue including specific circumstances, locations, and impacts.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintNumber rdf:type rdf:Property ;
    rdfs:label 'Complaint Number' ;
    rdfs:comment 'Externally visible, human-readable complaint reference number communicated to the customer and used in regulatory correspondence. Format: CMP-YYYY-NNNNNNN.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintSource rdf:type rdf:Property ;
    rdfs:label 'Complaint Source' ;
    rdfs:comment 'Channel or origination point through which the complaint was received. Regulatory agency source indicates complaints filed directly by EPA, OSHA, DOT, or state environmental bodies requiring mandatory response timelines.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintStatus rdf:type rdf:Property ;
    rdfs:label 'Complaint Status' ;
    rdfs:comment 'Current workflow lifecycle state of the complaint from initial receipt through resolution and closure. Drives SLA tracking and operational dashboards.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintType rdf:type rdf:Property ;
    rdfs:label 'Complaint Type' ;
    rdfs:comment 'Primary classification of the complaint subject matter. Missed pickup covers scheduled collection failures; billing dispute covers invoice or charge disagreements; driver behavior covers conduct or safety concerns; odor/noise covers nuisance impacts; environmental concern covers spills, leachate, or regulatory issues; container damage covers physical damage to customer containers.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditAmountUsd rdf:type rdf:Property ;
    rdfs:label 'Credit Amount Usd' ;
    rdfs:comment 'Dollar value of the billing or service credit issued to the customer as resolution for the complaint. Populated only when credit_issued_flag is true. Feeds into revenue management and EBITDA impact reporting.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditIssuedFlag rdf:type rdf:Property ;
    rdfs:label 'Credit Issued Flag' ;
    rdfs:comment 'Indicates whether a billing credit or service credit was issued to the customer as part of the complaint resolution. Supports accounts receivable (AR) adjustment tracking and revenue impact reporting.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:firstResponseTimestamp rdf:type rdf:Property ;
    rdfs:label 'First Response Timestamp' ;
    rdfs:comment 'Date and time when the customer received the first substantive response to their complaint. Used to calculate first response time against SLA targets and regulatory response obligations.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:incidentDate rdf:type rdf:Property ;
    rdfs:label 'Incident Date' ;
    rdfs:comment 'Calendar date on which the underlying service failure or incident that prompted the complaint actually occurred. May differ from received_timestamp if the customer reported the issue after the fact.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Legal Hold Flag' ;
    rdfs:comment 'Indicates whether this complaint record is subject to a legal hold, preventing deletion or modification of associated records. Set when litigation is threatened or initiated.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Received Timestamp' ;
    rdfs:comment 'Date and time when the complaint was formally received and logged in the system. This is the principal business event timestamp used as the SLA clock start for all response time calculations.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:regulatoryAgency rdf:type rdf:Property ;
    rdfs:label 'Regulatory Agency' ;
    rdfs:comment 'Identifies the specific regulatory body involved when regulatory_escalation_flag is true. Determines applicable response timelines, reporting formats, and compliance obligations. LEA (Local Enforcement Agency) complaints are captured under local_enforcement. [ENUM-REF-CANDIDATE: EPA|OSHA|DOT|state_env_agency|local_enforcement|CERCLA|none — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryEscalationFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Escalation Flag' ;
    rdfs:comment 'Indicates whether this complaint requires mandatory reporting or response to a regulatory body (EPA, OSHA, DOT, state environmental agency). When true, triggers regulatory response workflow with statutory deadlines.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reference Number' ;
    rdfs:comment 'External case or docket number assigned by the regulatory agency (EPA, OSHA, DOT) for tracking the complaint in their system. Required for regulatory correspondence and compliance documentation.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repeatComplaintFlag rdf:type rdf:Property ;
    rdfs:label 'Repeat Complaint Flag' ;
    rdfs:comment 'Indicates whether this complaint is a recurrence of a previously filed complaint for the same customer and same issue type within a rolling 90-day window. Repeat complaints trigger enhanced resolution workflows and root cause analysis requirements.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resolutionAction rdf:type rdf:Property ;
    rdfs:label 'Resolution Action' ;
    rdfs:comment 'Free-text description of the corrective action taken to resolve the complaint, such as re-collection dispatched, billing credit issued, driver counseling completed, or environmental remediation performed.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionOutcome rdf:type rdf:Property ;
    rdfs:label 'Resolution Outcome' ;
    rdfs:comment 'Final outcome classification of the complaint resolution. Resolved_accepted means customer confirmed satisfaction; resolved_rejected means customer disputed the resolution; referred_to_regulatory means the complaint was escalated to an external regulatory body for adjudication.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Resolved Timestamp' ;
    rdfs:comment 'Date and time when the complaint was marked as resolved, meaning the root cause was addressed and corrective action completed. Used to calculate total resolution time against SLA targets.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rootCauseCode rdf:type rdf:Property ;
    rdfs:label 'Root Cause Code' ;
    rdfs:comment 'Standardized code identifying the underlying operational or systemic cause of the complaint (e.g., driver_error, route_planning_failure, equipment_malfunction, billing_system_error, weather_delay, container_overfill). Used for operational quality improvement and recurring issue analysis. [ENUM-REF-CANDIDATE: driver_error|route_planning_failure|equipment_malfunction|billing_system_error|weather_delay|container_overfill|access_obstruction|contamination|permit_violation|staffing_shortage — promote to reference product]' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesforceCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Salesforce Case Number' ;
    rdfs:comment 'External system identifier for this complaint record in Salesforce CRM, enabling bidirectional synchronization and audit traceability between the data lakehouse and the operational CRM system.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severityLevel rdf:type rdf:Property ;
    rdfs:label 'Severity Level' ;
    rdfs:comment 'Operational severity rating assigned to the complaint indicating urgency and resource prioritization. Critical severity triggers immediate escalation workflows and may require regulatory notification.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaResolutionDueTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sla Resolution Due Timestamp' ;
    rdfs:comment 'Calculated deadline by which the complaint must be fully resolved and closed based on severity level and SLA tier. Distinct from response due timestamp which only covers initial acknowledgment.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:slaResponseDueTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sla Response Due Timestamp' ;
    rdfs:comment 'Calculated deadline by which the complaint must receive an initial response based on severity level and SLA tier. Regulatory complaints have statutory response deadlines that override standard SLA tiers.' ;
    rdfs:domain ind:Complaint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:subtype rdf:type rdf:Property ;
    rdfs:label 'Subtype' ;
    rdfs:comment 'Secondary classification providing granular detail within the complaint type (e.g., under missed_pickup: residential_route_skip, commercial_container_not_serviced; under billing_dispute: incorrect_tipping_fee, unauthorized_surcharge). [ENUM-REF-CANDIDATE: route_skip|container_not_serviced|incorrect_tipping_fee|unauthorized_surcharge|spill_incident|property_damage|aggressive_driving|noise_violation|odor_complaint|hazmat_concern — promote to reference product]' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cellId rdf:type rdf:Property ;
    rdfs:label 'Cell Id' ;
    rdfs:comment 'Foreign key linking to landfill.cell. Business justification: Work orders for cell-specific repairs (liner patches, gas collection pipe repairs, leachate pump replacements) must reference the specific cell for airspace accounting, regulatory reporting, and closu' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Cell .

ind:failureModeId rdf:type rdf:Property ;
    rdfs:label 'Failure Mode Id' ;
    rdfs:comment 'Foreign key linking to maintenance.failure_mode. Business justification: work_order currently stores failure_code (STRING) and failure_description (STRING) as denormalized free-text fields. The failure_mode table is the authoritative catalog with failure_code and failure_d' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FailureMode .

ind:serviceOfferingId rdf:type rdf:Property ;
    rdfs:label 'Service Offering Id' ;
    rdfs:comment 'Foreign key linking to service.offering. Business justification: Work orders for service equipment (compactors, balers, containers) are tracked against service offerings for cost allocation, warranty claims, and SLA compliance. Real WM operations require linking ma' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Offering .

ind:siteContactId rdf:type rdf:Property ;
    rdfs:label 'Site Contact Id' ;
    rdfs:comment 'Foreign key linking to customer.contact. Business justification: Work order dispatch requires a site contact (e.g., facility manager, service contact) for technician coordination, access instructions, and completion sign-off. Role-prefixed \'site_contact_id\' disting' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:typeId rdf:type rdf:Property ;
    rdfs:label 'Type Id' ;
    rdfs:comment 'Foreign key linking to maintenance.maintenance_type. Business justification: Work orders should be classified by standardized maintenance type for consistent categorization, cost allocation, and regulatory reporting. Currently has wo_type (STRING) which should reference mainte' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Type .

ind:warrantyId rdf:type rdf:Property ;
    rdfs:label 'Warranty Id' ;
    rdfs:comment 'Foreign key linking to asset.warranty. Business justification: Warranty claim management: work_order has warranty_claim_flag but no FK to the specific warranty record. When a WO triggers a warranty claim, maintenance teams must reference the warranty to validate ' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Warranty .

ind:actualCost rdf:type rdf:Property ;
    rdfs:label 'Actual Cost' ;
    rdfs:comment 'Total actual cost incurred for the work order upon completion, including actual labor, parts consumed, and external contractor charges in USD. Posted to the SAP FI/CO cost center. Used for EBITDA reporting, maintenance budget variance, and asset lifecycle cost analysis.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual End Timestamp' ;
    rdfs:comment 'Actual date and time when the maintenance work was completed and the asset was returned to service. Used to calculate actual labor duration, downtime, and mean time to repair (MTTR) metrics.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualLaborHours rdf:type rdf:Property ;
    rdfs:label 'Actual Labor Hours' ;
    rdfs:comment 'Actual number of labor hours expended by technicians to complete the work order. Captured from time confirmations in SAP PM or Infor EAM. Used for labor cost calculation, productivity analysis, and maintenance KPI reporting.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Start Timestamp' ;
    rdfs:comment 'Actual date and time when the technician began executing the work order. Used to calculate schedule adherence, labor hours, and downtime duration. Compared against scheduled_start_date for KPI reporting.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assetMeterReading rdf:type rdf:Property ;
    rdfs:label 'Asset Meter Reading' ;
    rdfs:comment 'Odometer (miles) or engine hours reading of the asset at the time the work order was executed. Used to track PM intervals (e.g., oil change every 5,000 miles), calculate mean time between failures (MTBF), and validate DOT inspection compliance.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:correctiveAction rdf:type rdf:Property ;
    rdfs:label 'Corrective Action' ;
    rdfs:comment 'Free-text description of the repair, adjustment, or corrective action performed by the technician to resolve the failure. Captured at work order completion. Required for DOT inspection records and OSHA incident documentation.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dotInspectionFlag rdf:type rdf:Property ;
    rdfs:label 'Dot Inspection Flag' ;
    rdfs:comment 'Indicates whether this work order is associated with or fulfills a DOT vehicle inspection requirement under 49 CFR Part 396. When True, the work order record serves as part of the DOT inspection documentation and must be retained per regulatory retention schedules.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dotInspectionType rdf:type rdf:Property ;
    rdfs:label 'Dot Inspection Type' ;
    rdfs:comment 'Type of DOT inspection associated with this work order, if applicable. Annual = federally mandated annual vehicle inspection; Pre_Trip = driver pre-trip inspection defect repair; Post_Trip = post-trip defect repair; Roadside = repair following roadside enforcement inspection; None = not a DOT inspection work order.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downtimeEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Downtime End Timestamp' ;
    rdfs:comment 'Timestamp when the asset was returned to operational service following maintenance completion. Used with downtime_start_timestamp to calculate total asset downtime duration for fleet availability reporting.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:downtimeStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Downtime Start Timestamp' ;
    rdfs:comment 'Timestamp when the asset was taken out of service due to the maintenance event. May precede actual_start_timestamp if the asset was grounded before a technician was assigned. Critical for fleet availability and route impact analysis.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:estimatedCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Cost' ;
    rdfs:comment 'Total estimated cost of the work order at time of creation, including planned labor, parts, and external services in USD. Used for budget planning, purchase order approval thresholds, and maintenance cost forecasting.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedLaborHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Labor Hours' ;
    rdfs:comment 'Planned number of labor hours required to complete the work order, as estimated at time of creation. Used for workforce scheduling, capacity planning, and cost estimation. Compared against actual_labor_hours for variance analysis.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:externalServiceCost rdf:type rdf:Property ;
    rdfs:label 'External Service Cost' ;
    rdfs:comment 'Cost of external contractor or vendor services engaged to complete or support the work order in USD. Linked to purchase orders (PO) in SAP MM. Relevant for outsourced repairs, specialized inspections, and warranty work.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lotoCleared rdf:type rdf:Property ;
    rdfs:label 'Loto Cleared' ;
    rdfs:comment 'Indicates whether the required LOTO energy isolation procedure has been completed and verified prior to work commencement. Must be True before work begins on LOTO-required work orders. Supports OSHA compliance audit trails.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lotoRequired rdf:type rdf:Property ;
    rdfs:label 'Loto Required' ;
    rdfs:comment 'Indicates whether Lockout/Tagout (LOTO) energy isolation procedures are required before executing this work order. Mandatory safety clearance flag per OSHA 29 CFR 1910.147 for work on equipment with hazardous energy sources (hydraulics, electrical, pneumatic).' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:meterUnit rdf:type rdf:Property ;
    rdfs:label 'Meter Unit' ;
    rdfs:comment 'Unit of measure for the asset_meter_reading field. Miles or kilometers for vehicle odometers; hours for engine hour meters; cycles for equipment with cycle-based PM intervals.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originatingSystem rdf:type rdf:Property ;
    rdfs:label 'Originating System' ;
    rdfs:comment 'Source system that created and owns this work order record. Determines the authoritative system of record for reconciliation. SAP_PM indicates SAP S/4HANA Plant Maintenance module; INFOR_EAM indicates Infor Enterprise Asset Management.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partsCost rdf:type rdf:Property ;
    rdfs:label 'Parts Cost' ;
    rdfs:comment 'Actual cost of spare parts and materials consumed during work order execution in USD. Sourced from SAP MM goods issue or Infor EAM parts transactions. Enables parts vs. labor cost split analysis for maintenance optimization.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:poNumber rdf:type rdf:Property ;
    rdfs:label 'Po Number' ;
    rdfs:comment 'Purchase order number from SAP MM associated with external services or parts procurement for this work order. Links maintenance execution to the procurement process for AP matching and spend management.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priority rdf:type rdf:Property ;
    rdfs:label 'Priority' ;
    rdfs:comment 'Business priority level assigned to the work order, driving scheduling urgency and resource allocation. Critical = immediate safety or regulatory risk (e.g., brake failure, DOT out-of-service condition); High = significant operational impact; Medium = moderate impact; Low = minor issue; Routine = standard PM cycle.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Flag' ;
    rdfs:comment 'Indicates whether this work order is required to satisfy a regulatory compliance obligation beyond DOT (e.g., EPA equipment inspection, OSHA mandated maintenance, RCRA hazardous waste equipment certification, Clean Air Act emission control maintenance). Triggers enhanced documentation and retention requirements.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requestedDate rdf:type rdf:Property ;
    rdfs:label 'Requested Date' ;
    rdfs:comment 'The business event date on which the maintenance need was identified and the work order was formally requested. Represents the BUSINESS_EVENT_TIMESTAMP canonical category. Distinct from created_timestamp (system entry time) — captures the real-world trigger date for SLA and compliance measurement.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rootCause rdf:type rdf:Property ;
    rdfs:label 'Root Cause' ;
    rdfs:comment 'Technician-documented root cause of the failure or maintenance need, captured upon work order completion. Supports reliability-centered maintenance (RCM) analysis, repeat failure prevention, and regulatory reporting for DOT and OSHA incidents.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledEndDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Date' ;
    rdfs:comment 'Planned date on which the maintenance work is expected to be completed. Used for fleet availability commitments, route planning coordination, and maintenance window management.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledStartDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Date' ;
    rdfs:comment 'Planned date on which the maintenance work is scheduled to begin. Used for workforce scheduling, parts pre-staging, and fleet availability planning. May differ from actual_start_date if work is rescheduled.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceSystemWoReference rdf:type rdf:Property ;
    rdfs:label 'Source System Wo Reference' ;
    rdfs:comment 'Native primary key or internal identifier of this work order in the originating system (SAP PM order number or Infor EAM internal WO ID). Enables bidirectional traceability between the lakehouse Silver layer and the operational system of record.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyClaimFlag rdf:type rdf:Property ;
    rdfs:label 'Warranty Claim Flag' ;
    rdfs:comment 'Indicates whether the repair or parts replacement on this work order is eligible for or has been submitted as a warranty claim to the OEM or parts supplier. When True, actual_cost may be partially or fully recovered. Supports warranty recovery tracking and vendor management.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:woNumber rdf:type rdf:Property ;
    rdfs:label 'Wo Number' ;
    rdfs:comment 'Externally-known, human-readable work order number assigned by the originating system (SAP PM or Infor EAM). Used for cross-system reference, technician communication, and regulatory documentation such as DOT inspection records.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:woStatus rdf:type rdf:Property ;
    rdfs:label 'Wo Status' ;
    rdfs:comment 'Current lifecycle state of the work order. Open = created but not started; In_Progress = technician actively working; On_Hold = paused pending approval or resources; Pending_Parts = awaiting parts from inventory; Completed = work finished, pending closure review; Closed = fully closed and costed; Cancelled = voided without execution. [ENUM-REF-CANDIDATE: open|in_progress|on_hold|pending_parts|completed|closed|cancelled — promote to reference product]' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionPointId rdf:type rdf:Property ;
    rdfs:label 'Collection Point Id' ;
    rdfs:comment 'Foreign key linking to landfill.collection_point. Business justification: PM schedules for leachate collection points (pump inspection, flow meter calibration, pipe inspection) are required under disposal permits. Scheduling must reference the specific collection point infr' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CollectionPoint .

ind:groundwaterMonitoringWellId rdf:type rdf:Property ;
    rdfs:label 'Groundwater Monitoring Well Id' ;
    rdfs:comment 'Foreign key linking to landfill.groundwater_monitoring_well. Business justification: PM schedules for groundwater monitoring wells (pump maintenance, sensor calibration, well development) are required under RCRA and state permits. Scheduling must reference the specific well. No curren' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GroundwaterMonitoringWell .

ind:inspectionChecklistId rdf:type rdf:Property ;
    rdfs:label 'Inspection Checklist Id' ;
    rdfs:comment 'Foreign key linking to asset.inspection_checklist. Business justification: PM-driven inspection compliance: pm_schedule has is_dot_inspection, is_epa_required, is_osha_required flags but no FK to the checklist governing execution. Regulators (DOT, EPA, OSHA) require specific' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InspectionChecklist .

ind:lfgExtractionWellId rdf:type rdf:Property ;
    rdfs:label 'Lfg Extraction Well Id' ;
    rdfs:comment 'Foreign key linking to landfill.lfg_extraction_well. Business justification: PM schedules for LFG extraction wells (wellhead inspection, flow measurement calibration, condensate removal) are mandated under EPA NSPS and state air permits. Scheduling must reference the specific ' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LfgExtractionWell .

ind:monitoringPointId rdf:type rdf:Property ;
    rdfs:label 'Monitoring Point Id' ;
    rdfs:comment 'Foreign key linking to landfill.monitoring_point. Business justification: PM schedules for monitoring points (sensor calibration, equipment inspection at gas/groundwater monitoring stations) are required under EPA and state permit conditions. Scheduling must reference the s' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MonitoringPoint .

ind:assetCategory rdf:type rdf:Property ;
    rdfs:label 'Asset Category' ;
    rdfs:comment 'High-level category of the asset covered by this PM schedule. Determines applicable regulatory inspection requirements (e.g., DOT for fleet vehicles, EPA for landfill equipment). [ENUM-REF-CANDIDATE: fleet_vehicle|facility_equipment|container|transfer_station|landfill_equipment|mrf_equipment — promote to reference product]' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoWoGeneration rdf:type rdf:Property ;
    rdfs:label 'Auto Wo Generation' ;
    rdfs:comment 'Indicates whether work orders are automatically generated by the CMMS (Infor EAM or SAP PM) when the PM due date or meter threshold is reached. When false, a planner must manually release the work order. Supports both automated and manual scheduling workflows.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costCenterCode rdf:type rdf:Property ;
    rdfs:label 'Cost Center Code' ;
    rdfs:comment 'SAP FI/CO cost center code to which maintenance costs for this PM schedule are allocated. Enables financial reporting of maintenance expenditure by business unit, region, or asset class. Sourced from SAP S/4HANA FI/CO module.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveDate rdf:type rdf:Property ;
    rdfs:label 'Effective Date' ;
    rdfs:comment 'Date from which this PM schedule becomes active and begins generating work orders. Allows future-dated PM plans to be configured in advance (e.g., when a new asset is commissioned or a regulatory requirement takes effect).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:estimatedDurationHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Duration Hours' ;
    rdfs:comment 'Estimated number of labor hours required to complete the PM task. Used for technician scheduling, crew capacity planning, and asset downtime forecasting. Sourced from the task list standard times in Infor EAM or SAP PM.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedLaborCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Labor Cost' ;
    rdfs:comment 'Estimated labor cost to complete one cycle of this PM task, in US dollars. Calculated from estimated_duration_hours multiplied by the applicable technician labor rate. Used for maintenance budget planning and COGS allocation.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedPartsCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Parts Cost' ;
    rdfs:comment 'Estimated cost of parts and materials required to complete one cycle of this PM task, in US dollars. Sourced from the Bill of Materials (BOM) associated with the task list. Used for maintenance budget planning and cost forecasting.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expiryDate rdf:type rdf:Property ;
    rdfs:label 'Expiry Date' ;
    rdfs:comment 'Date after which this PM schedule is no longer active and will not generate new work orders. Applicable for temporary PM plans, asset disposal schedules, or time-limited regulatory inspection programs. Null for open-ended schedules.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:frequencyInterval rdf:type rdf:Property ;
    rdfs:label 'Frequency Interval' ;
    rdfs:comment 'Numeric value representing how often the PM task recurs, interpreted in conjunction with frequency_unit. For example, a value of 90 with frequency_unit of \'days\' means every 90 days. For meter-based plans, this is the meter increment (e.g., 5000 miles).' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:frequencyUnit rdf:type rdf:Property ;
    rdfs:label 'Frequency Unit' ;
    rdfs:comment 'Unit of measure for the frequency_interval. Defines whether the PM cycle is driven by elapsed time (days, weeks, months) or asset utilization meters (miles, engine_hours, operating_hours). Critical for calculating next due date or meter reading.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalLocationCode rdf:type rdf:Property ;
    rdfs:label 'Functional Location Code' ;
    rdfs:comment 'SAP PM or Infor EAM functional location code identifying the physical installation point or system hierarchy node where the asset is installed (e.g., fleet depot bay, landfill pump station). Supports hierarchical maintenance reporting.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDotInspection rdf:type rdf:Property ;
    rdfs:label 'Is Dot Inspection' ;
    rdfs:comment 'Indicates whether this PM schedule represents a federally mandated Department of Transportation (DOT) vehicle inspection cycle (e.g., annual inspection per 49 CFR Part 396.17). When true, completion records are subject to DOT recordkeeping requirements and regulatory audit.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isEpaRequired rdf:type rdf:Property ;
    rdfs:label 'Is Epa Required' ;
    rdfs:comment 'Indicates whether this PM schedule is mandated by EPA environmental regulations (e.g., landfill gas (LFG) collection system inspections, leachate system checks, or CNG fueling station inspections). When true, records are subject to EPA reporting requirements.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOshaRequired rdf:type rdf:Property ;
    rdfs:label 'Is Osha Required' ;
    rdfs:comment 'Indicates whether this PM schedule is mandated by OSHA regulations (e.g., crane inspections per 29 CFR 1910.179, powered industrial truck inspections per 29 CFR 1910.178). When true, records must be retained per OSHA recordkeeping requirements.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastPerformedDate rdf:type rdf:Property ;
    rdfs:label 'Last Performed Date' ;
    rdfs:comment 'Calendar date on which the most recent PM task was completed for this schedule. Used as the baseline for calculating the next due date for time-based plans. Populated from work order completion records in Infor EAM or SAP PM.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastPerformedMeterReading rdf:type rdf:Property ;
    rdfs:label 'Last Performed Meter Reading' ;
    rdfs:comment 'Odometer (miles) or engine hour meter reading recorded at the time the most recent PM was completed. Used as the baseline for calculating the next due meter reading for meter-based plans. Sourced from Geotab Fleet Telematics or Infor EAM meter readings.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Lead Time Days' ;
    rdfs:comment 'Number of days before the next_due_date that a work order should be automatically generated to allow for parts procurement, technician scheduling, and asset availability planning. Ensures PM tasks are not missed due to resource constraints.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Due Date' ;
    rdfs:comment 'Calculated calendar date by which the next PM task must be completed. For time-based plans, derived from last_performed_date plus frequency_interval. Drives work order generation and maintenance scheduling. Critical for DOT compliance tracking.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextDueMeterReading rdf:type rdf:Property ;
    rdfs:label 'Next Due Meter Reading' ;
    rdfs:comment 'Calculated odometer or engine hour meter value at which the next PM task must be performed. For meter-based plans, derived from last_performed_meter_reading plus frequency_interval. Null for time-based plans.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planName rdf:type rdf:Property ;
    rdfs:label 'Plan Name' ;
    rdfs:comment 'Human-readable descriptive name of the PM schedule plan (e.g., \'Annual DOT Brake Inspection – Class 8 Trucks\', \'Monthly Compactor Hydraulic Service\'). Used for display and reporting.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planNumber rdf:type rdf:Property ;
    rdfs:label 'Plan Number' ;
    rdfs:comment 'Externally-known alphanumeric identifier for the PM plan as assigned in Infor EAM or SAP PM. Used for cross-system reference and audit trail. Format: PM- followed by 4-20 alphanumeric characters.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionDate rdf:type rdf:Property ;
    rdfs:label 'Revision Date' ;
    rdfs:comment 'Date on which the most recent revision to this PM schedule was approved and applied. Used in conjunction with revision_number for change history tracking and regulatory audit documentation.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revisionNumber rdf:type rdf:Property ;
    rdfs:label 'Revision Number' ;
    rdfs:comment 'Sequential revision counter incremented each time the PM schedule definition is modified (e.g., frequency change, task list update, regulatory requirement change). Supports change management and audit trail for compliance purposes.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scheduleStatus rdf:type rdf:Property ;
    rdfs:label 'Schedule Status' ;
    rdfs:comment 'Current lifecycle status of the PM schedule record. Active schedules generate work orders on due dates. Suspended schedules are temporarily paused (e.g., asset out of service). Archived schedules are retained for historical reference.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemPlanReference rdf:type rdf:Property ;
    rdfs:label 'Source System Plan Reference' ;
    rdfs:comment 'Native identifier of this PM plan record in the originating source system (Infor EAM plan number or SAP PM maintenance plan number). Enables traceability and reconciliation between the lakehouse Silver layer and the operational system of record.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicianRole rdf:type rdf:Property ;
    rdfs:label 'Technician Role' ;
    rdfs:comment 'Skill or trade classification required to perform this PM task. Used for workforce planning and technician qualification matching. Examples include mechanic for engine service, electrician for CNG system checks, or inspector for DOT annual inspections. [ENUM-REF-CANDIDATE: mechanic|electrician|hydraulic_tech|tire_tech|inspector|welder|general_tech — promote to reference product]' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:toleranceDays rdf:type rdf:Property ;
    rdfs:label 'Tolerance Days' ;
    rdfs:comment 'Allowable number of days before or after the next_due_date within which the PM task can be completed without being flagged as overdue. Provides scheduling flexibility while maintaining compliance. Negative values indicate early completion tolerance.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:toleranceMeterUnits rdf:type rdf:Property ;
    rdfs:label 'Tolerance Meter Units' ;
    rdfs:comment 'Allowable meter reading variance (miles or engine hours) above or below the next_due_meter_reading within which the PM task can be completed without being flagged as overdue. Applicable only to meter-based PM plans. Null for time-based plans.' ;
    rdfs:domain ind:PmSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workOrderType rdf:type rdf:Property ;
    rdfs:label 'Work Order Type' ;
    rdfs:comment 'Type of work order that will be generated when this PM schedule triggers. Aligns with SAP PM order types and Infor EAM work order categories. PM is standard preventive maintenance, inspection is a check-only task, lubrication is a fluid service, calibration is for measurement equipment, and overhaul is a major rebuild.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:woTaskId rdf:type rdf:Property ;
    rdfs:label 'Wo Task Id' ;
    rdfs:comment 'Unique system-generated identifier for an individual task line within a work order. Serves as the primary key for the wo_task entity in the Infor EAM / SAP PM integrated maintenance execution workflow.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WoTask .

ind:inspectionFindingId rdf:type rdf:Property ;
    rdfs:label 'Inspection Finding Id' ;
    rdfs:comment 'Foreign key linking to compliance.inspection_finding. Business justification: Work order tasks are created to remediate specific inspection findings. Linking tasks to findings enables tracking of finding-level remediation progress, supports regulatory verification that each cit' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InspectionFinding .

ind:invoiceLineId rdf:type rdf:Property ;
    rdfs:label 'Invoice Line Id' ;
    rdfs:comment 'Foreign key linking to billing.invoice_line. Business justification: Time-and-materials contract billing: on T&M maintenance contracts, individual work order tasks (labor, inspection steps) are billed as separate invoice line items. Waste Management contract billing re' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InvoiceLine .

ind:permitConditionId rdf:type rdf:Property ;
    rdfs:label 'Permit Condition Id' ;
    rdfs:comment 'Foreign key linking to compliance.permit_condition. Business justification: Individual maintenance tasks satisfy specific permit conditions (e.g., verifying leachate pump operation satisfies a specific permit condition limit). Task-level permit condition linkage enables granu' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PermitCondition .

ind:primaryWorkOrderId rdf:type rdf:Property ;
    rdfs:label 'Primary Work Order Id' ;
    rdfs:comment 'Reference to the parent work order header that this task belongs to. Establishes the header-detail relationship between the work order and its constituent task steps.' ;
    rdfs:domain ind:WoTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkOrder .

ind:actualCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Timestamp' ;
    rdfs:comment 'Date and time when the technician marked this task as complete. Triggers downstream WO completion logic and asset return-to-service workflows. Critical for downtime duration and Mean Time to Repair (MTTR) calculations.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualLaborCost rdf:type rdf:Property ;
    rdfs:label 'Actual Labor Cost' ;
    rdfs:comment 'Actual labor cost incurred for this task based on actual hours worked and the technician\'s labor rate. Feeds into work order total cost and asset maintenance cost reporting in SAP FI/CO.' ;
    rdfs:domain ind:WoTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualPartsCost rdf:type rdf:Property ;
    rdfs:label 'Actual Parts Cost' ;
    rdfs:comment 'Actual cost of parts and materials consumed during task execution, recorded upon parts issuance from inventory. Used for work order cost variance analysis and asset lifecycle cost tracking.' ;
    rdfs:domain ind:WoTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:defectDescription rdf:type rdf:Property ;
    rdfs:label 'Defect Description' ;
    rdfs:comment 'Narrative description of any defect, fault, or abnormal condition discovered during task execution. Populated by the technician and used to initiate corrective work orders, parts procurement, and safety incident reporting.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectFoundFlag rdf:type rdf:Property ;
    rdfs:label 'Defect Found Flag' ;
    rdfs:comment 'Indicates whether a defect, fault, or out-of-tolerance condition was identified during execution of this task. Triggers corrective action workflow and defect documentation in Infor EAM and Enviance EHS.' ;
    rdfs:domain ind:WoTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:downtimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Downtime Minutes' ;
    rdfs:comment 'Total minutes the asset was taken out of service specifically for this task. Contributes to overall work order downtime and feeds fleet availability and Mean Time to Repair (MTTR) calculations. Distinct from labor hours as it includes wait time for parts or approvals.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Updated Timestamp' ;
    rdfs:comment 'Date and time when this task record was most recently modified, including status changes, labor hour updates, or technician note additions. Supports data lineage tracking and change audit requirements in the Databricks Silver Layer.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lotoRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Loto Required Flag' ;
    rdfs:comment 'Indicates whether Lockout/Tagout (LOTO) energy isolation procedures are required before performing this task, per OSHA 29 CFR 1910.147. Enforces hazardous energy control compliance for tasks involving electrical, hydraulic, or pneumatic systems.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:meterReadingAtTask rdf:type rdf:Property ;
    rdfs:label 'Meter Reading At Task' ;
    rdfs:comment 'Odometer (miles) or engine hours reading recorded at the time this task was performed. Critical for mileage-based and hour-based PM interval tracking, DOT inspection records, and asset lifecycle management in Infor EAM.' ;
    rdfs:domain ind:WoTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partsRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Parts Required Flag' ;
    rdfs:comment 'Indicates whether this task requires one or more parts or materials from inventory to be completed. Drives parts reservation workflow in Infor EAM and SAP MM materials management integration.' ;
    rdfs:domain ind:WoTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ppeRequirements rdf:type rdf:Property ;
    rdfs:label 'Ppe Requirements' ;
    rdfs:comment 'Comma-delimited list of required Personal Protective Equipment (PPE) items for this task (e.g., \'safety_glasses,gloves,steel_toe_boots,hearing_protection\'). Sourced from the EHS system and enforced per OSHA 29 CFR 1910.132 standards.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityCode rdf:type rdf:Property ;
    rdfs:label 'Priority Code' ;
    rdfs:comment 'Priority level assigned to this task, which may differ from the parent work order priority if specific steps are more time-critical (e.g., a safety-critical brake inspection step within a broader PM work order). Drives technician scheduling and dispatch sequencing.' ;
    rdfs:domain ind:WoTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredCertification rdf:type rdf:Property ;
    rdfs:label 'Required Certification' ;
    rdfs:comment 'Specific regulatory or industry certification required to perform this task (e.g., CDL for vehicle brake inspection, ASE for engine diagnostics, DOT_INSPECTOR for federal vehicle inspection). Enforces compliance with DOT 49 CFR Part 396 and OSHA standards. [ENUM-REF-CANDIDATE: CDL|ASE|DOT_INSPECTOR|HAZMAT|OSHA_30|FORKLIFT|NONE|EPA_608|RCRA_HAZWASTE — promote to reference product]' ;
    rdfs:domain ind:WoTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredSkillCode rdf:type rdf:Property ;
    rdfs:label 'Required Skill Code' ;
    rdfs:comment 'Code identifying the minimum skill or trade qualification required to perform this task (e.g., \'MECH-DIESEL\', \'ELEC-HV\', \'HVAC-CERT\'). Used for technician assignment validation and workforce capability gap analysis.' ;
    rdfs:domain ind:WoTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyInstructions rdf:type rdf:Property ;
    rdfs:label 'Safety Instructions' ;
    rdfs:comment 'Mandatory safety procedures, lockout/tagout (LOTO) requirements, Personal Protective Equipment (PPE) specifications, and hazard warnings that must be followed before and during task execution. Sourced from EHS system and linked to OSHA compliance requirements.' ;
    rdfs:domain ind:WoTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Timestamp' ;
    rdfs:comment 'Planned date and time when the technician is scheduled to begin this task. Used for maintenance scheduling, shift planning, and asset downtime window management.' ;
    rdfs:domain ind:WoTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:skipReason rdf:type rdf:Property ;
    rdfs:label 'Skip Reason' ;
    rdfs:comment 'Reason code explaining why a task was skipped or bypassed in the work order execution. Required when task_status is \'skipped\' to maintain audit trail integrity and support PM compliance reporting. [ENUM-REF-CANDIDATE: not_applicable|deferred|parts_unavailable|asset_unavailable|safety_hold|supervisor_override|weather|other — promote to reference product]' ;
    rdfs:domain ind:WoTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardTaskCode rdf:type rdf:Property ;
    rdfs:label 'Standard Task Code' ;
    rdfs:comment 'Reference code linking this task to a standardized maintenance task template in the CMMS library (e.g., \'HYD-INSP-001\' for hydraulic inspection). Enables consistent task definition, labor estimation benchmarking, and cross-fleet maintenance analytics.' ;
    rdfs:domain ind:WoTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskDescription rdf:type rdf:Property ;
    rdfs:label 'Task Description' ;
    rdfs:comment 'Detailed narrative description of the maintenance task to be performed, including the specific action, component, and expected outcome (e.g., \'Inspect and replace hydraulic hose on compactor lift arm\'). Sourced from standard task library or entered by planner.' ;
    rdfs:domain ind:WoTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskNumber rdf:type rdf:Property ;
    rdfs:label 'Task Number' ;
    rdfs:comment 'Externally visible alphanumeric identifier for the task, typically formatted as the parent WO number suffixed with a task sequence (e.g., WO-2024-00123-T01). Used in technician communications, printed work packets, and audit trails.' ;
    rdfs:domain ind:WoTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskSequence rdf:type rdf:Property ;
    rdfs:label 'Task Sequence' ;
    rdfs:comment 'Numeric ordering of this task within the parent work order, defining the execution sequence of multi-step maintenance procedures (e.g., 10, 20, 30 in SAP PM operation numbering convention). Enables dependency management and step-by-step workflow tracking.' ;
    rdfs:domain ind:WoTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:taskStatus rdf:type rdf:Property ;
    rdfs:label 'Task Status' ;
    rdfs:comment 'Current lifecycle state of the maintenance task within the work order execution workflow. Drives technician dashboard visibility, WO completion logic, and downtime reporting. [ENUM-REF-CANDIDATE: pending|in_progress|complete|skipped|on_hold|cancelled — promote to reference product]' ;
    rdfs:domain ind:WoTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskType rdf:type rdf:Property ;
    rdfs:label 'Task Type' ;
    rdfs:comment 'Classification of the maintenance task by the nature of the work performed. Used for labor planning, parts forecasting, and maintenance cost categorization. [ENUM-REF-CANDIDATE: inspection|repair|replacement|lubrication|calibration|cleaning|adjustment|testing|documentation — promote to reference product]' ;
    rdfs:domain ind:WoTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicianNotes rdf:type rdf:Property ;
    rdfs:label 'Technician Notes' ;
    rdfs:comment 'Free-text field for the assigned technician to record observations, findings, deviations from standard procedure, or recommendations during task execution. Captured via Infor EAM mobile app and retained for maintenance history and knowledge management.' ;
    rdfs:domain ind:WoTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Verification Timestamp' ;
    rdfs:comment 'Date and time when the supervisor or quality inspector verified and approved the completed task. Establishes the regulatory sign-off timestamp for DOT inspection records and OSHA compliance documentation.' ;
    rdfs:domain ind:WoTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:partsUsageId rdf:type rdf:Property ;
    rdfs:label 'Parts Usage Id' ;
    rdfs:comment 'Unique surrogate identifier for each parts usage transaction record in the Silver Layer lakehouse. Primary key for this transactional line entity.' ;
    rdfs:domain ind:PartsUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bomId rdf:type rdf:Property ;
    rdfs:label 'Bom Id' ;
    rdfs:comment 'Foreign key linking to asset.bom. Business justification: BOM consumption tracking: parts_usage has bom_reference_number as a denormalized text field. Linking to asset.bom enables tracking which BOM line items are consumed during maintenance, supporting asse' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Bom .

ind:generatedWasteProfileId rdf:type rdf:Property ;
    rdfs:label 'Generated Waste Profile Id' ;
    rdfs:comment 'Foreign key linking to hazmat.waste_profile. Business justification: Hazardous parts replacement transactions must reference waste profiles for disposal tracking, manifest preparation, and cost allocation. Critical for tracking waste generation at the transaction level' ;
    rdfs:domain ind:PartsUsage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WasteProfile .

ind:partsCatalogId rdf:type rdf:Property ;
    rdfs:label 'Parts Catalog Id' ;
    rdfs:comment 'Reference to the parts catalog master record identifying the specific part or material consumed. Links to Bill of Materials (BOM) for traceability and reorder analysis.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PartsCatalog .

ind:storeroomId rdf:type rdf:Property ;
    rdfs:label 'Storeroom Id' ;
    rdfs:comment 'Reference to the issuing warehouse or storeroom from which the part was physically dispensed. Supports inventory location tracking and storeroom replenishment analysis.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Storeroom .

ind:assetType rdf:type rdf:Property ;
    rdfs:label 'Asset Type' ;
    rdfs:comment 'Broad classification of the asset category for which parts were consumed. Distinguishes fleet vehicles (trucks, loaders) from facility assets (compactors, conveyors) and containers for parts spend segmentation.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currencyCode rdf:type rdf:Property ;
    rdfs:label 'Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for all monetary amounts on this record (e.g., USD). Supports multi-currency operations for international or cross-border maintenance activities.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dotInspectionRelated rdf:type rdf:Property ;
    rdfs:label 'Dot Inspection Related' ;
    rdfs:comment 'Indicates whether the parts usage was associated with a DOT-required vehicle inspection or compliance repair. Supports regulatory reporting for DOT out-of-service violations and fleet compliance audits.' ;
    rdfs:domain ind:PartsUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:glAccountCode rdf:type rdf:Property ;
    rdfs:label 'Gl Account Code' ;
    rdfs:comment 'General Ledger account code used to post the parts cost in SAP FI. Determines whether the expense is capitalized (asset improvement) or expensed (maintenance COGS) per accounting policy.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsIssueNumber rdf:type rdf:Property ;
    rdfs:label 'Goods Issue Number' ;
    rdfs:comment 'SAP MM goods issue document number generated at the time of physical parts issuance from inventory. Provides cross-system traceability between Infor EAM work order and SAP MM inventory movement.' ;
    rdfs:domain ind:PartsUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatPartFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Part Flag' ;
    rdfs:comment 'Indicates whether the part or material is classified as hazardous (e.g., certain lubricants, solvents, refrigerants). Triggers special handling, storage, and disposal requirements per EPA and OSHA regulations.' ;
    rdfs:domain ind:PartsUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issueDate rdf:type rdf:Property ;
    rdfs:label 'Issue Date' ;
    rdfs:comment 'Calendar date on which the parts were physically issued from the storeroom to the work order. Used for inventory aging, consumption trend analysis, and maintenance scheduling alignment. Satisfies TRANSACTION_LINE LINE_VALUE_OR_RESULT date dimension.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:issueStatus rdf:type rdf:Property ;
    rdfs:label 'Issue Status' ;
    rdfs:comment 'Current lifecycle status of the parts issuance transaction. Tracks progression from initial request through reservation, physical issuance, and potential return. Satisfies TRANSACTION_LINE LINE_VALUE_OR_RESULT lifecycle state.' ;
    rdfs:domain ind:PartsUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issueTimestamp rdf:type rdf:Property ;
    rdfs:label 'Issue Timestamp' ;
    rdfs:comment 'Precise date and time when the parts were physically issued from the storeroom. Enables time-of-day analysis for storeroom operations and supports audit trail requirements. Satisfies TRANSACTION_HEADER BUSINESS_EVENT_TIMESTAMP category.' ;
    rdfs:domain ind:PartsUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lineNumber rdf:type rdf:Property ;
    rdfs:label 'Line Number' ;
    rdfs:comment 'Sequential line number ordering this parts usage record within the parent work order. Enables multi-part work orders to be reconstructed in original sequence. Satisfies TRANSACTION_LINE LINE_SEQUENCE category.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:manufacturerName rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Name' ;
    rdfs:comment 'Name of the original equipment manufacturer (OEM) or parts manufacturer. Used for vendor performance analysis, warranty tracking, and preferred supplier compliance.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturerPartNumber rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Part Number' ;
    rdfs:comment 'Original equipment manufacturer (OEM) part number as assigned by the manufacturer. Enables cross-referencing between internal catalog numbers and OEM catalogs for procurement and warranty claims.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partCategory rdf:type rdf:Property ;
    rdfs:label 'Part Category' ;
    rdfs:comment 'High-level classification of the part type used for spend analysis and inventory segmentation. [ENUM-REF-CANDIDATE: mechanical|electrical|hydraulic|pneumatic|body|consumable|lubricant|tire|safety|other — promote to reference product]' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partDescription rdf:type rdf:Property ;
    rdfs:label 'Part Description' ;
    rdfs:comment 'Human-readable description of the part or material consumed (e.g., \'Air Filter - Heavy Duty Diesel\', \'Hydraulic Pump Seal Kit\'). Supports reporting and technician communication.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partNumber rdf:type rdf:Property ;
    rdfs:label 'Part Number' ;
    rdfs:comment 'Manufacturer or internal catalog part number uniquely identifying the part or material. Used for procurement, cross-referencing with vendor catalogs, and BOM traceability.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityIssued rdf:type rdf:Property ;
    rdfs:label 'Quantity Issued' ;
    rdfs:comment 'Actual number of units physically dispensed from the storeroom to the work order. May differ from quantity requested due to partial availability or over-issuance. Satisfies TRANSACTION_LINE LINE_QUANTITY category.' ;
    rdfs:domain ind:PartsUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityRequested rdf:type rdf:Property ;
    rdfs:label 'Quantity Requested' ;
    rdfs:comment 'Number of units of the part originally requested by the technician or planner for the work order. Compared against quantity issued to identify fulfillment gaps and partial issuances.' ;
    rdfs:domain ind:PartsUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityReturned rdf:type rdf:Property ;
    rdfs:label 'Quantity Returned' ;
    rdfs:comment 'Number of units returned to the storeroom after work order completion because they were not consumed. Used to calculate net consumption and adjust inventory balances.' ;
    rdfs:domain ind:PartsUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reorderTriggeredFlag rdf:type rdf:Property ;
    rdfs:label 'Reorder Triggered Flag' ;
    rdfs:comment 'Indicates whether this parts issuance triggered an automatic reorder request because inventory fell below the minimum reorder point. Supports proactive inventory replenishment and prevents stockout-driven maintenance delays.' ;
    rdfs:domain ind:PartsUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reservationNumber rdf:type rdf:Property ;
    rdfs:label 'Reservation Number' ;
    rdfs:comment 'Externally-known reservation or pick ticket number generated when parts are reserved against a work order prior to physical issuance. Enables pre-staging and kitting of parts for planned maintenance. Satisfies TRANSACTION_HEADER BUSINESS_IDENTIFIER category.' ;
    rdfs:domain ind:PartsUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnDate rdf:type rdf:Property ;
    rdfs:label 'Return Date' ;
    rdfs:comment 'Date on which unused parts were returned to the storeroom after work order completion. Null if no parts were returned. Used to calculate net consumption and storeroom restocking timelines.' ;
    rdfs:domain ind:PartsUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Source Transaction Reference' ;
    rdfs:comment 'Native transaction identifier from the originating source system (Infor EAM parts issuance ID or SAP MM material document number). Enables cross-system reconciliation and audit trail back to the system of record.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCost rdf:type rdf:Property ;
    rdfs:label 'Total Cost' ;
    rdfs:comment 'Total cost of parts issued calculated as quantity issued minus quantity returned multiplied by unit cost. Represents the net parts spend charged to the work order for COGS allocation and maintenance budget tracking. Satisfies TRANSACTION_LINE LINE_VALUE_OR_RESULT monetary category.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionType rdf:type rdf:Property ;
    rdfs:label 'Transaction Type' ;
    rdfs:comment 'Classifies the nature of the parts movement: issue (parts dispensed to work order), return (unused parts returned to storeroom), transfer (moved between storerooms), or adjustment (inventory correction). Satisfies TRANSACTION_LINE LINE_VALUE_OR_RESULT discriminator.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitCost rdf:type rdf:Property ;
    rdfs:label 'Unit Cost' ;
    rdfs:comment 'Standard or moving average cost per unit of the part at the time of issuance, sourced from SAP MM material valuation. Used for COGS allocation and maintenance cost reporting.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Unit Of Measure' ;
    rdfs:comment 'Standard unit of measure for the part quantity (e.g., EA=Each, QT=Quart, GL=Gallon, LB=Pound, KG=Kilogram, FT=Feet, L=Liter). Aligns with SAP MM base unit of measure for inventory valuation consistency. [ENUM-REF-CANDIDATE: EA|QT|GL|LB|KG|FT|M|L|BOX|SET|KIT|PR — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repairHistoryId rdf:type rdf:Property ;
    rdfs:label 'Repair History Id' ;
    rdfs:comment 'Unique surrogate identifier for each closed/archived repair or maintenance event record in the repair history. Primary key for this data product.' ;
    rdfs:domain ind:RepairHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:downtimeEventId rdf:type rdf:Property ;
    rdfs:label 'Downtime Event Id' ;
    rdfs:comment 'Foreign key linking to maintenance.downtime_event. Business justification: repair_history and downtime_event are both children of work_order, but a direct link from repair_history to downtime_event establishes the causal chain: a downtime event triggers a repair, and the rep' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DowntimeEvent .

ind:assetNumber rdf:type rdf:Property ;
    rdfs:label 'Asset Number' ;
    rdfs:comment 'Externally-known asset tag or equipment number (e.g., fleet unit number, facility equipment tag) as assigned in Infor EAM or SAP PM. Enables direct lookup without requiring a join to the asset master.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Completion Timestamp' ;
    rdfs:comment 'Date and time when the repair or maintenance event was completed and the asset was returned to service. Used to calculate actual repair duration and Mean Time To Repair (MTTR). Distinct from the WO close date which may occur later during administrative closure.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:componentRepaired rdf:type rdf:Property ;
    rdfs:label 'Component Repaired' ;
    rdfs:comment 'Name or description of the specific component, sub-assembly, or system on the asset that was repaired or replaced (e.g., rear axle, hydraulic pump, compactor blade, engine air filter, brake caliper). Supports Bill of Materials (BOM) analysis and component-level MTBF tracking.' ;
    rdfs:domain ind:RepairHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dotInspectionNumber rdf:type rdf:Property ;
    rdfs:label 'Dot Inspection Number' ;
    rdfs:comment 'Official DOT inspection report number assigned by the inspecting authority for DOT-mandated inspections. Required for regulatory compliance documentation and FMCSA audit response. Populated only when is_dot_inspection is True.' ;
    rdfs:domain ind:RepairHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downtimeHours rdf:type rdf:Property ;
    rdfs:label 'Downtime Hours' ;
    rdfs:comment 'Total hours the asset was out of service (unavailable for operations) due to this repair event, from the time it was taken out of service to the time it was returned to active duty. Key input for fleet availability rate and operational impact assessment.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:engineHoursAtRepair rdf:type rdf:Property ;
    rdfs:label 'Engine Hours At Repair' ;
    rdfs:comment 'Engine hour meter reading recorded at the time of repair for hour-metered assets (compactors, generators, heavy equipment, Waste-to-Energy (WTE) plant equipment). Used for hour-based PM interval tracking and MTBF analysis where mileage is not applicable.' ;
    rdfs:domain ind:RepairHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isWarrantyClaim rdf:type rdf:Property ;
    rdfs:label 'Is Warranty Claim' ;
    rdfs:comment 'Indicates whether the repair costs are recoverable under an OEM or vendor warranty. When True, triggers the warranty recovery process and cost reclassification from maintenance expense to warranty receivable.' ;
    rdfs:domain ind:RepairHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laborCost rdf:type rdf:Property ;
    rdfs:label 'Labor Cost' ;
    rdfs:comment 'Total labor cost in US dollars for this repair event, calculated from technician hours and applicable labor rates. Component of total repair cost and lifecycle cost analysis. Confidential as it reflects internal labor rate structures.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laborHours rdf:type rdf:Property ;
    rdfs:label 'Labor Hours' ;
    rdfs:comment 'Total actual labor hours expended by all technicians on this repair event, as recorded in the CMMS time entry. Used for Mean Time To Repair (MTTR) calculation, technician productivity analysis, and labor cost allocation.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:odometerAtRepair rdf:type rdf:Property ;
    rdfs:label 'Odometer At Repair' ;
    rdfs:comment 'Odometer reading in miles recorded at the time of repair for wheeled fleet assets (trucks, ASL, FEL, REL vehicles). Used to calculate mileage-based Mean Time Between Failures (MTBF), establish PM trigger intervals, and support DOT inspection compliance records.' ;
    rdfs:domain ind:RepairHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:purchaseOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Number' ;
    rdfs:comment 'SAP Purchase Order (PO) number associated with external parts procurement or subcontractor services for this repair. Links the maintenance record to the Accounts Payable (AP) process for cost reconciliation.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repairDescription rdf:type rdf:Property ;
    rdfs:label 'Repair Description' ;
    rdfs:comment 'Free-text narrative describing the work performed, findings, corrective actions taken, and any relevant observations by the technician. Provides the detailed maintenance record for audit, warranty claims, and future diagnostic reference.' ;
    rdfs:domain ind:RepairHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repairStatus rdf:type rdf:Property ;
    rdfs:label 'Repair Status' ;
    rdfs:comment 'Lifecycle status of the repair history record. Completed indicates work was finished and verified; closed indicates the WO was formally archived; cancelled indicates the WO was voided; deferred indicates work was postponed and re-scheduled.' ;
    rdfs:domain ind:RepairHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repairType rdf:type rdf:Property ;
    rdfs:label 'Repair Type' ;
    rdfs:comment 'Classification of the maintenance event: corrective (reactive repair after failure), preventive (scheduled Preventive Maintenance (PM) cycle), predictive (condition-based), emergency (unplanned critical failure), or inspection (DOT/regulatory inspection). Drives MTBF and MTTR segmentation.' ;
    rdfs:domain ind:RepairHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportedDate rdf:type rdf:Property ;
    rdfs:label 'Reported Date' ;
    rdfs:comment 'Date the failure, defect, or maintenance need was first reported or identified, either by a driver vehicle inspection report (DVIR), operator, or automated telematics alert. Establishes the start of the repair lifecycle for Mean Time To Repair (MTTR) calculation.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rootCauseDescription rdf:type rdf:Property ;
    rdfs:label 'Root Cause Description' ;
    rdfs:comment 'Technician or engineer analysis of the underlying root cause of the failure or maintenance need (e.g., deferred maintenance, operator misuse, manufacturing defect, environmental exposure). Supports root cause analysis (RCA) and continuous improvement programs.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:startTimestamp rdf:type rdf:Property ;
    rdfs:label 'Start Timestamp' ;
    rdfs:comment 'Date and time when the technician physically began work on the asset. Used as the primary business event timestamp for Mean Time To Repair (MTTR) calculation and technician utilization analysis.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:subcontractorCost rdf:type rdf:Property ;
    rdfs:label 'Subcontractor Cost' ;
    rdfs:comment 'Cost in US dollars paid to external vendors or subcontractors for work performed on this repair event (e.g., specialized engine rebuilds, body shop work, OEM warranty repairs). Tracked separately from internal labor cost for make-vs-buy analysis.' ;
    rdfs:domain ind:RepairHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supervisorApprovedBy rdf:type rdf:Property ;
    rdfs:label 'Supervisor Approved By' ;
    rdfs:comment 'Name or employee ID of the maintenance supervisor or fleet manager who reviewed and approved the completed repair before work order closure. Required for DOT annual inspection certification and internal quality control.' ;
    rdfs:domain ind:RepairHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicianName rdf:type rdf:Property ;
    rdfs:label 'Technician Name' ;
    rdfs:comment 'Full name of the primary technician who performed the repair, as recorded at the time of work order closure. Retained in the historical record for audit and accountability purposes even if the technician record changes. Classified confidential as it is employee data.' ;
    rdfs:domain ind:RepairHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalRepairCost rdf:type rdf:Property ;
    rdfs:label 'Total Repair Cost' ;
    rdfs:comment 'Total cost in US dollars for the complete repair event, encompassing labor, parts, subcontractor, and any other direct costs. Primary financial metric for asset lifecycle cost analysis, EBITDA impact assessment, and repair vs. replace decision support.' ;
    rdfs:domain ind:RepairHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vmrsSystemCode rdf:type rdf:Property ;
    rdfs:label 'Vmrs System Code' ;
    rdfs:comment 'Three-digit Vehicle Maintenance Reporting Standards (VMRS) system code identifying the major vehicle system affected by the repair (e.g., 011 = Air Brakes, 013 = Cooling System, 032 = Engine). Industry-standard classification for fleet maintenance benchmarking and DOT compliance reporting.' ;
    rdfs:domain ind:RepairHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sortLineId rdf:type rdf:Property ;
    rdfs:label 'Sort Line Id' ;
    rdfs:comment 'Foreign key linking to recycling.sort_line. Business justification: Sort line availability and OEE (Overall Equipment Effectiveness) reporting requires direct linkage between downtime events and the specific sort line affected. MRF maintenance planners track sort line' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SortLine .

ind:sortSessionId rdf:type rdf:Property ;
    rdfs:label 'Sort Session Id' ;
    rdfs:comment 'Foreign key linking to recycling.sort_session. Business justification: MRF operations managers correlate equipment downtime events with sort session throughput loss, residue rate spikes, and recovery impacts. This link enables the MRF downtime impact report — a standard ' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SortSession .

ind:vehicleAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Vehicle Assignment Id' ;
    rdfs:comment 'Foreign key linking to fleet.vehicle_assignment. Business justification: When a vehicle breaks down mid-shift, the downtime event must reference the specific vehicle assignment disrupted. This enables operational impact reporting (stops missed, routes incomplete), SLA brea' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VehicleAssignment .

ind:assetIdentifier rdf:type rdf:Property ;
    rdfs:label 'Asset Identifier' ;
    rdfs:comment 'Human-readable asset tag, vehicle unit number, or equipment identifier as registered in the fleet management system (e.g., truck unit number, equipment tag). Used for operational cross-referencing with Geotab telematics and AMCS dispatch.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dotInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Dot Inspection Date' ;
    rdfs:comment 'Date on which the DOT inspection was completed for this downtime event. Populated only when is_dot_inspection_required is True. Required for regulatory compliance documentation.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dotInspectionResult rdf:type rdf:Property ;
    rdfs:label 'Dot Inspection Result' ;
    rdfs:comment 'Outcome of the DOT inspection conducted during or following the downtime event: passed (vehicle cleared for service), failed (vehicle requires additional repairs before service), conditional_pass (vehicle approved with restrictions), not_applicable (no DOT inspection required).' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downtimeCategory rdf:type rdf:Property ;
    rdfs:label 'Downtime Category' ;
    rdfs:comment 'Primary classification of the downtime event type: planned_pm (scheduled Preventive Maintenance cycle), unplanned_breakdown (unexpected mechanical or operational failure), awaiting_parts (asset idle pending parts availability from BOM/inventory), awaiting_technician (asset idle pending technician assignment), dot_hold (asset placed out-of-service pending Department of Transportation (DOT) inspection or compliance resolution).' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downtimeDurationHours rdf:type rdf:Property ;
    rdfs:label 'Downtime Duration Hours' ;
    rdfs:comment 'Total elapsed time in hours that the asset was unavailable for service, calculated as the difference between downtime_end_timestamp and downtime_start_timestamp. Populated upon event closure. Critical for fleet availability KPI and Mean Time to Repair (MTTR) calculations.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:downtimeStatus rdf:type rdf:Property ;
    rdfs:label 'Downtime Status' ;
    rdfs:comment 'Current lifecycle status of the downtime event: open (event recorded, work not yet started), in_progress (maintenance actively underway), resolved (repair complete, asset returned to service), closed (event fully documented and closed in CMMS), cancelled (event voided, e.g., duplicate entry).' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engineHours rdf:type rdf:Property ;
    rdfs:label 'Engine Hours' ;
    rdfs:comment 'Total engine operating hours recorded at the time the downtime event began. Used for hour-based PM scheduling and asset lifecycle management, particularly for heavy equipment and facility machinery where engine hours are the primary maintenance interval metric.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eventNumber rdf:type rdf:Property ;
    rdfs:label 'Event Number' ;
    rdfs:comment 'Externally-known, human-readable business identifier for the downtime event, formatted as DT-{YEAR}-{SEQUENCE}. Used for cross-system reference, reporting, and communication with operations teams.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDotInspectionRequired rdf:type rdf:Property ;
    rdfs:label 'Is Dot Inspection Required' ;
    rdfs:comment 'Indicates whether a Department of Transportation (DOT) inspection is required before the asset can be returned to service. True when downtime_category is dot_hold or when a safety-critical failure is identified. Supports DOT FMCSR compliance tracking.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRepeatFailure rdf:type rdf:Property ;
    rdfs:label 'Is Repeat Failure' ;
    rdfs:comment 'Indicates whether this downtime event represents a recurrence of the same failure mode on the same asset within a defined lookback period (typically 90 days). True signals a chronic reliability issue requiring escalated investigation or asset replacement consideration.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:locationDescription rdf:type rdf:Property ;
    rdfs:label 'Location Description' ;
    rdfs:comment 'Free-text description of the geographic location where the asset breakdown or failure occurred (e.g., route name, street address, facility name, depot). Relevant for unplanned breakdowns occurring in the field.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lostRevenueEstimate rdf:type rdf:Property ;
    rdfs:label 'Lost Revenue Estimate' ;
    rdfs:comment 'Estimated revenue in USD lost due to service disruptions caused by this downtime event, based on affected stops and applicable service rates. Used for operational impact financial assessment and ROI analysis of maintenance investments.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:odometerReadingMiles rdf:type rdf:Property ;
    rdfs:label 'Odometer Reading Miles' ;
    rdfs:comment 'Odometer reading in miles recorded at the time the downtime event began. Used for mileage-based maintenance interval tracking and asset lifecycle analysis. Sourced from Geotab telematics or driver log.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operationalImpactType rdf:type rdf:Property ;
    rdfs:label 'Operational Impact Type' ;
    rdfs:comment 'Classification of the operational impact caused by the downtime event on waste collection or facility operations: route_cancellation (entire route not serviced), route_delay (route completed late), service_disruption (partial or degraded service), partial_service (some stops serviced by alternate vehicle), no_impact (downtime absorbed without service effect).' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partsWaitHours rdf:type rdf:Property ;
    rdfs:label 'Parts Wait Hours' ;
    rdfs:comment 'Total hours the asset was idle specifically waiting for parts or materials to become available from inventory or procurement. Supports parts inventory optimization and supply chain analysis.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:repairTimeHours rdf:type rdf:Property ;
    rdfs:label 'Repair Time Hours' ;
    rdfs:comment 'Actual hands-on repair or maintenance labor time in hours, excluding waiting time for parts or technician. Used to calculate Mean Time to Repair (MTTR) and labor efficiency metrics.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reported Timestamp' ;
    rdfs:comment 'Date and time when the downtime event was first reported to the maintenance team or entered into the CMMS system. May differ from downtime_start_timestamp if there was a reporting lag.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:responseTimeHours rdf:type rdf:Property ;
    rdfs:label 'Response Time Hours' ;
    rdfs:comment 'Elapsed time in hours between the reported_timestamp and the time a technician began active work on the asset. Key KPI for maintenance responsiveness and SLA compliance measurement.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stopsAffectedCount rdf:type rdf:Property ;
    rdfs:label 'Stops Affected Count' ;
    rdfs:comment 'Number of customer service stops that were not completed or were disrupted as a direct result of this downtime event. Used to quantify customer impact and SLA compliance reporting.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalDowntimeCost rdf:type rdf:Property ;
    rdfs:label 'Total Downtime Cost' ;
    rdfs:comment 'Total financial cost in USD attributable to this downtime event, encompassing labor cost, parts cost, and any additional costs such as rental equipment or contractor fees. Used for cost of downtime analysis and EBITDA impact assessment.' ;
    rdfs:domain ind:DowntimeEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:technicianAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Technician Assignment Id' ;
    rdfs:comment 'Unique surrogate identifier for each technician assignment record linking a maintenance technician to a specific work order and task in the Infor EAM / SAP PM system.' ;
    rdfs:domain ind:TechnicianAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trainingCertificationId rdf:type rdf:Property ;
    rdfs:label 'Training Certification Id' ;
    rdfs:comment 'Foreign key linking to compliance.training_certification. Business justification: Technician assignments for regulated work (DOT inspections, hazmat handling, confined space entry) require verified certifications. Referencing the specific training_certification used for the assignm' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TrainingCertification .

ind:actualEndDatetime rdf:type rdf:Property ;
    rdfs:label 'Actual End Datetime' ;
    rdfs:comment 'Actual date and time the technician completed work on the assigned task, as confirmed in Infor EAM. Used to calculate actual labor hours, measure WO cycle time, and support payroll confirmation. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:TechnicianAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualStartDatetime rdf:type rdf:Property ;
    rdfs:label 'Actual Start Datetime' ;
    rdfs:comment 'Actual date and time the technician began work on the assigned task, as recorded in Infor EAM or via mobile confirmation. Compared against scheduled start to measure schedule adherence and response time. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:TechnicianAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assignmentNotes rdf:type rdf:Property ;
    rdfs:label 'Assignment Notes' ;
    rdfs:comment 'Free-text field for technician or supervisor notes specific to this assignment, including observations, deviations from standard procedure, safety concerns, or follow-up actions required. Captured in Infor EAM mobile or SAP PM confirmation.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentType rdf:type rdf:Property ;
    rdfs:label 'Assignment Type' ;
    rdfs:comment 'Categorizes the technician\'s role on the work order: primary (lead technician responsible for execution), secondary (supporting technician), supervisor (oversight role), trainee (under supervision), or contractor (external labor). Drives crew scheduling and cost rate selection.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationUsed rdf:type rdf:Property ;
    rdfs:label 'Certification Used' ;
    rdfs:comment 'Specific certification or license applied by the technician for this assignment (e.g., CDL, DOT Inspector, RCRA Hazardous Waste Handler, ASE Certification). Ensures regulatory compliance and documents that qualified personnel performed the work. [ENUM-REF-CANDIDATE: CDL|DOT_INSPECTOR|RCRA_HANDLER|ASE|OSHA_30|HAZWOPER|CDL_HAZMAT — promote to reference product]' ;
    rdfs:domain ind:TechnicianAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionCode rdf:type rdf:Property ;
    rdfs:label 'Completion Code' ;
    rdfs:comment 'Standardized outcome code recorded at assignment closure: completed_normal (fully executed as planned), completed_partial (partial work done, follow-up required), deferred (rescheduled), cancelled_no_fault (cancelled without technician fault), or cancelled_parts (cancelled due to parts unavailability).' ;
    rdfs:domain ind:TechnicianAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmedDatetime rdf:type rdf:Property ;
    rdfs:label 'Confirmed Datetime' ;
    rdfs:comment 'Date and time when the labor hours for this assignment were formally confirmed and approved in SAP PM or Infor EAM. Used for payroll cutoff processing, financial period allocation, and audit trail. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:TechnicianAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:craftCode rdf:type rdf:Property ;
    rdfs:label 'Craft Code' ;
    rdfs:comment 'Trade or craft classification code identifying the technician\'s skill category for this assignment (e.g., MECH for mechanic, ELEC for electrician, WELD for welder, HVAC for HVAC technician). Used in Infor EAM for labor planning and rate determination. [ENUM-REF-CANDIDATE: MECH|ELEC|WELD|HVAC|LUBE|DIAG|BODY|TIRE|INSP — promote to reference product]' ;
    rdfs:domain ind:TechnicianAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatWorkFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Work Flag' ;
    rdfs:comment 'Indicates whether this assignment involves work on hazardous waste handling equipment or requires HAZMAT-certified personnel (True). Triggers PPE requirements, RCRA compliance documentation, and OSHA HAZWOPER certification verification.' ;
    rdfs:domain ind:TechnicianAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laborConfirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Labor Confirmation Number' ;
    rdfs:comment 'SAP PM or Infor EAM labor confirmation document number generated when the technician\'s actual hours are posted and confirmed against the work order. Serves as the audit reference linking this assignment to the financial posting in SAP FI/CO.' ;
    rdfs:domain ind:TechnicianAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laborConfirmedFlag rdf:type rdf:Property ;
    rdfs:label 'Labor Confirmed Flag' ;
    rdfs:comment 'Indicates whether the technician\'s actual labor hours have been formally confirmed and posted in SAP PM or Infor EAM (True), triggering financial posting to the work order cost object. False indicates hours are still pending confirmation.' ;
    rdfs:domain ind:TechnicianAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:laborRate rdf:type rdf:Property ;
    rdfs:label 'Labor Rate' ;
    rdfs:comment 'Hourly labor rate applied to this technician assignment for cost calculation, sourced from the technician\'s craft/trade rate in SAP PM or Infor EAM. May reflect standard, overtime, or contractor rate depending on assignment type.' ;
    rdfs:domain ind:TechnicianAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overtimeHours rdf:type rdf:Property ;
    rdfs:label 'Overtime Hours' ;
    rdfs:comment 'Number of overtime hours logged by the technician for this assignment beyond the standard shift, as tracked per FLSA and company policy. Drives overtime cost calculation and labor budget variance reporting.' ;
    rdfs:domain ind:TechnicianAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ppeRequired rdf:type rdf:Property ;
    rdfs:label 'Ppe Required' ;
    rdfs:comment 'Comma-delimited list of required PPE items for this technician assignment (e.g., \'hard_hat,safety_vest,gloves,respirator\'). Derived from the task hazard assessment and OSHA requirements. Supports safety compliance verification and incident prevention.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledEndDatetime rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Datetime' ;
    rdfs:comment 'Planned date and time the technician is expected to complete work on the assigned task. Used for shift planning, resource availability, and work order duration estimation. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:TechnicianAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledLaborHours rdf:type rdf:Property ;
    rdfs:label 'Scheduled Labor Hours' ;
    rdfs:comment 'Planned number of labor hours allocated to this technician for the assigned task, as estimated during work order planning. Used for capacity planning, cost estimation, and variance analysis against actual hours.' ;
    rdfs:domain ind:TechnicianAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduledStartDatetime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Datetime' ;
    rdfs:comment 'Planned date and time the technician is scheduled to begin work on the assigned task. Used for crew scheduling, resource capacity planning, and SLA compliance monitoring. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:TechnicianAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shiftCode rdf:type rdf:Property ;
    rdfs:label 'Shift Code' ;
    rdfs:comment 'Work shift during which this technician assignment is scheduled or executed: day, evening, night, weekend, or on_call. Used for shift differential pay calculation, labor scheduling, and 24/7 maintenance coverage analysis.' ;
    rdfs:domain ind:TechnicianAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skillLevel rdf:type rdf:Property ;
    rdfs:label 'Skill Level' ;
    rdfs:comment 'Proficiency level of the technician for the craft applied in this assignment: apprentice (entry-level under supervision), journeyman (qualified independent), senior (experienced), master (highest craft level), or specialist (domain-specific expert). Used for crew composition validation and training gap analysis.' ;
    rdfs:domain ind:TechnicianAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:travelTimeHours rdf:type rdf:Property ;
    rdfs:label 'Travel Time Hours' ;
    rdfs:comment 'Number of hours the technician spent traveling to and from the maintenance site for this assignment. Captured separately from labor hours for accurate cost allocation, technician utilization analysis, and field service efficiency reporting.' ;
    rdfs:domain ind:TechnicianAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workOrderPriority rdf:type rdf:Property ;
    rdfs:label 'Work Order Priority' ;
    rdfs:comment 'Priority level of the parent work order, denormalized to the assignment level to support technician dispatch sequencing and scheduling decisions: emergency (immediate response), urgent (same-day), high (next available), normal (scheduled), or low (deferred).' ;
    rdfs:domain ind:TechnicianAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalWasteCodeId rdf:type rdf:Property ;
    rdfs:label 'Disposal Waste Code Id' ;
    rdfs:comment 'Foreign key linking to hazmat.waste_code. Business justification: Parts containing hazardous materials (batteries, mercury switches, PCB capacitors) must link to EPA waste codes for disposal planning, waste characterization, and regulatory compliance. Essential for ' ;
    rdfs:domain ind:PartsCatalog ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WasteCode .

ind:dotHazmatClassificationId rdf:type rdf:Property ;
    rdfs:label 'Dot Hazmat Classification Id' ;
    rdfs:comment 'Foreign key linking to hazmat.dot_hazmat_classification. Business justification: Parts catalog entries for hazardous materials (fluids, batteries, aerosols) must carry DOT classification for 49 CFR shipping and storage compliance. Normalizes denormalized hazmat_class and un_number' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DotHazmatClassification .

ind:catalogEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Catalog Effective Date' ;
    rdfs:comment 'Date on which this part record became effective and available for use in work orders and purchasing. Supports catalog version management and historical BOM accuracy.' ;
    rdfs:domain ind:PartsCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:coreChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Core Charge Amount' ;
    rdfs:comment 'Refundable deposit amount charged by the supplier for a remanufactured part\'s core. Credited back upon return of the used core. Expressed in USD. Applicable only when is_core_returnable is True.' ;
    rdfs:domain ind:PartsCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dotInspectionPart rdf:type rdf:Property ;
    rdfs:label 'Dot Inspection Part' ;
    rdfs:comment 'Indicates whether this part is a safety-critical component subject to Department of Transportation (DOT) vehicle inspection requirements (True). Examples include brake components, tires, lights, and steering parts. Ensures compliance tracking for DOT roadworthiness inspections.' ;
    rdfs:domain ind:PartsCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:expectedServiceLifeDays rdf:type rdf:Property ;
    rdfs:label 'Expected Service Life Days' ;
    rdfs:comment 'Manufacturer or engineering-specified expected useful service life of the part in calendar days under normal operating conditions. Used for PM interval planning, lifecycle cost analysis, and asset reliability modeling.' ;
    rdfs:domain ind:PartsCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isCoreReturnable rdf:type rdf:Property ;
    rdfs:label 'Is Core Returnable' ;
    rdfs:comment 'Indicates whether a core (used/rebuildable) part must be returned to the supplier upon installation of a replacement (True). Common for remanufactured parts such as alternators, starters, and hydraulic pumps. Drives core charge tracking in procurement.' ;
    rdfs:domain ind:PartsCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHazardousMaterial rdf:type rdf:Property ;
    rdfs:label 'Is Hazardous Material' ;
    rdfs:comment 'Indicates whether this part or material is classified as a hazardous material requiring special handling, storage, and disposal procedures under DOT, EPA, and OSHA regulations (e.g., certain fluids, batteries, refrigerants). True = hazardous; False = non-hazardous.' ;
    rdfs:domain ind:PartsCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSerialized rdf:type rdf:Property ;
    rdfs:label 'Is Serialized' ;
    rdfs:comment 'Indicates whether individual units of this part are tracked by unique serial number (True) or managed as bulk/lot inventory (False). Serialized parts (e.g., engines, transmissions, compactors) require individual asset tracking in Infor EAM.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastCostReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Cost Review Date' ;
    rdfs:comment 'Date on which the standard cost for this part was last reviewed and updated. Supports annual cost roll-up processes and ensures standard costs remain aligned with market pricing.' ;
    rdfs:domain ind:PartsCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maximumStockQuantity rdf:type rdf:Property ;
    rdfs:label 'Maximum Stock Quantity' ;
    rdfs:comment 'Maximum allowable on-hand inventory quantity to prevent overstocking and excess carrying costs. Used in min-max inventory planning. Expressed in the part\'s unit of measure.' ;
    rdfs:domain ind:PartsCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumStockQuantity rdf:type rdf:Property ;
    rdfs:label 'Minimum Stock Quantity' ;
    rdfs:comment 'Safety stock level — the absolute minimum quantity that must be maintained on hand to prevent stockouts during lead time. Distinct from reorder_point which is the trigger level. Expressed in the part\'s unit of measure.' ;
    rdfs:domain ind:PartsCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:obsoleteDate rdf:type rdf:Property ;
    rdfs:label 'Obsolete Date' ;
    rdfs:comment 'Date on which this part was designated as obsolete or discontinued. After this date, the part is no longer available for new work orders or purchase orders. Null if the part is still active.' ;
    rdfs:domain ind:PartsCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:oemPartNumber rdf:type rdf:Property ;
    rdfs:label 'Oem Part Number' ;
    rdfs:comment 'The Original Equipment Manufacturer (OEM) part number as assigned by the vehicle or equipment manufacturer (e.g., Mack Trucks, Heil Environmental, McNeilus). Used for cross-referencing with manufacturer catalogs and sourcing OEM replacements.' ;
    rdfs:domain ind:PartsCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partName rdf:type rdf:Property ;
    rdfs:label 'Part Name' ;
    rdfs:comment 'Human-readable short name or title of the part (e.g., \'Hydraulic Pump Assembly\', \'Air Filter Element\', \'Brake Caliper\'). Used as the primary identity label for display in work orders, purchase orders, and inventory reports.' ;
    rdfs:domain ind:PartsCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partStatus rdf:type rdf:Property ;
    rdfs:label 'Part Status' ;
    rdfs:comment 'Current lifecycle status of the part in the catalog. Active parts are available for use in work orders and purchasing. Obsolete parts are no longer procured. Superseded parts have been replaced by a newer part number. Pending_approval parts are under review before activation.' ;
    rdfs:domain ind:PartsCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partType rdf:type rdf:Property ;
    rdfs:label 'Part Type' ;
    rdfs:comment 'Classification of the part by its maintenance disposition: consumable (single-use, e.g., filters, fluids), repairable (can be rebuilt), rotable (tracked serialized item returned to stock after repair), expendable (low-cost, not tracked), or capital (high-value tracked asset component).' ;
    rdfs:domain ind:PartsCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pmApplicable rdf:type rdf:Property ;
    rdfs:label 'Pm Applicable' ;
    rdfs:comment 'Indicates whether this part is used in scheduled Preventive Maintenance (PM) cycles (True) versus only in corrective/unplanned repairs (False). Drives PM parts kit planning and stocking strategies.' ;
    rdfs:domain ind:PartsCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reorderPoint rdf:type rdf:Property ;
    rdfs:label 'Reorder Point' ;
    rdfs:comment 'Minimum on-hand inventory quantity threshold that triggers a replenishment purchase order. When stock falls to or below this level, procurement is initiated. Expressed in the part\'s unit of measure.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reorderQuantity rdf:type rdf:Property ;
    rdfs:label 'Reorder Quantity' ;
    rdfs:comment 'Standard quantity to order when a replenishment is triggered. Represents the economic order quantity (EOQ) or fixed lot size for the part. Expressed in the part\'s unit of measure.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdsNumber rdf:type rdf:Property ;
    rdfs:label 'Sds Number' ;
    rdfs:comment 'Reference number for the Safety Data Sheet (SDS) associated with this part or material. Required by OSHA Hazard Communication Standard for hazardous chemicals. Enables technicians to access handling, storage, and emergency response information.' ;
    rdfs:domain ind:PartsCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemCode rdf:type rdf:Property ;
    rdfs:label 'Source System Code' ;
    rdfs:comment 'Identifies the operational system of record from which this part record originated (e.g., INFOR_EAM for Infor EAM parts master, SAP_MM for SAP S/4HANA Material Master, MANUAL for manually entered records). Supports data lineage and reconciliation in the Silver Layer.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardCost rdf:type rdf:Property ;
    rdfs:label 'Standard Cost' ;
    rdfs:comment 'Standard cost per unit of measure for the part as maintained in the cost accounting system. Used for work order cost estimation, budget planning, and variance analysis. Expressed in USD. Corresponds to the standard price in SAP MM Material Master costing view.' ;
    rdfs:domain ind:PartsCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageLocationCode rdf:type rdf:Property ;
    rdfs:label 'Storage Location Code' ;
    rdfs:comment 'Default warehouse or parts room storage location code where this part is stocked (e.g., bin, shelf, or zone identifier). Used for inventory picking, cycle counting, and parts room organization in Infor EAM.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyDurationDays rdf:type rdf:Property ;
    rdfs:label 'Warranty Duration Days' ;
    rdfs:comment 'Standard warranty period in calendar days provided by the manufacturer or supplier for this part. Used to track warranty claims and determine eligibility for no-cost replacements on failed parts.' ;
    rdfs:domain ind:PartsCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:weightLbs rdf:type rdf:Property ;
    rdfs:label 'Weight Lbs' ;
    rdfs:comment 'Physical weight of the part in pounds. Used for shipping cost estimation, DOT weight compliance on service vehicles, and ergonomic safety assessments for technician handling under OSHA guidelines.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentStoreroomId rdf:type rdf:Property ;
    rdfs:label 'Parent Storeroom Id' ;
    rdfs:comment 'Self-referencing identifier pointing to the parent storeroom in a hierarchical storeroom network (e.g., a satellite storeroom references its central hub storeroom). Enables multi-tier inventory replenishment and inter-storeroom transfer management.' ;
    rdfs:domain ind:Storeroom ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Storeroom .

ind:storageUnitId rdf:type rdf:Property ;
    rdfs:label 'Storage Unit Id' ;
    rdfs:comment 'Foreign key linking to hazmat.storage_unit. Business justification: Maintenance storerooms certified as hazmat satellite accumulation areas must be linked to the hazmat storage_unit record for EPA accumulation time limit enforcement and unified inspection scheduling. ' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:StorageUnit .

ind:binLocationCount rdf:type rdf:Property ;
    rdfs:label 'Bin Location Count' ;
    rdfs:comment 'Total number of discrete bin, shelf, or rack locations within the storeroom. Drives bin-level inventory tracking configuration in the CMMS and determines the granularity of parts storage management.' ;
    rdfs:domain ind:Storeroom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cycleCountFrequency rdf:type rdf:Property ;
    rdfs:label 'Cycle Count Frequency' ;
    rdfs:comment 'Frequency at which physical inventory cycle counts are performed in this storeroom. Cycle counts verify on-hand quantities against system records and are required for SOX-compliant inventory accuracy controls.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decommissionDate rdf:type rdf:Property ;
    rdfs:label 'Decommission Date' ;
    rdfs:comment 'Date on which the storeroom was or is scheduled to be permanently decommissioned and removed from active inventory operations. Populated when storeroom_status transitions to decommissioned.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eamStoreroomRef rdf:type rdf:Property ;
    rdfs:label 'Eam Storeroom Ref' ;
    rdfs:comment 'External reference identifier for this storeroom as recorded in the Infor EAM system. Used for cross-system reconciliation between the lakehouse silver layer and the operational CMMS source of record.' ;
    rdfs:domain ind:Storeroom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emailAddress rdf:type rdf:Property ;
    rdfs:label 'Email Address' ;
    rdfs:comment 'Primary email address for the storeroom used for purchase order confirmations, parts requisition notifications, and vendor communications.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:establishedDate rdf:type rdf:Property ;
    rdfs:label 'Established Date' ;
    rdfs:comment 'Date on which the storeroom was formally established and made operational. Used for asset lifecycle tracking, depreciation scheduling, and historical inventory network analysis.' ;
    rdfs:domain ind:Storeroom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fireSuppressionType rdf:type rdf:Property ;
    rdfs:label 'Fire Suppression Type' ;
    rdfs:comment 'Type of fire suppression system installed in the storeroom. Required for OSHA and local fire code compliance, particularly for storerooms holding flammable lubricants, solvents, or compressed gas cylinders.' ;
    rdfs:domain ind:Storeroom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryValuationMethod rdf:type rdf:Property ;
    rdfs:label 'Inventory Valuation Method' ;
    rdfs:comment 'Accounting method used to value parts inventory held in this storeroom. Standard cost uses predetermined prices; moving average recalculates cost with each receipt; FIFO and LIFO are queue-based methods. Determines how parts cost flows to work orders and financial statements.' ;
    rdfs:domain ind:Storeroom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBonded rdf:type rdf:Property ;
    rdfs:label 'Is Bonded' ;
    rdfs:comment 'Indicates whether the storeroom operates as a bonded (secured, access-controlled) inventory location where parts are tracked under formal custody and issuance controls. Bonded storerooms require documented check-in/check-out procedures and are subject to periodic audits.' ;
    rdfs:domain ind:Storeroom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isClimateControlled rdf:type rdf:Property ;
    rdfs:label 'Is Climate Controlled' ;
    rdfs:comment 'Indicates whether the storeroom maintains controlled temperature and humidity conditions. Climate-controlled storerooms are required for storing temperature-sensitive parts such as electronic control modules, batteries, lubricants, and certain chemical supplies.' ;
    rdfs:domain ind:Storeroom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isHazmatCertified rdf:type rdf:Property ;
    rdfs:label 'Is Hazmat Certified' ;
    rdfs:comment 'Indicates whether the storeroom is certified to store hazardous materials such as solvents, lubricants, batteries, and other regulated substances. Certification requires compliance with EPA, DOT, and OSHA hazmat storage regulations.' ;
    rdfs:domain ind:Storeroom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVendorManaged rdf:type rdf:Property ;
    rdfs:label 'Is Vendor Managed' ;
    rdfs:comment 'Indicates whether inventory replenishment for this storeroom is managed by an external vendor under a Vendor Managed Inventory (VMI) agreement. VMI storerooms have supplier-controlled reorder triggers and consignment stock arrangements.' ;
    rdfs:domain ind:Storeroom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastAuditDate rdf:type rdf:Property ;
    rdfs:label 'Last Audit Date' ;
    rdfs:comment 'Date of the most recent formal storeroom audit covering inventory accuracy, hazmat compliance, storage conditions, and security controls. Supports regulatory compliance tracking and internal audit scheduling.' ;
    rdfs:domain ind:Storeroom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastCycleCountDate rdf:type rdf:Property ;
    rdfs:label 'Last Cycle Count Date' ;
    rdfs:comment 'Date on which the most recent physical inventory cycle count was completed for this storeroom. Used to track compliance with cycle count schedules and identify storerooms overdue for physical verification.' ;
    rdfs:domain ind:Storeroom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maxInventoryValueUsd rdf:type rdf:Property ;
    rdfs:label 'Max Inventory Value Usd' ;
    rdfs:comment 'Authorized maximum dollar value of parts inventory that may be held in this storeroom at any time. Used for capital budgeting, insurance coverage determination, and inventory investment controls. Expressed in US dollars.' ;
    rdfs:domain ind:Storeroom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatingHours rdf:type rdf:Property ;
    rdfs:label 'Operating Hours' ;
    rdfs:comment 'Descriptive text specifying the days and hours during which the storeroom is staffed and open for parts issuance and receipt (e.g., \'Mon-Fri 06:00-18:00, Sat 07:00-12:00\'). Used for work order planning and technician parts availability scheduling.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phoneNumber rdf:type rdf:Property ;
    rdfs:label 'Phone Number' ;
    rdfs:comment 'Primary contact telephone number for the storeroom. Used by technicians, procurement staff, and fleet managers to coordinate parts availability, emergency parts requests, and delivery scheduling.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryCostCenterCode rdf:type rdf:Property ;
    rdfs:label 'Primary Cost Center Code' ;
    rdfs:comment 'SAP cost center code to which storeroom operating expenses (overhead, labor, utilities) are charged. Enables financial reporting of storeroom costs within the maintenance domain P&L.' ;
    rdfs:domain ind:Storeroom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replenishmentMethod rdf:type rdf:Property ;
    rdfs:label 'Replenishment Method' ;
    rdfs:comment 'The inventory replenishment strategy applied to this storeroom. Min/max triggers reorder when stock falls below minimum level; reorder_point uses statistical demand forecasting; kanban uses visual pull signals; vmi delegates replenishment to the vendor; manual requires human-initiated purchase orders.' ;
    rdfs:domain ind:Storeroom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapStorageLocationCode rdf:type rdf:Property ;
    rdfs:label 'Sap Storage Location Code' ;
    rdfs:comment 'Four-character SAP S/4HANA MM storage location code corresponding to this storeroom. Used for purchase order goods receipt, material document posting, and inventory reconciliation between SAP and Infor EAM.' ;
    rdfs:domain ind:Storeroom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityAccessLevel rdf:type rdf:Property ;
    rdfs:label 'Security Access Level' ;
    rdfs:comment 'Physical security access control level for the storeroom. Open storerooms have no access restriction; badge_access requires electronic credential; supervised requires attendant presence; locked requires key/combination access. Drives access control configuration and audit requirements.' ;
    rdfs:domain ind:Storeroom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageCapacitySqft rdf:type rdf:Property ;
    rdfs:label 'Storage Capacity Sqft' ;
    rdfs:comment 'Total physical floor area of the storeroom in square feet. Used for capacity planning, storeroom utilization analysis, and determining maximum parts inventory volume that can be physically accommodated.' ;
    rdfs:domain ind:Storeroom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storeroomCode rdf:type rdf:Property ;
    rdfs:label 'Storeroom Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the storeroom within the enterprise maintenance network. Used in work orders, purchase orders, and parts requisitions to reference the issuing storeroom. Aligns with Infor EAM storeroom code field.' ;
    rdfs:domain ind:Storeroom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storeroomName rdf:type rdf:Property ;
    rdfs:label 'Storeroom Name' ;
    rdfs:comment 'Human-readable descriptive name of the storeroom (e.g., \'Houston Central Fleet Parts Storeroom\', \'Dallas North Satellite Storeroom\'). Used in reports, dashboards, and user interfaces.' ;
    rdfs:domain ind:Storeroom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storeroomStatus rdf:type rdf:Property ;
    rdfs:label 'Storeroom Status' ;
    rdfs:comment 'Current lifecycle status of the storeroom record. Active storerooms are operational and available for parts issuance and receipt. Inactive storerooms are temporarily closed. Decommissioned storerooms are permanently closed and no longer used.' ;
    rdfs:domain ind:Storeroom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storeroomType rdf:type rdf:Property ;
    rdfs:label 'Storeroom Type' ;
    rdfs:comment 'Classification of the storeroom by its operational role within the parts distribution network. Central storerooms serve as primary hubs; satellite storerooms serve regional yards; mobile storerooms are truck-mounted for field use; field_cache are small on-site bins; virtual storerooms represent consignment or vendor-managed inventory locations.' ;
    rdfs:domain ind:Storeroom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partsInventoryId rdf:type rdf:Property ;
    rdfs:label 'Parts Inventory Id' ;
    rdfs:comment 'Unique surrogate identifier for each parts inventory record representing the on-hand stock position of a specific part at a specific storeroom and bin location. Primary key for the parts_inventory data product in the Databricks Silver Layer.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryPartsCatalogId rdf:type rdf:Property ;
    rdfs:label 'Primary Parts Catalog Id' ;
    rdfs:comment 'Reference to the part master record in the parts catalog. Links this inventory position to the part definition including description, specifications, and classification. Sourced from Infor EAM parts catalog.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PartsCatalog .

ind:abcClassification rdf:type rdf:Property ;
    rdfs:label 'Abc Classification' ;
    rdfs:comment 'ABC analysis classification of the part based on annual consumption value. \'A\' items represent high-value/high-usage parts requiring tight inventory control; \'B\' items are moderate; \'C\' items are low-value/low-usage parts. Used to prioritize cycle count frequency and inventory management effort.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualUsageQuantity rdf:type rdf:Property ;
    rdfs:label 'Annual Usage Quantity' ;
    rdfs:comment 'Total quantity of this part issued from this storeroom over the trailing 12-month period. Used for ABC classification, reorder point calculation, safety stock sizing, and inventory carrying cost analysis. Updated periodically from goods issue history.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:binLocation rdf:type rdf:Property ;
    rdfs:label 'Bin Location' ;
    rdfs:comment 'Specific bin, shelf, rack, or aisle location within the storeroom where the part is physically stored (e.g., \'A-12-3\', \'RACK-B-SHELF-4\'). Enables efficient parts picking during work order execution and physical inventory counts.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countVarianceQuantity rdf:type rdf:Property ;
    rdfs:label 'Count Variance Quantity' ;
    rdfs:comment 'Difference between last_count_quantity and the system quantity_on_hand at the time of the physical count. Positive values indicate more stock found than recorded; negative values indicate shrinkage or unrecorded usage. Used to trigger inventory adjustments and investigate discrepancies.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:criticalityLevel rdf:type rdf:Property ;
    rdfs:label 'Criticality Level' ;
    rdfs:comment 'Classification of the part\'s operational criticality based on the impact of a stockout on fleet or facility operations. \'critical\' parts (e.g., DOT-required safety components, CNG system parts) cause immediate vehicle out-of-service if unavailable. Used to prioritize reorder actions and safety stock levels.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatClass rdf:type rdf:Property ;
    rdfs:label 'Hazmat Class' ;
    rdfs:comment 'DOT hazardous materials classification code for the part when is_hazardous is True (e.g., \'3\' for flammable liquids, \'8\' for corrosives, \'9\' for miscellaneous). Required for compliant storage, handling, and disposal documentation. Null when is_hazardous is False.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryStatus rdf:type rdf:Property ;
    rdfs:label 'Inventory Status' ;
    rdfs:comment 'Current lifecycle status of this inventory record. \'active\' indicates the part is available for use; \'quarantine\' indicates the part is held pending quality inspection; \'obsolete\' indicates the part is no longer used but stock remains; \'pending_disposal\' indicates stock is being removed from service.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryValue rdf:type rdf:Property ;
    rdfs:label 'Inventory Value' ;
    rdfs:comment 'Total monetary value of the on-hand inventory for this part at this storeroom, calculated as quantity_on_hand multiplied by unit_cost. Expressed in USD. Used for balance sheet inventory asset reporting, carrying cost analysis, and financial close processes per GAAP/IFRS.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isHazardous rdf:type rdf:Property ;
    rdfs:label 'Is Hazardous' ;
    rdfs:comment 'Indicates whether this part or material is classified as hazardous under DOT, EPA, or OSHA regulations (e.g., solvents, lubricants, refrigerants, battery acid). Triggers special handling, storage, and disposal requirements. True = hazardous material requiring regulatory compliance controls.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLotControlled rdf:type rdf:Property ;
    rdfs:label 'Is Lot Controlled' ;
    rdfs:comment 'Indicates whether this part is managed by lot or batch number for traceability purposes (True). Lot-controlled parts (e.g., lubricants, chemicals, safety-critical components) require lot tracking for quality control, recall management, and regulatory compliance.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastCountQuantity rdf:type rdf:Property ;
    rdfs:label 'Last Count Quantity' ;
    rdfs:comment 'Actual quantity recorded during the most recent physical inventory count for this part at this storeroom. Compared against the system quantity_on_hand to identify and reconcile inventory discrepancies.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastIssueDate rdf:type rdf:Property ;
    rdfs:label 'Last Issue Date' ;
    rdfs:comment 'Date on which the most recent stock issue (goods issue to a work order or cost center) was posted for this part at this storeroom. Used to identify slow-moving or obsolete inventory and support inventory rationalization decisions.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastPhysicalCountDate rdf:type rdf:Property ;
    rdfs:label 'Last Physical Count Date' ;
    rdfs:comment 'Date on which the most recent physical inventory count was performed for this part at this storeroom. Used to assess inventory record accuracy, schedule cycle counts, and support audit compliance. Required for SOX internal controls over inventory.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Last Receipt Date' ;
    rdfs:comment 'Date on which the most recent stock receipt (goods receipt from a purchase order or transfer) was posted for this part at this storeroom. Used to assess replenishment frequency and identify slow-moving or dormant inventory.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maxStockLevel rdf:type rdf:Property ;
    rdfs:label 'Max Stock Level' ;
    rdfs:comment 'Maximum quantity of the part that should be held in the storeroom at any time. Used to prevent overstocking, control carrying costs, and optimize storeroom space utilization. Replenishment orders are sized to bring stock up to but not exceed this level.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minStockLevel rdf:type rdf:Property ;
    rdfs:label 'Min Stock Level' ;
    rdfs:comment 'Minimum reorder point quantity below which a replenishment requisition or purchase order should be triggered. Used by the CMMS to generate automatic reorder alerts and prevent stockouts that could cause fleet or facility downtime.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextCycleCountDate rdf:type rdf:Property ;
    rdfs:label 'Next Cycle Count Date' ;
    rdfs:comment 'Scheduled date for the next physical cycle count of this part at this storeroom. Calculated based on last_physical_count_date and cycle_count_frequency. Used by storeroom supervisors to plan and assign counting tasks.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quantityAvailable rdf:type rdf:Property ;
    rdfs:label 'Quantity Available' ;
    rdfs:comment 'Net quantity available for new work order allocation, calculated as quantity_on_hand minus quantity_reserved. Represents the true available-to-promise stock for WO planning and parts availability checks. Stored as a business field to support real-time availability queries without recalculation.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityOnHand rdf:type rdf:Property ;
    rdfs:label 'Quantity On Hand' ;
    rdfs:comment 'Current physical quantity of the part available in the storeroom at the time of the last inventory update. Expressed in the part\'s unit of measure (e.g., EA, GAL, FT). This is the gross stock before reservations are subtracted.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityOnOrder rdf:type rdf:Property ;
    rdfs:label 'Quantity On Order' ;
    rdfs:comment 'Total quantity of the part currently on open Purchase Orders (POs) that have been issued to suppliers but not yet received into the storeroom. Used for replenishment planning and projected stock availability calculations.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityReserved rdf:type rdf:Property ;
    rdfs:label 'Quantity Reserved' ;
    rdfs:comment 'Quantity of the part currently allocated or reserved against open Work Orders (WOs) that have not yet been issued/picked. Reduces the effective available quantity for new WO planning. Sourced from Infor EAM or SAP PM reservation records.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyStockQuantity rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Quantity' ;
    rdfs:comment 'Buffer stock quantity maintained above the minimum stock level to protect against demand variability and supplier lead time uncertainty. Particularly important for critical fleet parts (e.g., DOT-required components) where stockouts cause vehicle out-of-service events.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shelfLifeDays rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Days' ;
    rdfs:comment 'Maximum number of days this part can be stored before it expires or degrades and must be disposed of (e.g., lubricants, adhesives, rubber seals, safety equipment with expiry dates). Null for parts with no shelf life restriction. Used to manage FIFO rotation and prevent use of expired materials.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:valuationMethod rdf:type rdf:Property ;
    rdfs:label 'Valuation Method' ;
    rdfs:comment 'Accounting method used to value this part\'s inventory (e.g., moving_average, standard_cost, FIFO, LIFO). Determines how unit_cost is calculated when stock is received at varying prices. Must align with the company\'s GAAP/IFRS inventory accounting policy.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classId rdf:type rdf:Property ;
    rdfs:label 'Class Id' ;
    rdfs:comment 'Foreign key linking to asset.class. Business justification: FMEA per asset class: failure_mode has asset_class as a plain text field — a denormalized reference to asset.class. Failure modes in waste management are defined per asset class (compactors, transfer ' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Class .

ind:componentSystem rdf:type rdf:Property ;
    rdfs:label 'Component System' ;
    rdfs:comment 'The primary vehicle or facility component system affected by this failure mode (e.g., \'Engine\', \'Transmission\', \'Hydraulic Lift System\', \'Braking System\', \'Electrical System\', \'Compactor Body\', \'Chassis\'). Aligns with VMRS system codes for fleet assets and EAM component hierarchy for facility assets.' ;
    rdfs:domain ind:FailureMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionMethod rdf:type rdf:Property ;
    rdfs:label 'Detection Method' ;
    rdfs:comment 'Standard method by which this failure mode is typically detected. Informs PM schedule design and sensor/telematics alert configuration. Sensor alerts integrate with Geotab telematics; diagnostic codes align with OBD-II/J1939 fault code systems for fleet assets. [ENUM-REF-CANDIDATE: visual_inspection|sensor_alert|driver_report|pm_inspection|diagnostic_code|operator_complaint|third_party_inspection — promote to reference product]' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dotReportableFlag rdf:type rdf:Property ;
    rdfs:label 'Dot Reportable Flag' ;
    rdfs:comment 'Indicates whether this failure mode, when identified on a commercial motor vehicle, constitutes a DOT-reportable defect requiring out-of-service designation or driver vehicle inspection report (DVIR) notation. Drives compliance workflows in fleet maintenance and DOT inspection management.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:epaReportableFlag rdf:type rdf:Property ;
    rdfs:label 'Epa Reportable Flag' ;
    rdfs:comment 'Indicates whether this failure mode may result in an EPA-reportable environmental incident (e.g., hydraulic fluid spill, leachate containment breach, LFG emission exceedance). When true, triggers environmental incident notification workflows in Enviance EHS and CERCLA/RCRA compliance reporting.' ;
    rdfs:domain ind:FailureMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedDowntimeHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Downtime Hours' ;
    rdfs:comment 'Standard estimated number of hours an asset is expected to be out of service when this failure mode occurs, including diagnosis, repair, and return-to-service time. Used for fleet availability modeling, route coverage planning, and KPI reporting on asset utilization.' ;
    rdfs:domain ind:FailureMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expirationDate rdf:type rdf:Property ;
    rdfs:label 'Expiration Date' ;
    rdfs:comment 'Date after which this failure mode code is no longer valid for assignment to new work orders. Null for codes with no planned expiration. Supports catalog lifecycle management and ensures deprecated codes are not used in active maintenance workflows.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:failureCategory rdf:type rdf:Property ;
    rdfs:label 'Failure Category' ;
    rdfs:comment 'High-level classification grouping failure modes by the nature of the failure mechanism. Drives routing of work orders to the appropriate technician skill set and supports trend analysis by failure type. [ENUM-REF-CANDIDATE: mechanical|electrical|hydraulic|structural|operator_induced|pneumatic|software — promote to reference product if additional categories are needed]' ;
    rdfs:domain ind:FailureMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureCode rdf:type rdf:Property ;
    rdfs:label 'Failure Code' ;
    rdfs:comment 'Standardized alphanumeric code uniquely identifying the failure mode within the enterprise catalog. Used as the externally-known business identifier on work orders, repair records, and FMEA documentation. Sourced from Infor EAM failure code configuration.' ;
    rdfs:domain ind:FailureMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureDescription rdf:type rdf:Property ;
    rdfs:label 'Failure Description' ;
    rdfs:comment 'Detailed narrative describing the nature of the failure, observable symptoms, and conditions under which it typically occurs. Provides technicians and engineers with sufficient context to identify and classify the failure accurately in the field.' ;
    rdfs:domain ind:FailureMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureModeGroup rdf:type rdf:Property ;
    rdfs:label 'Failure Mode Group' ;
    rdfs:comment 'Logical grouping of related failure modes for reporting and analysis purposes (e.g., \'Powertrain Failures\', \'Body and Compactor Failures\', \'Hydraulic System Failures\', \'Containment Failures\'). Supports roll-up reporting in maintenance dashboards and FMEA analysis by system group.' ;
    rdfs:domain ind:FailureMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureModeStatus rdf:type rdf:Property ;
    rdfs:label 'Failure Mode Status' ;
    rdfs:comment 'Current lifecycle status of the failure mode record in the enterprise catalog. Active records are available for selection on work orders and PM schedules. Inactive or deprecated records are retained for historical reporting but cannot be assigned to new work orders.' ;
    rdfs:domain ind:FailureMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failureName rdf:type rdf:Property ;
    rdfs:label 'Failure Name' ;
    rdfs:comment 'Short, human-readable name for the failure mode (e.g., \'Hydraulic Hose Burst\', \'Brake Pad Wear\', \'Electrical Short Circuit\'). Used as the identity label in work order dropdowns, dashboards, and maintenance reports.' ;
    rdfs:domain ind:FailureMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fmeaDetectabilityScore rdf:type rdf:Property ;
    rdfs:label 'Fmea Detectability Score' ;
    rdfs:comment 'FMEA detectability rating on a 1-10 scale representing the ability of current inspection and monitoring controls to detect the failure before it causes asset breakdown. Score of 10 indicates the failure is virtually undetectable. Component of the RPN calculation.' ;
    rdfs:domain ind:FailureMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fmeaOccurrenceScore rdf:type rdf:Property ;
    rdfs:label 'Fmea Occurrence Score' ;
    rdfs:comment 'FMEA occurrence rating on a 1-10 scale representing the likelihood of this failure mode occurring within a given operating period. Score of 10 indicates near-certain occurrence. Derived from historical work order frequency data and OEM reliability data. Component of the RPN calculation.' ;
    rdfs:domain ind:FailureMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fmeaRpn rdf:type rdf:Property ;
    rdfs:label 'Fmea Rpn' ;
    rdfs:comment 'Composite risk score calculated as the product of Severity, Occurrence, and Detectability ratings (each 1-10) per FMEA methodology. Range 1-1000. Higher RPN values indicate higher priority for preventive maintenance investment and engineering redesign. Maintained by reliability engineering and reviewed during PM optimization cycles.' ;
    rdfs:domain ind:FailureMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fmeaSeverityScore rdf:type rdf:Property ;
    rdfs:label 'Fmea Severity Score' ;
    rdfs:comment 'FMEA severity rating on a 1-10 scale representing the seriousness of the failure effect on asset function, safety, or regulatory compliance. Score of 10 indicates catastrophic safety or environmental impact. Component of the RPN calculation.' ;
    rdfs:domain ind:FailureMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hazmatFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Flag' ;
    rdfs:comment 'Indicates whether repair of this failure mode involves handling, containment, or disposal of hazardous materials (e.g., hydraulic fluid, refrigerants, battery acid, leachate). When true, triggers hazardous waste handling procedures and DOT/EPA hazmat compliance workflows.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:industryStandardCode rdf:type rdf:Property ;
    rdfs:label 'Industry Standard Code' ;
    rdfs:comment 'External industry standard code that maps this failure mode to a recognized classification system beyond VMRS (e.g., ISO 14224 failure mechanism code, SWANA equipment failure taxonomy, or OEM-specific fault code). Enables cross-system benchmarking and regulatory reporting alignment.' ;
    rdfs:domain ind:FailureMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meanTimeBetweenFailures rdf:type rdf:Property ;
    rdfs:label 'Mean Time Between Failures' ;
    rdfs:comment 'Average operating hours between occurrences of this failure mode across the asset population, expressed in hours. Derived from historical work order data and used to calibrate PM interval recommendations and reliability forecasting models. Null for newly cataloged failure modes with insufficient history.' ;
    rdfs:domain ind:FailureMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:meanTimeToRepair rdf:type rdf:Property ;
    rdfs:label 'Mean Time To Repair' ;
    rdfs:comment 'Average labor hours required to diagnose and repair this failure mode, expressed in hours. Used for maintenance scheduling, technician capacity planning, and downtime impact estimation on work orders. Derived from actual labor hours recorded in Infor EAM and SAP PM work order history.' ;
    rdfs:domain ind:FailureMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:obdFaultCode rdf:type rdf:Property ;
    rdfs:label 'Obd Fault Code' ;
    rdfs:comment 'SAE J1939 or OBD-II diagnostic trouble code (DTC) associated with this failure mode for fleet assets. Enables automatic failure mode classification from telematics fault code alerts received via Geotab. Null for non-fleet or non-electronic failure modes.' ;
    rdfs:domain ind:FailureMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pmTriggerFlag rdf:type rdf:Property ;
    rdfs:label 'Pm Trigger Flag' ;
    rdfs:comment 'Indicates whether detection of this failure mode should automatically trigger creation of a preventive maintenance work order or PM schedule review. Supports proactive maintenance strategy by escalating recurring failure patterns to PM program adjustments.' ;
    rdfs:domain ind:FailureMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recommendedCorrectiveAction rdf:type rdf:Property ;
    rdfs:label 'Recommended Corrective Action' ;
    rdfs:comment 'Standardized guidance on the preferred corrective maintenance action to resolve this failure mode (e.g., \'Replace hydraulic hose assembly\', \'Inspect and replace brake pads\', \'Perform electrical continuity test and rewire\'). Used to pre-populate work order task instructions and support technician decision-making.' ;
    rdfs:domain ind:FailureMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recurrenceRisk rdf:type rdf:Property ;
    rdfs:label 'Recurrence Risk' ;
    rdfs:comment 'Assessed likelihood that this failure mode will recur on the same asset within 90 days of repair if only corrective action is taken without addressing the root cause. High recurrence risk failure modes are flagged for root cause analysis and PM program review.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewDate rdf:type rdf:Property ;
    rdfs:label 'Review Date' ;
    rdfs:comment 'Date on which this failure mode record was last reviewed by reliability engineering for accuracy, relevance, and FMEA score currency. Supports periodic catalog maintenance governance and ensures failure mode data quality for analytics and AI/ML applications.' ;
    rdfs:domain ind:FailureMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewedBy rdf:type rdf:Property ;
    rdfs:label 'Reviewed By' ;
    rdfs:comment 'Name or employee identifier of the reliability engineer or maintenance manager who last reviewed and approved this failure mode record for catalog inclusion. Supports quality assurance and change management governance for the failure mode catalog.' ;
    rdfs:domain ind:FailureMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Risk Flag' ;
    rdfs:comment 'Indicates whether this failure mode presents a direct safety risk to operators, technicians, or the public. When true, triggers mandatory safety review, LOTO (Lockout/Tagout) procedures, and potential DOT out-of-service designation on associated work orders. Supports OSHA and DOT compliance workflows.' ;
    rdfs:domain ind:FailureMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:typicalRootCause rdf:type rdf:Property ;
    rdfs:label 'Typical Root Cause' ;
    rdfs:comment 'Narrative description of the most common underlying root cause(s) associated with this failure mode (e.g., \'Lack of lubrication\', \'Fatigue cracking due to overloading\', \'Corrosion from leachate exposure\'). Supports root cause analysis (RCA) and FMEA documentation. Populated by maintenance engineering based on historical repair data.' ;
    rdfs:domain ind:FailureMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vmrsCode rdf:type rdf:Property ;
    rdfs:label 'Vmrs Code' ;
    rdfs:comment 'Industry-standard VMRS code mapping this failure mode to the American Trucking Associations Vehicle Maintenance Reporting Standards taxonomy. Enables benchmarking against industry fleet maintenance data, DOT compliance reporting, and interoperability with fleet telematics systems such as Geotab. Null for non-fleet (facility) failure modes.' ;
    rdfs:domain ind:FailureMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Warranty Impact Flag' ;
    rdfs:comment 'Indicates whether this failure mode may be covered under OEM or vendor warranty, triggering warranty claim initiation in SAP MM. When true, work orders associated with this failure mode are flagged for warranty review before parts are charged to the maintenance cost center.' ;
    rdfs:domain ind:FailureMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Approval Required Flag' ;
    rdfs:comment 'Indicates whether work orders of this maintenance type require supervisory or management approval before execution (True) or can be executed without prior approval (False). Drives approval workflow routing in SAP PM and Infor EAM for cost control and compliance.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvalThresholdUsd rdf:type rdf:Property ;
    rdfs:label 'Approval Threshold Usd' ;
    rdfs:comment 'Minimum estimated cost in US dollars above which a work order of this maintenance type requires management approval. Supports tiered authorization controls for maintenance spend in compliance with SOX internal control requirements.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:avgLaborCostUsd rdf:type rdf:Property ;
    rdfs:label 'Avg Labor Cost Usd' ;
    rdfs:comment 'Standard average labor cost for a maintenance activity of this type, expressed in US dollars. Derived from technician labor rates and estimated duration. Used for work order cost estimation, maintenance budget planning, and COGS reporting.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:avgPartsCostUsd rdf:type rdf:Property ;
    rdfs:label 'Avg Parts Cost Usd' ;
    rdfs:comment 'Standard average cost of parts and materials consumed for a maintenance activity of this type, expressed in US dollars. Used for maintenance budget planning, work order cost estimation, and BOM cost benchmarking in SAP MM and Infor EAM.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Cost Category Code' ;
    rdfs:comment 'Maps this maintenance type to a cost accounting category in SAP FI/CO for GL posting and COGS allocation (e.g., PREV_MAINT, CORR_MAINT, EMER_MAINT, DOT_INSP, WARRANTY). Enables financial reporting by maintenance type and supports EBITDA analysis for fleet operations.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultPriorityCode rdf:type rdf:Property ;
    rdfs:label 'Default Priority Code' ;
    rdfs:comment 'Default work order priority assigned when a work order is created under this maintenance type. Drives scheduling urgency, technician dispatch sequencing, and SLA compliance tracking. Can be overridden at the individual work order level.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eamTypeCode rdf:type rdf:Property ;
    rdfs:label 'Eam Type Code' ;
    rdfs:comment 'Native maintenance type code as defined in Infor EAM, used for system integration and data lineage tracing. Enables bidirectional synchronization between the lakehouse silver layer and the Infor EAM CMMS source system.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalServiceFlag rdf:type rdf:Property ;
    rdfs:label 'External Service Flag' ;
    rdfs:comment 'Indicates whether maintenance activities of this type are typically performed by an external vendor or contractor (True) rather than internal technicians (False). When True, triggers purchase order (PO) creation workflow in SAP MM for external service procurement.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:failureModeApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Failure Mode Applicable Flag' ;
    rdfs:comment 'Indicates whether failure mode and root cause analysis is required for work orders of this maintenance type (True) or not (False). When True, technicians must document failure codes, cause codes, and remediation actions in Infor EAM for reliability-centered maintenance (RCM) analysis.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ghgReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Ghg Reporting Flag' ;
    rdfs:comment 'Indicates whether maintenance activities of this type generate reportable GHG emissions data (True) or not (False). Applicable for maintenance involving CNG/RNG fuel systems, LFG equipment, or WTE facility assets where EPA GHG reporting under the Clean Air Act is required.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxAllowableDowntimeHours rdf:type rdf:Property ;
    rdfs:label 'Max Allowable Downtime Hours' ;
    rdfs:comment 'Maximum number of hours an asset is permitted to remain out of service for maintenance of this type before escalation is triggered. Used to enforce SLA compliance for fleet availability and to drive escalation workflows in Infor EAM and AMCS dispatch.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planningLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Planning Lead Time Days' ;
    rdfs:comment 'Standard number of calendar days required to plan and prepare for a maintenance activity of this type before execution. Used by maintenance planners to schedule parts procurement, technician availability, and asset downtime windows. Sourced from Infor EAM PM cycle configuration.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pmTriggerBasis rdf:type rdf:Property ;
    rdfs:label 'Pm Trigger Basis' ;
    rdfs:comment 'Defines the basis on which PM schedules of this maintenance type are triggered: time-based (fixed calendar intervals), meter-based (mileage, engine hours, cycles), condition-based (sensor thresholds), event-based (after specific operational events), or calendar-based (fixed dates). Drives PM cycle configuration in Infor EAM.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recurrenceIntervalDays rdf:type rdf:Property ;
    rdfs:label 'Recurrence Interval Days' ;
    rdfs:comment 'Default calendar-based recurrence interval in days for PM schedules of this maintenance type. Used when pm_trigger_basis is \'time\' or \'calendar\'. Drives automatic PM work order generation in Infor EAM and SAP PM scheduling cycles.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recurrenceIntervalMeter rdf:type rdf:Property ;
    rdfs:label 'Recurrence Interval Meter' ;
    rdfs:comment 'Default meter-based recurrence interval for PM schedules of this maintenance type (e.g., miles, engine hours, lift cycles). Used when pm_trigger_basis is \'meter\'. The unit of measure is defined by meter_unit. Drives meter-based PM work order generation in Infor EAM.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Flag' ;
    rdfs:comment 'Indicates whether maintenance activities of this type must be reported to a regulatory authority (True) or not (False). Triggers mandatory documentation workflows in Enviance EHS and SAP EHS for DOT inspections, EPA compliance events, and OSHA-required maintenance records.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiredCertificationCode rdf:type rdf:Property ;
    rdfs:label 'Required Certification Code' ;
    rdfs:comment 'Code identifying the specific technician certification required to perform maintenance of this type (e.g., CDL_CLASS_A, ASE_MASTER, DOT_INSPECTOR, HAZMAT_HANDLER). Enforced during work order technician assignment in Infor EAM and Workday HCM. Applicable when requires_certified_technician is True.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresAssetShutdown rdf:type rdf:Property ;
    rdfs:label 'Requires Asset Shutdown' ;
    rdfs:comment 'Indicates whether maintenance of this type requires the asset (vehicle, equipment, or facility) to be taken out of service (True) or can be performed while the asset remains operational (False). Drives downtime planning and route coverage adjustments in AMCS and Locus Dispatch.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresCertifiedTechnician rdf:type rdf:Property ;
    rdfs:label 'Requires Certified Technician' ;
    rdfs:comment 'Indicates whether maintenance activities of this type must be performed by a technician holding a specific certification (True) or can be performed by any qualified technician (False). When True, the required_certification_code field specifies the certification. Supports CDL, ASE, and DOT certification enforcement.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sapOrderTypeCode rdf:type rdf:Property ;
    rdfs:label 'Sap Order Type Code' ;
    rdfs:comment 'SAP PM order type code corresponding to this maintenance type (e.g., PM01, PM02, PM03). Used for GL posting, cost settlement, and integration with SAP FI/CO for maintenance cost reporting and EBITDA analysis.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:typeCategory rdf:type rdf:Property ;
    rdfs:label 'Type Category' ;
    rdfs:comment 'High-level grouping of the maintenance type indicating whether the activity is planned (scheduled in advance), unplanned (reactive/emergency), regulatory (DOT/EPA/OSHA mandated), or warranty (covered under manufacturer or service warranty). Supports cost allocation and KPI segmentation.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:typeCode rdf:type rdf:Property ;
    rdfs:label 'Type Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the maintenance type, used as a business key across work orders, PM schedules, and reporting systems (e.g., PREV, CORR, PRED, EMER, CBM, DOT, WARR, RBLD). Sourced from Infor EAM and SAP PM type classification.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:typeDescription rdf:type rdf:Property ;
    rdfs:label 'Type Description' ;
    rdfs:comment 'Detailed narrative explaining the purpose, scope, and application of this maintenance type. Provides guidance to planners and technicians on when and how to apply this classification across fleet vehicles, containers, and facility assets.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:typeName rdf:type rdf:Property ;
    rdfs:label 'Type Name' ;
    rdfs:comment 'Full descriptive name of the maintenance type as recognized across fleet and facility operations (e.g., Preventive, Corrective, Predictive, Emergency, Condition-Based, DOT Inspection, Warranty, Rebuild). Used in work order displays, PM schedule labels, and management reporting.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:typeStatus rdf:type rdf:Property ;
    rdfs:label 'Type Status' ;
    rdfs:comment 'Current lifecycle status of the maintenance type record indicating whether it is actively used in work order and PM schedule creation (active), temporarily disabled (inactive), or retired from use (deprecated). Controls availability in downstream scheduling and dispatch systems.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Warranty Applicable Flag' ;
    rdfs:comment 'Indicates whether maintenance activities of this type may be covered under an OEM or service warranty (True) or are not warranty-eligible (False). When True, triggers warranty claim validation workflow in Infor EAM before cost posting to internal cost centers.' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workOrderClass rdf:type rdf:Property ;
    rdfs:label 'Work Order Class' ;
    rdfs:comment 'SAP PM and Infor EAM work order class associated with this maintenance type. Determines the work order processing workflow, approval routing, and cost settlement rules. Maps directly to the order type configuration in SAP PM (e.g., PM01 Corrective, PM02 Preventive, PM03 Inspection).' ;
    rdfs:domain ind:Type ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epaFacilityId rdf:type rdf:Property ;
    rdfs:label 'Epa Facility Id' ;
    rdfs:comment 'EPA-assigned facility identifier registered in the EPA Facility Registry System (FRS). Required for federal environmental reporting, RCRA compliance submissions, and EPA inspection records. Serves as the federal regulatory identity of the facility.' ;
    rdfs:domain ind:MrfFacility ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:acceptsCdWaste rdf:type rdf:Property ;
    rdfs:label 'Accepts Cd Waste' ;
    rdfs:comment 'Indicates whether the MRF facility is permitted and equipped to process Construction and Demolition (C&D) waste streams including concrete, wood, drywall, and metals. C&D processing requires specialized equipment and separate permit conditions.' ;
    rdfs:domain ind:MrfFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:acceptsCommercial rdf:type rdf:Property ;
    rdfs:label 'Accepts Commercial' ;
    rdfs:comment 'Indicates whether the MRF facility is permitted and equipped to accept commercial and industrial recyclable materials. Drives commercial hauling route assignments in AMCS and contract eligibility in Salesforce CRM.' ;
    rdfs:domain ind:MrfFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:acceptsResidential rdf:type rdf:Property ;
    rdfs:label 'Accepts Residential' ;
    rdfs:comment 'Indicates whether the MRF facility is permitted and equipped to accept residential curbside recyclable materials. Drives routing logic in AMCS and service enrollment eligibility in Waste Logics.' ;
    rdfs:domain ind:MrfFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:balingLineCount rdf:type rdf:Property ;
    rdfs:label 'Baling Line Count' ;
    rdfs:comment 'Number of baling lines (balers) at the MRF facility used to compress and bind recovered commodities (paper, plastics, metals) into marketable bales. Determines bale production capacity and influences commodity sales throughput.' ;
    rdfs:domain ind:MrfFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:commissionedDate rdf:type rdf:Property ;
    rdfs:label 'Commissioned Date' ;
    rdfs:comment 'Date on which the MRF facility was officially commissioned and began commercial operations. Used for asset age calculations, depreciation schedules, permit anniversary tracking, and capital planning.' ;
    rdfs:domain ind:MrfFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:county rdf:type rdf:Property ;
    rdfs:label 'County' ;
    rdfs:comment 'County in which the MRF facility is located. Relevant for Local Enforcement Agency (LEA) jurisdiction, county solid waste authority reporting, and local permit compliance under SWIS.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designCapacityTpd rdf:type rdf:Property ;
    rdfs:label 'Design Capacity Tpd' ;
    rdfs:comment 'Engineering-designed maximum daily throughput capacity in tons per day (TPD) as specified in the facility\'s original design documentation. May differ from permitted capacity due to regulatory limits or operational constraints. Used for capital planning and equipment sizing.' ;
    rdfs:domain ind:MrfFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:facilityCode rdf:type rdf:Property ;
    rdfs:label 'Facility Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the MRF facility, used in operational systems (AMCS, SAP MM), regulatory submissions, and inter-system integration. Format: MRF-[STATE]-[SEQUENCE].' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityName rdf:type rdf:Property ;
    rdfs:label 'Facility Name' ;
    rdfs:comment 'Official human-readable name of the MRF facility as registered with regulatory authorities and used in customer-facing communications, contracts, and reporting (e.g., \'Houston North MRF\').' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityType rdf:type rdf:Property ;
    rdfs:label 'Facility Type' ;
    rdfs:comment 'Classification of the MRF by processing methodology. Single-stream accepts all recyclables commingled; dual-stream separates fiber from containers; mixed-waste MRF processes unsorted MSW; source-separated handles pre-sorted materials; drop-off serves public drop-off programs.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iso14001Certified rdf:type rdf:Property ;
    rdfs:label 'Iso 14001 Certified' ;
    rdfs:comment 'Indicates whether the MRF facility holds a current ISO 14001 Environmental Management System certification. ISO 14001 certification demonstrates systematic environmental management and is required for certain municipal contracts and sustainability reporting.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iso45001Certified rdf:type rdf:Property ;
    rdfs:label 'Iso 45001 Certified' ;
    rdfs:comment 'Indicates whether the MRF facility holds a current ISO 45001 Occupational Health and Safety Management System certification. Relevant for OSHA compliance, worker safety programs, and contract qualification requirements.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxContaminationRatePct rdf:type rdf:Property ;
    rdfs:label 'Max Contamination Rate Pct' ;
    rdfs:comment 'Maximum allowable contamination rate percentage for outbound commodity bales as specified in commodity offtake contracts and quality standards. Exceeding this threshold may result in load rejection, price penalties, or contract violations. Used in quality control and commodity sales management.' ;
    rdfs:domain ind:Recycling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatingDays rdf:type rdf:Property ;
    rdfs:label 'Operating Days' ;
    rdfs:comment 'Comma-separated list of days of the week the MRF facility operates (e.g., \'MON,TUE,WED,THU,FRI,SAT\'). Used for route scheduling in AMCS, customer service availability, and workforce planning in Workday HCM.' ;
    rdfs:domain ind:MrfFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingHoursEnd rdf:type rdf:Property ;
    rdfs:label 'Operating Hours End' ;
    rdfs:comment 'Standard daily end time for MRF facility operations in HH:MM (24-hour) format. Used for inbound vehicle scheduling, tipping fee window management in Oracle Revenue Management, and AMCS route dispatch timing.' ;
    rdfs:domain ind:MrfFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingHoursStart rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Start' ;
    rdfs:comment 'Standard daily start time for MRF facility operations in HH:MM (24-hour) format. Used for inbound vehicle scheduling, tipping fee window management in Oracle Revenue Management, and AMCS route dispatch timing.' ;
    rdfs:domain ind:MrfFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationalStatus rdf:type rdf:Property ;
    rdfs:label 'Operational Status' ;
    rdfs:comment 'Current lifecycle state of the MRF facility. Active indicates full operations; temporarily_closed covers planned or unplanned shutdowns; decommissioned indicates permanent closure; permitted_not_operating indicates permit held but no active processing. [ENUM-REF-CANDIDATE: active|inactive|under_construction|temporarily_closed|decommissioned|permitted_not_operating — promote to reference product]' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:opticalSorterCount rdf:type rdf:Property ;
    rdfs:label 'Optical Sorter Count' ;
    rdfs:comment 'Number of optical sorting units (near-infrared or AI-vision sorters) installed at the facility for automated material identification and separation. Indicates automation level, influences contamination rates, and is tracked in Infor EAM for maintenance scheduling.' ;
    rdfs:domain ind:Recycling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ownershipType rdf:type rdf:Property ;
    rdfs:label 'Ownership Type' ;
    rdfs:comment 'Indicates the ownership or operational arrangement for the facility. Company-owned assets are on Waste Management\'s balance sheet; leased facilities carry lease obligations; joint ventures involve shared ownership; contracted facilities are operated under service agreements with municipalities or third parties.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permittedCapacityTpd rdf:type rdf:Property ;
    rdfs:label 'Permitted Capacity Tpd' ;
    rdfs:comment 'Maximum permitted daily processing throughput in tons per day (TPD) as authorized by the facility\'s state environmental permit. This is the regulatory ceiling for inbound material acceptance and is used for compliance monitoring, capacity planning, and diversion rate reporting.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plantCode rdf:type rdf:Property ;
    rdfs:label 'Plant Code' ;
    rdfs:comment 'SAP S/4HANA MM plant code corresponding to this MRF facility. Used for inventory management of recovered commodities, purchase orders (PO) for consumables, and materials management integration between the MRF and SAP MM module.' ;
    rdfs:domain ind:Recycling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionCode rdf:type rdf:Property ;
    rdfs:label 'Region Code' ;
    rdfs:comment 'Internal Waste Management operational region code to which this MRF facility is assigned (e.g., \'SOUTH\', \'NORTHEAST\', \'WEST\'). Used for regional performance reporting, P&L allocation in SAP FI/CO, and organizational hierarchy management.' ;
    rdfs:domain ind:Recycling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sortLineCount rdf:type rdf:Property ;
    rdfs:label 'Sort Line Count' ;
    rdfs:comment 'Number of active sorting lines (conveyor-based manual or automated sort systems) at the MRF facility. Directly determines sorting throughput capacity and staffing requirements. Used in capacity planning and equipment maintenance scheduling in Infor EAM.' ;
    rdfs:domain ind:MrfFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stateCode rdf:type rdf:Property ;
    rdfs:label 'State Code' ;
    rdfs:comment 'Two-letter USPS state abbreviation for the state in which the MRF facility is located. Determines applicable state environmental regulations, permit requirements, and reporting jurisdictions.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageCapacityTons rdf:type rdf:Property ;
    rdfs:label 'Storage Capacity Tons' ;
    rdfs:comment 'Maximum on-site storage capacity in tons for processed and baled commodities awaiting outbound shipment. Used for inventory management in SAP MM, commodity sales scheduling, and market timing decisions.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetDiversionRatePct rdf:type rdf:Property ;
    rdfs:label 'Target Diversion Rate Pct' ;
    rdfs:comment 'Facility-level target percentage of inbound material weight that is successfully recovered and diverted from landfill disposal. Expressed as a percentage (0-100). Used as a KPI benchmark for operational performance, EPA recycling reporting, and sustainability goal tracking.' ;
    rdfs:domain ind:MrfFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tippingFloorAreaSqft rdf:type rdf:Property ;
    rdfs:label 'Tipping Floor Area Sqft' ;
    rdfs:comment 'Total area of the tipping floor in square feet where inbound recyclable materials are unloaded from collection vehicles. Determines maximum simultaneous unloading capacity and influences throughput planning and safety compliance under OSHA.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalFloorAreaSqft rdf:type rdf:Property ;
    rdfs:label 'Total Floor Area Sqft' ;
    rdfs:comment 'Total enclosed floor area of the MRF facility building in square feet, including tipping floor, sort lines, baling area, storage, and office space. Used for property tax assessments, lease calculations, and facility planning.' ;
    rdfs:domain ind:MrfFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingTippingFeeScheduleId rdf:type rdf:Property ;
    rdfs:label 'Billing Tipping Fee Schedule Id' ;
    rdfs:comment 'Foreign key linking to billing.billing_tipping_fee_schedule. Business justification: Each inbound load is assessed a tipping fee using a specific fee schedule. Linking inbound_load to billing_tipping_fee_schedule enables fee audit trails, rate change impact analysis, and billing dispu' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BillingTippingFeeSchedule .

ind:generatorEpaIdRegistrationId rdf:type rdf:Property ;
    rdfs:label 'Generator Epa Id Registration Id' ;
    rdfs:comment 'Foreign key linking to hazmat.epa_id_registration. Business justification: MRFs receiving contaminated loads from generators must track EPA ID registrations for regulatory compliance and enforcement. When hazardous contamination exceeds thresholds, generator EPA ID is requir' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EpaIdRegistration .

ind:wasteAcceptancePermitId rdf:type rdf:Property ;
    rdfs:label 'Waste Acceptance Permit Id' ;
    rdfs:comment 'Foreign key linking to compliance.permit. Business justification: Inbound loads must comply with facility waste acceptance permits specifying allowed material types, contamination limits, and capacity thresholds. Critical for scale house permit verification and regu' ;
    rdfs:domain ind:InboundLoad ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Permit .

ind:wasteCodeId rdf:type rdf:Property ;
    rdfs:label 'Waste Code Id' ;
    rdfs:comment 'Foreign key linking to hazmat.waste_code. Business justification: Inbound loads containing hazardous fractions (contamination_type, material_stream_type) require RCRA waste code classification for regulatory compliance, proper routing decisions, and manifest prepara' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WasteCode .

ind:amcsLoadReference rdf:type rdf:Property ;
    rdfs:label 'Amcs Load Reference' ;
    rdfs:comment 'Reference identifier from the AMCS Platform linking this MRF inbound load record to the originating route dispatch and collection event. Enables route-to-MRF load reconciliation and confirms that collected materials were delivered to the correct facility.' ;
    rdfs:domain ind:InboundLoad ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billOfLadingNumber rdf:type rdf:Property ;
    rdfs:label 'Bill Of Lading Number' ;
    rdfs:comment 'Bill of Lading number associated with this inbound load, used for third-party hauler loads and transfer station deliveries. Provides chain-of-custody documentation and supports SAP MM goods receipt matching.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contaminationFlag rdf:type rdf:Property ;
    rdfs:label 'Contamination Flag' ;
    rdfs:comment 'Indicates whether the inbound load was visually identified as contaminated at the time of receipt. True = contamination detected; False = load appears clean. Triggers contamination workflow including surcharge assessment, customer notification, and Enviance EHS incident logging if contamination exceeds threshold.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contaminationPct rdf:type rdf:Property ;
    rdfs:label 'Contamination Pct' ;
    rdfs:comment 'Initial visual estimate of contamination level as a percentage of total load volume, assessed by the MRF receiving operator at the tipping floor. Expressed as 0.00 to 100.00. Used for contamination trending, customer education programs, and EPA recycling quality reporting. Formal contamination rate may be updated after sort audit.' ;
    rdfs:domain ind:Recycling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contaminationSurcharge rdf:type rdf:Property ;
    rdfs:label 'Contamination Surcharge' ;
    rdfs:comment 'Additional fee assessed on this load due to contamination exceeding the contractual threshold, expressed in US dollars. Applied per customer contract terms when contamination percentage exceeds the agreed acceptable contamination rate. Posted to Oracle Revenue Management for billing.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contaminationType rdf:type rdf:Property ;
    rdfs:label 'Contamination Type' ;
    rdfs:comment 'Primary category of contamination identified in the load (e.g., food waste, hazardous materials, non-recyclable plastics, bagged recyclables, electronics, textiles, medical waste). Used for contamination root cause analysis and targeted customer outreach. [ENUM-REF-CANDIDATE: food_waste|hazardous|non_recyclable_plastic|bagged_recyclables|electronics|textiles|medical_waste|other — promote to reference product]' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedDiversionTons rdf:type rdf:Property ;
    rdfs:label 'Estimated Diversion Tons' ;
    rdfs:comment 'Estimated tonnage of this load that is expected to be diverted from landfill through recycling or recovery, based on material stream type and historical contamination-adjusted yield rates. Expressed in short tons. Used for real-time diversion rate tracking and EPA recycling program reporting. Distinct from actual recovered commodity weight which is captured at bale production.' ;
    rdfs:domain ind:InboundLoad ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossWeightTons rdf:type rdf:Property ;
    rdfs:label 'Gross Weight Tons' ;
    rdfs:comment 'Total weight of the loaded vehicle as measured at the MRF inbound scale, expressed in short tons. Gross weight is the first weigh-in measurement before tare deduction. Critical for Tons Per Day (TPD) throughput reporting and tipping fee calculation.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isAudited rdf:type rdf:Property ;
    rdfs:label 'Is Audited' ;
    rdfs:comment 'Indicates whether this inbound load has been selected for and completed a formal sort audit or waste characterization study. True = audit completed. Sort audits are used to validate contamination estimates, measure commodity composition, and support EPA recycling program reporting accuracy.' ;
    rdfs:domain ind:InboundLoad ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loadNotes rdf:type rdf:Property ;
    rdfs:label 'Load Notes' ;
    rdfs:comment 'Free-text field for scale operator or supervisor notes regarding this inbound load. May include observations about load quality, unusual materials, driver communications, or special handling instructions. Supports operational exception management.' ;
    rdfs:domain ind:InboundLoad ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadSourceType rdf:type rdf:Property ;
    rdfs:label 'Load Source Type' ;
    rdfs:comment 'Classification of how the load arrived at the MRF. \'direct_haul\' = collection vehicle delivering directly from route; \'transfer_station\' = consolidated load from a transfer station; \'drop_off_center\' = aggregated materials from a public drop-off facility; \'special_event\' = community recycling event; \'third_party_hauler\' = independent hauler delivering under contract.' ;
    rdfs:domain ind:InboundLoad ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadStatus rdf:type rdf:Property ;
    rdfs:label 'Load Status' ;
    rdfs:comment 'Current workflow state of the inbound load record. \'received\' = weighed and logged at scale; \'accepted\' = cleared for processing; \'rejected\' = refused entry (contamination, wrong material, etc.); \'pending_review\' = flagged for supervisor review; \'posted\' = SAP MM material receipt posted; \'voided\' = record cancelled.' ;
    rdfs:domain ind:InboundLoad ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manifestNumber rdf:type rdf:Property ;
    rdfs:label 'Manifest Number' ;
    rdfs:comment 'Hazardous waste tracking manifest number, if applicable. Required under RCRA for loads containing any hazardous waste fraction. Null for standard recyclable loads. Links to Enviance EHS manifest tracking for regulatory compliance.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netWeightTons rdf:type rdf:Property ;
    rdfs:label 'Net Weight Tons' ;
    rdfs:comment 'Net weight of the inbound material load, calculated as gross weight minus tare weight, expressed in short tons. This is the primary tonnage figure used for TPD throughput reporting, tipping fee billing, diversion rate calculations, and SAP MM material receipt posting.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processingShift rdf:type rdf:Property ;
    rdfs:label 'Processing Shift' ;
    rdfs:comment 'Work shift during which this inbound load was received and processed at the MRF. Used for shift-level throughput reporting, labor allocation, and operational performance benchmarking.' ;
    rdfs:domain ind:InboundLoad ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingDock rdf:type rdf:Property ;
    rdfs:label 'Receiving Dock' ;
    rdfs:comment 'Identifier of the MRF tipping floor dock or bay assigned to receive this load. Used for floor traffic management, sorting line assignment, and operational throughput balancing across dock positions.' ;
    rdfs:domain ind:InboundLoad ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionReason rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason' ;
    rdfs:comment 'Reason code or description explaining why a load was rejected at the MRF gate. Populated only when load_status = \'rejected\'. Common reasons include excessive contamination, prohibited materials, missing documentation, or capacity constraints. [ENUM-REF-CANDIDATE: excessive_contamination|prohibited_materials|missing_documentation|capacity_exceeded|wrong_material_type|hazardous_detected|other — promote to reference product]' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapMaterialDocNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Material Doc Number' ;
    rdfs:comment 'SAP MM material document number generated upon goods receipt posting for this inbound load. Confirms the load has been formally received into SAP inventory management. Null until load_status = \'posted\'. Enables reconciliation between MRF scale records and SAP MM inventory.' ;
    rdfs:domain ind:InboundLoad ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scaleTicketNumber rdf:type rdf:Property ;
    rdfs:label 'Scale Ticket Number' ;
    rdfs:comment 'Externally-visible scale house ticket number assigned at the weigh station upon load receipt. Used as the primary operational reference for load reconciliation between the MRF, hauling contractor, and SAP MM material receipt posting. Printed on the physical scale ticket given to the driver.' ;
    rdfs:domain ind:InboundLoad ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supervisorReviewFlag rdf:type rdf:Property ;
    rdfs:label 'Supervisor Review Flag' ;
    rdfs:comment 'Indicates whether this load record has been flagged for or has undergone supervisor review. True = supervisor review required or completed. Triggered by contamination above threshold, weight anomalies, rejected loads, or missing documentation.' ;
    rdfs:domain ind:InboundLoad ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supervisorReviewTimestamp rdf:type rdf:Property ;
    rdfs:label 'Supervisor Review Timestamp' ;
    rdfs:comment 'Date and time the supervisor completed review of this flagged load record. Null if supervisor_review_flag is False or review is pending. Used for SLA compliance on review turnaround and audit trail.' ;
    rdfs:domain ind:InboundLoad ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:tareWeightTons rdf:type rdf:Property ;
    rdfs:label 'Tare Weight Tons' ;
    rdfs:comment 'Weight of the empty hauling vehicle as measured at the MRF outbound scale after unloading, expressed in short tons. Used with gross weight to calculate net material weight. May be sourced from vehicle tare records if a second weigh is not performed.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tippingFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Tipping Fee Amount' ;
    rdfs:comment 'Total tipping fee charged for this inbound load in US dollars, calculated as net weight multiplied by the tipping fee rate. Represents the gross revenue amount for this load transaction. Posted to Oracle Revenue Management and SAP FI/CO for billing and GL recognition.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vehicleType rdf:type rdf:Property ;
    rdfs:label 'Vehicle Type' ;
    rdfs:comment 'Type of collection or hauling vehicle that delivered the load. ASL = Automated Side Loader; FEL = Front End Loader; REL = Rear End Loader; roll_off = roll-off container truck; transfer_trailer = semi-trailer from transfer station; rear_load = rear-loading compactor. Affects expected compaction ratio and material quality.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weatherCondition rdf:type rdf:Property ;
    rdfs:label 'Weather Condition' ;
    rdfs:comment 'Weather condition at the MRF at the time of load receipt. Used for operational analytics correlating weather with contamination rates, load volumes, and processing throughput. Supports capacity planning and seasonal trend analysis.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:airQualityPermitId rdf:type rdf:Property ;
    rdfs:label 'Air Quality Permit Id' ;
    rdfs:comment 'Foreign key linking to compliance.permit. Business justification: Sort lines operate under equipment-specific air quality permits governing particulate emissions, VOC controls, and operational parameters. Enables tracking of permit-mandated throughput limits, emissi' ;
    rdfs:domain ind:SortLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Permit .

ind:amcsLineReference rdf:type rdf:Property ;
    rdfs:label 'Amcs Line Reference' ;
    rdfs:comment 'Identifier used to reference this sort line within the AMCS Platform for recycling route management and material flow tracking integration. Enables cross-system reconciliation between MRF operations and collection route data.' ;
    rdfs:domain ind:SortLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:automationLevel rdf:type rdf:Property ;
    rdfs:label 'Automation Level' ;
    rdfs:comment 'Degree of automation on the sort line. Manual lines rely entirely on human sorters; semi-automated lines combine optical sorters or mechanical separators with manual quality control; fully automated lines use robotics and optical sorting with minimal human intervention.' ;
    rdfs:domain ind:SortLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:balerCount rdf:type rdf:Property ;
    rdfs:label 'Baler Count' ;
    rdfs:comment 'Number of baling machines installed on or directly serving this sort line. Balers compress recovered commodities into bales for outbound commodity sales. Affects throughput capacity and commodity output rates.' ;
    rdfs:domain ind:SortLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:commissioningDate rdf:type rdf:Property ;
    rdfs:label 'Commissioning Date' ;
    rdfs:comment 'Date on which the sort line was formally accepted into production operation following installation testing and validation. Marks the start of the operational lifecycle and warranty period.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:conveyorLengthM rdf:type rdf:Property ;
    rdfs:label 'Conveyor Length M' ;
    rdfs:comment 'Total length of the primary sort conveyor belt in meters. Used for maintenance planning (belt replacement scheduling), throughput modeling, and facility layout documentation.' ;
    rdfs:domain ind:SortLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conveyorSpeedMpm rdf:type rdf:Property ;
    rdfs:label 'Conveyor Speed Mpm' ;
    rdfs:comment 'Rated operating speed of the sort line conveyor belt in meters per minute (MPM). Directly affects sort quality and throughput rate; used in process optimization and OSHA ergonomic compliance for sorter workload assessment.' ;
    rdfs:domain ind:SortLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:designRecoveryRatePct rdf:type rdf:Property ;
    rdfs:label 'Design Recovery Rate Pct' ;
    rdfs:comment 'Engineered target material recovery rate expressed as a percentage of inbound material weight that is successfully recovered as saleable commodity. Used as the baseline for diversion rate reporting and performance benchmarking against EPA recycling goals.' ;
    rdfs:domain ind:SortLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:designThroughputTpd rdf:type rdf:Property ;
    rdfs:label 'Design Throughput Tpd' ;
    rdfs:comment 'Engineered design capacity of the sort line expressed in tons per day (TPD), calculated based on standard operating shift hours. Used for daily production planning, EPA recycling reporting, and diversion rate calculations.' ;
    rdfs:domain ind:SortLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:designThroughputTph rdf:type rdf:Property ;
    rdfs:label 'Design Throughput Tph' ;
    rdfs:comment 'Engineered design capacity of the sort line expressed in tons per hour (TPH). Represents the maximum rated processing rate under optimal conditions as specified by the equipment manufacturer or system integrator. Used for capacity planning and performance benchmarking.' ;
    rdfs:domain ind:SortLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dustSuppressionSystem rdf:type rdf:Property ;
    rdfs:label 'Dust Suppression System' ;
    rdfs:comment 'Indicates whether a dust suppression or dust collection system is installed on this sort line. Required for air quality compliance under the Clean Air Act and OSHA particulate matter exposure limits, particularly on glass and shredder lines.' ;
    rdfs:domain ind:SortLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eddyCurrentSeparatorCount rdf:type rdf:Property ;
    rdfs:label 'Eddy Current Separator Count' ;
    rdfs:comment 'Number of eddy current separator units installed on this sort line. Eddy current separators use magnetic induction to eject non-ferrous metals (aluminum, copper) from the material stream. Critical for aluminum recovery rates.' ;
    rdfs:domain ind:SortLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:equipmentCount rdf:type rdf:Property ;
    rdfs:label 'Equipment Count' ;
    rdfs:comment 'Total number of individual equipment assets installed on this sort line (e.g., balers, optical sorters, conveyors, eddy current separators, magnetic separators, shredders, glass breakers). Used for maintenance planning and asset inventory management.' ;
    rdfs:domain ind:SortLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fireSuppressionSystem rdf:type rdf:Property ;
    rdfs:label 'Fire Suppression System' ;
    rdfs:comment 'Indicates whether an automated fire suppression system (e.g., sprinkler, spark detection and suppression) is installed on this sort line. MRF sort lines processing paper and plastics carry elevated fire risk; fire suppression is required by NFPA 13 and local fire codes.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:floorAreaSqm rdf:type rdf:Property ;
    rdfs:label 'Floor Area Sqm' ;
    rdfs:comment 'Total floor area occupied by the sort line and its associated equipment in square meters. Used for facility layout planning, fire safety compliance, and OSHA egress requirement calculations.' ;
    rdfs:domain ind:SortLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:glassBreakerCount rdf:type rdf:Property ;
    rdfs:label 'Glass Breaker Count' ;
    rdfs:comment 'Number of glass breaking/crushing units installed on this sort line. Glass breakers reduce glass to cullet for downstream processing or disposal. Relevant for container sort lines processing single-stream material.' ;
    rdfs:domain ind:SortLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:installationDate rdf:type rdf:Property ;
    rdfs:label 'Installation Date' ;
    rdfs:comment 'Date on which the sort line was physically installed and commissioned at the facility. Used to calculate asset age, depreciation schedules, and to trigger lifecycle replacement planning.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastMajorOverhaulDate rdf:type rdf:Property ;
    rdfs:label 'Last Major Overhaul Date' ;
    rdfs:comment 'Date of the most recent major overhaul or capital refurbishment of the sort line. Used to assess remaining useful life, schedule next overhaul, and support capital expenditure planning.' ;
    rdfs:domain ind:SortLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lineCode rdf:type rdf:Property ;
    rdfs:label 'Line Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the sort line within the facility (e.g., MRF-SL-01, OCC-LINE-A). Used in operational communications, work orders, and reporting.' ;
    rdfs:domain ind:SortLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineName rdf:type rdf:Property ;
    rdfs:label 'Line Name' ;
    rdfs:comment 'Human-readable descriptive name for the sort line (e.g., \'OCC Pre-Sort Line 1\', \'Fiber Sorting Line B\'). Used in operational dashboards, maintenance scheduling, and facility floor plans.' ;
    rdfs:domain ind:SortLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineStatus rdf:type rdf:Property ;
    rdfs:label 'Line Status' ;
    rdfs:comment 'Current operational lifecycle status of the sort line. Active indicates normal production operation; maintenance indicates the line is taken offline for scheduled or unscheduled maintenance; commissioning indicates new installation under testing; decommissioned indicates permanently retired.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineType rdf:type rdf:Property ;
    rdfs:label 'Line Type' ;
    rdfs:comment 'Classification of the sort line by the material stream it processes. Pre-sort lines handle initial separation; OCC (Old Corrugated Cardboard) lines process cardboard; fiber lines handle paper; container lines process plastics, metals, and glass; residue lines handle non-recoverable material. [ENUM-REF-CANDIDATE: pre_sort|occ|fiber|container|residue|glass|mixed — promote to reference product]' ;
    rdfs:domain ind:SortLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:magneticSeparatorCount rdf:type rdf:Property ;
    rdfs:label 'Magnetic Separator Count' ;
    rdfs:comment 'Number of magnetic separator (overhead magnet or drum magnet) units installed on this sort line for ferrous metal recovery. Ferrous metal recovery rate is directly dependent on magnetic separator performance.' ;
    rdfs:domain ind:SortLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:manufacturer rdf:type rdf:Property ;
    rdfs:label 'Manufacturer' ;
    rdfs:comment 'Name of the original equipment manufacturer (OEM) who designed and built the sort line system (e.g., Machinex, Van Dyk, CP Group, Bollegraaf). Used for warranty management, spare parts sourcing, and technical support.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxContaminationPct rdf:type rdf:Property ;
    rdfs:label 'Max Contamination Pct' ;
    rdfs:comment 'Maximum acceptable contamination rate (percentage of non-target material in the output stream) for this sort line before commodity quality is rejected by buyers. Exceeding this threshold triggers quality control interventions and may affect commodity sale prices.' ;
    rdfs:domain ind:Recycling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modelNumber rdf:type rdf:Property ;
    rdfs:label 'Model Number' ;
    rdfs:comment 'Manufacturer\'s model designation for the sort line system. Used for spare parts identification, technical documentation retrieval, and warranty claims.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noiseLevelDb rdf:type rdf:Property ;
    rdfs:label 'Noise Level Db' ;
    rdfs:comment 'Rated operational noise level of the sort line in decibels (dB). Used for OSHA hearing conservation program compliance, PPE (Personal Protective Equipment) requirements determination, and facility noise permit compliance.' ;
    rdfs:domain ind:Recycling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatingShiftCount rdf:type rdf:Property ;
    rdfs:label 'Operating Shift Count' ;
    rdfs:comment 'Number of production shifts per day this sort line is designed to operate (typically 1, 2, or 3 shifts). Used for daily throughput capacity calculations, workforce scheduling, and operational cost modeling.' ;
    rdfs:domain ind:SortLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:powerConsumptionKw rdf:type rdf:Property ;
    rdfs:label 'Power Consumption Kw' ;
    rdfs:comment 'Rated electrical power consumption of the sort line in kilowatts (KW) at full operating capacity. Used for energy cost modeling, utility budgeting, and greenhouse gas (GHG) emissions reporting under EPA and ISO 14001 requirements.' ;
    rdfs:domain ind:SortLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:residueRateTargetPct rdf:type rdf:Property ;
    rdfs:label 'Residue Rate Target Pct' ;
    rdfs:comment 'Target percentage of inbound material that is expected to be classified as residue (non-recoverable waste sent to landfill disposal). Lower residue rates indicate higher diversion performance. Used in EPA diversion rate reporting and sustainability KPI tracking.' ;
    rdfs:domain ind:SortLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rfidEnabled rdf:type rdf:Property ;
    rdfs:label 'Rfid Enabled' ;
    rdfs:comment 'Indicates whether RFID (Radio Frequency Identification) technology is installed on this sort line for automated container or material tracking. Supports integration with AMCS Platform for container management and material flow tracking.' ;
    rdfs:domain ind:SortLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sapFunctionalLocation rdf:type rdf:Property ;
    rdfs:label 'Sap Functional Location' ;
    rdfs:comment 'SAP S/4HANA Plant Maintenance (PM) functional location code assigned to this sort line. Used to link maintenance work orders, preventive maintenance plans, and cost center allocations in SAP PM and FI/CO modules.' ;
    rdfs:domain ind:SortLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screenCount rdf:type rdf:Property ;
    rdfs:label 'Screen Count' ;
    rdfs:comment 'Number of disc screen or trommel screen units installed on this sort line for size-based material separation. Screens separate 2D materials (paper, film) from 3D materials (containers, cans) and are a primary separation mechanism in MRF operations.' ;
    rdfs:domain ind:SortLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serialNumber rdf:type rdf:Property ;
    rdfs:label 'Serial Number' ;
    rdfs:comment 'Manufacturer-assigned serial number uniquely identifying this sort line system. Required for warranty registration, insurance documentation, and regulatory equipment records.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftDurationHours rdf:type rdf:Property ;
    rdfs:label 'Shift Duration Hours' ;
    rdfs:comment 'Standard duration of each operating shift in hours for this sort line. Combined with operating_shift_count and design_throughput_tph to derive design_throughput_tpd. Used in workforce planning and production scheduling.' ;
    rdfs:domain ind:SortLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shredderCount rdf:type rdf:Property ;
    rdfs:label 'Shredder Count' ;
    rdfs:comment 'Number of shredding units installed on this sort line for size reduction of incoming material. Shredders improve downstream sorting efficiency and are common on OCC and residue lines.' ;
    rdfs:domain ind:SortLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stationCount rdf:type rdf:Property ;
    rdfs:label 'Station Count' ;
    rdfs:comment 'Total number of manual sort stations installed along the sort line. Determines labor requirements for staffing the line at full capacity and is used in workforce planning and ergonomic compliance assessments.' ;
    rdfs:domain ind:SortLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:commodityId rdf:type rdf:Property ;
    rdfs:label 'Commodity Id' ;
    rdfs:comment 'Unique system-generated surrogate identifier for each recovered commodity master record in the Materials Recovery Facility (MRF). Primary key for the commodity reference table. Role: MASTER_RESOURCE.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Commodity .

ind:acceptedMaterials rdf:type rdf:Property ;
    rdfs:label 'Accepted Materials' ;
    rdfs:comment 'Narrative description of materials explicitly accepted within this commodity stream (e.g., \'Corrugated containers, kraft paper bags\' for OCC). Complements the prohibited materials list to fully define the commodity specification for MRF operations and customer education.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amcsCommodityCode rdf:type rdf:Property ;
    rdfs:label 'Amcs Commodity Code' ;
    rdfs:comment 'Commodity identifier as configured in the AMCS Platform for route management and MRF dispatching. Used to link commodity master records to AMCS recycling route assignments, container tracking, and inbound material receiving workflows.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:balingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Baling Required Flag' ;
    rdfs:comment 'Indicates whether this commodity must be baled prior to outbound shipment to end-market buyers. Drives MRF baler scheduling, bale production tracking, and outbound logistics planning. False for loose commodities such as glass cullet or scrap metal.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:basePricePerTon rdf:type rdf:Property ;
    rdfs:label 'Base Price Per Ton' ;
    rdfs:comment 'Current or standard base price per ton (USD) for this commodity as used in MRF commodity sales. For positive-value commodities, this is the revenue received per ton sold. For negative-value commodities, this is the cost paid per ton disposed. Sensitive commercial pricing data. Integrated with Oracle Revenue Management and SAP FI/CO.' ;
    rdfs:domain ind:Recycling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commodityCategory rdf:type rdf:Property ;
    rdfs:label 'Commodity Category' ;
    rdfs:comment 'High-level material category grouping for the commodity. Drives MRF sorting line configuration, equipment routing, and EPA diversion rate reporting by material stream. Serves as the primary CLASSIFICATION_OR_TYPE for this MASTER_RESOURCE. [ENUM-REF-CANDIDATE: paper|plastics|metals|glass|organics|electronics|textiles|residue|other — promote to reference product]' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commodityCode rdf:type rdf:Property ;
    rdfs:label 'Commodity Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the commodity type (e.g., OCC, HDPE, ALU, ONP). Used as the business-facing identifier in SAP MM material master, AMCS commodity catalog, and commodity sales contracts. Serves as the BUSINESS_IDENTIFIER for this MASTER_RESOURCE.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commodityName rdf:type rdf:Property ;
    rdfs:label 'Commodity Name' ;
    rdfs:comment 'Full descriptive name of the recovered commodity (e.g., \'Old Corrugated Containers\', \'High-Density Polyethylene Natural\', \'Aluminum Used Beverage Cans\'). Serves as the IDENTITY_LABEL for this MASTER_RESOURCE and is used in customer-facing reports, commodity sales invoices, and EPA recycling disclosures.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commodityStatus rdf:type rdf:Property ;
    rdfs:label 'Commodity Status' ;
    rdfs:comment 'Current lifecycle status of the commodity master record. Active commodities are processed and sold from MRF operations. Inactive or discontinued commodities are retained for historical reporting. Pending_approval records are under review for addition to the MRF commodity catalog. Serves as the LIFECYCLE_STATUS for this MASTER_RESOURCE.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contaminationFeePerTon rdf:type rdf:Property ;
    rdfs:label 'Contamination Fee Per Ton' ;
    rdfs:comment 'Fee charged per ton (USD) when a commodity load exceeds the maximum contamination percentage threshold. Applied as a deduction from the commodity sale price or as a separate charge to the originating customer account. Configured in Oracle Revenue Management billing rules.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:diversionEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Diversion Eligible Flag' ;
    rdfs:comment 'Indicates whether tonnage of this commodity counts toward the diversion rate calculation (percentage of waste diverted from landfill). True for recyclable and compostable commodities; false for residue streams that are landfilled. Drives EPA and state-level diversion rate reporting.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:endMarketType rdf:type rdf:Property ;
    rdfs:label 'End Market Type' ;
    rdfs:comment 'Indicates whether this commodity is sold to domestic end-market buyers, exported to international markets, or both. Drives logistics planning, export documentation requirements (BOL, customs), and market pricing strategy. Export commodities may require additional DOT and customs compliance.' ;
    rdfs:domain ind:Recycling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epaMaterialCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Epa Material Category Code' ;
    rdfs:comment 'EPA-assigned material category code used in mandatory recycling and diversion rate reporting submissions. Aligns commodity records with EPA\'s Advancing Sustainable Materials Management (SMM) reporting framework and state environmental quality department reporting requirements.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ghgEmissionFactor rdf:type rdf:Property ;
    rdfs:label 'Ghg Emission Factor' ;
    rdfs:comment 'Greenhouse gas (GHG) emission factor in metric tons of carbon dioxide equivalent (CO2e) per ton of commodity recycled versus landfilled. Used to calculate GHG emission reductions from recycling activities for sustainability reporting, EPA GHG inventory submissions, and circular economy goal tracking.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gradeDescription rdf:type rdf:Property ;
    rdfs:label 'Grade Description' ;
    rdfs:comment 'Narrative description of the ISRI grade specification including allowable materials, prohibited items, and quality characteristics. Used by MRF quality control staff to assess bale acceptance and by sales teams to communicate product quality to end-market buyers.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardousMaterialFlag rdf:type rdf:Property ;
    rdfs:label 'Hazardous Material Flag' ;
    rdfs:comment 'Indicates whether this commodity is classified as a hazardous material under RCRA or DOT regulations. When true, triggers special handling, manifesting, and TSDF routing requirements. Integrates with Enviance EHS for compliance tracking and SAP EHS module for hazardous material management.' ;
    rdfs:domain ind:Recycling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isriGradeCode rdf:type rdf:Property ;
    rdfs:label 'Isri Grade Code' ;
    rdfs:comment 'Standardized grade code assigned by the Institute of Scrap Recycling Industries (ISRI) Scrap Specifications Circular. Defines the accepted quality standard for the commodity and is referenced in commodity purchase/sale contracts, bill of lading (BOL) documentation, and end-market buyer specifications.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketClassification rdf:type rdf:Property ;
    rdfs:label 'Market Classification' ;
    rdfs:comment 'Indicates whether the commodity generates revenue (positive_value — MRF receives payment from buyer), incurs a cost (negative_value — MRF pays buyer to accept), or is non-marketable residue. Critical for commodity sales pricing strategy, P&L reporting, and Oracle Revenue Management billing configuration.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxBaleDensityLbsPerCf rdf:type rdf:Property ;
    rdfs:label 'Max Bale Density Lbs Per Cf' ;
    rdfs:comment 'Maximum allowable bale density in pounds per cubic foot for this commodity. Overly dense bales may be rejected by buyers due to handling or processing constraints. Used alongside minimum density to define the acceptable bale density range for quality control.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxMoisturePct rdf:type rdf:Property ;
    rdfs:label 'Max Moisture Pct' ;
    rdfs:comment 'Maximum allowable moisture content percentage (by weight) for this commodity. Excess moisture reduces commodity value, increases transportation weight, and may cause rejection by end-market buyers. Used in MRF quality control inspections and bale certification.' ;
    rdfs:domain ind:Recycling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxStorageDays rdf:type rdf:Property ;
    rdfs:label 'Max Storage Days' ;
    rdfs:comment 'Maximum number of days this commodity may be stored at the MRF before quality degradation or regulatory limits require outbound shipment. Drives inventory turnover alerts in SAP MM and AMCS commodity inventory management. Critical for hazardous commodities with RCRA storage time limits.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minBaleDensityLbsPerCf rdf:type rdf:Property ;
    rdfs:label 'Min Bale Density Lbs Per Cf' ;
    rdfs:comment 'Minimum required bale density in pounds per cubic foot for this commodity. Bales below this density threshold may be rejected by buyers or subject to price discounts. Used to configure MRF baling equipment settings and quality control acceptance criteria.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minProcessingThroughputTpd rdf:type rdf:Property ;
    rdfs:label 'Min Processing Throughput Tpd' ;
    rdfs:comment 'Minimum expected processing throughput in tons per day (TPD) for this commodity on the MRF sort line. Used for MRF capacity planning, equipment performance benchmarking, and operational KPI reporting. Below-threshold throughput triggers operational review.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceFloorPerTon rdf:type rdf:Property ;
    rdfs:label 'Price Floor Per Ton' ;
    rdfs:comment 'Minimum acceptable sale price per ton (USD) below which the commodity should not be sold without management approval. Used in Oracle Revenue Management to trigger pricing exception workflows and protect MRF revenue margins during market downturns.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricingBasis rdf:type rdf:Property ;
    rdfs:label 'Pricing Basis' ;
    rdfs:comment 'Method by which the commodity sale price is determined: spot (current market spot price), index (tied to a published commodity index such as RISI or AMM), contract (fixed price per sales contract), or negotiated (case-by-case negotiation). Drives Oracle Revenue Management pricing configuration and commodity sales contract terms.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prohibitedMaterials rdf:type rdf:Property ;
    rdfs:label 'Prohibited Materials' ;
    rdfs:comment 'Narrative description of materials explicitly prohibited from inclusion in this commodity stream (e.g., \'No food-soiled paper, no wax-coated board\' for OCC; \'No PVC, no colored HDPE\' for natural HDPE). Used by MRF sorting staff, quality control inspectors, and driver education programs to prevent contamination.' ;
    rdfs:domain ind:Recycling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recyclabilityTier rdf:type rdf:Property ;
    rdfs:label 'Recyclability Tier' ;
    rdfs:comment 'Classification of the commodity\'s recyclability and market demand: tier_1 (high-value, readily recyclable with established markets), tier_2 (moderate-value, recyclable with limited markets), tier_3 (low-value, difficult to recycle), residue (non-recyclable, destined for disposal). Drives diversion rate calculations and sustainability reporting.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referencePriceIndex rdf:type rdf:Property ;
    rdfs:label 'Reference Price Index' ;
    rdfs:comment 'Name of the published commodity price index used as the pricing reference for index-priced commodities (e.g., \'RISI OCC Index\', \'AMM Aluminum Index\', \'Fastmarkets HDPE Index\'). Null for spot or contract-priced commodities. Used in Oracle Revenue Management for automated price updates.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resinCode rdf:type rdf:Property ;
    rdfs:label 'Resin Code' ;
    rdfs:comment 'Society of the Plastics Industry (SPI) Resin Identification Code (RIC) for plastic commodities (1=PET, 2=HDPE, 3=PVC, 4=LDPE, 5=PP, 6=PS, 7=Other). Null for non-plastic commodities. Required for plastics market reporting and end-market buyer specifications. [ENUM-REF-CANDIDATE: 1|2|3|4|5|6|7 — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sortLineCode rdf:type rdf:Property ;
    rdfs:label 'Sort Line Code' ;
    rdfs:comment 'Code identifying the MRF sorting line or processing stream assigned to this commodity (e.g., \'FIBER-1\', \'PLASTIC-2\', \'METAL-OCC\'). Used by AMCS Platform for route-to-sort-line assignment and MRF equipment configuration. Supports throughput (TPD) reporting by sort line.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardBaleWeightLbs rdf:type rdf:Property ;
    rdfs:label 'Standard Bale Weight Lbs' ;
    rdfs:comment 'Target or standard weight in pounds for a single bale of this commodity as produced by MRF baling equipment. Used for bale production planning, outbound load configuration, and weight-based pricing reconciliation with end-market buyers.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageRequirement rdf:type rdf:Property ;
    rdfs:label 'Storage Requirement' ;
    rdfs:comment 'Storage condition requirement for this commodity at the MRF prior to outbound shipment (e.g., indoor for paper to prevent moisture, hazmat_storage for hazardous commodities, outdoor for metals). Drives MRF facility layout planning and OSHA/EPA storage compliance.' ;
    rdfs:domain ind:Commodity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subcategory rdf:type rdf:Property ;
    rdfs:label 'Subcategory' ;
    rdfs:comment 'Secondary classification within the material category providing finer segmentation (e.g., \'corrugated\' within paper, \'PET bottles\' within plastics, \'ferrous\' within metals). Used for detailed MRF throughput reporting and commodity-specific market pricing.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tclpTestingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Tclp Testing Required Flag' ;
    rdfs:comment 'Indicates whether Toxicity Characteristic Leaching Procedure (TCLP) testing is required for this commodity prior to disposal or sale. Applicable to commodities that may exhibit hazardous characteristics under RCRA. Triggers laboratory testing workflow in Enviance EHS.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commodityGradeId rdf:type rdf:Property ;
    rdfs:label 'Commodity Grade Id' ;
    rdfs:comment 'Unique surrogate identifier for each commodity grade specification record in the Materials Recovery Facility (MRF) quality reference table. [REFERENCE_LOOKUP role — this is a reference/specification table defining grade standards; per canonical-attrs-enforced rule, REFERENCE_LOOKUP is exempt from per-role minimums. _canonical_skip_reason: commodity_grade is a reference lookup table defining quality grade specifications for MRF commodities; it has its own identity and lifecycle but functions as a standards reference, not a transactional or master-party entity.]' ;
    rdfs:domain ind:Recycling ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CommodityGrade .

ind:supersededByGradeCommodityGradeId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Grade Commodity Grade Id' ;
    rdfs:comment 'Reference to the commodity_grade_id of the newer grade specification that replaces this record when a grade is deprecated or revised. Null if this is the current active version. Supports grade version lineage tracking and ensures operational systems transition to updated specifications.' ;
    rdfs:domain ind:CommodityGrade ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CommodityGrade .

ind:applicableMrfRegion rdf:type rdf:Property ;
    rdfs:label 'Applicable Mrf Region' ;
    rdfs:comment 'Geographic region or operational division for which this grade specification applies (e.g., \'Northeast\', \'Southeast\', \'National\'). Some grade specifications may vary by region due to local buyer requirements or state recycling regulations. Null or \'National\' indicates the grade applies enterprise-wide.' ;
    rdfs:domain ind:CommodityGrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalDate rdf:type rdf:Property ;
    rdfs:label 'Approval Date' ;
    rdfs:comment 'Date on which this commodity grade specification was formally approved by the authorized quality manager or operations director. Required for quality management system documentation and regulatory audit readiness.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:baleDimensionSpec rdf:type rdf:Property ;
    rdfs:label 'Bale Dimension Spec' ;
    rdfs:comment 'Required or target bale dimensions (length x width x height in inches) for this commodity grade as specified by buyers or ISRI standards (e.g., \'60x30x48\'). Ensures compatibility with buyer receiving equipment and maximizes trailer load efficiency. Used in baler setup configuration.' ;
    rdfs:domain ind:CommodityGrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buyerAcceptanceRequired rdf:type rdf:Property ;
    rdfs:label 'Buyer Acceptance Required' ;
    rdfs:comment 'Indicates whether material classified under this grade requires explicit buyer acceptance confirmation before outbound shipment. True for specialty or off-grade materials where buyers must pre-approve loads. False for standard grades with standing purchase agreements. Drives outbound logistics workflow in AMCS.' ;
    rdfs:domain ind:CommodityGrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:co2eAvoidedPerTon rdf:type rdf:Property ;
    rdfs:label 'Co2e Avoided Per Ton' ;
    rdfs:comment 'Estimated metric tons of CO2e greenhouse gas emissions avoided per ton of commodity recovered and sold at this grade, compared to virgin material production. Used for GHG emissions reporting, sustainability disclosures, and circular economy impact quantification. Sourced from EPA WARM (Waste Reduction Model) emission factors.' ;
    rdfs:domain ind:CommodityGrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:colorSpecification rdf:type rdf:Property ;
    rdfs:label 'Color Specification' ;
    rdfs:comment 'Color or color mix specification required for this commodity grade (e.g., \'clear only\', \'clear and green\', \'mixed colors acceptable\', \'brown only\'). Primarily applicable to glass and PET plastic grades where color separation directly impacts end-market value and processing requirements at buyer facilities.' ;
    rdfs:domain ind:CommodityGrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diversionRateCredit rdf:type rdf:Property ;
    rdfs:label 'Diversion Rate Credit' ;
    rdfs:comment 'Indicates whether material sold under this commodity grade qualifies for diversion rate credit in EPA and state recycling program reporting. True for grades that represent genuine material recovery; False for off-grade or contaminated material routed to landfill or WTE. Impacts sustainability KPI reporting and circular economy goal tracking.' ;
    rdfs:domain ind:Recycling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:domesticExportEligibility rdf:type rdf:Property ;
    rdfs:label 'Domestic Export Eligibility' ;
    rdfs:comment 'Indicates whether this commodity grade is eligible for domestic sale only, export sale only, or both. Export eligibility is subject to Basel Convention restrictions on hazardous waste exports and country-specific import regulations. Drives market routing decisions in commodity sales management.' ;
    rdfs:domain ind:CommodityGrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epaCommodityCode rdf:type rdf:Property ;
    rdfs:label 'Epa Commodity Code' ;
    rdfs:comment 'EPA-assigned commodity classification code used for federal recycling diversion rate reporting and Solid Waste Information System (SWIS) submissions. Enables accurate tracking of material recovery volumes by commodity type for regulatory compliance and sustainability reporting.' ;
    rdfs:domain ind:CommodityGrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gradeCode rdf:type rdf:Property ;
    rdfs:label 'Grade Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the commodity grade specification (e.g., OCC-A, PET-1, ALU-P). Used as the externally-known business identifier in SAP MM material master, AMCS commodity tracking, and buyer purchase orders. Aligns with ISRI commodity grade coding conventions.' ;
    rdfs:domain ind:CommodityGrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gradeName rdf:type rdf:Property ;
    rdfs:label 'Grade Name' ;
    rdfs:comment 'Human-readable name of the commodity grade specification (e.g., \'Grade A Old Corrugated Containers\', \'Premium Clear PET\', \'Standard Mixed Paper\', \'Off-Grade Aluminum\'). Used in quality control reports, buyer contracts, and MRF operational dashboards.' ;
    rdfs:domain ind:CommodityGrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gradeStatus rdf:type rdf:Property ;
    rdfs:label 'Grade Status' ;
    rdfs:comment 'Current lifecycle status of the commodity grade specification. Active grades are in use for quality control and pricing. Inactive grades are suspended from use. Deprecated grades have been superseded by updated specifications. Under Review grades are pending revision approval. Controls whether the grade is available for selection in MRF quality control workflows.' ;
    rdfs:domain ind:CommodityGrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gradeTier rdf:type rdf:Property ;
    rdfs:label 'Grade Tier' ;
    rdfs:comment 'Quality tier classification of the grade specification indicating relative market value and purity level. Premium and Grade A command market premiums; Standard meets baseline buyer requirements; Off-Grade triggers price discounts; Rejected material is non-saleable and requires alternative disposition. Drives pricing factor application in Oracle Revenue Management.' ;
    rdfs:domain ind:CommodityGrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isriSpecReference rdf:type rdf:Property ;
    rdfs:label 'Isri Spec Reference' ;
    rdfs:comment 'Official ISRI Scrap Specifications Circular grade designation code that this internal grade maps to (e.g., \'ISRI-11\' for OCC, \'ISRI-600\' for Aluminum Cans). Enables standardized communication with commodity buyers, brokers, and end-markets. Required for export commodity sales documentation.' ;
    rdfs:domain ind:CommodityGrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketPriceFactor rdf:type rdf:Property ;
    rdfs:label 'Market Price Factor' ;
    rdfs:comment 'Multiplicative premium or discount factor applied to the base commodity market price for this grade (e.g., 1.15 = 15% premium for Premium grade; 0.85 = 15% discount for Off-Grade; 1.00 = no adjustment for Standard). Used in Oracle Revenue Management to calculate commodity sale prices and MRF revenue projections.' ;
    rdfs:domain ind:CommodityGrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxBaleWeightLbs rdf:type rdf:Property ;
    rdfs:label 'Max Bale Weight Lbs' ;
    rdfs:comment 'Maximum allowable bale weight in pounds for this commodity grade. Ensures compliance with DOT weight regulations for transport and safe handling limits for forklift and loading equipment. Bales exceeding this limit require splitting before outbound shipment.' ;
    rdfs:domain ind:CommodityGrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxParticleSizeInches rdf:type rdf:Property ;
    rdfs:label 'Max Particle Size Inches' ;
    rdfs:comment 'Maximum allowable individual particle or item size in inches for material classified under this grade. Oversized items can damage processing equipment at end-market facilities and may trigger load rejection. Particularly relevant for glass, metal, and plastic grades.' ;
    rdfs:domain ind:CommodityGrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minBaleDensityLbsPerCuft rdf:type rdf:Property ;
    rdfs:label 'Min Bale Density Lbs Per Cuft' ;
    rdfs:comment 'Minimum required bale density in pounds per cubic foot for this commodity grade. Ensures structural integrity during transport and storage, and maximizes trailer payload efficiency. Bales failing density requirements may be rejected by buyers or require re-baling. Monitored via baler equipment sensors integrated with AMCS.' ;
    rdfs:domain ind:CommodityGrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minPurityPct rdf:type rdf:Property ;
    rdfs:label 'Min Purity Pct' ;
    rdfs:comment 'Minimum required percentage of the target commodity material in a bale or load for this grade classification (e.g., 98.00 for Premium Aluminum = minimum 98% pure aluminum content). Complements the contamination threshold by specifying the positive purity floor rather than the negative contamination ceiling.' ;
    rdfs:domain ind:CommodityGrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minSampleSizeLbs rdf:type rdf:Property ;
    rdfs:label 'Min Sample Size Lbs' ;
    rdfs:comment 'Minimum weight in pounds of material sample required for quality control testing under this grade specification. Ensures statistical validity of contamination and purity measurements. Applies when sort_purity_test_method is grab_sample or full_sort.' ;
    rdfs:domain ind:CommodityGrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rejectionDisposition rdf:type rdf:Property ;
    rdfs:label 'Rejection Disposition' ;
    rdfs:comment 'Default disposition action for material that fails to meet this grade specification. Landfill routes rejected material to disposal; Reprocess returns material to the MRF sorting line; Downgrade reclassifies to a lower grade; Return to Sender sends contaminated loads back to the collection route origin; WTE (Waste-to-Energy) routes to energy recovery. Drives operational workflow in AMCS.' ;
    rdfs:domain ind:CommodityGrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresLabTesting rdf:type rdf:Property ;
    rdfs:label 'Requires Lab Testing' ;
    rdfs:comment 'Indicates whether material classified under this grade requires laboratory analysis (e.g., TCLP — Toxicity Characteristic Leaching Procedure testing, moisture analysis, or purity assay) before sale or shipment. True for grades with strict purity or regulatory requirements. Triggers lab sample workflow in Enviance EHS.' ;
    rdfs:domain ind:CommodityGrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sortPurityTestMethod rdf:type rdf:Property ;
    rdfs:label 'Sort Purity Test Method' ;
    rdfs:comment 'Quality control testing method used to verify that a bale or load meets this grade specification. Visual Sort is a manual inspector review; Grab Sample is a representative sample extraction; Full Sort is complete material separation and weighing; Lab Analysis is laboratory chemical or physical testing; Automated Sensor uses optical or NIR sorting equipment data.' ;
    rdfs:domain ind:CommodityGrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downtimeWorkOrderId rdf:type rdf:Property ;
    rdfs:label 'Downtime Work Order Id' ;
    rdfs:comment 'Foreign key linking to maintenance.work_order. Business justification: Links sort session downtime events to the maintenance work order that resolved the equipment failure. Critical for downtime root cause analysis, throughput loss calculation, and maintenance response t' ;
    rdfs:domain ind:SortSession ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkOrder .

ind:abortReason rdf:type rdf:Property ;
    rdfs:label 'Abort Reason' ;
    rdfs:comment 'Free-text description of the reason for premature session termination when session_status is \'aborted\'. Captures operational context not covered by downtime_reason_code. Null for completed or active sessions.' ;
    rdfs:domain ind:SortSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baleCount rdf:type rdf:Property ;
    rdfs:label 'Bale Count' ;
    rdfs:comment 'Total number of commodity bales produced during this sort session across all material types. Used for outbound commodity inventory management in SAP MM and baler productivity tracking.' ;
    rdfs:domain ind:SortSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contaminationInputPct rdf:type rdf:Property ;
    rdfs:label 'Contamination Input Pct' ;
    rdfs:comment 'Estimated percentage of the inbound material stream classified as contamination (non-recyclable materials, food waste, hazardous items) at session start. High contamination rates impact commodity quality grades and residue tonnage. Key metric for EPA recycling diversion rate reporting.' ;
    rdfs:domain ind:SortSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contaminationRatePct rdf:type rdf:Property ;
    rdfs:label 'Contamination Rate Pct' ;
    rdfs:comment 'Measured contamination rate percentage of the recovered commodity output after sorting, as determined by quality control sampling. Distinct from inbound contamination percentage; reflects sort line effectiveness. Used for commodity buyer compliance and quality control reporting.' ;
    rdfs:domain ind:SortSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:diversionRatePct rdf:type rdf:Property ;
    rdfs:label 'Diversion Rate Pct' ;
    rdfs:comment 'Percentage of total input tonnage successfully diverted from landfill disposal through recovery of recyclable commodities during this session. Calculated as (recovered_tonnage / input_tonnage) * 100. Core EPA recycling reporting metric and circular economy KPI.' ;
    rdfs:domain ind:SortSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:downtimeReasonCode rdf:type rdf:Property ;
    rdfs:label 'Downtime Reason Code' ;
    rdfs:comment 'Standardized reason code categorizing the primary cause of downtime during this sort session. Used for root cause analysis, maintenance scheduling, and operational improvement initiatives. [ENUM-REF-CANDIDATE: equipment_failure|material_jam|safety_stop|scheduled_maintenance|operator_shortage|power_outage|quality_hold|other — promote to reference product]' ;
    rdfs:domain ind:SortSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endTimestamp rdf:type rdf:Property ;
    rdfs:label 'End Timestamp' ;
    rdfs:comment 'Date and time when the sort session officially ended (completed or aborted). Null if the session is still active or paused. Used to calculate session duration and throughput rates.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:equipmentFaultFlag rdf:type rdf:Property ;
    rdfs:label 'Equipment Fault Flag' ;
    rdfs:comment 'Indicates whether a mechanical or electrical equipment fault was recorded during this sort session. When True, triggers a Work Order (WO) in Infor EAM for corrective maintenance. Supports equipment reliability and Overall Equipment Effectiveness (OEE) tracking.' ;
    rdfs:domain ind:SortSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:glassInputPct rdf:type rdf:Property ;
    rdfs:label 'Glass Input Pct' ;
    rdfs:comment 'Estimated percentage of the inbound material stream composed of glass commodities at session start. Used for commodity recovery planning and glass processing equipment configuration.' ;
    rdfs:domain ind:SortSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inputTonnage rdf:type rdf:Property ;
    rdfs:label 'Input Tonnage' ;
    rdfs:comment 'Total weight in short tons of inbound material received and processed during this sort session. Core metric for Tons Per Day (TPD) throughput reporting and EPA recycling diversion rate calculations.' ;
    rdfs:domain ind:SortSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:metalInputPct rdf:type rdf:Property ;
    rdfs:label 'Metal Input Pct' ;
    rdfs:comment 'Estimated percentage of the inbound material stream composed of metal commodities (aluminum, steel, ferrous, non-ferrous) at session start. Used for commodity recovery planning and eddy current separator configuration.' ;
    rdfs:domain ind:SortSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatorCount rdf:type rdf:Property ;
    rdfs:label 'Operator Count' ;
    rdfs:comment 'Number of sort station operators assigned and actively working during this sort session. Used for labor productivity analysis (tons per operator per hour) and staffing optimization.' ;
    rdfs:domain ind:SortSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paperInputPct rdf:type rdf:Property ;
    rdfs:label 'Paper Input Pct' ;
    rdfs:comment 'Estimated percentage of the inbound material stream composed of paper and fiber commodities (OCC, ONP, mixed paper) at session start. Used for commodity recovery planning and sort line configuration.' ;
    rdfs:domain ind:SortSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plasticInputPct rdf:type rdf:Property ;
    rdfs:label 'Plastic Input Pct' ;
    rdfs:comment 'Estimated percentage of the inbound material stream composed of plastic commodities (PET, HDPE, mixed plastics) at session start. Used for commodity recovery planning and sort line configuration.' ;
    rdfs:domain ind:SortSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qcSampleCount rdf:type rdf:Property ;
    rdfs:label 'Qc Sample Count' ;
    rdfs:comment 'Number of quality control samples taken during this sort session to assess commodity purity and contamination levels. Supports statistical validity of contamination rate measurements and MRF quality assurance programs.' ;
    rdfs:domain ind:SortSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualityGrade rdf:type rdf:Property ;
    rdfs:label 'Quality Grade' ;
    rdfs:comment 'Overall quality grade assigned to the commodity output of this sort session based on contamination levels and commodity purity. Drives commodity pricing and market acceptance. \'off_spec\' indicates material outside buyer specifications; \'rejected\' indicates material refused by commodity buyer.' ;
    rdfs:domain ind:SortSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recoveredTonnage rdf:type rdf:Property ;
    rdfs:label 'Recovered Tonnage' ;
    rdfs:comment 'Total weight in short tons of all recovered recyclable commodities (paper, plastics, metals, glass) produced during this sort session. Used for diversion rate calculation and commodity inventory reconciliation in SAP MM.' ;
    rdfs:domain ind:SortSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:residueTonnage rdf:type rdf:Property ;
    rdfs:label 'Residue Tonnage' ;
    rdfs:comment 'Total weight in short tons of non-recoverable residue (contamination and non-recyclable material) sent to landfill disposal after sorting. Used to calculate the diversion rate and residue rate for EPA reporting.' ;
    rdfs:domain ind:SortSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyIncidentFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Incident Flag' ;
    rdfs:comment 'Indicates whether a safety incident (injury, near-miss, or OSHA recordable event) occurred during this sort session. When True, triggers linkage to an incident record in Enviance EHS. Supports OSHA 300 log reporting and safety performance tracking.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sessionDate rdf:type rdf:Property ;
    rdfs:label 'Session Date' ;
    rdfs:comment 'Calendar date on which the sort session occurred. Used for daily Tons Per Day (TPD) aggregation, EPA recycling reporting, and operational scheduling alignment.' ;
    rdfs:domain ind:SortSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sessionDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Session Duration Minutes' ;
    rdfs:comment 'Total elapsed time in minutes from session start to session end, including both active processing time and downtime periods. Used for labor cost allocation and shift utilization analysis.' ;
    rdfs:domain ind:SortSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sessionNumber rdf:type rdf:Property ;
    rdfs:label 'Session Number' ;
    rdfs:comment 'Externally-known business identifier for the sort session, used in operational reporting, shift logs, and AMCS platform references. Format: SS-YYYY-MM-DD-NNNN.' ;
    rdfs:domain ind:SortSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionStatus rdf:type rdf:Property ;
    rdfs:label 'Session Status' ;
    rdfs:comment 'Current lifecycle state of the sort session. \'active\' indicates the session is in progress; \'completed\' indicates normal closure; \'aborted\' indicates premature termination due to equipment failure, safety event, or operational decision; \'paused\' indicates a temporary halt; \'pending\' indicates scheduled but not yet started.' ;
    rdfs:domain ind:SortSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionType rdf:type rdf:Property ;
    rdfs:label 'Session Type' ;
    rdfs:comment 'Classification of the sort session by operational purpose. \'standard\' is a normal production run; \'trial\' is a test run for new material streams; \'calibration\' is a quality calibration run; \'training\' is a supervised training session for new operators.' ;
    rdfs:domain ind:SortSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftType rdf:type rdf:Property ;
    rdfs:label 'Shift Type' ;
    rdfs:comment 'Classification of the work shift during which this sort session occurred. Used for labor cost allocation, productivity benchmarking across shifts, and workforce scheduling analysis.' ;
    rdfs:domain ind:SortSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sortLineSpeedFpm rdf:type rdf:Property ;
    rdfs:label 'Sort Line Speed Fpm' ;
    rdfs:comment 'Operational belt conveyor speed in feet per minute (FPM) at which the sort line was configured for this session. Affects throughput rate and operator sorting effectiveness. Used for equipment performance analysis.' ;
    rdfs:domain ind:SortSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceSystemSessionRef rdf:type rdf:Property ;
    rdfs:label 'Source System Session Ref' ;
    rdfs:comment 'The native identifier of this sort session record in the originating operational system (e.g., AMCS session ID, SAP production order number). Used for cross-system reconciliation and data lineage tracing in the Silver Layer.' ;
    rdfs:domain ind:SortSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:throughputRateTph rdf:type rdf:Property ;
    rdfs:label 'Throughput Rate Tph' ;
    rdfs:comment 'Processing throughput rate measured in tons per hour (TPH) for this sort session. Calculated as input tonnage divided by active processing time. Key operational KPI for sort line efficiency and capacity planning.' ;
    rdfs:domain ind:SortSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceRouteId rdf:type rdf:Property ;
    rdfs:label 'Source Route Id' ;
    rdfs:comment 'Identifier of the collection route from which the contaminated material originated. Enables geographic contamination trending.' ;
    rdfs:domain ind:ContaminationEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Route .

ind:specialWasteApprovalId rdf:type rdf:Property ;
    rdfs:label 'Special Waste Approval Id' ;
    rdfs:comment 'Foreign key linking to landfill.special_waste_approval. Business justification: Contamination events identifying hazardous or special waste in recyclable streams trigger a landfill special_waste_approval request. Regulators and environmental managers require this link to trace co' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SpecialWasteApproval .

ind:analysisType rdf:type rdf:Property ;
    rdfs:label 'Analysis Type' ;
    rdfs:comment 'Type of material quality analysis performed. Contamination check focuses on non-recyclable content; full composition audit provides complete material breakdown; NIR scan uses near-infrared technology for automated detection.' ;
    rdfs:domain ind:ContaminationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commodityValueLossUsd rdf:type rdf:Property ;
    rdfs:label 'Commodity Value Loss Usd' ;
    rdfs:comment 'Estimated revenue loss due to reduced commodity quality or rejected material, measured in US dollars.' ;
    rdfs:domain ind:ContaminationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contaminantsPercentage rdf:type rdf:Property ;
    rdfs:label 'Contaminants Percentage' ;
    rdfs:comment 'Percentage of non-recyclable contaminants (trash, hazardous materials, textiles, electronics) in the sample by weight. Primary metric for contamination rate tracking.' ;
    rdfs:domain ind:ContaminationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contaminationLevel rdf:type rdf:Property ;
    rdfs:label 'Contamination Level' ;
    rdfs:comment 'Categorical classification of contamination severity based on percentage thresholds. Acceptable: <5%, Moderate: 5-10%, High: 10-20%, Severe: 20-30%, Rejected: >30%.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerNotificationSent rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Sent' ;
    rdfs:comment 'Indicates whether the source generator was notified about the contamination event for education and corrective action purposes.' ;
    rdfs:domain ind:ContaminationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dispositionAction rdf:type rdf:Property ;
    rdfs:label 'Disposition Action' ;
    rdfs:comment 'Action taken on the contaminated load or material. Determines whether material proceeds through MRF processing or is diverted.' ;
    rdfs:domain ind:ContaminationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diversionImpactTons rdf:type rdf:Property ;
    rdfs:label 'Diversion Impact Tons' ;
    rdfs:comment 'Estimated tonnage impact on facility diversion rate due to this contamination event. Negative value indicates material diverted to landfill instead of recycling.' ;
    rdfs:domain ind:ContaminationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:epaReportable rdf:type rdf:Property ;
    rdfs:label 'Epa Reportable' ;
    rdfs:comment 'Indicates whether this contamination event must be included in EPA recycling and diversion rate reporting.' ;
    rdfs:domain ind:ContaminationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eventTimestamp rdf:type rdf:Property ;
    rdfs:label 'Event Timestamp' ;
    rdfs:comment 'Date and time when the contamination event was detected and recorded. Represents the actual moment of detection during MRF operations.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fiberPercentage rdf:type rdf:Property ;
    rdfs:label 'Fiber Percentage' ;
    rdfs:comment 'Percentage of fiber materials (paper, cardboard, newsprint) in the sample by weight. Key commodity category for MRF revenue and EPA recycling reporting.' ;
    rdfs:domain ind:ContaminationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:glassPercentage rdf:type rdf:Property ;
    rdfs:label 'Glass Percentage' ;
    rdfs:comment 'Percentage of glass materials (clear, green, brown) in the sample by weight. Tracked separately due to processing challenges and market constraints.' ;
    rdfs:domain ind:ContaminationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:metalsPercentage rdf:type rdf:Property ;
    rdfs:label 'Metals Percentage' ;
    rdfs:comment 'Percentage of metal materials (aluminum, steel, tin) in the sample by weight. High-value commodity category for MRF operations.' ;
    rdfs:domain ind:ContaminationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:notificationSentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Timestamp' ;
    rdfs:comment 'Date and time when customer notification was sent regarding the contamination event.' ;
    rdfs:domain ind:ContaminationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:organicsPercentage rdf:type rdf:Property ;
    rdfs:label 'Organics Percentage' ;
    rdfs:comment 'Percentage of organic materials (food waste, yard waste, compostables) in the sample by weight. Considered contamination in single-stream recycling.' ;
    rdfs:domain ind:ContaminationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:photoEvidenceUrl rdf:type rdf:Property ;
    rdfs:label 'Photo Evidence Url' ;
    rdfs:comment 'URL or file path to photographic documentation of the contamination event. Used for customer education, training, and dispute resolution.' ;
    rdfs:domain ind:ContaminationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plasticsPercentage rdf:type rdf:Property ;
    rdfs:label 'Plastics Percentage' ;
    rdfs:comment 'Percentage of plastic materials (PET, HDPE, PP, film) in the sample by weight. Includes all resin types recovered at the MRF.' ;
    rdfs:domain ind:ContaminationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processingCostImpactUsd rdf:type rdf:Property ;
    rdfs:label 'Processing Cost Impact Usd' ;
    rdfs:comment 'Estimated additional processing cost incurred due to contamination, including labor, equipment downtime, and disposal fees, measured in US dollars.' ;
    rdfs:domain ind:ContaminationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sampleWeightLbs rdf:type rdf:Property ;
    rdfs:label 'Sample Weight Lbs' ;
    rdfs:comment 'Total weight of the material sample analyzed, measured in pounds. Used to calculate contamination rates and material composition percentages.' ;
    rdfs:domain ind:ContaminationEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baleId rdf:type rdf:Property ;
    rdfs:label 'Bale Id' ;
    rdfs:comment 'Unique system-generated identifier for each commodity bale produced at a Materials Recovery Facility (MRF). Primary key for the bale master record. MASTER_RESOURCE role — serves as the globally unique surrogate key for bale identity, traceability, and lifecycle management.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Bale .

ind:commodityBuyerId rdf:type rdf:Property ;
    rdfs:label 'Commodity Buyer Id' ;
    rdfs:comment 'Reference to the commodity buyer or end-market customer who purchased or is contracted to receive this bale. Links bale to buyer account for sales order management, buyer-specific quality specification enforcement, and market channel analytics.' ;
    rdfs:domain ind:Recycling ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CommodityBuyer .

ind:commoditySaleId rdf:type rdf:Property ;
    rdfs:label 'Commodity Sale Id' ;
    rdfs:comment 'Reference to the outbound commodity sales order to which this bale has been allocated or shipped. Null when bale is in-storage or unallocated. Links bale to revenue recognition in SAP SD and Oracle Revenue Management.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CommoditySale .

ind:mrfEquipmentId rdf:type rdf:Property ;
    rdfs:label 'Mrf Equipment Id' ;
    rdfs:comment 'Reference to the baler machine that produced this bale. Supports equipment performance monitoring, preventive maintenance scheduling, and bale quality correlation with specific baler units via Infor EAM.' ;
    rdfs:domain ind:Recycling ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MrfEquipment .

ind:storageLocationId rdf:type rdf:Property ;
    rdfs:label 'Storage Location Id' ;
    rdfs:comment 'Reference to the designated storage bay, pad, or warehouse location within the MRF where this bale is currently stored. Supports inventory management, FIFO rotation, and outbound logistics planning.' ;
    rdfs:domain ind:Bale ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Location .

ind:allocatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Allocated Timestamp' ;
    rdfs:comment 'Date and time when this bale was allocated to a specific sales order or outbound shipment. Marks the transition from in_storage to allocated lifecycle status. Used for inventory turnover analysis and order fulfillment lead time tracking.' ;
    rdfs:domain ind:Bale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:barcode rdf:type rdf:Property ;
    rdfs:label 'Barcode' ;
    rdfs:comment 'Human-readable barcode label affixed to the bale for physical identification and scanning during storage, quality inspection, and outbound shipment. Printed at time of production and scanned at each lifecycle checkpoint.' ;
    rdfs:domain ind:Bale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bolNumber rdf:type rdf:Property ;
    rdfs:label 'Bol Number' ;
    rdfs:comment 'Bill of Lading number assigned to the outbound shipment carrying this bale. The BOL is the primary freight transport document required by DOT regulations. Null until bale is loaded for shipment. Enables shipment tracking and dispute resolution with commodity buyers.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationNumber rdf:type rdf:Property ;
    rdfs:label 'Certification Number' ;
    rdfs:comment 'Unique quality certification document number issued for this bale upon passing inspection, confirming it meets the specified commodity grade and buyer quality requirements. Required for certain commodity buyers and export shipments. Null if no formal certification was issued.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daysInStorage rdf:type rdf:Property ;
    rdfs:label 'Days In Storage' ;
    rdfs:comment 'Number of days this bale has been in MRF storage since production. Tracked to manage inventory aging, prioritize FIFO shipment sequencing, and identify slow-moving commodity inventory that may be subject to quality degradation or market price risk. Updated daily.' ;
    rdfs:domain ind:Bale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:densityKgPerM3 rdf:type rdf:Property ;
    rdfs:label 'Density Kg Per M3' ;
    rdfs:comment 'Calculated density of the bale expressed as kilograms per cubic meter, derived from weight and physical dimensions. Indicates baler compression performance and material compaction ratio. Low density may signal baler maintenance needs or loose material feed. Used for baler performance KPI tracking.' ;
    rdfs:domain ind:Bale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedValueUsd rdf:type rdf:Property ;
    rdfs:label 'Estimated Value Usd' ;
    rdfs:comment 'Estimated monetary value of this bale in USD, calculated as weight in tons multiplied by the applicable commodity market price per ton. Used for MRF commodity inventory valuation, revenue forecasting, and financial reporting in SAP FI/CO. Not a final invoiced amount — actual sale price is recorded on the sales order.' ;
    rdfs:domain ind:Bale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:heightCm rdf:type rdf:Property ;
    rdfs:label 'Height Cm' ;
    rdfs:comment 'Physical height dimension of the bale in centimeters as measured at production. Combined with length and width for volume calculation, stacking safety assessment, and storage bay capacity planning.' ;
    rdfs:domain ind:Bale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inspectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Inspection Timestamp' ;
    rdfs:comment 'Date and time when the most recent quality inspection was performed on this bale. Used for inspection age tracking, pre-shipment inspection validity windows, and audit trail for quality certification documentation.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:inspectionType rdf:type rdf:Property ;
    rdfs:label 'Inspection Type' ;
    rdfs:comment 'Type of quality inspection performed on this bale. Production QC is conducted at time of baling; pre-shipment inspection occurs before loading; buyer-requested inspection is initiated by the commodity buyer; re-inspection follows a prior rejection or dispute. Determines inspection protocol and documentation requirements.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lengthCm rdf:type rdf:Property ;
    rdfs:label 'Length Cm' ;
    rdfs:comment 'Physical length dimension of the bale in centimeters as measured at production. Used with width and height to calculate bale volume, verify baler performance, and plan trailer loading configurations for outbound commodity shipments.' ;
    rdfs:domain ind:Bale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marketPricePerTon rdf:type rdf:Property ;
    rdfs:label 'Market Price Per Ton' ;
    rdfs:comment 'Prevailing commodity market price per ton in USD at the time this bale was produced or allocated to a sales order. Captured for commodity inventory valuation, revenue forecasting, and market price trend analysis. Reflects spot market or contracted price depending on buyer agreement type.' ;
    rdfs:domain ind:Recycling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:moisturePct rdf:type rdf:Property ;
    rdfs:label 'Moisture Pct' ;
    rdfs:comment 'Measured moisture content of the bale expressed as a percentage of total bale weight. Excess moisture reduces net commodity value, increases transport weight without material value, and can cause mold or degradation in paper bales. Monitored against buyer moisture tolerance thresholds.' ;
    rdfs:domain ind:Bale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:productionShift rdf:type rdf:Property ;
    rdfs:label 'Production Shift' ;
    rdfs:comment 'MRF operating shift during which this bale was produced. Used for shift-level productivity analysis, quality trend analysis by shift, and workforce scheduling optimization. Correlates bale quality and throughput metrics to specific shift teams.' ;
    rdfs:domain ind:Bale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Production Timestamp' ;
    rdfs:comment 'Date and time when the bale was ejected from the baler and production was completed. The principal business event timestamp for this MASTER_RESOURCE. Used for throughput calculations (Tons Per Day), shift productivity reporting, and bale age tracking for FIFO inventory management.' ;
    rdfs:domain ind:Bale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reinspectionRequired rdf:type rdf:Property ;
    rdfs:label 'Reinspection Required' ;
    rdfs:comment 'Indicates whether this bale requires a follow-up quality inspection, typically after remediation of a failed inspection, buyer dispute, or conditional pass with noted concerns. True triggers a re-inspection workflow in the MRF quality management process.' ;
    rdfs:domain ind:Bale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shippedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Shipped Timestamp' ;
    rdfs:comment 'Date and time when this bale was loaded onto an outbound transport vehicle and departed the MRF facility. Marks the transition to shipped lifecycle status. Used for inventory reconciliation, Bill of Lading (BOL) documentation, and commodity revenue recognition timing.' ;
    rdfs:domain ind:Bale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:weightKg rdf:type rdf:Property ;
    rdfs:label 'Weight Kg' ;
    rdfs:comment 'Gross weight of the bale in kilograms as measured by the baler scale or floor scale at time of production. The principal quantitative measurement for this resource. Used for Tons Per Day (TPD) throughput calculations, commodity inventory valuation, sales order fulfillment, and EPA recycling tonnage reporting.' ;
    rdfs:domain ind:Bale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:widthCm rdf:type rdf:Property ;
    rdfs:label 'Width Cm' ;
    rdfs:comment 'Physical width dimension of the bale in centimeters as measured at production. Combined with length and height for volume calculation, storage space planning, and trailer load optimization.' ;
    rdfs:domain ind:Bale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wireCount rdf:type rdf:Property ;
    rdfs:label 'Wire Count' ;
    rdfs:comment 'Number of wire ties or strapping bands securing the bale. Standard bale configurations use 4, 5, or 6 wires depending on commodity type and baler model. Deviations from standard wire count may indicate bale integrity risk during transport and are flagged during quality inspection.' ;
    rdfs:domain ind:Bale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:commodityInventoryId rdf:type rdf:Property ;
    rdfs:label 'Commodity Inventory Id' ;
    rdfs:comment 'Unique identifier for the commodity inventory snapshot record.' ;
    rdfs:domain ind:CommodityInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocatedBales rdf:type rdf:Property ;
    rdfs:label 'Allocated Bales' ;
    rdfs:comment 'Number of bales committed to pending sales orders or customer allocations.' ;
    rdfs:domain ind:CommodityInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocatedWeightTons rdf:type rdf:Property ;
    rdfs:label 'Allocated Weight Tons' ;
    rdfs:comment 'Total weight in tons of commodity inventory allocated to pending sales orders.' ;
    rdfs:domain ind:CommodityInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:availableBales rdf:type rdf:Property ;
    rdfs:label 'Available Bales' ;
    rdfs:comment 'Number of bales available for sale, calculated as total bales on hand minus allocated bales.' ;
    rdfs:domain ind:CommodityInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:availableWeightTons rdf:type rdf:Property ;
    rdfs:label 'Available Weight Tons' ;
    rdfs:comment 'Total weight in tons of commodity inventory available for sale, calculated as total weight minus allocated weight.' ;
    rdfs:domain ind:CommodityInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageBaleAgeDays rdf:type rdf:Property ;
    rdfs:label 'Average Bale Age Days' ;
    rdfs:comment 'Average age in days of all bales in inventory, calculated from production date to snapshot date.' ;
    rdfs:domain ind:CommodityInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:batchNumber rdf:type rdf:Property ;
    rdfs:label 'Batch Number' ;
    rdfs:comment 'Representative batch or lot number for traceability of the commodity inventory, particularly for quality tracking.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commodityGrade rdf:type rdf:Property ;
    rdfs:label 'Commodity Grade' ;
    rdfs:comment 'Quality grade classification of the recovered commodity bales based on contamination levels and material purity standards.' ;
    rdfs:domain ind:CommodityInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contaminationRatePercent rdf:type rdf:Property ;
    rdfs:label 'Contamination Rate Percent' ;
    rdfs:comment 'Average contamination rate percentage across all bales in inventory, indicating non-recyclable material content.' ;
    rdfs:domain ind:Recycling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inventoryTurnoverDays rdf:type rdf:Property ;
    rdfs:label 'Inventory Turnover Days' ;
    rdfs:comment 'Average number of days commodity inventory remains in storage before being sold, calculated over a rolling period.' ;
    rdfs:domain ind:CommodityInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inventoryValuationAmount rdf:type rdf:Property ;
    rdfs:label 'Inventory Valuation Amount' ;
    rdfs:comment 'Total financial valuation of the commodity inventory on hand based on current market pricing or standard cost.' ;
    rdfs:domain ind:CommodityInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastQualityInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Last Quality Inspection Date' ;
    rdfs:comment 'Date of the most recent quality inspection or certification performed on this commodity inventory.' ;
    rdfs:domain ind:CommodityInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:materialNumber rdf:type rdf:Property ;
    rdfs:label 'Material Number' ;
    rdfs:comment 'SAP material master number for the commodity, used for integration with SAP MM inventory and financial systems.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumCapacityTons rdf:type rdf:Property ;
    rdfs:label 'Maximum Capacity Tons' ;
    rdfs:comment 'Maximum storage capacity in tons for this commodity type at this facility.' ;
    rdfs:domain ind:CommodityInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oldestBaleProductionDate rdf:type rdf:Property ;
    rdfs:label 'Oldest Bale Production Date' ;
    rdfs:comment 'Production date of the oldest bale currently in inventory, used to track inventory aging and FIFO management.' ;
    rdfs:domain ind:CommodityInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priceEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Price Effective Date' ;
    rdfs:comment 'Effective date of the current market price per ton used for inventory valuation.' ;
    rdfs:domain ind:Recycling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualityCertificationStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Certification Status' ;
    rdfs:comment 'Status of quality certification or inspection for the commodity inventory against ISRI or customer specifications.' ;
    rdfs:domain ind:CommodityInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reorderPointTons rdf:type rdf:Property ;
    rdfs:label 'Reorder Point Tons' ;
    rdfs:comment 'Minimum inventory threshold in tons that triggers production planning or sales acceleration actions.' ;
    rdfs:domain ind:CommodityInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:snapshotDate rdf:type rdf:Property ;
    rdfs:label 'Snapshot Date' ;
    rdfs:comment 'Business date for which this inventory snapshot was captured, representing the inventory position as of end of day.' ;
    rdfs:domain ind:CommodityInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:snapshotTimestamp rdf:type rdf:Property ;
    rdfs:label 'Snapshot Timestamp' ;
    rdfs:comment 'Precise timestamp when this inventory snapshot was captured from the source system.' ;
    rdfs:domain ind:CommodityInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:storageCapacityUtilizationPercent rdf:type rdf:Property ;
    rdfs:label 'Storage Capacity Utilization Percent' ;
    rdfs:comment 'Percentage of total MRF storage capacity utilized by this commodity inventory.' ;
    rdfs:domain ind:CommodityInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalBalesOnHand rdf:type rdf:Property ;
    rdfs:label 'Total Bales On Hand' ;
    rdfs:comment 'Total count of commodity bales currently in MRF storage at the snapshot date.' ;
    rdfs:domain ind:CommodityInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalWeightTons rdf:type rdf:Property ;
    rdfs:label 'Total Weight Tons' ;
    rdfs:comment 'Total weight of commodity inventory on hand measured in tons.' ;
    rdfs:domain ind:CommodityInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valuationCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Valuation Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for inventory valuation amount.' ;
    rdfs:domain ind:CommodityInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activeFlag rdf:type rdf:Property ;
    rdfs:label 'Active Flag' ;
    rdfs:comment 'Indicates whether the buyer is currently active and eligible for commodity sales. True means active and available for transactions, False means inactive and excluded from sales processes.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:billingAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Billing Address Line2' ;
    rdfs:comment 'Second line of the buyer\'s billing address for suite, floor, or building information. Optional field for additional address details.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Billing Country Code' ;
    rdfs:comment 'Three-letter ISO country code for the buyer\'s billing address.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingStateProvince rdf:type rdf:Property ;
    rdfs:label 'Billing State Province' ;
    rdfs:comment 'State or province code for the buyer\'s billing address. Uses standard postal abbreviations.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buyerEstablishedDate rdf:type rdf:Property ;
    rdfs:label 'Buyer Established Date' ;
    rdfs:comment 'Date when the business relationship with this commodity buyer was first established. Used for buyer tenure analysis and relationship management.' ;
    rdfs:domain ind:CommodityBuyer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:buyerName rdf:type rdf:Property ;
    rdfs:label 'Buyer Name' ;
    rdfs:comment 'Legal or trade name of the commodity buyer organization that purchases recovered materials from MRF operations.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buyerType rdf:type rdf:Property ;
    rdfs:label 'Buyer Type' ;
    rdfs:comment 'Classification of the commodity buyer based on their role in the recovered materials supply chain. Domestic mills process materials domestically, export brokers facilitate international sales, reprocessors transform materials into new feedstock, direct end-users consume materials in manufacturing, aggregators consolidate materials from multiple sources, and traders buy and resell commodities.' ;
    rdfs:domain ind:CommodityBuyer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactEmail rdf:type rdf:Property ;
    rdfs:label 'Contact Email' ;
    rdfs:comment 'Primary email address for the buyer contact. Used for purchase orders, invoices, shipping notifications, and quality documentation.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPhone rdf:type rdf:Property ;
    rdfs:label 'Contact Phone' ;
    rdfs:comment 'Primary telephone number for the buyer contact. Used for order coordination, quality issues, and logistics communication.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Amount' ;
    rdfs:comment 'Maximum outstanding accounts receivable balance allowed for this buyer in USD. Used for credit risk management and sales order approval workflows.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastTransactionDate rdf:type rdf:Property ;
    rdfs:label 'Last Transaction Date' ;
    rdfs:comment 'Date of the most recent commodity sale transaction with this buyer. Used to identify dormant buyer relationships and trigger reactivation campaigns.' ;
    rdfs:domain ind:CommodityBuyer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:minimumOrderQuantityTons rdf:type rdf:Property ;
    rdfs:label 'Minimum Order Quantity Tons' ;
    rdfs:comment 'Minimum shipment size in tons that the buyer will accept per order. Used for load planning and sales order validation.' ;
    rdfs:domain ind:Recycling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preferredCommodities rdf:type rdf:Property ;
    rdfs:label 'Preferred Commodities' ;
    rdfs:comment 'Comma-separated list of recovered material commodity types the buyer prefers to purchase (e.g., OCC, mixed paper, PET, HDPE, aluminum, ferrous metals, glass). Supports sales planning and material allocation decisions.' ;
    rdfs:domain ind:CommodityBuyer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredDeliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Preferred Delivery Method' ;
    rdfs:comment 'Buyer\'s preferred logistics arrangement. FOB MRF (Free On Board at Materials Recovery Facility) means buyer arranges transport, delivered means seller delivers to buyer facility, buyer pickup means buyer collects from MRF, third-party carrier means mutually agreed logistics provider.' ;
    rdfs:domain ind:CommodityBuyer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityCertificationRequired rdf:type rdf:Property ;
    rdfs:label 'Quality Certification Required' ;
    rdfs:comment 'Indicates whether the buyer requires quality certification documentation (e.g., contamination reports, bale composition analysis) with each shipment. True means certification is mandatory, False means standard documentation suffices.' ;
    rdfs:domain ind:CommodityBuyer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sapVendorNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Vendor Number' ;
    rdfs:comment 'SAP MM vendor master record number linking this commodity buyer to the enterprise procurement and accounts payable system. Used for purchase order and invoice reconciliation when buyer also supplies services or materials.' ;
    rdfs:domain ind:CommodityBuyer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Shipping Address Line1' ;
    rdfs:comment 'First line of the buyer\'s shipping or delivery address. Used for logistics planning and Bill of Lading (BOL) documentation.' ;
    rdfs:domain ind:CommodityBuyer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Shipping Address Line2' ;
    rdfs:comment 'Second line of the buyer\'s shipping address for dock, gate, or facility-specific routing information.' ;
    rdfs:domain ind:CommodityBuyer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingCity rdf:type rdf:Property ;
    rdfs:label 'Shipping City' ;
    rdfs:comment 'City name for the buyer\'s shipping or receiving facility.' ;
    rdfs:domain ind:CommodityBuyer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Shipping Country Code' ;
    rdfs:comment 'Three-letter ISO country code for the buyer\'s shipping destination. Critical for export compliance and international logistics.' ;
    rdfs:domain ind:CommodityBuyer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingPostalCode rdf:type rdf:Property ;
    rdfs:label 'Shipping Postal Code' ;
    rdfs:comment 'Postal or ZIP code for the buyer\'s shipping facility.' ;
    rdfs:domain ind:CommodityBuyer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingStateProvince rdf:type rdf:Property ;
    rdfs:label 'Shipping State Province' ;
    rdfs:comment 'State or province code for the buyer\'s shipping address.' ;
    rdfs:domain ind:CommodityBuyer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxIdNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Id Number' ;
    rdfs:comment 'Buyer organization\'s tax identification number (EIN in USA, VAT number in EU, or equivalent). Required for tax reporting and compliance with revenue recognition standards.' ;
    rdfs:domain ind:CommodityBuyer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketPriceId rdf:type rdf:Property ;
    rdfs:label 'Market Price Id' ;
    rdfs:comment 'Unique identifier for the market price record. Primary key.' ;
    rdfs:domain ind:Recycling ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MarketPrice .

ind:contaminationAdjustmentFactor rdf:type rdf:Property ;
    rdfs:label 'Contamination Adjustment Factor' ;
    rdfs:comment 'Multiplier applied to base price to account for contamination levels in recovered materials. Values less than 1.0 indicate price reductions for contaminated loads. Critical for MRF quality control and revenue management.' ;
    rdfs:domain ind:MarketPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Number' ;
    rdfs:comment 'Reference number of the sales contract or pricing agreement governing this market price. Links to contract management system for terms and conditions.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdByUser rdf:type rdf:Property ;
    rdfs:label 'Created By User' ;
    rdfs:comment 'Username or identifier of the system user who created this market price record. Supports audit trail and data governance.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryTerms rdf:type rdf:Property ;
    rdfs:label 'Delivery Terms' ;
    rdfs:comment 'Incoterms delivery terms defining when risk and cost transfer from seller to buyer. FOB (Free On Board) means buyer arranges transport, delivered means seller delivers to buyer location, ex-works means buyer picks up at MRF, CIF (Cost Insurance Freight), CFR (Cost and Freight).' ;
    rdfs:domain ind:Recycling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketCondition rdf:type rdf:Property ;
    rdfs:label 'Market Condition' ;
    rdfs:comment 'Qualitative assessment of the current market condition for this commodity. Strong indicates high demand and rising prices, weak indicates oversupply and falling prices, volatile indicates rapid price fluctuations, stable indicates consistent pricing.' ;
    rdfs:domain ind:MarketPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Modified By User' ;
    rdfs:comment 'Username or identifier of the system user who last modified this market price record. Supports audit trail and data governance.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceAdjustmentFrequency rdf:type rdf:Property ;
    rdfs:label 'Price Adjustment Frequency' ;
    rdfs:comment 'How often this market price is reviewed and updated. Daily for spot markets, weekly or monthly for published indices, quarterly or annual for long-term contracts, as-published for index-linked pricing.' ;
    rdfs:domain ind:MarketPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceCeilingPerTonUsd rdf:type rdf:Property ;
    rdfs:label 'Price Ceiling Per Ton Usd' ;
    rdfs:comment 'Maximum price per ton in contract agreements. Protects buyer from extreme market spikes. Nullable if no ceiling is negotiated.' ;
    rdfs:domain ind:MarketPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceChangePercentage rdf:type rdf:Property ;
    rdfs:label 'Price Change Percentage' ;
    rdfs:comment 'Percentage change in price compared to the previous pricing period. Positive values indicate price increases, negative values indicate decreases. Used for trend analysis and revenue forecasting.' ;
    rdfs:domain ind:MarketPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceChangeReason rdf:type rdf:Property ;
    rdfs:label 'Price Change Reason' ;
    rdfs:comment 'Business explanation for significant price changes (e.g., increased demand from China, mill shutdowns, contamination issues, seasonal demand, transportation cost increases). Supports market intelligence and strategic planning.' ;
    rdfs:domain ind:MarketPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Price Expiration Date' ;
    rdfs:comment 'Date when this market price expires and is no longer applicable. Nullable for open-ended pricing agreements. End of the pricing validity period.' ;
    rdfs:domain ind:MarketPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priceFloorPerTonUsd rdf:type rdf:Property ;
    rdfs:label 'Price Floor Per Ton Usd' ;
    rdfs:comment 'Minimum guaranteed price per ton in contract agreements. Protects seller from extreme market downturns. Nullable if no floor is negotiated.' ;
    rdfs:domain ind:MarketPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceIndexReference rdf:type rdf:Property ;
    rdfs:label 'Price Index Reference' ;
    rdfs:comment 'Name or identifier of the market index this price is linked to (e.g., OBM #11 Mixed Paper, RISI North American Boxboard Index). Used for index-linked pricing agreements.' ;
    rdfs:domain ind:Recycling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricePerTonUsd rdf:type rdf:Property ;
    rdfs:label 'Price Per Ton Usd' ;
    rdfs:comment 'Market price per ton of the commodity in US Dollars. Core pricing metric for MRF commodity sales valuation and revenue forecasting.' ;
    rdfs:domain ind:MarketPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricePublishedDate rdf:type rdf:Property ;
    rdfs:label 'Price Published Date' ;
    rdfs:comment 'Date when this market price was published or announced by the pricing source (OBM, RISI, etc.). May differ from effective date for forward-looking pricing.' ;
    rdfs:domain ind:MarketPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priceRegion rdf:type rdf:Property ;
    rdfs:label 'Price Region' ;
    rdfs:comment 'Geographic scope of the market price. National for US-wide pricing, regional for multi-state areas (northeast, southeast, midwest, southwest, west), or local for specific market areas. Commodity prices vary significantly by region due to transportation costs and local demand. [ENUM-REF-CANDIDATE: national|northeast|southeast|midwest|southwest|west|regional|local — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MarketPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceRegionCode rdf:type rdf:Property ;
    rdfs:label 'Price Region Code' ;
    rdfs:comment 'Abbreviated code for the pricing region (e.g., NE for Northeast, MW for Midwest, SW for Southwest). Used for reporting and system integration.' ;
    rdfs:domain ind:MarketPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceSource rdf:type rdf:Property ;
    rdfs:label 'Price Source' ;
    rdfs:comment 'Source of the market price data. OBM (Official Board Markets) for paper pricing, RISI for pulp and paper market intelligence, internal contract for negotiated customer agreements, spot market for current trading prices, broker quote, exchange index, or customer contract. [ENUM-REF-CANDIDATE: OBM|RISI|internal_contract|spot_market|broker_quote|exchange_index|customer_contract — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MarketPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceStatus rdf:type rdf:Property ;
    rdfs:label 'Price Status' ;
    rdfs:comment 'Current lifecycle status of this market price record. Active for currently applicable prices, expired for past prices, pending for future prices not yet effective, superseded for prices replaced by newer records, cancelled for withdrawn pricing.' ;
    rdfs:domain ind:MarketPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceType rdf:type rdf:Property ;
    rdfs:label 'Price Type' ;
    rdfs:comment 'Classification of the pricing mechanism. Spot for immediate market prices, contract for long-term agreement prices, index-linked for prices tied to a market index, negotiated for custom pricing, published for industry-published rates, average for calculated averages.' ;
    rdfs:domain ind:MarketPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transportationIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Transportation Included Flag' ;
    rdfs:comment 'Indicates whether transportation costs are included in the price per ton. True if price includes delivery (delivered pricing), False if price is FOB (Free On Board) at MRF location.' ;
    rdfs:domain ind:MarketPrice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:buyerContractId rdf:type rdf:Property ;
    rdfs:label 'Buyer Contract Id' ;
    rdfs:comment 'Reference to the master commodity sales contract or agreement governing this transaction. Links to contract terms and pricing schedules.' ;
    rdfs:domain ind:Recycling ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BuyerContract .

ind:adjustmentAmountUsd rdf:type rdf:Property ;
    rdfs:label 'Adjustment Amount Usd' ;
    rdfs:comment 'Any price adjustments, discounts, or surcharges applied to the sale in USD. Can be positive or negative.' ;
    rdfs:domain ind:CommoditySale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:destinationAddress rdf:type rdf:Property ;
    rdfs:label 'Destination Address' ;
    rdfs:comment 'Full delivery address where the commodity materials were shipped. Buyer facility or designated receiving location.' ;
    rdfs:domain ind:Recycling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationCity rdf:type rdf:Property ;
    rdfs:label 'Destination City' ;
    rdfs:comment 'City name of the commodity delivery destination.' ;
    rdfs:domain ind:Recycling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationCountryCode rdf:type rdf:Property ;
    rdfs:label 'Destination Country Code' ;
    rdfs:comment 'Three-letter ISO country code of the commodity delivery destination. Typically USA for domestic sales.' ;
    rdfs:domain ind:CommoditySale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationPostalCode rdf:type rdf:Property ;
    rdfs:label 'Destination Postal Code' ;
    rdfs:comment 'ZIP or postal code of the commodity delivery destination.' ;
    rdfs:domain ind:Recycling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationState rdf:type rdf:Property ;
    rdfs:label 'Destination State' ;
    rdfs:comment 'Two-letter state code of the commodity delivery destination.' ;
    rdfs:domain ind:Recycling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightChargeUsd rdf:type rdf:Property ;
    rdfs:label 'Freight Charge Usd' ;
    rdfs:comment 'Freight or transportation charges in USD associated with the commodity sale. May be billed to buyer or absorbed by seller.' ;
    rdfs:domain ind:CommoditySale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceDate rdf:type rdf:Property ;
    rdfs:label 'Invoice Date' ;
    rdfs:comment 'Date when the invoice was generated for this commodity sale transaction.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:invoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Invoice Number' ;
    rdfs:comment 'Invoice number generated for this commodity sale. Links to billing system for accounts receivable tracking.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isExportSale rdf:type rdf:Property ;
    rdfs:label 'Is Export Sale' ;
    rdfs:comment 'Flag indicating whether this commodity sale is an international export transaction requiring customs documentation and compliance.' ;
    rdfs:domain ind:CommoditySale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketIndexReference rdf:type rdf:Property ;
    rdfs:label 'Market Index Reference' ;
    rdfs:comment 'Reference to the commodity market pricing index used for this sale. Examples include RISI, Fastmarkets, or regional market indices.' ;
    rdfs:domain ind:CommoditySale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netSaleAmountUsd rdf:type rdf:Property ;
    rdfs:label 'Net Sale Amount Usd' ;
    rdfs:comment 'Final net revenue amount in USD after all adjustments and freight charges. Amount to be invoiced and collected.' ;
    rdfs:domain ind:CommoditySale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentDueDate rdf:type rdf:Property ;
    rdfs:label 'Payment Due Date' ;
    rdfs:comment 'Date by which payment for the commodity sale is due from the buyer, calculated based on payment terms.' ;
    rdfs:domain ind:CommoditySale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Payment Received Date' ;
    rdfs:comment 'Date when payment was received from the buyer for this commodity sale. Null if payment is still outstanding.' ;
    rdfs:domain ind:CommoditySale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualityGradeCertification rdf:type rdf:Property ;
    rdfs:label 'Quality Grade Certification' ;
    rdfs:comment 'Quality certification or grade verification documentation for the commodity materials. May reference third-party inspection reports.' ;
    rdfs:domain ind:CommoditySale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:saleDate rdf:type rdf:Property ;
    rdfs:label 'Sale Date' ;
    rdfs:comment 'Date when the commodity sale transaction was executed and ownership transferred to the buyer.' ;
    rdfs:domain ind:CommoditySale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:saleOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Sale Order Number' ;
    rdfs:comment 'Business identifier for the commodity sale order. Externally-known unique reference number used for tracking and reconciliation with buyers and billing systems.' ;
    rdfs:domain ind:CommoditySale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:saleStatus rdf:type rdf:Property ;
    rdfs:label 'Sale Status' ;
    rdfs:comment 'Current lifecycle status of the commodity sale transaction. Tracks progression from order creation through payment completion. [ENUM-REF-CANDIDATE: draft|confirmed|shipped|delivered|invoiced|paid|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CommoditySale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapDeliveryNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Delivery Number' ;
    rdfs:comment 'SAP SD module delivery document number. Tracks the outbound delivery and goods issue for the commodity shipment.' ;
    rdfs:domain ind:CommoditySale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapSalesOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Sales Order Number' ;
    rdfs:comment 'SAP SD module sales order document number. System reference for integration with ERP financial and logistics processes.' ;
    rdfs:domain ind:CommoditySale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentDate rdf:type rdf:Property ;
    rdfs:label 'Shipment Date' ;
    rdfs:comment 'Date when the commodity materials were physically shipped or picked up by the buyer.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shipmentMethod rdf:type rdf:Property ;
    rdfs:label 'Shipment Method' ;
    rdfs:comment 'Transportation method used to deliver the commodity to the buyer. Indicates logistics mode for the sale.' ;
    rdfs:domain ind:CommoditySale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalBaleCount rdf:type rdf:Property ;
    rdfs:label 'Total Bale Count' ;
    rdfs:comment 'Total number of bales included in this commodity sale transaction across all line items.' ;
    rdfs:domain ind:CommoditySale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalGrossWeightTons rdf:type rdf:Property ;
    rdfs:label 'Total Gross Weight Tons' ;
    rdfs:comment 'Total gross weight in tons including bale wrapping and any packaging materials. Used for transportation and logistics planning.' ;
    rdfs:domain ind:CommoditySale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalNetWeightTons rdf:type rdf:Property ;
    rdfs:label 'Total Net Weight Tons' ;
    rdfs:comment 'Total net weight in tons of all commodity materials sold in this transaction. Sum of all line item weights.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalSaleAmountUsd rdf:type rdf:Property ;
    rdfs:label 'Total Sale Amount Usd' ;
    rdfs:comment 'Total revenue amount in USD for the entire commodity sale transaction. Sum of all line item values before adjustments.' ;
    rdfs:domain ind:CommoditySale ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outboundShipmentId rdf:type rdf:Property ;
    rdfs:label 'Outbound Shipment Id' ;
    rdfs:comment 'Unique identifier for the outbound commodity shipment from MRF facility to buyer.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OutboundShipment .

ind:transportPermitId rdf:type rdf:Property ;
    rdfs:label 'Transport Permit Id' ;
    rdfs:comment 'Foreign key linking to compliance.permit. Business justification: Hazmat shipments of certain commodities (batteries in mixed loads, contaminated bales) require DOT transportation permits. Links shipments to permit compliance verification for hazardous material tran' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Permit .

ind:transporterRegistrationId rdf:type rdf:Property ;
    rdfs:label 'Transporter Registration Id' ;
    rdfs:comment 'Foreign key linking to hazmat.transporter_registration. Business justification: Hazardous commodity outbound shipments require a DOT/EPA-registered transporter. outbound_shipment has denormalized carrier_scac_code but no transporter_registration FK for regulatory compliance verif' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TransporterRegistration .

ind:actualArrivalDate rdf:type rdf:Property ;
    rdfs:label 'Actual Arrival Date' ;
    rdfs:comment 'Actual date when the shipment was received and confirmed at the buyer destination facility.' ;
    rdfs:domain ind:OutboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deliveryConfirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Delivery Confirmation Number' ;
    rdfs:comment 'Unique confirmation number issued by the buyer upon successful receipt and acceptance of the shipment.' ;
    rdfs:domain ind:OutboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryNotes rdf:type rdf:Property ;
    rdfs:label 'Delivery Notes' ;
    rdfs:comment 'Free-text notes documenting delivery conditions, exceptions, damages, or special instructions recorded at delivery.' ;
    rdfs:domain ind:OutboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Departure Timestamp' ;
    rdfs:comment 'Precise date and time when the loaded vehicle departed the MRF facility gate.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:destinationCountry rdf:type rdf:Property ;
    rdfs:label 'Destination Country' ;
    rdfs:comment 'Three-letter ISO country code of the buyer destination facility.' ;
    rdfs:domain ind:OutboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedArrivalDate rdf:type rdf:Property ;
    rdfs:label 'Estimated Arrival Date' ;
    rdfs:comment 'Projected date when the shipment is expected to arrive at the buyer destination.' ;
    rdfs:domain ind:OutboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:freightChargesUsd rdf:type rdf:Property ;
    rdfs:label 'Freight Charges Usd' ;
    rdfs:comment 'Total freight transportation charges for this shipment in US dollars.' ;
    rdfs:domain ind:OutboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hazmatIndicator rdf:type rdf:Property ;
    rdfs:label 'Hazmat Indicator' ;
    rdfs:comment 'Flag indicating whether the shipment contains or is classified as hazardous materials requiring special handling.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insuranceValueUsd rdf:type rdf:Property ;
    rdfs:label 'Insurance Value Usd' ;
    rdfs:comment 'Declared insurance value of the commodity shipment in US dollars for liability coverage.' ;
    rdfs:domain ind:OutboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sealNumber rdf:type rdf:Property ;
    rdfs:label 'Seal Number' ;
    rdfs:comment 'Unique security seal number applied to the container to ensure shipment integrity and prevent tampering.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentStatus rdf:type rdf:Property ;
    rdfs:label 'Shipment Status' ;
    rdfs:comment 'Current lifecycle status of the outbound commodity shipment in the logistics workflow.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureControlled rdf:type rdf:Property ;
    rdfs:label 'Temperature Controlled' ;
    rdfs:comment 'Indicates whether the shipment requires temperature-controlled transportation conditions.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalBalesShipped rdf:type rdf:Property ;
    rdfs:label 'Total Bales Shipped' ;
    rdfs:comment 'Total count of commodity bales loaded onto this shipment.' ;
    rdfs:domain ind:OutboundShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:residueDisposalId rdf:type rdf:Property ;
    rdfs:label 'Residue Disposal Id' ;
    rdfs:comment 'Unique identifier for the residue disposal transaction record.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ResidueDisposal .

ind:disposalCellId rdf:type rdf:Property ;
    rdfs:label 'Disposal Cell Id' ;
    rdfs:comment 'Identifier of the specific landfill cell where residue was placed, if applicable. Used for landfill capacity tracking.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Cell .

ind:disposalPermitId rdf:type rdf:Property ;
    rdfs:label 'Disposal Permit Id' ;
    rdfs:comment 'Foreign key linking to compliance.permit. Business justification: Residue disposal to landfills or WTE facilities must comply with waste acceptance permits and manifesting requirements. Enables verification of permitted waste streams, manifest compliance tracking, a' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WasteManagement .

ind:haulingVehicleId rdf:type rdf:Property ;
    rdfs:label 'Hauling Vehicle Id' ;
    rdfs:comment 'Reference to the fleet vehicle used to transport residue from MRF to disposal destination.' ;
    rdfs:domain ind:ResidueDisposal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vehicle .

ind:tonnageReceiptId rdf:type rdf:Property ;
    rdfs:label 'Tonnage Receipt Id' ;
    rdfs:comment 'Foreign key linking to landfill.tonnage_receipt. Business justification: MRF residue disposal generates a corresponding landfill tonnage receipt. This FK enables direct reconciliation of MRF residue output tonnage against landfill intake records — essential for diversion r' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TonnageReceipt .

ind:disposalDate rdf:type rdf:Property ;
    rdfs:label 'Disposal Date' ;
    rdfs:comment 'Date when the residue material was disposed of at the destination facility.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disposalDestinationType rdf:type rdf:Property ;
    rdfs:label 'Disposal Destination Type' ;
    rdfs:comment 'Type of facility receiving the residue material for final disposal or treatment.' ;
    rdfs:domain ind:ResidueDisposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalMethod rdf:type rdf:Property ;
    rdfs:label 'Disposal Method' ;
    rdfs:comment 'Specific method used for residue disposal. Determines environmental impact and regulatory reporting category.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalStatus rdf:type rdf:Property ;
    rdfs:label 'Disposal Status' ;
    rdfs:comment 'Current status of the residue disposal transaction in its lifecycle from scheduling through final acceptance.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Disposal Timestamp' ;
    rdfs:comment 'Precise date and time when the residue disposal transaction was completed at the receiving facility.' ;
    rdfs:domain ind:ResidueDisposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:environmentalSurcharge rdf:type rdf:Property ;
    rdfs:label 'Environmental Surcharge' ;
    rdfs:comment 'Additional fee assessed for environmental compliance, remediation, or special handling requirements.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:haulingCost rdf:type rdf:Property ;
    rdfs:label 'Hauling Cost' ;
    rdfs:comment 'Transportation cost for hauling the residue from MRF to disposal destination.' ;
    rdfs:domain ind:ResidueDisposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Status' ;
    rdfs:comment 'Current status of payment processing for this disposal transaction.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residueCompositionNotes rdf:type rdf:Property ;
    rdfs:label 'Residue Composition Notes' ;
    rdfs:comment 'Free-text description of residue material composition, contamination types, and any notable characteristics observed during disposal.' ;
    rdfs:domain ind:ResidueDisposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residueWeightTons rdf:type rdf:Property ;
    rdfs:label 'Residue Weight Tons' ;
    rdfs:comment 'Total weight of residue material disposed, measured in tons. Used for diversion rate calculation and cost allocation.' ;
    rdfs:domain ind:ResidueDisposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ticketNumber rdf:type rdf:Property ;
    rdfs:label 'Ticket Number' ;
    rdfs:comment 'Disposal facility-issued ticket or receipt number confirming acceptance and weighing of the residue load.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tippingFeePerTon rdf:type rdf:Property ;
    rdfs:label 'Tipping Fee Per Ton' ;
    rdfs:comment 'Charge per ton assessed by the receiving facility for accepting and disposing of the residue material.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDisposalCost rdf:type rdf:Property ;
    rdfs:label 'Total Disposal Cost' ;
    rdfs:comment 'Total cost incurred for this residue disposal transaction, including tipping fees, hauling, and any surcharges.' ;
    rdfs:domain ind:ResidueDisposal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weighInTimestamp rdf:type rdf:Property ;
    rdfs:label 'Weigh In Timestamp' ;
    rdfs:comment 'Date and time when the loaded vehicle was weighed at the disposal facility scale upon arrival.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:weighOutTimestamp rdf:type rdf:Property ;
    rdfs:label 'Weigh Out Timestamp' ;
    rdfs:comment 'Date and time when the empty vehicle was weighed at the disposal facility scale after unloading.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:equipmentPermitId rdf:type rdf:Property ;
    rdfs:label 'Equipment Permit Id' ;
    rdfs:comment 'Foreign key linking to compliance.permit. Business justification: Equipment like balers, optical sorters, and shredders operate under equipment-specific air quality permits governing particulate emissions and noise levels. Critical for tracking permit conditions dur' ;
    rdfs:domain ind:MrfEquipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Permit .

ind:lastWorkOrderId rdf:type rdf:Property ;
    rdfs:label 'Last Work Order Id' ;
    rdfs:comment 'Foreign key linking to maintenance.work_order. Business justification: Tracks most recent maintenance work order for MRF equipment. Essential for equipment history tracking, MTTR analysis, and maintenance cost allocation. Operations teams need quick access to last servic' ;
    rdfs:domain ind:MrfEquipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkOrder .

ind:acquisitionCost rdf:type rdf:Property ;
    rdfs:label 'Acquisition Cost' ;
    rdfs:comment 'Original purchase price or capital cost of the equipment in USD. Used for asset valuation, depreciation calculations, and return on investment analysis.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:criticalityRating rdf:type rdf:Property ;
    rdfs:label 'Criticality Rating' ;
    rdfs:comment 'Business criticality classification of the equipment based on impact to MRF operations if the equipment fails. Used for maintenance prioritization and spare parts inventory planning.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depreciationMethod rdf:type rdf:Property ;
    rdfs:label 'Depreciation Method' ;
    rdfs:comment 'Accounting method used to depreciate the equipment asset over its useful life. Determines how asset value is expensed over time.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designThroughputCapacityTph rdf:type rdf:Property ;
    rdfs:label 'Design Throughput Capacity Tph' ;
    rdfs:comment 'Manufacturer-rated processing capacity of the equipment measured in tons per hour. Used for capacity planning, bottleneck analysis, and performance benchmarking.' ;
    rdfs:domain ind:MrfEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalPermitRequired rdf:type rdf:Property ;
    rdfs:label 'Environmental Permit Required' ;
    rdfs:comment 'Indicates whether this equipment requires specific environmental permits or air quality permits for operation. Used for EPA and state environmental compliance tracking.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:equipmentName rdf:type rdf:Property ;
    rdfs:label 'Equipment Name' ;
    rdfs:comment 'Human-readable name or designation of the MRF equipment asset for operational identification and reporting.' ;
    rdfs:domain ind:MrfEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentTag rdf:type rdf:Property ;
    rdfs:label 'Equipment Tag' ;
    rdfs:comment 'Externally-known unique asset tag or equipment number assigned to this MRF processing equipment. Used for physical identification, maintenance tracking, and cross-system reference.' ;
    rdfs:domain ind:MrfEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentType rdf:type rdf:Property ;
    rdfs:label 'Equipment Type' ;
    rdfs:comment 'Classification of the MRF processing equipment by functional category. Determines the equipment\'s role in the material recovery and sorting process. [ENUM-REF-CANDIDATE: baler|optical_sorter|conveyor|eddy_current_separator|magnetic_separator|shredder|glass_breaker|trommel_screen|air_classifier|compactor — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:floorSpaceSqft rdf:type rdf:Property ;
    rdfs:label 'Floor Space Sqft' ;
    rdfs:comment 'Physical footprint of the equipment in square feet. Used for facility layout planning and space utilization analysis.' ;
    rdfs:domain ind:MrfEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inforEamAssetCode rdf:type rdf:Property ;
    rdfs:label 'Infor Eam Asset Code' ;
    rdfs:comment 'Cross-reference identifier to the corresponding asset record in the Infor EAM system. Enables integration for maintenance work orders, parts inventory, and asset lifecycle management.' ;
    rdfs:domain ind:MrfEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastPmDate rdf:type rdf:Property ;
    rdfs:label 'Last Pm Date' ;
    rdfs:comment 'Date when the most recent preventive maintenance service was completed on this equipment. Used for maintenance compliance tracking and scheduling.' ;
    rdfs:domain ind:MrfEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lockoutTagoutRequired rdf:type rdf:Property ;
    rdfs:label 'Lockout Tagout Required' ;
    rdfs:comment 'Indicates whether this equipment requires lockout/tagout procedures during maintenance or service per OSHA regulations. Critical for worker safety compliance.' ;
    rdfs:domain ind:MrfEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:meanTimeBetweenFailuresHours rdf:type rdf:Property ;
    rdfs:label 'Mean Time Between Failures Hours' ;
    rdfs:comment 'Average operational time between equipment failures measured in hours. Key reliability metric used for maintenance planning and equipment performance benchmarking.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meanTimeToRepairHours rdf:type rdf:Property ;
    rdfs:label 'Mean Time To Repair Hours' ;
    rdfs:comment 'Average time required to repair the equipment when a failure occurs, measured in hours. Used for downtime planning and maintenance resource allocation.' ;
    rdfs:domain ind:MrfEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextInspectionDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Inspection Due Date' ;
    rdfs:comment 'Scheduled date for the next required safety or operational inspection. Used for compliance planning and inspection scheduling.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextPmDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Pm Due Date' ;
    rdfs:comment 'Scheduled date for the next preventive maintenance service on this equipment. Used for maintenance planning and downtime scheduling.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operatingHoursMeter rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Meter' ;
    rdfs:comment 'Cumulative operating hours recorded for this equipment since installation or last meter reset. Used for usage-based maintenance scheduling and lifecycle tracking.' ;
    rdfs:domain ind:MrfEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:powerRatingKw rdf:type rdf:Property ;
    rdfs:label 'Power Rating Kw' ;
    rdfs:comment 'Electrical power consumption rating of the equipment in kilowatts. Used for energy cost analysis, electrical capacity planning, and sustainability reporting.' ;
    rdfs:domain ind:MrfEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyCertification rdf:type rdf:Property ;
    rdfs:label 'Safety Certification' ;
    rdfs:comment 'Safety certifications or compliance standards met by the equipment (e.g., UL, CE, OSHA). Used for regulatory compliance and workplace safety verification.' ;
    rdfs:domain ind:MrfEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usefulLifeYears rdf:type rdf:Property ;
    rdfs:label 'Useful Life Years' ;
    rdfs:comment 'Expected operational lifespan of the equipment in years for depreciation and lifecycle planning purposes.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:voltageRequirement rdf:type rdf:Property ;
    rdfs:label 'Voltage Requirement' ;
    rdfs:comment 'Electrical voltage specification required for equipment operation (e.g., 480V 3-phase). Used for electrical infrastructure planning and safety compliance.' ;
    rdfs:domain ind:MrfEquipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Warranty Expiration Date' ;
    rdfs:comment 'Date when the manufacturer\'s warranty coverage for this equipment expires. Used for maintenance cost planning and warranty claim eligibility.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exportPermitId rdf:type rdf:Property ;
    rdfs:label 'Export Permit Id' ;
    rdfs:comment 'Foreign key linking to compliance.permit. Business justification: Export contracts for recyclable commodities require EPA export permits and international waste shipment permits (Basel Convention compliance). Enables verification of export authorization and tracking' ;
    rdfs:domain ind:BuyerContract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Permit .

ind:minimumQualityCommodityGradeId rdf:type rdf:Property ;
    rdfs:label 'Minimum Quality Commodity Grade Id' ;
    rdfs:comment 'Foreign key linking to recycling.commodity_grade. Business justification: A recycling buyer contract specifies a minimum quality grade requirement for accepted commodity. recycling_buyer_contract currently stores minimum_quality_grade as a denormalized string. Adding minimu' ;
    rdfs:domain ind:BuyerContract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CommodityGrade .

ind:primaryBuyerSalesforceContractId rdf:type rdf:Property ;
    rdfs:label 'Primary Buyer Salesforce Contract Id' ;
    rdfs:comment 'The Salesforce CRM contract record identifier linked to this commodity offtake agreement. Used for cross-system traceability between the MRF data product and the CRM contract management module.' ;
    rdfs:domain ind:BuyerContract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contract .

ind:autoRenewal rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal' ;
    rdfs:comment 'Indicates whether this contract automatically renews at expiration unless either party provides written notice of non-renewal within the renewal_notice_days period.' ;
    rdfs:domain ind:BuyerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:baleWeightSpecLbs rdf:type rdf:Property ;
    rdfs:label 'Bale Weight Spec Lbs' ;
    rdfs:comment 'The contractually specified target bale weight in pounds for commodity shipments under this agreement. Deviations from this specification may trigger price adjustments or load rejections.' ;
    rdfs:domain ind:BuyerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ceilingPricePerTon rdf:type rdf:Property ;
    rdfs:label 'Ceiling Price Per Ton' ;
    rdfs:comment 'The maximum price per short ton the buyer will pay, applicable when price_mechanism is \'floor_and_ceiling\'. Caps the MRF\'s upside in exchange for floor price protection. Null for non-floor-and-ceiling contracts.' ;
    rdfs:domain ind:BuyerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:committedVolumeTonsMonthly rdf:type rdf:Property ;
    rdfs:label 'Committed Volume Tons Monthly' ;
    rdfs:comment 'The contractually committed volume of recovered commodity in short tons per month that Waste Management agrees to supply to the buyer. Used for production planning, route optimization, and SLA compliance tracking.' ;
    rdfs:domain ind:BuyerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contaminationPenaltyBasis rdf:type rdf:Property ;
    rdfs:label 'Contamination Penalty Basis' ;
    rdfs:comment 'The method by which contamination penalties are assessed: per_ton (rate applied to excess contamination weight), flat_fee (fixed charge per non-conforming load), price_deduction_pct (percentage reduction from invoice price), or load_rejection (load refused and returned at seller\'s cost).' ;
    rdfs:domain ind:BuyerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contaminationPenaltyRate rdf:type rdf:Property ;
    rdfs:label 'Contamination Penalty Rate' ;
    rdfs:comment 'The contractual penalty rate in US dollars per short ton applied to shipments that exceed the maximum allowable contamination percentage. Used to calculate contamination surcharge deductions from commodity revenue.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractNotes rdf:type rdf:Property ;
    rdfs:label 'Contract Notes' ;
    rdfs:comment 'Free-text field for capturing additional contract terms, special conditions, buyer-specific requirements, or operational notes not captured in structured fields.' ;
    rdfs:domain ind:BuyerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractStatus rdf:type rdf:Property ;
    rdfs:label 'Contract Status' ;
    rdfs:comment 'Current lifecycle state of the commodity offtake agreement. Draft: under negotiation; Active: binding and in force; Suspended: temporarily paused; Expired: reached end date without renewal; Terminated: cancelled before end date.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractType rdf:type rdf:Property ;
    rdfs:label 'Contract Type' ;
    rdfs:comment 'Classification of the commodity sales agreement by duration and commitment structure. Spot contracts are single-transaction; short-term are typically under 12 months; long-term offtake agreements are multi-year committed volume arrangements; evergreen contracts auto-renew; trial contracts are provisional.' ;
    rdfs:domain ind:BuyerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeResolutionMethod rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Method' ;
    rdfs:comment 'The contractually agreed method for resolving disputes between Waste Management and the commodity buyer regarding contract terms, quality, or payment.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endDate rdf:type rdf:Property ;
    rdfs:label 'End Date' ;
    rdfs:comment 'The date on which the commodity offtake agreement expires or is scheduled to terminate. Null for open-ended evergreen contracts.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exclusivityFlag rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Flag' ;
    rdfs:comment 'Indicates whether this contract grants the buyer exclusive rights to purchase a specific commodity from this MRF facility, preventing Waste Management from selling that commodity to competing buyers during the contract term.' ;
    rdfs:domain ind:BuyerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:executionDate rdf:type rdf:Property ;
    rdfs:label 'Execution Date' ;
    rdfs:comment 'The date on which the contract was formally signed and executed by both parties. May differ from the effective start date for contracts with retroactive or future effective dates.' ;
    rdfs:domain ind:BuyerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:floorPricePerTon rdf:type rdf:Property ;
    rdfs:label 'Floor Price Per Ton' ;
    rdfs:comment 'The minimum guaranteed price per short ton below which the buyer will not pay, applicable when price_mechanism is \'floor_and_ceiling\'. Protects the MRF from extreme market downturns. Null for non-floor-and-ceiling contracts.' ;
    rdfs:domain ind:BuyerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forceMajeureClause rdf:type rdf:Property ;
    rdfs:label 'Force Majeure Clause' ;
    rdfs:comment 'Indicates whether the contract contains a force majeure clause that suspends obligations in the event of extraordinary circumstances (natural disasters, regulatory shutdowns, pandemics). Relevant for EPA/OSHA emergency compliance scenarios.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingLawState rdf:type rdf:Property ;
    rdfs:label 'Governing Law State' ;
    rdfs:comment 'The U.S. state whose laws govern the interpretation and enforcement of this commodity sales contract (e.g., \'TX\', \'CA\', \'FL\'). Relevant for dispute resolution and regulatory compliance.' ;
    rdfs:domain ind:BuyerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoicingFrequency rdf:type rdf:Property ;
    rdfs:label 'Invoicing Frequency' ;
    rdfs:comment 'The frequency at which invoices are generated and submitted to the buyer for commodity shipments under this contract. Drives Oracle Revenue Management billing cycle configuration.' ;
    rdfs:domain ind:BuyerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceMechanism rdf:type rdf:Property ;
    rdfs:label 'Price Mechanism' ;
    rdfs:comment 'The pricing methodology governing how the commodity sale price is determined under this contract. Fixed: set price per ton; Index-linked: tied to a published market index; Floor-and-ceiling: bounded index pricing; Negotiated: periodic bilateral negotiation; Revenue-share: buyer and seller split net proceeds.' ;
    rdfs:domain ind:BuyerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Notice Days' ;
    rdfs:comment 'Number of calendar days prior to the contract end date by which either party must provide written notice of intent to renew or not renew the agreement.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:renewalOption rdf:type rdf:Property ;
    rdfs:label 'Renewal Option' ;
    rdfs:comment 'Indicates whether the contract contains a renewal option clause allowing either party to extend the agreement beyond the original end date.' ;
    rdfs:domain ind:BuyerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sapSdContractNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Sd Contract Number' ;
    rdfs:comment 'The SAP S/4HANA SD module contract document number (scheduling agreement or quantity contract) linked to this MRF commodity sales agreement. Used for cross-system reconciliation.' ;
    rdfs:domain ind:BuyerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:startDate rdf:type rdf:Property ;
    rdfs:label 'Start Date' ;
    rdfs:comment 'The date on which the commodity offtake agreement becomes legally binding and commodity deliveries may commence under its terms.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:terminationDate rdf:type rdf:Property ;
    rdfs:label 'Termination Date' ;
    rdfs:comment 'The actual date on which the contract was terminated early, if applicable. Null for contracts that expire naturally at end_date or remain active.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:terminationReason rdf:type rdf:Property ;
    rdfs:label 'Termination Reason' ;
    rdfs:comment 'Reason code explaining why the contract was terminated before its scheduled end date. Populated only when contract_status is \'terminated\'. [ENUM-REF-CANDIDATE: buyer_default|seller_default|mutual_agreement|market_exit|regulatory|force_majeure|non_renewal — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transportResponsibility rdf:type rdf:Property ;
    rdfs:label 'Transport Responsibility' ;
    rdfs:comment 'Identifies which party is responsible for arranging and paying for transportation of commodity bales from the MRF to the buyer\'s facility. Impacts logistics cost allocation and fleet planning.' ;
    rdfs:domain ind:BuyerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeTolerancePct rdf:type rdf:Property ;
    rdfs:label 'Volume Tolerance Pct' ;
    rdfs:comment 'The allowable percentage variance (plus or minus) from the committed monthly volume before penalty or renegotiation clauses are triggered. For example, 10% means the MRF may deliver between 90% and 110% of committed volume without penalty.' ;
    rdfs:domain ind:BuyerContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lineId rdf:type rdf:Property ;
    rdfs:label 'Line Id' ;
    rdfs:comment 'Foreign key linking to service.line. Business justification: A recycling program belongs to a service line (e.g., Residential Recycling, Commercial Recycling). This link enables P&L reporting by service line for recycling programs, pricing model inheritance, an' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Line .

ind:municipalityId rdf:type rdf:Property ;
    rdfs:label 'Municipality Id' ;
    rdfs:comment 'Foreign key linking to contract.municipality. Business justification: Recycling programs are scoped to specific municipalities for franchise compliance, diversion rate reporting, and LEA jurisdiction tracking. municipality_name is a denormalized plain-text representatio' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Municipality .

ind:acceptedMaterialsList rdf:type rdf:Property ;
    rdfs:label 'Accepted Materials List' ;
    rdfs:comment 'Comma-delimited list of material categories accepted under this recycling program (e.g., \'OCC,ONP,PET,HDPE,aluminum_cans,steel_cans,glass\'). Drives contamination assessment, MRF sort line configuration, and public education materials. Sourced from Waste Logics container management.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amcsProgramReference rdf:type rdf:Property ;
    rdfs:label 'Amcs Program Reference' ;
    rdfs:comment 'External reference identifier for this recycling program as registered in the AMCS Platform for route optimization and fleet dispatching. Enables end-to-end traceability from collection route to MRF processing.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualTonnageCommitment rdf:type rdf:Property ;
    rdfs:label 'Annual Tonnage Commitment' ;
    rdfs:comment 'Contractually committed annual volume of recyclable material (in short tons) to be collected and processed under this program. Used for MRF capacity planning, commodity revenue forecasting, and contract compliance monitoring.' ;
    rdfs:domain ind:Recycling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:co2eDiversionFactor rdf:type rdf:Property ;
    rdfs:label 'Co2e Diversion Factor' ;
    rdfs:comment 'EPA-approved CO2e emission reduction factor (metric tons CO2e per short ton of material diverted) applied to this program for GHG reporting and sustainability disclosures. Varies by material stream type.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:iso14001Applicable rdf:type rdf:Property ;
    rdfs:label 'Iso 14001 Applicable' ;
    rdfs:comment 'Indicates whether this recycling program is subject to ISO 14001 Environmental Management System requirements. True for programs operating under ISO 14001 certified facilities. Drives environmental audit scope in Enviance EHS.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leaJurisdictionCode rdf:type rdf:Property ;
    rdfs:label 'Lea Jurisdiction Code' ;
    rdfs:comment 'Code identifying the Local Enforcement Agency (LEA) jurisdiction governing this recycling program. Used for regulatory compliance tracking in Enviance EHS and local solid waste authority reporting.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingPriority rdf:type rdf:Property ;
    rdfs:label 'Processing Priority' ;
    rdfs:comment 'Priority level assigned to inbound loads from this program for MRF sort line scheduling. High priority programs (e.g., municipal contracts with SLA penalties) are processed before standard or low priority commercial loads.' ;
    rdfs:domain ind:Recycling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programCode rdf:type rdf:Property ;
    rdfs:label 'Program Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for the recycling program, used in AMCS route management, SAP MM commodity inventory, and customer-facing communications. Unique across all active programs.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programName rdf:type rdf:Property ;
    rdfs:label 'Program Name' ;
    rdfs:comment 'Human-readable name of the recycling program (e.g., \'City of Houston Curbside Recycling\', \'Downtown Commercial MRF Program\'). Used in reporting, customer portals, and EPA recycling disclosures.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programStatus rdf:type rdf:Property ;
    rdfs:label 'Program Status' ;
    rdfs:comment 'Current lifecycle state of the recycling program. Active indicates the program is currently collecting and processing materials. Pending indicates the program is approved but not yet operational. Suspended indicates temporary halt (e.g., due to contamination issues or contract dispute). Closed indicates the program has permanently ended.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicEducationRequired rdf:type rdf:Property ;
    rdfs:label 'Public Education Required' ;
    rdfs:comment 'Indicates whether the program contract or municipal agreement requires Waste Management to provide public education and outreach materials (e.g., accepted materials guides, contamination reduction campaigns). Drives marketing and communications obligations.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportingFrequency rdf:type rdf:Property ;
    rdfs:label 'Reporting Frequency' ;
    rdfs:comment 'Frequency at which diversion rate, tonnage, and contamination reports must be submitted to the sponsoring municipality, state agency, or EPA under this program\'s contractual and regulatory obligations.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueSharePct rdf:type rdf:Property ;
    rdfs:label 'Revenue Share Pct' ;
    rdfs:comment 'Percentage of net commodity sales revenue shared back with the sponsoring municipality or customer account under this program. Expressed as a percentage (0.00–100.00). Null if no revenue-share arrangement exists. Tracked in Oracle Revenue Management.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:siteId rdf:type rdf:Property ;
    rdfs:label 'Site Id' ;
    rdfs:comment 'Unique system-generated identifier for the landfill site. Primary key for all landfill operational, environmental, and compliance data anchored to this facility.' ;
    rdfs:domain ind:Landfill ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Site .

ind:siteEnvianceFacilityId rdf:type rdf:Property ;
    rdfs:label 'Site Enviance Facility Id' ;
    rdfs:comment 'Facility identifier as configured in the Enviance EHS system, which is the system of record for environmental compliance, permit tracking, and incident management at this facility. Used for cross-system data integration and compliance record linkage.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:siteEpaFacilityId rdf:type rdf:Property ;
    rdfs:label 'Site Epa Facility Id' ;
    rdfs:comment 'EPA-assigned facility identifier used for federal environmental reporting, RCRA compliance tracking, and CERCLA/Superfund obligations. Format: two-letter state code followed by 10-digit numeric identifier.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:airspaceSurveyDate rdf:type rdf:Property ;
    rdfs:label 'Airspace Survey Date' ;
    rdfs:comment 'Date of the most recent engineering airspace survey used to calculate remaining airspace. Ensures remaining_airspace_cy reflects current conditions and supports audit trail for capacity reporting.' ;
    rdfs:domain ind:Landfill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:capSystemType rdf:type rdf:Property ;
    rdfs:label 'Cap System Type' ;
    rdfs:comment 'Type of final cover (cap) system installed or planned for the landfill. The cap is the final cover system placed over closed portions of the landfill to minimize infiltration and control LFG emissions. \'final_cap\' indicates permanent closure cap installed; \'interim_cap\' indicates temporary cover on inactive areas; \'none\' indicates active filling area; \'planned\' indicates cap design approved but not yet constructed.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cerclaStatus rdf:type rdf:Property ;
    rdfs:label 'Cercla Status' ;
    rdfs:comment 'Current CERCLA/Superfund status of the facility. Indicates whether the site is listed on the National Priorities List (NPL) or subject to CERCLA remedial action obligations. Drives legal liability accruals and environmental compliance reporting. [ENUM-REF-CANDIDATE: not_listed|npl_listed|remedial_investigation|remedial_action|completed|other — promote to reference product]' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classification rdf:type rdf:Property ;
    rdfs:label 'Classification' ;
    rdfs:comment 'Regulatory and operational classification of the landfill facility. MSW (Municipal Solid Waste) accepts household and commercial waste; C&D (Construction and Demolition) accepts construction debris; monofill accepts a single waste type; industrial accepts non-hazardous industrial waste; hazardous is a RCRA Subtitle C facility. Drives applicable regulatory framework and permitted waste streams.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureDate rdf:type rdf:Property ;
    rdfs:label 'Closure Date' ;
    rdfs:comment 'Date on which the landfill facility ceased accepting waste and initiated the formal closure process. Null for active facilities. Triggers post-closure care obligations under RCRA Subtitle D including 30-year monitoring requirements.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:groundwaterMonitoringRequired rdf:type rdf:Property ;
    rdfs:label 'Groundwater Monitoring Required' ;
    rdfs:comment 'Indicates whether the facility is subject to groundwater monitoring requirements under RCRA Subtitle D or state permit conditions. Drives scheduling of monitoring well sampling events and Enviance EHS compliance tracking.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hostCommunityAgreementRef rdf:type rdf:Property ;
    rdfs:label 'Host Community Agreement Ref' ;
    rdfs:comment 'Reference number or document identifier for the host community agreement (HCA) between the facility operator and the local municipality. HCAs govern tipping fee sharing, traffic mitigation, odor controls, and community benefit obligations. Links to contract management records in Salesforce CRM.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaName rdf:type rdf:Property ;
    rdfs:label 'Lea Name' ;
    rdfs:comment 'Name of the Local Enforcement Agency (LEA) responsible for routine inspection and enforcement at the facility. In California and other states, LEAs are county-level agencies delegated enforcement authority by the state. Required for compliance contact management and inspection scheduling.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leachateManagementType rdf:type rdf:Property ;
    rdfs:label 'Leachate Management Type' ;
    rdfs:comment 'Type of leachate collection and management system installed at the facility. Leachate is the liquid that drains through the waste mass and must be managed to prevent groundwater contamination. Drives operational costs, permit conditions, and Clean Water Act (CWA) compliance obligations.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lfgCollectionSystem rdf:type rdf:Property ;
    rdfs:label 'Lfg Collection System' ;
    rdfs:comment 'Indicates whether an active landfill gas (LFG) collection and control system is installed at the facility. LFG systems capture methane for waste-to-energy (WTE) or renewable natural gas (RNG) conversion, and are required under EPA New Source Performance Standards (NSPS) for qualifying facilities. Drives Clean Air Act compliance and sustainability reporting.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lfgUtilizationType rdf:type rdf:Property ;
    rdfs:label 'Lfg Utilization Type' ;
    rdfs:comment 'Method by which captured landfill gas (LFG) is utilized or destroyed. \'flare_only\' indicates gas is combusted without energy recovery; \'electricity_generation\' indicates WTE power generation; \'RNG\' indicates renewable natural gas pipeline injection; \'direct_use\' indicates direct thermal use; \'none\' indicates no LFG system. Drives GHG emissions reporting and sustainability metrics.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linerSystemType rdf:type rdf:Property ;
    rdfs:label 'Liner System Type' ;
    rdfs:comment 'Type of engineered liner system installed at the base of the landfill to prevent leachate migration into groundwater. Determines applicable regulatory standards, leachate collection design, and groundwater monitoring requirements. [ENUM-REF-CANDIDATE: single_composite|double_composite|clay|geomembrane|no_liner|other — promote to reference product if additional liner subtypes are needed]' ;
    rdfs:domain ind:Landfill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringWellCount rdf:type rdf:Property ;
    rdfs:label 'Monitoring Well Count' ;
    rdfs:comment 'Total number of groundwater monitoring wells installed at the facility perimeter and downgradient locations as required by the facility permit. Used for compliance scheduling, sampling cost estimation, and permit condition verification.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:openDate rdf:type rdf:Property ;
    rdfs:label 'Open Date' ;
    rdfs:comment 'Date on which the landfill facility first began accepting waste. Used for site age calculations, post-closure care timeline planning, and historical capacity consumption analysis.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:permitExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Permit Expiration Date' ;
    rdfs:comment 'Date on which the current RCRA Subtitle D or state solid waste operating permit expires. Triggers permit renewal workflow in Enviance EHS. Facilities operating beyond this date without renewal are in violation of RCRA and state regulations.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:permitIssuedDate rdf:type rdf:Property ;
    rdfs:label 'Permit Issued Date' ;
    rdfs:comment 'Date on which the current operating permit was issued by the regulatory authority. Used to calculate permit duration, track renewal cycles, and support compliance audit documentation.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:permittedAcreage rdf:type rdf:Property ;
    rdfs:label 'Permitted Acreage' ;
    rdfs:comment 'Total land area in acres authorized under the current operating permit for waste disposal activities. Drives capacity planning, cell development scheduling, and permit boundary compliance monitoring.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:permittedDailyReceiptTons rdf:type rdf:Property ;
    rdfs:label 'Permitted Daily Receipt Tons' ;
    rdfs:comment 'Maximum tonnage per day (TPD) the facility is permitted to receive under its current operating permit. Operational throughput must not exceed this limit without permit modification. Used for daily tonnage monitoring and permit compliance alerts in Enviance EHS.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postClosureEndDate rdf:type rdf:Property ;
    rdfs:label 'Post Closure End Date' ;
    rdfs:comment 'Projected or actual date on which the mandatory post-closure care period ends (minimum 30 years after closure under RCRA Subtitle D). Used for long-range financial liability estimation and closure cost accrual under IFRS/GAAP.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rcraPermitNumber rdf:type rdf:Property ;
    rdfs:label 'Rcra Permit Number' ;
    rdfs:comment 'State-issued RCRA Subtitle D operating permit number authorizing the facility to receive and dispose of municipal solid waste (MSW) or other permitted waste streams. Required for regulatory compliance and annual permit renewal tracking.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Regulatory Jurisdiction' ;
    rdfs:comment 'Name of the primary state or local regulatory agency with permitting and enforcement authority over the facility (e.g., \'California Department of Resources Recycling and Recovery\', \'Texas Commission on Environmental Quality\'). Determines applicable state-specific regulatory requirements beyond federal RCRA Subtitle D baseline.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remainingAirspaceCy rdf:type rdf:Property ;
    rdfs:label 'Remaining Airspace Cy' ;
    rdfs:comment 'Current remaining permitted airspace in cubic yards, calculated from the most recent engineering survey. Critical KPI for capacity planning, site life estimation, and financial asset valuation under IFRS/GAAP. Updated following each annual or semi-annual airspace survey.' ;
    rdfs:domain ind:Landfill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sapPlantCode rdf:type rdf:Property ;
    rdfs:label 'Sap Plant Code' ;
    rdfs:comment 'Four-character SAP S/4HANA plant code assigned to this landfill facility. Used for financial cost center assignment, materials management (MM), plant maintenance (PM), and EHS module integration. Enables cross-domain financial and operational reporting.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteCode rdf:type rdf:Property ;
    rdfs:label 'Site Code' ;
    rdfs:comment 'Internally assigned alphanumeric code uniquely identifying the landfill site across enterprise systems including SAP S/4HANA, Enviance EHS, and Infor EAM. Used as the cross-system business key.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardTippingFee rdf:type rdf:Property ;
    rdfs:label 'Standard Tipping Fee' ;
    rdfs:comment 'Standard gate rate charged per short ton for waste disposal at the facility (tipping fee). This is the base rate before contractual discounts or surcharges. Confidential commercial pricing data used in Oracle Revenue Management rate configuration and financial planning.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:swisRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Swis Registration Number' ;
    rdfs:comment 'State Solid Waste Information System (SWIS) registration number assigned by the state environmental agency. Used for EPA SWIS reporting submissions and state-level compliance tracking.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalDesignCapacityCy rdf:type rdf:Property ;
    rdfs:label 'Total Design Capacity Cy' ;
    rdfs:comment 'Total permitted airspace capacity of the landfill in cubic yards as approved in the facility design engineering report. Represents the maximum volume of waste and cover material the site is engineered and permitted to contain. Used for long-range capacity planning and permit compliance.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDesignCapacityTons rdf:type rdf:Property ;
    rdfs:label 'Total Design Capacity Tons' ;
    rdfs:comment 'Total permitted disposal capacity of the landfill in short tons as approved in the facility design engineering report. Complements cubic yard capacity for tonnage-based regulatory reporting and financial capacity valuation.' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wasteStreamsAccepted rdf:type rdf:Property ;
    rdfs:label 'Waste Streams Accepted' ;
    rdfs:comment 'Comma-delimited list of waste stream types the facility is permitted to accept (e.g., \'MSW, C&D, industrial non-hazardous, special waste\'). Drives waste acceptance screening, manifest verification, and permit compliance. [ENUM-REF-CANDIDATE: MSW|C&D|industrial_non_hazardous|special_waste|ash|sludge|other — promote to reference product]' ;
    rdfs:domain ind:Site ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capitalProjectId rdf:type rdf:Property ;
    rdfs:label 'Capital Project Id' ;
    rdfs:comment 'Foreign key linking to asset.capital_project. Business justification: Each landfill cell is constructed as a discrete capital project with design, permitting, and construction phases. Capital project completion triggers cell activation and asset capitalization. Construc' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CapitalProject .

ind:actualFillDate rdf:type rdf:Property ;
    rdfs:label 'Actual Fill Date' ;
    rdfs:comment 'Actual date when the cell reached design capacity and was closed to further waste placement.' ;
    rdfs:domain ind:Cell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:areaAcres rdf:type rdf:Property ;
    rdfs:label 'Area Acres' ;
    rdfs:comment 'Horizontal footprint area of the cell in acres, measured at the base liner surface.' ;
    rdfs:domain ind:Cell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageDailyTonnage rdf:type rdf:Property ;
    rdfs:label 'Average Daily Tonnage' ;
    rdfs:comment 'Average tons per day (TPD) received in this cell during active operations, used for capacity planning and operational forecasting.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseElevationFeet rdf:type rdf:Property ;
    rdfs:label 'Base Elevation Feet' ;
    rdfs:comment 'Elevation of the cell base (liner surface) in feet above mean sea level, used for airspace calculations and grading plans.' ;
    rdfs:domain ind:Cell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cellName rdf:type rdf:Property ;
    rdfs:label 'Cell Name' ;
    rdfs:comment 'Descriptive name for the cell used in operational and planning documents.' ;
    rdfs:domain ind:Cell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cellNumber rdf:type rdf:Property ;
    rdfs:label 'Cell Number' ;
    rdfs:comment 'Business identifier for the cell, typically alphanumeric code used in operational communications and regulatory reporting (e.g., CELL-A1, PHASE2-C3).' ;
    rdfs:domain ind:Cell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cellStatus rdf:type rdf:Property ;
    rdfs:label 'Cell Status' ;
    rdfs:comment 'Current operational status of the cell in its lifecycle: planned (designed but not built), under_construction (being prepared), active (receiving waste), filled (at capacity but not closed), closed (operations ceased, interim cover applied), capped (final cover system installed).' ;
    rdfs:domain ind:Cell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compactionRatioTarget rdf:type rdf:Property ;
    rdfs:label 'Compaction Ratio Target' ;
    rdfs:comment 'Target volume reduction ratio for waste compaction operations in this cell, typically expressed as ratio of loose volume to compacted volume (e.g., 4.0 means 4:1 reduction).' ;
    rdfs:domain ind:Cell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:constructionCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Construction Completion Date' ;
    rdfs:comment 'Date when cell construction was completed and the cell was certified ready for waste placement.' ;
    rdfs:domain ind:Cell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:constructionStartDate rdf:type rdf:Property ;
    rdfs:label 'Construction Start Date' ;
    rdfs:comment 'Date when physical construction of the cell (excavation, liner installation) commenced.' ;
    rdfs:domain ind:Cell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:currentElevationFeet rdf:type rdf:Property ;
    rdfs:label 'Current Elevation Feet' ;
    rdfs:comment 'Current elevation of the active waste surface in feet above mean sea level, updated from periodic topographic surveys.' ;
    rdfs:domain ind:Cell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dailyCoverMaterialType rdf:type rdf:Property ;
    rdfs:label 'Daily Cover Material Type' ;
    rdfs:comment 'Type of material used for daily cover application to control odors, vectors, and litter: soil (traditional 6-inch soil cover), alternative_daily_cover (ADC such as compost, shredded green waste), tarps (reusable geomembrane tarps), foam (spray-applied foam), auto_daily_cover (automated tarp systems).' ;
    rdfs:domain ind:Cell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designCapacityCubicYards rdf:type rdf:Property ;
    rdfs:label 'Design Capacity Cubic Yards' ;
    rdfs:comment 'Total permitted airspace volume for waste placement in cubic yards, as specified in the engineering design and regulatory permit.' ;
    rdfs:domain ind:Cell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:designCapacityTons rdf:type rdf:Property ;
    rdfs:label 'Design Capacity Tons' ;
    rdfs:comment 'Total permitted waste tonnage capacity, calculated from design volume and assumed compaction density.' ;
    rdfs:domain ind:Cell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalMonitoringFrequency rdf:type rdf:Property ;
    rdfs:label 'Environmental Monitoring Frequency' ;
    rdfs:comment 'Required frequency for environmental monitoring activities (groundwater sampling, gas monitoring, leachate testing) as specified in the permit.' ;
    rdfs:domain ind:Cell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finalCapInstallationDate rdf:type rdf:Property ;
    rdfs:label 'Final Cap Installation Date' ;
    rdfs:comment 'Date when the final cover system (cap) was installed over the closed cell, marking the beginning of post-closure care period.' ;
    rdfs:domain ind:Cell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gasCollectionStartDate rdf:type rdf:Property ;
    rdfs:label 'Gas Collection Start Date' ;
    rdfs:comment 'Date when active gas collection operations commenced in this cell, required for EPA NSPS/EG compliance tracking.' ;
    rdfs:domain ind:Cell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gasCollectionSystemInstalled rdf:type rdf:Property ;
    rdfs:label 'Gas Collection System Installed' ;
    rdfs:comment 'Indicates whether an active landfill gas collection system (vertical wells and/or horizontal collectors) has been installed in this cell.' ;
    rdfs:domain ind:Cell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geometryCoordinates rdf:type rdf:Property ;
    rdfs:label 'Geometry Coordinates' ;
    rdfs:comment 'Well-Known Text (WKT) representation of the cell boundary polygon coordinates for GIS mapping and spatial analysis.' ;
    rdfs:domain ind:Cell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groundwaterMonitoringWells rdf:type rdf:Property ;
    rdfs:label 'Groundwater Monitoring Wells' ;
    rdfs:comment 'Comma-separated list of groundwater monitoring well identifiers assigned to this cell for environmental compliance monitoring per RCRA Subtitle D requirements.' ;
    rdfs:domain ind:Cell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linerThicknessInches rdf:type rdf:Property ;
    rdfs:label 'Liner Thickness Inches' ;
    rdfs:comment 'Total thickness of the liner system in inches, including all geomembrane and clay layers.' ;
    rdfs:domain ind:Cell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:openingDate rdf:type rdf:Property ;
    rdfs:label 'Opening Date' ;
    rdfs:comment 'Date when the cell was opened for active waste placement operations.' ;
    rdfs:domain ind:Cell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:permittedWasteTypes rdf:type rdf:Property ;
    rdfs:label 'Permitted Waste Types' ;
    rdfs:comment 'Comma-separated list of waste types authorized for disposal in this cell per regulatory permit (e.g., MSW, C&D, special waste, industrial non-hazardous). [ENUM-REF-CANDIDATE: MSW|C&D|special_waste|industrial_non_hazardous|asbestos|contaminated_soil|sludge|ash — promote to reference product]' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phaseNumber rdf:type rdf:Property ;
    rdfs:label 'Phase Number' ;
    rdfs:comment 'Development phase identifier indicating the sequential construction phase of the landfill expansion plan.' ;
    rdfs:domain ind:Cell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postClosureCareEndDate rdf:type rdf:Property ;
    rdfs:label 'Post Closure Care End Date' ;
    rdfs:comment 'Projected or actual date when the 30-year post-closure care period (monitoring, maintenance, gas management) will end or ended.' ;
    rdfs:domain ind:Landfill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:projectedFillDate rdf:type rdf:Property ;
    rdfs:label 'Projected Fill Date' ;
    rdfs:comment 'Forecasted date when the cell is expected to reach design capacity based on current waste placement rates and airspace consumption trends.' ;
    rdfs:domain ind:Cell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remainingCapacityCubicYards rdf:type rdf:Property ;
    rdfs:label 'Remaining Capacity Cubic Yards' ;
    rdfs:comment 'Current available airspace for waste placement in cubic yards, updated based on survey measurements and waste placement records.' ;
    rdfs:domain ind:Cell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responsibleEngineer rdf:type rdf:Property ;
    rdfs:label 'Responsible Engineer' ;
    rdfs:comment 'Name of the licensed professional engineer responsible for design certification and ongoing compliance oversight for this cell.' ;
    rdfs:domain ind:Landfill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:topElevationFeet rdf:type rdf:Property ;
    rdfs:label 'Top Elevation Feet' ;
    rdfs:comment 'Permitted final elevation of the cell top surface in feet above mean sea level, defining the maximum fill height.' ;
    rdfs:domain ind:Cell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalTonnageReceived rdf:type rdf:Property ;
    rdfs:label 'Total Tonnage Received' ;
    rdfs:comment 'Cumulative tonnage of waste placed in this cell since opening, tracked for capacity management and regulatory reporting.' ;
    rdfs:domain ind:Cell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:collectionRouteExecutionId rdf:type rdf:Property ;
    rdfs:label 'Collection Route Execution Id' ;
    rdfs:comment 'Foreign key linking to collection.route_execution. Business justification: Landfill tonnage receipts from direct collection routes (not transfer station hauls) need route execution reference for proof-of-service, billing reconciliation, and route-to-disposal tracking. Core d' ;
    rdfs:domain ind:TonnageReceipt ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RouteExecution .

ind:collectionWeightTicketId rdf:type rdf:Property ;
    rdfs:label 'Collection Weight Ticket Id' ;
    rdfs:comment 'Foreign key linking to collection.weight_ticket. Business justification: Landfill tonnage receipts should reference originating collection weight tickets for end-to-end waste tracking, weight reconciliation, and audit trail from collection through disposal. Core collection' ;
    rdfs:domain ind:TonnageReceipt ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WeightTicket .

ind:landfillTippingFeeScheduleId rdf:type rdf:Property ;
    rdfs:label 'Landfill Tipping Fee Schedule Id' ;
    rdfs:comment 'Foreign key linking to landfill.landfill_tipping_fee_schedule. Business justification: Each tonnage receipt is priced according to a tipping fee schedule based on waste type, customer segment, and effective date. Linking receipt to the fee schedule provides audit trail for rate justific' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LandfillTippingFeeSchedule .

ind:primaryTonnageLandfillSiteId rdf:type rdf:Property ;
    rdfs:label 'Primary Tonnage Landfill Site Id' ;
    rdfs:comment 'Identifier of the landfill facility where this tonnage receipt was recorded. Supports multi-site operations and reporting.' ;
    rdfs:domain ind:TonnageReceipt ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Site .

ind:contaminationNotes rdf:type rdf:Property ;
    rdfs:label 'Contamination Notes' ;
    rdfs:comment 'Detailed notes describing any contamination, prohibited materials, or acceptance criteria violations observed during load inspection.' ;
    rdfs:domain ind:TonnageReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inboundScaleTime rdf:type rdf:Property ;
    rdfs:label 'Inbound Scale Time' ;
    rdfs:comment 'Timestamp when the loaded vehicle was weighed on the inbound scale.' ;
    rdfs:domain ind:TonnageReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:loadInspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Load Inspection Status' ;
    rdfs:comment 'Status of visual or detailed inspection performed on the waste load at the scale house to verify compliance with acceptance criteria.' ;
    rdfs:domain ind:TonnageReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadRejectedFlag rdf:type rdf:Property ;
    rdfs:label 'Load Rejected Flag' ;
    rdfs:comment 'Boolean indicator of whether the waste load was rejected and not accepted for disposal at the landfill.' ;
    rdfs:domain ind:TonnageReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:moistureContentPercent rdf:type rdf:Property ;
    rdfs:label 'Moisture Content Percent' ;
    rdfs:comment 'Estimated moisture content of the waste load as a percentage. Used for waste characterization and compaction ratio calculations.' ;
    rdfs:domain ind:TonnageReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netTonnage rdf:type rdf:Property ;
    rdfs:label 'Net Tonnage' ;
    rdfs:comment 'Calculated net weight of waste material in tons (gross weight minus tare weight). Primary measure for TPD (Tons Per Day) reporting and tipping fee calculation.' ;
    rdfs:domain ind:TonnageReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outboundScaleTime rdf:type rdf:Property ;
    rdfs:label 'Outbound Scale Time' ;
    rdfs:comment 'Timestamp when the empty vehicle was weighed on the outbound scale after waste disposal.' ;
    rdfs:domain ind:TonnageReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:paymentMethod rdf:type rdf:Property ;
    rdfs:label 'Payment Method' ;
    rdfs:comment 'Method by which tipping fees for this load will be collected (account billing, immediate payment, etc.).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiptTimestamp rdf:type rdf:Property ;
    rdfs:label 'Receipt Timestamp' ;
    rdfs:comment 'Date and time when the waste load was received and weighed at the landfill scale house. Primary business event timestamp for this transaction.' ;
    rdfs:domain ind:TonnageReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:specialHandlingCode rdf:type rdf:Property ;
    rdfs:label 'Special Handling Code' ;
    rdfs:comment 'Code indicating any special handling requirements for this waste load (e.g., asbestos protocols, odor control, immediate cover).' ;
    rdfs:domain ind:TonnageReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tippingFeeRate rdf:type rdf:Property ;
    rdfs:label 'Tipping Fee Rate' ;
    rdfs:comment 'Per-ton tipping fee rate applied to this waste load based on waste type, customer contract, and applicable rate schedule. Expressed in USD per ton.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionStatus rdf:type rdf:Property ;
    rdfs:label 'Transaction Status' ;
    rdfs:comment 'Current lifecycle status of the tonnage receipt transaction in the billing and operational workflow.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleLicensePlate rdf:type rdf:Property ;
    rdfs:label 'Vehicle License Plate' ;
    rdfs:comment 'License plate number of the vehicle that delivered the waste load. Used for vehicle identification and security tracking.' ;
    rdfs:domain ind:TonnageReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteOriginType rdf:type rdf:Property ;
    rdfs:label 'Waste Origin Type' ;
    rdfs:comment 'Classification of the source from which the waste load originated (collection route, transfer station, direct customer haul, etc.).' ;
    rdfs:domain ind:TonnageReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteSubtype rdf:type rdf:Property ;
    rdfs:label 'Waste Subtype' ;
    rdfs:comment 'Secondary or detailed classification of waste material within the primary waste type category. Provides granular categorization for specialized waste streams.' ;
    rdfs:domain ind:TonnageReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteType rdf:type rdf:Property ;
    rdfs:label 'Waste Type' ;
    rdfs:comment 'Primary classification of waste material type received. MSW (Municipal Solid Waste), C&D (Construction and Demolition Waste), special waste, sludge, or other regulated categories per RCRA Subtitle D. [ENUM-REF-CANDIDATE: MSW|C&D|special_waste|sludge|industrial|medical|asbestos — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TonnageReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:airspaceConsumptionId rdf:type rdf:Property ;
    rdfs:label 'Airspace Consumption Id' ;
    rdfs:comment 'Unique identifier for the airspace consumption measurement record.' ;
    rdfs:domain ind:AirspaceConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cndTonnageTons rdf:type rdf:Property ;
    rdfs:label 'Cnd Tonnage Tons' ;
    rdfs:comment 'Tonnage of Construction and Demolition waste placed during the measurement period.' ;
    rdfs:domain ind:AirspaceConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compactionRatio rdf:type rdf:Property ;
    rdfs:label 'Compaction Ratio' ;
    rdfs:comment 'Ratio of in-place waste density achieved versus design density, indicating compaction effectiveness.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coverMaterialVolumeCubicYards rdf:type rdf:Property ;
    rdfs:label 'Cover Material Volume Cubic Yards' ;
    rdfs:comment 'Volume of daily cover material (soil, alternative daily cover) applied during the measurement period, measured in cubic yards.' ;
    rdfs:domain ind:AirspaceConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cumulativeVolumeConsumedCubicYards rdf:type rdf:Property ;
    rdfs:label 'Cumulative Volume Consumed Cubic Yards' ;
    rdfs:comment 'Total cumulative volume of airspace consumed in the cell or site since opening, measured in cubic yards.' ;
    rdfs:domain ind:AirspaceConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:designDensityLbsPerCubicYard rdf:type rdf:Property ;
    rdfs:label 'Design Density Lbs Per Cubic Yard' ;
    rdfs:comment 'Target design density for waste compaction as specified in facility design, measured in pounds per cubic yard.' ;
    rdfs:domain ind:AirspaceConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inPlaceDensityLbsPerCubicYard rdf:type rdf:Property ;
    rdfs:label 'In Place Density Lbs Per Cubic Yard' ;
    rdfs:comment 'Actual density of compacted waste in place, measured in pounds per cubic yard.' ;
    rdfs:domain ind:AirspaceConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementAccuracyCubicYards rdf:type rdf:Property ;
    rdfs:label 'Measurement Accuracy Cubic Yards' ;
    rdfs:comment 'Estimated accuracy or margin of error of the airspace measurement, expressed in cubic yards.' ;
    rdfs:domain ind:AirspaceConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementDate rdf:type rdf:Property ;
    rdfs:label 'Measurement Date' ;
    rdfs:comment 'Date when the airspace consumption measurement was performed.' ;
    rdfs:domain ind:AirspaceConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measurementPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Measurement Period End Date' ;
    rdfs:comment 'End date of the period for which airspace consumption is being measured.' ;
    rdfs:domain ind:AirspaceConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measurementPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Measurement Period Start Date' ;
    rdfs:comment 'Start date of the period for which airspace consumption is being measured.' ;
    rdfs:domain ind:AirspaceConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measurementStatus rdf:type rdf:Property ;
    rdfs:label 'Measurement Status' ;
    rdfs:comment 'Current status of the airspace consumption measurement in the review and approval workflow.' ;
    rdfs:domain ind:AirspaceConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mswTonnageTons rdf:type rdf:Property ;
    rdfs:label 'Msw Tonnage Tons' ;
    rdfs:comment 'Tonnage of Municipal Solid Waste placed during the measurement period.' ;
    rdfs:domain ind:AirspaceConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:projectedClosureDate rdf:type rdf:Property ;
    rdfs:label 'Projected Closure Date' ;
    rdfs:comment 'Estimated date when the cell or site will reach permitted capacity based on current consumption rates.' ;
    rdfs:domain ind:AirspaceConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rateCubicYardsPerDay rdf:type rdf:Property ;
    rdfs:label 'Rate Cubic Yards Per Day' ;
    rdfs:comment 'Average daily rate of airspace consumption during the measurement period, calculated as volume consumed divided by days in period.' ;
    rdfs:domain ind:AirspaceConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryReportingPeriod rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Period' ;
    rdfs:comment 'Regulatory reporting period identifier (e.g., Q1 2024, Annual 2024) for which this measurement applies.' ;
    rdfs:domain ind:AirspaceConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remainingPermittedAirspaceCubicYards rdf:type rdf:Property ;
    rdfs:label 'Remaining Permitted Airspace Cubic Yards' ;
    rdfs:comment 'Remaining permitted airspace capacity available in the cell or site, measured in cubic yards.' ;
    rdfs:domain ind:AirspaceConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:specialWasteTonnageTons rdf:type rdf:Property ;
    rdfs:label 'Special Waste Tonnage Tons' ;
    rdfs:comment 'Tonnage of special waste (non-hazardous industrial, contaminated soil, etc.) placed during the measurement period.' ;
    rdfs:domain ind:AirspaceConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:surveyCertificationDate rdf:type rdf:Property ;
    rdfs:label 'Survey Certification Date' ;
    rdfs:comment 'Date when the surveyor certified the airspace consumption measurement.' ;
    rdfs:domain ind:AirspaceConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:surveyMethod rdf:type rdf:Property ;
    rdfs:label 'Survey Method' ;
    rdfs:comment 'Method used to measure airspace consumption (e.g., drone photogrammetry, GPS survey, LiDAR, total station).' ;
    rdfs:domain ind:AirspaceConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyReportReference rdf:type rdf:Property ;
    rdfs:label 'Survey Report Reference' ;
    rdfs:comment 'Reference number or document identifier for the detailed survey report supporting this measurement.' ;
    rdfs:domain ind:AirspaceConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyorLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Surveyor License Number' ;
    rdfs:comment 'Professional license number of the surveyor who certified the measurement.' ;
    rdfs:domain ind:AirspaceConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyorName rdf:type rdf:Property ;
    rdfs:label 'Surveyor Name' ;
    rdfs:comment 'Name of the licensed surveyor or survey firm that performed the airspace measurement.' ;
    rdfs:domain ind:AirspaceConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalPermittedCapacityCubicYards rdf:type rdf:Property ;
    rdfs:label 'Total Permitted Capacity Cubic Yards' ;
    rdfs:comment 'Total permitted airspace capacity for the cell or site as authorized by regulatory permit, measured in cubic yards.' ;
    rdfs:domain ind:AirspaceConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeConsumedCubicYards rdf:type rdf:Property ;
    rdfs:label 'Volume Consumed Cubic Yards' ;
    rdfs:comment 'Volume of airspace consumed during the measurement period, measured in cubic yards.' ;
    rdfs:domain ind:AirspaceConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wasteTonnagePlacedTons rdf:type rdf:Property ;
    rdfs:label 'Waste Tonnage Placed Tons' ;
    rdfs:comment 'Total tonnage of waste placed in the cell or site during the measurement period.' ;
    rdfs:domain ind:AirspaceConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yearsRemainingCapacity rdf:type rdf:Property ;
    rdfs:label 'Years Remaining Capacity' ;
    rdfs:comment 'Estimated number of years of remaining airspace capacity based on current consumption trends.' ;
    rdfs:domain ind:AirspaceConsumption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dailyCoverId rdf:type rdf:Property ;
    rdfs:label 'Daily Cover Id' ;
    rdfs:comment 'Unique identifier for the daily cover application event record.' ;
    rdfs:domain ind:DailyCover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adcPermitNumber rdf:type rdf:Property ;
    rdfs:label 'Adc Permit Number' ;
    rdfs:comment 'EPA or state-issued permit number authorizing use of alternative daily cover materials in lieu of traditional soil cover.' ;
    rdfs:domain ind:DailyCover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceNotes rdf:type rdf:Property ;
    rdfs:label 'Compliance Notes' ;
    rdfs:comment 'Additional notes regarding compliance status, including reasons for non-compliance, corrective actions taken, or special circumstances.' ;
    rdfs:domain ind:DailyCover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Completed Timestamp' ;
    rdfs:comment 'Timestamp when corrective action was completed and verified.' ;
    rdfs:domain ind:DailyCover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:correctiveActionDescription rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Description' ;
    rdfs:comment 'Description of corrective actions taken or planned to address daily cover deficiencies.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Required Flag' ;
    rdfs:comment 'Indicates whether corrective action is required to address deficiencies in the daily cover application. True = corrective action required, False = no action required.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coverApplicationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cover Application Timestamp' ;
    rdfs:comment 'Precise timestamp when the daily cover application was completed.' ;
    rdfs:domain ind:DailyCover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:coverDate rdf:type rdf:Property ;
    rdfs:label 'Cover Date' ;
    rdfs:comment 'The date on which the daily cover was applied to the active working face.' ;
    rdfs:domain ind:DailyCover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:coverMaterialCostUsd rdf:type rdf:Property ;
    rdfs:label 'Cover Material Cost Usd' ;
    rdfs:comment 'Total cost of cover material used in this application event, measured in US dollars. Includes material purchase or extraction cost.' ;
    rdfs:domain ind:DailyCover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coverMaterialDescription rdf:type rdf:Property ;
    rdfs:label 'Cover Material Description' ;
    rdfs:comment 'Detailed description of the specific cover material used, including brand name, product specifications, or soil classification.' ;
    rdfs:domain ind:DailyCover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverMaterialType rdf:type rdf:Property ;
    rdfs:label 'Cover Material Type' ;
    rdfs:comment 'Type of material used for daily cover application. Soil is traditional 6-inch cover; ADC (Alternative Daily Cover) includes tarps, foam, spray-on products, and other EPA-approved alternatives.' ;
    rdfs:domain ind:DailyCover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deficienciesIdentified rdf:type rdf:Property ;
    rdfs:label 'Deficiencies Identified' ;
    rdfs:comment 'Description of any deficiencies or non-conformances identified during inspection, such as inadequate thickness, incomplete coverage, or material failure.' ;
    rdfs:domain ind:DailyCover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentHours rdf:type rdf:Property ;
    rdfs:label 'Equipment Hours' ;
    rdfs:comment 'Total equipment operating hours logged during this daily cover application event.' ;
    rdfs:domain ind:DailyCover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fireRiskMitigation rdf:type rdf:Property ;
    rdfs:label 'Fire Risk Mitigation' ;
    rdfs:comment 'Assessment of how effectively the daily cover reduced subsurface fire risk by limiting oxygen infiltration.' ;
    rdfs:domain ind:DailyCover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gpsCoordinates rdf:type rdf:Property ;
    rdfs:label 'Gps Coordinates' ;
    rdfs:comment 'GPS coordinates (latitude, longitude) of the covered working face area for spatial tracking and airspace management.' ;
    rdfs:domain ind:DailyCover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionPerformedFlag rdf:type rdf:Property ;
    rdfs:label 'Inspection Performed Flag' ;
    rdfs:comment 'Indicates whether a formal inspection of the daily cover application was performed by supervisory or compliance staff. True = inspection performed, False = no inspection.' ;
    rdfs:domain ind:DailyCover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:litterControlEffectiveness rdf:type rdf:Property ;
    rdfs:label 'Litter Control Effectiveness' ;
    rdfs:comment 'Assessment of how effectively the daily cover prevented windblown litter and debris dispersal from the working face.' ;
    rdfs:domain ind:DailyCover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:odorControlEffectiveness rdf:type rdf:Property ;
    rdfs:label 'Odor Control Effectiveness' ;
    rdfs:comment 'Subjective assessment of how effectively the daily cover controlled odor emissions from the working face.' ;
    rdfs:domain ind:DailyCover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:photoDocumentationUrl rdf:type rdf:Property ;
    rdfs:label 'Photo Documentation Url' ;
    rdfs:comment 'URL or file path to photographic documentation of the daily cover application, used for compliance records and quality assurance.' ;
    rdfs:domain ind:DailyCover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordStatus rdf:type rdf:Property ;
    rdfs:label 'Record Status' ;
    rdfs:comment 'Current status of this daily cover record in the system lifecycle.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remarks rdf:type rdf:Property ;
    rdfs:label 'Remarks' ;
    rdfs:comment 'Free-text field for additional operational notes, observations, or special circumstances related to the daily cover application event.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shift rdf:type rdf:Property ;
    rdfs:label 'Shift' ;
    rdfs:comment 'Work shift during which the daily cover application was performed.' ;
    rdfs:domain ind:DailyCover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureFahrenheit rdf:type rdf:Property ;
    rdfs:label 'Temperature Fahrenheit' ;
    rdfs:comment 'Ambient air temperature at time of cover application, measured in degrees Fahrenheit. Affects material handling and curing for certain ADC products.' ;
    rdfs:domain ind:Landfill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:thicknessAchievedInches rdf:type rdf:Property ;
    rdfs:label 'Thickness Achieved Inches' ;
    rdfs:comment 'Actual thickness of cover material achieved after compaction, measured in inches. RCRA Subtitle D requires minimum 6 inches of soil or approved ADC equivalent.' ;
    rdfs:domain ind:DailyCover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vectorControlEffectiveness rdf:type rdf:Property ;
    rdfs:label 'Vector Control Effectiveness' ;
    rdfs:comment 'Assessment of how effectively the daily cover prevented access by birds, rodents, and insects (disease vectors).' ;
    rdfs:domain ind:DailyCover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeAppliedCubicYards rdf:type rdf:Property ;
    rdfs:label 'Volume Applied Cubic Yards' ;
    rdfs:comment 'Total volume of cover material applied measured in cubic yards. Applicable primarily to soil and bulk ADC materials.' ;
    rdfs:domain ind:DailyCover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weatherConditions rdf:type rdf:Property ;
    rdfs:label 'Weather Conditions' ;
    rdfs:comment 'Prevailing weather conditions during cover application. Weather impacts material performance and application effectiveness.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:windSpeedMph rdf:type rdf:Property ;
    rdfs:label 'Wind Speed Mph' ;
    rdfs:comment 'Wind speed during cover application measured in miles per hour. High winds can affect tarp and foam application effectiveness.' ;
    rdfs:domain ind:Landfill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:workingFaceAreaSquareFeet rdf:type rdf:Property ;
    rdfs:label 'Working Face Area Square Feet' ;
    rdfs:comment 'Total surface area of the active working face covered during this application event, measured in square feet.' ;
    rdfs:domain ind:DailyCover ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leachateCollectionId rdf:type rdf:Property ;
    rdfs:label 'Leachate Collection Id' ;
    rdfs:comment 'Unique identifier for the leachate collection event record.' ;
    rdfs:domain ind:LeachateCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:disposalFacilityId rdf:type rdf:Property ;
    rdfs:label 'Disposal Facility Id' ;
    rdfs:comment 'Identifier of the Treatment, Storage, and Disposal Facility (TSDF) or municipal wastewater treatment plant where leachate was sent for disposal.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:leachateManifestId rdf:type rdf:Property ;
    rdfs:label 'Leachate Manifest Id' ;
    rdfs:comment 'Foreign key linking to hazmat.manifest. Business justification: When characteristically hazardous leachate is transported off-site to a TSDF, RCRA requires a hazardous waste manifest. The leachate_collection record tracks off-site disposal events; linking to the g' ;
    rdfs:domain ind:LeachateCollection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Manifest .

ind:ammoniaNitrogenMgL rdf:type rdf:Property ;
    rdfs:label 'Ammonia Nitrogen Mg L' ;
    rdfs:comment 'Ammonia nitrogen concentration in milligrams per liter, a key nutrient pollutant parameter.' ;
    rdfs:domain ind:LeachateCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bodMgL rdf:type rdf:Property ;
    rdfs:label 'Bod Mg L' ;
    rdfs:comment 'Biological Oxygen Demand measurement in milligrams per liter, indicating biodegradable organic matter in the leachate.' ;
    rdfs:domain ind:Landfill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:codMgL rdf:type rdf:Property ;
    rdfs:label 'Cod Mg L' ;
    rdfs:comment 'Chemical Oxygen Demand measurement in milligrams per liter, indicating organic pollutant load in the leachate.' ;
    rdfs:domain ind:Landfill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:collectionDate rdf:type rdf:Property ;
    rdfs:label 'Collection Date' ;
    rdfs:comment 'Date when the leachate collection event occurred.' ;
    rdfs:domain ind:LeachateCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:collectionMethod rdf:type rdf:Property ;
    rdfs:label 'Collection Method' ;
    rdfs:comment 'Method used to collect the leachate from the collection point.' ;
    rdfs:domain ind:LeachateCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionPointType rdf:type rdf:Property ;
    rdfs:label 'Collection Point Type' ;
    rdfs:comment 'Type of collection infrastructure where leachate was gathered.' ;
    rdfs:domain ind:LeachateCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionSystemStatus rdf:type rdf:Property ;
    rdfs:label 'Collection System Status' ;
    rdfs:comment 'Operational status of the leachate collection system at the time of the event.' ;
    rdfs:domain ind:LeachateCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Collection Timestamp' ;
    rdfs:comment 'Precise timestamp when the leachate collection measurement was recorded.' ;
    rdfs:domain ind:LeachateCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:conductivityUmhosCm rdf:type rdf:Property ;
    rdfs:label 'Conductivity Umhos Cm' ;
    rdfs:comment 'Electrical conductivity of the leachate sample measured in micromhos per centimeter, indicating dissolved solids concentration.' ;
    rdfs:domain ind:LeachateCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disposalCostUsd rdf:type rdf:Property ;
    rdfs:label 'Disposal Cost Usd' ;
    rdfs:comment 'Cost incurred for leachate disposal or treatment in US dollars.' ;
    rdfs:domain ind:LeachateCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disposalVolumeGallons rdf:type rdf:Property ;
    rdfs:label 'Disposal Volume Gallons' ;
    rdfs:comment 'Volume of leachate disposed or treated, measured in gallons.' ;
    rdfs:domain ind:LeachateCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exceedanceParameters rdf:type rdf:Property ;
    rdfs:label 'Exceedance Parameters' ;
    rdfs:comment 'Comma-separated list of parameters that exceeded permit limits during this collection event.' ;
    rdfs:domain ind:Landfill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:heavyMetalsDetected rdf:type rdf:Property ;
    rdfs:label 'Heavy Metals Detected' ;
    rdfs:comment 'Comma-separated list of heavy metals detected in the leachate sample (e.g., lead, cadmium, mercury, arsenic) per TCLP testing.' ;
    rdfs:domain ind:LeachateCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labAnalysisDate rdf:type rdf:Property ;
    rdfs:label 'Lab Analysis Date' ;
    rdfs:comment 'Date when the laboratory analysis of the leachate sample was completed.' ;
    rdfs:domain ind:Landfill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:labSampleNumber rdf:type rdf:Property ;
    rdfs:label 'Lab Sample Number' ;
    rdfs:comment 'Unique identifier assigned to the laboratory sample for chain-of-custody tracking and analysis.' ;
    rdfs:domain ind:Landfill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leachateHeadLevelInches rdf:type rdf:Property ;
    rdfs:label 'Leachate Head Level Inches' ;
    rdfs:comment 'Measured leachate head level in inches above the liner at the collection point, critical for liner integrity monitoring.' ;
    rdfs:domain ind:LeachateCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:linerIntegrityStatus rdf:type rdf:Property ;
    rdfs:label 'Liner Integrity Status' ;
    rdfs:comment 'Assessment of liner integrity at the collection point based on leachate head levels and monitoring data.' ;
    rdfs:domain ind:Landfill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitLimitComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Permit Limit Compliance Flag' ;
    rdfs:comment 'Boolean flag indicating whether the leachate quality parameters were within permitted discharge limits (True = compliant, False = violation).' ;
    rdfs:domain ind:LeachateCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:phLevel rdf:type rdf:Property ;
    rdfs:label 'Ph Level' ;
    rdfs:comment 'pH measurement of the collected leachate sample, indicating acidity or alkalinity.' ;
    rdfs:domain ind:Landfill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:precipitationLast24hInches rdf:type rdf:Property ;
    rdfs:label 'Precipitation Last 24h Inches' ;
    rdfs:comment 'Total precipitation in inches during the 24 hours prior to collection, affecting leachate generation volume.' ;
    rdfs:domain ind:LeachateCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sampleCollectedFlag rdf:type rdf:Property ;
    rdfs:label 'Sample Collected Flag' ;
    rdfs:comment 'Boolean flag indicating whether a laboratory sample was collected during this event for detailed analysis (True = sample collected, False = no sample).' ;
    rdfs:domain ind:Landfill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalDissolvedSolidsMgL rdf:type rdf:Property ;
    rdfs:label 'Total Dissolved Solids Mg L' ;
    rdfs:comment 'Total dissolved solids concentration in milligrams per liter.' ;
    rdfs:domain ind:LeachateCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalSuspendedSolidsMgL rdf:type rdf:Property ;
    rdfs:label 'Total Suspended Solids Mg L' ;
    rdfs:comment 'Total suspended solids concentration in milligrams per liter.' ;
    rdfs:domain ind:LeachateCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeCollectedGallons rdf:type rdf:Property ;
    rdfs:label 'Volume Collected Gallons' ;
    rdfs:comment 'Total volume of leachate collected during this event, measured in gallons.' ;
    rdfs:domain ind:LeachateCollection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lfgMonitoringId rdf:type rdf:Property ;
    rdfs:label 'Lfg Monitoring Id' ;
    rdfs:comment 'Unique identifier for the landfill gas monitoring record.' ;
    rdfs:domain ind:LfgMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:correctiveWorkOrderId rdf:type rdf:Property ;
    rdfs:label 'Corrective Work Order Id' ;
    rdfs:comment 'Foreign key linking to maintenance.work_order. Business justification: When LFG monitoring detects exceedances requiring corrective maintenance (well repairs, header pipe leaks), operations generate work orders. Tracking this linkage is essential for demonstrating regula' ;
    rdfs:domain ind:LfgMonitoring ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkOrder .

ind:barometricPressureInhg rdf:type rdf:Property ;
    rdfs:label 'Barometric Pressure Inhg' ;
    rdfs:comment 'Atmospheric barometric pressure at the time of monitoring measured in inches of mercury. Barometric pressure changes can affect landfill gas migration patterns.' ;
    rdfs:domain ind:LfgMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carbonDioxideConcentrationPct rdf:type rdf:Property ;
    rdfs:label 'Carbon Dioxide Concentration Pct' ;
    rdfs:comment 'Carbon dioxide concentration measured as a percentage by volume at the monitoring point. Used to assess landfill gas composition and biological activity.' ;
    rdfs:domain ind:LfgMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carbonMonoxidePpm rdf:type rdf:Property ;
    rdfs:label 'Carbon Monoxide Ppm' ;
    rdfs:comment 'Carbon monoxide concentration measured in parts per million. Elevated CO levels may indicate incomplete combustion or subsurface smoldering.' ;
    rdfs:domain ind:LfgMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Status' ;
    rdfs:comment 'Current compliance status of the monitoring point based on the reading and applicable regulatory thresholds.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataQualityFlag rdf:type rdf:Property ;
    rdfs:label 'Data Quality Flag' ;
    rdfs:comment 'Quality assurance flag indicating the reliability and validity of the monitoring data. Suspect or invalid data may require re-sampling or equipment recalibration.' ;
    rdfs:domain ind:LfgMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceedanceFlag rdf:type rdf:Property ;
    rdfs:label 'Exceedance Flag' ;
    rdfs:comment 'Boolean indicator that is set to True when the monitoring reading exceeds regulatory thresholds, such as LEL greater than 25%, triggering mandatory regulatory action and reporting.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exceedanceType rdf:type rdf:Property ;
    rdfs:label 'Exceedance Type' ;
    rdfs:comment 'Classification of the type of regulatory or operational threshold that was exceeded during the monitoring event.' ;
    rdfs:domain ind:LfgMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hydrogenSulfidePpm rdf:type rdf:Property ;
    rdfs:label 'Hydrogen Sulfide Ppm' ;
    rdfs:comment 'Hydrogen sulfide concentration measured in parts per million. H2S is a toxic and corrosive gas that poses health and safety risks and can damage gas collection equipment.' ;
    rdfs:domain ind:LfgMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lelPercentage rdf:type rdf:Property ;
    rdfs:label 'Lel Percentage' ;
    rdfs:comment 'Lower Explosive Limit reading expressed as a percentage. LEL measures the concentration of combustible gas relative to the minimum concentration required for ignition. Regulatory action is triggered when LEL exceeds 25%.' ;
    rdfs:domain ind:LfgMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lfgFlowRateScfm rdf:type rdf:Property ;
    rdfs:label 'Lfg Flow Rate Scfm' ;
    rdfs:comment 'Volumetric flow rate of landfill gas measured in standard cubic feet per minute at the monitoring point. Used to calculate total gas extraction and energy recovery potential.' ;
    rdfs:domain ind:LfgMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:methaneConcentrationPct rdf:type rdf:Property ;
    rdfs:label 'Methane Concentration Pct' ;
    rdfs:comment 'Methane concentration measured as a percentage by volume at the monitoring point. Critical for assessing landfill gas composition and explosion risk.' ;
    rdfs:domain ind:LfgMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:monitoringDate rdf:type rdf:Property ;
    rdfs:label 'Monitoring Date' ;
    rdfs:comment 'Calendar date of the landfill gas monitoring event, used for daily and periodic compliance reporting.' ;
    rdfs:domain ind:LfgMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:monitoringFrequency rdf:type rdf:Property ;
    rdfs:label 'Monitoring Frequency' ;
    rdfs:comment 'Scheduled frequency of monitoring at this point as required by regulatory permits or operational procedures.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringMethod rdf:type rdf:Property ;
    rdfs:label 'Monitoring Method' ;
    rdfs:comment 'Standardized method or protocol used to conduct the landfill gas monitoring, ensuring consistency and regulatory compliance.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringPointType rdf:type rdf:Property ;
    rdfs:label 'Monitoring Point Type' ;
    rdfs:comment 'Classification of the monitoring point indicating its purpose and location within the landfill gas collection and monitoring system.' ;
    rdfs:domain ind:LfgMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringTimestamp rdf:type rdf:Property ;
    rdfs:label 'Monitoring Timestamp' ;
    rdfs:comment 'Date and time when the landfill gas monitoring reading was recorded in the field. This is the actual event time of the measurement, distinct from system audit timestamps.' ;
    rdfs:domain ind:LfgMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:nitrogenConcentrationPct rdf:type rdf:Property ;
    rdfs:label 'Nitrogen Concentration Pct' ;
    rdfs:comment 'Nitrogen concentration measured as a percentage by volume. Elevated nitrogen levels may indicate air intrusion or dilution of landfill gas.' ;
    rdfs:domain ind:LfgMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oxygenConcentrationPct rdf:type rdf:Property ;
    rdfs:label 'Oxygen Concentration Pct' ;
    rdfs:comment 'Oxygen concentration measured as a percentage by volume. Low oxygen levels indicate anaerobic conditions; elevated levels may indicate air intrusion into the landfill gas collection system.' ;
    rdfs:domain ind:LfgMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recordCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Created Timestamp' ;
    rdfs:comment 'Timestamp when this monitoring record was first created in the source system or data platform.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Updated Timestamp' ;
    rdfs:comment 'Timestamp when this monitoring record was last updated in the source system or data platform.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:staticPressureInchesWc rdf:type rdf:Property ;
    rdfs:label 'Static Pressure Inches Wc' ;
    rdfs:comment 'Static pressure measured in inches of water column at the monitoring point. Indicates the vacuum or pressure within the landfill gas collection system.' ;
    rdfs:domain ind:LfgMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:landfillCellId rdf:type rdf:Property ;
    rdfs:label 'Landfill Cell Id' ;
    rdfs:comment 'Reference to the specific landfill cell where this extraction well is located. Supports cell-level gas collection tracking and capacity planning.' ;
    rdfs:domain ind:LfgExtractionWell ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Cell .

ind:abandonmentDate rdf:type rdf:Property ;
    rdfs:label 'Abandonment Date' ;
    rdfs:comment 'Date when the well was permanently closed and abandoned. Wells are abandoned when no longer needed due to cell closure, system reconfiguration, or end of gas generation. Null for active wells.' ;
    rdfs:domain ind:LfgExtractionWell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:abandonmentMethod rdf:type rdf:Property ;
    rdfs:label 'Abandonment Method' ;
    rdfs:comment 'Method used to permanently close the well. Grouted wells are filled with cement grout; capped wells have sealed wellheads; removed wells are fully extracted; other methods per site-specific procedures. Null for active wells.' ;
    rdfs:domain ind:LfgExtractionWell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetTagNumber rdf:type rdf:Property ;
    rdfs:label 'Asset Tag Number' ;
    rdfs:comment 'Fixed asset tag or barcode identifier assigned by the asset management system. Links to Infor EAM for maintenance scheduling, parts inventory, and lifecycle tracking.' ;
    rdfs:domain ind:LfgExtractionWell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:casingMaterial rdf:type rdf:Property ;
    rdfs:label 'Casing Material' ;
    rdfs:comment 'Material composition of the well casing. High-Density Polyethylene (HDPE) is most common for corrosion resistance; PVC, steel, and fiberglass are alternatives based on site conditions and design specifications.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constructionContractor rdf:type rdf:Property ;
    rdfs:label 'Construction Contractor' ;
    rdfs:comment 'Name of the contractor or vendor that installed the extraction well. Used for warranty claims, quality tracking, and vendor performance evaluation.' ;
    rdfs:domain ind:LfgExtractionWell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:constructionCostUsd rdf:type rdf:Property ;
    rdfs:label 'Construction Cost Usd' ;
    rdfs:comment 'Total cost of well installation including materials, labor, and equipment in US dollars. Used for capital expenditure tracking, asset valuation, and ROI analysis.' ;
    rdfs:domain ind:LfgExtractionWell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:designExtractionRateScfm rdf:type rdf:Property ;
    rdfs:label 'Design Extraction Rate Scfm' ;
    rdfs:comment 'Designed gas extraction capacity of the well measured in standard cubic feet per minute (SCFM) at standard temperature and pressure. Used for system capacity planning and performance evaluation.' ;
    rdfs:domain ind:LfgExtractionWell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:designVacuumInchesH2o rdf:type rdf:Property ;
    rdfs:label 'Design Vacuum Inches H2o' ;
    rdfs:comment 'Target vacuum pressure at the wellhead measured in inches of water column. Optimal vacuum range is typically 2-6 inches H2O to maximize gas extraction while minimizing air intrusion.' ;
    rdfs:domain ind:LfgExtractionWell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:elevationFeet rdf:type rdf:Property ;
    rdfs:label 'Elevation Feet' ;
    rdfs:comment 'Ground surface elevation at the well location measured in feet above mean sea level. Used for hydraulic gradient calculations and leachate management.' ;
    rdfs:domain ind:LfgExtractionWell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextScheduledInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Inspection Date' ;
    rdfs:comment 'Planned date for the next regulatory or preventive maintenance inspection. Supports compliance calendar management and field crew scheduling.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rngProductionEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Rng Production Eligible Flag' ;
    rdfs:comment 'Indicates whether gas from this well is routed to the RNG production facility. True if well contributes to RNG production; false if gas is flared or used for waste-to-energy only. Supports RNG revenue allocation and environmental credit tracking.' ;
    rdfs:domain ind:LfgExtractionWell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:screenIntervalBottomFeet rdf:type rdf:Property ;
    rdfs:label 'Screen Interval Bottom Feet' ;
    rdfs:comment 'Depth in feet from ground surface to the bottom of the perforated screen section. Defines the lower boundary of the gas collection zone.' ;
    rdfs:domain ind:Landfill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:screenIntervalTopFeet rdf:type rdf:Property ;
    rdfs:label 'Screen Interval Top Feet' ;
    rdfs:comment 'Depth in feet from ground surface to the top of the perforated screen section. Defines the upper boundary of the gas collection zone.' ;
    rdfs:domain ind:Landfill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wellDepthFeet rdf:type rdf:Property ;
    rdfs:label 'Well Depth Feet' ;
    rdfs:comment 'Total depth of the extraction well measured in feet from ground surface to bottom of well screen. Critical for gas collection efficiency and design capacity calculations.' ;
    rdfs:domain ind:LfgExtractionWell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wellDiameterInches rdf:type rdf:Property ;
    rdfs:label 'Well Diameter Inches' ;
    rdfs:comment 'Internal diameter of the well casing measured in inches. Affects gas flow capacity and extraction efficiency.' ;
    rdfs:domain ind:LfgExtractionWell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wellIdentifier rdf:type rdf:Property ;
    rdfs:label 'Well Identifier' ;
    rdfs:comment 'Business identifier or tag number for the LFG extraction well. Used for field operations, maintenance work orders, and regulatory reporting. May follow site-specific naming conventions (e.g., SITE-CELL-WELL-###).' ;
    rdfs:domain ind:LfgExtractionWell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wellType rdf:type rdf:Property ;
    rdfs:label 'Well Type' ;
    rdfs:comment 'Classification of the extraction well design. Vertical wells are drilled vertically into waste mass; horizontal wells are installed horizontally in trenches; trench wells are perforated pipes in gravel-filled trenches.' ;
    rdfs:domain ind:Landfill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wellheadEquipmentType rdf:type rdf:Property ;
    rdfs:label 'Wellhead Equipment Type' ;
    rdfs:comment 'Classification of wellhead control and monitoring equipment. Standard wellheads have manual valves; adjustable wellheads allow field tuning; automated wellheads have remote control capability; monitoring-only wellheads are for observation wells.' ;
    rdfs:domain ind:LfgExtractionWell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringStationId rdf:type rdf:Property ;
    rdfs:label 'Monitoring Station Id' ;
    rdfs:comment 'Foreign key linking to compliance.monitoring_station. Business justification: Groundwater monitoring wells at landfills are monitoring stations tracked in compliance domain. Linking to canonical monitoring station record enables enterprise-wide environmental monitoring coordina' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MonitoringStation .

ind:analyteListCode rdf:type rdf:Property ;
    rdfs:label 'Analyte List Code' ;
    rdfs:comment 'Code or reference to the list of chemical analytes (parameters) tested during sampling events at this well. Typically Appendix I, Appendix II, or site-specific list per RCRA.' ;
    rdfs:domain ind:GroundwaterMonitoringWell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aquiferZone rdf:type rdf:Property ;
    rdfs:label 'Aquifer Zone' ;
    rdfs:comment 'Name or designation of the aquifer zone or hydrogeologic unit being monitored by this well (e.g., Upper Alluvial, Bedrock, Perched Water Table).' ;
    rdfs:domain ind:Landfill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:casingDiameterInches rdf:type rdf:Property ;
    rdfs:label 'Casing Diameter Inches' ;
    rdfs:comment 'Inside diameter of the well casing in inches. Determines sampling equipment compatibility and well capacity.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:decommissionReason rdf:type rdf:Property ;
    rdfs:label 'Decommission Reason' ;
    rdfs:comment 'Business or regulatory reason for decommissioning the well (e.g., landfill closure, well damage, redundant monitoring point, permit modification).' ;
    rdfs:domain ind:GroundwaterMonitoringWell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:elevationFeetMsl rdf:type rdf:Property ;
    rdfs:label 'Elevation Feet Msl' ;
    rdfs:comment 'Elevation of the well top-of-casing or ground surface reference point in feet above mean sea level. Critical for calculating hydraulic gradients and groundwater flow direction.' ;
    rdfs:domain ind:GroundwaterMonitoringWell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:epaSwisWellCode rdf:type rdf:Property ;
    rdfs:label 'Epa Swis Well Code' ;
    rdfs:comment 'Unique identifier assigned by EPA SWIS for this monitoring well. Used in federal reporting and data exchange with EPA.' ;
    rdfs:domain ind:GroundwaterMonitoringWell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filterPackMaterial rdf:type rdf:Property ;
    rdfs:label 'Filter Pack Material' ;
    rdfs:comment 'Material placed around the well screen to prevent fine sediment from entering the well while allowing groundwater flow. Typically clean silica sand.' ;
    rdfs:domain ind:GroundwaterMonitoringWell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastSamplingDate rdf:type rdf:Property ;
    rdfs:label 'Last Sampling Date' ;
    rdfs:comment 'Date of the most recent groundwater sampling event at this well. Used to track compliance with sampling frequency requirements.' ;
    rdfs:domain ind:GroundwaterMonitoringWell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextScheduledSamplingDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Sampling Date' ;
    rdfs:comment 'Planned date for the next groundwater sampling event. Calculated based on sampling frequency and last sampling date. Used for field scheduling.' ;
    rdfs:domain ind:GroundwaterMonitoringWell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:permitReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Permit Reference Number' ;
    rdfs:comment 'Reference number of the environmental permit or regulatory order that mandates monitoring at this well. Links well to specific compliance obligations.' ;
    rdfs:domain ind:GroundwaterMonitoringWell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplingFrequency rdf:type rdf:Property ;
    rdfs:label 'Sampling Frequency' ;
    rdfs:comment 'Regulatory or operational frequency at which groundwater samples are collected from this well. Quarterly is typical for RCRA detection monitoring.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sealMaterial rdf:type rdf:Property ;
    rdfs:label 'Seal Material' ;
    rdfs:comment 'Material used to seal the annular space between the borehole wall and well casing. Prevents surface water infiltration and cross-contamination between aquifer zones.' ;
    rdfs:domain ind:GroundwaterMonitoringWell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateWellPermitNumber rdf:type rdf:Property ;
    rdfs:label 'State Well Permit Number' ;
    rdfs:comment 'State-issued permit or registration number for the monitoring well. Required in many jurisdictions for all groundwater monitoring wells.' ;
    rdfs:domain ind:GroundwaterMonitoringWell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:staticWaterLevelFeet rdf:type rdf:Property ;
    rdfs:label 'Static Water Level Feet' ;
    rdfs:comment 'Most recent measured depth to groundwater from the top of casing, in feet. Used to calculate groundwater elevation and flow direction. Updated after each sampling event.' ;
    rdfs:domain ind:GroundwaterMonitoringWell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDepthFeet rdf:type rdf:Property ;
    rdfs:label 'Total Depth Feet' ;
    rdfs:comment 'Total depth of the monitoring well from ground surface to bottom, measured in feet. Determines the aquifer zone being monitored.' ;
    rdfs:domain ind:GroundwaterMonitoringWell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wellConstructionMethod rdf:type rdf:Property ;
    rdfs:label 'Well Construction Method' ;
    rdfs:comment 'Drilling and installation method used to construct the monitoring well. Hollow stem auger is most common for shallow environmental wells.' ;
    rdfs:domain ind:GroundwaterMonitoringWell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wellDesignation rdf:type rdf:Property ;
    rdfs:label 'Well Designation' ;
    rdfs:comment 'Business identifier for the monitoring well, typically assigned per site naming convention (e.g., MW-01, GW-UG-03). Used in regulatory reports and field operations.' ;
    rdfs:domain ind:GroundwaterMonitoringWell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wellDevelopmentDate rdf:type rdf:Property ;
    rdfs:label 'Well Development Date' ;
    rdfs:comment 'Date when well development (removal of drilling fluids and fines) was completed and the well was ready for sampling. Typically occurs shortly after installation.' ;
    rdfs:domain ind:GroundwaterMonitoringWell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:wellNotes rdf:type rdf:Property ;
    rdfs:label 'Well Notes' ;
    rdfs:comment 'Free-text field for operational notes, field observations, maintenance history, or special sampling instructions for this well.' ;
    rdfs:domain ind:GroundwaterMonitoringWell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wellStatus rdf:type rdf:Property ;
    rdfs:label 'Well Status' ;
    rdfs:comment 'Current operational status of the monitoring well in its lifecycle. Active wells are sampled per schedule; inactive wells are not currently monitored.' ;
    rdfs:domain ind:GroundwaterMonitoringWell ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groundwaterSampleId rdf:type rdf:Property ;
    rdfs:label 'Groundwater Sample Id' ;
    rdfs:comment 'Unique identifier for the groundwater sampling event record.' ;
    rdfs:domain ind:GroundwaterSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:environmentalMonitoringId rdf:type rdf:Property ;
    rdfs:label 'Environmental Monitoring Id' ;
    rdfs:comment 'Foreign key linking to compliance.compliance_environmental_monitoring. Business justification: Groundwater samples collected at landfills are compliance environmental monitoring events. Linking to compliance domain\'s canonical monitoring record enables regulatory reporting (SWIS, CERCLA), excee' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EnvironmentalMonitoring .

ind:analysisCompleteDate rdf:type rdf:Property ;
    rdfs:label 'Analysis Complete Date' ;
    rdfs:comment 'Date when laboratory analysis of the sample was completed.' ;
    rdfs:domain ind:GroundwaterSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:analysisStartDate rdf:type rdf:Property ;
    rdfs:label 'Analysis Start Date' ;
    rdfs:comment 'Date when laboratory analysis of the sample began.' ;
    rdfs:domain ind:GroundwaterSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:analyticalParametersTested rdf:type rdf:Property ;
    rdfs:label 'Analytical Parameters Tested' ;
    rdfs:comment 'Comma-separated list of analytical parameters and contaminants tested in this sample (e.g., VOCs, metals, indicator parameters).' ;
    rdfs:domain ind:GroundwaterSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cerclaReportableFlag rdf:type rdf:Property ;
    rdfs:label 'Cercla Reportable Flag' ;
    rdfs:comment 'Indicates whether detected concentrations trigger CERCLA (Superfund) reporting obligations.' ;
    rdfs:domain ind:GroundwaterSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:chainOfCustodyNumber rdf:type rdf:Property ;
    rdfs:label 'Chain Of Custody Number' ;
    rdfs:comment 'Unique chain of custody document number tracking sample handling from collection through analysis.' ;
    rdfs:domain ind:GroundwaterSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceedanceDetectedFlag rdf:type rdf:Property ;
    rdfs:label 'Exceedance Detected Flag' ;
    rdfs:comment 'Indicates whether any detected concentrations exceeded applicable Groundwater Protection Standard (GWPS) limits or regulatory thresholds.' ;
    rdfs:domain ind:GroundwaterSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fieldConductivityUmhos rdf:type rdf:Property ;
    rdfs:label 'Field Conductivity Umhos' ;
    rdfs:comment 'Specific conductivity measured in the field at the time of sample collection, in micromhos per centimeter.' ;
    rdfs:domain ind:GroundwaterSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fieldDissolvedOxygenMgL rdf:type rdf:Property ;
    rdfs:label 'Field Dissolved Oxygen Mg L' ;
    rdfs:comment 'Dissolved oxygen concentration measured in the field at the time of sample collection, in milligrams per liter.' ;
    rdfs:domain ind:GroundwaterSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fieldNotes rdf:type rdf:Property ;
    rdfs:label 'Field Notes' ;
    rdfs:comment 'Additional field observations, notes, or comments recorded by the sampling technician during sample collection.' ;
    rdfs:domain ind:GroundwaterSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fieldOxidationReductionPotentialMv rdf:type rdf:Property ;
    rdfs:label 'Field Oxidation Reduction Potential Mv' ;
    rdfs:comment 'Oxidation-reduction potential (ORP) measured in the field at the time of sample collection, in millivolts.' ;
    rdfs:domain ind:GroundwaterSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fieldPh rdf:type rdf:Property ;
    rdfs:label 'Field Ph' ;
    rdfs:comment 'pH measurement taken in the field at the time of sample collection.' ;
    rdfs:domain ind:GroundwaterSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fieldTemperatureCelsius rdf:type rdf:Property ;
    rdfs:label 'Field Temperature Celsius' ;
    rdfs:comment 'Water temperature measured in the field at the time of sample collection, in degrees Celsius.' ;
    rdfs:domain ind:GroundwaterSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fieldTurbidityNtu rdf:type rdf:Property ;
    rdfs:label 'Field Turbidity Ntu' ;
    rdfs:comment 'Turbidity measured in the field at the time of sample collection, in Nephelometric Turbidity Units.' ;
    rdfs:domain ind:GroundwaterSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gwpsLimitExceeded rdf:type rdf:Property ;
    rdfs:label 'Gwps Limit Exceeded' ;
    rdfs:comment 'Description of the specific Groundwater Protection Standard limit that was exceeded, including the parameter name and limit value.' ;
    rdfs:domain ind:GroundwaterSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laboratoryName rdf:type rdf:Property ;
    rdfs:label 'Laboratory Name' ;
    rdfs:comment 'Name of the certified analytical laboratory that performed the sample analysis.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laboratorySampleNumber rdf:type rdf:Property ;
    rdfs:label 'Laboratory Sample Number' ;
    rdfs:comment 'Unique identifier assigned by the analytical laboratory for tracking and reporting purposes.' ;
    rdfs:domain ind:GroundwaterSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:metalsAnalysisMethod rdf:type rdf:Property ;
    rdfs:label 'Metals Analysis Method' ;
    rdfs:comment 'EPA analytical method used for metals analysis (typically ICP or ICP-MS). [ENUM-REF-CANDIDATE: EPA_6010|EPA_6010B|EPA_6010C|EPA_6010D|EPA_6020|EPA_6020A|EPA_6020B|not_tested — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GroundwaterSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringProgramType rdf:type rdf:Property ;
    rdfs:label 'Monitoring Program Type' ;
    rdfs:comment 'Type of groundwater monitoring program under which this sample was collected (detection, assessment, corrective action, or post-closure).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purgeVolumeGallons rdf:type rdf:Property ;
    rdfs:label 'Purge Volume Gallons' ;
    rdfs:comment 'Volume of water purged from the monitoring well prior to sample collection, measured in gallons.' ;
    rdfs:domain ind:GroundwaterSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qaQcFlag rdf:type rdf:Property ;
    rdfs:label 'Qa Qc Flag' ;
    rdfs:comment 'Quality assurance and quality control status of the sample results.' ;
    rdfs:domain ind:GroundwaterSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qaQcNotes rdf:type rdf:Property ;
    rdfs:label 'Qa Qc Notes' ;
    rdfs:comment 'Notes regarding quality assurance or quality control issues, qualifications, or observations related to the sample.' ;
    rdfs:domain ind:GroundwaterSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Date' ;
    rdfs:comment 'Date when regulatory authorities were notified of exceedance or other reportable conditions.' ;
    rdfs:domain ind:Landfill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryNotificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Required Flag' ;
    rdfs:comment 'Indicates whether regulatory notification to EPA, state, or Local Enforcement Agency (LEA) is required based on sample results.' ;
    rdfs:domain ind:GroundwaterSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sampleAppearance rdf:type rdf:Property ;
    rdfs:label 'Sample Appearance' ;
    rdfs:comment 'Visual description of the sample appearance (e.g., clear, cloudy, discolored, odor present).' ;
    rdfs:domain ind:GroundwaterSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleDate rdf:type rdf:Property ;
    rdfs:label 'Sample Date' ;
    rdfs:comment 'Date when the groundwater sample was collected from the monitoring well.' ;
    rdfs:domain ind:GroundwaterSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sampleNumber rdf:type rdf:Property ;
    rdfs:label 'Sample Number' ;
    rdfs:comment 'Unique field sample identification number assigned by the sampling technician or laboratory.' ;
    rdfs:domain ind:GroundwaterSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Sample Received Date' ;
    rdfs:comment 'Date when the sample was received by the analytical laboratory.' ;
    rdfs:domain ind:GroundwaterSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sampleTime rdf:type rdf:Property ;
    rdfs:label 'Sample Time' ;
    rdfs:comment 'Precise timestamp when the groundwater sample was collected, including time zone.' ;
    rdfs:domain ind:GroundwaterSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sampleType rdf:type rdf:Property ;
    rdfs:label 'Sample Type' ;
    rdfs:comment 'Classification of the sample purpose (routine monitoring, confirmation, assessment, background, quality control duplicate, or blank).' ;
    rdfs:domain ind:GroundwaterSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:samplingMethod rdf:type rdf:Property ;
    rdfs:label 'Sampling Method' ;
    rdfs:comment 'Method used to collect the groundwater sample from the monitoring well.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:swisReportingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Swis Reporting Required Flag' ;
    rdfs:comment 'Indicates whether this sample result must be included in EPA Solid Waste Information System (SWIS) reporting.' ;
    rdfs:domain ind:GroundwaterSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vocAnalysisMethod rdf:type rdf:Property ;
    rdfs:label 'Voc Analysis Method' ;
    rdfs:comment 'EPA analytical method used for volatile organic compound analysis.' ;
    rdfs:domain ind:GroundwaterSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityPlanId rdf:type rdf:Property ;
    rdfs:label 'Capacity Plan Id' ;
    rdfs:comment 'Unique identifier for the capacity plan version record. Primary key.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:annualWasteAcceptanceRateTons rdf:type rdf:Property ;
    rdfs:label 'Annual Waste Acceptance Rate Tons' ;
    rdfs:comment 'Assumed annual waste acceptance volume in tons used for capacity planning. Calculated from daily rate assumptions.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annualWasteAcceptanceRateTpd rdf:type rdf:Property ;
    rdfs:label 'Annual Waste Acceptance Rate Tpd' ;
    rdfs:comment 'Assumed average daily waste acceptance rate in Tons Per Day (TPD) used for capacity planning projections. Based on historical trends and market forecasts.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assumptionsNotes rdf:type rdf:Property ;
    rdfs:label 'Assumptions Notes' ;
    rdfs:comment 'Detailed narrative describing key assumptions, methodologies, constraints, and special considerations used in developing this capacity plan.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityConsumedToDateCy rdf:type rdf:Property ;
    rdfs:label 'Capacity Consumed To Date Cy' ;
    rdfs:comment 'Cumulative airspace consumed as of the plan effective date, measured in cubic yards. Based on topographic surveys and waste placement records.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityConsumedToDateTons rdf:type rdf:Property ;
    rdfs:label 'Capacity Consumed To Date Tons' ;
    rdfs:comment 'Cumulative waste tonnage received as of the plan effective date. Based on scale house records and historical acceptance data.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capitalInvestmentRequired rdf:type rdf:Property ;
    rdfs:label 'Capital Investment Required' ;
    rdfs:comment 'Estimated total capital investment required to execute this capacity plan, including expansion construction, infrastructure, and equipment. Measured in US dollars.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compactionRatioAssumption rdf:type rdf:Property ;
    rdfs:label 'Compaction Ratio Assumption' ;
    rdfs:comment 'Assumed waste compaction ratio (volume reduction factor) used in capacity calculations. Represents the ratio of in-place compacted waste density to loose waste density.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dailyCoverFactorPercent rdf:type rdf:Property ;
    rdfs:label 'Daily Cover Factor Percent' ;
    rdfs:comment 'Percentage of airspace consumed by daily cover material application. Used to adjust net waste capacity calculations.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:engineerLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Engineer License Number' ;
    rdfs:comment 'Professional engineering license number of the responsible engineer who certified this capacity plan.' ;
    rdfs:domain ind:Landfill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expansionPermitStatus rdf:type rdf:Property ;
    rdfs:label 'Expansion Permit Status' ;
    rdfs:comment 'Current status of permit applications for planned capacity expansions (vertical or lateral). Not applicable if no expansion is planned.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expansionTargetCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Expansion Target Completion Date' ;
    rdfs:comment 'Target date for completion of planned expansion construction and availability of additional capacity. Null if no expansion is planned.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:finalCoverFactorPercent rdf:type rdf:Property ;
    rdfs:label 'Final Cover Factor Percent' ;
    rdfs:comment 'Percentage of airspace consumed by final cap system installation. Includes liner, drainage, and vegetation layers.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:intermediateCoverFactorPercent rdf:type rdf:Property ;
    rdfs:label 'Intermediate Cover Factor Percent' ;
    rdfs:comment 'Percentage of airspace consumed by intermediate cover systems. Applied to areas inactive for extended periods.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lateralExpansionCapacityCy rdf:type rdf:Property ;
    rdfs:label 'Lateral Expansion Capacity Cy' ;
    rdfs:comment 'Additional airspace capacity (cubic yards) to be gained through lateral expansion, if planned. Null if no lateral expansion is planned.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lateralExpansionPlanned rdf:type rdf:Property ;
    rdfs:label 'Lateral Expansion Planned' ;
    rdfs:comment 'Indicates whether lateral expansion (footprint increase) is included in this capacity plan. True if lateral expansion is planned and permitted.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:permitRenewalRequired rdf:type rdf:Property ;
    rdfs:label 'Permit Renewal Required' ;
    rdfs:comment 'Indicates whether permit renewal or modification is required to execute this capacity plan. True if regulatory action is needed.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:permitRenewalTargetDate rdf:type rdf:Property ;
    rdfs:label 'Permit Renewal Target Date' ;
    rdfs:comment 'Target date for obtaining required permit renewals or modifications to support this capacity plan. Null if no permit action is required.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Plan Approval Date' ;
    rdfs:comment 'Date when this capacity plan version was formally approved by management or regulatory authorities.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planStatus rdf:type rdf:Property ;
    rdfs:label 'Plan Status' ;
    rdfs:comment 'Current lifecycle status of the capacity plan. Tracks approval workflow and active status.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planType rdf:type rdf:Property ;
    rdfs:label 'Plan Type' ;
    rdfs:comment 'Classification of the capacity plan by planning horizon and purpose (e.g., annual operational plan, long-range strategic plan, permit renewal plan).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planVersion rdf:type rdf:Property ;
    rdfs:label 'Plan Version' ;
    rdfs:comment 'Version identifier for this capacity plan iteration (e.g., 2024.1, 2024.2). Supports tracking of plan revisions over time.' ;
    rdfs:domain ind:Landfill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningHorizonYears rdf:type rdf:Property ;
    rdfs:label 'Planning Horizon Years' ;
    rdfs:comment 'Number of years covered by this capacity plan (e.g., 1, 5, 10, 20).' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:projectedClosureYear rdf:type rdf:Property ;
    rdfs:label 'Projected Closure Year' ;
    rdfs:comment 'Calendar year in which the landfill is projected to reach capacity and begin final closure activities.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:projectedSiteLifeYears rdf:type rdf:Property ;
    rdfs:label 'Projected Site Life Years' ;
    rdfs:comment 'Estimated number of years until the landfill reaches permitted capacity and requires closure, based on current waste acceptance rates and compaction assumptions.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remainingCapacityTons rdf:type rdf:Property ;
    rdfs:label 'Remaining Capacity Tons' ;
    rdfs:comment 'Available waste capacity remaining, measured in tons. Calculated using remaining airspace and assumed compaction ratios.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPermittedCapacityCy rdf:type rdf:Property ;
    rdfs:label 'Total Permitted Capacity Cy' ;
    rdfs:comment 'Total airspace capacity permitted for the landfill site, measured in cubic yards. Represents the maximum volume authorized by regulatory permits.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPermittedCapacityTons rdf:type rdf:Property ;
    rdfs:label 'Total Permitted Capacity Tons' ;
    rdfs:comment 'Total waste capacity permitted for the landfill site, measured in tons. Derived from cubic yards using assumed compaction ratios.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:verticalExpansionCapacityCy rdf:type rdf:Property ;
    rdfs:label 'Vertical Expansion Capacity Cy' ;
    rdfs:comment 'Additional airspace capacity (cubic yards) to be gained through vertical expansion, if planned. Null if no vertical expansion is planned.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:verticalExpansionPlanned rdf:type rdf:Property ;
    rdfs:label 'Vertical Expansion Planned' ;
    rdfs:comment 'Indicates whether vertical expansion (height increase) is included in this capacity plan. True if vertical expansion is planned and permitted.' ;
    rdfs:domain ind:CapacityPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:applicableOfferingId rdf:type rdf:Property ;
    rdfs:label 'Applicable Offering Id' ;
    rdfs:comment 'Foreign key linking to service.offering. Business justification: Tipping fee schedules are often structured by service offering type to enable service-specific pricing, competitive analysis, and margin management. Linking schedules to offerings ensures fee structur' ;
    rdfs:domain ind:LandfillTippingFeeSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Offering .

ind:baseRate rdf:type rdf:Property ;
    rdfs:label 'Base Rate' ;
    rdfs:comment 'Standard tipping fee rate per unit of measure before any surcharges or adjustments. Core pricing component for revenue calculation.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractReference rdf:type rdf:Property ;
    rdfs:label 'Contract Reference' ;
    rdfs:comment 'Reference number or identifier of the customer contract or municipal agreement that governs this fee schedule. Links pricing to contractual terms.' ;
    rdfs:domain ind:LandfillTippingFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountPercentage rdf:type rdf:Property ;
    rdfs:label 'Discount Percentage' ;
    rdfs:comment 'Percentage discount applied to the base rate for volume commitments, long-term contracts, or promotional pricing. Expressed as a percentage (e.g., 5.00 for 5%).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalSurchargeRate rdf:type rdf:Property ;
    rdfs:label 'Environmental Surcharge Rate' ;
    rdfs:comment 'Per-unit fee to cover environmental compliance costs including monitoring, remediation, and regulatory reporting. Supports EPA and state environmental program funding.' ;
    rdfs:domain ind:LandfillTippingFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelSurchargeRate rdf:type rdf:Property ;
    rdfs:label 'Fuel Surcharge Rate' ;
    rdfs:comment 'Additional per-unit charge to offset fuel cost fluctuations. Applied on top of base rate and adjusted periodically based on fuel price indices.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hostCommunityFeeRate rdf:type rdf:Property ;
    rdfs:label 'Host Community Fee Rate' ;
    rdfs:comment 'Per-unit fee paid to the host municipality or community as part of host community agreements. Compensates local jurisdictions for hosting landfill operations.' ;
    rdfs:domain ind:LandfillTippingFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumCharge rdf:type rdf:Property ;
    rdfs:label 'Maximum Charge' ;
    rdfs:comment 'Maximum fee cap per transaction for high-volume loads. Used in negotiated contracts or promotional pricing structures.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumCharge rdf:type rdf:Property ;
    rdfs:label 'Minimum Charge' ;
    rdfs:comment 'Minimum fee amount charged per transaction regardless of tonnage or volume. Ensures cost recovery for small loads and administrative processing.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modifiedBy rdf:type rdf:Property ;
    rdfs:label 'Modified By' ;
    rdfs:comment 'User identifier or name of the person who last modified this fee schedule record. Supports change tracking and accountability.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorySurchargeRate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Surcharge Rate' ;
    rdfs:comment 'Per-unit fee to cover regulatory compliance costs including permit fees, inspections, and mandated reporting. Varies by jurisdiction and waste type.' ;
    rdfs:domain ind:LandfillTippingFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduleName rdf:type rdf:Property ;
    rdfs:label 'Schedule Name' ;
    rdfs:comment 'Descriptive name for the tipping fee schedule to identify the rate structure (e.g., Standard MSW Rates 2024, Commercial C&D Rates).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleVersion rdf:type rdf:Property ;
    rdfs:label 'Schedule Version' ;
    rdfs:comment 'Version identifier for the fee schedule to track revisions and updates over time. Supports historical fee analysis and audit trails.' ;
    rdfs:domain ind:LandfillTippingFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialHandlingRequired rdf:type rdf:Property ;
    rdfs:label 'Special Handling Required' ;
    rdfs:comment 'Indicates whether waste under this fee schedule requires special handling procedures, equipment, or disposal methods. True if special handling is required, False otherwise.' ;
    rdfs:domain ind:LandfillTippingFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxExemptFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Exempt Flag' ;
    rdfs:comment 'Indicates whether this fee schedule applies to tax-exempt customers (e.g., government entities, non-profits). True if tax-exempt, False otherwise.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:volumeThresholdTons rdf:type rdf:Property ;
    rdfs:label 'Volume Threshold Tons' ;
    rdfs:comment 'Minimum tonnage threshold required to qualify for this fee schedule or pricing tier. Supports volume-based pricing incentives.' ;
    rdfs:domain ind:LandfillTippingFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:createdBy rdf:type rdf:Property ;
    rdfs:label 'Created By' ;
    rdfs:comment 'User identifier or name of the person who created this fee schedule record. Supports accountability and audit trail.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalCoordinatorName rdf:type rdf:Property ;
    rdfs:label 'Environmental Coordinator Name' ;
    rdfs:comment 'Name of the internal environmental coordinator responsible for managing this permit.' ;
    rdfs:domain ind:DisposalPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialAssuranceAmount rdf:type rdf:Property ;
    rdfs:label 'Financial Assurance Amount' ;
    rdfs:comment 'Total amount of financial assurance required for closure and post-closure care under this permit, in USD.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financialAssuranceMechanism rdf:type rdf:Property ;
    rdfs:label 'Financial Assurance Mechanism' ;
    rdfs:comment 'Type of financial assurance mechanism used to meet permit requirements (trust fund, surety bond, letter of credit, insurance, corporate guarantee, state fund).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialAssuranceRequired rdf:type rdf:Property ;
    rdfs:label 'Financial Assurance Required' ;
    rdfs:comment 'Indicates whether financial assurance (closure and post-closure care funding) is required under this permit.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuingAgency rdf:type rdf:Property ;
    rdfs:label 'Issuing Agency' ;
    rdfs:comment 'Name of the regulatory agency that issued the permit (e.g., EPA, state environmental agency, Local Enforcement Agency).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingAgencyCode rdf:type rdf:Property ;
    rdfs:label 'Issuing Agency Code' ;
    rdfs:comment 'Standardized code for the issuing regulatory agency.' ;
    rdfs:domain ind:DisposalPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastRenewalDate rdf:type rdf:Property ;
    rdfs:label 'Last Renewal Date' ;
    rdfs:comment 'Date when the permit was most recently renewed.' ;
    rdfs:domain ind:DisposalPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastReportSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Last Report Submission Date' ;
    rdfs:comment 'Date when the most recent compliance report was submitted to the regulatory authority.' ;
    rdfs:domain ind:DisposalPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextReportDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Report Due Date' ;
    rdfs:comment 'Deadline for the next compliance report submission required under this permit.' ;
    rdfs:domain ind:DisposalPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:permitConditionsSummary rdf:type rdf:Property ;
    rdfs:label 'Permit Conditions Summary' ;
    rdfs:comment 'High-level summary of key conditions, restrictions, and operational requirements imposed by the permit.' ;
    rdfs:domain ind:DisposalPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Permit Document Reference' ;
    rdfs:comment 'File path, URL, or document management system reference to the official permit document.' ;
    rdfs:domain ind:DisposalPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permittedDailyTonnageLimit rdf:type rdf:Property ;
    rdfs:label 'Permitted Daily Tonnage Limit' ;
    rdfs:comment 'Maximum tonnage of waste authorized for receipt per day under this permit, measured in tons per day (TPD).' ;
    rdfs:domain ind:DisposalPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:permittedTotalCapacityCubicYards rdf:type rdf:Property ;
    rdfs:label 'Permitted Total Capacity Cubic Yards' ;
    rdfs:comment 'Total lifetime capacity authorized under this permit, measured in cubic yards.' ;
    rdfs:domain ind:DisposalPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:permittedTotalCapacityTons rdf:type rdf:Property ;
    rdfs:label 'Permitted Total Capacity Tons' ;
    rdfs:comment 'Total lifetime capacity authorized under this permit, measured in tons.' ;
    rdfs:domain ind:DisposalPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewalApplicationDueDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Application Due Date' ;
    rdfs:comment 'Deadline by which the permit renewal application must be submitted to the regulatory authority to avoid lapse.' ;
    rdfs:domain ind:DisposalPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responsiblePartyContact rdf:type rdf:Property ;
    rdfs:label 'Responsible Party Contact' ;
    rdfs:comment 'Contact information (phone or email) for the responsible party.' ;
    rdfs:domain ind:DisposalPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsiblePartyName rdf:type rdf:Property ;
    rdfs:label 'Responsible Party Name' ;
    rdfs:comment 'Name of the individual or organization legally responsible for compliance with this permit.' ;
    rdfs:domain ind:DisposalPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialConditions rdf:type rdf:Property ;
    rdfs:label 'Special Conditions' ;
    rdfs:comment 'Detailed description of any special or site-specific conditions attached to the permit (e.g., enhanced monitoring, restricted hours, buffer zone requirements).' ;
    rdfs:domain ind:DisposalPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryInspectionId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Inspection Id' ;
    rdfs:comment 'Unique identifier for the regulatory inspection record. Primary key.' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:agencyJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Agency Jurisdiction' ;
    rdfs:comment 'Level of government jurisdiction of the inspecting agency (federal, state, local, or tribal authority).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:areasInspected rdf:type rdf:Property ;
    rdfs:label 'Areas Inspected' ;
    rdfs:comment 'Comma-separated list or detailed description of specific physical areas and operational zones inspected (e.g., active face, leachate treatment plant, gas collection wells, perimeter monitoring stations, equipment yard).' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cerclaRelevance rdf:type rdf:Property ;
    rdfs:label 'Cercla Relevance' ;
    rdfs:comment 'Boolean flag indicating whether this inspection has relevance to CERCLA (Superfund) obligations or potential liability (True) or not (False).' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:correctiveActionCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Completion Date' ;
    rdfs:comment 'Actual date on which all required corrective actions were completed and documented by the facility.' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionDueDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Due Date' ;
    rdfs:comment 'Deadline date by which the facility must complete and document all required corrective actions to achieve compliance.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionRequired rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Required' ;
    rdfs:comment 'Detailed description of corrective actions, remediation measures, or operational changes required by the regulatory agency to address identified violations or deficiencies.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionStatus rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Status' ;
    rdfs:comment 'Current status of corrective action implementation (not started, in progress, completed, verified by agency, or overdue).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enforcementActionTaken rdf:type rdf:Property ;
    rdfs:label 'Enforcement Action Taken' ;
    rdfs:comment 'Type of formal enforcement action taken by the regulatory agency as a result of the inspection findings (none, warning letter, notice of violation, consent order, or monetary penalty).' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityResponseDate rdf:type rdf:Property ;
    rdfs:label 'Facility Response Date' ;
    rdfs:comment 'Date on which the facility submitted its formal response or corrective action plan to the regulatory agency.' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:facilityResponseReference rdf:type rdf:Property ;
    rdfs:label 'Facility Response Reference' ;
    rdfs:comment 'Document reference number or file path to the facility\'s formal response, corrective action plan, or appeal submitted to the regulatory agency.' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingsSummary rdf:type rdf:Property ;
    rdfs:label 'Findings Summary' ;
    rdfs:comment 'High-level summary of the inspection findings, including observations, deficiencies identified, and areas of compliance.' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Inspection Date' ;
    rdfs:comment 'Scheduled or actual date of the follow-up inspection conducted to verify corrective action implementation and compliance restoration.' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:followUpInspectionRequired rdf:type rdf:Property ;
    rdfs:label 'Follow Up Inspection Required' ;
    rdfs:comment 'Boolean flag indicating whether the regulatory agency has mandated a follow-up inspection to verify corrective action completion (True) or not (False).' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectingAgency rdf:type rdf:Property ;
    rdfs:label 'Inspecting Agency' ;
    rdfs:comment 'Name of the regulatory agency that conducted the inspection (e.g., EPA, state environmental quality department, Local Enforcement Agency).' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionClosureDate rdf:type rdf:Property ;
    rdfs:label 'Inspection Closure Date' ;
    rdfs:comment 'Date on which the inspection case was officially closed by the regulatory agency, indicating all corrective actions have been verified and compliance has been restored.' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inspectionDate rdf:type rdf:Property ;
    rdfs:label 'Inspection Date' ;
    rdfs:comment 'Date on which the regulatory inspection was conducted at the landfill site.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inspectionDurationHours rdf:type rdf:Property ;
    rdfs:label 'Inspection Duration Hours' ;
    rdfs:comment 'Total duration of the inspection in hours, from arrival to departure of the inspection team.' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inspectionNumber rdf:type rdf:Property ;
    rdfs:label 'Inspection Number' ;
    rdfs:comment 'Unique business identifier assigned to the inspection by the regulatory agency or internal tracking system.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionReportReference rdf:type rdf:Property ;
    rdfs:label 'Inspection Report Reference' ;
    rdfs:comment 'Document reference number, file path, or URL to the official inspection report issued by the regulatory agency.' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionScope rdf:type rdf:Property ;
    rdfs:label 'Inspection Scope' ;
    rdfs:comment 'Description of the areas, systems, and operations included in the inspection scope (e.g., active face, leachate collection system, LFG system, groundwater monitoring wells, daily cover operations, liner integrity).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Inspection Status' ;
    rdfs:comment 'Current lifecycle status of the inspection record (scheduled, in-progress, completed, closed, or pending response from facility).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Penalty Amount' ;
    rdfs:comment 'Monetary penalty amount assessed by the regulatory agency for violations identified during the inspection, in US dollars.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rcraComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Rcra Compliance Status' ;
    rdfs:comment 'Overall RCRA Subtitle D compliance status determination resulting from the inspection (compliant, non-compliant, or conditional compliance with corrective action plan).' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryCitations rdf:type rdf:Property ;
    rdfs:label 'Regulatory Citations' ;
    rdfs:comment 'Specific regulatory code sections, permit conditions, or rule citations that were violated or referenced in the inspection findings (e.g., 40 CFR 258.28, state permit condition 4.2.1).' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleManager rdf:type rdf:Property ;
    rdfs:label 'Responsible Manager' ;
    rdfs:comment 'Name of the facility manager or compliance officer responsible for coordinating the inspection response and corrective action implementation.' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:swisReportingRequired rdf:type rdf:Property ;
    rdfs:label 'Swis Reporting Required' ;
    rdfs:comment 'Boolean flag indicating whether this inspection must be reported to the EPA Solid Waste Information System (SWIS) (True) or not (False).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:swisSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Swis Submission Date' ;
    rdfs:comment 'Date on which the inspection data was submitted to the EPA Solid Waste Information System for regulatory reporting.' ;
    rdfs:domain ind:RegulatoryInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:violationCount rdf:type rdf:Property ;
    rdfs:label 'Violation Count' ;
    rdfs:comment 'Total number of distinct violations or deficiencies cited in the inspection report.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:violationsCited rdf:type rdf:Property ;
    rdfs:label 'Violations Cited' ;
    rdfs:comment 'Detailed description of any regulatory violations cited during the inspection, including specific non-compliance issues identified.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closurePlanId rdf:type rdf:Property ;
    rdfs:label 'Closure Plan Id' ;
    rdfs:comment 'Unique identifier for the landfill closure and post-closure care plan record. Primary key.' ;
    rdfs:domain ind:ClosurePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualClosureCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Closure Completion Date' ;
    rdfs:comment 'Actual date on which all closure construction activities were completed and the final cap system was installed.' ;
    rdfs:domain ind:ClosurePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualClosureStartDate rdf:type rdf:Property ;
    rdfs:label 'Actual Closure Start Date' ;
    rdfs:comment 'Actual date on which closure activities commenced.' ;
    rdfs:domain ind:ClosurePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvalAuthority rdf:type rdf:Property ;
    rdfs:label 'Approval Authority' ;
    rdfs:comment 'Name of the regulatory agency or Local Enforcement Agency (LEA) that approved the closure plan.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capBarrierMaterial rdf:type rdf:Property ;
    rdfs:label 'Cap Barrier Material' ;
    rdfs:comment 'Type of impermeable barrier material used in the cap system (e.g., geomembrane, clay, composite liner).' ;
    rdfs:domain ind:ClosurePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capDrainageSystem rdf:type rdf:Property ;
    rdfs:label 'Cap Drainage System' ;
    rdfs:comment 'Description of the drainage layer and system designed to manage stormwater runoff and prevent infiltration into the waste mass.' ;
    rdfs:domain ind:ClosurePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capInspectionFrequency rdf:type rdf:Property ;
    rdfs:label 'Cap Inspection Frequency' ;
    rdfs:comment 'Frequency of visual inspections of the final cap system during the post-closure care period (e.g., quarterly, semi-annually).' ;
    rdfs:domain ind:ClosurePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capLayerCount rdf:type rdf:Property ;
    rdfs:label 'Cap Layer Count' ;
    rdfs:comment 'Number of distinct layers in the final cap system (e.g., barrier layer, drainage layer, soil layer, vegetation layer).' ;
    rdfs:domain ind:ClosurePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capSystemDesign rdf:type rdf:Property ;
    rdfs:label 'Cap System Design' ;
    rdfs:comment 'Detailed description of the final cover system design, including layer composition, materials, and engineering specifications.' ;
    rdfs:domain ind:ClosurePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capTotalThicknessInches rdf:type rdf:Property ;
    rdfs:label 'Cap Total Thickness Inches' ;
    rdfs:comment 'Total thickness of the final cap system measured in inches, from the waste surface to the top of the vegetation layer.' ;
    rdfs:domain ind:ClosurePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capVegetationType rdf:type rdf:Property ;
    rdfs:label 'Cap Vegetation Type' ;
    rdfs:comment 'Type of vegetation to be established on the final cap surface (e.g., native grasses, low-maintenance groundcover).' ;
    rdfs:domain ind:ClosurePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costEstimateBasis rdf:type rdf:Property ;
    rdfs:label 'Cost Estimate Basis' ;
    rdfs:comment 'Methodology or standard used to prepare the cost estimate (e.g., third-party engineer estimate, regulatory cost formula).' ;
    rdfs:domain ind:ClosurePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costEstimateDate rdf:type rdf:Property ;
    rdfs:label 'Cost Estimate Date' ;
    rdfs:comment 'Date on which the closure and post-closure cost estimates were prepared or last updated.' ;
    rdfs:domain ind:ClosurePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:estimatedClosureCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Closure Cost' ;
    rdfs:comment 'Estimated total cost for completing all closure activities, including final cap installation, grading, and site preparation.' ;
    rdfs:domain ind:ClosurePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedPostClosureCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Post Closure Cost' ;
    rdfs:comment 'Estimated total cost for the 30-year post-closure care period, including monitoring, maintenance, and reporting activities.' ;
    rdfs:domain ind:ClosurePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financialAssuranceExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Financial Assurance Expiration Date' ;
    rdfs:comment 'Expiration or renewal date of the financial assurance instrument, if applicable.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:financialAssuranceProvider rdf:type rdf:Property ;
    rdfs:label 'Financial Assurance Provider' ;
    rdfs:comment 'Name of the institution or entity providing the financial assurance instrument (e.g., bank, insurance company, surety).' ;
    rdfs:domain ind:ClosurePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groundwaterSamplingFrequency rdf:type rdf:Property ;
    rdfs:label 'Groundwater Sampling Frequency' ;
    rdfs:comment 'Frequency of groundwater monitoring well sampling during the post-closure care period (e.g., quarterly, semi-annually).' ;
    rdfs:domain ind:ClosurePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leachateMonitoringFrequency rdf:type rdf:Property ;
    rdfs:label 'Leachate Monitoring Frequency' ;
    rdfs:comment 'Frequency of leachate collection system inspections and monitoring during the post-closure care period.' ;
    rdfs:domain ind:ClosurePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lfgMonitoringFrequency rdf:type rdf:Property ;
    rdfs:label 'Lfg Monitoring Frequency' ;
    rdfs:comment 'Frequency of landfill gas monitoring activities during the post-closure care period, including Lower Explosive Limit (LEL) readings.' ;
    rdfs:domain ind:ClosurePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringSchedule rdf:type rdf:Property ;
    rdfs:label 'Monitoring Schedule' ;
    rdfs:comment 'Detailed schedule of post-closure monitoring activities, including frequency and timing of inspections, sampling, and reporting.' ;
    rdfs:domain ind:ClosurePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Plan Document Reference' ;
    rdfs:comment 'File path, document management system reference, or URL to the full closure plan document.' ;
    rdfs:domain ind:ClosurePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedClosureCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Planned Closure Completion Date' ;
    rdfs:comment 'Scheduled date for completion of all closure construction activities, including final cap installation.' ;
    rdfs:domain ind:ClosurePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedClosureStartDate rdf:type rdf:Property ;
    rdfs:label 'Planned Closure Start Date' ;
    rdfs:comment 'Scheduled date for commencement of closure activities for the landfill site or cell.' ;
    rdfs:domain ind:ClosurePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:postClosureCarePeriodYears rdf:type rdf:Property ;
    rdfs:label 'Post Closure Care Period Years' ;
    rdfs:comment 'Duration of the post-closure care period in years, typically 30 years as required under RCRA Subtitle D.' ;
    rdfs:domain ind:ClosurePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:postClosureCareStartDate rdf:type rdf:Property ;
    rdfs:label 'Post Closure Care Start Date' ;
    rdfs:comment 'Date on which the 30-year post-closure care period begins, typically following completion of closure construction.' ;
    rdfs:domain ind:ClosurePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Status' ;
    rdfs:comment 'Status of regulatory agency approval for this closure plan.' ;
    rdfs:domain ind:ClosurePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleParty rdf:type rdf:Property ;
    rdfs:label 'Responsible Party' ;
    rdfs:comment 'Name of the legal entity or organization responsible for implementing and funding the closure and post-closure care plan.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionHistory rdf:type rdf:Property ;
    rdfs:label 'Revision History' ;
    rdfs:comment 'Summary of major revisions and amendments to the closure plan, including dates and reasons for changes.' ;
    rdfs:domain ind:ClosurePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementSurveyFrequency rdf:type rdf:Property ;
    rdfs:label 'Settlement Survey Frequency' ;
    rdfs:comment 'Frequency of topographic surveys to monitor settlement and subsidence of the final cap during post-closure care.' ;
    rdfs:domain ind:ClosurePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vegetationAssessmentFrequency rdf:type rdf:Property ;
    rdfs:label 'Vegetation Assessment Frequency' ;
    rdfs:comment 'Frequency of vegetation health and erosion control assessments on the final cap during post-closure care.' ;
    rdfs:domain ind:ClosurePlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stormwaterEventId rdf:type rdf:Property ;
    rdfs:label 'Stormwater Event Id' ;
    rdfs:comment 'Unique identifier for the stormwater management event record.' ;
    rdfs:domain ind:StormwaterEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bmpDeficiencies rdf:type rdf:Property ;
    rdfs:label 'Bmp Deficiencies' ;
    rdfs:comment 'Detailed description of any deficiencies or maintenance needs identified during BMP inspection, such as erosion, sediment accumulation, damaged controls, or inadequate coverage.' ;
    rdfs:domain ind:StormwaterEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bmpInspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Bmp Inspection Status' ;
    rdfs:comment 'Assessment result of the BMP inspection. Satisfactory indicates controls are functioning as designed, needs maintenance indicates minor repairs required, deficient indicates significant issues requiring prompt attention, and failed indicates BMP is not functioning and requires immediate corrective action.' ;
    rdfs:domain ind:StormwaterEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:copperMgL rdf:type rdf:Property ;
    rdfs:label 'Copper Mg L' ;
    rdfs:comment 'Concentration of copper in the stormwater discharge, measured in milligrams per liter. Copper is a regulated heavy metal that can be toxic to aquatic life.' ;
    rdfs:domain ind:StormwaterEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:correctiveActionDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Date' ;
    rdfs:comment 'Date when corrective actions were completed to address permit exceedances or BMP deficiencies.' ;
    rdfs:domain ind:StormwaterEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionTaken rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Taken' ;
    rdfs:comment 'Description of corrective actions implemented in response to permit exceedances or identified deficiencies in stormwater management practices.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dischargeFlowRateGpm rdf:type rdf:Property ;
    rdfs:label 'Discharge Flow Rate Gpm' ;
    rdfs:comment 'Rate of stormwater discharge measured in gallons per minute at the time of monitoring.' ;
    rdfs:domain ind:StormwaterEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dischargeVolumeGallons rdf:type rdf:Property ;
    rdfs:label 'Discharge Volume Gallons' ;
    rdfs:comment 'Total volume of stormwater discharged from the outfall during the event, measured in gallons.' ;
    rdfs:domain ind:StormwaterEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eventDate rdf:type rdf:Property ;
    rdfs:label 'Event Date' ;
    rdfs:comment 'Date when the stormwater event occurred or was observed.' ;
    rdfs:domain ind:StormwaterEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eventStatus rdf:type rdf:Property ;
    rdfs:label 'Event Status' ;
    rdfs:comment 'Current lifecycle status of the stormwater event record in the compliance workflow.' ;
    rdfs:domain ind:StormwaterEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventType rdf:type rdf:Property ;
    rdfs:label 'Event Type' ;
    rdfs:comment 'Classification of the stormwater management event. Discharge monitoring tracks outfall water quality, BMP (Best Management Practice) inspection verifies erosion and sediment controls, spill response addresses contamination incidents, routine inspection covers scheduled site walkthroughs, corrective action implements remediation measures, and emergency response handles urgent environmental threats.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectorCertification rdf:type rdf:Property ;
    rdfs:label 'Inspector Certification' ;
    rdfs:comment 'Professional certification or qualification held by the inspector, such as Certified Professional in Erosion and Sediment Control (CPESC) or Qualified Stormwater Manager (QSM).' ;
    rdfs:domain ind:StormwaterEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectorName rdf:type rdf:Property ;
    rdfs:label 'Inspector Name' ;
    rdfs:comment 'Name of the qualified individual who performed the stormwater inspection or monitoring, as required by NPDES permit.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadMgL rdf:type rdf:Property ;
    rdfs:label 'Lead Mg L' ;
    rdfs:comment 'Concentration of lead in the stormwater discharge, measured in milligrams per liter. Lead is a toxic heavy metal regulated under NPDES permits.' ;
    rdfs:domain ind:StormwaterEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oilGreaseMgL rdf:type rdf:Property ;
    rdfs:label 'Oil Grease Mg L' ;
    rdfs:comment 'Concentration of oil and grease in the stormwater discharge, measured in milligrams per liter. Indicates petroleum-based contamination from vehicles and equipment.' ;
    rdfs:domain ind:StormwaterEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:permitLimitPhMax rdf:type rdf:Property ;
    rdfs:label 'Permit Limit Ph Max' ;
    rdfs:comment 'Maximum allowable pH level specified in the NPDES permit for this outfall.' ;
    rdfs:domain ind:StormwaterEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:permitLimitPhMin rdf:type rdf:Property ;
    rdfs:label 'Permit Limit Ph Min' ;
    rdfs:comment 'Minimum allowable pH level specified in the NPDES permit for this outfall.' ;
    rdfs:domain ind:StormwaterEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:permitLimitTssMgL rdf:type rdf:Property ;
    rdfs:label 'Permit Limit Tss Mg L' ;
    rdfs:comment 'Maximum allowable concentration of total suspended solids specified in the NPDES permit for this outfall.' ;
    rdfs:domain ind:StormwaterEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:precipitationAmountInches rdf:type rdf:Property ;
    rdfs:label 'Precipitation Amount Inches' ;
    rdfs:comment 'Total rainfall measured in inches during the monitoring period or prior to the discharge event, used to assess stormwater runoff volume and pollutant loading.' ;
    rdfs:domain ind:StormwaterEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalNitrogenMgL rdf:type rdf:Property ;
    rdfs:label 'Total Nitrogen Mg L' ;
    rdfs:comment 'Total nitrogen concentration in the stormwater discharge, measured in milligrams per liter. Nitrogen is a nutrient pollutant that can cause eutrophication in receiving waters.' ;
    rdfs:domain ind:StormwaterEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPhosphorusMgL rdf:type rdf:Property ;
    rdfs:label 'Total Phosphorus Mg L' ;
    rdfs:comment 'Total phosphorus concentration in the stormwater discharge, measured in milligrams per liter. Phosphorus is a nutrient pollutant that contributes to algal blooms and water quality degradation.' ;
    rdfs:domain ind:StormwaterEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tssMgL rdf:type rdf:Property ;
    rdfs:label 'Tss Mg L' ;
    rdfs:comment 'Concentration of total suspended solids in the stormwater discharge, measured in milligrams per liter. TSS is a key indicator of sediment and particulate pollution.' ;
    rdfs:domain ind:StormwaterEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:zincMgL rdf:type rdf:Property ;
    rdfs:label 'Zinc Mg L' ;
    rdfs:comment 'Concentration of zinc in the stormwater discharge, measured in milligrams per liter. Zinc is a regulated heavy metal commonly found in stormwater runoff.' ;
    rdfs:domain ind:StormwaterEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originatingOfferingId rdf:type rdf:Property ;
    rdfs:label 'Originating Offering Id' ;
    rdfs:comment 'Foreign key linking to service.offering. Business justification: Special waste approvals are triggered by specific service offerings requiring non-standard waste acceptance. Tracking the originating service offering is essential for approval workflow routing, prici' ;
    rdfs:domain ind:SpecialWasteApproval ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Offering .

ind:proposedDisposalCellId rdf:type rdf:Property ;
    rdfs:label 'Proposed Disposal Cell Id' ;
    rdfs:comment 'Reference to the specific landfill cell proposed for disposal of the special waste stream.' ;
    rdfs:domain ind:SpecialWasteApproval ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Cell .

ind:analyticalProfileReference rdf:type rdf:Property ;
    rdfs:label 'Analytical Profile Reference' ;
    rdfs:comment 'Reference number or identifier for the complete analytical profile and laboratory test results submitted with the approval request.' ;
    rdfs:domain ind:SpecialWasteApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalDecisionDate rdf:type rdf:Property ;
    rdfs:label 'Approval Decision Date' ;
    rdfs:comment 'Date when the final approval or rejection decision was made by the approving authority.' ;
    rdfs:domain ind:SpecialWasteApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvalDecisionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approval Decision Timestamp' ;
    rdfs:comment 'Precise timestamp when the approval or rejection decision was recorded in the system.' ;
    rdfs:domain ind:SpecialWasteApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:approvalExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Approval Expiration Date' ;
    rdfs:comment 'Date when the special waste approval expires and a new approval request must be submitted for continued disposal.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvalRequestNumber rdf:type rdf:Property ;
    rdfs:label 'Approval Request Number' ;
    rdfs:comment 'Business identifier for the special waste approval request, used for tracking and reference in communications with customers and regulatory agencies.' ;
    rdfs:domain ind:SpecialWasteApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedDisposalConditions rdf:type rdf:Property ;
    rdfs:label 'Approved Disposal Conditions' ;
    rdfs:comment 'Specific conditions, restrictions, or requirements that must be met for disposal of the approved special waste stream, such as placement requirements, cover specifications, or monitoring protocols.' ;
    rdfs:domain ind:SpecialWasteApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedTonnageLimit rdf:type rdf:Property ;
    rdfs:label 'Approved Tonnage Limit' ;
    rdfs:comment 'Maximum tonnage of the special waste stream approved for disposal under this approval, measured in tons.' ;
    rdfs:domain ind:SpecialWasteApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalReviewRequired rdf:type rdf:Property ;
    rdfs:label 'Environmental Review Required' ;
    rdfs:comment 'Indicates whether an additional environmental impact review or assessment is required before final approval can be granted.' ;
    rdfs:domain ind:SpecialWasteApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedVolumeCubicYards rdf:type rdf:Property ;
    rdfs:label 'Estimated Volume Cubic Yards' ;
    rdfs:comment 'Estimated total volume of the special waste stream proposed for disposal, measured in cubic yards.' ;
    rdfs:domain ind:SpecialWasteApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedVolumeTons rdf:type rdf:Property ;
    rdfs:label 'Estimated Volume Tons' ;
    rdfs:comment 'Estimated total weight of the special waste stream proposed for disposal, measured in tons.' ;
    rdfs:domain ind:SpecialWasteApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:labCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Lab Certification Number' ;
    rdfs:comment 'Certification or accreditation number of the laboratory that performed the waste analysis.' ;
    rdfs:domain ind:SpecialWasteApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labName rdf:type rdf:Property ;
    rdfs:label 'Lab Name' ;
    rdfs:comment 'Name of the certified laboratory that performed the waste characterization analysis.' ;
    rdfs:domain ind:SpecialWasteApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryNotificationRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Required' ;
    rdfs:comment 'Indicates whether the approval decision must be reported to state or federal regulatory agencies.' ;
    rdfs:domain ind:SpecialWasteApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requestDate rdf:type rdf:Property ;
    rdfs:label 'Request Date' ;
    rdfs:comment 'Date when the special waste approval request was submitted for review.' ;
    rdfs:domain ind:SpecialWasteApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestTimestamp rdf:type rdf:Property ;
    rdfs:label 'Request Timestamp' ;
    rdfs:comment 'Precise timestamp when the special waste approval request was received in the system.' ;
    rdfs:domain ind:SpecialWasteApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:specialHandlingRequirements rdf:type rdf:Property ;
    rdfs:label 'Special Handling Requirements' ;
    rdfs:comment 'Description of any special handling, equipment, or operational procedures required for safe disposal of the approved special waste stream.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tclpResultsAvailable rdf:type rdf:Property ;
    rdfs:label 'Tclp Results Available' ;
    rdfs:comment 'Indicates whether TCLP analytical test results have been provided as part of the waste characterization data.' ;
    rdfs:domain ind:SpecialWasteApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tclpTestDate rdf:type rdf:Property ;
    rdfs:label 'Tclp Test Date' ;
    rdfs:comment 'Date when the TCLP analytical testing was performed on the waste sample.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:wasteClassification rdf:type rdf:Property ;
    rdfs:label 'Waste Classification' ;
    rdfs:comment 'Regulatory classification of the special waste stream based on RCRA Subtitle D criteria and state-specific waste acceptance standards.' ;
    rdfs:domain ind:SpecialWasteApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteDescription rdf:type rdf:Property ;
    rdfs:label 'Waste Description' ;
    rdfs:comment 'Detailed description of the special waste stream including physical characteristics, composition, and any known contaminants or hazardous properties.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteOriginAddress rdf:type rdf:Property ;
    rdfs:label 'Waste Origin Address' ;
    rdfs:comment 'Physical address of the facility or location where the special waste was generated.' ;
    rdfs:domain ind:SpecialWasteApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteOriginCity rdf:type rdf:Property ;
    rdfs:label 'Waste Origin City' ;
    rdfs:comment 'City where the special waste was generated.' ;
    rdfs:domain ind:SpecialWasteApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteOriginDescription rdf:type rdf:Property ;
    rdfs:label 'Waste Origin Description' ;
    rdfs:comment 'Description of the industrial process, facility, or activity that generated the special waste stream.' ;
    rdfs:domain ind:SpecialWasteApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteOriginPostalCode rdf:type rdf:Property ;
    rdfs:label 'Waste Origin Postal Code' ;
    rdfs:comment 'Postal code of the location where the special waste was generated.' ;
    rdfs:domain ind:SpecialWasteApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteOriginStateCode rdf:type rdf:Property ;
    rdfs:label 'Waste Origin State Code' ;
    rdfs:comment 'Two-letter state code where the special waste was generated.' ;
    rdfs:domain ind:SpecialWasteApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalLandfillSiteId rdf:type rdf:Property ;
    rdfs:label 'Disposal Landfill Site Id' ;
    rdfs:comment 'Foreign key linking to landfill.site. Business justification: Route planning requires direct reference to the landfill site to validate permitted waste types, daily receipt limits, and tipping fee schedules before dispatch. Dispatchers and route planners need th' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Site .

ind:primaryDriverId rdf:type rdf:Property ;
    rdfs:label 'Primary Driver Id' ;
    rdfs:comment 'Reference to the driver typically assigned to this route. Actual daily assignments may vary and are tracked in route execution records.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Driver .

ind:routeOptimizationRunId rdf:type rdf:Property ;
    rdfs:label 'Route Optimization Run Id' ;
    rdfs:comment 'Foreign key linking to collection.route_optimization_run. Business justification: A route is often created or updated as the output of a route_optimization_run. route has optimization_score (DECIMAL) which is a result of optimization, indicating a direct relationship exists. Adding' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RouteOptimizationRun .

ind:capacityConstraintTons rdf:type rdf:Property ;
    rdfs:label 'Capacity Constraint Tons' ;
    rdfs:comment 'Maximum tonnage capacity for this route based on truck payload limits and disposal facility constraints.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:containerTypePrimary rdf:type rdf:Property ;
    rdfs:label 'Container Type Primary' ;
    rdfs:comment 'Primary type of waste container serviced on this route: cart (residential curbside), bin (small commercial), dumpster (large commercial), compactor, or roll-off container.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endLocationLatitude rdf:type rdf:Property ;
    rdfs:label 'End Location Latitude' ;
    rdfs:comment 'Latitude coordinate of the route end location (typically a disposal facility, transfer station, or return depot).' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:endLocationLongitude rdf:type rdf:Property ;
    rdfs:label 'End Location Longitude' ;
    rdfs:comment 'Longitude coordinate of the route end location (typically a disposal facility, transfer station, or return depot).' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Estimated Duration Minutes' ;
    rdfs:comment 'Planned duration in minutes to complete the entire route under normal conditions, including drive time and service time.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedFuelConsumptionGallons rdf:type rdf:Property ;
    rdfs:label 'Estimated Fuel Consumption Gallons' ;
    rdfs:comment 'Estimated fuel consumption in gallons for a typical execution of this route, used for budgeting and environmental reporting.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedGhgEmissionsCo2eKg rdf:type rdf:Property ;
    rdfs:label 'Estimated Ghg Emissions Co2e Kg' ;
    rdfs:comment 'Estimated greenhouse gas emissions in kilograms of Carbon Dioxide Equivalent (CO2e) for a typical execution of this route, supporting sustainability and EPA reporting.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedTonnage rdf:type rdf:Property ;
    rdfs:label 'Estimated Tonnage' ;
    rdfs:comment 'Expected total tonnage of waste to be collected on a typical execution of this route, used for capacity planning.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelTypeRequired rdf:type rdf:Property ;
    rdfs:label 'Fuel Type Required' ;
    rdfs:comment 'Type of fuel required for vehicles assigned to this route: diesel, Compressed Natural Gas (CNG), Renewable Natural Gas (RNG), electric, or hybrid.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optimizationScore rdf:type rdf:Property ;
    rdfs:label 'Optimization Score' ;
    rdfs:comment 'Efficiency score (0-100) assigned by route optimization algorithms, reflecting factors such as mileage efficiency, stop density, and time utilization.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requiresCdl rdf:type rdf:Property ;
    rdfs:label 'Requires Cdl' ;
    rdfs:comment 'Indicates whether a Commercial Driver License (CDL) is required to operate the vehicle type assigned to this route.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresHazmatCertification rdf:type rdf:Property ;
    rdfs:label 'Requires Hazmat Certification' ;
    rdfs:comment 'Indicates whether hazardous materials handling certification is required for drivers on this route due to the nature of waste collected.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:routeCode rdf:type rdf:Property ;
    rdfs:label 'Route Code' ;
    rdfs:comment 'Business identifier for the route, used in operational systems and driver communications. Typically alphanumeric code assigned by dispatch.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeName rdf:type rdf:Property ;
    rdfs:label 'Route Name' ;
    rdfs:comment 'Human-readable name or description of the route, often including geographic area or customer segment (e.g., \'Downtown Commercial MSW Monday\').' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeStatus rdf:type rdf:Property ;
    rdfs:label 'Route Status' ;
    rdfs:comment 'Current lifecycle status of the route: active (in regular operation), inactive (temporarily not scheduled), suspended (on hold), planned (designed but not yet operational), or retired (permanently discontinued).' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledDayOfWeek rdf:type rdf:Property ;
    rdfs:label 'Scheduled Day Of Week' ;
    rdfs:comment 'Primary day of the week this route is scheduled to run (for weekly/biweekly routes). Multiple days may result in multiple route records or a separate schedule table.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:startLocationLatitude rdf:type rdf:Property ;
    rdfs:label 'Start Location Latitude' ;
    rdfs:comment 'Latitude coordinate of the route start location (typically a depot or transfer station).' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:startLocationLongitude rdf:type rdf:Property ;
    rdfs:label 'Start Location Longitude' ;
    rdfs:comment 'Longitude coordinate of the route start location (typically a depot or transfer station).' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalMileage rdf:type rdf:Property ;
    rdfs:label 'Total Mileage' ;
    rdfs:comment 'Total planned mileage for the route in miles, including travel to first stop, between stops, and return to facility.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalStops rdf:type rdf:Property ;
    rdfs:label 'Total Stops' ;
    rdfs:comment 'Total number of scheduled service stops (customer pickup points) on this route.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:zoneCode rdf:type rdf:Property ;
    rdfs:label 'Zone Code' ;
    rdfs:comment 'Sub-district zone code for finer geographic segmentation within a district.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualEndTime rdf:type rdf:Property ;
    rdfs:label 'Actual End Time' ;
    rdfs:comment 'Actual timestamp when the route execution was completed or terminated. Captured from GPS or driver mobile device.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualStartTime rdf:type rdf:Property ;
    rdfs:label 'Actual Start Time' ;
    rdfs:comment 'Actual timestamp when the driver began executing the route. Captured from GPS or driver mobile device.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:completionPercentage rdf:type rdf:Property ;
    rdfs:label 'Completion Percentage' ;
    rdfs:comment 'Percentage of planned stops that were successfully completed. Calculated as (total_stops_completed / total_stops_planned) * 100.' ;
    rdfs:domain ind:RouteExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerComplaintFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Complaint Flag' ;
    rdfs:comment 'Indicates whether any customer complaints were logged against this route execution. True if service quality issues were reported.' ;
    rdfs:domain ind:RouteExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dispatchNotes rdf:type rdf:Property ;
    rdfs:label 'Dispatch Notes' ;
    rdfs:comment 'Free-text notes from dispatch regarding special instructions, route changes, or operational considerations for this execution.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distanceTraveledMiles rdf:type rdf:Property ;
    rdfs:label 'Distance Traveled Miles' ;
    rdfs:comment 'Total distance traveled during route execution measured in miles. Captured from GPS telematics.' ;
    rdfs:domain ind:RouteExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:driverNotes rdf:type rdf:Property ;
    rdfs:label 'Driver Notes' ;
    rdfs:comment 'Free-text notes entered by the driver regarding route conditions, exceptions, or issues encountered during execution.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionStatus rdf:type rdf:Property ;
    rdfs:label 'Execution Status' ;
    rdfs:comment 'Current lifecycle status of the route execution. Tracks progression from scheduled through completion or cancellation.' ;
    rdfs:domain ind:RouteExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelConsumedGallons rdf:type rdf:Property ;
    rdfs:label 'Fuel Consumed Gallons' ;
    rdfs:comment 'Total fuel consumed by the vehicle during this route execution measured in gallons. Sourced from telematics or fuel card data.' ;
    rdfs:domain ind:RouteExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:helperAssignedFlag rdf:type rdf:Property ;
    rdfs:label 'Helper Assigned Flag' ;
    rdfs:comment 'Indicates whether a helper or second crew member was assigned to assist with this route execution.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:numberOfDumps rdf:type rdf:Property ;
    rdfs:label 'Number Of Dumps' ;
    rdfs:comment 'Count of times the vehicle dumped its load at a disposal or transfer facility during this route execution.' ;
    rdfs:domain ind:RouteExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overtimeFlag rdf:type rdf:Property ;
    rdfs:label 'Overtime Flag' ;
    rdfs:comment 'Indicates whether the route execution resulted in driver overtime hours. True if actual duration exceeded standard shift length.' ;
    rdfs:domain ind:RouteExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:plannedEndTime rdf:type rdf:Property ;
    rdfs:label 'Planned End Time' ;
    rdfs:comment 'Scheduled completion time for the route execution as defined in the dispatch plan.' ;
    rdfs:domain ind:RouteExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedStartTime rdf:type rdf:Property ;
    rdfs:label 'Planned Start Time' ;
    rdfs:comment 'Scheduled start time for the route execution as defined in the dispatch plan.' ;
    rdfs:domain ind:RouteExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:routeDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Route Duration Minutes' ;
    rdfs:comment 'Total elapsed time from actual start to actual end of route execution measured in minutes.' ;
    rdfs:domain ind:RouteExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:routeType rdf:type rdf:Property ;
    rdfs:label 'Route Type' ;
    rdfs:comment 'Classification of the route based on customer segment and waste stream. Determines service characteristics and equipment requirements.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceDate rdf:type rdf:Property ;
    rdfs:label 'Service Date' ;
    rdfs:comment 'The calendar date on which this route execution occurred. Represents the business event date for collection operations.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalStopsCompleted rdf:type rdf:Property ;
    rdfs:label 'Total Stops Completed' ;
    rdfs:comment 'Number of collection stops successfully serviced during this route execution.' ;
    rdfs:domain ind:RouteExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalStopsMissed rdf:type rdf:Property ;
    rdfs:label 'Total Stops Missed' ;
    rdfs:comment 'Number of planned stops that were not serviced during this route execution. Includes skipped, inaccessible, and cancelled stops.' ;
    rdfs:domain ind:RouteExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalStopsPlanned rdf:type rdf:Property ;
    rdfs:label 'Total Stops Planned' ;
    rdfs:comment 'Number of collection stops scheduled for this route execution based on the route definition and service calendar.' ;
    rdfs:domain ind:RouteExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalTonnageCollected rdf:type rdf:Property ;
    rdfs:label 'Total Tonnage Collected' ;
    rdfs:comment 'Total weight of waste collected during this route execution measured in tons. Key operational metric for capacity planning and billing.' ;
    rdfs:domain ind:RouteExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalVolumeCollectedCubicYards rdf:type rdf:Property ;
    rdfs:label 'Total Volume Collected Cubic Yards' ;
    rdfs:comment 'Total volume of waste collected during this route execution measured in cubic yards. Used for capacity utilization analysis.' ;
    rdfs:domain ind:RouteExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accessInstructions rdf:type rdf:Property ;
    rdfs:label 'Access Instructions' ;
    rdfs:comment 'Special instructions for accessing the service location, such as gate codes, key locations, or entry procedures.' ;
    rdfs:domain ind:Stop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualArrivalTime rdf:type rdf:Property ;
    rdfs:label 'Actual Arrival Time' ;
    rdfs:comment 'Actual timestamp when the collection vehicle arrived at this stop, captured via GPS telematics or driver input.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualServiceEndTime rdf:type rdf:Property ;
    rdfs:label 'Actual Service End Time' ;
    rdfs:comment 'Timestamp when service activity was completed at this stop.' ;
    rdfs:domain ind:Stop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualServiceStartTime rdf:type rdf:Property ;
    rdfs:label 'Actual Service Start Time' ;
    rdfs:comment 'Timestamp when service activity began at this stop.' ;
    rdfs:domain ind:Stop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cidTagIdentifiers rdf:type rdf:Property ;
    rdfs:label 'Cid Tag Identifiers' ;
    rdfs:comment 'Comma-separated list of CID or RFID tag identifiers for containers at this stop, used for automated container tracking.' ;
    rdfs:domain ind:Stop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedServiceDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Estimated Service Duration Minutes' ;
    rdfs:comment 'Expected time in minutes required to complete service at this stop, used for route time calculations.' ;
    rdfs:domain ind:Stop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:geofenceRadiusMeters rdf:type rdf:Property ;
    rdfs:label 'Geofence Radius Meters' ;
    rdfs:comment 'Radius in meters defining the geofence boundary around the stop location, used to trigger automated arrival/departure events.' ;
    rdfs:domain ind:Stop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedArrivalTime rdf:type rdf:Property ;
    rdfs:label 'Planned Arrival Time' ;
    rdfs:comment 'Scheduled timestamp when the collection vehicle is expected to arrive at this stop, based on route optimization.' ;
    rdfs:domain ind:Stop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedServiceWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Planned Service Window End' ;
    rdfs:comment 'End of the time window during which service is scheduled to occur.' ;
    rdfs:domain ind:Stop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedServiceWindowStart rdf:type rdf:Property ;
    rdfs:label 'Planned Service Window Start' ;
    rdfs:comment 'Beginning of the time window during which service is scheduled to occur, often used for commercial SLA commitments.' ;
    rdfs:domain ind:Stop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requiresBackup rdf:type rdf:Property ;
    rdfs:label 'Requires Backup' ;
    rdfs:comment 'Flag indicating whether the collection vehicle must back up to access this stop, relevant for safety and route planning.' ;
    rdfs:domain ind:Stop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresPpe rdf:type rdf:Property ;
    rdfs:label 'Requires Ppe' ;
    rdfs:comment 'Flag indicating whether specialized personal protective equipment is required for service at this stop due to hazardous materials or safety concerns.' ;
    rdfs:domain ind:Stop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Sequence Number' ;
    rdfs:comment 'Ordinal position of this stop within the route. Determines the order in which the driver visits stops.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:skipReasonCode rdf:type rdf:Property ;
    rdfs:label 'Skip Reason Code' ;
    rdfs:comment 'Standardized code indicating why service was not completed at this stop, if applicable. [ENUM-REF-CANDIDATE: no_access|blocked|weather|customer_request|equipment_failure|safety_concern|no_waste_out — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Stop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skipReasonNotes rdf:type rdf:Property ;
    rdfs:label 'Skip Reason Notes' ;
    rdfs:comment 'Free-text explanation providing additional context for why service was skipped.' ;
    rdfs:domain ind:Stop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stopNumber rdf:type rdf:Property ;
    rdfs:label 'Stop Number' ;
    rdfs:comment 'Business identifier for the stop, often used in driver manifests and dispatch communications.' ;
    rdfs:domain ind:Stop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stopStatus rdf:type rdf:Property ;
    rdfs:label 'Stop Status' ;
    rdfs:comment 'Current operational status of the stop within its service lifecycle.' ;
    rdfs:domain ind:Stop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stopType rdf:type rdf:Property ;
    rdfs:label 'Stop Type' ;
    rdfs:comment 'Classification of the stop based on customer segment and service characteristics.' ;
    rdfs:domain ind:Stop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeCollectedCubicYards rdf:type rdf:Property ;
    rdfs:label 'Volume Collected Cubic Yards' ;
    rdfs:comment 'Estimated volume in cubic yards of waste collected at this stop.' ;
    rdfs:domain ind:Stop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightCollectedLbs rdf:type rdf:Property ;
    rdfs:label 'Weight Collected Lbs' ;
    rdfs:comment 'Total weight in pounds of waste collected at this stop, captured via onboard scales or estimated.' ;
    rdfs:domain ind:Stop ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceScheduleId rdf:type rdf:Property ;
    rdfs:label 'Service Schedule Id' ;
    rdfs:comment 'Foreign key linking to collection.service_schedule. Business justification: A pickup_event is the actual execution of a scheduled service defined in service_schedule. Linking pickup_event to service_schedule enables SLA compliance tracking (was the scheduled service actually ' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceSchedule .

ind:arrivalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Arrival Timestamp' ;
    rdfs:comment 'Timestamp when the collection vehicle arrived at the service stop, captured from GPS telemetry.' ;
    rdfs:domain ind:PickupEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:billableFlag rdf:type rdf:Property ;
    rdfs:label 'Billable Flag' ;
    rdfs:comment 'Boolean flag indicating whether this pickup event is billable to the customer account, used for revenue recognition and invoicing.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerSignatureCapturedFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Signature Captured Flag' ;
    rdfs:comment 'Boolean flag indicating whether a customer signature was captured as proof of service delivery, typically for special waste or high-value services.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedWeightLbs rdf:type rdf:Property ;
    rdfs:label 'Estimated Weight Lbs' ;
    rdfs:comment 'Estimated weight of waste collected in pounds, derived from onboard scale sensors or volumetric calculations.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exceptionCode rdf:type rdf:Property ;
    rdfs:label 'Exception Code' ;
    rdfs:comment 'Standardized code indicating the reason for service exception or non-completion, used for operational reporting and customer communication.' ;
    rdfs:domain ind:PickupEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gpsAccuracyMeters rdf:type rdf:Property ;
    rdfs:label 'Gps Accuracy Meters' ;
    rdfs:comment 'Accuracy of the GPS reading in meters, indicating the precision of the location capture.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gpsLatitude rdf:type rdf:Property ;
    rdfs:label 'Gps Latitude' ;
    rdfs:comment 'GPS latitude coordinate of the vehicle location at the time of service completion, used for proof of service and route verification.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gpsLongitude rdf:type rdf:Property ;
    rdfs:label 'Gps Longitude' ;
    rdfs:comment 'GPS longitude coordinate of the vehicle location at the time of service completion, used for proof of service and route verification.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:liftConfirmationFlag rdf:type rdf:Property ;
    rdfs:label 'Lift Confirmation Flag' ;
    rdfs:comment 'Boolean flag indicating whether the Power Take-Off (PTO) sensor confirmed that the container was physically lifted and emptied.' ;
    rdfs:domain ind:PickupEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:liftCount rdf:type rdf:Property ;
    rdfs:label 'Lift Count' ;
    rdfs:comment 'Number of container lifts performed during this pickup event. Typically 1, but may be higher for multiple containers at a single stop.' ;
    rdfs:domain ind:PickupEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overageChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Overage Charge Amount' ;
    rdfs:comment 'Additional charge amount in USD for overage conditions such as excess weight or extra containers, applied per contract terms.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:photoCapturedFlag rdf:type rdf:Property ;
    rdfs:label 'Photo Captured Flag' ;
    rdfs:comment 'Boolean flag indicating whether a photo was captured during service for proof of service or documentation of service issues.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:photoStorageUrl rdf:type rdf:Property ;
    rdfs:label 'Photo Storage Url' ;
    rdfs:comment 'URL reference to the stored photo image in the document management system, if a photo was captured.' ;
    rdfs:domain ind:PickupEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfidScanStatus rdf:type rdf:Property ;
    rdfs:label 'Rfid Scan Status' ;
    rdfs:comment 'Status of the RFID scan attempt indicating whether the container tag was successfully read, failed to read, or encountered other issues.' ;
    rdfs:domain ind:PickupEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfidTagNumber rdf:type rdf:Property ;
    rdfs:label 'Rfid Tag Number' ;
    rdfs:comment 'The Radio Frequency Identification (RFID) tag number scanned from the container at time of service, providing automated proof of service.' ;
    rdfs:domain ind:PickupEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledPickupTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Pickup Time' ;
    rdfs:comment 'The originally scheduled time for this pickup as planned in the route optimization system.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:serviceChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Service Charge Amount' ;
    rdfs:comment 'Monetary charge amount for this pickup service in USD, used for billing and revenue tracking.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Service Completion Timestamp' ;
    rdfs:comment 'Timestamp when the pickup service was completed and the vehicle departed the stop.' ;
    rdfs:domain ind:PickupEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:serviceDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Service Duration Seconds' ;
    rdfs:comment 'Total time in seconds spent at the stop from arrival to departure, used for route efficiency analysis.' ;
    rdfs:domain ind:PickupEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceOutcome rdf:type rdf:Property ;
    rdfs:label 'Service Outcome' ;
    rdfs:comment 'Final outcome of the pickup attempt indicating whether service was completed successfully or the reason for non-completion.' ;
    rdfs:domain ind:PickupEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stopSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Stop Sequence Number' ;
    rdfs:comment 'Sequential order of this stop within the route execution, used for route optimization and performance analysis.' ;
    rdfs:domain ind:PickupEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:truckLoaderType rdf:type rdf:Property ;
    rdfs:label 'Truck Loader Type' ;
    rdfs:comment 'Type of loading mechanism on the collection vehicle. ASL (Automated Side Loader), FEL (Front End Loader), REL (Rear End Loader), Roll-Off, or Side-Load.' ;
    rdfs:domain ind:PickupEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceExceptionId rdf:type rdf:Property ;
    rdfs:label 'Service Exception Id' ;
    rdfs:comment 'Unique identifier for the service exception record. Primary key.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceException .

ind:maintenanceWorkOrderId rdf:type rdf:Property ;
    rdfs:label 'Maintenance Work Order Id' ;
    rdfs:comment 'Foreign key linking to maintenance.work_order. Business justification: Service exceptions (container damage, equipment failure at stop, access issues requiring physical changes) often trigger maintenance work orders for corrective action. Tracking the resulting WO enable' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkOrder .

ind:primaryServiceRouteId rdf:type rdf:Property ;
    rdfs:label 'Primary Service Route Id' ;
    rdfs:comment 'Reference to the collection route where the exception occurred.' ;
    rdfs:domain ind:ServiceException ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Route .

ind:contaminationSeverity rdf:type rdf:Property ;
    rdfs:label 'Contamination Severity' ;
    rdfs:comment 'Severity level of contamination requiring different handling or customer education responses.' ;
    rdfs:domain ind:ServiceException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Amount' ;
    rdfs:comment 'Monetary value of credit issued to customer account due to service exception, in USD.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerNotificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Timestamp' ;
    rdfs:comment 'Date and time when the customer was notified about the service exception.' ;
    rdfs:domain ind:ServiceException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:customerNotifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Notified Flag' ;
    rdfs:comment 'Indicates whether the customer has been notified about the service exception.' ;
    rdfs:domain ind:ServiceException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exceptionDescription rdf:type rdf:Property ;
    rdfs:label 'Exception Description' ;
    rdfs:comment 'Detailed narrative description of the service exception event, circumstances, and any relevant observations from the field.' ;
    rdfs:domain ind:ServiceException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionNumber rdf:type rdf:Property ;
    rdfs:label 'Exception Number' ;
    rdfs:comment 'Business-facing unique exception tracking number displayed to customers and service personnel.' ;
    rdfs:domain ind:ServiceException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionStatus rdf:type rdf:Property ;
    rdfs:label 'Exception Status' ;
    rdfs:comment 'Current lifecycle status of the service exception indicating resolution progress.' ;
    rdfs:domain ind:ServiceException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Exception Timestamp' ;
    rdfs:comment 'Date and time when the service exception was encountered or reported by the driver in the field.' ;
    rdfs:domain ind:ServiceException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:exceptionTypeCode rdf:type rdf:Property ;
    rdfs:label 'Exception Type Code' ;
    rdfs:comment 'Standardized code categorizing the type of service exception encountered during collection operations. [ENUM-REF-CANDIDATE: MISSED_PICKUP|CONTAMINATION|BLOCKED_ACCESS|OVERWEIGHT|OVERFILLED|WRONG_MATERIAL|NO_CONTAINER|DAMAGED_CONTAINER|SAFETY_HAZARD|WEATHER_DELAY|EQUIPMENT_FAILURE|CUSTOMER_NOT_READY — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ServiceException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpScheduledDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Scheduled Date' ;
    rdfs:comment 'Scheduled date for follow-up service or resolution action related to this exception.' ;
    rdfs:domain ind:ServiceException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:photoStoragePath rdf:type rdf:Property ;
    rdfs:label 'Photo Storage Path' ;
    rdfs:comment 'File system or cloud storage path reference to exception documentation photos.' ;
    rdfs:domain ind:ServiceException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preventableFlag rdf:type rdf:Property ;
    rdfs:label 'Preventable Flag' ;
    rdfs:comment 'Indicates whether the exception was preventable through operational improvements or customer education.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:repeatExceptionFlag rdf:type rdf:Property ;
    rdfs:label 'Repeat Exception Flag' ;
    rdfs:comment 'Indicates whether this is a recurring exception at the same service address or for the same customer.' ;
    rdfs:domain ind:ServiceException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportedBySource rdf:type rdf:Property ;
    rdfs:label 'Reported By Source' ;
    rdfs:comment 'Indicates the source or channel through which the exception was initially reported.' ;
    rdfs:domain ind:ServiceException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresFollowUpFlag rdf:type rdf:Property ;
    rdfs:label 'Requires Follow Up Flag' ;
    rdfs:comment 'Indicates whether this exception requires additional follow-up action or customer contact.' ;
    rdfs:domain ind:ServiceException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rescheduleRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Reschedule Required Flag' ;
    rdfs:comment 'Indicates whether the missed or incomplete service requires rescheduling on a future route.' ;
    rdfs:domain ind:ServiceException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resolutionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Resolution Timestamp' ;
    rdfs:comment 'Date and time when the service exception was marked as resolved or closed.' ;
    rdfs:domain ind:ServiceException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rootCauseCategory rdf:type rdf:Property ;
    rdfs:label 'Root Cause Category' ;
    rdfs:comment 'High-level categorization of the underlying root cause of the service exception for trend analysis. [ENUM-REF-CANDIDATE: CUSTOMER_ERROR|DRIVER_ERROR|EQUIPMENT_FAILURE|ROUTE_PLANNING|WEATHER|ACCESS_ISSUE|CONTAMINATION|OTHER — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerPlacementId rdf:type rdf:Property ;
    rdfs:label 'Container Placement Id' ;
    rdfs:comment 'Unique identifier for the container placement record. Primary key for tracking the assignment of a container to a specific service location.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContainerPlacement .

ind:primaryContainerRemovalDriverId rdf:type rdf:Property ;
    rdfs:label 'Primary Container Removal Driver Id' ;
    rdfs:comment 'Reference to the driver who performed the container removal. Links to the workforce employee record.' ;
    rdfs:domain ind:ContainerPlacement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Driver .

ind:primaryContainerRemovalVehicleId rdf:type rdf:Property ;
    rdfs:label 'Primary Container Removal Vehicle Id' ;
    rdfs:comment 'Reference to the fleet vehicle used to remove the container. Links to the fleet asset master record.' ;
    rdfs:domain ind:ContainerPlacement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vehicle .

ind:primaryContainerRemovalWorkOrderId rdf:type rdf:Property ;
    rdfs:label 'Primary Container Removal Work Order Id' ;
    rdfs:comment 'Reference to the work order that authorized and tracked the container removal activity. Links to the work order management system.' ;
    rdfs:domain ind:ContainerPlacement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkOrder .

ind:rfidTagId rdf:type rdf:Property ;
    rdfs:label 'Rfid Tag Id' ;
    rdfs:comment 'Unique RFID tag identifier embedded in or attached to the container for automated tracking and identification during collection operations.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RfidTag .

ind:serviceCommitmentId rdf:type rdf:Property ;
    rdfs:label 'Service Commitment Id' ;
    rdfs:comment 'Foreign key linking to contract.contract_service_commitment. Business justification: Container placements physically fulfill contract service commitments specifying container type, size, and quantity. Linking placements to commitments enables contract fulfillment tracking, equipment d' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceCommitment .

ind:actualRemovalDate rdf:type rdf:Property ;
    rdfs:label 'Actual Removal Date' ;
    rdfs:comment 'Actual date when the container was physically removed from the service location. Marks the end of the container assignment lifecycle.' ;
    rdfs:domain ind:ContainerPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:containerConditionAtPlacement rdf:type rdf:Property ;
    rdfs:label 'Container Condition At Placement' ;
    rdfs:comment 'Physical condition assessment of the container at the time of placement. Used for asset lifecycle tracking and maintenance planning.' ;
    rdfs:domain ind:ContainerPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerConditionAtRemoval rdf:type rdf:Property ;
    rdfs:label 'Container Condition At Removal' ;
    rdfs:comment 'Physical condition assessment of the container at the time of removal. Used for asset lifecycle tracking, maintenance planning, and loss tracking.' ;
    rdfs:domain ind:ContainerPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerSize rdf:type rdf:Property ;
    rdfs:label 'Container Size' ;
    rdfs:comment 'Physical capacity of the container expressed with unit of measure (e.g., 2-yd, 4-yd, 6-yd, 8-yd, 96-gal, 10-cu-yd, 20-cu-yd, 30-cu-yd, 40-cu-yd). Critical for route planning and capacity management.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isBillable rdf:type rdf:Property ;
    rdfs:label 'Is Billable' ;
    rdfs:comment 'Flag indicating whether this container placement generates billable charges to the customer account. Some placements may be promotional, warranty replacements, or non-revenue generating.' ;
    rdfs:domain ind:ContainerPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTemporaryPlacement rdf:type rdf:Property ;
    rdfs:label 'Is Temporary Placement' ;
    rdfs:comment 'Flag indicating whether this is a temporary container placement (e.g., roll-off for construction project, event-based service) versus a permanent ongoing service.' ;
    rdfs:domain ind:ContainerPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:placementAccuracyMeters rdf:type rdf:Property ;
    rdfs:label 'Placement Accuracy Meters' ;
    rdfs:comment 'GPS accuracy radius in meters for the placement coordinates. Indicates the precision of the recorded location.' ;
    rdfs:domain ind:ContainerPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:placementDate rdf:type rdf:Property ;
    rdfs:label 'Placement Date' ;
    rdfs:comment 'Date when the container was physically placed at the service location. Marks the start of the container assignment lifecycle.' ;
    rdfs:domain ind:ContainerPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:placementNotes rdf:type rdf:Property ;
    rdfs:label 'Placement Notes' ;
    rdfs:comment 'Free-text notes recorded by the driver or dispatcher at the time of placement. Captures special instructions, access issues, or site-specific details.' ;
    rdfs:domain ind:ContainerPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:placementReason rdf:type rdf:Property ;
    rdfs:label 'Placement Reason' ;
    rdfs:comment 'Business reason for the container placement. Indicates whether this is a new service, replacement, additional container, temporary placement, seasonal service, or event-based service.' ;
    rdfs:domain ind:ContainerPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:placementStatus rdf:type rdf:Property ;
    rdfs:label 'Placement Status' ;
    rdfs:comment 'Current lifecycle status of the container placement. Tracks whether the container is actively in service, pending placement, pending removal, removed, relocated, damaged, or under repair. [ENUM-REF-CANDIDATE: active|pending-placement|pending-removal|removed|relocated|damaged|under-repair — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ContainerPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:placementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Placement Timestamp' ;
    rdfs:comment 'Precise date and time when the container was placed at the service location. Captured from GPS-enabled fleet telematics or driver mobile application.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:removalNotes rdf:type rdf:Property ;
    rdfs:label 'Removal Notes' ;
    rdfs:comment 'Free-text notes recorded by the driver or dispatcher at the time of removal. Captures condition issues, access problems, or other relevant observations.' ;
    rdfs:domain ind:ContainerPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:removalReason rdf:type rdf:Property ;
    rdfs:label 'Removal Reason' ;
    rdfs:comment 'Business reason for the container removal. Indicates whether this is due to service termination, replacement, relocation, end of temporary service, seasonal end, customer request, non-payment, or damage. [ENUM-REF-CANDIDATE: service-termination|replacement|relocation|temporary-end|seasonal-end|customer-request|non-payment|damaged — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ContainerPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:removalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Removal Timestamp' ;
    rdfs:comment 'Precise date and time when the container was removed from the service location. Captured from GPS-enabled fleet telematics or driver mobile application.' ;
    rdfs:domain ind:ContainerPlacement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:driverAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Driver Assignment Id' ;
    rdfs:comment 'Unique identifier for the driver assignment record. Primary key for this transactional entity capturing the assignment of a CDL-licensed driver to a specific route execution.' ;
    rdfs:domain ind:DriverAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hosLogId rdf:type rdf:Property ;
    rdfs:label 'Hos Log Id' ;
    rdfs:comment 'Foreign key linking to fleet.hos_log. Business justification: Dispatch compliance requires linking driver assignments to the governing HOS log record for DOT Hours of Service verification. hos_available_drive_hours and hos_available_duty_hours are denormalized f' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HosLog .

ind:prePostTripInspectionId rdf:type rdf:Property ;
    rdfs:label 'Pre Post Trip Inspection Id' ;
    rdfs:comment 'Foreign key linking to fleet.pre_post_trip_inspection. Business justification: DOT FMCSA requires driver assignments to reference actual pre-trip inspection records. pre_trip_inspection_status and pre_trip_inspection_timestamp are denormalized from pre_post_trip_inspection. Safe' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PrePostTripInspection .

ind:absenceReasonCode rdf:type rdf:Property ;
    rdfs:label 'Absence Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for driver absence if assignment status is absent. Sick for illness, vacation for planned time off, personal for personal leave, injury for work-related injury, no_show for unexcused absence, other for miscellaneous reasons. Null if driver reported for duty.' ;
    rdfs:domain ind:DriverAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentCreatedBy rdf:type rdf:Property ;
    rdfs:label 'Assignment Created By' ;
    rdfs:comment 'Username or identifier of the dispatcher or system user who created this driver assignment record. Used for accountability and audit trail.' ;
    rdfs:domain ind:DriverAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assignment Created Timestamp' ;
    rdfs:comment 'The timestamp when this driver assignment record was first created in the Locus Dispatch system. Used for audit trail and assignment lead time analysis.' ;
    rdfs:domain ind:DriverAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assignmentModifiedBy rdf:type rdf:Property ;
    rdfs:label 'Assignment Modified By' ;
    rdfs:comment 'Username or identifier of the dispatcher or system user who last modified this driver assignment record. Used for accountability and audit trail.' ;
    rdfs:domain ind:DriverAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assignment Modified Timestamp' ;
    rdfs:comment 'The timestamp when this driver assignment record was last modified in the Locus Dispatch system. Used for audit trail and change tracking.' ;
    rdfs:domain ind:DriverAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assignmentPriority rdf:type rdf:Property ;
    rdfs:label 'Assignment Priority' ;
    rdfs:comment 'Priority classification of the driver assignment indicating urgency and importance. Critical for time-sensitive routes or service level agreement (SLA) commitments, high for premium customers, normal for standard service, low for flexible/deferred routes.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdlClassRequired rdf:type rdf:Property ;
    rdfs:label 'Cdl Class Required' ;
    rdfs:comment 'The minimum Commercial Driver License (CDL) class required to operate the assigned truck and execute the route. Class A for combination vehicles over 26,001 lbs, Class B for single vehicles over 26,001 lbs, Class C for vehicles designed to transport 16+ passengers or hazardous materials.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdlEndorsementsRequired rdf:type rdf:Property ;
    rdfs:label 'Cdl Endorsements Required' ;
    rdfs:comment 'Comma-separated list of CDL endorsements required for the assignment. Common endorsements include H (Hazardous Materials), N (Tank Vehicle), P (Passenger), S (School Bus), T (Double/Triple Trailers). Empty if no special endorsements required.' ;
    rdfs:domain ind:DriverAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatchSequence rdf:type rdf:Property ;
    rdfs:label 'Dispatch Sequence' ;
    rdfs:comment 'The sequential order in which this driver assignment was dispatched from the depot on the service date. Used for operational tracking and first-out/last-in analysis.' ;
    rdfs:domain ind:DriverAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dotHosCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Dot Hos Compliant Flag' ;
    rdfs:comment 'Boolean indicator of whether the driver assignment complies with DOT hours-of-service regulations at the time of assignment. True indicates the driver has sufficient available hours and rest periods to legally execute the route, false indicates a compliance violation or risk.' ;
    rdfs:domain ind:DriverAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedRouteDurationHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Route Duration Hours' ;
    rdfs:comment 'The estimated total duration in hours required to complete the assigned route execution, including driving time, service stops, and breaks. Used for scheduling and DOT hours-of-service compliance planning.' ;
    rdfs:domain ind:DriverAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shiftEndTime rdf:type rdf:Property ;
    rdfs:label 'Shift End Time' ;
    rdfs:comment 'The scheduled timestamp when the driver is expected to complete their shift and return to the depot. Used for workforce scheduling and DOT hours-of-service compliance tracking.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shiftStartTime rdf:type rdf:Property ;
    rdfs:label 'Shift Start Time' ;
    rdfs:comment 'The scheduled timestamp when the driver is expected to begin their shift and commence route execution. Used for workforce scheduling and Department of Transportation (DOT) hours-of-service compliance tracking.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sourceSystemRecordCode rdf:type rdf:Property ;
    rdfs:label 'Source System Record Code' ;
    rdfs:comment 'The unique record identifier from the source operational system (Locus Dispatch or Workday HCM). Used for data lineage tracking and reconciliation with source systems.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:truckAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Truck Assignment Id' ;
    rdfs:comment 'Unique identifier for the truck assignment record. Primary key for this transactional entity capturing the assignment of a collection vehicle to a route execution on a specific service date.' ;
    rdfs:domain ind:TruckAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inspectionWorkOrderId rdf:type rdf:Property ;
    rdfs:label 'Inspection Work Order Id' ;
    rdfs:comment 'Foreign key linking to maintenance.work_order. Business justification: truck_assignment records pre-trip and post-trip inspection statuses. When an inspection fails, a maintenance work order is generated to remediate the defect before dispatch. This link enables DOT comp' ;
    rdfs:domain ind:TruckAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkOrder .

ind:primaryTruckDispatchFacilityId rdf:type rdf:Property ;
    rdfs:label 'Primary Truck Dispatch Facility Id' ;
    rdfs:comment 'Reference to the facility or yard from which the truck was dispatched for this route execution. Typically a collection operations center, transfer station, or regional depot.' ;
    rdfs:domain ind:TruckAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:assignmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assignment Timestamp' ;
    rdfs:comment 'Date and time when the truck was assigned to the route execution. Represents the business event time when dispatch confirmed the vehicle-to-route pairing.' ;
    rdfs:domain ind:TruckAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:capacityCubicYards rdf:type rdf:Property ;
    rdfs:label 'Capacity Cubic Yards' ;
    rdfs:comment 'Rated capacity of the assigned truck in cubic yards. Represents the maximum volume of waste the vehicle can carry per load, used for route optimization and load planning.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityTons rdf:type rdf:Property ;
    rdfs:label 'Capacity Tons' ;
    rdfs:comment 'Rated weight capacity of the assigned truck in tons. Represents the maximum weight the vehicle can legally and safely carry, constrained by DOT regulations and vehicle GVWR.' ;
    rdfs:domain ind:TruckAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalIncidentFlag rdf:type rdf:Property ;
    rdfs:label 'Environmental Incident Flag' ;
    rdfs:comment 'Indicates whether an environmental incident occurred during this truck assignment. True if a spill, leak, unauthorized discharge, or EPA-reportable event was logged during route execution.' ;
    rdfs:domain ind:TruckAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fuelType rdf:type rdf:Property ;
    rdfs:label 'Fuel Type' ;
    rdfs:comment 'Primary fuel or energy source for the assigned vehicle. CNG (Compressed Natural Gas), RNG (Renewable Natural Gas), diesel, electric, or hybrid powertrain. Critical for sustainability reporting and GHG emissions tracking.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gpsTrackingEnabled rdf:type rdf:Property ;
    rdfs:label 'Gps Tracking Enabled' ;
    rdfs:comment 'Indicates whether real-time GPS tracking was active for this truck assignment. True if Geotab telematics was operational and transmitting location data during route execution.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:odometerEnd rdf:type rdf:Property ;
    rdfs:label 'Odometer End' ;
    rdfs:comment 'Odometer reading in miles at the time the truck completed the route execution and returned. Used to calculate route mileage and update vehicle lifecycle metrics.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:odometerStart rdf:type rdf:Property ;
    rdfs:label 'Odometer Start' ;
    rdfs:comment 'Odometer reading in miles at the time the truck was assigned and departed for route execution. Used for mileage tracking, fuel efficiency analysis, and preventive maintenance scheduling.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reassignmentReason rdf:type rdf:Property ;
    rdfs:label 'Reassignment Reason' ;
    rdfs:comment 'Free-text explanation for why the truck was reassigned during route execution. Captures operational context for vehicle breakdowns, driver changes, route adjustments, or emergency redeployment.' ;
    rdfs:domain ind:TruckAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeDeviationFlag rdf:type rdf:Property ;
    rdfs:label 'Route Deviation Flag' ;
    rdfs:comment 'Indicates whether the truck deviated from the planned route during execution. True if GPS tracking detected significant off-route travel, triggering operational review or customer service follow-up.' ;
    rdfs:domain ind:TruckAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduledStartTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Time' ;
    rdfs:comment 'Planned date and time when the truck is scheduled to begin the route execution. Used for dispatch planning and driver coordination.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:truckType rdf:type rdf:Property ;
    rdfs:label 'Truck Type' ;
    rdfs:comment 'Classification of the collection vehicle by body configuration and loading mechanism. ASL (Automated Side Loader), FEL (Front End Loader), REL (Rear End Loader), roll-off for container hauling, compactor for transfer operations. [ENUM-REF-CANDIDATE: ASL|FEL|REL|roll_off|compactor|hook_lift|grapple|flatbed — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TruckAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessRequirements rdf:type rdf:Property ;
    rdfs:label 'Access Requirements' ;
    rdfs:comment 'Special access conditions required to service this stop. Used for driver preparation and route planning.' ;
    rdfs:domain ind:ServiceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoRenewFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Renew Flag' ;
    rdfs:comment 'Indicates whether this schedule automatically renews at the end of its term. True if the schedule continues indefinitely unless cancelled.' ;
    rdfs:domain ind:ServiceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:containerQuantity rdf:type rdf:Property ;
    rdfs:label 'Container Quantity' ;
    rdfs:comment 'Number of containers serviced at this stop per scheduled pickup. Used for capacity planning and billing calculations.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:containerSizeUnit rdf:type rdf:Property ;
    rdfs:label 'Container Size Unit' ;
    rdfs:comment 'Unit of measure for the container size. Standardizes capacity reporting across different container types.' ;
    rdfs:domain ind:ServiceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalScheduleCode rdf:type rdf:Property ;
    rdfs:label 'External Schedule Code' ;
    rdfs:comment 'Unique identifier from the source operational system. Used for cross-system reconciliation and integration.' ;
    rdfs:domain ind:ServiceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fridayFlag rdf:type rdf:Property ;
    rdfs:label 'Friday Flag' ;
    rdfs:comment 'Indicates whether service is scheduled on Fridays. True if Friday is a scheduled service day.' ;
    rdfs:domain ind:ServiceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:holidayHandlingRule rdf:type rdf:Property ;
    rdfs:label 'Holiday Handling Rule' ;
    rdfs:comment 'Defines how service is adjusted when a scheduled day falls on a recognized holiday. Determines whether service is skipped, rescheduled, or delivered as normal.' ;
    rdfs:domain ind:ServiceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mondayFlag rdf:type rdf:Property ;
    rdfs:label 'Monday Flag' ;
    rdfs:comment 'Indicates whether service is scheduled on Mondays. True if Monday is a scheduled service day.' ;
    rdfs:domain ind:ServiceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:routeAssignmentMethod rdf:type rdf:Property ;
    rdfs:label 'Route Assignment Method' ;
    rdfs:comment 'Method used to assign this schedule to collection routes. Fixed schedules are always on the same route; dynamic schedules are optimized daily.' ;
    rdfs:domain ind:ServiceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:saturdayFlag rdf:type rdf:Property ;
    rdfs:label 'Saturday Flag' ;
    rdfs:comment 'Indicates whether service is scheduled on Saturdays. True if Saturday is a scheduled service day.' ;
    rdfs:domain ind:ServiceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduleCode rdf:type rdf:Property ;
    rdfs:label 'Schedule Code' ;
    rdfs:comment 'Business identifier for the service schedule. Human-readable code used in operations and customer communications.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceWindowEndTime rdf:type rdf:Property ;
    rdfs:label 'Service Window End Time' ;
    rdfs:comment 'Latest time of day when service can be performed at this stop. Format HH:MM in 24-hour notation. Used for route optimization and customer expectations.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:serviceWindowStartTime rdf:type rdf:Property ;
    rdfs:label 'Service Window Start Time' ;
    rdfs:comment 'Earliest time of day when service can be performed at this stop. Format HH:MM in 24-hour notation. Used for route optimization and customer expectations.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sundayFlag rdf:type rdf:Property ;
    rdfs:label 'Sunday Flag' ;
    rdfs:comment 'Indicates whether service is scheduled on Sundays. True if Sunday is a scheduled service day.' ;
    rdfs:domain ind:ServiceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:thursdayFlag rdf:type rdf:Property ;
    rdfs:label 'Thursday Flag' ;
    rdfs:comment 'Indicates whether service is scheduled on Thursdays. True if Thursday is a scheduled service day.' ;
    rdfs:domain ind:ServiceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tuesdayFlag rdf:type rdf:Property ;
    rdfs:label 'Tuesday Flag' ;
    rdfs:comment 'Indicates whether service is scheduled on Tuesdays. True if Tuesday is a scheduled service day.' ;
    rdfs:domain ind:ServiceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:wednesdayFlag rdf:type rdf:Property ;
    rdfs:label 'Wednesday Flag' ;
    rdfs:comment 'Indicates whether service is scheduled on Wednesdays. True if Wednesday is a scheduled service day.' ;
    rdfs:domain ind:ServiceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:acceptanceDecision rdf:type rdf:Property ;
    rdfs:label 'Acceptance Decision' ;
    rdfs:comment 'Indicates whether the optimized route plan was accepted for deployment (accepted), rejected by operations (rejected), awaiting management review (pending_review), or partially implemented (partially_accepted).' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acceptanceDecisionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Acceptance Decision Timestamp' ;
    rdfs:comment 'The date and time when the acceptance decision was made. Nullable if decision is still pending.' ;
    rdfs:domain ind:RouteOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:algorithmVersion rdf:type rdf:Property ;
    rdfs:label 'Algorithm Version' ;
    rdfs:comment 'Version number of the route optimization algorithm used for this run, formatted as major.minor.patch (e.g., 3.2.1).' ;
    rdfs:domain ind:RouteOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baselineTotalMiles rdf:type rdf:Property ;
    rdfs:label 'Baseline Total Miles' ;
    rdfs:comment 'Total route miles from the previous or baseline plan, used for comparison to measure optimization improvement. Nullable if no baseline exists.' ;
    rdfs:domain ind:RouteOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:configurationProfileCode rdf:type rdf:Property ;
    rdfs:label 'Configuration Profile Code' ;
    rdfs:comment 'Reference to the optimization configuration profile (parameter set) used for this run, defining weights, constraints, and objectives.' ;
    rdfs:domain ind:RouteOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:errorMessage rdf:type rdf:Property ;
    rdfs:label 'Error Message' ;
    rdfs:comment 'Detailed error or exception message if the optimization run failed or encountered issues. Nullable if run completed successfully.' ;
    rdfs:domain ind:RouteOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionMode rdf:type rdf:Property ;
    rdfs:label 'Execution Mode' ;
    rdfs:comment 'Indicates how the optimization run was initiated: manual (user-triggered), scheduled (automated on schedule), automatic (event-driven), or api_triggered (external system integration).' ;
    rdfs:domain ind:RouteOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inputDriverCount rdf:type rdf:Property ;
    rdfs:label 'Input Driver Count' ;
    rdfs:comment 'Total number of drivers available and included as input to the optimization algorithm.' ;
    rdfs:domain ind:RouteOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inputStopCount rdf:type rdf:Property ;
    rdfs:label 'Input Stop Count' ;
    rdfs:comment 'Total number of customer stops (service locations) included as input to the optimization algorithm.' ;
    rdfs:domain ind:RouteOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inputTruckCount rdf:type rdf:Property ;
    rdfs:label 'Input Truck Count' ;
    rdfs:comment 'Total number of collection vehicles (trucks) available and included as input to the optimization algorithm.' ;
    rdfs:domain ind:RouteOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:milesImprovementPercentage rdf:type rdf:Property ;
    rdfs:label 'Miles Improvement Percentage' ;
    rdfs:comment 'Percentage reduction in total route miles compared to the baseline plan. Positive values indicate improvement (fewer miles). Nullable if no baseline exists.' ;
    rdfs:domain ind:RouteOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:optimizationDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Optimization Duration Seconds' ;
    rdfs:comment 'Total elapsed time in seconds for the optimization algorithm to complete execution.' ;
    rdfs:domain ind:RouteOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:optimizationEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Optimization End Timestamp' ;
    rdfs:comment 'The date and time when the optimization algorithm execution completed or terminated.' ;
    rdfs:domain ind:RouteOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:optimizationQualityScore rdf:type rdf:Property ;
    rdfs:label 'Optimization Quality Score' ;
    rdfs:comment 'Algorithm-generated quality score (0-100) indicating how well the optimized solution meets the defined objectives and constraints. Higher scores indicate better optimization results.' ;
    rdfs:domain ind:RouteOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:optimizationRunNumber rdf:type rdf:Property ;
    rdfs:label 'Optimization Run Number' ;
    rdfs:comment 'Business-friendly identifier for the optimization run, typically formatted as OPT-YYYYMMDD-HHMMSS for traceability.' ;
    rdfs:domain ind:RouteOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optimizationScenarioType rdf:type rdf:Property ;
    rdfs:label 'Optimization Scenario Type' ;
    rdfs:comment 'The business scenario or trigger that initiated this optimization run, such as daily re-optimization, seasonal rebalancing, new customer onboarding, emergency reroute, capacity expansion, or service area change.' ;
    rdfs:domain ind:RouteOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optimizationStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Optimization Start Timestamp' ;
    rdfs:comment 'The date and time when the optimization algorithm execution began.' ;
    rdfs:domain ind:RouteOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:optimizationStatus rdf:type rdf:Property ;
    rdfs:label 'Optimization Status' ;
    rdfs:comment 'Current lifecycle status of the optimization run: queued (awaiting execution), running (in progress), completed (successfully finished), failed (encountered errors), cancelled (manually stopped), or partially_accepted (some routes accepted, others rejected).' ;
    rdfs:domain ind:RouteOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outputAverageHoursPerRoute rdf:type rdf:Property ;
    rdfs:label 'Output Average Hours Per Route' ;
    rdfs:comment 'Average estimated time in hours per route in the optimized plan.' ;
    rdfs:domain ind:RouteOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outputAverageMilesPerRoute rdf:type rdf:Property ;
    rdfs:label 'Output Average Miles Per Route' ;
    rdfs:comment 'Average distance in miles per route in the optimized plan.' ;
    rdfs:domain ind:RouteOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outputAverageStopsPerRoute rdf:type rdf:Property ;
    rdfs:label 'Output Average Stops Per Route' ;
    rdfs:comment 'Average number of customer stops per route in the optimized plan.' ;
    rdfs:domain ind:RouteOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outputRouteCount rdf:type rdf:Property ;
    rdfs:label 'Output Route Count' ;
    rdfs:comment 'Total number of optimized routes generated by the algorithm as output.' ;
    rdfs:domain ind:RouteOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:outputTotalRouteHours rdf:type rdf:Property ;
    rdfs:label 'Output Total Route Hours' ;
    rdfs:comment 'Total estimated time in hours across all optimized routes, including drive time, service time, and breaks.' ;
    rdfs:domain ind:RouteOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outputTotalRouteMiles rdf:type rdf:Property ;
    rdfs:label 'Output Total Route Miles' ;
    rdfs:comment 'Total distance in miles across all optimized routes generated by the algorithm.' ;
    rdfs:domain ind:RouteOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outputUnassignedStopCount rdf:type rdf:Property ;
    rdfs:label 'Output Unassigned Stop Count' ;
    rdfs:comment 'Number of customer stops that could not be assigned to any route due to constraints (capacity, time windows, or other limitations).' ;
    rdfs:domain ind:RouteOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryOptimizationObjective rdf:type rdf:Property ;
    rdfs:label 'Primary Optimization Objective' ;
    rdfs:comment 'The primary business objective the optimization algorithm was configured to achieve: minimize total route miles, minimize total route time, maximize compaction efficiency, balance workload across drivers, minimize operational cost, or maximize service quality.' ;
    rdfs:domain ind:RouteOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeWindowEnforcementFlag rdf:type rdf:Property ;
    rdfs:label 'Time Window Enforcement Flag' ;
    rdfs:comment 'Indicates whether customer-specific time window constraints were enforced during optimization (True) or relaxed (False).' ;
    rdfs:domain ind:RouteOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vehicleCapacityConstraintFlag rdf:type rdf:Property ;
    rdfs:label 'Vehicle Capacity Constraint Flag' ;
    rdfs:comment 'Indicates whether vehicle capacity constraints (weight and volume limits) were enforced during optimization (True) or relaxed (False).' ;
    rdfs:domain ind:RouteOptimizationRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:areaSquareMiles rdf:type rdf:Property ;
    rdfs:label 'Area Square Miles' ;
    rdfs:comment 'Geographic area of the district in square miles. Used for route density analysis and operational efficiency metrics.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commercialAccountCount rdf:type rdf:Property ;
    rdfs:label 'Commercial Account Count' ;
    rdfs:comment 'Number of commercial customer accounts served in this district. Used for route planning and revenue forecasting.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:containerTypeSupported rdf:type rdf:Property ;
    rdfs:label 'Container Type Supported' ;
    rdfs:comment 'Types of waste containers supported in this district (e.g., \'96-gallon cart, 2-yard dumpster, 8-yard compactor\'). Comma-separated list.' ;
    rdfs:domain ind:District ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depotLocation rdf:type rdf:Property ;
    rdfs:label 'Depot Location' ;
    rdfs:comment 'Name or identifier of the primary depot or yard location that services this district.' ;
    rdfs:domain ind:District ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:districtCode rdf:type rdf:Property ;
    rdfs:label 'District Code' ;
    rdfs:comment 'Business identifier code for the collection district used in operational systems and reporting. Typically alphanumeric, 2-10 characters.' ;
    rdfs:domain ind:District ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:districtName rdf:type rdf:Property ;
    rdfs:label 'District Name' ;
    rdfs:comment 'Human-readable name of the collection district (e.g., \'North Metro District\', \'Downtown Commercial Zone\').' ;
    rdfs:domain ind:District ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:districtStatus rdf:type rdf:Property ;
    rdfs:label 'District Status' ;
    rdfs:comment 'Current operational status of the district. Values: active (currently serviced), inactive (no longer serviced), planned (future service area), suspended (temporarily not serviced).' ;
    rdfs:domain ind:District ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diversionRateTarget rdf:type rdf:Property ;
    rdfs:label 'Diversion Rate Target' ;
    rdfs:comment 'Target percentage of waste diverted from landfill through recycling, composting, and other programs. Expressed as a percentage (0.00 to 100.00).' ;
    rdfs:domain ind:District ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:endTime rdf:type rdf:Property ;
    rdfs:label 'End Time' ;
    rdfs:comment 'Standard end time for collection operations in this district (HH:MM format, 24-hour clock).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:geographicBoundaryDescription rdf:type rdf:Property ;
    rdfs:label 'Geographic Boundary Description' ;
    rdfs:comment 'Textual description of the geographic boundaries of the district (e.g., \'Bounded by Main St to the north, Highway 101 to the south\').' ;
    rdfs:domain ind:District ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatCollectionAllowed rdf:type rdf:Property ;
    rdfs:label 'Hazmat Collection Allowed' ;
    rdfs:comment 'Indicates whether hazardous waste collection is permitted in this district. True if allowed, False if not. Subject to RCRA and DOT regulations.' ;
    rdfs:domain ind:District ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:householdCount rdf:type rdf:Property ;
    rdfs:label 'Household Count' ;
    rdfs:comment 'Number of residential households served in this district. Used for route planning and service level analysis.' ;
    rdfs:domain ind:District ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:organicsProgramActive rdf:type rdf:Property ;
    rdfs:label 'Organics Program Active' ;
    rdfs:comment 'Indicates whether an organics/composting collection program is active in this district. True if active, False if not.' ;
    rdfs:domain ind:District ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:populationServed rdf:type rdf:Property ;
    rdfs:label 'Population Served' ;
    rdfs:comment 'Estimated population count served by this collection district. Used for capacity planning and regulatory reporting.' ;
    rdfs:domain ind:District ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recyclingProgramActive rdf:type rdf:Property ;
    rdfs:label 'Recycling Program Active' ;
    rdfs:comment 'Indicates whether a recycling collection program is active in this district. True if active, False if not.' ;
    rdfs:domain ind:District ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:routeCount rdf:type rdf:Property ;
    rdfs:label 'Route Count' ;
    rdfs:comment 'Number of active collection routes operating within this district. Used for resource allocation and performance tracking.' ;
    rdfs:domain ind:District ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceDays rdf:type rdf:Property ;
    rdfs:label 'Service Days' ;
    rdfs:comment 'Days of the week when collection service is provided in this district (e.g., \'Monday, Wednesday, Friday\').' ;
    rdfs:domain ind:District ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:startTime rdf:type rdf:Property ;
    rdfs:label 'Start Time' ;
    rdfs:comment 'Standard start time for collection operations in this district (HH:MM format, 24-hour clock).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:vehicleTypeRequired rdf:type rdf:Property ;
    rdfs:label 'Vehicle Type Required' ;
    rdfs:comment 'Primary type of collection vehicle required for this district. Values: automated_side_loader (ASL), front_end_loader (FEL), rear_end_loader (REL), roll_off, mixed.' ;
    rdfs:domain ind:District ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedDriverId rdf:type rdf:Property ;
    rdfs:label 'Assigned Driver Id' ;
    rdfs:comment 'Reference to the driver assigned to fulfill this on-demand request. Links to workforce management system for labor tracking and performance metrics.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Driver .

ind:assignedVehicleId rdf:type rdf:Property ;
    rdfs:label 'Assigned Vehicle Id' ;
    rdfs:comment 'Reference to the collection vehicle assigned to fulfill this request. Used for fleet utilization tracking and capacity validation.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vehicle .

ind:actualWeightTons rdf:type rdf:Property ;
    rdfs:label 'Actual Weight Tons' ;
    rdfs:comment 'Actual weight of material collected in tons, measured at disposal facility or transfer station. Used for final billing calculation and operational reporting.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cancellationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cancellation Timestamp' ;
    rdfs:comment 'Date and time when the request was cancelled or rejected. Used for SLA tracking and operational metrics.' ;
    rdfs:domain ind:OnDemandRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:customerSignatureRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Signature Required Flag' ;
    rdfs:comment 'Indicates whether customer signature is required to confirm service completion. True for high-value services or contractual requirements.' ;
    rdfs:domain ind:OnDemandRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disposalFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Disposal Fee Amount' ;
    rdfs:comment 'Tipping fee or disposal cost charged for processing the collected material at landfill or transfer station in USD. Weight-based or flat fee depending on waste stream and facility.' ;
    rdfs:domain ind:OnDemandRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:photoRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Photo Required Flag' ;
    rdfs:comment 'Indicates whether photographic documentation is required for this request. True for high-value items, disputed services, or compliance documentation needs.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requestNumber rdf:type rdf:Property ;
    rdfs:label 'Request Number' ;
    rdfs:comment 'Externally visible unique business identifier for the on-demand request, formatted as ODR-NNNNNNNN. Used for customer communication and tracking.' ;
    rdfs:domain ind:OnDemandRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledServiceDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Service Date' ;
    rdfs:comment 'Actual date scheduled for the collection service after route optimization and capacity planning. Confirmed date communicated to customer.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledTimeWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Scheduled Time Window End' ;
    rdfs:comment 'End of the time window when the collection service is scheduled to occur. Defines customer expectation window for service completion.' ;
    rdfs:domain ind:OnDemandRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledTimeWindowStart rdf:type rdf:Property ;
    rdfs:label 'Scheduled Time Window Start' ;
    rdfs:comment 'Beginning of the time window when the collection service is scheduled to occur. Provides customer with expected arrival timeframe.' ;
    rdfs:domain ind:OnDemandRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:serviceDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Service Duration Minutes' ;
    rdfs:comment 'Actual time spent by driver at service location in minutes, from arrival to departure. Used for labor costing, route optimization, and productivity analysis.' ;
    rdfs:domain ind:OnDemandRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaMetFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Met Flag' ;
    rdfs:comment 'Indicates whether the service was completed within the SLA target timeframe. True if completion_timestamp minus created_timestamp is less than or equal to sla_target_hours. Used for performance reporting and customer satisfaction tracking.' ;
    rdfs:domain ind:OnDemandRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceChannel rdf:type rdf:Property ;
    rdfs:label 'Source Channel' ;
    rdfs:comment 'Channel through which the on-demand request was initiated. Customer portal for self-service web, mobile app for customer mobile application, call center for phone requests, email for email submissions, field sales for in-person requests, CRM for internal service team entries.' ;
    rdfs:domain ind:OnDemandRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Amount' ;
    rdfs:comment 'Total sales tax, VAT, or other applicable taxes charged on this on-demand service in USD. Calculated based on service address jurisdiction.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Total Charge Amount' ;
    rdfs:comment 'Total amount charged to customer for this on-demand request in USD, including service charge, disposal fee, additional fees, and taxes. Used for billing and revenue recognition.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:containerPrepWorkOrderId rdf:type rdf:Property ;
    rdfs:label 'Container Prep Work Order Id' ;
    rdfs:comment 'Foreign key linking to maintenance.work_order. Business justification: Rolloff containers require inspection, cleaning, or repair work orders before deployment to customer sites. Linking rolloff_order to the container preparation work order supports container readiness t' ;
    rdfs:domain ind:RolloffOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkOrder .

ind:weightTicketId rdf:type rdf:Property ;
    rdfs:label 'Weight Ticket Id' ;
    rdfs:comment 'Foreign key linking to collection.weight_ticket. Business justification: rolloff_order has a denormalized weight_ticket_number (STRING) attribute that is a textual reference to the weight ticket. Replacing this with a proper FK weight_ticket_id -> weight_ticket.weight_tick' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WeightTicket .

ind:baseRentalCharge rdf:type rdf:Property ;
    rdfs:label 'Base Rental Charge' ;
    rdfs:comment 'Base rental fee in USD for the roll-off container for the authorized rental duration.' ;
    rdfs:domain ind:RolloffOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:containerSizeYards rdf:type rdf:Property ;
    rdfs:label 'Container Size Yards' ;
    rdfs:comment 'Size of the roll-off container in cubic yards. Common sizes: 10, 20, 30, 40 yards.' ;
    rdfs:domain ind:RolloffOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryActualTimestamp rdf:type rdf:Property ;
    rdfs:label 'Delivery Actual Timestamp' ;
    rdfs:comment 'Actual date and time when the roll-off container was delivered to the service address. Captured via driver mobile app or GPS telematics.' ;
    rdfs:domain ind:RolloffOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deliveryScheduledDate rdf:type rdf:Property ;
    rdfs:label 'Delivery Scheduled Date' ;
    rdfs:comment 'Scheduled date for initial delivery of the roll-off container to the service address.' ;
    rdfs:domain ind:RolloffOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disposalCharge rdf:type rdf:Property ;
    rdfs:label 'Disposal Charge' ;
    rdfs:comment 'Charge in USD for disposal of the waste at the landfill or transfer station, based on actual weight and tipping fee schedule.' ;
    rdfs:domain ind:RolloffOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalFee rdf:type rdf:Property ;
    rdfs:label 'Environmental Fee' ;
    rdfs:comment 'Regulatory environmental fee in USD assessed per order or per ton, as required by state or local environmental agencies.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderNumber rdf:type rdf:Property ;
    rdfs:label 'Order Number' ;
    rdfs:comment 'Externally-visible business identifier for the roll-off order. Used on customer communications, work orders, and invoices.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderPlacedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Order Placed Timestamp' ;
    rdfs:comment 'Date and time when the customer placed the roll-off order. Principal business event timestamp for this transaction.' ;
    rdfs:domain ind:RolloffOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:orderStatus rdf:type rdf:Property ;
    rdfs:label 'Order Status' ;
    rdfs:comment 'Current lifecycle status of the roll-off order. Tracks progression from order placement through delivery, service, pull, and invoicing. [ENUM-REF-CANDIDATE: pending|scheduled|delivered|on_site|swapped|pulled|invoiced|cancelled — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overageWeightTons rdf:type rdf:Property ;
    rdfs:label 'Overage Weight Tons' ;
    rdfs:comment 'Weight in tons exceeding the authorized weight limit. Used to calculate overage charges.' ;
    rdfs:domain ind:RolloffOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pullActualTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pull Actual Timestamp' ;
    rdfs:comment 'Actual date and time when the roll-off container was pulled from the service address. Captured via driver mobile app or GPS telematics.' ;
    rdfs:domain ind:RolloffOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pullScheduledDate rdf:type rdf:Property ;
    rdfs:label 'Pull Scheduled Date' ;
    rdfs:comment 'Scheduled date for final pull (removal) of the roll-off container from the service address.' ;
    rdfs:domain ind:RolloffOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rentalDurationDays rdf:type rdf:Property ;
    rdfs:label 'Rental Duration Days' ;
    rdfs:comment 'Number of days the roll-off container is authorized to remain on-site before additional rental charges apply.' ;
    rdfs:domain ind:RolloffOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:swapCount rdf:type rdf:Property ;
    rdfs:label 'Swap Count' ;
    rdfs:comment 'Number of times the roll-off container was swapped (full container pulled and empty container delivered) during the rental period.' ;
    rdfs:domain ind:RolloffOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:weightLimitTons rdf:type rdf:Property ;
    rdfs:label 'Weight Limit Tons' ;
    rdfs:comment 'Maximum authorized weight in tons for the roll-off container. Overage charges apply if exceeded.' ;
    rdfs:domain ind:RolloffOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disposalSiteId rdf:type rdf:Property ;
    rdfs:label 'Disposal Site Id' ;
    rdfs:comment 'Foreign key linking to landfill.site. Business justification: Weight tickets from collection routes disposing at landfills require landfill site reference for disposal tracking, regulatory reporting, tipping fee reconciliation, and landfill capacity management. ' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Site .

ind:outboundHaulId rdf:type rdf:Property ;
    rdfs:label 'Outbound Haul Id' ;
    rdfs:comment 'Foreign key linking to collection.outbound_haul. Business justification: A weight_ticket is generated when a collection vehicle or outbound haul vehicle is weighed at a disposal facility. When an outbound_haul arrives at a destination facility, a weight_ticket is generated' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OutboundHaul .

ind:billingDate rdf:type rdf:Property ;
    rdfs:label 'Billing Date' ;
    rdfs:comment 'Date when this weight ticket was included in customer billing. Used for revenue recognition and accounts receivable aging.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:grossWeightLbs rdf:type rdf:Property ;
    rdfs:label 'Gross Weight Lbs' ;
    rdfs:comment 'Total weight of the loaded vehicle in pounds, measured at weigh-in. Includes vehicle tare weight plus waste payload.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:loadType rdf:type rdf:Property ;
    rdfs:label 'Load Type' ;
    rdfs:comment 'Classification of the load delivery. Full Route = completed collection route, Partial Route = mid-route dump, Direct Haul = single-customer large load, Emergency = unscheduled service, Special Waste = pre-approved non-standard material, Return Trip = second trip from same route.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netWeightLbs rdf:type rdf:Property ;
    rdfs:label 'Net Weight Lbs' ;
    rdfs:comment 'Calculated net weight of waste payload in pounds (gross weight minus tare weight). Used for tonnage reporting and billing.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originType rdf:type rdf:Property ;
    rdfs:label 'Origin Type' ;
    rdfs:comment 'Source classification of the waste collected. Used for waste characterization studies and regulatory reporting.' ;
    rdfs:domain ind:WeightTicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionFlag rdf:type rdf:Property ;
    rdfs:label 'Rejection Flag' ;
    rdfs:comment 'Indicates whether the load was rejected and not accepted for disposal. True = rejected, False = accepted. Rejected loads must be redirected to appropriate facility.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tareWeightLbs rdf:type rdf:Property ;
    rdfs:label 'Tare Weight Lbs' ;
    rdfs:comment 'Weight of the empty vehicle in pounds, measured at weigh-out. Subtracted from gross weight to determine net waste tonnage.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ticketStatus rdf:type rdf:Property ;
    rdfs:label 'Ticket Status' ;
    rdfs:comment 'Current lifecycle status of the weight ticket. Draft = initial capture, Validated = scale operator approved, Billed = sent to customer billing, Disputed = under review, Voided = cancelled, Corrected = amended after issuance.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationFlag rdf:type rdf:Property ;
    rdfs:label 'Validation Flag' ;
    rdfs:comment 'Indicates whether the weight ticket has passed automated validation checks (weight reasonableness, vehicle capacity limits, duplicate detection). True = passed, False = requires manual review.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:validationNotes rdf:type rdf:Property ;
    rdfs:label 'Validation Notes' ;
    rdfs:comment 'Free-text notes documenting validation issues, manual overrides, or special circumstances related to this weight ticket.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:generatorFacilityId rdf:type rdf:Property ;
    rdfs:label 'Generator Facility Id' ;
    rdfs:comment 'Foreign key linking to asset.facility. Business justification: Generator sites ARE facilities in waste management operations. Links generator regulatory records to facility asset master for permit tracking, inspection scheduling, facility utilization reporting, a' ;
    rdfs:domain ind:HazardousWasteGenerator ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:accumulationStartDateLimitDays rdf:type rdf:Property ;
    rdfs:label 'Accumulation Start Date Limit Days' ;
    rdfs:comment 'Maximum number of days hazardous waste may be accumulated on-site before shipment, based on generator category. LQG: 90 days; SQG: 180 days (or 270 if >200 miles from TSDF); VSQG: no time limit but quantity limits apply.' ;
    rdfs:domain ind:HazardousWasteGenerator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:biennialReportRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Biennial Report Required Flag' ;
    rdfs:comment 'Indicates whether the generator is required to submit biennial hazardous waste reports to EPA. Required for LQGs and some SQGs.' ;
    rdfs:domain ind:HazardousWasteGenerator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contingencyPlanLastUpdatedDate rdf:type rdf:Property ;
    rdfs:label 'Contingency Plan Last Updated Date' ;
    rdfs:comment 'Date when the contingency plan was last reviewed and updated. Plans must be reviewed annually and updated as needed.' ;
    rdfs:domain ind:HazardousWasteGenerator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contingencyPlanReference rdf:type rdf:Property ;
    rdfs:label 'Contingency Plan Reference' ;
    rdfs:comment 'Reference identifier or document location for the site\'s hazardous waste contingency plan. Required for LQGs and SQGs.' ;
    rdfs:domain ind:HazardousWasteGenerator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyContactName rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Name' ;
    rdfs:comment 'Name of the designated emergency response contact for incidents involving hazardous waste at this site.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyContactPhone rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Phone' ;
    rdfs:comment '24-hour emergency phone number for hazardous waste incidents. Must be staffed or monitored continuously.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enforcementActionCount rdf:type rdf:Property ;
    rdfs:label 'Enforcement Action Count' ;
    rdfs:comment 'Total number of formal enforcement actions (notices of violation, administrative orders, civil penalties) issued against this generator.' ;
    rdfs:domain ind:HazardousWasteGenerator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:federalFacilityFlag rdf:type rdf:Property ;
    rdfs:label 'Federal Facility Flag' ;
    rdfs:comment 'Indicates whether the generator is a federal government facility (e.g., military base, federal laboratory). Federal facilities have specific RCRA compliance requirements.' ;
    rdfs:domain ind:HazardousWasteGenerator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:generatorCategory rdf:type rdf:Property ;
    rdfs:label 'Generator Category' ;
    rdfs:comment 'EPA classification of generator based on monthly waste generation volume. LQG (Large Quantity Generator): ≥1,000 kg/month; SQG (Small Quantity Generator): 100-1,000 kg/month; VSQG (Very Small Quantity Generator): <100 kg/month; CESQG (Conditionally Exempt Small Quantity Generator): legacy term for VSQG.' ;
    rdfs:domain ind:HazardousWasteGenerator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:generatorLegalName rdf:type rdf:Property ;
    rdfs:label 'Generator Legal Name' ;
    rdfs:comment 'The official legal name of the hazardous waste generating entity as registered with EPA and state authorities.' ;
    rdfs:domain ind:HazardousWasteGenerator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:generatorStatus rdf:type rdf:Property ;
    rdfs:label 'Generator Status' ;
    rdfs:comment 'Current operational and regulatory status of the hazardous waste generator registration.' ;
    rdfs:domain ind:Hazmat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initialNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Initial Notification Date' ;
    rdfs:comment 'Date when the generator first notified EPA of hazardous waste generation activities and received EPA ID number.' ;
    rdfs:domain ind:HazardousWasteGenerator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inspectionFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Inspection Frequency Months' ;
    rdfs:comment 'Expected frequency of regulatory inspections by EPA or state authorities, in months. Varies by generator category and compliance history.' ;
    rdfs:domain ind:HazardousWasteGenerator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastBiennialReportYear rdf:type rdf:Property ;
    rdfs:label 'Last Biennial Report Year' ;
    rdfs:comment 'The reporting year of the most recently submitted biennial hazardous waste report (e.g., 2022 for the 2021-2022 reporting period).' ;
    rdfs:domain ind:HazardousWasteGenerator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastNotificationUpdateDate rdf:type rdf:Property ;
    rdfs:label 'Last Notification Update Date' ;
    rdfs:comment 'Date of the most recent update to the generator\'s EPA notification information. Generators must notify EPA of changes within 30 days.' ;
    rdfs:domain ind:HazardousWasteGenerator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mailingAddress rdf:type rdf:Property ;
    rdfs:label 'Mailing Address' ;
    rdfs:comment 'Mailing address for correspondence and regulatory notifications if different from site address.' ;
    rdfs:domain ind:HazardousWasteGenerator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Email' ;
    rdfs:comment 'Email address of the primary contact for electronic manifest notifications and regulatory correspondence.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Phone' ;
    rdfs:comment 'Primary phone number for the generator contact. Used for operational coordination and emergency response.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactTitle rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Title' ;
    rdfs:comment 'Job title or role of the primary contact person (e.g., Environmental Manager, EHS Coordinator).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Record Source System' ;
    rdfs:comment 'Name of the source system from which this generator record originated (e.g., Enviance EHS, SAP EHS, EPA RCRAInfo).' ;
    rdfs:domain ind:HazardousWasteGenerator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sicCode rdf:type rdf:Property ;
    rdfs:label 'Sic Code' ;
    rdfs:comment 'Four-digit SIC code for the generator\'s primary business activity. Legacy classification system still used in some regulatory contexts.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteCity rdf:type rdf:Property ;
    rdfs:label 'Site City' ;
    rdfs:comment 'City where the hazardous waste generation site is located.' ;
    rdfs:domain ind:Hazmat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteCounty rdf:type rdf:Property ;
    rdfs:label 'Site County' ;
    rdfs:comment 'County where the generator site is located. Required for local enforcement agency (LEA) coordination.' ;
    rdfs:domain ind:Hazmat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteState rdf:type rdf:Property ;
    rdfs:label 'Site State' ;
    rdfs:comment 'Two-letter state code for the generator site location. Used for jurisdictional compliance determination.' ;
    rdfs:domain ind:HazardousWasteGenerator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteStreetAddress rdf:type rdf:Property ;
    rdfs:label 'Site Street Address' ;
    rdfs:comment 'Physical street address of the hazardous waste generation site. Required for manifest preparation and emergency response.' ;
    rdfs:domain ind:HazardousWasteGenerator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteZipCode rdf:type rdf:Property ;
    rdfs:label 'Site Zip Code' ;
    rdfs:comment 'ZIP code for the generator site. Supports 5-digit or 9-digit (ZIP+4) format.' ;
    rdfs:domain ind:HazardousWasteGenerator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateGeneratorCode rdf:type rdf:Property ;
    rdfs:label 'State Generator Code' ;
    rdfs:comment 'State-specific generator identification number if different from EPA ID. Some states maintain parallel registration systems.' ;
    rdfs:domain ind:HazardousWasteGenerator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteMinimizationPlanFlag rdf:type rdf:Property ;
    rdfs:label 'Waste Minimization Plan Flag' ;
    rdfs:comment 'Indicates whether the generator has a documented waste minimization plan in place. Required for LQGs under some state programs.' ;
    rdfs:domain ind:HazardousWasteGenerator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvedTsdfFacilityId rdf:type rdf:Property ;
    rdfs:label 'Approved Tsdf Facility Id' ;
    rdfs:comment 'Reference to the Treatment, Storage, and Disposal Facility authorized to accept this waste profile. Links to facility master data.' ;
    rdfs:domain ind:WasteProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TsdfFacility .

ind:annualQuantityEstimateTons rdf:type rdf:Property ;
    rdfs:label 'Annual Quantity Estimate Tons' ;
    rdfs:comment 'Estimated annual quantity of waste expected to be generated under this profile, measured in tons. Used for capacity planning and permit compliance.' ;
    rdfs:domain ind:WasteProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:constituentsOfConcern rdf:type rdf:Property ;
    rdfs:label 'Constituents Of Concern' ;
    rdfs:comment 'List of specific chemical constituents or contaminants present in the waste that drive its hazardous classification (e.g., \'Lead, Chromium, Toluene\').' ;
    rdfs:domain ind:WasteProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerTypeApproved rdf:type rdf:Property ;
    rdfs:label 'Container Type Approved' ;
    rdfs:comment 'Approved container types for this waste stream (e.g., \'55-gallon steel drum\', \'Bulk tanker\', \'Fiber drum\', \'Supersack\'). Multiple types may be listed.' ;
    rdfs:domain ind:WasteProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dotHazardClass rdf:type rdf:Property ;
    rdfs:label 'Dot Hazard Class' ;
    rdfs:comment 'Department of Transportation hazard classification for transportation purposes (e.g., Class 3 Flammable Liquid, Class 6.1 Toxic, Class 8 Corrosive, Class 9 Miscellaneous).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyResponseProcedure rdf:type rdf:Property ;
    rdfs:label 'Emergency Response Procedure' ;
    rdfs:comment 'Summary of emergency response procedures in case of spill, release, or exposure incident involving this waste material.' ;
    rdfs:domain ind:WasteProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flashPointCelsius rdf:type rdf:Property ;
    rdfs:label 'Flash Point Celsius' ;
    rdfs:comment 'Lowest temperature at which vapors ignite when exposed to an ignition source. Used to determine ignitability characteristic (D001: flash point <60°C).' ;
    rdfs:domain ind:WasteProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isCorrosive rdf:type rdf:Property ;
    rdfs:label 'Is Corrosive' ;
    rdfs:comment 'Indicates whether the waste exhibits the characteristic of corrosivity per EPA D002 criteria (aqueous with pH ≤2 or ≥12.5, or liquid that corrodes steel at rate >6.35mm per year at 55°C).' ;
    rdfs:domain ind:WasteProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isIgnitable rdf:type rdf:Property ;
    rdfs:label 'Is Ignitable' ;
    rdfs:comment 'Indicates whether the waste exhibits the characteristic of ignitability per EPA D001 criteria (liquid with flash point <60°C, non-liquid capable of spontaneous combustion, ignitable compressed gas, or oxidizer).' ;
    rdfs:domain ind:WasteProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReactive rdf:type rdf:Property ;
    rdfs:label 'Is Reactive' ;
    rdfs:comment 'Indicates whether the waste exhibits the characteristic of reactivity per EPA D003 criteria (unstable, reacts violently with water, generates toxic gases, contains cyanide or sulfide, or capable of detonation).' ;
    rdfs:domain ind:WasteProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isToxic rdf:type rdf:Property ;
    rdfs:label 'Is Toxic' ;
    rdfs:comment 'Indicates whether the waste exhibits the toxicity characteristic per TCLP testing, with contaminant concentrations exceeding regulatory thresholds (D004-D043).' ;
    rdfs:domain ind:WasteProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:landDisposalRestricted rdf:type rdf:Property ;
    rdfs:label 'Land Disposal Restricted' ;
    rdfs:comment 'Indicates whether the waste is subject to Land Disposal Restrictions requiring treatment to meet specific standards before landfill disposal.' ;
    rdfs:domain ind:WasteProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Review Date' ;
    rdfs:comment 'Date of the most recent periodic review of this waste profile. Profiles should be reviewed annually or when waste characteristics change.' ;
    rdfs:domain ind:Hazmat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ldrTreatmentStandards rdf:type rdf:Property ;
    rdfs:label 'Ldr Treatment Standards' ;
    rdfs:comment 'Specific treatment standards that must be met before land disposal, including concentration limits for hazardous constituents or required treatment technologies.' ;
    rdfs:domain ind:WasteProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packingGroup rdf:type rdf:Property ;
    rdfs:label 'Packing Group' ;
    rdfs:comment 'DOT packing group indicating degree of danger: I (great danger), II (medium danger), III (minor danger). Used for transportation classification.' ;
    rdfs:domain ind:Hazmat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phValue rdf:type rdf:Property ;
    rdfs:label 'Ph Value' ;
    rdfs:comment 'Measured pH level of the waste material. Critical for determining corrosivity characteristic (D002: pH ≤2 or ≥12.5).' ;
    rdfs:domain ind:Hazmat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:physicalState rdf:type rdf:Property ;
    rdfs:label 'Physical State' ;
    rdfs:comment 'Physical form of the waste material at ambient temperature and pressure.' ;
    rdfs:domain ind:Hazmat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processGeneratingWaste rdf:type rdf:Property ;
    rdfs:label 'Process Generating Waste' ;
    rdfs:comment 'Description of the industrial or commercial process that generates this waste stream (e.g., \'Metal degreasing operation\', \'Paint booth cleaning\').' ;
    rdfs:domain ind:WasteProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileName rdf:type rdf:Property ;
    rdfs:label 'Profile Name' ;
    rdfs:comment 'Descriptive name of the waste stream or material being profiled (e.g., \'Industrial Solvent Waste\', \'Lead-Contaminated Soil\').' ;
    rdfs:domain ind:WasteProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileNumber rdf:type rdf:Property ;
    rdfs:label 'Profile Number' ;
    rdfs:comment 'Business identifier for the waste profile, used for external reference and tracking. Typically formatted as WP- followed by numeric sequence.' ;
    rdfs:domain ind:WasteProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:properShippingName rdf:type rdf:Property ;
    rdfs:label 'Proper Shipping Name' ;
    rdfs:comment 'DOT-approved proper shipping name for the hazardous material as it must appear on shipping papers and manifests (e.g., \'Waste Flammable Liquid, N.O.S.\').' ;
    rdfs:domain ind:Hazmat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialHandlingInstructions rdf:type rdf:Property ;
    rdfs:label 'Special Handling Instructions' ;
    rdfs:comment 'Any special handling, storage, or safety requirements for this waste stream (e.g., \'Keep refrigerated\', \'Incompatible with oxidizers\', \'Requires secondary containment\').' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tclpResultsSummary rdf:type rdf:Property ;
    rdfs:label 'Tclp Results Summary' ;
    rdfs:comment 'Summary of TCLP test results listing detected contaminants and their concentrations in mg/L. Used to determine D-code assignments for toxic characteristics.' ;
    rdfs:domain ind:WasteProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatmentMethodRequired rdf:type rdf:Property ;
    rdfs:label 'Treatment Method Required' ;
    rdfs:comment 'Approved treatment or disposal method for this waste stream (e.g., \'Incineration\', \'Stabilization\', \'Landfill Disposal\', \'Fuel Blending\').' ;
    rdfs:domain ind:WasteProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unNaNumber rdf:type rdf:Property ;
    rdfs:label 'Un Na Number' ;
    rdfs:comment 'Four-digit United Nations or North America identification number assigned to the hazardous material for transportation purposes (e.g., UN1203, NA1993).' ;
    rdfs:domain ind:Hazmat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:generatorPermitId rdf:type rdf:Property ;
    rdfs:label 'Generator Permit Id' ;
    rdfs:comment 'Foreign key linking to compliance.permit. Business justification: Manifests document shipments under generator\'s permit authority. Required for regulatory traceability, compliance audits, and verifying generator operated within permit conditions during shipment peri' ;
    rdfs:domain ind:Hazmat ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Permit .

ind:manifestAlternateFacilityEpaEpaIdRegistrationId rdf:type rdf:Property ;
    rdfs:label 'Manifest Alternate Facility Epa Epa Id Registration Id' ;
    rdfs:comment 'EPA ID of an alternate TSDF facility designated by the generator if the primary TSDF cannot accept the waste.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EpaIdRegistration .

ind:manifestEpaIdRegistrationId rdf:type rdf:Property ;
    rdfs:label 'Manifest Epa Id Registration Id' ;
    rdfs:comment 'EPA ID of the first transporter in the chain of custody. Required for all hazardous waste shipments.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EpaIdRegistration .

ind:manifestGeneratorEpaIdRegistrationId rdf:type rdf:Property ;
    rdfs:label 'Manifest Generator Epa Id Registration Id' ;
    rdfs:comment 'Foreign key linking to hazmat.epa_id_registration. Business justification: Manifest tracks generator EPA ID as a string. This should be normalized to FK to epa_id_registration. Labeled FK (generator_epa_id_registration_id) distinguishes this from other EPA ID references on m' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EpaIdRegistration .

ind:manifestTransporter2EpaEpaIdRegistrationId rdf:type rdf:Property ;
    rdfs:label 'Manifest Transporter 2 Epa Epa Id Registration Id' ;
    rdfs:comment 'EPA ID of the second transporter if multiple transporters are involved in the shipment chain.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EpaIdRegistration .

ind:manifestTsdfEpaEpaIdRegistrationId rdf:type rdf:Property ;
    rdfs:label 'Manifest Tsdf Epa Epa Id Registration Id' ;
    rdfs:comment 'EPA ID of the designated TSDF facility that will receive and process the hazardous waste.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EpaIdRegistration .

ind:primaryWasteCodeId rdf:type rdf:Property ;
    rdfs:label 'Primary Waste Code Id' ;
    rdfs:comment 'Foreign key linking to hazmat.waste_code. Business justification: Manifest has epa_waste_codes (string, comma-separated) but no FK to waste_code reference table. Adding FK for primary waste code provides standardized waste code lookup. Keep epa_waste_codes string fo' ;
    rdfs:domain ind:Hazmat ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WasteCode .

ind:transporter1TransporterRegistrationId rdf:type rdf:Property ;
    rdfs:label 'Transporter 1 Transporter Registration Id' ;
    rdfs:comment 'Foreign key linking to hazmat.transporter_registration. Business justification: The manifest captures transporter_1_name as a string but has no FK to transporter_registration for the primary transporter. The EPA manifest form requires the first transporter\'s EPA ID and name. Norm' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TransporterRegistration .

ind:discrepancyDescription rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Description' ;
    rdfs:comment 'Detailed description of any discrepancies noted by the TSDF, including quantity variances, container damage, or waste type mismatches.' ;
    rdfs:domain ind:Hazmat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discrepancyIndication rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Indication' ;
    rdfs:comment 'Boolean flag indicating whether the TSDF identified any discrepancies between the manifest and the actual shipment received (quantity, type, condition).' ;
    rdfs:domain ind:Hazmat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dotIdNumber rdf:type rdf:Property ;
    rdfs:label 'Dot Id Number' ;
    rdfs:comment 'Four-digit UN or NA identification number assigned to the hazardous material for transportation (e.g., UN1203 for gasoline).' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dotPackingGroup rdf:type rdf:Property ;
    rdfs:label 'Dot Packing Group' ;
    rdfs:comment 'DOT packing group indicating degree of danger: I=Great Danger, II=Medium Danger, III=Minor Danger.' ;
    rdfs:domain ind:Hazmat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dotShippingName rdf:type rdf:Property ;
    rdfs:label 'Dot Shipping Name' ;
    rdfs:comment 'DOT-required proper shipping name from the Hazardous Materials Table (49 CFR 172.101) describing the waste for transportation purposes.' ;
    rdfs:domain ind:Hazmat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epaWasteCodes rdf:type rdf:Property ;
    rdfs:label 'Epa Waste Codes' ;
    rdfs:comment 'Comma-separated list of EPA hazardous waste codes (D, F, K, P, U series) identifying the specific waste characteristics or sources. Example: D001,F005,D008.' ;
    rdfs:domain ind:Hazmat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:generatorCity rdf:type rdf:Property ;
    rdfs:label 'Generator City' ;
    rdfs:comment 'City where the generator facility is located.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:generatorContactName rdf:type rdf:Property ;
    rdfs:label 'Generator Contact Name' ;
    rdfs:comment 'Name of the authorized representative at the generator facility responsible for the manifest.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:generatorContactPhone rdf:type rdf:Property ;
    rdfs:label 'Generator Contact Phone' ;
    rdfs:comment 'Primary phone number for the generator facility contact person.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:generatorEmergencyPhone rdf:type rdf:Property ;
    rdfs:label 'Generator Emergency Phone' ;
    rdfs:comment '24-hour emergency response phone number for incidents involving this waste shipment (e.g., CHEMTREC, facility emergency line).' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:generatorName rdf:type rdf:Property ;
    rdfs:label 'Generator Name' ;
    rdfs:comment 'Legal name of the hazardous waste generator facility originating the waste shipment.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:generatorSignatureDate rdf:type rdf:Property ;
    rdfs:label 'Generator Signature Date' ;
    rdfs:comment 'Date the generator authorized representative signed the manifest certifying the waste information is accurate.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:generatorSiteAddress rdf:type rdf:Property ;
    rdfs:label 'Generator Site Address' ;
    rdfs:comment 'Physical street address of the generator facility where the hazardous waste was produced.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:generatorState rdf:type rdf:Property ;
    rdfs:label 'Generator State' ;
    rdfs:comment 'Two-letter US state code for the generator facility location.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:generatorZipCode rdf:type rdf:Property ;
    rdfs:label 'Generator Zip Code' ;
    rdfs:comment 'US postal ZIP code for the generator facility (5-digit or ZIP+4 format).' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:importIndication rdf:type rdf:Property ;
    rdfs:label 'Import Indication' ;
    rdfs:comment 'Boolean flag indicating whether this manifest documents an international import of hazardous waste into the United States.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:importPortOfEntry rdf:type rdf:Property ;
    rdfs:label 'Import Port Of Entry' ;
    rdfs:comment 'US port of entry location for international hazardous waste imports.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manifestStatus rdf:type rdf:Property ;
    rdfs:label 'Manifest Status' ;
    rdfs:comment 'Current lifecycle status of the manifest document. Tracks progression from draft through final disposition at TSDF. [ENUM-REF-CANDIDATE: draft|in_transit|received_by_tsdf|completed|corrected|rejected|voided — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manifestType rdf:type rdf:Property ;
    rdfs:label 'Manifest Type' ;
    rdfs:comment 'Format type of the manifest submission: paper (traditional hard copy), electronic (e-Manifest via RCRAInfo), or hybrid (combination).' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityUnit rdf:type rdf:Property ;
    rdfs:label 'Quantity Unit' ;
    rdfs:comment 'Unit of measure for total waste quantity. EPA codes: K=Kilograms, P=Pounds, T=Tons (2000 lbs), G=Gallons, L=Liters, M=Metric Tons, N=Cubic Meters, Y=Cubic Yards. [ENUM-REF-CANDIDATE: K|P|T|G|L|M|N|Y — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Hazmat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivedDate rdf:type rdf:Property ;
    rdfs:label 'Received Date' ;
    rdfs:comment 'Date the TSDF facility received and accepted the hazardous waste shipment. Used to calculate transit time and verify timely delivery.' ;
    rdfs:domain ind:Hazmat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rejectionIndication rdf:type rdf:Property ;
    rdfs:label 'Rejection Indication' ;
    rdfs:comment 'Boolean flag indicating whether the TSDF rejected all or part of the waste shipment.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:residueIndication rdf:type rdf:Property ;
    rdfs:label 'Residue Indication' ;
    rdfs:comment 'Boolean flag indicating whether the containers being shipped contain only residue (less than 3% by weight remaining after emptying).' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalQuantity rdf:type rdf:Property ;
    rdfs:label 'Total Quantity' ;
    rdfs:comment 'Total quantity of hazardous waste on this manifest across all waste streams and containers.' ;
    rdfs:domain ind:Hazmat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trackingNumber rdf:type rdf:Property ;
    rdfs:label 'Tracking Number' ;
    rdfs:comment 'EPA-issued 12-character unique tracking number for the Uniform Hazardous Waste Manifest (9 digits + 3 letter suffix). Required for cradle-to-grave tracking under RCRA Subtitle C.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transporter2Name rdf:type rdf:Property ;
    rdfs:label 'Transporter 2 Name' ;
    rdfs:comment 'Legal name of the second transporter company if applicable.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transporterSignatureDate rdf:type rdf:Property ;
    rdfs:label 'Transporter Signature Date' ;
    rdfs:comment 'Date the transporter signed the manifest acknowledging receipt of the waste shipment from the generator.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tsdfSignatureDate rdf:type rdf:Property ;
    rdfs:label 'Tsdf Signature Date' ;
    rdfs:comment 'Date the TSDF authorized representative signed the manifest certifying receipt of the waste shipment.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:manifestLineId rdf:type rdf:Property ;
    rdfs:label 'Manifest Line Id' ;
    rdfs:comment 'Unique identifier for the manifest line item. Primary key for the manifest line entity.' ;
    rdfs:domain ind:Hazmat ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ManifestLine .

ind:discrepancyComments rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Comments' ;
    rdfs:comment 'Detailed explanation of any discrepancy between the manifest description and the waste received. Required when discrepancy_indication is not none.' ;
    rdfs:domain ind:ManifestLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dotProperShippingName rdf:type rdf:Property ;
    rdfs:label 'Dot Proper Shipping Name' ;
    rdfs:comment 'Official DOT proper shipping name from the Hazardous Materials Table. Must be used on shipping papers and placards.' ;
    rdfs:domain ind:ManifestLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flashPointFahrenheit rdf:type rdf:Property ;
    rdfs:label 'Flash Point Fahrenheit' ;
    rdfs:comment 'Flash point temperature in degrees Fahrenheit. Wastes with flash point below 140°F are characteristic hazardous wastes (D001) and DOT Class 3 flammable liquids.' ;
    rdfs:domain ind:ManifestLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:generatorComments rdf:type rdf:Property ;
    rdfs:label 'Generator Comments' ;
    rdfs:comment 'Additional comments or notes from the waste generator regarding this waste stream. May include process information, generation date, or other relevant details.' ;
    rdfs:domain ind:ManifestLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managementMethodCode rdf:type rdf:Property ;
    rdfs:label 'Management Method Code' ;
    rdfs:comment 'Code indicating the intended treatment, storage, or disposal method for this waste stream at the designated TSDF facility.' ;
    rdfs:domain ind:ManifestLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marinePollutantFlag rdf:type rdf:Property ;
    rdfs:label 'Marine Pollutant Flag' ;
    rdfs:comment 'Indicates whether the waste is designated as a marine pollutant under DOT regulations. Requires special marking and documentation for water transportation.' ;
    rdfs:domain ind:ManifestLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pcbConcentrationPpm rdf:type rdf:Property ;
    rdfs:label 'Pcb Concentration Ppm' ;
    rdfs:comment 'Concentration of PCBs in parts per million if the waste contains PCBs. Wastes with PCB concentrations of 50 ppm or greater are subject to TSCA PCB regulations.' ;
    rdfs:domain ind:ManifestLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receivedQuantity rdf:type rdf:Property ;
    rdfs:label 'Received Quantity' ;
    rdfs:comment 'Actual quantity received by the designated facility in the specified unit of measure. May differ from total_quantity if discrepancies exist.' ;
    rdfs:domain ind:ManifestLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportableQuantityFlag rdf:type rdf:Property ;
    rdfs:label 'Reportable Quantity Flag' ;
    rdfs:comment 'Indicates whether this waste stream meets or exceeds the CERCLA reportable quantity threshold. If true, the letters RQ must appear on the manifest and shipping papers.' ;
    rdfs:domain ind:ManifestLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:wasteMinimizationCode rdf:type rdf:Property ;
    rdfs:label 'Waste Minimization Code' ;
    rdfs:comment 'Code indicating the waste minimization efforts applied to this waste stream. Required for biennial reporting under RCRA.' ;
    rdfs:domain ind:Hazmat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatContainerId rdf:type rdf:Property ;
    rdfs:label 'Hazmat Container Id' ;
    rdfs:comment 'Unique identifier for the hazardous waste container. Primary key for tracking individual drums, totes, IBCs, lab packs, and roll-offs throughout their lifecycle from generation through disposal.' ;
    rdfs:domain ind:Hazmat ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HazmatContainer .

ind:primaryHazmatEpaIdRegistrationId rdf:type rdf:Property ;
    rdfs:label 'Primary Hazmat Epa Id Registration Id' ;
    rdfs:comment 'EPA ID number of the licensed hazardous waste transporter currently responsible for this container during shipment. Required for manifest documentation.' ;
    rdfs:domain ind:HazmatContainer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EpaIdRegistration .

ind:serviceOrderId rdf:type rdf:Property ;
    rdfs:label 'Service Order Id' ;
    rdfs:comment 'Foreign key linking to hazmat.hazmat_service_order. Business justification: Containers are collected via hazmat service orders. This links the container to the service order that picked it up from the generator site. One container is collected in one service order event. This' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceOrder .

ind:storageFacilityId rdf:type rdf:Property ;
    rdfs:label 'Storage Facility Id' ;
    rdfs:comment 'Reference to the physical facility or site where the container is currently stored. Links to facility EPA ID number and permit information.' ;
    rdfs:domain ind:HazmatContainer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:tertiaryHazmatTsdfEpaEpaIdRegistrationId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Hazmat Tsdf Epa Epa Id Registration Id' ;
    rdfs:comment 'EPA ID number of the permitted TSDF facility designated to receive and dispose of this container. Must be listed on the hazardous waste manifest.' ;
    rdfs:domain ind:HazmatContainer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EpaIdRegistration .

ind:accumulationDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Accumulation Deadline Date' ;
    rdfs:comment 'Regulatory deadline by which the container must be shipped off-site to avoid RCRA violations. Calculated based on generator status and accumulation start date.' ;
    rdfs:domain ind:HazmatContainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accumulationStartDate rdf:type rdf:Property ;
    rdfs:label 'Accumulation Start Date' ;
    rdfs:comment 'Date when hazardous waste was first placed into this container. Triggers regulatory accumulation time limits (90-day rule for large quantity generators, 180/270-day for small quantity generators).' ;
    rdfs:domain ind:HazmatContainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:capacityGallons rdf:type rdf:Property ;
    rdfs:label 'Capacity Gallons' ;
    rdfs:comment 'Maximum rated capacity of the container in U.S. gallons. Used to calculate fill levels, determine accumulation limits, and plan transportation logistics.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chainOfCustodyStatus rdf:type rdf:Property ;
    rdfs:label 'Chain Of Custody Status' ;
    rdfs:comment 'Current custody status in the cradle-to-grave tracking chain. Indicates which party currently has physical possession and legal responsibility for the container.' ;
    rdfs:domain ind:HazmatContainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:condition rdf:type rdf:Property ;
    rdfs:label 'Condition' ;
    rdfs:comment 'Assessment of the physical integrity and condition of the container. Critical for safety, regulatory compliance, and determining if container requires overpacking or replacement.' ;
    rdfs:domain ind:HazmatContainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerStatus rdf:type rdf:Property ;
    rdfs:label 'Container Status' ;
    rdfs:comment 'Current state of the container in its lifecycle from deployment through final disposal. Drives regulatory compliance timelines (e.g., 90-day accumulation limits) and operational workflows.' ;
    rdfs:domain ind:HazmatContainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dotUnNumber rdf:type rdf:Property ;
    rdfs:label 'Dot Un Number' ;
    rdfs:comment 'Four-digit UN identification number assigned to the hazardous material for international transportation (e.g., UN1203 for gasoline). Required on shipping papers and labels.' ;
    rdfs:domain ind:HazmatContainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fillLevelPercent rdf:type rdf:Property ;
    rdfs:label 'Fill Level Percent' ;
    rdfs:comment 'Current fill level of the container as a percentage of total capacity. Used to determine when container is full and ready for pickup, and to comply with DOT fill requirements.' ;
    rdfs:domain ind:HazmatContainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:identificationNumber rdf:type rdf:Property ;
    rdfs:label 'Identification Number' ;
    rdfs:comment 'External business identifier for the container, typically a barcode or RFID tag number used for scanning and tracking in the field. May be printed on container label.' ;
    rdfs:domain ind:HazmatContainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelAffixedDate rdf:type rdf:Property ;
    rdfs:label 'Label Affixed Date' ;
    rdfs:comment 'Date when the hazardous waste label was affixed to the container. RCRA requires containers to be labeled upon start of accumulation with waste identity and accumulation start date.' ;
    rdfs:domain ind:HazmatContainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:materialOfConstruction rdf:type rdf:Property ;
    rdfs:label 'Material Of Construction' ;
    rdfs:comment 'Primary material used in container construction. Must be compatible with waste characteristics to prevent corrosion, leakage, or chemical reaction.' ;
    rdfs:domain ind:HazmatContainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netWasteWeightLbs rdf:type rdf:Property ;
    rdfs:label 'Net Waste Weight Lbs' ;
    rdfs:comment 'Calculated weight of waste contents only (gross weight minus tare weight) in pounds. Used for billing, regulatory reporting, and disposal facility acceptance.' ;
    rdfs:domain ind:HazmatContainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unPerformanceRating rdf:type rdf:Property ;
    rdfs:label 'Un Performance Rating' ;
    rdfs:comment 'UN packaging specification code indicating the container has been tested and certified for transporting hazardous materials. Format example: UN1A2/X150/S for a steel drum.' ;
    rdfs:domain ind:HazmatContainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acceptsBulkWaste rdf:type rdf:Property ;
    rdfs:label 'Accepts Bulk Waste' ;
    rdfs:comment 'Boolean flag indicating whether the facility is equipped and permitted to accept bulk hazardous waste shipments (tanker trucks, rail cars).' ;
    rdfs:domain ind:TsdfFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:acceptsContainerizedWaste rdf:type rdf:Property ;
    rdfs:label 'Accepts Containerized Waste' ;
    rdfs:comment 'Boolean flag indicating whether the facility accepts containerized hazardous waste (drums, totes, boxes).' ;
    rdfs:domain ind:TsdfFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disposalCapacityTons rdf:type rdf:Property ;
    rdfs:label 'Disposal Capacity Tons' ;
    rdfs:comment 'Maximum permitted disposal capacity for hazardous waste at the facility measured in tons. Applicable for landfill and land disposal units.' ;
    rdfs:domain ind:TsdfFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emergencyCoordinatorTitle rdf:type rdf:Property ;
    rdfs:label 'Emergency Coordinator Title' ;
    rdfs:comment 'Job title or position of the designated emergency coordinator at the TSDF facility.' ;
    rdfs:domain ind:TsdfFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyPhoneNumber rdf:type rdf:Property ;
    rdfs:label 'Emergency Phone Number' ;
    rdfs:comment '24-hour emergency contact phone number for the TSDF facility as required by RCRA contingency plans. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:TsdfFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityStatus rdf:type rdf:Property ;
    rdfs:label 'Facility Status' ;
    rdfs:comment 'Current operational status of the TSDF facility indicating whether it is authorized to receive and process hazardous waste.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastInspectionResult rdf:type rdf:Property ;
    rdfs:label 'Last Inspection Result' ;
    rdfs:comment 'Outcome of the most recent regulatory inspection indicating compliance status and any violations found.' ;
    rdfs:domain ind:TsdfFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liabilityInsuranceCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Liability Insurance Certificate Number' ;
    rdfs:comment 'Certificate number for the facility\'s liability insurance coverage for sudden and non-sudden accidental occurrences as required by RCRA.' ;
    rdfs:domain ind:TsdfFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liabilityInsuranceExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Liability Insurance Expiration Date' ;
    rdfs:comment 'Expiration date of the facility\'s current liability insurance policy. Must maintain continuous coverage per RCRA requirements.' ;
    rdfs:domain ind:Hazmat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:manifestApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Manifest Approval Status' ;
    rdfs:comment 'Approval status indicating whether the facility is authorized to be designated as a receiving facility on hazardous waste manifests. Determines if waste can be shipped to this TSDF.' ;
    rdfs:domain ind:TsdfFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permittedWasteCodes rdf:type rdf:Property ;
    rdfs:label 'Permitted Waste Codes' ;
    rdfs:comment 'Comma-separated list of EPA hazardous waste codes (D, F, K, P, U series) that the facility is permitted to accept under its RCRA permit. Determines which waste streams can be sent to this TSDF.' ;
    rdfs:domain ind:Hazmat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatmentMethods rdf:type rdf:Property ;
    rdfs:label 'Treatment Methods' ;
    rdfs:comment 'Comma-separated list of treatment method codes (e.g., incineration, stabilization, neutralization, thermal desorption) that the facility is authorized to perform under its RCRA permit.' ;
    rdfs:domain ind:TsdfFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorRating rdf:type rdf:Property ;
    rdfs:label 'Vendor Rating' ;
    rdfs:comment 'Internal vendor performance rating assigned to the TSDF facility based on compliance history, service quality, and reliability. Used for vendor selection decisions.' ;
    rdfs:domain ind:TsdfFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryWasteEpaIdRegistrationId rdf:type rdf:Property ;
    rdfs:label 'Primary Waste Epa Id Registration Id' ;
    rdfs:comment 'EPA-issued 12-character identification number for the destination TSDF facility. Required for all permitted TSDFs under RCRA.' ;
    rdfs:domain ind:WasteShipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EpaIdRegistration .

ind:tertiaryWasteTransporterEpaEpaIdRegistrationId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Waste Transporter Epa Epa Id Registration Id' ;
    rdfs:comment 'EPA-issued 12-character identification number for the transporter. Required for all hazardous waste transporters under RCRA.' ;
    rdfs:domain ind:WasteShipment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EpaIdRegistration .

ind:actualDepartureTime rdf:type rdf:Property ;
    rdfs:label 'Actual Departure Time' ;
    rdfs:comment 'Actual timestamp when the vehicle departed the generator site with the loaded hazardous waste. Captured via Geotab telematics or driver mobile app.' ;
    rdfs:domain ind:WasteShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualTransitHours rdf:type rdf:Property ;
    rdfs:label 'Actual Transit Hours' ;
    rdfs:comment 'Actual elapsed time in hours from departure to arrival. Calculated from actual_departure_time and actual_arrival_time for performance tracking.' ;
    rdfs:domain ind:WasteShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingWeightLbs rdf:type rdf:Property ;
    rdfs:label 'Billing Weight Lbs' ;
    rdfs:comment 'Weight in pounds used for billing purposes. May differ from total_weight_lbs if minimum billing weight or rounding rules apply.' ;
    rdfs:domain ind:WasteShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chainOfCustodyVerified rdf:type rdf:Property ;
    rdfs:label 'Chain Of Custody Verified' ;
    rdfs:comment 'Indicates whether chain-of-custody documentation has been verified and all required signatures obtained from generator, transporter, and TSDF.' ;
    rdfs:domain ind:WasteShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dotPlacardCodes rdf:type rdf:Property ;
    rdfs:label 'Dot Placard Codes' ;
    rdfs:comment 'Comma-separated list of DOT placard codes required for this shipment (e.g., Class 3 Flammable Liquid, Class 8 Corrosive). Determines vehicle marking requirements.' ;
    rdfs:domain ind:WasteShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dotPlacardRequired rdf:type rdf:Property ;
    rdfs:label 'Dot Placard Required' ;
    rdfs:comment 'Indicates whether DOT hazmat placards are required on the vehicle for this shipment based on waste classification and quantity thresholds.' ;
    rdfs:domain ind:WasteShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:driverCdlNumber rdf:type rdf:Property ;
    rdfs:label 'Driver Cdl Number' ;
    rdfs:comment 'Commercial Driver License number of the driver transporting the hazardous waste. Must include hazmat endorsement for RCRA waste transport.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyResponseGuideNumber rdf:type rdf:Property ;
    rdfs:label 'Emergency Response Guide Number' ;
    rdfs:comment 'Three-digit ERG guide number from the DOT Emergency Response Guidebook. Used by first responders in case of spill or accident during transport.' ;
    rdfs:domain ind:WasteShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedTransitHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Transit Hours' ;
    rdfs:comment 'Estimated travel time in hours from generator site to destination TSDF. Used for route planning and customer communication.' ;
    rdfs:domain ind:WasteShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exceptionReason rdf:type rdf:Property ;
    rdfs:label 'Exception Reason' ;
    rdfs:comment 'Description of any exception or discrepancy encountered during shipment (e.g., rejected load, quantity mismatch, container damage, route deviation).' ;
    rdfs:domain ind:WasteShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionReportedDate rdf:type rdf:Property ;
    rdfs:label 'Exception Reported Date' ;
    rdfs:comment 'Date when a shipment exception or discrepancy was formally reported to the generator and regulatory authorities. Required within 30 days under RCRA.' ;
    rdfs:domain ind:WasteShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastModifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Last Modified By User' ;
    rdfs:comment 'Username or employee ID of the system user who last modified this shipment record. Used for accountability and audit purposes.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeDeviationDetected rdf:type rdf:Property ;
    rdfs:label 'Route Deviation Detected' ;
    rdfs:comment 'Flag indicating whether the vehicle deviated from the planned or approved hazmat route during transport. Triggers compliance review.' ;
    rdfs:domain ind:WasteShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:routeRestrictions rdf:type rdf:Property ;
    rdfs:label 'Route Restrictions' ;
    rdfs:comment 'Special routing restrictions or requirements for this hazardous waste shipment (e.g., avoid tunnels, no residential areas, designated hazmat routes only).' ;
    rdfs:domain ind:WasteShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentNotes rdf:type rdf:Property ;
    rdfs:label 'Shipment Notes' ;
    rdfs:comment 'Free-text field for additional operational notes, driver observations, or special circumstances related to this shipment.' ;
    rdfs:domain ind:WasteShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalWeightLbs rdf:type rdf:Property ;
    rdfs:label 'Total Weight Lbs' ;
    rdfs:comment 'Total weight of hazardous waste in this shipment measured in pounds. Aggregated from all containers included in the shipment.' ;
    rdfs:domain ind:WasteShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vehicleUnitNumber rdf:type rdf:Property ;
    rdfs:label 'Vehicle Unit Number' ;
    rdfs:comment 'Fleet unit number or license plate identifier of the vehicle used for this shipment. Used for tracking and compliance reporting.' ;
    rdfs:domain ind:WasteShipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chainOfCustodyId rdf:type rdf:Property ;
    rdfs:label 'Chain Of Custody Id' ;
    rdfs:comment 'Unique identifier for the chain of custody record. Primary key for immutable cradle-to-grave tracking of hazardous waste container transfers.' ;
    rdfs:domain ind:ChainOfCustody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryChainEpaIdRegistrationId rdf:type rdf:Property ;
    rdfs:label 'Primary Chain Epa Id Registration Id' ;
    rdfs:comment 'EPA identification number of the party accepting custody of the hazardous waste. 12-character format: 2-letter state code + 9 digits.' ;
    rdfs:domain ind:ChainOfCustody ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EpaIdRegistration .

ind:discrepancyIndicator rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Indicator' ;
    rdfs:comment 'Flag indicating whether a discrepancy was noted during this custody transfer (e.g., container count mismatch, quantity variance, damage observed).' ;
    rdfs:domain ind:Hazmat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discrepancyNotes rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Notes' ;
    rdfs:comment 'Detailed notes describing any discrepancy observed during the custody transfer. Required for RCRA exception reporting and CERCLA liability documentation.' ;
    rdfs:domain ind:ChainOfCustody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discrepancyType rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Type' ;
    rdfs:comment 'Classification of the discrepancy noted during custody transfer, if any. Used for exception handling and regulatory reporting.' ;
    rdfs:domain ind:ChainOfCustody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyResponsePhone rdf:type rdf:Property ;
    rdfs:label 'Emergency Response Phone' ;
    rdfs:comment '24-hour emergency response phone number for incidents involving this hazardous waste shipment. Required by DOT HMR.' ;
    rdfs:domain ind:ChainOfCustody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingPartyContactName rdf:type rdf:Property ;
    rdfs:label 'Receiving Party Contact Name' ;
    rdfs:comment 'Full name of the individual representative who physically accepted custody on behalf of the receiving party.' ;
    rdfs:domain ind:ChainOfCustody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingPartyName rdf:type rdf:Property ;
    rdfs:label 'Receiving Party Name' ;
    rdfs:comment 'Legal business name of the organization or facility accepting custody of the hazardous waste container.' ;
    rdfs:domain ind:ChainOfCustody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingPartySignature rdf:type rdf:Property ;
    rdfs:label 'Receiving Party Signature' ;
    rdfs:comment 'Digital signature or signature identifier of the receiving party representative acknowledging acceptance of custody. May be electronic signature hash or physical signature reference.' ;
    rdfs:domain ind:ChainOfCustody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordCreatedBy rdf:type rdf:Property ;
    rdfs:label 'Record Created By' ;
    rdfs:comment 'User ID or system identifier of the person or process that created this chain of custody record. Supports audit and compliance requirements.' ;
    rdfs:domain ind:ChainOfCustody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferEventType rdf:type rdf:Property ;
    rdfs:label 'Transfer Event Type' ;
    rdfs:comment 'Classification of the chain of custody transfer event. Defines the nature of the custody change in the cradle-to-grave lifecycle.' ;
    rdfs:domain ind:ChainOfCustody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferLocationAddress rdf:type rdf:Property ;
    rdfs:label 'Transfer Location Address' ;
    rdfs:comment 'Full street address of the location where the custody transfer occurred. Required for DOT and EPA compliance documentation.' ;
    rdfs:domain ind:ChainOfCustody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferLocationCity rdf:type rdf:Property ;
    rdfs:label 'Transfer Location City' ;
    rdfs:comment 'City where the custody transfer occurred.' ;
    rdfs:domain ind:ChainOfCustody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferLocationLatitude rdf:type rdf:Property ;
    rdfs:label 'Transfer Location Latitude' ;
    rdfs:comment 'Geographic latitude coordinate of the custody transfer location. Supports GPS-based verification and geospatial compliance analysis.' ;
    rdfs:domain ind:ChainOfCustody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transferLocationLongitude rdf:type rdf:Property ;
    rdfs:label 'Transfer Location Longitude' ;
    rdfs:comment 'Geographic longitude coordinate of the custody transfer location. Supports GPS-based verification and geospatial compliance analysis.' ;
    rdfs:domain ind:ChainOfCustody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transferLocationName rdf:type rdf:Property ;
    rdfs:label 'Transfer Location Name' ;
    rdfs:comment 'Name of the physical location where the custody transfer occurred (e.g., generator facility, transporter depot, TSDF receiving dock).' ;
    rdfs:domain ind:ChainOfCustody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferLocationPostalCode rdf:type rdf:Property ;
    rdfs:label 'Transfer Location Postal Code' ;
    rdfs:comment 'ZIP code of the location where the custody transfer occurred.' ;
    rdfs:domain ind:ChainOfCustody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferLocationState rdf:type rdf:Property ;
    rdfs:label 'Transfer Location State' ;
    rdfs:comment 'Two-letter state code where the custody transfer occurred. Used for state-level regulatory reporting.' ;
    rdfs:domain ind:ChainOfCustody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Transfer Sequence Number' ;
    rdfs:comment 'Sequential order of this transfer event within the container\'s complete chain of custody. Starts at 1 for generator handoff and increments with each subsequent transfer.' ;
    rdfs:domain ind:ChainOfCustody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transferTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transfer Timestamp' ;
    rdfs:comment 'Exact date and time when physical custody of the hazardous waste container was transferred from the relinquishing party to the receiving party. Critical for CERCLA liability determination.' ;
    rdfs:domain ind:ChainOfCustody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:transferringPartyContactName rdf:type rdf:Property ;
    rdfs:label 'Transferring Party Contact Name' ;
    rdfs:comment 'Full name of the individual representative who physically relinquished custody on behalf of the transferring party.' ;
    rdfs:domain ind:ChainOfCustody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferringPartyName rdf:type rdf:Property ;
    rdfs:label 'Transferring Party Name' ;
    rdfs:comment 'Legal business name of the organization or facility relinquishing custody of the hazardous waste container.' ;
    rdfs:domain ind:ChainOfCustody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferringPartySignature rdf:type rdf:Property ;
    rdfs:label 'Transferring Party Signature' ;
    rdfs:comment 'Digital signature or signature identifier of the transferring party representative acknowledging relinquishment of custody. May be electronic signature hash or physical signature reference.' ;
    rdfs:domain ind:ChainOfCustody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unIdentificationNumber rdf:type rdf:Property ;
    rdfs:label 'Un Identification Number' ;
    rdfs:comment 'Four-digit UN number assigned to the hazardous material for international transportation. Format: UN followed by 4 digits.' ;
    rdfs:domain ind:ChainOfCustody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteCode rdf:type rdf:Property ;
    rdfs:label 'Waste Code' ;
    rdfs:comment 'EPA hazardous waste code(s) for the material being transferred. Format: letter (D/F/K/P/U) followed by 3 digits. Multiple codes may be comma-separated.' ;
    rdfs:domain ind:Hazmat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:witnessSignature rdf:type rdf:Property ;
    rdfs:label 'Witness Signature' ;
    rdfs:comment 'Digital signature or signature identifier of the witness, if present. Provides additional verification for critical transfers.' ;
    rdfs:domain ind:ChainOfCustody ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatmentRecordId rdf:type rdf:Property ;
    rdfs:label 'Treatment Record Id' ;
    rdfs:comment 'Unique identifier for the hazardous waste treatment record. Primary key for tracking individual treatment operations performed at Treatment, Storage, and Disposal Facilities (TSDF) or permitted on-site treatment units under Resource Conservation and Recovery Act (RCRA) Subtitle C regulations.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TreatmentRecord .

ind:disposalRecordId rdf:type rdf:Property ;
    rdfs:label 'Disposal Record Id' ;
    rdfs:comment 'Foreign key linking to hazmat.disposal_record. Business justification: Treatment record should link to disposal_record for final disposition tracking. Treatment often precedes disposal in the waste lifecycle. This FK provides traceability from treatment to final disposal' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DisposalRecord .

ind:primaryTreatmentFacilityEpaIdRegistrationId rdf:type rdf:Property ;
    rdfs:label 'Primary Treatment Facility Epa Id Registration Id' ;
    rdfs:comment 'Foreign key linking to hazmat.epa_id_registration. Business justification: Treatment record tracks treatment facility EPA ID as a string. This should be normalized to FK to epa_id_registration. Labeled FK (treatment_facility_epa_id_registration_id) distinguishes this from ge' ;
    rdfs:domain ind:TreatmentRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EpaIdRegistration .

ind:tertiaryTreatmentTransporterEpaEpaIdRegistrationId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Treatment Transporter Epa Epa Id Registration Id' ;
    rdfs:comment 'The EPA identification number of the transporter who delivered the waste to the treatment facility. Part of the manifest chain-of-custody documentation.' ;
    rdfs:domain ind:TreatmentRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EpaIdRegistration .

ind:treatmentFacilityId rdf:type rdf:Property ;
    rdfs:label 'Treatment Facility Id' ;
    rdfs:comment 'Foreign key linking to asset.facility. Business justification: Treatment operations occur at specific facilities. Links treatment records to facility asset master for capacity utilization analysis, maintenance scheduling (treatment equipment downtime), facility p' ;
    rdfs:domain ind:TreatmentRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:treatmentFacilityPermitId rdf:type rdf:Property ;
    rdfs:label 'Treatment Facility Permit Id' ;
    rdfs:comment 'Foreign key linking to compliance.permit. Business justification: Treatment operations must comply with permit conditions (40 CFR 264 Subpart X). Permit specifies treatment technologies, waste codes, and operating parameters. Required for demonstrating permit compli' ;
    rdfs:domain ind:TreatmentRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Permit .

ind:disposalMethodCode rdf:type rdf:Property ;
    rdfs:label 'Disposal Method Code' ;
    rdfs:comment 'EPA code indicating the intended final disposal or management method for the treated residual. Values: LANDF=Landfill, INJCT=Underground Injection, SURFI=Surface Impoundment, WSTPL=Waste Pile, RCYCL=Recycling, ENRGY=Energy Recovery, OTHRD=Other Disposal. [ENUM-REF-CANDIDATE: LANDF|INJCT|SURFI|WSTPL|RCYCL|ENRGY|OTHRD — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Hazmat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyResponseFlag rdf:type rdf:Property ;
    rdfs:label 'Emergency Response Flag' ;
    rdfs:comment 'Boolean flag indicating whether this treatment operation was performed as part of an emergency response action under CERCLA (Superfund) or RCRA Corrective Action. True=Emergency response treatment, False=Routine permitted treatment.' ;
    rdfs:domain ind:Hazmat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:emissionControlSystemCode rdf:type rdf:Property ;
    rdfs:label 'Emission Control System Code' ;
    rdfs:comment 'Identifier for the air pollution control equipment used during thermal treatment operations (e.g., scrubbers, baghouses, electrostatic precipitators). Required for Clean Air Act (CAA) compliance and RCRA air emission standards.' ;
    rdfs:domain ind:TreatmentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inputQuantityUnit rdf:type rdf:Property ;
    rdfs:label 'Input Quantity Unit' ;
    rdfs:comment 'Unit of measure for the input waste quantity. Values: KG=Kilograms, LB=Pounds, GAL=Gallons, L=Liters, TON=US Tons, MT=Metric Tonnes. Must align with manifest and facility reporting units.' ;
    rdfs:domain ind:TreatmentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inputWasteCodes rdf:type rdf:Property ;
    rdfs:label 'Input Waste Codes' ;
    rdfs:comment 'Comma-separated list of EPA hazardous waste codes (D, F, K, P, U series) assigned to the input waste stream. Determines applicable treatment standards and Land Disposal Restrictions (LDR).' ;
    rdfs:domain ind:TreatmentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inputWasteQuantity rdf:type rdf:Property ;
    rdfs:label 'Input Waste Quantity' ;
    rdfs:comment 'The quantity of hazardous waste fed into the treatment unit for this operation, measured in the unit specified by input_quantity_unit. Critical for mass balance calculations and regulatory reporting.' ;
    rdfs:domain ind:TreatmentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ldrComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Ldr Compliance Status' ;
    rdfs:comment 'Indicates whether the treated waste meets EPA Land Disposal Restrictions treatment standards and is eligible for land disposal. Values: COMPLIANT=Meets LDR standards, NON_COMPLIANT=Requires additional treatment, EXEMPT=Waste category exempt from LDR, PENDING_ANALYSIS=Awaiting analytical results.' ;
    rdfs:domain ind:TreatmentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatorCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Operator Certification Number' ;
    rdfs:comment 'Certification number of the trained and certified operator who performed or supervised the treatment operation. RCRA requires personnel training and certification for hazardous waste treatment operations.' ;
    rdfs:domain ind:TreatmentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outputQuantityUnit rdf:type rdf:Property ;
    rdfs:label 'Output Quantity Unit' ;
    rdfs:comment 'Unit of measure for the output residual quantity. Values: KG=Kilograms, LB=Pounds, GAL=Gallons, L=Liters, TON=US Tons, MT=Metric Tonnes.' ;
    rdfs:domain ind:TreatmentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outputResidualQuantity rdf:type rdf:Property ;
    rdfs:label 'Output Residual Quantity' ;
    rdfs:comment 'The quantity of treated residual material or byproduct remaining after treatment, measured in the unit specified by output_quantity_unit. Used for mass balance verification and subsequent disposal or recycling decisions.' ;
    rdfs:domain ind:TreatmentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outputWasteCharacterization rdf:type rdf:Property ;
    rdfs:label 'Output Waste Characterization' ;
    rdfs:comment 'Description of the physical and chemical characteristics of the treated residual, including any remaining hazardous waste codes. Determines whether the residual meets Land Disposal Restrictions (LDR) treatment standards or requires further treatment.' ;
    rdfs:domain ind:TreatmentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pressurePsi rdf:type rdf:Property ;
    rdfs:label 'Pressure Psi' ;
    rdfs:comment 'Operating pressure in pounds per square inch (PSI) during treatment. Relevant for pressurized treatment technologies such as wet air oxidation or supercritical water oxidation.' ;
    rdfs:domain ind:TreatmentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityAssuranceReviewStatus rdf:type rdf:Property ;
    rdfs:label 'Quality Assurance Review Status' ;
    rdfs:comment 'Status of the quality assurance review for this treatment record. Values: APPROVED=Record verified and approved by QA, REJECTED=Record failed QA review, PENDING_REVIEW=Awaiting QA review, NOT_REQUIRED=QA review not required for this operation.' ;
    rdfs:domain ind:TreatmentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryUnitCode rdf:type rdf:Property ;
    rdfs:label 'Regulatory Unit Code' ;
    rdfs:comment 'EPA-assigned code identifying the specific treatment unit under the facility\'s RCRA Part B permit. Each unit has unique permit conditions, operating parameters, and waste acceptance criteria.' ;
    rdfs:domain ind:TreatmentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residenceTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Residence Time Minutes' ;
    rdfs:comment 'The duration in minutes that the waste remained in the treatment unit. Critical for ensuring adequate contact time for chemical reactions, thermal destruction, or physical separation processes per permit specifications.' ;
    rdfs:domain ind:TreatmentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stackEmissionTestResult rdf:type rdf:Property ;
    rdfs:label 'Stack Emission Test Result' ;
    rdfs:comment 'Result of stack emission testing performed during or after the treatment operation to verify compliance with air quality standards. Values: PASS=Emissions within permitted limits, FAIL=Emissions exceed limits, NOT_TESTED=No test performed for this operation.' ;
    rdfs:domain ind:TreatmentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tclpTestPerformed rdf:type rdf:Property ;
    rdfs:label 'Tclp Test Performed' ;
    rdfs:comment 'Boolean flag indicating whether a Toxicity Characteristic Leaching Procedure (TCLP) test was performed on the treated residual to verify that hazardous characteristics have been successfully treated. True=TCLP performed, False=TCLP not performed.' ;
    rdfs:domain ind:TreatmentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tclpTestResult rdf:type rdf:Property ;
    rdfs:label 'Tclp Test Result' ;
    rdfs:comment 'Result of the TCLP test if performed. Values: PASS=Treated waste no longer exhibits toxicity characteristic, FAIL=Waste still exhibits toxicity characteristic, NOT_APPLICABLE=TCLP not required for this waste, PENDING=Test results not yet available.' ;
    rdfs:domain ind:TreatmentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatmentBatchNumber rdf:type rdf:Property ;
    rdfs:label 'Treatment Batch Number' ;
    rdfs:comment 'Internal batch identifier for grouping multiple treatment records that were processed together or as part of a continuous treatment campaign. Enables batch-level quality control and traceability.' ;
    rdfs:domain ind:TreatmentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatmentCostUsd rdf:type rdf:Property ;
    rdfs:label 'Treatment Cost Usd' ;
    rdfs:comment 'The total cost in US dollars incurred for this treatment operation, including labor, energy, consumables, and equipment depreciation. Used for cost accounting and profitability analysis.' ;
    rdfs:domain ind:TreatmentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:treatmentDate rdf:type rdf:Property ;
    rdfs:label 'Treatment Date' ;
    rdfs:comment 'The calendar date on which the hazardous waste treatment operation was performed. Critical for regulatory reporting timelines and Land Disposal Restrictions (LDR) compliance tracking.' ;
    rdfs:domain ind:TreatmentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:treatmentEfficiencyPercent rdf:type rdf:Property ;
    rdfs:label 'Treatment Efficiency Percent' ;
    rdfs:comment 'The calculated treatment efficiency expressed as a percentage, representing the degree of contaminant removal or destruction achieved. For incinerators, this is the Destruction and Removal Efficiency (DRE) which must meet or exceed 99.99% for most hazardous wastes.' ;
    rdfs:domain ind:TreatmentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:treatmentEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Treatment End Timestamp' ;
    rdfs:comment 'The precise date and time when the treatment process was completed. Used to calculate total treatment duration and verify process completion per permit requirements.' ;
    rdfs:domain ind:TreatmentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:treatmentPhLevel rdf:type rdf:Property ;
    rdfs:label 'Treatment Ph Level' ;
    rdfs:comment 'The pH level maintained during chemical treatment processes such as neutralization or chemical oxidation. Must be within permitted operating ranges to ensure effective treatment and regulatory compliance.' ;
    rdfs:domain ind:TreatmentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:treatmentStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Treatment Start Timestamp' ;
    rdfs:comment 'The precise date and time when the treatment process began. Used to calculate residence time and verify compliance with treatment technology specifications.' ;
    rdfs:domain ind:TreatmentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:treatmentStatus rdf:type rdf:Property ;
    rdfs:label 'Treatment Status' ;
    rdfs:comment 'Current status of the treatment operation. Values: COMPLETED=Treatment successfully finished, IN_PROGRESS=Treatment underway, FAILED=Treatment did not meet specifications, ABORTED=Treatment stopped before completion, PENDING_VERIFICATION=Awaiting analytical confirmation of treatment effectiveness.' ;
    rdfs:domain ind:TreatmentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatmentTechnologyCode rdf:type rdf:Property ;
    rdfs:label 'Treatment Technology Code' ;
    rdfs:comment 'EPA-defined code representing the treatment technology applied. Values: INCIN=Incineration, NEUTR=Neutralization, STBLZ=Stabilization, FBLEN=Fuel Blending, SOLVR=Solvent Recovery, CARBN=Carbon Adsorption, WETOX=Wet Air Oxidation, CHOXD=Chemical Oxidation, CMBST=Combustion, DEACT=Deactivation, MACRO=Macroencapsulation, RORGS=Recovery of Organics, RMETL=Recovery of Metals, WTRRX=Water Reaction. [ENUM-REF-CANDIDATE: INCIN|NEUTR|STBLZ|FBLEN|SOLVR|CARBN|WETOX|CHOXD|CMBST|DEACT|MACRO|RORGS|RMETL|WTRRX — 14 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TreatmentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatmentTemperatureCelsius rdf:type rdf:Property ;
    rdfs:label 'Treatment Temperature Celsius' ;
    rdfs:comment 'Operating temperature of the treatment process in degrees Celsius. Critical parameter for thermal treatment technologies (incineration, combustion) to ensure destruction and removal efficiency (DRE) requirements are met.' ;
    rdfs:domain ind:TreatmentRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryDisposalEpaIdRegistrationId rdf:type rdf:Property ;
    rdfs:label 'Primary Disposal Epa Id Registration Id' ;
    rdfs:comment 'EPA-issued 12-character identification number for the TSDF facility performing the disposal. Required for all permitted hazardous waste treatment, storage, and disposal facilities.' ;
    rdfs:domain ind:DisposalRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EpaIdRegistration .

ind:tertiaryDisposalTransporterEpaEpaIdRegistrationId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Disposal Transporter Epa Epa Id Registration Id' ;
    rdfs:comment 'EPA ID number of the transporter who delivered the waste to the TSDF. Documents the transportation link in the chain of custody.' ;
    rdfs:domain ind:DisposalRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EpaIdRegistration .

ind:tsdfPermitId rdf:type rdf:Property ;
    rdfs:label 'Tsdf Permit Id' ;
    rdfs:comment 'Foreign key linking to compliance.permit. Business justification: Disposal operations governed by TSDF permit conditions (40 CFR 264 Subpart N). Permit defines disposal unit capacity, waste codes, and LDR compliance requirements. Core regulatory relationship for dis' ;
    rdfs:domain ind:DisposalRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Permit .

ind:certificateOfDisposalNumber rdf:type rdf:Property ;
    rdfs:label 'Certificate Of Disposal Number' ;
    rdfs:comment 'Unique certificate number issued by the TSDF confirming final disposal of the hazardous waste. Provides legal documentation that waste has been properly disposed per RCRA requirements.' ;
    rdfs:domain ind:DisposalRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Disposal Completion Timestamp' ;
    rdfs:comment 'Date and time when the disposal process was fully completed and the record was finalized. Marks the official closure of the cradle-to-grave tracking cycle.' ;
    rdfs:domain ind:DisposalRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:disposalCostAmount rdf:type rdf:Property ;
    rdfs:label 'Disposal Cost Amount' ;
    rdfs:comment 'Total cost charged by the TSDF for disposal of this waste shipment. Includes tipping fees, treatment costs, and any surcharges. Used for billing and cost tracking.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disposalCostCurrency rdf:type rdf:Property ;
    rdfs:label 'Disposal Cost Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the disposal cost amount (e.g., USD, CAD, EUR). Supports multi-currency operations for international waste disposal.' ;
    rdfs:domain ind:DisposalRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalMethodDescription rdf:type rdf:Property ;
    rdfs:label 'Disposal Method Description' ;
    rdfs:comment 'Detailed description of the disposal method employed at the TSDF, including specific technology, process, or unit operation used for final waste disposition.' ;
    rdfs:domain ind:DisposalRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyResponseRequired rdf:type rdf:Property ;
    rdfs:label 'Emergency Response Required' ;
    rdfs:comment 'Boolean flag indicating whether emergency response procedures were activated during receipt or disposal of this waste. Triggers incident reporting and documentation requirements.' ;
    rdfs:domain ind:DisposalRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ldrCertificationDate rdf:type rdf:Property ;
    rdfs:label 'Ldr Certification Date' ;
    rdfs:comment 'Date when the TSDF certified LDR compliance for the disposed waste. Documents when treatment standards were verified prior to land disposal.' ;
    rdfs:domain ind:DisposalRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ldrComplianceCertified rdf:type rdf:Property ;
    rdfs:label 'Ldr Compliance Certified' ;
    rdfs:comment 'Boolean flag indicating whether the TSDF has certified that the waste meets Land Disposal Restriction treatment standards prior to disposal. Required for restricted hazardous wastes under RCRA.' ;
    rdfs:domain ind:DisposalRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ldrTreatmentMethod rdf:type rdf:Property ;
    rdfs:label 'Ldr Treatment Method' ;
    rdfs:comment 'Description of the treatment method applied to meet LDR standards before disposal (e.g., stabilization, neutralization, thermal treatment). Required for restricted waste codes.' ;
    rdfs:domain ind:DisposalRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Date' ;
    rdfs:comment 'Date when regulatory reports related to this disposal were submitted to EPA or state environmental agencies. Documents compliance with reporting deadlines.' ;
    rdfs:domain ind:DisposalRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryReportSubmitted rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Submitted' ;
    rdfs:comment 'Boolean flag indicating whether required regulatory reports (e.g., biennial report, exception report) have been submitted for this disposal event. Tracks compliance reporting obligations.' ;
    rdfs:domain ind:DisposalRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tsdfSignatureName rdf:type rdf:Property ;
    rdfs:label 'Tsdf Signature Name' ;
    rdfs:comment 'Name of the authorized TSDF representative who signed and certified the disposal record. Provides accountability for disposal confirmation.' ;
    rdfs:domain ind:DisposalRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tsdfSignatureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Tsdf Signature Timestamp' ;
    rdfs:comment 'Date and time when the TSDF representative signed the disposal record, confirming receipt and disposal of the hazardous waste shipment.' ;
    rdfs:domain ind:DisposalRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:tsdfSignatureTitle rdf:type rdf:Property ;
    rdfs:label 'Tsdf Signature Title' ;
    rdfs:comment 'Job title of the TSDF representative who signed the disposal record (e.g., Facility Manager, Environmental Compliance Officer). Establishes authority of signatory.' ;
    rdfs:domain ind:DisposalRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteCodePrimary rdf:type rdf:Property ;
    rdfs:label 'Waste Code Primary' ;
    rdfs:comment 'Primary EPA hazardous waste code (D, F, K, P, or U list) identifying the principal hazardous characteristic or listing of the disposed waste. Determines regulatory requirements and disposal restrictions.' ;
    rdfs:domain ind:DisposalRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteCodesAdditional rdf:type rdf:Property ;
    rdfs:label 'Waste Codes Additional' ;
    rdfs:comment 'Comma-separated list of additional EPA hazardous waste codes applicable to the disposed waste. Captures multiple hazardous characteristics or listings for mixed waste streams.' ;
    rdfs:domain ind:DisposalRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteQuantityLbs rdf:type rdf:Property ;
    rdfs:label 'Waste Quantity Lbs' ;
    rdfs:comment 'Total quantity of hazardous waste disposed, measured in pounds. Represents the actual weight accepted and disposed by the TSDF facility.' ;
    rdfs:domain ind:DisposalRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wasteQuantityTons rdf:type rdf:Property ;
    rdfs:label 'Waste Quantity Tons' ;
    rdfs:comment 'Total quantity of hazardous waste disposed, measured in tons. Calculated or measured weight for regulatory reporting and capacity tracking purposes.' ;
    rdfs:domain ind:DisposalRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wasteVolumeGallons rdf:type rdf:Property ;
    rdfs:label 'Waste Volume Gallons' ;
    rdfs:comment 'Volume of liquid or semi-liquid hazardous waste disposed, measured in gallons. Used for liquid waste streams and deep well injection disposal methods.' ;
    rdfs:domain ind:DisposalRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryServiceEpaIdRegistrationId rdf:type rdf:Property ;
    rdfs:label 'Primary Service Epa Id Registration Id' ;
    rdfs:comment 'EPA identification number of the destination treatment, storage, or disposal facility where the hazardous waste will be delivered.' ;
    rdfs:domain ind:ServiceOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EpaIdRegistration .

ind:serviceFacilityId rdf:type rdf:Property ;
    rdfs:label 'Service Facility Id' ;
    rdfs:comment 'Foreign key linking to asset.facility. Business justification: Hazmat service orders are fulfilled at facilities (customer sites or company facilities). Links service orders to facility asset records for facility utilization tracking, service history analysis, fa' ;
    rdfs:domain ind:ServiceOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:actualAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Amount' ;
    rdfs:comment 'Final invoiced amount for the hazardous waste service based on actual quantities and services performed.' ;
    rdfs:domain ind:ServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualQuantityUom rdf:type rdf:Property ;
    rdfs:label 'Actual Quantity Uom' ;
    rdfs:comment 'Unit of measure for the actual waste quantity collected: drums, gallons, pounds, tons, cubic yards, liters, or kilograms. [ENUM-REF-CANDIDATE: drums|gallons|pounds|tons|cubic_yards|liters|kilograms — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualWasteQuantity rdf:type rdf:Property ;
    rdfs:label 'Actual Waste Quantity' ;
    rdfs:comment 'Actual quantity of hazardous waste collected or treated, as measured by the field crew upon service completion.' ;
    rdfs:domain ind:ServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:completedDate rdf:type rdf:Property ;
    rdfs:label 'Completed Date' ;
    rdfs:comment 'Date when the hazardous waste service was actually completed in the field.' ;
    rdfs:domain ind:ServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customerPoNumber rdf:type rdf:Property ;
    rdfs:label 'Customer Po Number' ;
    rdfs:comment 'Customer-provided purchase order number for billing and accounts payable reconciliation.' ;
    rdfs:domain ind:ServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedQuantityUom rdf:type rdf:Property ;
    rdfs:label 'Estimated Quantity Uom' ;
    rdfs:comment 'Unit of measure for the estimated waste quantity: drums, gallons, pounds, tons, cubic yards, liters, or kilograms. [ENUM-REF-CANDIDATE: drums|gallons|pounds|tons|cubic_yards|liters|kilograms — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedWasteQuantity rdf:type rdf:Property ;
    rdfs:label 'Estimated Waste Quantity' ;
    rdfs:comment 'Estimated quantity of hazardous waste to be collected or treated, as provided by the customer during order placement.' ;
    rdfs:domain ind:ServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderDate rdf:type rdf:Property ;
    rdfs:label 'Order Date' ;
    rdfs:comment 'Date when the hazardous waste service order was placed by the customer.' ;
    rdfs:domain ind:ServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quotedAmount rdf:type rdf:Property ;
    rdfs:label 'Quoted Amount' ;
    rdfs:comment 'Initial quoted price for the hazardous waste service provided to the customer during order placement.' ;
    rdfs:domain ind:ServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyBriefingRequired rdf:type rdf:Property ;
    rdfs:label 'Safety Briefing Required' ;
    rdfs:comment 'Indicates whether a site-specific safety briefing is required before performing the hazardous waste service.' ;
    rdfs:domain ind:ServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceNotes rdf:type rdf:Property ;
    rdfs:label 'Service Notes' ;
    rdfs:comment 'Additional notes, instructions, or observations related to the hazardous waste service order, including site access instructions, customer requests, or field crew observations.' ;
    rdfs:domain ind:ServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unNumber rdf:type rdf:Property ;
    rdfs:label 'Un Number' ;
    rdfs:comment 'Four-digit UN identification number for the hazardous material being transported, as required by DOT regulations.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedStateProgram rdf:type rdf:Property ;
    rdfs:label 'Authorized State Program' ;
    rdfs:comment 'Indicates whether the state has an EPA-authorized RCRA program and administers the program in lieu of the federal EPA.' ;
    rdfs:domain ind:EpaIdRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:epaIdNumber rdf:type rdf:Property ;
    rdfs:label 'Epa Id Number' ;
    rdfs:comment 'The 12-character EPA identification number assigned to the regulated site (format: 2-letter state code + 9 digits). This is the regulatory identity anchor for all RCRA (Resource Conservation and Recovery Act) compliance activities.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityContactEmail rdf:type rdf:Property ;
    rdfs:label 'Facility Contact Email' ;
    rdfs:comment 'Email address for the facility contact person for regulatory correspondence.' ;
    rdfs:domain ind:EpaIdRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityContactName rdf:type rdf:Property ;
    rdfs:label 'Facility Contact Name' ;
    rdfs:comment 'Name of the primary contact person for regulatory correspondence and compliance matters at the registered facility.' ;
    rdfs:domain ind:EpaIdRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityContactPhone rdf:type rdf:Property ;
    rdfs:label 'Facility Contact Phone' ;
    rdfs:comment 'Primary phone number for the facility contact person.' ;
    rdfs:domain ind:EpaIdRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:generatorClassification rdf:type rdf:Property ;
    rdfs:label 'Generator Classification' ;
    rdfs:comment 'Generator size classification: LQG (Large Quantity Generator, >1000 kg/month), SQG (Small Quantity Generator, 100-1000 kg/month), VSQG (Very Small Quantity Generator, <100 kg/month), CESQG (Conditionally Exempt Small Quantity Generator, legacy term), or not_applicable for non-generators.' ;
    rdfs:domain ind:EpaIdRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handlerStatus rdf:type rdf:Property ;
    rdfs:label 'Handler Status' ;
    rdfs:comment 'Current operational status of the EPA ID registration: active (currently operating), inactive (not currently handling hazardous waste), pending (application submitted), withdrawn (voluntarily terminated), or suspended (regulatory action).' ;
    rdfs:domain ind:EpaIdRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handlerType rdf:type rdf:Property ;
    rdfs:label 'Handler Type' ;
    rdfs:comment 'Primary regulated activity type for this EPA ID: generator (produces hazardous waste), transporter (hauls hazardous waste), TSDF (Treatment Storage and Disposal Facility), or mixed (multiple activities).' ;
    rdfs:domain ind:EpaIdRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isGenerator rdf:type rdf:Property ;
    rdfs:label 'Is Generator' ;
    rdfs:comment 'Indicates whether this EPA ID is registered as a hazardous waste generator.' ;
    rdfs:domain ind:EpaIdRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTransporter rdf:type rdf:Property ;
    rdfs:label 'Is Transporter' ;
    rdfs:comment 'Indicates whether this EPA ID is registered as a hazardous waste transporter.' ;
    rdfs:domain ind:EpaIdRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTsdf rdf:type rdf:Property ;
    rdfs:label 'Is Tsdf' ;
    rdfs:comment 'Indicates whether this EPA ID is registered as a Treatment, Storage, and Disposal Facility for hazardous waste.' ;
    rdfs:domain ind:EpaIdRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:locationVerificationMethod rdf:type rdf:Property ;
    rdfs:label 'Location Verification Method' ;
    rdfs:comment 'Method used to verify the geographic coordinates of the site: GPS (field measurement), address_geocoding (automated), survey (professional land survey), or map_interpolation (manual map reading).' ;
    rdfs:domain ind:EpaIdRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Notification Effective Date' ;
    rdfs:comment 'Date when the EPA ID registration became effective and the site was authorized to conduct regulated activities.' ;
    rdfs:domain ind:EpaIdRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:notificationSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Notification Submission Date' ;
    rdfs:comment 'Date when the RCRA notification form (EPA Form 8700-12) was submitted to the EPA or authorized state agency.' ;
    rdfs:domain ind:EpaIdRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ownerOperatorName rdf:type rdf:Property ;
    rdfs:label 'Owner Operator Name' ;
    rdfs:comment 'Legal name of the entity that owns or operates the regulated facility.' ;
    rdfs:domain ind:EpaIdRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerOperatorType rdf:type rdf:Property ;
    rdfs:label 'Owner Operator Type' ;
    rdfs:comment 'Type of entity that owns or operates the facility: private (commercial), public (publicly traded), federal (U.S. government), state (state government), or municipal (local government).' ;
    rdfs:domain ind:EpaIdRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rcrainfoLastSyncTimestamp rdf:type rdf:Property ;
    rdfs:label 'Rcrainfo Last Sync Timestamp' ;
    rdfs:comment 'Timestamp of the last successful data synchronization with the EPA RCRAInfo system.' ;
    rdfs:domain ind:EpaIdRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rcrainfoSyncStatus rdf:type rdf:Property ;
    rdfs:label 'Rcrainfo Sync Status' ;
    rdfs:comment 'Status of data synchronization with the EPA RCRAInfo national database: synced (up to date), pending (sync in progress), failed (sync error), or not_synced (not yet synchronized).' ;
    rdfs:domain ind:EpaIdRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Registration Expiration Date' ;
    rdfs:comment 'Date when the EPA ID registration expires and must be renewed (if applicable based on state requirements).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:siteAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Site Address Line1' ;
    rdfs:comment 'Primary street address of the regulated site.' ;
    rdfs:domain ind:EpaIdRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Site Address Line2' ;
    rdfs:comment 'Secondary address information (suite, building, floor) for the regulated site.' ;
    rdfs:domain ind:EpaIdRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteCountryCode rdf:type rdf:Property ;
    rdfs:label 'Site Country Code' ;
    rdfs:comment 'Three-letter ISO country code for the regulated site location.' ;
    rdfs:domain ind:EpaIdRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sitePostalCode rdf:type rdf:Property ;
    rdfs:label 'Site Postal Code' ;
    rdfs:comment 'ZIP code or ZIP+4 code for the regulated site address.' ;
    rdfs:domain ind:EpaIdRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteStateCode rdf:type rdf:Property ;
    rdfs:label 'Site State Code' ;
    rdfs:comment 'Two-letter state code where the regulated site is located.' ;
    rdfs:domain ind:EpaIdRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateAgencyNotificationDate rdf:type rdf:Property ;
    rdfs:label 'State Agency Notification Date' ;
    rdfs:comment 'Date when the state environmental agency was notified of this EPA ID registration.' ;
    rdfs:domain ind:EpaIdRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:stateAgencyNotified rdf:type rdf:Property ;
    rdfs:label 'State Agency Notified' ;
    rdfs:comment 'Indicates whether the state environmental quality department or local enforcement agency has been notified of this EPA ID registration.' ;
    rdfs:domain ind:EpaIdRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stateIdNumber rdf:type rdf:Property ;
    rdfs:label 'State Id Number' ;
    rdfs:comment 'State-issued identification number for hazardous waste handling (if different from EPA ID and required by state regulations).' ;
    rdfs:domain ind:EpaIdRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rcraBiennialReportId rdf:type rdf:Property ;
    rdfs:label 'Rcra Biennial Report Id' ;
    rdfs:comment 'Unique identifier for the RCRA Biennial Report submission record. Primary key.' ;
    rdfs:domain ind:RcraBiennialReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reportingFacilityId rdf:type rdf:Property ;
    rdfs:label 'Reporting Facility Id' ;
    rdfs:comment 'Foreign key linking to asset.facility. Business justification: Biennial reports are submitted per facility to EPA. Links regulatory reports to facility asset master for compliance tracking, facility performance benchmarking, audit trails, and facility-level waste' ;
    rdfs:domain ind:RcraBiennialReport ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:amendmentDate rdf:type rdf:Property ;
    rdfs:label 'Amendment Date' ;
    rdfs:comment 'The date on which an amended version of the biennial report was submitted. Nullable if no amendment has been filed.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:amendmentReason rdf:type rdf:Property ;
    rdfs:label 'Amendment Reason' ;
    rdfs:comment 'Explanation for why the biennial report was amended after initial submission. Nullable if the report has not been amended. Common reasons include data corrections, additional waste codes discovered, or regulatory agency feedback.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationDate rdf:type rdf:Property ;
    rdfs:label 'Certification Date' ;
    rdfs:comment 'The date on which the authorized representative signed and certified the biennial report, attesting to its accuracy under penalty of law.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationTitle rdf:type rdf:Property ;
    rdfs:label 'Certification Title' ;
    rdfs:comment 'Job title of the authorized facility representative who certified the biennial report (e.g., Environmental Manager, Facility Director, Compliance Officer).' ;
    rdfs:domain ind:RcraBiennialReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberOfTsdfDestinations rdf:type rdf:Property ;
    rdfs:label 'Number Of Tsdf Destinations' ;
    rdfs:comment 'The count of distinct off-site TSDF facilities to which hazardous waste was shipped during the reporting year. Each TSDF is identified by its EPA ID number.' ;
    rdfs:domain ind:RcraBiennialReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numberOfWasteCodesReported rdf:type rdf:Property ;
    rdfs:label 'Number Of Waste Codes Reported' ;
    rdfs:comment 'The count of distinct EPA hazardous waste codes (e.g., D001, F001, K001) reported in this biennial report. Each waste stream is classified by one or more waste codes.' ;
    rdfs:domain ind:RcraBiennialReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:offsiteShipmentFlag rdf:type rdf:Property ;
    rdfs:label 'Offsite Shipment Flag' ;
    rdfs:comment 'Indicates whether the facility shipped any hazardous waste off-site to TSDFs during the reporting year. True = off-site shipments occurred, False = all waste managed on-site.' ;
    rdfs:domain ind:RcraBiennialReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:onsiteTreatmentFlag rdf:type rdf:Property ;
    rdfs:label 'Onsite Treatment Flag' ;
    rdfs:comment 'Indicates whether the facility performed any on-site treatment, storage, or disposal of hazardous waste during the reporting year. True = on-site management occurred, False = all waste shipped off-site.' ;
    rdfs:domain ind:RcraBiennialReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryTreatmentMethod rdf:type rdf:Property ;
    rdfs:label 'Primary Treatment Method' ;
    rdfs:comment 'The predominant treatment, storage, or disposal method used for hazardous waste during the reporting year. Examples: incineration, stabilization, landfill, fuel blending, recycling, neutralization.' ;
    rdfs:domain ind:RcraBiennialReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryWasteDescription rdf:type rdf:Property ;
    rdfs:label 'Primary Waste Description' ;
    rdfs:comment 'Textual description of the primary waste stream corresponding to the primary waste code. Describes the waste source, composition, and hazardous characteristics.' ;
    rdfs:domain ind:RcraBiennialReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingYear rdf:type rdf:Property ;
    rdfs:label 'Reporting Year' ;
    rdfs:comment 'The even-numbered calendar year for which this biennial report is submitted (e.g., 2022, 2024). Reports are required every two years per RCRA regulations.' ;
    rdfs:domain ind:RcraBiennialReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stateAgencyCode rdf:type rdf:Property ;
    rdfs:label 'State Agency Code' ;
    rdfs:comment 'Two-letter abbreviation of the state environmental agency to which this biennial report was submitted. Corresponds to the state where the facility is located.' ;
    rdfs:domain ind:RcraBiennialReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalWasteGeneratedLbs rdf:type rdf:Property ;
    rdfs:label 'Total Waste Generated Lbs' ;
    rdfs:comment 'The total quantity of RCRA hazardous waste generated during the reporting year, measured in pounds. Aggregated across all waste codes managed by the facility.' ;
    rdfs:domain ind:RcraBiennialReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalWasteManagedOnsiteLbs rdf:type rdf:Property ;
    rdfs:label 'Total Waste Managed Onsite Lbs' ;
    rdfs:comment 'The total quantity of hazardous waste treated, stored, or disposed of on-site at the generator facility during the reporting year, measured in pounds.' ;
    rdfs:domain ind:RcraBiennialReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalWasteShippedOffsiteLbs rdf:type rdf:Property ;
    rdfs:label 'Total Waste Shipped Offsite Lbs' ;
    rdfs:comment 'The total quantity of hazardous waste shipped off-site to Treatment, Storage, and Disposal Facilities (TSDFs) during the reporting year, measured in pounds.' ;
    rdfs:domain ind:RcraBiennialReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wasteMinimizationAchievedFlag rdf:type rdf:Property ;
    rdfs:label 'Waste Minimization Achieved Flag' ;
    rdfs:comment 'Indicates whether the facility achieved measurable waste minimization or source reduction during the reporting year. True = minimization achieved, False = no reduction.' ;
    rdfs:domain ind:RcraBiennialReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:wasteMinimizationActivities rdf:type rdf:Property ;
    rdfs:label 'Waste Minimization Activities' ;
    rdfs:comment 'Narrative description of waste minimization, source reduction, and pollution prevention activities undertaken during the reporting year. Required disclosure per RCRA biennial reporting requirements.' ;
    rdfs:domain ind:RcraBiennialReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activeStatus rdf:type rdf:Property ;
    rdfs:label 'Active Status' ;
    rdfs:comment 'Indicates whether this waste code is currently active and should be used for new waste classifications. True for codes in current regulatory use. False for obsolete, superseded, or delisted codes that are retained for historical reference only.' ;
    rdfs:domain ind:WasteCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:acuteHazardousFlag rdf:type rdf:Property ;
    rdfs:label 'Acute Hazardous Flag' ;
    rdfs:comment 'Indicates whether this waste code designates an acutely hazardous waste under RCRA. True for P-listed wastes and certain F-listed wastes that are subject to more stringent quantity thresholds (1 kg vs 100 kg for generator status determination) and management requirements.' ;
    rdfs:domain ind:WasteCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:containerTypeRestriction rdf:type rdf:Property ;
    rdfs:label 'Container Type Restriction' ;
    rdfs:comment 'Specific container or packaging requirements for this waste code during storage and transportation. May specify DOT-approved containers, compatibility requirements, or prohibited container materials. Critical for safe handling and DOT Hazardous Materials Regulations compliance.' ;
    rdfs:domain ind:WasteCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:delistingPetitionEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Delisting Petition Eligible Flag' ;
    rdfs:comment 'Indicates whether generators may petition EPA to delist this waste code for specific waste streams that do not exhibit hazardous characteristics. True for listed wastes (F, K, P, U codes) where site-specific delisting is possible. False for characteristic wastes (D codes) which cannot be delisted.' ;
    rdfs:domain ind:WasteCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:generatorAccumulationLimitDays rdf:type rdf:Property ;
    rdfs:label 'Generator Accumulation Limit Days' ;
    rdfs:comment 'Maximum number of days a generator may accumulate this waste on-site before shipping to a TSDF. Typically 90 days for large quantity generators, 180 days for small quantity generators, or 270 days with approved extension. Shorter limits (e.g., 1 day) may apply to acutely hazardous wastes.' ;
    rdfs:domain ind:WasteCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hazardBasis rdf:type rdf:Property ;
    rdfs:label 'Hazard Basis' ;
    rdfs:comment 'Primary hazard characteristic that qualifies this waste as hazardous under RCRA. Ignitability (D001) covers flammable liquids and oxidizers. Corrosivity (D002) covers acids and bases. Reactivity (D003) covers unstable or explosive materials. Toxicity (D004-D043) covers materials that leach toxic constituents. Listed wastes are hazardous by definition regardless of characteristics. Multiple indicates waste exhibits more than one characteristic.' ;
    rdfs:domain ind:WasteCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prohibitedMethodCode rdf:type rdf:Property ;
    rdfs:label 'Prohibited Method Code' ;
    rdfs:comment 'Management method codes that are prohibited for this waste code under Land Disposal Restrictions. Typically references disposal methods that are banned without prior treatment (e.g., landfill disposal, deep well injection). Comma-separated list if multiple methods are prohibited.' ;
    rdfs:domain ind:WasteCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recyclingPotentialFlag rdf:type rdf:Property ;
    rdfs:label 'Recycling Potential Flag' ;
    rdfs:comment 'Indicates whether this waste code has known recycling or reclamation pathways that may qualify for reduced regulatory requirements under RCRA recycling exemptions. True if legitimate recycling options exist (e.g., solvent recovery, metal reclamation, fuel blending).' ;
    rdfs:domain ind:WasteCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportableQuantityLbs rdf:type rdf:Property ;
    rdfs:label 'Reportable Quantity Lbs' ;
    rdfs:comment 'CERCLA reportable quantity in pounds. If a spill or release of this waste equals or exceeds this quantity, it must be reported to the National Response Center immediately. Values typically range from 1 lb (most hazardous) to 5,000 lbs. Null if no RQ is assigned.' ;
    rdfs:domain ind:Hazmat ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:smallQuantityExclusionKg rdf:type rdf:Property ;
    rdfs:label 'Small Quantity Exclusion Kg' ;
    rdfs:comment 'Quantity threshold in kilograms below which a generator may qualify for reduced regulatory requirements. Typically 100 kg per month for hazardous waste or 1 kg per month for acutely hazardous waste. Used to determine generator category (VSQG, SQG, LQG).' ;
    rdfs:domain ind:WasteCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stateSpecificFlag rdf:type rdf:Property ;
    rdfs:label 'State Specific Flag' ;
    rdfs:comment 'Indicates whether this waste code is a state-specific designation beyond federal EPA requirements. True when the code is defined by state environmental regulations and may not be recognized in other states. False for federal EPA codes that apply nationwide.' ;
    rdfs:domain ind:WasteCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sunsetDate rdf:type rdf:Property ;
    rdfs:label 'Sunset Date' ;
    rdfs:comment 'Date when this waste code was or will be removed from regulatory lists. Null for active codes. Populated when EPA or state agencies delist a waste code or when state-specific codes are superseded. Historical record retention required for audit trails.' ;
    rdfs:domain ind:WasteCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tclpConstituent rdf:type rdf:Property ;
    rdfs:label 'Tclp Constituent' ;
    rdfs:comment 'Specific toxic constituent measured in TCLP testing for toxicity characteristic wastes. Examples include arsenic, barium, cadmium, chromium, lead, mercury, selenium, silver, benzene, trichloroethylene. Only populated for D-code toxicity characteristic wastes (D004-D043).' ;
    rdfs:domain ind:WasteCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tclpRegulatoryLevelMgL rdf:type rdf:Property ;
    rdfs:label 'Tclp Regulatory Level Mg L' ;
    rdfs:comment 'Maximum concentration in milligrams per liter of TCLP extract that triggers hazardous waste classification for toxicity characteristic wastes. Waste exceeding this level must be managed as hazardous. Only applicable to D-code toxicity characteristic wastes.' ;
    rdfs:domain ind:WasteCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:toxicityCharacteristicFlag rdf:type rdf:Property ;
    rdfs:label 'Toxicity Characteristic Flag' ;
    rdfs:comment 'Indicates whether this waste code is based on Toxicity Characteristic Leaching Procedure (TCLP) test results. True for D004-D043 codes where waste is hazardous if TCLP extract exceeds regulatory levels for specific contaminants. Requires periodic testing to confirm classification.' ;
    rdfs:domain ind:WasteCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:treatmentStandardCode rdf:type rdf:Property ;
    rdfs:label 'Treatment Standard Code' ;
    rdfs:comment 'Land Disposal Restrictions (LDR) treatment standard code that applies to this waste before land disposal. References 40 CFR Part 268 treatment standards. Specifies required treatment technology or concentration limits (e.g., DEACT for deactivation, IMERC for incineration, specific mg/L or mg/kg limits for TCLP constituents).' ;
    rdfs:domain ind:WasteCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatmentSubcategory rdf:type rdf:Property ;
    rdfs:label 'Treatment Subcategory' ;
    rdfs:comment 'Subcategory designation for wastes with multiple treatment standards based on waste form or concentration. Used when a single waste code has different treatment requirements for wastewater versus non-wastewater forms, or for different concentration ranges.' ;
    rdfs:domain ind:WasteCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:universalTreatmentStandard rdf:type rdf:Property ;
    rdfs:label 'Universal Treatment Standard' ;
    rdfs:comment 'Universal Treatment Standard concentration limits for underlying hazardous constituents. Specifies maximum allowable concentrations (in mg/L for TCLP or mg/kg total) for each constituent before the waste can be land disposed. Multiple constituents may be listed with their respective limits.' ;
    rdfs:domain ind:WasteCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteCodeType rdf:type rdf:Property ;
    rdfs:label 'Waste Code Type' ;
    rdfs:comment 'Classification category of the waste code. D-listed are characteristic wastes (ignitability, corrosivity, reactivity, toxicity). F-listed are wastes from non-specific sources. K-listed are wastes from specific sources. P-listed are acutely hazardous discarded commercial chemical products. U-listed are toxic discarded commercial chemical products. State-specific codes are additional classifications imposed by state environmental agencies.' ;
    rdfs:domain ind:WasteCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surchargeId rdf:type rdf:Property ;
    rdfs:label 'Surcharge Id' ;
    rdfs:comment 'Foreign key linking to billing.surcharge. Business justification: DOT hazmat classifications (hazard class, packing group, placard requirements) trigger specific billing surcharges (hazmat handling surcharge, placard surcharge, emergency response surcharge). Billing' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Surcharge .

ind:cargoAircraftQuantityLimit rdf:type rdf:Property ;
    rdfs:label 'Cargo Aircraft Quantity Limit' ;
    rdfs:comment 'Maximum net quantity per package permitted on cargo-only aircraft. May be expressed as weight (kg), volume (L), or \'Forbidden\' if not permitted.' ;
    rdfs:domain ind:DotHazmatClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classificationEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Classification Effective Date' ;
    rdfs:comment 'Date when this classification entry became effective in the Hazardous Materials Regulations. Used to track regulatory changes over time.' ;
    rdfs:domain ind:DotHazmatClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:classificationStatus rdf:type rdf:Property ;
    rdfs:label 'Classification Status' ;
    rdfs:comment 'Current regulatory status of this classification entry. Active = currently in force, Superseded = replaced by newer entry, Withdrawn = no longer valid.' ;
    rdfs:domain ind:DotHazmatClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ergGuideNumber rdf:type rdf:Property ;
    rdfs:label 'Erg Guide Number' ;
    rdfs:comment 'Three-digit guide number from the DOT Emergency Response Guidebook that provides first responders with initial action guidance for incidents involving this material.' ;
    rdfs:domain ind:DotHazmatClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptedQuantityCode rdf:type rdf:Property ;
    rdfs:label 'Excepted Quantity Code' ;
    rdfs:comment 'Code (E0-E5) indicating the maximum quantity per inner packaging permitted under excepted quantity provisions, which allow minimal regulatory requirements for very small quantities.' ;
    rdfs:domain ind:DotHazmatClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptions rdf:type rdf:Property ;
    rdfs:label 'Exceptions' ;
    rdfs:comment 'Reference to regulatory sections (e.g., 173.###) that provide exceptions or reduced requirements for limited quantities, small quantities, or specific transport modes.' ;
    rdfs:domain ind:DotHazmatClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forbiddenCargoAircraft rdf:type rdf:Property ;
    rdfs:label 'Forbidden Cargo Aircraft' ;
    rdfs:comment 'Indicates whether transport of this material on cargo-only aircraft is prohibited under any circumstances.' ;
    rdfs:domain ind:DotHazmatClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:forbiddenPassengerAircraft rdf:type rdf:Property ;
    rdfs:label 'Forbidden Passenger Aircraft' ;
    rdfs:comment 'Indicates whether transport of this material on passenger-carrying aircraft is prohibited under any circumstances.' ;
    rdfs:domain ind:DotHazmatClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazardClass rdf:type rdf:Property ;
    rdfs:label 'Hazard Class' ;
    rdfs:comment 'Primary hazard class or division (1-9) assigned to the material based on its predominant hazard. Examples: 1.1 (explosives), 2.1 (flammable gas), 3 (flammable liquid), 4.1 (flammable solid), 5.1 (oxidizer), 6.1 (toxic), 7 (radioactive), 8 (corrosive), 9 (miscellaneous).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardDivision rdf:type rdf:Property ;
    rdfs:label 'Hazard Division' ;
    rdfs:comment 'Subdivision within a hazard class that further categorizes the material by specific hazard characteristics (e.g., 1.1, 1.2, 2.1, 2.2, 6.1). May be null for classes without divisions.' ;
    rdfs:domain ind:DotHazmatClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inhalationHazardZone rdf:type rdf:Property ;
    rdfs:label 'Inhalation Hazard Zone' ;
    rdfs:comment 'For materials that are poisonous by inhalation, the hazard zone (A, B, C, or D) indicating the degree of inhalation toxicity. Zone A is the most toxic.' ;
    rdfs:domain ind:DotHazmatClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:labelCode rdf:type rdf:Property ;
    rdfs:label 'Label Code' ;
    rdfs:comment 'Code(s) identifying the required hazard warning label(s) that must be affixed to packages. Multiple labels may be required for materials with subsidiary hazards. Examples: 3 (flammable liquid), 6.1 (poison), 8 (corrosive).' ;
    rdfs:domain ind:DotHazmatClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limitedQuantityEligible rdf:type rdf:Property ;
    rdfs:label 'Limited Quantity Eligible' ;
    rdfs:comment 'Indicates whether this material is eligible for limited quantity exceptions, which allow reduced packaging, marking, and labeling requirements when transported in small quantities.' ;
    rdfs:domain ind:DotHazmatClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:limitedQuantityMaxNet rdf:type rdf:Property ;
    rdfs:label 'Limited Quantity Max Net' ;
    rdfs:comment 'Maximum net quantity per inner receptacle or article permitted under limited quantity provisions. Expressed as weight or volume.' ;
    rdfs:domain ind:DotHazmatClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marinePollutant rdf:type rdf:Property ;
    rdfs:label 'Marine Pollutant' ;
    rdfs:comment 'Indicates whether the material is designated as a marine pollutant under DOT and International Maritime Dangerous Goods (IMDG) Code regulations. Requires special marking and handling for water transport.' ;
    rdfs:domain ind:DotHazmatClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:packagingAuthorizations rdf:type rdf:Property ;
    rdfs:label 'Packaging Authorizations' ;
    rdfs:comment 'Codes referencing the authorized packaging sections (e.g., 173.###) that specify which container types and specifications are approved for this material.' ;
    rdfs:domain ind:DotHazmatClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passengerAircraftQuantityLimit rdf:type rdf:Property ;
    rdfs:label 'Passenger Aircraft Quantity Limit' ;
    rdfs:comment 'Maximum net quantity per package permitted on passenger-carrying aircraft. May be expressed as weight (kg), volume (L), or \'Forbidden\' if not permitted.' ;
    rdfs:domain ind:DotHazmatClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:placardCode rdf:type rdf:Property ;
    rdfs:label 'Placard Code' ;
    rdfs:comment 'Code identifying the specific placard design required for the transport vehicle. Examples: FLAMMABLE, CORROSIVE, POISON, OXIDIZER, DANGEROUS.' ;
    rdfs:domain ind:DotHazmatClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:placardRequired rdf:type rdf:Property ;
    rdfs:label 'Placard Required' ;
    rdfs:comment 'Indicates whether placards must be displayed on the transport vehicle for this material when transported in specified quantities.' ;
    rdfs:domain ind:DotHazmatClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:severeMarinePollutant rdf:type rdf:Property ;
    rdfs:label 'Severe Marine Pollutant' ;
    rdfs:comment 'Indicates whether the material is classified as a severe marine pollutant (PP designation) requiring enhanced environmental protection measures during marine transport.' ;
    rdfs:domain ind:DotHazmatClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specialProvisions rdf:type rdf:Property ;
    rdfs:label 'Special Provisions' ;
    rdfs:comment 'Comma-separated list of special provision codes (e.g., B1, IB2, T4, TP1) that impose additional requirements or grant exceptions for packaging, handling, or transport of this material.' ;
    rdfs:domain ind:DotHazmatClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subsidiaryHazardClass rdf:type rdf:Property ;
    rdfs:label 'Subsidiary Hazard Class' ;
    rdfs:comment 'Secondary hazard class(es) for materials that present more than one type of hazard. Multiple subsidiary classes may be listed, separated by commas.' ;
    rdfs:domain ind:DotHazmatClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByUnNaNumber rdf:type rdf:Property ;
    rdfs:label 'Superseded By Un Na Number' ;
    rdfs:comment 'If this classification has been superseded, the UN/NA number of the replacement classification entry. Null if status is active.' ;
    rdfs:domain ind:DotHazmatClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalNameRequired rdf:type rdf:Property ;
    rdfs:label 'Technical Name Required' ;
    rdfs:comment 'Indicates whether the technical or chemical name of the hazardous constituent(s) must be entered in parentheses after the proper shipping name on shipping papers.' ;
    rdfs:domain ind:DotHazmatClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vesselStowageLocation rdf:type rdf:Property ;
    rdfs:label 'Vessel Stowage Location' ;
    rdfs:comment 'Code indicating where the material must be stowed on a vessel (e.g., A = on deck only, B = under deck, C = on or under deck). Applies to marine transport.' ;
    rdfs:domain ind:DotHazmatClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vesselStowageOther rdf:type rdf:Property ;
    rdfs:label 'Vessel Stowage Other' ;
    rdfs:comment 'Additional stowage requirements or restrictions for marine transport, such as segregation from other materials, ventilation requirements, or temperature controls.' ;
    rdfs:domain ind:DotHazmatClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buildingLocation rdf:type rdf:Property ;
    rdfs:label 'Building Location' ;
    rdfs:comment 'Physical building or structure identifier where the storage unit is located within the facility campus.' ;
    rdfs:domain ind:StorageUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Closure Certification Number' ;
    rdfs:comment 'Certification number issued by regulatory authority confirming that the storage unit closure was completed in accordance with RCRA requirements.' ;
    rdfs:domain ind:StorageUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentInventoryQuantity rdf:type rdf:Property ;
    rdfs:label 'Current Inventory Quantity' ;
    rdfs:comment 'Current quantity of hazardous waste stored in the unit at the time of last inventory update. Measured in the unit of measure specified for this storage unit.' ;
    rdfs:domain ind:StorageUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emergencyResponseZone rdf:type rdf:Property ;
    rdfs:label 'Emergency Response Zone' ;
    rdfs:comment 'Emergency response zone designation for this storage unit within the facility emergency action plan. Used for HAZWOPER response coordination.' ;
    rdfs:domain ind:StorageUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exemptionBasis rdf:type rdf:Property ;
    rdfs:label 'Exemption Basis' ;
    rdfs:comment 'Regulatory basis under which this storage unit operates without a full RCRA permit. Identifies the specific exemption category that applies.' ;
    rdfs:domain ind:StorageUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incompatibleWasteCodes rdf:type rdf:Property ;
    rdfs:label 'Incompatible Waste Codes' ;
    rdfs:comment 'Comma-separated list of EPA waste codes that must not be stored in this unit due to incompatibility concerns. Used to prevent dangerous chemical reactions.' ;
    rdfs:domain ind:StorageUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Inspection Frequency Days' ;
    rdfs:comment 'Required frequency for routine inspections of the storage unit measured in days. Satellite accumulation areas require weekly inspections; 90-day areas require daily inspections per RCRA.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inventoryUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Inventory Unit Of Measure' ;
    rdfs:comment 'Unit of measure used for tracking inventory quantity in this storage unit. Must align with the capacity measurement unit.' ;
    rdfs:domain ind:StorageUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumCapacityGallons rdf:type rdf:Property ;
    rdfs:label 'Maximum Capacity Gallons' ;
    rdfs:comment 'Maximum permitted storage capacity of the unit measured in gallons. Applicable for liquid waste storage tanks and container storage areas. Regulatory limit that must not be exceeded.' ;
    rdfs:domain ind:StorageUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumCapacityPounds rdf:type rdf:Property ;
    rdfs:label 'Maximum Capacity Pounds' ;
    rdfs:comment 'Maximum permitted storage capacity of the unit measured in pounds. Applicable for solid waste storage areas and satellite accumulation points. Regulatory limit that must not be exceeded.' ;
    rdfs:domain ind:StorageUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumTemperatureFahrenheit rdf:type rdf:Property ;
    rdfs:label 'Maximum Temperature Fahrenheit' ;
    rdfs:comment 'Maximum allowable temperature in Fahrenheit for safe storage of waste in this unit. Applicable when temperature control is required.' ;
    rdfs:domain ind:StorageUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumTemperatureFahrenheit rdf:type rdf:Property ;
    rdfs:label 'Minimum Temperature Fahrenheit' ;
    rdfs:comment 'Minimum allowable temperature in Fahrenheit for safe storage of waste in this unit. Applicable when temperature control is required.' ;
    rdfs:domain ind:StorageUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:roomAreaDesignation rdf:type rdf:Property ;
    rdfs:label 'Room Area Designation' ;
    rdfs:comment 'Specific room number, area code, or zone designation within the building for precise location identification.' ;
    rdfs:domain ind:StorageUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageTimeLimitDays rdf:type rdf:Property ;
    rdfs:label 'Storage Time Limit Days' ;
    rdfs:comment 'Maximum number of days that hazardous waste may be stored in this unit before shipment is required. Varies by unit type: satellite accumulation has no time limit until 55 gallons accumulated; 90-day areas have 90-day limit.' ;
    rdfs:domain ind:StorageUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:temperatureControlRequired rdf:type rdf:Property ;
    rdfs:label 'Temperature Control Required' ;
    rdfs:comment 'Indicates whether this storage unit requires active temperature control to maintain waste stability and prevent hazardous conditions. True for temperature-sensitive wastes.' ;
    rdfs:domain ind:StorageUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unitName rdf:type rdf:Property ;
    rdfs:label 'Unit Name' ;
    rdfs:comment 'Human-readable name or designation for the storage unit, used by facility personnel for identification and communication.' ;
    rdfs:domain ind:StorageUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitNumber rdf:type rdf:Property ;
    rdfs:label 'Unit Number' ;
    rdfs:comment 'Business identifier for the storage unit, used in facility documentation, permits, and operational tracking. Externally visible unit designation.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitStatus rdf:type rdf:Property ;
    rdfs:label 'Unit Status' ;
    rdfs:comment 'Current operational status of the storage unit in its lifecycle. Active units are available for waste storage; inactive units are temporarily out of service; closed units have completed closure procedures.' ;
    rdfs:domain ind:StorageUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitType rdf:type rdf:Property ;
    rdfs:label 'Unit Type' ;
    rdfs:comment 'Classification of the storage unit based on RCRA regulatory categories. Determines applicable storage time limits, capacity restrictions, and operational requirements. [ENUM-REF-CANDIDATE: satellite_accumulation_area|90_day_accumulation_area|permitted_storage_tank|container_storage_building|drip_pad|containment_building|less_than_90_day_area — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:StorageUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ventilationSystemType rdf:type rdf:Property ;
    rdfs:label 'Ventilation System Type' ;
    rdfs:comment 'Type of ventilation system installed to control vapor accumulation and maintain air quality in the storage area. Required for volatile hazardous waste storage.' ;
    rdfs:domain ind:StorageUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedForManifestUse rdf:type rdf:Property ;
    rdfs:label 'Approved For Manifest Use' ;
    rdfs:comment 'Boolean flag indicating whether this transporter is currently approved for use on hazardous waste manifests. False indicates transporter cannot be selected for new shipments.' ;
    rdfs:domain ind:TransporterRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:authorizedDotHazardClasses rdf:type rdf:Property ;
    rdfs:label 'Authorized Dot Hazard Classes' ;
    rdfs:comment 'Comma-separated list of DOT hazard classes (1-9) that the transporter is authorized to transport based on DOT operating authority and vehicle placarding.' ;
    rdfs:domain ind:TransporterRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedVehicleTypes rdf:type rdf:Property ;
    rdfs:label 'Authorized Vehicle Types' ;
    rdfs:comment 'Comma-separated list of vehicle types the transporter is authorized and equipped to operate for hazardous waste transport (e.g., tanker truck, box truck, flatbed, roll-off, vacuum truck).' ;
    rdfs:domain ind:TransporterRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedWasteCodes rdf:type rdf:Property ;
    rdfs:label 'Authorized Waste Codes' ;
    rdfs:comment 'Comma-separated list of EPA hazardous waste codes (D, F, K, P, U series) that the transporter is authorized and equipped to handle based on permits, equipment, and training.' ;
    rdfs:domain ind:TransporterRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cargoInsuranceCarrier rdf:type rdf:Property ;
    rdfs:label 'Cargo Insurance Carrier' ;
    rdfs:comment 'Name of the insurance company providing cargo insurance coverage for hazardous waste in transit.' ;
    rdfs:domain ind:TransporterRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cargoInsuranceCoverageAmount rdf:type rdf:Property ;
    rdfs:label 'Cargo Insurance Coverage Amount' ;
    rdfs:comment 'Total cargo insurance coverage amount in USD for hazardous waste shipments in transit.' ;
    rdfs:domain ind:TransporterRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cargoInsuranceExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Cargo Insurance Expiration Date' ;
    rdfs:comment 'Date when the current cargo insurance policy expires. Transporter must maintain continuous coverage to remain approved.' ;
    rdfs:domain ind:TransporterRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cargoInsurancePolicyNumber rdf:type rdf:Property ;
    rdfs:label 'Cargo Insurance Policy Number' ;
    rdfs:comment 'Policy number for the cargo insurance coverage protecting hazardous waste shipments in transit.' ;
    rdfs:domain ind:TransporterRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dotOperatingAuthorityNumber rdf:type rdf:Property ;
    rdfs:label 'Dot Operating Authority Number' ;
    rdfs:comment 'DOT motor carrier operating authority number (MC, FF, or MX number) required for interstate hazardous materials transportation. Format: MC-XXXXXX or FF-XXXXXX.' ;
    rdfs:domain ind:TransporterRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatEmployeeTrainingComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Hazmat Employee Training Compliance Status' ;
    rdfs:comment 'Current compliance status of the transporters HAZMAT employee training program per DOT HMR requirements. All drivers and handlers must receive training every 3 years.' ;
    rdfs:domain ind:TransporterRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatTrainingLastVerifiedDate rdf:type rdf:Property ;
    rdfs:label 'Hazmat Training Last Verified Date' ;
    rdfs:comment 'Date when Waste Management last verified that the transporter maintains compliant HAZMAT employee training records and certifications.' ;
    rdfs:domain ind:TransporterRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:liabilityInsuranceCarrier rdf:type rdf:Property ;
    rdfs:label 'Liability Insurance Carrier' ;
    rdfs:comment 'Name of the insurance company providing hazardous waste transporter liability coverage for this transporter.' ;
    rdfs:domain ind:TransporterRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liabilityInsuranceCoverageAmount rdf:type rdf:Property ;
    rdfs:label 'Liability Insurance Coverage Amount' ;
    rdfs:comment 'Total liability insurance coverage amount in USD. Minimum coverage requirements vary by waste type and quantity transported.' ;
    rdfs:domain ind:TransporterRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:liabilityInsuranceEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Liability Insurance Effective Date' ;
    rdfs:comment 'Date when the current liability insurance policy became effective.' ;
    rdfs:domain ind:TransporterRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:liabilityInsurancePolicyNumber rdf:type rdf:Property ;
    rdfs:label 'Liability Insurance Policy Number' ;
    rdfs:comment 'Policy number for the transporter liability insurance coverage. Required for RCRA compliance and vendor approval.' ;
    rdfs:domain ind:TransporterRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Review Date' ;
    rdfs:comment 'Date when the next periodic compliance and performance review is scheduled for this transporter.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:registrationStatus rdf:type rdf:Property ;
    rdfs:label 'Registration Status' ;
    rdfs:comment 'Current lifecycle status of the transporter registration. Active transporters are approved for use on manifests. Suspended or revoked transporters cannot be used.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyRating rdf:type rdf:Property ;
    rdfs:label 'Safety Rating' ;
    rdfs:comment 'Current FMCSA safety rating assigned to the motor carrier based on compliance reviews and safety performance. Unsatisfactory rating may disqualify transporter.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateTransporterPermitNumbers rdf:type rdf:Property ;
    rdfs:label 'State Transporter Permit Numbers' ;
    rdfs:comment 'Comma-separated list of state-specific hazardous waste transporter permit or license numbers. Some states require additional permits beyond EPA ID.' ;
    rdfs:domain ind:TransporterRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:streetAddress rdf:type rdf:Property ;
    rdfs:label 'Street Address' ;
    rdfs:comment 'Primary street address of the transporter company headquarters or principal place of business.' ;
    rdfs:domain ind:TransporterRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transporterDbaName rdf:type rdf:Property ;
    rdfs:label 'Transporter Dba Name' ;
    rdfs:comment 'Trade name or doing-business-as name used by the transporter, if different from legal name.' ;
    rdfs:domain ind:TransporterRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transporterLegalName rdf:type rdf:Property ;
    rdfs:label 'Transporter Legal Name' ;
    rdfs:comment 'The full legal business name of the hazardous waste transporter company as registered with EPA and state authorities.' ;
    rdfs:domain ind:TransporterRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usdotNumber rdf:type rdf:Property ;
    rdfs:label 'Usdot Number' ;
    rdfs:comment 'Unique USDOT identification number assigned by FMCSA for commercial motor vehicle operations. Required for all interstate carriers.' ;
    rdfs:domain ind:TransporterRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorPerformanceScore rdf:type rdf:Property ;
    rdfs:label 'Vendor Performance Score' ;
    rdfs:comment 'Internal performance score (0-100) based on on-time performance, compliance incidents, customer feedback, and service quality metrics.' ;
    rdfs:domain ind:TransporterRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:homeLandfillSiteId rdf:type rdf:Property ;
    rdfs:label 'Home Landfill Site Id' ;
    rdfs:comment 'Foreign key linking to landfill.site. Business justification: Fleet dispatch and route planning assign vehicles a primary disposal site. Tipping fee billing, permitted waste stream compliance, and daily route optimization all depend on knowing which landfill a v' ;
    rdfs:domain ind:Vehicle ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Site .

ind:homeYardFacilityId rdf:type rdf:Property ;
    rdfs:label 'Home Yard Facility Id' ;
    rdfs:comment 'Foreign key linking to asset.facility. Business justification: Vehicles are domiciled at a specific yard/facility for dispatch, maintenance cost center allocation, and regulatory compliance reporting. Fleet managers and finance teams require vehicle-to-facility a' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:operatingPermitId rdf:type rdf:Property ;
    rdfs:label 'Operating Permit Id' ;
    rdfs:comment 'Foreign key linking to compliance.permit. Business justification: Waste collection vehicles require operating permits for air emissions, hazmat transport, and noise ordinances. Regulatory compliance officers track permit status per vehicle for DOT/EPA audits. Natura' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Permit .

ind:serviceLineId rdf:type rdf:Property ;
    rdfs:label 'Service Line Id' ;
    rdfs:comment 'Foreign key linking to service.line. Business justification: Vehicles are physically configured and permitted for specific service lines (residential, commercial, roll-off, hazmat). Fleet dispatch, capacity planning, and regulatory compliance reports require kn' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Line .

ind:acquisitionDate rdf:type rdf:Property ;
    rdfs:label 'Acquisition Date' ;
    rdfs:comment 'Date the vehicle was acquired by Waste Management through purchase, lease, or other means.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:axleConfiguration rdf:type rdf:Property ;
    rdfs:label 'Axle Configuration' ;
    rdfs:comment 'Axle arrangement of the vehicle (e.g., 4x2, 6x4, 8x4) indicating total wheels and driven wheels.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bodyCapacityCubicYards rdf:type rdf:Property ;
    rdfs:label 'Body Capacity Cubic Yards' ;
    rdfs:comment 'Maximum volume capacity of the vehicle body measured in cubic yards.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bodyType rdf:type rdf:Property ;
    rdfs:label 'Body Type' ;
    rdfs:comment 'Type of vehicle body configuration. ASL = Automated Side Loader, FEL = Front End Loader, REL = Rear End Loader. [ENUM-REF-CANDIDATE: ASL|FEL|REL|Roll-Off|Transfer Tractor|Service Truck|Pickup|Van|Other — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdlRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Cdl Required Flag' ;
    rdfs:comment 'Indicates whether a Commercial Driver License (CDL) is required to operate this vehicle based on GVWR and vehicle class.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:compactionType rdf:type rdf:Property ;
    rdfs:label 'Compaction Type' ;
    rdfs:comment 'Type of waste compaction mechanism installed on the vehicle body.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentEngineHours rdf:type rdf:Property ;
    rdfs:label 'Current Engine Hours' ;
    rdfs:comment 'Most recent engine hour meter reading recorded for the vehicle.' ;
    rdfs:domain ind:Vehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:currentOdometerMiles rdf:type rdf:Property ;
    rdfs:label 'Current Odometer Miles' ;
    rdfs:comment 'Most recent odometer reading recorded for the vehicle, measured in miles.' ;
    rdfs:domain ind:Vehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dotNumber rdf:type rdf:Property ;
    rdfs:label 'Dot Number' ;
    rdfs:comment 'DOT registration number assigned to the vehicle for interstate commerce compliance.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emissionsCertification rdf:type rdf:Property ;
    rdfs:label 'Emissions Certification' ;
    rdfs:comment 'EPA emissions standard certification level (e.g., EPA 2010, EPA 2021, CARB compliant).' ;
    rdfs:domain ind:Vehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engineMake rdf:type rdf:Property ;
    rdfs:label 'Engine Make' ;
    rdfs:comment 'Manufacturer of the engine installed in the vehicle (e.g., Cummins, Detroit Diesel, Paccar).' ;
    rdfs:domain ind:Vehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engineModel rdf:type rdf:Property ;
    rdfs:label 'Engine Model' ;
    rdfs:comment 'Specific model designation of the engine.' ;
    rdfs:domain ind:Vehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engineSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Engine Serial Number' ;
    rdfs:comment 'Unique serial number assigned to the engine by the manufacturer for warranty and service tracking.' ;
    rdfs:domain ind:Vehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelTankCapacityGallons rdf:type rdf:Property ;
    rdfs:label 'Fuel Tank Capacity Gallons' ;
    rdfs:comment 'Total fuel tank capacity measured in gallons (or gallon-equivalent for CNG/RNG).' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gvwr rdf:type rdf:Property ;
    rdfs:label 'Gvwr' ;
    rdfs:comment 'Maximum operating weight of the vehicle including chassis, body, engine, fuel, driver, passengers, and cargo, measured in pounds.' ;
    rdfs:domain ind:Vehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hydraulicSystemType rdf:type rdf:Property ;
    rdfs:label 'Hydraulic System Type' ;
    rdfs:comment 'Type of hydraulic system used for compaction and lifting operations (applicable to collection vehicles).' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insurancePolicyNumber rdf:type rdf:Property ;
    rdfs:label 'Insurance Policy Number' ;
    rdfs:comment 'Policy number of the insurance coverage for this vehicle.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licensePlate rdf:type rdf:Property ;
    rdfs:label 'License Plate' ;
    rdfs:comment 'Current license plate number registered with the Department of Transportation (DOT) for this vehicle.' ;
    rdfs:domain ind:Vehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liftMechanism rdf:type rdf:Property ;
    rdfs:label 'Lift Mechanism' ;
    rdfs:comment 'Type of lifting mechanism used to pick up and empty containers or bins. [ENUM-REF-CANDIDATE: Automated Arm|Manual|Front Forks|Rear Forks|Hook Lift|Cable Hoist|N/A — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:make rdf:type rdf:Property ;
    rdfs:label 'Make' ;
    rdfs:comment 'Manufacturer of the vehicle (e.g., Mack, Peterbilt, Freightliner, International).' ;
    rdfs:domain ind:Vehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:model rdf:type rdf:Property ;
    rdfs:label 'Model' ;
    rdfs:comment 'Specific model designation of the vehicle as assigned by the manufacturer.' ;
    rdfs:domain ind:Vehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelYear rdf:type rdf:Property ;
    rdfs:label 'Model Year' ;
    rdfs:comment 'Year the vehicle was manufactured as designated by the manufacturer.' ;
    rdfs:domain ind:Vehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:payloadCapacityLbs rdf:type rdf:Property ;
    rdfs:label 'Payload Capacity Lbs' ;
    rdfs:comment 'Maximum weight of waste or cargo the vehicle can legally carry, measured in pounds.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:telematicsDeviceCode rdf:type rdf:Property ;
    rdfs:label 'Telematics Device Code' ;
    rdfs:comment 'Unique identifier of the GPS/telematics device installed on the vehicle for tracking and monitoring (e.g., Geotab device ID).' ;
    rdfs:domain ind:Vehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transmissionType rdf:type rdf:Property ;
    rdfs:label 'Transmission Type' ;
    rdfs:comment 'Type of transmission installed in the vehicle.' ;
    rdfs:domain ind:Vehicle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vin rdf:type rdf:Property ;
    rdfs:label 'Vin' ;
    rdfs:comment '17-character Vehicle Identification Number assigned by the manufacturer. Used for registration, insurance, and warranty tracking.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleRegistrationId rdf:type rdf:Property ;
    rdfs:label 'Vehicle Registration Id' ;
    rdfs:comment 'Unique identifier for the vehicle registration record. Primary key.' ;
    rdfs:domain ind:VehicleRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:annualInspectionDueDate rdf:type rdf:Property ;
    rdfs:label 'Annual Inspection Due Date' ;
    rdfs:comment 'Date by which the vehicle must complete its annual DOT safety inspection to maintain compliance. Failure to inspect by this date results in out-of-service status.' ;
    rdfs:domain ind:VehicleRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cabCardStorageLocation rdf:type rdf:Property ;
    rdfs:label 'Cab Card Storage Location' ;
    rdfs:comment 'Physical or digital location where the IRP cab card (registration document) is stored. Cab cards must be carried in the vehicle at all times for roadside inspection readiness.' ;
    rdfs:domain ind:VehicleRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossVehicleWeight rdf:type rdf:Property ;
    rdfs:label 'Gross Vehicle Weight' ;
    rdfs:comment 'Maximum allowable weight of the vehicle including cargo, as registered with the state DMV. Measured in pounds. Determines registration class and fee structure.' ;
    rdfs:domain ind:VehicleRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:iftaDecalNumber rdf:type rdf:Property ;
    rdfs:label 'Ifta Decal Number' ;
    rdfs:comment 'Unique identifier for the IFTA decal affixed to the vehicle. IFTA simplifies fuel tax reporting for commercial vehicles operating across multiple jurisdictions.' ;
    rdfs:domain ind:VehicleRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iftaExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Ifta Expiration Date' ;
    rdfs:comment 'Date when the IFTA decal expires and must be renewed. Typically aligns with calendar year end.' ;
    rdfs:domain ind:VehicleRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:irpApportionedFlag rdf:type rdf:Property ;
    rdfs:label 'Irp Apportioned Flag' ;
    rdfs:comment 'Indicates whether this vehicle is registered under the International Registration Plan (IRP), which allows commercial vehicles to travel across multiple jurisdictions with a single registration and apportioned fees.' ;
    rdfs:domain ind:VehicleRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:irpBaseJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Irp Base Jurisdiction' ;
    rdfs:comment 'Two-letter state or province code representing the base jurisdiction for IRP apportionment. This is where the carrier maintains its principal place of business.' ;
    rdfs:domain ind:VehicleRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irpFleetNumber rdf:type rdf:Property ;
    rdfs:label 'Irp Fleet Number' ;
    rdfs:comment 'Unique fleet identifier assigned under the IRP program. Used for tracking and reporting across multiple jurisdictions.' ;
    rdfs:domain ind:VehicleRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingState rdf:type rdf:Property ;
    rdfs:label 'Issuing State' ;
    rdfs:comment 'Two-letter state code where the vehicle registration was issued (e.g., TX, CA, IL).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lienHolderName rdf:type rdf:Property ;
    rdfs:label 'Lien Holder Name' ;
    rdfs:comment 'Name of the financial institution or entity holding a lien on the vehicle, if applicable. Recorded on the title and registration documents.' ;
    rdfs:domain ind:VehicleRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mcNumber rdf:type rdf:Property ;
    rdfs:label 'Mc Number' ;
    rdfs:comment 'Operating authority number issued by FMCSA for carriers transporting regulated commodities in interstate commerce. Not all vehicles require an MC number.' ;
    rdfs:domain ind:VehicleRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredOwnerAddress rdf:type rdf:Property ;
    rdfs:label 'Registered Owner Address' ;
    rdfs:comment 'Mailing address of the registered owner as recorded on the vehicle registration document. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:VehicleRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredOwnerName rdf:type rdf:Property ;
    rdfs:label 'Registered Owner Name' ;
    rdfs:comment 'Legal name of the entity or individual listed as the registered owner on the vehicle registration. Typically the company name for fleet vehicles.' ;
    rdfs:domain ind:VehicleRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationClass rdf:type rdf:Property ;
    rdfs:label 'Registration Class' ;
    rdfs:comment 'Classification of the vehicle registration as defined by state DMV regulations. Determines fee structure and operational restrictions.' ;
    rdfs:domain ind:VehicleRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Registration Document Url' ;
    rdfs:comment 'URL or file path to the digital copy of the vehicle registration document. Used for electronic record-keeping and roadside inspection readiness.' ;
    rdfs:domain ind:VehicleRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Registration Fee Amount' ;
    rdfs:comment 'Total fee paid for the vehicle registration, including base registration, IRP apportionment fees, and any applicable surcharges. Denominated in USD.' ;
    rdfs:domain ind:VehicleRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:registrationFeeCurrency rdf:type rdf:Property ;
    rdfs:label 'Registration Fee Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the registration fee. Typically USD for U.S. operations.' ;
    rdfs:domain ind:VehicleRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationNumber rdf:type rdf:Property ;
    rdfs:label 'Registration Number' ;
    rdfs:comment 'The official license plate or registration number issued by the state Department of Motor Vehicles (DMV). This is the externally-known identifier displayed on the vehicle.' ;
    rdfs:domain ind:VehicleRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Date' ;
    rdfs:comment 'Date when the registration was last renewed. Used to track renewal history and calculate next renewal cycle.' ;
    rdfs:domain ind:VehicleRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:titleNumber rdf:type rdf:Property ;
    rdfs:label 'Title Number' ;
    rdfs:comment 'Unique identifier for the vehicle title document issued by the state. Links registration to proof of ownership.' ;
    rdfs:domain ind:VehicleRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ucrRegistrationYear rdf:type rdf:Property ;
    rdfs:label 'Ucr Registration Year' ;
    rdfs:comment 'Calendar year for which the UCR registration is valid. UCR must be renewed annually.' ;
    rdfs:domain ind:VehicleRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ucrStatus rdf:type rdf:Property ;
    rdfs:label 'Ucr Status' ;
    rdfs:comment 'Current status of the Unified Carrier Registration for this vehicle. UCR is a federally-mandated registration system for commercial motor carriers operating in interstate commerce.' ;
    rdfs:domain ind:VehicleRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleYear rdf:type rdf:Property ;
    rdfs:label 'Vehicle Year' ;
    rdfs:comment 'Model year of the vehicle as recorded on the registration document.' ;
    rdfs:domain ind:VehicleRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cdlTrainingCertificationId rdf:type rdf:Property ;
    rdfs:label 'Cdl Training Certification Id' ;
    rdfs:comment 'Foreign key linking to compliance.training_certification. Business justification: CDL licenses, hazmat endorsements, and DOT medical certifications are regulatory training certifications. Driver qualification files require linking to certification records for FMCSA compliance audit' ;
    rdfs:domain ind:Driver ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TrainingCertification .

ind:homeDistrictId rdf:type rdf:Property ;
    rdfs:label 'Home District Id' ;
    rdfs:comment 'Reference to the primary operational district where the driver is based. Used for route assignment and workforce planning.' ;
    rdfs:domain ind:Driver ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:District .

ind:cdlClass rdf:type rdf:Property ;
    rdfs:label 'Cdl Class' ;
    rdfs:comment 'Classification of the Commercial Driver License indicating the types of vehicles the driver is authorized to operate. Class A for combination vehicles, Class B for heavy straight vehicles, Class C for smaller vehicles requiring placards or designed to transport 16+ passengers.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdlEndorsements rdf:type rdf:Property ;
    rdfs:label 'Cdl Endorsements' ;
    rdfs:comment 'Comma-separated list of CDL endorsements held by the driver (e.g., H for Hazmat, N for Tanker, T for Doubles/Triples, P for Passenger). Determines specialized vehicle and cargo authorization.' ;
    rdfs:domain ind:Driver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdlExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Cdl Expiration Date' ;
    rdfs:comment 'Date when the Commercial Driver License expires and must be renewed. Critical for DOT compliance monitoring.' ;
    rdfs:domain ind:Driver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cdlIssueDate rdf:type rdf:Property ;
    rdfs:label 'Cdl Issue Date' ;
    rdfs:comment 'Date when the current Commercial Driver License was issued by the state authority.' ;
    rdfs:domain ind:Driver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cdlNumber rdf:type rdf:Property ;
    rdfs:label 'Cdl Number' ;
    rdfs:comment 'Unique Commercial Driver License number issued by the state licensing authority. Required for all drivers operating commercial motor vehicles.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdlState rdf:type rdf:Property ;
    rdfs:label 'Cdl State' ;
    rdfs:comment 'Two-letter state code where the Commercial Driver License was issued (e.g., CA, TX, NY).' ;
    rdfs:domain ind:Driver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dotPhysicalExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Dot Physical Expiration Date' ;
    rdfs:comment 'Date when the DOT medical examiner certificate expires. Drivers must maintain current medical certification to operate commercial vehicles.' ;
    rdfs:domain ind:Driver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dotPhysicalIssueDate rdf:type rdf:Property ;
    rdfs:label 'Dot Physical Issue Date' ;
    rdfs:comment 'Date when the current DOT medical examiner certificate was issued.' ;
    rdfs:domain ind:Driver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:drugAlcoholProgramEnrollmentDate rdf:type rdf:Property ;
    rdfs:label 'Drug Alcohol Program Enrollment Date' ;
    rdfs:comment 'Date when the driver was enrolled in the DOT drug and alcohol testing program.' ;
    rdfs:domain ind:Driver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:drugAlcoholProgramEnrollmentFlag rdf:type rdf:Property ;
    rdfs:label 'Drug Alcohol Program Enrollment Flag' ;
    rdfs:comment 'Indicates whether the driver is enrolled in the DOT-mandated drug and alcohol testing program. Required for all CDL drivers.' ;
    rdfs:domain ind:Driver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazmatClearanceExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Hazmat Clearance Expiration Date' ;
    rdfs:comment 'Expiration date of the driver\'s TSA security threat assessment clearance required for Hazmat endorsement. Must be renewed every five years.' ;
    rdfs:domain ind:Driver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:hazmatEndorsementFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Endorsement Flag' ;
    rdfs:comment 'Indicates whether the driver holds a valid Hazmat endorsement on their CDL, required for transporting hazardous waste materials subject to RCRA regulations.' ;
    rdfs:domain ind:Driver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hireDate rdf:type rdf:Property ;
    rdfs:label 'Hire Date' ;
    rdfs:comment 'Date when the driver was hired by Waste Management. Used for seniority, tenure analysis, and route assignment priority.' ;
    rdfs:domain ind:Driver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastAlcoholTestDate rdf:type rdf:Property ;
    rdfs:label 'Last Alcohol Test Date' ;
    rdfs:comment 'Date of the driver\'s most recent alcohol test (pre-employment, random, post-accident, reasonable suspicion, or return-to-duty).' ;
    rdfs:domain ind:Driver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastAlcoholTestResult rdf:type rdf:Property ;
    rdfs:label 'Last Alcohol Test Result' ;
    rdfs:comment 'Result of the driver\'s most recent alcohol test. Positive results (BAC >= 0.04) or refusals trigger disqualification.' ;
    rdfs:domain ind:Driver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastDrugTestDate rdf:type rdf:Property ;
    rdfs:label 'Last Drug Test Date' ;
    rdfs:comment 'Date of the driver\'s most recent drug test (pre-employment, random, post-accident, reasonable suspicion, or return-to-duty).' ;
    rdfs:domain ind:Driver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastDrugTestResult rdf:type rdf:Property ;
    rdfs:label 'Last Drug Test Result' ;
    rdfs:comment 'Result of the driver\'s most recent drug test. Positive results or refusals trigger disqualification and return-to-duty protocols.' ;
    rdfs:domain ind:Driver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastQualificationReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Qualification Review Date' ;
    rdfs:comment 'Date when the driver\'s qualification file was last reviewed for completeness and compliance with DOT requirements.' ;
    rdfs:domain ind:Driver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:medicalExaminerCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Medical Examiner Certificate Number' ;
    rdfs:comment 'Unique identifier for the driver\'s DOT medical examiner certificate. Required to demonstrate physical fitness to operate commercial motor vehicles.' ;
    rdfs:domain ind:Driver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalExaminerName rdf:type rdf:Property ;
    rdfs:label 'Medical Examiner Name' ;
    rdfs:comment 'Name of the certified medical examiner who issued the DOT physical certificate.' ;
    rdfs:domain ind:Driver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mvrLastReviewDate rdf:type rdf:Property ;
    rdfs:label 'Mvr Last Review Date' ;
    rdfs:comment 'Date when the driver\'s Motor Vehicle Record was last reviewed by the fleet safety department. DOT requires annual MVR reviews.' ;
    rdfs:domain ind:Driver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mvrNextReviewDueDate rdf:type rdf:Property ;
    rdfs:label 'Mvr Next Review Due Date' ;
    rdfs:comment 'Date when the next Motor Vehicle Record review is due. Used for compliance tracking and proactive safety management.' ;
    rdfs:domain ind:Driver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mvrStatus rdf:type rdf:Property ;
    rdfs:label 'Mvr Status' ;
    rdfs:comment 'Current status of the driver\'s Motor Vehicle Record based on the most recent review. Indicates driving history and violation status for risk assessment and DOT compliance.' ;
    rdfs:domain ind:Driver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextQualificationReviewDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Qualification Review Due Date' ;
    rdfs:comment 'Date when the next driver qualification file review is due. Used for proactive compliance management.' ;
    rdfs:domain ind:Driver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:primaryRouteType rdf:type rdf:Property ;
    rdfs:label 'Primary Route Type' ;
    rdfs:comment 'Primary type of collection route the driver is assigned to. Determines vehicle type and operational requirements.' ;
    rdfs:domain ind:Driver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationStatus rdf:type rdf:Property ;
    rdfs:label 'Qualification Status' ;
    rdfs:comment 'Current qualification status of the driver based on DOT requirements, medical certification, license validity, and company safety standards. Determines whether the driver is authorized to operate fleet vehicles.' ;
    rdfs:domain ind:Driver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyScore rdf:type rdf:Property ;
    rdfs:label 'Safety Score' ;
    rdfs:comment 'Composite safety score based on driving behavior, incident history, and compliance metrics captured from Geotab Fleet Telematics. Scale 0-100, higher is better.' ;
    rdfs:domain ind:Driver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalMilesDriven rdf:type rdf:Property ;
    rdfs:label 'Total Miles Driven' ;
    rdfs:comment 'Cumulative total miles driven by the driver across all fleet vehicles since hire date. Used for experience assessment and performance analysis.' ;
    rdfs:domain ind:Driver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dispatchFacilityId rdf:type rdf:Property ;
    rdfs:label 'Dispatch Facility Id' ;
    rdfs:comment 'Foreign key linking to asset.facility. Business justification: Vehicle assignments are dispatched from a specific yard/facility. Linking to asset.facility enables facility-level dispatch reporting, shift cost allocation by yard, and operational capacity planning.' ;
    rdfs:domain ind:VehicleAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:assignmentDate rdf:type rdf:Property ;
    rdfs:label 'Assignment Date' ;
    rdfs:comment 'The calendar date for which this vehicle assignment is effective. Represents the operational day of the assignment.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cdlVerified rdf:type rdf:Property ;
    rdfs:label 'Cdl Verified' ;
    rdfs:comment 'Boolean flag indicating whether the drivers Commercial Driver License (CDL) was verified as valid and appropriate for the vehicle class at the time of assignment. Required for DOT compliance.' ;
    rdfs:domain ind:VehicleAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:defectsReported rdf:type rdf:Property ;
    rdfs:label 'Defects Reported' ;
    rdfs:comment 'Boolean flag indicating whether any vehicle defects or maintenance issues were reported during the pre-trip or post-trip inspection for this assignment.' ;
    rdfs:domain ind:VehicleAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:engineHoursEnd rdf:type rdf:Property ;
    rdfs:label 'Engine Hours End' ;
    rdfs:comment 'The cumulative engine operating hours at the end of the assignment. Used for preventive maintenance scheduling and asset lifecycle management.' ;
    rdfs:domain ind:VehicleAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:engineHoursStart rdf:type rdf:Property ;
    rdfs:label 'Engine Hours Start' ;
    rdfs:comment 'The cumulative engine operating hours at the beginning of the assignment. Used for preventive maintenance scheduling and asset lifecycle management.' ;
    rdfs:domain ind:VehicleAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelLevelEndPercent rdf:type rdf:Property ;
    rdfs:label 'Fuel Level End Percent' ;
    rdfs:comment 'The fuel tank level as a percentage at the end of the assignment. Used for fuel consumption tracking and refueling planning.' ;
    rdfs:domain ind:VehicleAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelLevelStartPercent rdf:type rdf:Property ;
    rdfs:label 'Fuel Level Start Percent' ;
    rdfs:comment 'The fuel tank level as a percentage at the beginning of the assignment. Used for fuel consumption tracking and refueling planning.' ;
    rdfs:domain ind:VehicleAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hosCompliant rdf:type rdf:Property ;
    rdfs:label 'Hos Compliant' ;
    rdfs:comment 'Boolean flag indicating whether the driver was in compliance with Hours of Service (HOS) regulations at the time of assignment. Ensures driver has adequate rest and is within allowable driving hours.' ;
    rdfs:domain ind:VehicleAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postTripInspectionCompleted rdf:type rdf:Property ;
    rdfs:label 'Post Trip Inspection Completed' ;
    rdfs:comment 'Boolean flag indicating whether the driver completed the mandatory post-trip vehicle inspection after completing the shift. Required for DOT compliance and vehicle maintenance tracking.' ;
    rdfs:domain ind:VehicleAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postTripInspectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Post Trip Inspection Timestamp' ;
    rdfs:comment 'The timestamp when the post-trip inspection was completed and recorded. Used for compliance audit trail.' ;
    rdfs:domain ind:VehicleAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:preTripInspectionCompleted rdf:type rdf:Property ;
    rdfs:label 'Pre Trip Inspection Completed' ;
    rdfs:comment 'Boolean flag indicating whether the driver completed the mandatory pre-trip vehicle inspection before beginning the shift. Required for DOT compliance.' ;
    rdfs:domain ind:VehicleAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:returnLocation rdf:type rdf:Property ;
    rdfs:label 'Return Location' ;
    rdfs:comment 'The facility or yard location to which the vehicle was returned at the end of the assignment. May differ from dispatch location for transfer operations.' ;
    rdfs:domain ind:VehicleAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyIncidentOccurred rdf:type rdf:Property ;
    rdfs:label 'Safety Incident Occurred' ;
    rdfs:comment 'Boolean flag indicating whether any safety incident, accident, or near-miss event occurred during this vehicle assignment. Triggers incident investigation and reporting workflow.' ;
    rdfs:domain ind:VehicleAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:telematicsEventId rdf:type rdf:Property ;
    rdfs:label 'Telematics Event Id' ;
    rdfs:comment 'Unique identifier for each telematics event record captured from the vehicle tracking system.' ;
    rdfs:domain ind:TelematicsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:altitudeFeet rdf:type rdf:Property ;
    rdfs:label 'Altitude Feet' ;
    rdfs:comment 'Elevation of the vehicle above sea level measured in feet at the time of the event.' ;
    rdfs:domain ind:TelematicsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batteryVoltage rdf:type rdf:Property ;
    rdfs:label 'Battery Voltage' ;
    rdfs:comment 'Vehicle battery voltage measured in volts at the time of the event.' ;
    rdfs:domain ind:TelematicsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coolantTemperatureFahrenheit rdf:type rdf:Property ;
    rdfs:label 'Coolant Temperature Fahrenheit' ;
    rdfs:comment 'Engine coolant temperature measured in degrees Fahrenheit at the time of the event.' ;
    rdfs:domain ind:TelematicsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deviceSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Device Serial Number' ;
    rdfs:comment 'Unique serial number of the telematics tracking device installed in the vehicle.' ;
    rdfs:domain ind:TelematicsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engineLoadPercent rdf:type rdf:Property ;
    rdfs:label 'Engine Load Percent' ;
    rdfs:comment 'Percentage of maximum engine load being utilized at the time of the event.' ;
    rdfs:domain ind:TelematicsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:engineRpm rdf:type rdf:Property ;
    rdfs:label 'Engine Rpm' ;
    rdfs:comment 'Engine speed measured in revolutions per minute at the time of the event.' ;
    rdfs:domain ind:TelematicsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fuelConsumptionGallons rdf:type rdf:Property ;
    rdfs:label 'Fuel Consumption Gallons' ;
    rdfs:comment 'Cumulative fuel consumed by the vehicle measured in gallons since the last reset or event.' ;
    rdfs:domain ind:TelematicsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelLevelPercent rdf:type rdf:Property ;
    rdfs:label 'Fuel Level Percent' ;
    rdfs:comment 'Percentage of fuel remaining in the vehicle tank at the time of the event.' ;
    rdfs:domain ind:TelematicsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:harshAccelerationFlag rdf:type rdf:Property ;
    rdfs:label 'Harsh Acceleration Flag' ;
    rdfs:comment 'Indicator of whether a harsh acceleration event occurred based on acceleration thresholds.' ;
    rdfs:domain ind:TelematicsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:harshBrakingFlag rdf:type rdf:Property ;
    rdfs:label 'Harsh Braking Flag' ;
    rdfs:comment 'Indicator of whether a harsh braking event occurred based on deceleration thresholds.' ;
    rdfs:domain ind:TelematicsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:headingDegrees rdf:type rdf:Property ;
    rdfs:label 'Heading Degrees' ;
    rdfs:comment 'Compass direction the vehicle is traveling measured in degrees from 0 to 359 where 0 is north.' ;
    rdfs:domain ind:TelematicsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:idleDurationFlag rdf:type rdf:Property ;
    rdfs:label 'Idle Duration Flag' ;
    rdfs:comment 'Indicator of whether the vehicle was idling for an extended period at the time of the event.' ;
    rdfs:domain ind:TelematicsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:idleTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Idle Time Minutes' ;
    rdfs:comment 'Duration of time the vehicle engine was running while stationary measured in minutes.' ;
    rdfs:domain ind:TelematicsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ignitionStatus rdf:type rdf:Property ;
    rdfs:label 'Ignition Status' ;
    rdfs:comment 'Current state of the vehicle ignition indicating whether the engine is running or off.' ;
    rdfs:domain ind:TelematicsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:odometerMiles rdf:type rdf:Property ;
    rdfs:label 'Odometer Miles' ;
    rdfs:comment 'Total cumulative distance traveled by the vehicle in miles as recorded at the time of the event.' ;
    rdfs:domain ind:TelematicsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postedSpeedLimitMph rdf:type rdf:Property ;
    rdfs:label 'Posted Speed Limit Mph' ;
    rdfs:comment 'Legal speed limit at the vehicles location at the time of the event in miles per hour.' ;
    rdfs:domain ind:TelematicsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ptoStatus rdf:type rdf:Property ;
    rdfs:label 'Pto Status' ;
    rdfs:comment 'Current state of the power take-off mechanism indicating whether it is engaged for auxiliary equipment operation.' ;
    rdfs:domain ind:TelematicsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:satelliteCount rdf:type rdf:Property ;
    rdfs:label 'Satellite Count' ;
    rdfs:comment 'Number of GPS satellites used to determine the vehicles location at the time of the event.' ;
    rdfs:domain ind:TelematicsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seatbeltStatus rdf:type rdf:Property ;
    rdfs:label 'Seatbelt Status' ;
    rdfs:comment 'Current state of the driver seatbelt indicating whether it is fastened or unfastened.' ;
    rdfs:domain ind:TelematicsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:speedingFlag rdf:type rdf:Property ;
    rdfs:label 'Speeding Flag' ;
    rdfs:comment 'Indicator of whether the vehicle was exceeding the posted speed limit at the time of the event.' ;
    rdfs:domain ind:TelematicsEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vehicleSpeedMph rdf:type rdf:Property ;
    rdfs:label 'Vehicle Speed Mph' ;
    rdfs:comment 'Instantaneous speed of the vehicle at the time of the event measured in miles per hour.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelTransactionId rdf:type rdf:Property ;
    rdfs:label 'Fuel Transaction Id' ;
    rdfs:comment 'Unique identifier for the fuel transaction record. Primary key.' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fuelingFacilityId rdf:type rdf:Property ;
    rdfs:label 'Fueling Facility Id' ;
    rdfs:comment 'Foreign key linking to asset.facility. Business justification: Fuel transactions at company-owned yards must be linked to the dispensing facility for underground storage tank (UST) compliance reporting, EPA environmental tracking, facility-level fuel cost allocat' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:authorizationCode rdf:type rdf:Property ;
    rdfs:label 'Authorization Code' ;
    rdfs:comment 'Authorization or approval code from the fuel card processor or yard pump system. Used for transaction reconciliation and dispute resolution.' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenter rdf:type rdf:Property ;
    rdfs:label 'Cost Center' ;
    rdfs:comment 'SAP cost center to which this fuel transaction cost is allocated. Supports financial reporting and budget tracking by operational unit.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defQuantityDispensed rdf:type rdf:Property ;
    rdfs:label 'Def Quantity Dispensed' ;
    rdfs:comment 'Volume of DEF (Diesel Exhaust Fluid) dispensed in gallons during this transaction. Required for diesel vehicles with SCR emissions systems to meet EPA standards.' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelCardNumber rdf:type rdf:Property ;
    rdfs:label 'Fuel Card Number' ;
    rdfs:comment 'Fleet fuel card number used for the transaction. Masked or tokenized for security. Used to reconcile with fuel card provider statements.' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelGrade rdf:type rdf:Property ;
    rdfs:label 'Fuel Grade' ;
    rdfs:comment 'Grade or specification of the fuel dispensed. ULSD = Ultra-Low Sulfur Diesel; B5/B20 = biodiesel blend percentages. Ensures compliance with vehicle manufacturer specifications.' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccount rdf:type rdf:Property ;
    rdfs:label 'Gl Account' ;
    rdfs:comment 'General ledger account code for fuel expense posting in SAP FI. Varies by fuel type and vehicle class.' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iftaJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Ifta Jurisdiction' ;
    rdfs:comment 'Two-letter state/province code where fuel was purchased. Required for IFTA quarterly fuel tax reporting for interstate commercial vehicles.' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isEmergencyFuel rdf:type rdf:Property ;
    rdfs:label 'Is Emergency Fuel' ;
    rdfs:comment 'Flag indicating whether this was an unplanned emergency fueling event (e.g., vehicle ran low on route). Used to identify route planning issues and driver behavior patterns.' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:odometerReading rdf:type rdf:Property ;
    rdfs:label 'Odometer Reading' ;
    rdfs:comment 'Vehicle odometer reading in miles at the time of fueling. Used to calculate fuel economy (MPG or MPGe) and validate vehicle utilization.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Pre Tax Amount' ;
    rdfs:comment 'Transaction cost before fuel taxes. Calculated as total_cost minus tax_amount. Used for cost analysis and vendor invoice reconciliation.' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pumpNumber rdf:type rdf:Property ;
    rdfs:label 'Pump Number' ;
    rdfs:comment 'Identifier of the specific fuel pump or dispenser used at the fueling station. Supports pump-level performance tracking and maintenance.' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityDispensed rdf:type rdf:Property ;
    rdfs:label 'Quantity Dispensed' ;
    rdfs:comment 'Volume or energy-equivalent quantity of fuel dispensed. For liquid fuels measured in gallons; for CNG/RNG measured in GGE (Gasoline Gallon Equivalent).' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stationType rdf:type rdf:Property ;
    rdfs:label 'Station Type' ;
    rdfs:comment 'Classification of the fueling station. Company yard = internal fleet facility; public station = commercial retail; CNG station = specialized compressed natural gas facility.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionSource rdf:type rdf:Property ;
    rdfs:label 'Transaction Source' ;
    rdfs:comment 'System or method that captured this fuel transaction. Fleet card = commercial fuel card network; yard pump = internal automated pump; telematics = vehicle onboard system; manual entry = driver-reported.' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transaction Timestamp' ;
    rdfs:comment 'Date and time when the fuel dispensing transaction occurred. Captured from fuel card system or yard pump controller.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:vendorName rdf:type rdf:Property ;
    rdfs:label 'Vendor Name' ;
    rdfs:comment 'Name of the fuel vendor or station operator (e.g., Shell, BP, internal fleet services). Used for vendor performance analysis and contract compliance.' ;
    rdfs:domain ind:FuelTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dotInspectionId rdf:type rdf:Property ;
    rdfs:label 'Dot Inspection Id' ;
    rdfs:comment 'Unique identifier for the DOT inspection record. Primary key.' ;
    rdfs:domain ind:DotInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:basicCategory rdf:type rdf:Property ;
    rdfs:label 'Basic Category' ;
    rdfs:comment 'CSA BASIC category that the violations fall under (e.g., Unsafe Driving, Hours of Service Compliance, Vehicle Maintenance, Controlled Substances/Alcohol, Driver Fitness, Hazardous Materials Compliance, Crash Indicator). [ENUM-REF-CANDIDATE: Unsafe Driving|Hours of Service|Vehicle Maintenance|Controlled Substances|Driver Fitness|Hazardous Materials|Crash Indicator — promote to reference product]' ;
    rdfs:domain ind:DotInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierDotNumber rdf:type rdf:Property ;
    rdfs:label 'Carrier Dot Number' ;
    rdfs:comment 'USDOT number of the carrier at the time of inspection. Seven-digit identifier assigned by FMCSA.' ;
    rdfs:domain ind:DotInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Completed Date' ;
    rdfs:comment 'Date when all required corrective actions were completed and verified.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:csaScoreImpact rdf:type rdf:Property ;
    rdfs:label 'Csa Score Impact' ;
    rdfs:comment 'Calculated impact of this inspection on the carrier\'s CSA score.' ;
    rdfs:domain ind:DotInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:driverLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Driver License Number' ;
    rdfs:comment 'CDL number of the driver at the time of inspection. Recorded for compliance tracking.' ;
    rdfs:domain ind:DotInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:driverLicenseState rdf:type rdf:Property ;
    rdfs:label 'Driver License State' ;
    rdfs:comment 'Two-letter state code of the issuing state for the driver\'s CDL.' ;
    rdfs:domain ind:DotInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:driverOosFlag rdf:type rdf:Property ;
    rdfs:label 'Driver Oos Flag' ;
    rdfs:comment 'Boolean flag indicating whether the driver specifically was placed out of service.' ;
    rdfs:domain ind:DotInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectionCategory rdf:type rdf:Property ;
    rdfs:label 'Inspection Category' ;
    rdfs:comment 'Category or context of the inspection event (roadside stop, scheduled annual inspection, state patrol enforcement, terminal audit, compliance review, or random selection).' ;
    rdfs:domain ind:DotInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Inspection Document Url' ;
    rdfs:comment 'URL or file path to the scanned or digital copy of the official inspection report.' ;
    rdfs:domain ind:DotInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Inspection Duration Minutes' ;
    rdfs:comment 'Total duration of the inspection in minutes.' ;
    rdfs:domain ind:DotInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inspectionLocation rdf:type rdf:Property ;
    rdfs:label 'Inspection Location' ;
    rdfs:comment 'Physical location where the inspection was conducted (address, weigh station name, or facility identifier).' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionNotes rdf:type rdf:Property ;
    rdfs:label 'Inspection Notes' ;
    rdfs:comment 'Additional notes or comments recorded by the inspector during the inspection.' ;
    rdfs:domain ind:DotInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionReportNumber rdf:type rdf:Property ;
    rdfs:label 'Inspection Report Number' ;
    rdfs:comment 'Official inspection report number issued by the inspector or enforcement agency. Unique identifier for the inspection event in DOT/CVSA systems.' ;
    rdfs:domain ind:DotInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionState rdf:type rdf:Property ;
    rdfs:label 'Inspection State' ;
    rdfs:comment 'Two-letter state code where the inspection occurred.' ;
    rdfs:domain ind:DotInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectorAgency rdf:type rdf:Property ;
    rdfs:label 'Inspector Agency' ;
    rdfs:comment 'Name of the enforcement agency or organization that conducted the inspection (e.g., State Highway Patrol, DOT, CVSA).' ;
    rdfs:domain ind:DotInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectorBadgeNumber rdf:type rdf:Property ;
    rdfs:label 'Inspector Badge Number' ;
    rdfs:comment 'Official badge or identification number of the inspector.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oosViolationCount rdf:type rdf:Property ;
    rdfs:label 'Oos Violation Count' ;
    rdfs:comment 'Number of violations that met FMCSA out-of-service criteria.' ;
    rdfs:domain ind:DotInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:outOfServiceFlag rdf:type rdf:Property ;
    rdfs:label 'Out Of Service Flag' ;
    rdfs:comment 'Boolean flag indicating whether the vehicle or driver was placed out of service as a result of the inspection. True if OOS order was issued.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:severityWeight rdf:type rdf:Property ;
    rdfs:label 'Severity Weight' ;
    rdfs:comment 'Severity weight assigned to the violations for CSA scoring purposes (1-10 scale, with 10 being most severe).' ;
    rdfs:domain ind:DotInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vehicleOdometerReading rdf:type rdf:Property ;
    rdfs:label 'Vehicle Odometer Reading' ;
    rdfs:comment 'Odometer reading of the vehicle at the time of inspection, in miles.' ;
    rdfs:domain ind:DotInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vehicleOosFlag rdf:type rdf:Property ;
    rdfs:label 'Vehicle Oos Flag' ;
    rdfs:comment 'Boolean flag indicating whether the vehicle specifically was placed out of service.' ;
    rdfs:domain ind:DotInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:violationCodes rdf:type rdf:Property ;
    rdfs:label 'Violation Codes' ;
    rdfs:comment 'Comma-separated list of FMCSA violation codes cited during the inspection (e.g., 393.75B, 396.3A1).' ;
    rdfs:domain ind:DotInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationDescription rdf:type rdf:Property ;
    rdfs:label 'Violation Description' ;
    rdfs:comment 'Detailed description of the violations found during the inspection, including inspector notes.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionFacilityId rdf:type rdf:Property ;
    rdfs:label 'Inspection Facility Id' ;
    rdfs:comment 'Foreign key linking to asset.facility. Business justification: Pre/post-trip inspections are conducted at the home yard facility before and after each shift. Linking to the facility enables facility-level FMCSA compliance reporting, safety audit aggregation by ya' ;
    rdfs:domain ind:PrePostTripInspection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:bodyFrameStatus rdf:type rdf:Property ;
    rdfs:label 'Body Frame Status' ;
    rdfs:comment 'Inspection result for the vehicle body, frame, and structural integrity including container body, hydraulic systems, and visible damage.' ;
    rdfs:domain ind:PrePostTripInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brakesStatus rdf:type rdf:Property ;
    rdfs:label 'Brakes Status' ;
    rdfs:comment 'Inspection result for the vehicle braking system including service brakes, parking brake, and emergency brake.' ;
    rdfs:domain ind:PrePostTripInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:couplingDevicesStatus rdf:type rdf:Property ;
    rdfs:label 'Coupling Devices Status' ;
    rdfs:comment 'Inspection result for fifth wheel, pintle hook, or other coupling devices used to attach trailers.' ;
    rdfs:domain ind:PrePostTripInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectReportedFlag rdf:type rdf:Property ;
    rdfs:label 'Defect Reported Flag' ;
    rdfs:comment 'Indicates whether any defects or safety concerns were identified during the inspection that require maintenance attention.' ;
    rdfs:domain ind:PrePostTripInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:defectSeverity rdf:type rdf:Property ;
    rdfs:label 'Defect Severity' ;
    rdfs:comment 'Classification of the defect severity: critical (vehicle out-of-service), major (requires immediate attention), or minor (can be scheduled for repair).' ;
    rdfs:domain ind:PrePostTripInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:driverSignatureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Driver Signature Timestamp' ;
    rdfs:comment 'The date and time when the driver electronically signed or certified the inspection report.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:emergencyEquipmentStatus rdf:type rdf:Property ;
    rdfs:label 'Emergency Equipment Status' ;
    rdfs:comment 'Inspection result for emergency equipment including fire extinguisher, warning triangles, first aid kit, and spill kit.' ;
    rdfs:domain ind:PrePostTripInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exhaustSystemStatus rdf:type rdf:Property ;
    rdfs:label 'Exhaust System Status' ;
    rdfs:comment 'Inspection result for the exhaust system including muffler, pipes, and emissions control components.' ;
    rdfs:domain ind:PrePostTripInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelSystemStatus rdf:type rdf:Property ;
    rdfs:label 'Fuel System Status' ;
    rdfs:comment 'Inspection result for the fuel system including tank, lines, and connections for leaks or damage. Applies to diesel, CNG, and RNG fuel systems.' ;
    rdfs:domain ind:PrePostTripInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hornStatus rdf:type rdf:Property ;
    rdfs:label 'Horn Status' ;
    rdfs:comment 'Inspection result for the vehicle horn functionality.' ;
    rdfs:domain ind:PrePostTripInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionSource rdf:type rdf:Property ;
    rdfs:label 'Inspection Source' ;
    rdfs:comment 'The method or system used to capture the inspection data: mobile application, paper form (later digitized), or telematics system.' ;
    rdfs:domain ind:PrePostTripInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lightsStatus rdf:type rdf:Property ;
    rdfs:label 'Lights Status' ;
    rdfs:comment 'Inspection result for all vehicle lighting including headlights, taillights, brake lights, turn signals, and hazard lights.' ;
    rdfs:domain ind:PrePostTripInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mechanicAcknowledgmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Mechanic Acknowledgment Timestamp' ;
    rdfs:comment 'The date and time when the mechanic reviewed and acknowledged the inspection report, required for regulatory compliance.' ;
    rdfs:domain ind:PrePostTripInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:mirrorsStatus rdf:type rdf:Property ;
    rdfs:label 'Mirrors Status' ;
    rdfs:comment 'Inspection result for all vehicle mirrors including side mirrors and rearview mirrors for proper adjustment and condition.' ;
    rdfs:domain ind:PrePostTripInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:steeringStatus rdf:type rdf:Property ;
    rdfs:label 'Steering Status' ;
    rdfs:comment 'Inspection result for the steering system including steering wheel, linkage, and power steering operation.' ;
    rdfs:domain ind:PrePostTripInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suspensionStatus rdf:type rdf:Property ;
    rdfs:label 'Suspension Status' ;
    rdfs:comment 'Inspection result for the vehicle suspension system including springs, shocks, and air suspension components.' ;
    rdfs:domain ind:PrePostTripInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tiresStatus rdf:type rdf:Property ;
    rdfs:label 'Tires Status' ;
    rdfs:comment 'Inspection result for all vehicle tires including tread depth, inflation, and visible damage.' ;
    rdfs:domain ind:PrePostTripInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trailerUnitNumber rdf:type rdf:Property ;
    rdfs:label 'Trailer Unit Number' ;
    rdfs:comment 'The fleet unit number or asset tag of the trailer inspected, if applicable.' ;
    rdfs:domain ind:PrePostTripInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wipersStatus rdf:type rdf:Property ;
    rdfs:label 'Wipers Status' ;
    rdfs:comment 'Inspection result for windshield wipers and washer system functionality.' ;
    rdfs:domain ind:PrePostTripInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryHosDriverId rdf:type rdf:Property ;
    rdfs:label 'Primary Hos Driver Id' ;
    rdfs:comment 'Identifier of the Commercial Driver\'s License (CDL) driver who generated this HOS log entry.' ;
    rdfs:domain ind:HosLog ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Driver .

ind:breakComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Break Compliance Flag' ;
    rdfs:comment 'Boolean flag indicating whether the driver has taken the required 30-minute break after 8 hours of driving time, as mandated by FMCSA.' ;
    rdfs:domain ind:HosLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificationStatus rdf:type rdf:Property ;
    rdfs:label 'Certification Status' ;
    rdfs:comment 'The certification status of this HOS log entry: certified by the driver, uncertified (pending driver review), or rejected by the driver.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Certification Timestamp' ;
    rdfs:comment 'The timestamp when the driver certified this HOS log entry, in yyyy-MM-ddTHH:mm:ss.SSSXXX format.' ;
    rdfs:domain ind:HosLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cumulativeDrivingHours8day rdf:type rdf:Property ;
    rdfs:label 'Cumulative Driving Hours 8day' ;
    rdfs:comment 'The cumulative driving hours accumulated by the driver in the rolling 8-day window at the time of this log entry, used to enforce the 60/70-hour rule.' ;
    rdfs:domain ind:HosLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cumulativeOnDutyHours8day rdf:type rdf:Property ;
    rdfs:label 'Cumulative On Duty Hours 8day' ;
    rdfs:comment 'The cumulative on-duty hours (driving plus on-duty not driving) accumulated by the driver in the rolling 8-day window at the time of this log entry.' ;
    rdfs:domain ind:HosLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataSource rdf:type rdf:Property ;
    rdfs:label 'Data Source' ;
    rdfs:comment 'The source of this HOS log entry: automatically captured by ELD, manually entered by driver, or edited by carrier.' ;
    rdfs:domain ind:HosLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationMinutes rdf:type rdf:Property ;
    rdfs:label 'Duration Minutes' ;
    rdfs:comment 'The total duration in minutes that the driver remained in this duty status.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dutyStatus rdf:type rdf:Property ;
    rdfs:label 'Duty Status' ;
    rdfs:comment 'The duty status category as defined by FMCSA: off duty, sleeper berth, driving, or on-duty not driving.' ;
    rdfs:domain ind:HosLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dutyStatusEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Duty Status End Timestamp' ;
    rdfs:comment 'The precise timestamp when the driver exited this duty status, in yyyy-MM-ddTHH:mm:ss.SSSXXX format. Null if the status is still active.' ;
    rdfs:domain ind:HosLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dutyStatusStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Duty Status Start Timestamp' ;
    rdfs:comment 'The precise timestamp when the driver entered this duty status, in yyyy-MM-ddTHH:mm:ss.SSSXXX format.' ;
    rdfs:domain ind:HosLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:editFlag rdf:type rdf:Property ;
    rdfs:label 'Edit Flag' ;
    rdfs:comment 'Boolean flag indicating whether this HOS log entry has been manually edited by the driver or carrier after initial creation.' ;
    rdfs:domain ind:HosLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:editReason rdf:type rdf:Property ;
    rdfs:label 'Edit Reason' ;
    rdfs:comment 'The reason provided for any manual edit made to this HOS log entry, as required by FMCSA regulations.' ;
    rdfs:domain ind:HosLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eldDeviceCode rdf:type rdf:Property ;
    rdfs:label 'Eld Device Code' ;
    rdfs:comment 'The unique identifier of the Electronic Logging Device (ELD) that recorded this HOS log entry.' ;
    rdfs:domain ind:HosLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eldSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Eld Serial Number' ;
    rdfs:comment 'The manufacturer serial number of the ELD device used to capture this log entry.' ;
    rdfs:domain ind:HosLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gpsLatitudeEnd rdf:type rdf:Property ;
    rdfs:label 'Gps Latitude End' ;
    rdfs:comment 'The GPS latitude coordinate at the end of this duty status period, captured by the ELD device.' ;
    rdfs:domain ind:HosLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gpsLatitudeStart rdf:type rdf:Property ;
    rdfs:label 'Gps Latitude Start' ;
    rdfs:comment 'The GPS latitude coordinate at the start of this duty status period, captured by the ELD device.' ;
    rdfs:domain ind:HosLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gpsLongitudeEnd rdf:type rdf:Property ;
    rdfs:label 'Gps Longitude End' ;
    rdfs:comment 'The GPS longitude coordinate at the end of this duty status period, captured by the ELD device.' ;
    rdfs:domain ind:HosLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gpsLongitudeStart rdf:type rdf:Property ;
    rdfs:label 'Gps Longitude Start' ;
    rdfs:comment 'The GPS longitude coordinate at the start of this duty status period, captured by the ELD device.' ;
    rdfs:domain ind:HosLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hosViolationFlag rdf:type rdf:Property ;
    rdfs:label 'Hos Violation Flag' ;
    rdfs:comment 'Boolean flag indicating whether this log entry resulted in an HOS violation (exceeding driving hours, on-duty hours, or missing required breaks).' ;
    rdfs:domain ind:HosLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:locationEnd rdf:type rdf:Property ;
    rdfs:label 'Location End' ;
    rdfs:comment 'The geographic location (city, state) where the driver ended this duty status period.' ;
    rdfs:domain ind:HosLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationStart rdf:type rdf:Property ;
    rdfs:label 'Location Start' ;
    rdfs:comment 'The geographic location (city, state) where the driver began this duty status period.' ;
    rdfs:domain ind:HosLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:logDate rdf:type rdf:Property ;
    rdfs:label 'Log Date' ;
    rdfs:comment 'The calendar date for which this HOS log entry applies, in yyyy-MM-dd format.' ;
    rdfs:domain ind:HosLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:shippingDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Shipping Document Number' ;
    rdfs:comment 'The reference number of the shipping document or Bill of Lading (BOL) associated with the load being transported during this duty period.' ;
    rdfs:domain ind:HosLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trailerNumber rdf:type rdf:Property ;
    rdfs:label 'Trailer Number' ;
    rdfs:comment 'The identification number of the trailer being hauled during this duty status period, if applicable.' ;
    rdfs:domain ind:HosLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationTypeCode rdf:type rdf:Property ;
    rdfs:label 'Violation Type Code' ;
    rdfs:comment 'The specific type of HOS violation detected: 11-hour driving limit, 14-hour on-duty limit, 30-minute break requirement, 60/70-hour limit, or none if no violation occurred.' ;
    rdfs:domain ind:HosLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accidentReportId rdf:type rdf:Property ;
    rdfs:label 'Accident Report Id' ;
    rdfs:comment 'Unique identifier for the accident report record. Primary key.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccidentReport .

ind:accidentDescription rdf:type rdf:Property ;
    rdfs:label 'Accident Description' ;
    rdfs:comment 'Detailed narrative description of how the accident occurred, including sequence of events, contributing factors, and circumstances.' ;
    rdfs:domain ind:AccidentReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:citationDescription rdf:type rdf:Property ;
    rdfs:label 'Citation Description' ;
    rdfs:comment 'Description of the traffic violation or citation issued, including violation code and description if applicable.' ;
    rdfs:domain ind:AccidentReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:citationIssuedFlag rdf:type rdf:Property ;
    rdfs:label 'Citation Issued Flag' ;
    rdfs:comment 'Indicates whether a traffic citation or ticket was issued to the driver as a result of the accident.' ;
    rdfs:domain ind:AccidentReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:csaReportableFlag rdf:type rdf:Property ;
    rdfs:label 'Csa Reportable Flag' ;
    rdfs:comment 'Indicates whether the accident is reportable under FMCSA CSA program and will impact the carriers safety score.' ;
    rdfs:domain ind:AccidentReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:driverAtFaultFlag rdf:type rdf:Property ;
    rdfs:label 'Driver At Fault Flag' ;
    rdfs:comment 'Indicates whether the company driver was determined to be at fault for the accident based on investigation findings.' ;
    rdfs:domain ind:AccidentReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedPropertyDamageAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Property Damage Amount' ;
    rdfs:comment 'Estimated total dollar amount of property damage resulting from the accident, including damage to company vehicle, other vehicles, and third-party property.' ;
    rdfs:domain ind:AccidentReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incidentSeverity rdf:type rdf:Property ;
    rdfs:label 'Incident Severity' ;
    rdfs:comment 'Overall severity classification of the accident based on injuries, fatalities, and property damage.' ;
    rdfs:domain ind:AccidentReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentTime rdf:type rdf:Property ;
    rdfs:label 'Incident Time' ;
    rdfs:comment 'The precise date and time when the accident occurred, including timezone information.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:incidentType rdf:type rdf:Property ;
    rdfs:label 'Incident Type' ;
    rdfs:comment 'Classification of the type of accident that occurred (collision with another vehicle, rollover, backing incident, pedestrian involvement, property damage only, single vehicle incident).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceCarrier rdf:type rdf:Property ;
    rdfs:label 'Insurance Carrier' ;
    rdfs:comment 'Name of the insurance company handling the claim for this accident.' ;
    rdfs:domain ind:AccidentReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceClaimNumber rdf:type rdf:Property ;
    rdfs:label 'Insurance Claim Number' ;
    rdfs:comment 'Claim number assigned by the insurance carrier for processing the accident claim.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Investigation Completed Date' ;
    rdfs:comment 'Date when the internal accident investigation was completed and findings documented.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:investigationStatus rdf:type rdf:Property ;
    rdfs:label 'Investigation Status' ;
    rdfs:comment 'Current status of the internal accident investigation process.' ;
    rdfs:domain ind:AccidentReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lightConditions rdf:type rdf:Property ;
    rdfs:label 'Light Conditions' ;
    rdfs:comment 'Lighting conditions at the time of the accident.' ;
    rdfs:domain ind:AccidentReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationLatitude rdf:type rdf:Property ;
    rdfs:label 'Location Latitude' ;
    rdfs:comment 'GPS latitude coordinate of the accident location, captured from telematics or manually entered.' ;
    rdfs:domain ind:AccidentReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:locationLongitude rdf:type rdf:Property ;
    rdfs:label 'Location Longitude' ;
    rdfs:comment 'GPS longitude coordinate of the accident location, captured from telematics or manually entered.' ;
    rdfs:domain ind:AccidentReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:locationZipCode rdf:type rdf:Property ;
    rdfs:label 'Location Zip Code' ;
    rdfs:comment 'ZIP or postal code where the accident occurred.' ;
    rdfs:domain ind:AccidentReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberOfFatalities rdf:type rdf:Property ;
    rdfs:label 'Number Of Fatalities' ;
    rdfs:comment 'Total count of fatalities resulting from the accident.' ;
    rdfs:domain ind:AccidentReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numberOfInjuries rdf:type rdf:Property ;
    rdfs:label 'Number Of Injuries' ;
    rdfs:comment 'Total count of individuals injured in the accident, including driver, passengers, pedestrians, and occupants of other vehicles.' ;
    rdfs:domain ind:AccidentReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:policeDepartment rdf:type rdf:Property ;
    rdfs:label 'Police Department' ;
    rdfs:comment 'Name of the law enforcement agency that responded to and documented the accident.' ;
    rdfs:domain ind:AccidentReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policeReportNumber rdf:type rdf:Property ;
    rdfs:label 'Police Report Number' ;
    rdfs:comment 'Official police report or case number assigned by law enforcement agency responding to the accident scene.' ;
    rdfs:domain ind:AccidentReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postAccidentTestCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Post Accident Test Completed Flag' ;
    rdfs:comment 'Indicates whether the required post-accident drug and alcohol test was completed within the regulatory timeframe.' ;
    rdfs:domain ind:AccidentReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postAccidentTestDate rdf:type rdf:Property ;
    rdfs:label 'Post Accident Test Date' ;
    rdfs:comment 'Date when the post-accident drug and alcohol test was administered.' ;
    rdfs:domain ind:AccidentReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:postAccidentTestRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Post Accident Test Required Flag' ;
    rdfs:comment 'Indicates whether a post-accident drug and alcohol test is required per FMCSA regulations (49 CFR Part 382) based on accident severity and circumstances.' ;
    rdfs:domain ind:AccidentReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:postAccidentTestResult rdf:type rdf:Property ;
    rdfs:label 'Post Accident Test Result' ;
    rdfs:comment 'Result of the post-accident drug and alcohol test (negative, positive, refused, or not completed).' ;
    rdfs:domain ind:AccidentReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roadConditions rdf:type rdf:Property ;
    rdfs:label 'Road Conditions' ;
    rdfs:comment 'Road surface conditions at the time and location of the accident.' ;
    rdfs:domain ind:AccidentReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accumulatedDepreciation rdf:type rdf:Property ;
    rdfs:label 'Accumulated Depreciation' ;
    rdfs:comment 'Total depreciation expense recognized since the asset was placed in service. Used to calculate current book value and remaining depreciable base.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assetDescription rdf:type rdf:Property ;
    rdfs:label 'Asset Description' ;
    rdfs:comment 'Detailed business description of the fixed asset including make, model, capacity, and distinguishing characteristics. Used for identification and reporting purposes.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityUnit rdf:type rdf:Property ;
    rdfs:label 'Capacity Unit' ;
    rdfs:comment 'Unit of measure for the capacity value. Must align with industry standards and operational reporting requirements.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityValue rdf:type rdf:Property ;
    rdfs:label 'Capacity Value' ;
    rdfs:comment 'Rated capacity or size of the asset in appropriate units. Examples: cubic yards for containers, tons per day for processing equipment, square feet for buildings.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capitalizationDate rdf:type rdf:Property ;
    rdfs:label 'Capitalization Date' ;
    rdfs:comment 'Date the asset was placed in service and capitalized on the balance sheet. Marks the start of depreciation calculations per GAAP/IFRS standards.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:conditionRating rdf:type rdf:Property ;
    rdfs:label 'Condition Rating' ;
    rdfs:comment 'Current physical condition assessment of the asset based on inspection and maintenance history. Used for replacement planning and risk assessment.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentBookValue rdf:type rdf:Property ;
    rdfs:label 'Current Book Value' ;
    rdfs:comment 'Current net book value of the asset after accumulated depreciation. Calculated as acquisition cost minus accumulated depreciation. Updated with each depreciation run.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disposalProceeds rdf:type rdf:Property ;
    rdfs:label 'Disposal Proceeds' ;
    rdfs:comment 'Amount received from sale or disposal of the asset. Used to calculate gain or loss on disposal for financial reporting.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Environmental Compliance Flag' ;
    rdfs:comment 'Indicates whether the asset requires environmental compliance monitoring per EPA, RCRA, or state regulations. Used for regulatory reporting and inspection scheduling.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leaseContractNumber rdf:type rdf:Property ;
    rdfs:label 'Lease Contract Number' ;
    rdfs:comment 'Contract number for leased assets. Links to lease agreement master data for payment tracking and lease accounting compliance.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salvageValue rdf:type rdf:Property ;
    rdfs:label 'Salvage Value' ;
    rdfs:comment 'Estimated residual value of the asset at the end of its useful life. Used in depreciation calculations to determine depreciable base.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parentAssetClassId rdf:type rdf:Property ;
    rdfs:label 'Parent Asset Class Id' ;
    rdfs:comment 'Reference to the parent asset class in the classification hierarchy, enabling multi-level asset categorization (e.g., Containers > Roll-Off Containers > 20-Yard Roll-Offs).' ;
    rdfs:domain ind:Class ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Class .

ind:assetClassCode rdf:type rdf:Property ;
    rdfs:label 'Asset Class Code' ;
    rdfs:comment 'External business identifier for the asset class used in SAP and financial reporting. Typically a 4-12 character alphanumeric code aligned with chart of accounts structure.' ;
    rdfs:domain ind:Class ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetClassDescription rdf:type rdf:Property ;
    rdfs:label 'Asset Class Description' ;
    rdfs:comment 'Detailed description of the asset class including scope, typical assets included, and business purpose.' ;
    rdfs:domain ind:Class ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetClassName rdf:type rdf:Property ;
    rdfs:label 'Asset Class Name' ;
    rdfs:comment 'Full descriptive name of the asset class (e.g., Roll-Off Containers, Front-End Loaders, Compactors, Landfill Infrastructure, MRF Equipment).' ;
    rdfs:domain ind:Class ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capitalizationThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Capitalization Threshold Amount' ;
    rdfs:comment 'Minimum acquisition cost required for an asset in this class to be capitalized rather than expensed, aligned with GAAP/IFRS policies and company materiality thresholds.' ;
    rdfs:domain ind:Class ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capitalizationThresholdCurrency rdf:type rdf:Property ;
    rdfs:label 'Capitalization Threshold Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the capitalization threshold amount (e.g., USD, CAD, MXN).' ;
    rdfs:domain ind:Class ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classStatus rdf:type rdf:Property ;
    rdfs:label 'Class Status' ;
    rdfs:comment 'Current lifecycle status of the asset class in the master data system. Active classes are available for new asset creation; deprecated classes are retained for historical assets only.' ;
    rdfs:domain ind:Class ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterDefault rdf:type rdf:Property ;
    rdfs:label 'Cost Center Default' ;
    rdfs:comment 'Default cost center code for assets in this class, used for management accounting and operational expense allocation in SAP CO.' ;
    rdfs:domain ind:Class ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:energyConsumptionTracked rdf:type rdf:Property ;
    rdfs:label 'Energy Consumption Tracked' ;
    rdfs:comment 'Indicates whether energy consumption (electricity, natural gas, diesel) is tracked at the asset class level for sustainability reporting and cost allocation.' ;
    rdfs:domain ind:Class ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:environmentalImpactCategory rdf:type rdf:Property ;
    rdfs:label 'Environmental Impact Category' ;
    rdfs:comment 'Classification of potential environmental impact from failure or improper operation of assets in this class. High for landfill liners and leachate systems; medium for compactors and balers; low for administrative assets.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epaReportingRequired rdf:type rdf:Property ;
    rdfs:label 'Epa Reporting Required' ;
    rdfs:comment 'Indicates whether assets in this class must be included in EPA regulatory reporting (e.g., landfill gas collection systems, leachate treatment equipment, air emission control devices).' ;
    rdfs:domain ind:Class ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ghgEmissionSource rdf:type rdf:Property ;
    rdfs:label 'Ghg Emission Source' ;
    rdfs:comment 'Indicates whether assets in this class are direct sources of greenhouse gas emissions requiring monitoring and reporting (e.g., landfill gas collection systems, WTE combustion equipment, stationary engines).' ;
    rdfs:domain ind:Class ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:glAccumulatedDepreciationAccount rdf:type rdf:Property ;
    rdfs:label 'Gl Accumulated Depreciation Account' ;
    rdfs:comment 'General Ledger contra-asset account number for accumulated depreciation of assets in this class. Maps to SAP FI chart of accounts.' ;
    rdfs:domain ind:Class ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAssetAccount rdf:type rdf:Property ;
    rdfs:label 'Gl Asset Account' ;
    rdfs:comment 'General Ledger account number for capitalizing assets in this class on the balance sheet. Maps to SAP FI chart of accounts.' ;
    rdfs:domain ind:Class ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glDepreciationAccount rdf:type rdf:Property ;
    rdfs:label 'Gl Depreciation Account' ;
    rdfs:comment 'General Ledger account number for recording depreciation expense for assets in this class. Maps to SAP FI chart of accounts.' ;
    rdfs:domain ind:Class ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glGainLossAccount rdf:type rdf:Property ;
    rdfs:label 'Gl Gain Loss Account' ;
    rdfs:comment 'General Ledger account number for recording gains or losses on disposal or retirement of assets in this class.' ;
    rdfs:domain ind:Class ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceRequired rdf:type rdf:Property ;
    rdfs:label 'Insurance Required' ;
    rdfs:comment 'Indicates whether assets in this class must carry specific insurance coverage beyond general property insurance (e.g., environmental liability insurance for landfill cells, equipment breakdown insurance for WTE plants).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insuranceType rdf:type rdf:Property ;
    rdfs:label 'Insurance Type' ;
    rdfs:comment 'Type of insurance coverage required for assets in this class (e.g., Environmental Liability, Equipment Breakdown, Pollution Legal Liability, Property and Casualty). Null if no specific insurance required.' ;
    rdfs:domain ind:Class ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceStrategy rdf:type rdf:Property ;
    rdfs:label 'Maintenance Strategy' ;
    rdfs:comment 'Default maintenance approach for assets in this class. Preventive for scheduled maintenance; predictive for sensor-monitored equipment; reactive for low-criticality items; condition-based for inspection-driven maintenance.' ;
    rdfs:domain ind:Class ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturerWarrantyMonths rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Warranty Months' ;
    rdfs:comment 'Typical manufacturer warranty period in months for new assets in this class. Used for warranty tracking and maintenance planning during warranty period.' ;
    rdfs:domain ind:Class ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rcraRegulated rdf:type rdf:Property ;
    rdfs:label 'Rcra Regulated' ;
    rdfs:comment 'Indicates whether assets in this class are subject to RCRA hazardous waste management regulations (e.g., hazardous waste storage containers, treatment equipment, TSDF infrastructure).' ;
    rdfs:domain ind:Class ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresGpsTracking rdf:type rdf:Property ;
    rdfs:label 'Requires Gps Tracking' ;
    rdfs:comment 'Indicates whether assets in this class require GPS tracking devices for location monitoring. May apply to mobile equipment and high-value portable assets.' ;
    rdfs:domain ind:Class ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresPeriodicInspection rdf:type rdf:Property ;
    rdfs:label 'Requires Periodic Inspection' ;
    rdfs:comment 'Indicates whether assets in this class are subject to mandatory periodic safety or compliance inspections (e.g., pressure vessels, lifting equipment, hazardous waste storage units).' ;
    rdfs:domain ind:Class ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresRfidTracking rdf:type rdf:Property ;
    rdfs:label 'Requires Rfid Tracking' ;
    rdfs:comment 'Indicates whether assets in this class must be equipped with RFID tags for automated tracking and inventory management. Typically true for containers (CID tracking), false for fixed infrastructure.' ;
    rdfs:domain ind:Class ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:salvageValuePercentage rdf:type rdf:Property ;
    rdfs:label 'Salvage Value Percentage' ;
    rdfs:comment 'Expected residual value as a percentage of original cost at end of useful life. Containers and equipment may have 5-15% salvage value; buildings typically higher; landfill cells near zero.' ;
    rdfs:domain ind:Class ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serializedTrackingRequired rdf:type rdf:Property ;
    rdfs:label 'Serialized Tracking Required' ;
    rdfs:comment 'Indicates whether individual assets in this class must be tracked by unique serial number in addition to asset ID. True for high-value equipment and containers; false for bulk infrastructure.' ;
    rdfs:domain ind:Class ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:usefulLifeYearsDefault rdf:type rdf:Property ;
    rdfs:label 'Useful Life Years Default' ;
    rdfs:comment 'Standard useful life in years applied by default when creating new assets in this class, typically the midpoint or most common value within the min-max range.' ;
    rdfs:domain ind:Class ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:usefulLifeYearsMax rdf:type rdf:Property ;
    rdfs:label 'Useful Life Years Max' ;
    rdfs:comment 'Maximum expected useful life in years for assets in this class, providing a range for depreciation planning based on usage intensity and maintenance quality.' ;
    rdfs:domain ind:Class ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:usefulLifeYearsMin rdf:type rdf:Property ;
    rdfs:label 'Useful Life Years Min' ;
    rdfs:comment 'Minimum expected useful life in years for assets in this class, used for depreciation calculation and asset lifecycle planning.' ;
    rdfs:domain ind:Class ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedWasteProfileId rdf:type rdf:Property ;
    rdfs:label 'Approved Waste Profile Id' ;
    rdfs:comment 'Foreign key linking to hazmat.waste_profile. Business justification: Containers must be approved for specific waste profiles based on material compatibility, DOT ratings, and waste characteristics. Links containers to approved waste profiles for safe deployment, regula' ;
    rdfs:domain ind:AssetContainer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WasteProfile .

ind:serviceVehicleId rdf:type rdf:Property ;
    rdfs:label 'Service Vehicle Id' ;
    rdfs:comment 'Foreign key linking to fleet.vehicle. Business justification: Containers are serviced by specific vehicles on routes. While route_id exists, direct vehicle linkage enables container-to-vehicle assignment validation, RFID read reconciliation for billing disputes,' ;
    rdfs:domain ind:AssetContainer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vehicle .

ind:amcsContainerReference rdf:type rdf:Property ;
    rdfs:label 'Amcs Container Reference' ;
    rdfs:comment 'The external identifier for this container in the AMCS Platform system. Used for integration and cross-system reconciliation between the enterprise data warehouse and the operational AMCS system.' ;
    rdfs:domain ind:AssetContainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:color rdf:type rdf:Property ;
    rdfs:label 'Color' ;
    rdfs:comment 'The exterior color of the container, often used to designate waste stream type (e.g., blue for recycling, green for organics, black for MSW). Color coding helps drivers and customers identify the correct container for each waste stream. [ENUM-REF-CANDIDATE: green|blue|black|gray|brown|yellow|red — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AssetContainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionGrade rdf:type rdf:Property ;
    rdfs:label 'Condition Grade' ;
    rdfs:comment 'Assessment of the physical condition of the container based on inspection findings. Excellent means like-new; good means minor wear; fair means functional with visible wear; poor means needs repair soon; critical means unsafe or non-functional.' ;
    rdfs:domain ind:AssetContainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deploymentDate rdf:type rdf:Property ;
    rdfs:label 'Deployment Date' ;
    rdfs:comment 'The date this container was most recently deployed to a customer service address. Used to track deployment history and calculate time-in-service metrics.' ;
    rdfs:domain ind:AssetContainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gpsDeviceCode rdf:type rdf:Property ;
    rdfs:label 'Gps Device Code' ;
    rdfs:comment 'Identifier for the GPS tracking device installed on high-value containers (typically roll-offs and compactors) for real-time location monitoring via Geotab Fleet Telematics or similar systems.' ;
    rdfs:domain ind:AssetContainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inforEamAssetReference rdf:type rdf:Property ;
    rdfs:label 'Infor Eam Asset Reference' ;
    rdfs:comment 'The asset identifier for this container in the Infor EAM system. Used for maintenance work order management, preventive maintenance scheduling, and parts inventory tracking.' ;
    rdfs:domain ind:AssetContainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isGpsEnabled rdf:type rdf:Property ;
    rdfs:label 'Is Gps Enabled' ;
    rdfs:comment 'Boolean flag indicating whether this container is equipped with an active GPS tracking device. True means GPS device is installed and transmitting; false means no GPS tracking.' ;
    rdfs:domain ind:AssetContainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRfidEnabled rdf:type rdf:Property ;
    rdfs:label 'Is Rfid Enabled' ;
    rdfs:comment 'Boolean flag indicating whether this container is equipped with an active RFID tag for automated scanning. True means RFID tag is attached and functional; false means no RFID capability.' ;
    rdfs:domain ind:AssetContainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lidType rdf:type rdf:Property ;
    rdfs:label 'Lid Type' ;
    rdfs:comment 'The type of lid or cover on the container. Lids help control odor, prevent unauthorized dumping, and keep out rain. Locking lids provide security for customer-specific waste. Some roll-offs have no lids.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:material rdf:type rdf:Property ;
    rdfs:label 'Material' ;
    rdfs:comment 'The primary construction material of the container body. Steel is common for commercial dumpsters and roll-offs; plastic (high-density polyethylene) for residential carts; fiberglass for specialized applications; aluminum for lightweight applications.' ;
    rdfs:domain ind:AssetContainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netBookValue rdf:type rdf:Property ;
    rdfs:label 'Net Book Value' ;
    rdfs:comment 'The current book value of the container calculated as acquisition cost minus accumulated depreciation in USD. Used for financial reporting and asset valuation. Confidential financial data.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ownershipStatus rdf:type rdf:Property ;
    rdfs:label 'Ownership Status' ;
    rdfs:comment 'Indicates whether the container is owned by Waste Management, leased from a third party, or owned by the customer. Owned containers are capitalized assets; leased containers have associated lease obligations; customer-owned containers are tracked for service purposes but not capitalized.' ;
    rdfs:domain ind:AssetContainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retrievalDate rdf:type rdf:Property ;
    rdfs:label 'Retrieval Date' ;
    rdfs:comment 'The date this container was retrieved from a customer service address and returned to inventory or maintenance. Null if container is currently deployed.' ;
    rdfs:domain ind:AssetContainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sapAssetNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Asset Number' ;
    rdfs:comment 'The asset number assigned to this container in the SAP S/4HANA Fixed Assets (FI-AA) module. Used for financial asset tracking, depreciation runs, and general ledger integration.' ;
    rdfs:domain ind:AssetContainer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line 1' ;
    rdfs:comment 'Primary street address of the facility (street number and name).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line 2' ;
    rdfs:comment 'Secondary address information (suite, building, unit) if applicable.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:airPermitNumber rdf:type rdf:Property ;
    rdfs:label 'Air Permit Number' ;
    rdfs:comment 'Permit number issued under the Clean Air Act (CAA) for facilities with air emissions (e.g., landfills with LFG flares, WTE plants).' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decommissioningDate rdf:type rdf:Property ;
    rdfs:label 'Decommissioning Date' ;
    rdfs:comment 'Date when the facility was permanently closed and decommissioned. Null for active facilities.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:epaFacilityNumber rdf:type rdf:Property ;
    rdfs:label 'Epa Facility Number' ;
    rdfs:comment 'Unique identifier assigned by the U.S. EPA for tracking environmental compliance and reporting (e.g., FRS Registry ID).' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatFacilityFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Facility Flag' ;
    rdfs:comment 'Indicates whether the facility is authorized to handle, store, or treat hazardous waste under RCRA Subtitle C (True/False).' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:landfillClosureDate rdf:type rdf:Property ;
    rdfs:label 'Landfill Closure Date' ;
    rdfs:comment 'Projected or actual date when the landfill will reach capacity and cease accepting waste. Null for non-landfill facilities.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:landfillRemainingCapacityTons rdf:type rdf:Property ;
    rdfs:label 'Landfill Remaining Capacity Tons' ;
    rdfs:comment 'Estimated remaining disposal capacity in tons for landfill facilities. Null for non-landfill facility types.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leaJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Lea Jurisdiction' ;
    rdfs:comment 'Name of the Local Enforcement Agency (LEA) or county environmental health department with regulatory oversight of the facility.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managerName rdf:type rdf:Property ;
    rdfs:label 'Manager Name' ;
    rdfs:comment 'Full name of the facility manager or site superintendent responsible for day-to-day operations.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:siteAreaAcres rdf:type rdf:Property ;
    rdfs:label 'Site Area Acres' ;
    rdfs:comment 'Total land area of the facility site in acres, including operational areas, buffer zones, and administrative buildings.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:solidWastePermitNumber rdf:type rdf:Property ;
    rdfs:label 'Solid Waste Permit Number' ;
    rdfs:comment 'Primary operating permit number issued by state or local authority under RCRA Subtitle D (non-hazardous) or Subtitle C (hazardous) for waste management operations.' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:swisNumber rdf:type rdf:Property ;
    rdfs:label 'Swis Number' ;
    rdfs:comment 'State-issued identifier for solid waste facilities used for regulatory tracking and reporting (varies by state).' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waterPermitNumber rdf:type rdf:Property ;
    rdfs:label 'Water Permit Number' ;
    rdfs:comment 'Permit number issued under the Clean Water Act (CWA) for facilities that discharge wastewater or manage leachate (e.g., NPDES permit).' ;
    rdfs:domain ind:Facility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationId rdf:type rdf:Property ;
    rdfs:label 'Location Id' ;
    rdfs:comment 'Unique identifier for the asset location record. Primary key.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:placementDriverId rdf:type rdf:Property ;
    rdfs:label 'Placement Driver Id' ;
    rdfs:comment 'Identifier of the driver who placed or delivered the asset to this location. Links to driver master for accountability and audit trail.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Driver .

ind:placementVehicleId rdf:type rdf:Property ;
    rdfs:label 'Placement Vehicle Id' ;
    rdfs:comment 'Identifier of the vehicle used to transport and place the asset at this location. Links to fleet vehicle master.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vehicle .

ind:placementWorkOrderId rdf:type rdf:Property ;
    rdfs:label 'Placement Work Order Id' ;
    rdfs:comment 'Identifier of the work order that authorized or executed the asset placement at this location. Links to field service work order system.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkOrder .

ind:assignmentReason rdf:type rdf:Property ;
    rdfs:label 'Assignment Reason' ;
    rdfs:comment 'Business reason for assigning the asset to this location. Supports root cause analysis for location changes and utilization patterns. [ENUM-REF-CANDIDATE: new_service|service_change|replacement|maintenance|temporary_placement|customer_request|route_optimization|lost_recovery|seasonal — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bayOrPadNumber rdf:type rdf:Property ;
    rdfs:label 'Bay Or Pad Number' ;
    rdfs:comment 'Specific bay, pad, or designated area within a building or facility where the asset is positioned. Used for precise location tracking of stationary equipment like compactors, balers, and scales.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buildingCode rdf:type rdf:Property ;
    rdfs:label 'Building Code' ;
    rdfs:comment 'Code identifying the specific building or structure within a facility where the asset is located. Used for maintenance shops, administrative buildings, and multi-building facilities.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geofenceZoneCode rdf:type rdf:Property ;
    rdfs:label 'Geofence Zone Code' ;
    rdfs:comment 'Identifier of the geofence zone that encompasses this asset location. Used for automated location alerts and compliance monitoring.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isBillableLocation rdf:type rdf:Property ;
    rdfs:label 'Is Billable Location' ;
    rdfs:comment 'Flag indicating whether the asset placement at this location is billable to a customer. True for customer sites with active service; false for internal facility locations.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrimaryLocation rdf:type rdf:Property ;
    rdfs:label 'Is Primary Location' ;
    rdfs:comment 'Flag indicating whether this is the primary or home location for the asset. True for the main assigned location; false for temporary or secondary locations.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastVerifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Verified Timestamp' ;
    rdfs:comment 'Date and time when the asset location was last verified or confirmed. Updated by RFID scans, GPS pings, or manual audits.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:locationStatus rdf:type rdf:Property ;
    rdfs:label 'Location Status' ;
    rdfs:comment 'Current status of the asset at this location. Indicates whether the asset is actively in service, temporarily placed, awaiting pickup, or lost/missing.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locationType rdf:type rdf:Property ;
    rdfs:label 'Location Type' ;
    rdfs:comment 'Classification of the location where the asset is currently positioned. Distinguishes between customer sites, internal facilities, and transit states. [ENUM-REF-CANDIDATE: customer_site|facility|yard|transfer_station|landfill|mrf|wte_plant|maintenance_shop|in_transit|storage — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utilizationStatus rdf:type rdf:Property ;
    rdfs:label 'Utilization Status' ;
    rdfs:comment 'Current utilization state of the asset at this location. Indicates whether the asset is actively being used, idle, or available for redeployment.' ;
    rdfs:domain ind:Location ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acquisitionId rdf:type rdf:Property ;
    rdfs:label 'Acquisition Id' ;
    rdfs:comment 'Unique identifier for the asset acquisition event. Primary key for the acquisition record.' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:acquisitionFixedAssetId rdf:type rdf:Property ;
    rdfs:label 'Acquisition Fixed Asset Id' ;
    rdfs:comment 'Reference to the fixed asset master record that was acquired through this acquisition event. Links to the asset master upon capitalization.' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FixedAsset .

ind:acquisitionTradeInAssetFixedAssetId rdf:type rdf:Property ;
    rdfs:label 'Acquisition Trade In Asset Fixed Asset Id' ;
    rdfs:comment 'Reference to the existing asset that was traded in as part of this acquisition. Links to the disposed asset record for gain/loss calculation.' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FixedAsset .

ind:acquisitionMethod rdf:type rdf:Property ;
    rdfs:label 'Acquisition Method' ;
    rdfs:comment 'Method by which the asset was acquired. Determines capitalization treatment and accounting entries per GAAP/IFRS standards.' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acquisitionNumber rdf:type rdf:Property ;
    rdfs:label 'Acquisition Number' ;
    rdfs:comment 'Business identifier for the acquisition transaction. Externally-known reference number used in procurement and accounting documentation.' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acquisitionStatus rdf:type rdf:Property ;
    rdfs:label 'Acquisition Status' ;
    rdfs:comment 'Current status of the acquisition transaction in its lifecycle. Tracks progression from approval through capitalization or cancellation. [ENUM-REF-CANDIDATE: pending|approved|in_transit|received|installed|capitalized|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetLineItem rdf:type rdf:Property ;
    rdfs:label 'Budget Line Item' ;
    rdfs:comment 'Specific budget line item or cost center code against which the acquisition was charged. Used for budget variance analysis and financial control.' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cost rdf:type rdf:Property ;
    rdfs:label 'Cost' ;
    rdfs:comment 'Base purchase price of the asset before additional costs. Represents the invoice amount paid to the vendor excluding freight, installation, and other capitalizable costs.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightCost rdf:type rdf:Property ;
    rdfs:label 'Freight Cost' ;
    rdfs:comment 'Transportation and shipping costs incurred to deliver the asset to its installation location. Capitalized as part of total asset cost per GAAP.' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fundingSource rdf:type rdf:Property ;
    rdfs:label 'Funding Source' ;
    rdfs:comment 'Source of funds used to finance the asset acquisition. Tracks whether the asset was funded through operating budget, capital expenditure budget, grants, or financing arrangements.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:installationCost rdf:type rdf:Property ;
    rdfs:label 'Installation Cost' ;
    rdfs:comment 'Costs incurred to install, configure, and prepare the asset for its intended use. Includes labor, materials, and contractor fees. Capitalized per GAAP.' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sapAssetDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Asset Document Number' ;
    rdfs:comment 'SAP asset acquisition document number generated when the asset was capitalized in SAP FI-AA. Links to SAP fixed asset master and depreciation runs.' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCapitalizedCost rdf:type rdf:Property ;
    rdfs:label 'Total Capitalized Cost' ;
    rdfs:comment 'Total cost capitalized for the asset, including acquisition cost, freight, installation, and other capitalizable costs. This is the depreciable basis for the asset.' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tradeInValue rdf:type rdf:Property ;
    rdfs:label 'Trade In Value' ;
    rdfs:comment 'Credit or allowance received for the trade-in asset, reducing the net acquisition cost. Used in gain/loss calculation on asset disposal.' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warrantyEndDate rdf:type rdf:Property ;
    rdfs:label 'Warranty End Date' ;
    rdfs:comment 'Date the manufacturer or vendor warranty coverage expires. Triggers transition to internal maintenance or extended warranty consideration.' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:warrantyStartDate rdf:type rdf:Property ;
    rdfs:label 'Warranty Start Date' ;
    rdfs:comment 'Date the manufacturer or vendor warranty coverage begins for the acquired asset. Used for maintenance planning and warranty claim tracking.' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:warrantyTerms rdf:type rdf:Property ;
    rdfs:label 'Warranty Terms' ;
    rdfs:comment 'Description of warranty coverage terms, including what is covered, exclusions, and claim procedures. Supports warranty management and cost avoidance.' ;
    rdfs:domain ind:Acquisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retirementId rdf:type rdf:Property ;
    rdfs:label 'Retirement Id' ;
    rdfs:comment 'Unique identifier for the asset retirement record. Primary key for the asset retirement transaction.' ;
    rdfs:domain ind:Retirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:retirementFixedAssetId rdf:type rdf:Property ;
    rdfs:label 'Retirement Fixed Asset Id' ;
    rdfs:comment 'Reference to the fixed asset being retired from the asset register. Links to the master asset record in the asset management system.' ;
    rdfs:domain ind:Retirement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FixedAsset .

ind:retirementReplacementAssetFixedAssetId rdf:type rdf:Property ;
    rdfs:label 'Retirement Replacement Asset Fixed Asset Id' ;
    rdfs:comment 'Reference to the new asset that replaced the retired asset, if applicable. Used for asset lifecycle planning, capacity management, and capital expenditure tracking.' ;
    rdfs:domain ind:Retirement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FixedAsset .

ind:approvingAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Approving Authority Name' ;
    rdfs:comment 'The name of the manager or executive who authorized the asset retirement. Required for governance and internal control compliance.' ;
    rdfs:domain ind:Retirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetSubcategory rdf:type rdf:Property ;
    rdfs:label 'Asset Subcategory' ;
    rdfs:comment 'Detailed classification within the asset category (e.g., Front End Loader (FEL) container, stationary compactor, Materials Recovery Facility (MRF), Automated Side Loader (ASL) truck). Provides granular asset type for reporting and analysis.' ;
    rdfs:domain ind:Retirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:buyerContactInformation rdf:type rdf:Property ;
    rdfs:label 'Buyer Contact Information' ;
    rdfs:comment 'Contact details (phone, email, address) for the buyer of the retired asset. Used for transaction documentation and warranty transfer. Business-confidential organizational contact data.' ;
    rdfs:domain ind:Retirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentNumber rdf:type rdf:Property ;
    rdfs:label 'Document Number' ;
    rdfs:comment 'The official document number generated in SAP FI-AA (Fixed Asset Accounting) module for the asset retirement transaction. Used for audit trail and financial reconciliation.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalDisposalCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Environmental Disposal Certification Number' ;
    rdfs:comment 'The certification or manifest number issued by the EPA, state environmental agency, or TSDF confirming compliant disposal of assets containing hazardous materials (e.g., compactors with hydraulic fluid, equipment with refrigerants). Required for RCRA and CERCLA compliance.' ;
    rdfs:domain ind:Retirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gainLossAmount rdf:type rdf:Property ;
    rdfs:label 'Gain Loss Amount' ;
    rdfs:comment 'The financial gain (positive) or loss (negative) recognized on asset retirement, calculated as (sale proceeds - disposal costs - net book value). Posted to the General Ledger (GL) for financial reporting.' ;
    rdfs:domain ind:Retirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hazardousMaterialIndicator rdf:type rdf:Property ;
    rdfs:label 'Hazardous Material Indicator' ;
    rdfs:comment 'Boolean flag indicating whether the retired asset contained or was contaminated with hazardous materials requiring special disposal procedures under RCRA or OSHA regulations. True if hazardous, False otherwise.' ;
    rdfs:domain ind:Retirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazardousMaterialType rdf:type rdf:Property ;
    rdfs:label 'Hazardous Material Type' ;
    rdfs:comment 'Description of the type of hazardous material contained in the retired asset (e.g., hydraulic fluid, refrigerant, lead-acid battery, PCB-containing transformer). Required for EPA manifest and TSDF acceptance.' ;
    rdfs:domain ind:Retirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceRecoveryAmount rdf:type rdf:Property ;
    rdfs:label 'Insurance Recovery Amount' ;
    rdfs:comment 'The amount recovered from insurance for the retired asset. Offsets the loss on disposal in financial reporting and may affect gain/loss calculation.' ;
    rdfs:domain ind:Retirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalAcquisitionCost rdf:type rdf:Property ;
    rdfs:label 'Original Acquisition Cost' ;
    rdfs:comment 'The original purchase price or capitalized cost of the asset when it was first acquired and placed in service. Used to calculate gain or loss on disposal.' ;
    rdfs:domain ind:Retirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:physicalLocationAtRetirement rdf:type rdf:Property ;
    rdfs:label 'Physical Location At Retirement' ;
    rdfs:comment 'The physical site, facility, or yard where the asset was located at the time of retirement. Used for asset tracking, inventory reconciliation, and logistics planning.' ;
    rdfs:domain ind:Retirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retirementDate rdf:type rdf:Property ;
    rdfs:label 'Retirement Date' ;
    rdfs:comment 'The effective date when the asset was officially retired from service and removed from the active asset register. Used for depreciation calculation cutoff and financial reporting.' ;
    rdfs:domain ind:Retirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:retirementStatus rdf:type rdf:Property ;
    rdfs:label 'Retirement Status' ;
    rdfs:comment 'Current workflow status of the retirement transaction: PENDING (awaiting approval), APPROVED (authorized but not yet processed), COMPLETED (fully processed and posted to GL), CANCELLED (retirement request withdrawn).' ;
    rdfs:domain ind:Retirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:saleInvoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Sale Invoice Number' ;
    rdfs:comment 'The invoice number issued to the buyer for the sale of the retired asset. Links to Oracle Revenue Management for Accounts Receivable (AR) tracking and revenue recognition.' ;
    rdfs:domain ind:Retirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:saleProceedsAmount rdf:type rdf:Property ;
    rdfs:label 'Sale Proceeds Amount' ;
    rdfs:comment 'The cash or fair market value received from the sale or disposal of the retired asset. Null if asset was scrapped with no salvage value. Used to calculate gain or loss on disposal.' ;
    rdfs:domain ind:Retirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transferId rdf:type rdf:Property ;
    rdfs:label 'Transfer Id' ;
    rdfs:comment 'Unique identifier for the asset transfer transaction. Primary key for the asset transfer record.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:receivingFacilityId rdf:type rdf:Property ;
    rdfs:label 'Receiving Facility Id' ;
    rdfs:comment 'Reference to the facility, plant, yard, or customer site to which the asset is being transferred. Destination location in the transfer transaction.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:sendingFacilityId rdf:type rdf:Property ;
    rdfs:label 'Sending Facility Id' ;
    rdfs:comment 'Reference to the facility, plant, yard, or customer site from which the asset is being transferred. Source location in the transfer transaction.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:actualTransferTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Transfer Timestamp' ;
    rdfs:comment 'Precise date and time when the asset physically arrived at the receiving facility and custody was transferred. Captured from RFID scan, GPS telematics, or manual confirmation.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assetBookValueAtTransfer rdf:type rdf:Property ;
    rdfs:label 'Asset Book Value At Transfer' ;
    rdfs:comment 'Net book value (acquisition cost minus accumulated depreciation) of the asset at the transfer date. Used for intercompany accounting entries and financial reporting.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assetConditionAtTransfer rdf:type rdf:Property ;
    rdfs:label 'Asset Condition At Transfer' ;
    rdfs:comment 'Physical and operational condition assessment of the asset at the time of transfer. Used to determine maintenance requirements at receiving location and validate transfer appropriateness.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierName rdf:type rdf:Property ;
    rdfs:label 'Carrier Name' ;
    rdfs:comment 'Name of the transportation company or internal fleet unit responsible for moving the asset. Applicable when shipping method involves a carrier.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Amount' ;
    rdfs:comment 'Total cost incurred to execute the asset transfer, including transportation, labor, inspection, and administrative expenses. Allocated to receiving cost center.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Cost Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the transfer cost amount. Typically USD for Waste Management domestic operations.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalPeriod rdf:type rdf:Property ;
    rdfs:label 'Fiscal Period' ;
    rdfs:comment 'Fiscal period (month) within the fiscal year when the asset transfer occurred. Used for financial reporting period assignment and depreciation calculation.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fiscalYear rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year' ;
    rdfs:comment 'Fiscal year in which the asset transfer occurred. Used for financial reporting period assignment and depreciation calculation.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gpsLatitudeAtTransfer rdf:type rdf:Property ;
    rdfs:label 'Gps Latitude At Transfer' ;
    rdfs:comment 'GPS latitude coordinate where the asset transfer was physically executed. Captured from Geotab telematics or AMCS platform for location verification.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gpsLongitudeAtTransfer rdf:type rdf:Property ;
    rdfs:label 'Gps Longitude At Transfer' ;
    rdfs:comment 'GPS longitude coordinate where the asset transfer was physically executed. Captured from Geotab telematics or AMCS platform for location verification.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:intercompanyAccountingDocument rdf:type rdf:Property ;
    rdfs:label 'Intercompany Accounting Document' ;
    rdfs:comment 'SAP FI-AA document number for the intercompany accounting entry generated by the asset transfer. Used for financial reconciliation and audit trail.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingCompanyCode rdf:type rdf:Property ;
    rdfs:label 'Receiving Company Code' ;
    rdfs:comment 'SAP company code of the legal entity assuming asset ownership. Required for intercompany transfers to generate proper accounting entries.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingCostCenter rdf:type rdf:Property ;
    rdfs:label 'Receiving Cost Center' ;
    rdfs:comment 'SAP FI-CO cost center code of the receiving organizational unit. Used for intercompany accounting entries and depreciation allocation after transfer.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresMaintenanceFlag rdf:type rdf:Property ;
    rdfs:label 'Requires Maintenance Flag' ;
    rdfs:comment 'Indicator whether the asset requires preventive maintenance (PM) or repair work order (WO) upon arrival at receiving facility. Triggers work order creation in Infor EAM.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduledTransferDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Transfer Date' ;
    rdfs:comment 'Planned date for the physical movement and custody change of the asset. May differ from actual transfer date due to logistics or operational constraints.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sendingCompanyCode rdf:type rdf:Property ;
    rdfs:label 'Sending Company Code' ;
    rdfs:comment 'SAP company code of the legal entity relinquishing asset ownership. Required for intercompany transfers to generate proper accounting entries.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sendingCostCenter rdf:type rdf:Property ;
    rdfs:label 'Sending Cost Center' ;
    rdfs:comment 'SAP FI-CO cost center code of the sending organizational unit. Used for intercompany accounting entries and depreciation allocation prior to transfer.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingMethod rdf:type rdf:Property ;
    rdfs:label 'Shipping Method' ;
    rdfs:comment 'Mode of transportation used to physically move the asset from sending to receiving location. Impacts transit time and cost allocation.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemRecordReference rdf:type rdf:Property ;
    rdfs:label 'Source System Record Reference' ;
    rdfs:comment 'Primary key or unique identifier of this asset transfer record in the source operational system. Enables traceability and reconciliation back to source.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferDate rdf:type rdf:Property ;
    rdfs:label 'Transfer Date' ;
    rdfs:comment 'The business date when the asset transfer was executed and ownership/custody changed from sending to receiving facility. Used for financial period assignment and depreciation calculation cutoff in SAP FI-AA.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transferStatus rdf:type rdf:Property ;
    rdfs:label 'Transfer Status' ;
    rdfs:comment 'Current lifecycle status of the asset transfer transaction. Tracks workflow progression from initiation through completion or cancellation. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|in_transit|completed|cancelled|rejected — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferType rdf:type rdf:Property ;
    rdfs:label 'Transfer Type' ;
    rdfs:comment 'Classification of the transfer transaction based on organizational scope and business purpose. Determines accounting treatment and approval workflow. [ENUM-REF-CANDIDATE: intercompany|interplant|interlocation|redeployment|consolidation|disposal_routing|customer_site_swap — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valueCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Value Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the asset book value at transfer. Typically USD for Waste Management domestic operations.' ;
    rdfs:domain ind:Transfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetInspectionId rdf:type rdf:Property ;
    rdfs:label 'Asset Inspection Id' ;
    rdfs:comment 'Unique identifier for the asset inspection record. Primary key.' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assetOutOfServiceFlag rdf:type rdf:Property ;
    rdfs:label 'Asset Out Of Service Flag' ;
    rdfs:comment 'Boolean indicator (True/False) specifying whether the asset was taken out of service as a result of this inspection due to safety concerns, regulatory non-compliance, or critical defects. Triggers asset status update in Infor EAM.' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:correctiveActionPriority rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Priority' ;
    rdfs:comment 'Priority level for corrective action: critical (immediate safety or regulatory risk), high (significant operational impact), medium (scheduled repair), or low (cosmetic or deferred maintenance).' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectFindings rdf:type rdf:Property ;
    rdfs:label 'Defect Findings' ;
    rdfs:comment 'Free-text or structured description of specific defects identified during inspection, such as dents, cracks, leaks, rust, graffiti, missing lids, broken hinges, worn seals, hydraulic leaks, structural damage, or electrical faults. Supports root cause analysis and maintenance planning.' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionMethod rdf:type rdf:Property ;
    rdfs:label 'Inspection Method' ;
    rdfs:comment 'Method or technique used to perform the inspection: visual (walk-around observation), manual (hands-on testing), automated (RFID scan, IoT sensor), sensor_based (remote monitoring), or third_party (external contractor or certification body).' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectorCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Inspector Certification Number' ;
    rdfs:comment 'Certification or license number of the inspector, if required by regulation (e.g., DOT inspector certification, OSHA competent person designation, EPA-certified technician). Validates inspector qualifications.' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:location rdf:type rdf:Property ;
    rdfs:label 'Location' ;
    rdfs:comment 'Physical location where the inspection was performed, such as facility name, yard, maintenance shop, customer site, or field location. Supports geographic analysis and compliance documentation.' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallConditionGrade rdf:type rdf:Property ;
    rdfs:label 'Overall Condition Grade' ;
    rdfs:comment 'Numeric condition rating on a 1-5 scale where 1=Excellent (no defects), 2=Good (minor wear), 3=Fair (moderate wear, functional), 4=Poor (significant defects, repair needed), 5=Critical (unsafe, immediate action required). Used for asset lifecycle and replacement planning.' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:passFailDetermination rdf:type rdf:Property ;
    rdfs:label 'Pass Fail Determination' ;
    rdfs:comment 'Binary or conditional outcome of the inspection: pass (asset meets all criteria), fail (asset does not meet criteria and cannot be used), or conditional_pass (asset can be used with restrictions or minor repairs).' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:photoDocumentationFlag rdf:type rdf:Property ;
    rdfs:label 'Photo Documentation Flag' ;
    rdfs:comment 'Boolean indicator (True/False) specifying whether photographic evidence was captured during the inspection. Photos are typically stored in a separate document management system and linked via inspection_id.' ;
    rdfs:domain ind:AssetInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:valuationId rdf:type rdf:Property ;
    rdfs:label 'Valuation Id' ;
    rdfs:comment 'Unique identifier for the asset valuation record. Primary key.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:appraisedValue rdf:type rdf:Property ;
    rdfs:label 'Appraised Value' ;
    rdfs:comment 'The monetary value assigned to the asset by the appraiser or valuation methodology at the valuation date, expressed in the reporting currency.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:appraiserCertification rdf:type rdf:Property ;
    rdfs:label 'Appraiser Certification' ;
    rdfs:comment 'Professional certification or credential of the appraiser (e.g., ASA, MAI, CPA, internal certification reference).' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appraiserFirm rdf:type rdf:Property ;
    rdfs:label 'Appraiser Firm' ;
    rdfs:comment 'Name of the external appraisal firm or internal department that conducted the valuation.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appraiserName rdf:type rdf:Property ;
    rdfs:label 'Appraiser Name' ;
    rdfs:comment 'Name of the individual or firm that performed the valuation (internal valuation team member or external certified appraiser).' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carryingAmount rdf:type rdf:Property ;
    rdfs:label 'Carrying Amount' ;
    rdfs:comment 'The book value (net book value after accumulated depreciation) of the asset at the valuation date, used for impairment comparison.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:depreciationMethodUsed rdf:type rdf:Property ;
    rdfs:label 'Depreciation Method Used' ;
    rdfs:comment 'The depreciation method applied in the valuation calculation: straight line, declining balance, units of production, sum of years digits, or none (for land or non-depreciable assets).' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:economicObsolescenceFlag rdf:type rdf:Property ;
    rdfs:label 'Economic Obsolescence Flag' ;
    rdfs:comment 'Boolean flag indicating whether the asset exhibits economic obsolescence (loss of value due to external market or regulatory factors beyond the assets control).' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:functionalObsolescenceFlag rdf:type rdf:Property ;
    rdfs:label 'Functional Obsolescence Flag' ;
    rdfs:comment 'Boolean flag indicating whether the asset exhibits functional obsolescence (outdated design, inefficiency, or inability to meet current operational requirements).' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:impairmentIndicatorFlag rdf:type rdf:Property ;
    rdfs:label 'Impairment Indicator Flag' ;
    rdfs:comment 'Boolean flag indicating whether this valuation identified an impairment condition (appraised value below carrying amount) requiring a write-down per GAAP ASC 360.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:impairmentLossAmount rdf:type rdf:Property ;
    rdfs:label 'Impairment Loss Amount' ;
    rdfs:comment 'The calculated impairment loss amount if an impairment was identified (carrying amount minus fair value). Null if no impairment.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceCoverageAmount rdf:type rdf:Property ;
    rdfs:label 'Insurance Coverage Amount' ;
    rdfs:comment 'The insurance coverage amount recommended or established based on this valuation, used for property and casualty insurance policy limits.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marketValueAdjustmentPct rdf:type rdf:Property ;
    rdfs:label 'Market Value Adjustment Pct' ;
    rdfs:comment 'Percentage adjustment applied to the base valuation to reflect current market conditions, expressed as a percentage (e.g., 5.00 for 5% increase, -10.00 for 10% decrease).' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:methodology rdf:type rdf:Property ;
    rdfs:label 'Methodology' ;
    rdfs:comment 'The technical approach used to determine the appraised value: cost approach (replacement cost less depreciation), market approach (comparable sales), income approach (discounted cash flow), or other industry-standard methodology.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextValuationDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Valuation Due Date' ;
    rdfs:comment 'The scheduled date for the next valuation of this asset, based on policy requirements (e.g., annual insurance appraisals, quarterly impairment testing).' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:physicalConditionRating rdf:type rdf:Property ;
    rdfs:label 'Physical Condition Rating' ;
    rdfs:comment 'Appraiser assessment of the physical condition of the asset at the valuation date: excellent (like new), good (minor wear), fair (moderate wear), poor (significant deterioration), critical (near end of life).' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purpose rdf:type rdf:Property ;
    rdfs:label 'Purpose' ;
    rdfs:comment 'Free-text description of the business purpose for this valuation (e.g., annual insurance renewal, quarterly impairment testing, pre-disposal assessment, merger and acquisition due diligence).' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replacementCostNew rdf:type rdf:Property ;
    rdfs:label 'Replacement Cost New' ;
    rdfs:comment 'The estimated cost to replace the asset with a new equivalent asset at current market prices, used for insurance and capital planning.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportReference rdf:type rdf:Property ;
    rdfs:label 'Report Reference' ;
    rdfs:comment 'Document reference number or file path to the detailed valuation report supporting this valuation record.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usefulLifeRemainingYears rdf:type rdf:Property ;
    rdfs:label 'Useful Life Remaining Years' ;
    rdfs:comment 'The estimated remaining useful life of the asset in years at the valuation date, as assessed by the appraiser.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valuationDate rdf:type rdf:Property ;
    rdfs:label 'Valuation Date' ;
    rdfs:comment 'The date on which the asset valuation was performed or effective.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:valuationNumber rdf:type rdf:Property ;
    rdfs:label 'Valuation Number' ;
    rdfs:comment 'Business identifier for the valuation event, often assigned by appraiser or internal valuation team.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationStatus rdf:type rdf:Property ;
    rdfs:label 'Valuation Status' ;
    rdfs:comment 'Current lifecycle status of the valuation record: draft (in progress), pending review (submitted for approval), approved (finalized and accepted), rejected (not accepted), superseded (replaced by a newer valuation).' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationType rdf:type rdf:Property ;
    rdfs:label 'Valuation Type' ;
    rdfs:comment 'The purpose or methodology category of the valuation: insurance appraisal for coverage renewal, fair market value for financial reporting, impairment test per ASC 360, replacement cost for capital planning, liquidation value for disposal scenarios, or book value reconciliation.' ;
    rdfs:domain ind:Valuation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bomLevel rdf:type rdf:Property ;
    rdfs:label 'Bom Level' ;
    rdfs:comment 'Hierarchical level of the component within the BOM structure. Level 0 is the parent asset; level 1 is a direct child assembly; level 2 is a sub-assembly of level 1, etc. Supports multi-level BOM explosion.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bomStatus rdf:type rdf:Property ;
    rdfs:label 'Bom Status' ;
    rdfs:comment 'Current lifecycle status of the BOM line item: active (in use), inactive (temporarily disabled), obsolete (superseded by newer component), or pending approval (engineering change pending).' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentDescription rdf:type rdf:Property ;
    rdfs:label 'Component Description' ;
    rdfs:comment 'Detailed textual description of the component part, including specifications, model information, and functional purpose within the parent asset.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentPartNumber rdf:type rdf:Property ;
    rdfs:label 'Component Part Number' ;
    rdfs:comment 'Internal part number or SKU identifying the component part or sub-assembly within the BOM structure. Used for inventory lookup and procurement.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentType rdf:type rdf:Property ;
    rdfs:label 'Component Type' ;
    rdfs:comment 'Classification of the component within the BOM hierarchy: assembly (major sub-system), sub-assembly (grouped parts), part (individual component), consumable (regularly replaced item), fluid (lubricant, hydraulic fluid), or fastener (bolt, nut, washer).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ehsNotes rdf:type rdf:Property ;
    rdfs:label 'Ehs Notes' ;
    rdfs:comment 'Free-text field capturing environmental, health, and safety considerations for the component, including PPE requirements, disposal instructions, and regulatory compliance notes.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interchangeablePartNumbers rdf:type rdf:Property ;
    rdfs:label 'Interchangeable Part Numbers' ;
    rdfs:comment 'Comma-separated list of alternative or equivalent part numbers that can substitute for this component. Supports flexible sourcing and reduces downtime when primary part is unavailable.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCapitalSpare rdf:type rdf:Property ;
    rdfs:label 'Is Capital Spare' ;
    rdfs:comment 'Indicates whether the component is classified as a capital spare (high-value, long-lead-time item stocked for emergency replacement) versus a consumable or routine spare. Capital spares are capitalized on the balance sheet.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isConsumable rdf:type rdf:Property ;
    rdfs:label 'Is Consumable' ;
    rdfs:comment 'Indicates whether the component is a consumable item (regularly replaced during preventive maintenance, such as filters, belts, fluids) versus a durable part. Consumables are expensed immediately.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastModifiedBy rdf:type rdf:Property ;
    rdfs:label 'Last Modified By' ;
    rdfs:comment 'Username or employee identifier of the person who last modified this BOM record. Tracks engineering change ownership.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentComponentPartNumber rdf:type rdf:Property ;
    rdfs:label 'Parent Component Part Number' ;
    rdfs:comment 'Part number of the immediate parent component in a multi-level BOM. Null for level-1 components that report directly to the parent asset. Enables hierarchical BOM navigation.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionReference rdf:type rdf:Property ;
    rdfs:label 'Position Reference' ;
    rdfs:comment 'Physical location or position identifier of the component within the parent asset (e.g., \'Front Left Wheel\', \'Hydraulic Pump #2\', \'Conveyor Belt Section A\'). Aids field technicians during maintenance.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityRequired rdf:type rdf:Property ;
    rdfs:label 'Quantity Required' ;
    rdfs:comment 'Number of units of this component required to assemble or maintain one unit of the parent asset. Supports fractional quantities for consumables.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recommendedReplacementIntervalHours rdf:type rdf:Property ;
    rdfs:label 'Recommended Replacement Interval Hours' ;
    rdfs:comment 'Manufacturer-recommended or company-standard operating hours between scheduled replacements for this component. Drives preventive maintenance (PM) work order generation.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:warrantyMonths rdf:type rdf:Property ;
    rdfs:label 'Warranty Months' ;
    rdfs:comment 'Duration of manufacturer warranty coverage for the component in months from date of installation. Used for warranty claim tracking and cost recovery.' ;
    rdfs:domain ind:Bom ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:replacedByTagId rdf:type rdf:Property ;
    rdfs:label 'Replaced By Tag Id' ;
    rdfs:comment 'Foreign key reference to the new RFID tag that replaced this tag. Creates a chain of custody for container tracking history. Null if the tag is still active or was retired without replacement.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RfidTag .

ind:assignedAssetType rdf:type rdf:Property ;
    rdfs:label 'Assigned Asset Type' ;
    rdfs:comment 'The category of asset to which this RFID tag is attached. Container is most common for waste management operations. Equipment includes compactors, balers, and scales. Vehicle tags are used for non-fleet tracking (fleet has separate DOT-compliant systems).' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:encryptionEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Encryption Enabled Flag' ;
    rdfs:comment 'Indicates whether the RFID tag uses encrypted communication protocols. True for tags with built-in encryption capabilities. Encryption enhances security for sensitive applications and prevents unauthorized tag cloning.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:environmentalRating rdf:type rdf:Property ;
    rdfs:label 'Environmental Rating' ;
    rdfs:comment 'The IP (Ingress Protection) rating indicating the tags resistance to dust and water. Waste container RFID tags typically require IP67 or higher for outdoor exposure, pressure washing, and harsh environmental conditions.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epcCode rdf:type rdf:Property ;
    rdfs:label 'Epc Code' ;
    rdfs:comment 'The unique EPC identifier encoded in the RFID tag, typically a 96-bit or 128-bit hexadecimal value conforming to GS1 EPC standards. This is the actual data read from the tag during scanning operations.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedLifespanYears rdf:type rdf:Property ;
    rdfs:label 'Expected Lifespan Years' ;
    rdfs:comment 'The manufacturer-specified expected operational lifespan of the RFID tag in years under normal operating conditions. Passive tags typically last 10-20 years; active tags with batteries last 3-7 years. Used for replacement forecasting and total cost of ownership calculations.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:frequencyBand rdf:type rdf:Property ;
    rdfs:label 'Frequency Band' ;
    rdfs:comment 'The radio frequency band on which the tag operates. UHF (860-960 MHz) is standard for waste container tracking due to long read range and fast read rates. Frequency band determines reader compatibility and regulatory compliance.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:installationLocation rdf:type rdf:Property ;
    rdfs:label 'Installation Location' ;
    rdfs:comment 'Describes where on the asset the RFID tag is physically mounted (e.g., front panel, lid interior, side wall, handle). Important for troubleshooting read failures and ensuring consistent tag placement across the fleet.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReadLocationLatitude rdf:type rdf:Property ;
    rdfs:label 'Last Read Location Latitude' ;
    rdfs:comment 'The geographic latitude coordinate where the RFID tag was last successfully read. Captured from GPS-enabled mobile readers on collection vehicles or fixed readers at facilities.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastReadLocationLongitude rdf:type rdf:Property ;
    rdfs:label 'Last Read Location Longitude' ;
    rdfs:comment 'The geographic longitude coordinate where the RFID tag was last successfully read. Used in conjunction with latitude for geospatial analysis and container location tracking.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastReadReaderCode rdf:type rdf:Property ;
    rdfs:label 'Last Read Reader Code' ;
    rdfs:comment 'Identifier of the RFID reader device that performed the last successful read. May be a vehicle-mounted reader, handheld scanner, or fixed portal reader. Used for reader performance analysis and troubleshooting.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReadTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Read Timestamp' ;
    rdfs:comment 'The most recent date and time when this RFID tag was successfully read by an RFID reader during a collection event, yard inventory scan, or other tracking operation. Used to identify potentially damaged or lost tags.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:memoryCapacityBytes rdf:type rdf:Property ;
    rdfs:label 'Memory Capacity Bytes' ;
    rdfs:comment 'The total memory capacity of the RFID tag in bytes. Typical passive UHF tags have 96-512 bits (12-64 bytes). Larger memory allows storage of additional data such as service history, container specifications, or maintenance records directly on the tag.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operatingTemperatureMaxC rdf:type rdf:Property ;
    rdfs:label 'Operating Temperature Max C' ;
    rdfs:comment 'The maximum ambient temperature in Celsius at which the RFID tag is rated to operate reliably. Important for tags on containers exposed to direct sunlight, hot climates, or high-temperature waste streams.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatingTemperatureMinC rdf:type rdf:Property ;
    rdfs:label 'Operating Temperature Min C' ;
    rdfs:comment 'The minimum ambient temperature in Celsius at which the RFID tag is rated to operate reliably. Critical for tags deployed in extreme cold climates or refrigerated waste applications.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:readFailureCount rdf:type rdf:Property ;
    rdfs:label 'Read Failure Count' ;
    rdfs:comment 'The total number of attempted reads that failed for this RFID tag. High failure counts indicate potential tag damage, environmental interference, or reader issues requiring investigation.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:readSuccessCount rdf:type rdf:Property ;
    rdfs:label 'Read Success Count' ;
    rdfs:comment 'The total number of successful reads recorded for this RFID tag since installation. Used to assess tag performance, durability, and expected remaining lifespan.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:replacementDate rdf:type rdf:Property ;
    rdfs:label 'Replacement Date' ;
    rdfs:comment 'The date when this RFID tag was replaced with a new tag. Marks the end of the tags active service life. Used in conjunction with installation_date to calculate actual tag lifespan for performance analysis.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:replacementReason rdf:type rdf:Property ;
    rdfs:label 'Replacement Reason' ;
    rdfs:comment 'Free-text description of why the RFID tag was replaced or retired. Common reasons include physical damage, read failures, container disposal, tag upgrade, or end of service life. Used for root cause analysis and tag durability improvement.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signalStrengthDbm rdf:type rdf:Property ;
    rdfs:label 'Signal Strength Dbm' ;
    rdfs:comment 'The signal strength of the last successful RFID tag read, measured in dBm. Typical values range from -70 dBm (weak) to -30 dBm (strong). Declining signal strength over time may indicate tag degradation or environmental factors affecting readability.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tagManufacturer rdf:type rdf:Property ;
    rdfs:label 'Tag Manufacturer' ;
    rdfs:comment 'The name of the company that manufactured the RFID tag hardware (e.g., Alien Technology, Impinj, Avery Dennison, Confidex). Important for warranty tracking, performance characteristics, and replacement sourcing.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tagModel rdf:type rdf:Property ;
    rdfs:label 'Tag Model' ;
    rdfs:comment 'The specific model or part number of the RFID tag. Different models have varying read ranges, durability ratings, and environmental tolerances critical for outdoor waste container applications.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tagStatus rdf:type rdf:Property ;
    rdfs:label 'Tag Status' ;
    rdfs:comment 'Current operational status of the RFID tag. Active tags are in service and readable. Damaged tags have been identified as non-functional during read attempts. Replaced tags have been swapped out. Retired tags are decommissioned. Lost tags cannot be located. Quarantined tags are temporarily suspended pending investigation.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tagType rdf:type rdf:Property ;
    rdfs:label 'Tag Type' ;
    rdfs:comment 'The technology type of the RFID tag. Passive UHF tags are most common for container tracking in waste management, offering long read ranges (up to 40 feet) without battery power. Active tags include battery for extended range and sensor capabilities.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitCostUsd rdf:type rdf:Property ;
    rdfs:label 'Unit Cost Usd' ;
    rdfs:comment 'The purchase cost of the individual RFID tag in USD. Used for asset valuation, inventory accounting, and cost-benefit analysis of RFID tracking programs. Passive UHF tags typically cost $0.10-$2.00; active tags cost $10-$50.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:writeProtectedFlag rdf:type rdf:Property ;
    rdfs:label 'Write Protected Flag' ;
    rdfs:comment 'Indicates whether the RFID tag memory is write-protected (locked). True means the tag is read-only and cannot be reprogrammed. False means the tag can be rewritten. Write protection prevents accidental or malicious data modification.' ;
    rdfs:domain ind:RfidTag ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leaseId rdf:type rdf:Property ;
    rdfs:label 'Lease Id' ;
    rdfs:comment 'Unique identifier for the lease contract record. Primary key.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:classificationDate rdf:type rdf:Property ;
    rdfs:label 'Classification Date' ;
    rdfs:comment 'Date on which the lease was classified as operating or finance lease per ASC 842/IFRS 16 criteria. Typically the lease commencement date or the date of initial recognition.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:companyCode rdf:type rdf:Property ;
    rdfs:label 'Company Code' ;
    rdfs:comment 'SAP company code representing the legal entity that is the lessee under this lease contract. Used for financial consolidation and reporting in SAP S/4HANA FI module.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentUrl rdf:type rdf:Property ;
    rdfs:label 'Document Url' ;
    rdfs:comment 'URL or file path to the scanned lease contract document stored in the enterprise document management system. Provides access to the original signed lease agreement for audit and reference purposes.' ;
    rdfs:domain ind:Asset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implicitInterestRate rdf:type rdf:Property ;
    rdfs:label 'Implicit Interest Rate' ;
    rdfs:comment 'Implicit interest rate in the lease contract, if determinable. Used to discount lease payments to present value for ROU asset and lease liability calculation. If not determinable, the lessee\'s incremental borrowing rate is used instead.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incrementalBorrowingRate rdf:type rdf:Property ;
    rdfs:label 'Incremental Borrowing Rate' ;
    rdfs:comment 'The rate of interest that the lessee would have to pay to borrow funds on a collateralized basis over a similar term to obtain an asset of similar value. Used as the discount rate when the implicit rate is not readily determinable.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leaseStatus rdf:type rdf:Property ;
    rdfs:label 'Lease Status' ;
    rdfs:comment 'Current lifecycle status of the lease contract. Active indicates the lease is in force; terminated indicates early termination; expired indicates natural end of term; renewed indicates transition to a new lease term.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaseType rdf:type rdf:Property ;
    rdfs:label 'Lease Type' ;
    rdfs:comment 'Classification of the lease as operating lease, finance lease, or capital lease per ASC 842 (US GAAP) and IFRS 16 accounting standards. Determines accounting treatment for right-of-use asset and lease liability recognition.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leasedAssetDescription rdf:type rdf:Property ;
    rdfs:label 'Leased Asset Description' ;
    rdfs:comment 'Detailed description of the asset(s) covered by this lease contract. May include containers (dumpsters, roll-offs, carts), compactors, balers, scales, or other equipment used in waste collection and processing operations.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liabilityBalance rdf:type rdf:Property ;
    rdfs:label 'Liability Balance' ;
    rdfs:comment 'Current outstanding lease liability balance on the balance sheet. Represents the present value of remaining lease payments. Reduced by principal portion of each lease payment and increased by interest accretion.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modificationDate rdf:type rdf:Property ;
    rdfs:label 'Modification Date' ;
    rdfs:comment 'Date of the most recent lease modification that changed the scope or consideration of the lease. Lease modifications require remeasurement of the lease liability and ROU asset per ASC 842/IFRS 16.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:modificationDescription rdf:type rdf:Property ;
    rdfs:label 'Modification Description' ;
    rdfs:comment 'Description of the most recent lease modification, including changes to lease term, payment amounts, or scope of leased assets. Null if no modifications have occurred.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monthlyLeasePayment rdf:type rdf:Property ;
    rdfs:label 'Monthly Lease Payment' ;
    rdfs:comment 'Fixed monthly payment amount due to the lessor under the lease contract. Excludes variable payments based on usage or performance. Denominated in the currency specified in payment_currency_code.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Payment Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for lease payment amounts (e.g., USD, CAD, EUR). All monetary fields in this lease record are denominated in this currency.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentFrequency rdf:type rdf:Property ;
    rdfs:label 'Payment Frequency' ;
    rdfs:comment 'Frequency of lease payment obligations. Most leases are monthly; some may be quarterly or annually depending on contract terms.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseOptionFlag rdf:type rdf:Property ;
    rdfs:label 'Purchase Option Flag' ;
    rdfs:comment 'Indicates whether the lease contract includes an option for the lessee to purchase the leased asset at the end of the lease term or during the lease period. True if purchase option exists; False otherwise.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:purchaseOptionPrice rdf:type rdf:Property ;
    rdfs:label 'Purchase Option Price' ;
    rdfs:comment 'Fixed purchase price or formula for calculating the purchase price if the lessee exercises the purchase option. Null if no purchase option exists or price is not predetermined.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewalOptionFlag rdf:type rdf:Property ;
    rdfs:label 'Renewal Option Flag' ;
    rdfs:comment 'Indicates whether the lease contract includes an option for the lessee to renew the lease term beyond the initial end date. True if renewal option exists; False otherwise.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalOptionTerms rdf:type rdf:Property ;
    rdfs:label 'Renewal Option Terms' ;
    rdfs:comment 'Detailed description of renewal option terms, including renewal period duration, payment adjustments, and conditions for exercising the renewal. Null if no renewal option exists.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rouAssetValue rdf:type rdf:Property ;
    rdfs:label 'Rou Asset Value' ;
    rdfs:comment 'Initial right-of-use asset value recognized on the balance sheet at lease commencement per ASC 842/IFRS 16. Calculated as the present value of lease payments plus initial direct costs. Amortized over the lease term.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sapLeaseContractReference rdf:type rdf:Property ;
    rdfs:label 'Sap Lease Contract Reference' ;
    rdfs:comment 'Reference number or document ID for the lease contract in SAP S/4HANA lease accounting module. Used for integration and reconciliation between lakehouse and SAP system of record.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termMonths rdf:type rdf:Property ;
    rdfs:label 'Term Months' ;
    rdfs:comment 'Total duration of the lease contract in months from start date to end date. Used for lease accounting calculations and amortization schedules.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:terminationOptionFlag rdf:type rdf:Property ;
    rdfs:label 'Termination Option Flag' ;
    rdfs:comment 'Indicates whether the lessee has the right to terminate the lease before the scheduled end date. True if early termination option exists; False otherwise.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:terminationPenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Termination Penalty Amount' ;
    rdfs:comment 'Financial penalty or fee payable by the lessee if the lease is terminated early. Null if no termination penalty applies or if termination is not permitted.' ;
    rdfs:domain ind:Lease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:claimLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Claim Limit Amount' ;
    rdfs:comment 'Maximum total dollar amount that can be claimed under this warranty over its lifetime. Null indicates unlimited coverage. Critical for high-value equipment like MRF sorting systems and WTE boilers.' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:claimLimitCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Claim Limit Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the claim limit amount (e.g., USD, CAD, EUR).' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimsApprovedCount rdf:type rdf:Property ;
    rdfs:label 'Claims Approved Count' ;
    rdfs:comment 'Total number of warranty claims that were approved and paid by the warranty provider. Used to calculate claim approval rate and assess warranty provider responsiveness.' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:claimsFiledCount rdf:type rdf:Property ;
    rdfs:label 'Claims Filed Count' ;
    rdfs:comment 'Total number of warranty claims filed against this warranty to date. Used for warranty utilization tracking and vendor performance assessment.' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contactName rdf:type rdf:Property ;
    rdfs:label 'Contact Name' ;
    rdfs:comment 'Name of the primary contact person at the warranty provider for claim submission and service coordination.' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageDurationMonths rdf:type rdf:Property ;
    rdfs:label 'Coverage Duration Months' ;
    rdfs:comment 'Total duration of warranty coverage expressed in months. Standard manufacturer warranties are typically 12-36 months; extended warranties may range from 12-120 months for high-value equipment.' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:coverageEndDate rdf:type rdf:Property ;
    rdfs:label 'Coverage End Date' ;
    rdfs:comment 'Date when warranty coverage expires. Critical for proactive warranty utilization planning and determining when assets transition to out-of-warranty maintenance.' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:coverageStartDate rdf:type rdf:Property ;
    rdfs:label 'Coverage Start Date' ;
    rdfs:comment 'Date when warranty coverage becomes effective. Typically the asset acquisition date for manufacturer warranties or the purchase date for extended warranties.' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deductibleAmount rdf:type rdf:Property ;
    rdfs:label 'Deductible Amount' ;
    rdfs:comment 'Amount that must be paid by Waste Management before warranty coverage applies to each claim. Zero indicates no deductible. Common for extended warranties on high-value equipment.' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deductibleCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Deductible Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the deductible amount (e.g., USD, CAD, EUR).' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusions rdf:type rdf:Property ;
    rdfs:label 'Exclusions' ;
    rdfs:comment 'Specific items, conditions, or circumstances not covered by the warranty. Common exclusions include consumables, normal wear and tear, misuse, unauthorized modifications, and environmental damage from landfill leachate or corrosive waste.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:laborCoverageFlag rdf:type rdf:Property ;
    rdfs:label 'Labor Coverage Flag' ;
    rdfs:comment 'Indicates whether the warranty covers labor costs for repairs and service. True means labor is covered; false means labor must be paid separately.' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:partsCoverageFlag rdf:type rdf:Property ;
    rdfs:label 'Parts Coverage Flag' ;
    rdfs:comment 'Indicates whether the warranty covers replacement parts costs. True means parts are covered; false means parts must be purchased separately.' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:providerName rdf:type rdf:Property ;
    rdfs:label 'Provider Name' ;
    rdfs:comment 'Name of the company or organization providing the warranty coverage. May be the original equipment manufacturer (OEM), third-party warranty provider, or service contractor.' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Renewal Eligible Flag' ;
    rdfs:comment 'Indicates whether this warranty is eligible for renewal upon expiration. True means renewal option is available; false means warranty cannot be renewed.' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Notification Date' ;
    rdfs:comment 'Date when Waste Management should be notified about warranty renewal options. Typically 60-90 days before coverage end date to allow procurement lead time.' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:serviceResponseTimeHours rdf:type rdf:Property ;
    rdfs:label 'Service Response Time Hours' ;
    rdfs:comment 'Guaranteed maximum time in hours for warranty provider to respond to a service request. Part of warranty Service Level Agreement (SLA). Critical for high-availability equipment like MRF sorting lines and WTE boilers.' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:termsAndConditions rdf:type rdf:Property ;
    rdfs:label 'Terms And Conditions' ;
    rdfs:comment 'Full text or summary of warranty terms, conditions, exclusions, and limitations. Includes coverage scope, maintenance requirements, claim procedures, and exclusions (e.g., misuse, environmental damage, normal wear).' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalClaimsCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Total Claims Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the total claims value (e.g., USD, CAD, EUR).' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalClaimsValue rdf:type rdf:Property ;
    rdfs:label 'Total Claims Value' ;
    rdfs:comment 'Cumulative dollar value of all approved warranty claims paid under this warranty. Used for warranty ROI calculation and vendor performance assessment.' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transferableFlag rdf:type rdf:Property ;
    rdfs:label 'Transferable Flag' ;
    rdfs:comment 'Indicates whether the warranty can be transferred to a new owner if the asset is sold or relocated. True means warranty transfers with the asset; false means warranty is non-transferable.' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:travelCoverageFlag rdf:type rdf:Property ;
    rdfs:label 'Travel Coverage Flag' ;
    rdfs:comment 'Indicates whether the warranty covers technician travel and trip charges for on-site service. Particularly relevant for remote landfill sites, transfer stations, and MRF facilities.' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:warrantyNumber rdf:type rdf:Property ;
    rdfs:label 'Warranty Number' ;
    rdfs:comment 'Unique warranty certificate or policy number issued by the warranty provider. Used for warranty claim reference and tracking.' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyStatus rdf:type rdf:Property ;
    rdfs:label 'Warranty Status' ;
    rdfs:comment 'Current lifecycle status of the warranty. Active indicates coverage is in effect; expired indicates coverage period has ended; cancelled indicates warranty was terminated early; suspended indicates temporary hold; pending activation indicates warranty purchased but not yet effective.' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyType rdf:type rdf:Property ;
    rdfs:label 'Warranty Type' ;
    rdfs:comment 'Classification of warranty coverage. Manufacturer warranty is included with asset purchase; extended warranty is purchased separately; comprehensive covers parts and labor; parts-only covers replacement parts; labor-only covers service labor; service contract is ongoing maintenance agreement.' ;
    rdfs:domain ind:Warranty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Date' ;
    rdfs:comment 'Actual date when the project was completed and ready for capitalization or operational handover.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Spend Amount' ;
    rdfs:comment 'Cumulative actual expenditure incurred to date on the capital project, including committed and posted costs.' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualStartDate rdf:type rdf:Property ;
    rdfs:label 'Actual Start Date' ;
    rdfs:comment 'Actual date when project execution commenced (first work order issued or first cost posted).' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvedBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Approved Budget Amount' ;
    rdfs:comment 'Total capital expenditure budget approved for the project by the investment committee or board. Represents the authorized spending limit.' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:committedAmount rdf:type rdf:Property ;
    rdfs:label 'Committed Amount' ;
    rdfs:comment 'Total amount committed via purchase orders and contracts but not yet invoiced or paid.' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Planned Completion Date' ;
    rdfs:comment 'Target date for project completion as defined in the approved project schedule.' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedStartDate rdf:type rdf:Property ;
    rdfs:label 'Planned Start Date' ;
    rdfs:comment 'Scheduled date for project execution to begin, as defined in the project plan.' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:projectName rdf:type rdf:Property ;
    rdfs:label 'Project Name' ;
    rdfs:comment 'Descriptive name of the capital project (e.g., \'Landfill Cell 7 Construction\', \'MRF Baler Upgrade\').' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectNotes rdf:type rdf:Property ;
    rdfs:label 'Project Notes' ;
    rdfs:comment 'Free-form notes capturing important project milestones, issues, decisions, or other relevant information for audit and knowledge management.' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectNumber rdf:type rdf:Property ;
    rdfs:label 'Project Number' ;
    rdfs:comment 'Business-facing unique project number or code assigned to the capital project for external reference and tracking.' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectPriority rdf:type rdf:Property ;
    rdfs:label 'Project Priority' ;
    rdfs:comment 'Business priority ranking of the capital project: critical (regulatory/safety), high (strategic), medium (operational improvement), low (discretionary).' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectScopeDescription rdf:type rdf:Property ;
    rdfs:label 'Project Scope Description' ;
    rdfs:comment 'Detailed narrative description of the capital project scope, objectives, deliverables, and expected business outcomes.' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectStatus rdf:type rdf:Property ;
    rdfs:label 'Project Status' ;
    rdfs:comment 'Current lifecycle status of the capital project: planning (pre-approval), approved (budget authorized), in_progress (active execution), on_hold (temporarily suspended), completed (construction finished), cancelled (terminated before completion), closed (financially settled and capitalized). [ENUM-REF-CANDIDATE: planning|approved|in_progress|on_hold|completed|cancelled|closed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectType rdf:type rdf:Property ;
    rdfs:label 'Project Type' ;
    rdfs:comment 'Classification of the capital project by nature of work: new construction (greenfield facility), expansion (capacity increase), rehabilitation (major repair/refurbishment), technology upgrade (system modernization), equipment replacement (asset renewal), or environmental compliance (regulatory-driven improvements).' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskLevel rdf:type rdf:Property ;
    rdfs:label 'Risk Level' ;
    rdfs:comment 'Overall risk assessment of the capital project considering technical complexity, regulatory exposure, schedule constraints, and financial impact.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapInternalOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Internal Order Number' ;
    rdfs:comment 'SAP internal order number used for cost collection and tracking for smaller capital projects not requiring full WBS structure.' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapWbsElement rdf:type rdf:Property ;
    rdfs:label 'Sap Wbs Element' ;
    rdfs:comment 'SAP WBS element identifier for complex capital projects structured with hierarchical work breakdown for cost and schedule control.' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleVarianceDays rdf:type rdf:Property ;
    rdfs:label 'Schedule Variance Days' ;
    rdfs:comment 'Schedule variance in days calculated as actual completion date minus planned completion date. Positive values indicate delay, negative values indicate early completion.' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:varianceAmount rdf:type rdf:Property ;
    rdfs:label 'Variance Amount' ;
    rdfs:comment 'Budget variance calculated as actual spend minus approved budget. Positive values indicate over-budget, negative values indicate under-budget.' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:variancePercentage rdf:type rdf:Property ;
    rdfs:label 'Variance Percentage' ;
    rdfs:comment 'Budget variance expressed as a percentage of approved budget: (actual spend / approved budget - 1) * 100.' ;
    rdfs:domain ind:CapitalProject ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capitalProjectExpenditureId rdf:type rdf:Property ;
    rdfs:label 'Capital Project Expenditure Id' ;
    rdfs:comment 'Unique identifier for the capital project expenditure line item. Primary key.' ;
    rdfs:domain ind:CapitalProjectExpenditure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assetClass rdf:type rdf:Property ;
    rdfs:label 'Asset Class' ;
    rdfs:comment 'The asset class or category to which the capitalized expenditure will be assigned upon asset creation. Determines depreciation method, useful life, and general ledger account assignment (e.g., Buildings, Machinery, Vehicles, Landfill Infrastructure, MRF Equipment).' ;
    rdfs:domain ind:CapitalProjectExpenditure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetVarianceAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Variance Amount' ;
    rdfs:comment 'The variance between this expenditure and the budgeted amount for the associated budget line item. Positive values indicate over-budget spending; negative values indicate under-budget. Supports project cost control and variance reporting.' ;
    rdfs:domain ind:CapitalProjectExpenditure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capitalizationEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Capitalization Eligible Flag' ;
    rdfs:comment 'Boolean indicator (True/False) denoting whether this expenditure is eligible for capitalization as part of the fixed asset cost basis. True indicates the cost will be capitalized; False indicates it will be expensed. Drives the asset acquisition cost calculation and financial statement treatment.' ;
    rdfs:domain ind:CapitalProjectExpenditure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capitalizationReasonCode rdf:type rdf:Property ;
    rdfs:label 'Capitalization Reason Code' ;
    rdfs:comment 'Code indicating the reason for the capitalization eligibility determination. Values include: direct_material (materials incorporated into the asset), direct_labor (labor directly attributable to asset construction), freight_delivery (transportation costs), installation (installation and commissioning), site_preparation (site work required for asset placement), engineering_design (design and engineering services), permits_fees (regulatory permits and fees), interest_during_construction (financing costs during construction period), overhead_allocation (allocated indirect costs), non_capitalizable_expense (operating expense not eligible for capitalization), maintenance_repair (routine maintenance or repair costs). [ENUM-REF-CANDIDATE: direct_material|direct_labor|freight_delivery|installation|site_preparation|engineering_design|permits_fees|interest_during_construction|overhead_allocation|non_capitalizable_expense|maintenance_repair — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CapitalProjectExpenditure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Commitment Document Number' ;
    rdfs:comment 'The document number representing the financial commitment (purchase requisition, purchase order, or contract) that reserved budget for this expenditure. Supports commitment accounting and funds reservation tracking.' ;
    rdfs:domain ind:CapitalProjectExpenditure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costElement rdf:type rdf:Property ;
    rdfs:label 'Cost Element' ;
    rdfs:comment 'The cost element or general ledger account code to which this expenditure is classified. Represents the nature of the cost (e.g., materials, labor, equipment rental, professional services, freight). Aligns with the chart of accounts and cost accounting structure.' ;
    rdfs:domain ind:CapitalProjectExpenditure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costElementDescription rdf:type rdf:Property ;
    rdfs:label 'Cost Element Description' ;
    rdfs:comment 'Human-readable description of the cost element, providing business context for the type of expenditure (e.g., Construction Materials, Engineering Services, Equipment Purchase, Site Preparation).' ;
    rdfs:domain ind:CapitalProjectExpenditure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentDate rdf:type rdf:Property ;
    rdfs:label 'Document Date' ;
    rdfs:comment 'The date of the originating source document (invoice date, goods receipt date, timesheet date) that triggered this expenditure posting. Used for audit trail and variance analysis between document and posting dates.' ;
    rdfs:domain ind:CapitalProjectExpenditure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expenditureAmount rdf:type rdf:Property ;
    rdfs:label 'Expenditure Amount' ;
    rdfs:comment 'The monetary value of this expenditure line item in the transaction currency. Represents the gross cost posted to the capital project before any adjustments, taxes, or allocations.' ;
    rdfs:domain ind:CapitalProjectExpenditure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expenditureDate rdf:type rdf:Property ;
    rdfs:label 'Expenditure Date' ;
    rdfs:comment 'The date on which this expenditure was posted to the capital project in the financial system. Represents the accounting date for cost recognition, distinct from the document date or goods receipt date.' ;
    rdfs:domain ind:CapitalProjectExpenditure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expenditureNumber rdf:type rdf:Property ;
    rdfs:label 'Expenditure Number' ;
    rdfs:comment 'Business-readable identifier or line number for this expenditure transaction within the project accounting system. May correspond to a journal entry line, goods receipt line, or invoice line.' ;
    rdfs:domain ind:CapitalProjectExpenditure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goodsReceiptNumber rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Number' ;
    rdfs:comment 'The goods receipt document number that confirmed physical receipt of materials or completion of services. Links expenditure to the three-way match process (PO, GR, Invoice) and inventory movements.' ;
    rdfs:domain ind:CapitalProjectExpenditure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentDate rdf:type rdf:Property ;
    rdfs:label 'Payment Date' ;
    rdfs:comment 'The date on which payment was made to the vendor for this expenditure. Supports cash flow analysis and working capital management for capital projects.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Document Number' ;
    rdfs:comment 'The financial document number for the payment that settled this expenditure. Links to accounts payable payment run and cash management.' ;
    rdfs:domain ind:CapitalProjectExpenditure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingStatus rdf:type rdf:Property ;
    rdfs:label 'Posting Status' ;
    rdfs:comment 'The current posting status of this expenditure in the financial system. Values: posted (successfully posted to GL and project), pending (awaiting approval or posting), reversed (posting has been reversed), cancelled (transaction cancelled before posting), parked (saved as draft, not yet posted).' ;
    rdfs:domain ind:CapitalProjectExpenditure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseOrderLineItem rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Line Item' ;
    rdfs:comment 'The specific line item number within the purchase order that this expenditure relates to. Provides granular linkage to the ordered material or service specification.' ;
    rdfs:domain ind:CapitalProjectExpenditure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantity rdf:type rdf:Property ;
    rdfs:label 'Quantity' ;
    rdfs:comment 'The quantity of goods or services received for this expenditure line item. Used in conjunction with unit_of_measure for materials management and unit cost analysis.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reversalDate rdf:type rdf:Property ;
    rdfs:label 'Reversal Date' ;
    rdfs:comment 'The date on which this expenditure posting was reversed. Used for period-end reconciliation and financial statement adjustments.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reversalIndicator rdf:type rdf:Property ;
    rdfs:label 'Reversal Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this expenditure posting has been reversed (True) or is active (False). Supports audit trail and correction tracking.' ;
    rdfs:domain ind:CapitalProjectExpenditure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reversedDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reversed Document Number' ;
    rdfs:comment 'The document number of the reversal transaction if this expenditure has been reversed. Provides audit trail linkage between original and reversal postings.' ;
    rdfs:domain ind:CapitalProjectExpenditure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCode rdf:type rdf:Property ;
    rdfs:label 'Tax Code' ;
    rdfs:comment 'The tax jurisdiction or tax code applied to this expenditure. Determines tax rate, tax type, and tax account assignment.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workBreakdownStructureElement rdf:type rdf:Property ;
    rdfs:label 'Work Breakdown Structure Element' ;
    rdfs:comment 'The WBS element code within the project hierarchy to which this expenditure is assigned. Provides granular project phase or deliverable-level cost tracking (e.g., Design Phase, Site Preparation, Equipment Installation, Commissioning).' ;
    rdfs:domain ind:CapitalProjectExpenditure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerInventoryId rdf:type rdf:Property ;
    rdfs:label 'Container Inventory Id' ;
    rdfs:comment 'Unique identifier for the container inventory snapshot record.' ;
    rdfs:domain ind:ContainerInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:yardFacilityId rdf:type rdf:Property ;
    rdfs:label 'Yard Facility Id' ;
    rdfs:comment 'Identifier of the yard, maintenance shop, or staging area where the container inventory is held.' ;
    rdfs:domain ind:ContainerInventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:averageDailyDeployment rdf:type rdf:Property ;
    rdfs:label 'Average Daily Deployment' ;
    rdfs:comment 'The average number of containers of this type and size deployed per day over the last 30 days.' ;
    rdfs:domain ind:ContainerInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cycleCountFrequencyDays rdf:type rdf:Property ;
    rdfs:label 'Cycle Count Frequency Days' ;
    rdfs:comment 'The number of days between scheduled cycle counts for this container type and size.' ;
    rdfs:domain ind:ContainerInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:daysOfSupply rdf:type rdf:Property ;
    rdfs:label 'Days Of Supply' ;
    rdfs:comment 'The number of days the current available inventory can support based on average daily deployment rate.' ;
    rdfs:domain ind:ContainerInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inventoryDate rdf:type rdf:Property ;
    rdfs:label 'Inventory Date' ;
    rdfs:comment 'The date for which this inventory snapshot was recorded.' ;
    rdfs:domain ind:ContainerInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastPhysicalCountBy rdf:type rdf:Property ;
    rdfs:label 'Last Physical Count By' ;
    rdfs:comment 'Name or identifier of the employee who performed the last physical inventory count.' ;
    rdfs:domain ind:ContainerInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextScheduledCountDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Count Date' ;
    rdfs:comment 'The date when the next physical inventory count is scheduled for this container type and size.' ;
    rdfs:domain ind:ContainerInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quantityCondemned rdf:type rdf:Property ;
    rdfs:label 'Quantity Condemned' ;
    rdfs:comment 'Number of containers marked as condemned or awaiting disposal due to irreparable damage or end of useful life.' ;
    rdfs:domain ind:ContainerInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantityInRepair rdf:type rdf:Property ;
    rdfs:label 'Quantity In Repair' ;
    rdfs:comment 'Number of containers currently undergoing maintenance or repair.' ;
    rdfs:domain ind:ContainerInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantityInTransit rdf:type rdf:Property ;
    rdfs:label 'Quantity In Transit' ;
    rdfs:comment 'Number of containers in transit between facilities or being relocated.' ;
    rdfs:domain ind:ContainerInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalInventoryValue rdf:type rdf:Property ;
    rdfs:label 'Total Inventory Value' ;
    rdfs:comment 'The total value of the inventory on hand (quantity_on_hand multiplied by unit_cost).' ;
    rdfs:domain ind:ContainerInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceQuantity rdf:type rdf:Property ;
    rdfs:label 'Variance Quantity' ;
    rdfs:comment 'The difference between the system inventory count and the last physical count (positive or negative).' ;
    rdfs:domain ind:ContainerInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryTransferFacilityId rdf:type rdf:Property ;
    rdfs:label 'Primary Transfer Facility Id' ;
    rdfs:comment 'FK to asset.facility.facility_id — Transfer stations are physical facilities tracked in the asset domain. This FK enables joining transfer operations to facility maintenance, inspections, and capital planning.' ;
    rdfs:domain ind:TransferStation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:acceptsCommercialWaste rdf:type rdf:Property ;
    rdfs:label 'Accepts Commercial Waste' ;
    rdfs:comment 'Indicates whether the transfer station accepts commercial waste from business and industrial customers.' ;
    rdfs:domain ind:TransferStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:acceptsConstructionDebris rdf:type rdf:Property ;
    rdfs:label 'Accepts Construction Debris' ;
    rdfs:comment 'Indicates whether the transfer station accepts construction and demolition waste materials.' ;
    rdfs:domain ind:TransferStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:acceptsHazardousWaste rdf:type rdf:Property ;
    rdfs:label 'Accepts Hazardous Waste' ;
    rdfs:comment 'Indicates whether the transfer station is permitted and equipped to handle hazardous waste materials under RCRA regulations.' ;
    rdfs:domain ind:TransferStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:acceptsRecyclables rdf:type rdf:Property ;
    rdfs:label 'Accepts Recyclables' ;
    rdfs:comment 'Indicates whether the transfer station accepts recyclable materials for processing or transfer to MRF facilities.' ;
    rdfs:domain ind:TransferStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:acceptsResidentialWaste rdf:type rdf:Property ;
    rdfs:label 'Accepts Residential Waste' ;
    rdfs:comment 'Indicates whether the transfer station accepts residential MSW from collection routes.' ;
    rdfs:domain ind:TransferStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:environmentalComplianceOfficer rdf:type rdf:Property ;
    rdfs:label 'Environmental Compliance Officer' ;
    rdfs:comment 'Name of the environmental compliance officer responsible for regulatory compliance at this transfer station.' ;
    rdfs:domain ind:TransferStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingHoursWeekday rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Weekday' ;
    rdfs:comment 'Standard operating hours for the transfer station on weekdays, typically in format HH:MM-HH:MM.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingHoursWeekend rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Weekend' ;
    rdfs:comment 'Standard operating hours for the transfer station on weekends, typically in format HH:MM-HH:MM.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationalCapacityTpd rdf:type rdf:Property ;
    rdfs:label 'Operational Capacity Tpd' ;
    rdfs:comment 'Actual operational throughput capacity in tons per day based on equipment, staffing, and facility configuration.' ;
    rdfs:domain ind:TransferStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:permitNumber rdf:type rdf:Property ;
    rdfs:label 'Permit Number' ;
    rdfs:comment 'Primary operating permit number issued by the regulatory authority authorizing waste transfer operations at this facility.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scaleCount rdf:type rdf:Property ;
    rdfs:label 'Scale Count' ;
    rdfs:comment 'Number of truck scales installed at the transfer station for weighing incoming and outgoing vehicles.' ;
    rdfs:domain ind:TransferStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scaleType rdf:type rdf:Property ;
    rdfs:label 'Scale Type' ;
    rdfs:comment 'Primary type of weighing scale configuration used at the transfer station for weight ticket generation.' ;
    rdfs:domain ind:TransferStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stationCode rdf:type rdf:Property ;
    rdfs:label 'Station Code' ;
    rdfs:comment 'Business identifier code for the transfer station facility used in operational systems and reporting. Externally-known unique code for the facility.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stationName rdf:type rdf:Property ;
    rdfs:label 'Station Name' ;
    rdfs:comment 'Official business name of the transfer station facility as registered with regulatory authorities and used in customer communications.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadTicketId rdf:type rdf:Property ;
    rdfs:label 'Load Ticket Id' ;
    rdfs:comment 'Unique identifier for the inbound load ticket record. Primary key for the load ticket entity.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LoadTicket .

ind:outboundHaulFacilityId rdf:type rdf:Property ;
    rdfs:label 'Outbound Haul Facility Id' ;
    rdfs:comment 'Reference to the final disposal facility (landfill, WTE plant, MRF) where this load will be hauled after transfer station consolidation.' ;
    rdfs:domain ind:LoadTicket ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:disposalAuthorizationNumber rdf:type rdf:Property ;
    rdfs:label 'Disposal Authorization Number' ;
    rdfs:comment 'Pre-authorization or permit number authorizing disposal of this specific load. Required for certain waste streams or customer contracts.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Environmental Fee Amount' ;
    rdfs:comment 'Additional environmental surcharge or regulatory fee applied to this load based on jurisdiction requirements or waste stream type.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gateEntryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Gate Entry Timestamp' ;
    rdfs:comment 'Date and time when the vehicle entered the transfer station gate. Used for queue time analysis and facility throughput metrics.' ;
    rdfs:domain ind:LoadTicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:gateExitTimestamp rdf:type rdf:Property ;
    rdfs:label 'Gate Exit Timestamp' ;
    rdfs:comment 'Date and time when the vehicle exited the transfer station gate. Used for total facility dwell time calculation.' ;
    rdfs:domain ind:LoadTicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:haulerType rdf:type rdf:Property ;
    rdfs:label 'Hauler Type' ;
    rdfs:comment 'Classification of the entity that delivered this load: company-owned fleet, third-party contractor, municipal vehicle, or customer self-haul.' ;
    rdfs:domain ind:LoadTicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementAccuracyGrade rdf:type rdf:Property ;
    rdfs:label 'Measurement Accuracy Grade' ;
    rdfs:comment 'Quality classification of the weight measurement: certified (calibrated scale), standard (operational scale), or estimated (manual or backup method).' ;
    rdfs:domain ind:LoadTicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preEntryInspectionResult rdf:type rdf:Property ;
    rdfs:label 'Pre Entry Inspection Result' ;
    rdfs:comment 'Result of the pre-entry safety and load inspection conducted at the gate before allowing vehicle entry. Failed inspections may result in rejection.' ;
    rdfs:domain ind:LoadTicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionDispositionInstructions rdf:type rdf:Property ;
    rdfs:label 'Rejection Disposition Instructions' ;
    rdfs:comment 'Instructions provided to the driver for proper disposal of rejected loads, including alternative facility recommendations or remediation requirements.' ;
    rdfs:domain ind:LoadTicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionReasonCode rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for load rejection (e.g., prohibited materials, excessive contamination, unauthorized waste stream, permit violation).' ;
    rdfs:domain ind:LoadTicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfidTransponderScan rdf:type rdf:Property ;
    rdfs:label 'Rfid Transponder Scan' ;
    rdfs:comment 'RFID tag or transponder identifier scanned from the vehicle at gate entry. Used for automated vehicle identification and access control.' ;
    rdfs:domain ind:LoadTicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scaleCalibrationDate rdf:type rdf:Property ;
    rdfs:label 'Scale Calibration Date' ;
    rdfs:comment 'Date of the most recent calibration for the scale used to weigh this load. Required for measurement accuracy validation and regulatory compliance.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:wasteCharacterizationMethod rdf:type rdf:Property ;
    rdfs:label 'Waste Characterization Method' ;
    rdfs:comment 'Method used to determine the waste stream type and material composition: visual inspection, manifest declaration, physical sampling, customer declaration, or default profile.' ;
    rdfs:domain ind:LoadTicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteOriginJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Waste Origin Jurisdiction' ;
    rdfs:comment 'Municipality, county, or jurisdiction where the waste was collected. Required for regulatory reporting and flow control compliance.' ;
    rdfs:domain ind:LoadTicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scaleTransactionId rdf:type rdf:Property ;
    rdfs:label 'Scale Transaction Id' ;
    rdfs:comment 'Unique identifier for the scale transaction record. Primary key for the scale transaction entity.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ScaleTransaction .

ind:scaleCalibrationWorkOrderId rdf:type rdf:Property ;
    rdfs:label 'Scale Calibration Work Order Id' ;
    rdfs:comment 'Foreign key linking to maintenance.work_order. Business justification: Weights and measures regulations require traceable scale calibration records. scale_transaction already stores scale_calibration_date and scale_calibration_record_number as denormalized fields. Linkin' ;
    rdfs:domain ind:ScaleTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkOrder .

ind:scaleFixedAssetId rdf:type rdf:Property ;
    rdfs:label 'Scale Fixed Asset Id' ;
    rdfs:comment 'Foreign key linking to asset.fixed_asset. Business justification: Weighmaster regulatory compliance and scale calibration audit trails require each transaction to reference the specific certified scale equipment (fixed_asset). scale_transaction has scale_calibration' ;
    rdfs:domain ind:ScaleTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FixedAsset .

ind:materialType rdf:type rdf:Property ;
    rdfs:label 'Material Type' ;
    rdfs:comment 'Detailed description of the specific material type within the waste stream. Provides granular classification for disposal and recycling operations.' ;
    rdfs:domain ind:ScaleTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scaleCalibrationRecordNumber rdf:type rdf:Property ;
    rdfs:label 'Scale Calibration Record Number' ;
    rdfs:comment 'Reference to the most recent scale calibration record at the time of transaction. Ensures measurement accuracy and regulatory compliance.' ;
    rdfs:domain ind:ScaleTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionDate rdf:type rdf:Property ;
    rdfs:label 'Transaction Date' ;
    rdfs:comment 'Business date of the scale transaction. Used for daily reporting, billing cycles, and operational analytics.' ;
    rdfs:domain ind:ScaleTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:vehiclePlateNumber rdf:type rdf:Property ;
    rdfs:label 'Vehicle Plate Number' ;
    rdfs:comment 'License plate number of the vehicle being weighed. Used for manual verification and cross-reference.' ;
    rdfs:domain ind:ScaleTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weighmasterCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Weighmaster Certification Number' ;
    rdfs:comment 'Certification number of the licensed weighmaster who validated the transaction. Required for regulatory compliance in jurisdictions with weighmaster certification requirements.' ;
    rdfs:domain ind:ScaleTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tippingFeeRateId rdf:type rdf:Property ;
    rdfs:label 'Tipping Fee Rate Id' ;
    rdfs:comment 'Unique identifier for the tipping fee rate record. Primary key.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TippingFeeRate .

ind:supersededByRateTippingFeeRateId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Rate Tipping Fee Rate Id' ;
    rdfs:comment 'Reference to the new rate that replaces this rate when status is superseded. Nullable for active rates. Maintains rate version history.' ;
    rdfs:domain ind:TippingFeeRate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TippingFeeRate .

ind:fuelSurchargeApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Fuel Surcharge Applicable Flag' ;
    rdfs:comment 'Indicates whether a fuel surcharge can be applied to this rate. True if fuel surcharge is allowed, False otherwise.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rateAdjustmentPercentage rdf:type rdf:Property ;
    rdfs:label 'Rate Adjustment Percentage' ;
    rdfs:comment 'Percentage adjustment applied to base rate for special circumstances. Positive for surcharges, negative for discounts. Nullable if no adjustment applies.' ;
    rdfs:domain ind:TippingFeeRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateBasis rdf:type rdf:Property ;
    rdfs:label 'Rate Basis' ;
    rdfs:comment 'Unit of measure for rate calculation. Determines how the tipping fee is computed and applied to weight tickets.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCode rdf:type rdf:Property ;
    rdfs:label 'Rate Code' ;
    rdfs:comment 'Unique business identifier for the tipping fee rate schedule. Used for rate lookup and billing system integration.' ;
    rdfs:domain ind:TippingFeeRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateName rdf:type rdf:Property ;
    rdfs:label 'Rate Name' ;
    rdfs:comment 'Descriptive name for the tipping fee rate schedule. Human-readable identifier used in billing and reporting.' ;
    rdfs:domain ind:TippingFeeRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateNotes rdf:type rdf:Property ;
    rdfs:label 'Rate Notes' ;
    rdfs:comment 'Additional notes, terms, conditions, or special instructions related to this tipping fee rate. Free-text field for operational guidance.' ;
    rdfs:domain ind:TippingFeeRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratePerTon rdf:type rdf:Property ;
    rdfs:label 'Rate Per Ton' ;
    rdfs:comment 'Tipping fee charged per ton of waste disposed. Primary pricing metric for tonnage-based billing. Expressed in local currency.' ;
    rdfs:domain ind:TippingFeeRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateStatus rdf:type rdf:Property ;
    rdfs:label 'Rate Status' ;
    rdfs:comment 'Current lifecycle status of the tipping fee rate. Controls whether the rate can be applied to new transactions.' ;
    rdfs:domain ind:TippingFeeRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateTier rdf:type rdf:Property ;
    rdfs:label 'Rate Tier' ;
    rdfs:comment 'Pricing tier classification for this rate. Used for rate card segmentation and pricing strategy analysis.' ;
    rdfs:domain ind:TippingFeeRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAuthority rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority' ;
    rdfs:comment 'Name of the regulatory body or local enforcement agency that governs this rate. Used for compliance tracking and audit trails.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryRateCap rdf:type rdf:Property ;
    rdfs:label 'Regulatory Rate Cap' ;
    rdfs:comment 'Maximum tipping fee allowed by local regulatory authority. Nullable if no cap applies. Ensures compliance with local solid waste authority rate limits.' ;
    rdfs:domain ind:TippingFeeRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:seasonalRateFlag rdf:type rdf:Property ;
    rdfs:label 'Seasonal Rate Flag' ;
    rdfs:comment 'Indicates whether this is a seasonal rate with time-limited applicability. True for seasonal rates, False for year-round rates.' ;
    rdfs:domain ind:TippingFeeRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:volumeDiscountRatePerTon rdf:type rdf:Property ;
    rdfs:label 'Volume Discount Rate Per Ton' ;
    rdfs:comment 'Discounted rate per ton applied when volume threshold is exceeded. Nullable if no volume discount applies.' ;
    rdfs:domain ind:TippingFeeRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeDiscountThresholdTons rdf:type rdf:Property ;
    rdfs:label 'Volume Discount Threshold Tons' ;
    rdfs:comment 'Minimum tonnage required to qualify for volume-based discount pricing. Nullable if no volume discount applies.' ;
    rdfs:domain ind:TippingFeeRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:destinationFacilityId rdf:type rdf:Property ;
    rdfs:label 'Destination Facility Id' ;
    rdfs:comment 'Identifier of the destination facility receiving the outbound haul load (landfill, MRF, WTE, or TSDF).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WasteManagement .

ind:hazmatManifestId rdf:type rdf:Property ;
    rdfs:label 'Hazmat Manifest Id' ;
    rdfs:comment 'Foreign key linking to hazmat.manifest. Business justification: Outbound hauls from transfer stations to TSDF facilities require manifests for hazardous waste. Role-prefixed to distinguish from internal tracking; removes denormalized manifest_number text field.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Manifest .

ind:actualArrivalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Arrival Timestamp' ;
    rdfs:comment 'Actual date and time when the vehicle arrived at the destination facility. Used for delivery confirmation and facility gate operations.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualDepartureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Departure Timestamp' ;
    rdfs:comment 'Actual date and time when the vehicle departed the transfer station. Used for on-time performance tracking and DOT compliance.' ;
    rdfs:domain ind:OutboundHaul ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualTonnage rdf:type rdf:Property ;
    rdfs:label 'Actual Tonnage' ;
    rdfs:comment 'Actual weight of the waste load in tons as measured at the destination facility scale. Used for billing and disposal fee calculation.' ;
    rdfs:domain ind:OutboundHaul ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:destinationFacilityType rdf:type rdf:Property ;
    rdfs:label 'Destination Facility Type' ;
    rdfs:comment 'Classification of the destination facility type. MRF = Materials Recovery Facility, WTE = Waste-to-Energy, TSDF = Treatment Storage and Disposal Facility.' ;
    rdfs:domain ind:OutboundHaul ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedArrivalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Estimated Arrival Timestamp' ;
    rdfs:comment 'Estimated date and time for the vehicle to arrive at the destination facility based on route planning and traffic conditions.' ;
    rdfs:domain ind:Collection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:generatorSignatureCapturedFlag rdf:type rdf:Property ;
    rdfs:label 'Generator Signature Captured Flag' ;
    rdfs:comment 'Indicates whether the waste generator signature was captured on the manifest or BOL for chain-of-custody compliance.' ;
    rdfs:domain ind:OutboundHaul ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:haulNumber rdf:type rdf:Property ;
    rdfs:label 'Haul Number' ;
    rdfs:comment 'Externally-known business identifier for the outbound haul assignment. Used for operational tracking and communication with drivers, facilities, and regulatory agencies.' ;
    rdfs:domain ind:OutboundHaul ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:haulStatus rdf:type rdf:Property ;
    rdfs:label 'Haul Status' ;
    rdfs:comment 'Current lifecycle status of the outbound haul assignment in the dispatch and delivery workflow.' ;
    rdfs:domain ind:OutboundHaul ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadRejectionFlag rdf:type rdf:Property ;
    rdfs:label 'Load Rejection Flag' ;
    rdfs:comment 'Indicates whether the destination facility rejected the load due to contamination, improper classification, or facility capacity constraints.' ;
    rdfs:domain ind:OutboundHaul ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receiverSignatureCapturedFlag rdf:type rdf:Property ;
    rdfs:label 'Receiver Signature Captured Flag' ;
    rdfs:comment 'Indicates whether the destination facility receiver signature was captured on the manifest or BOL for chain-of-custody completion.' ;
    rdfs:domain ind:OutboundHaul ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:routeDistanceMiles rdf:type rdf:Property ;
    rdfs:label 'Route Distance Miles' ;
    rdfs:comment 'Total distance in miles from transfer station origin to destination facility. Used for fuel cost allocation and route optimization.' ;
    rdfs:domain ind:OutboundHaul ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduledDepartureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Departure Timestamp' ;
    rdfs:comment 'Planned date and time for the vehicle to depart the transfer station with the consolidated load.' ;
    rdfs:domain ind:OutboundHaul ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:transporterSignatureCapturedFlag rdf:type rdf:Property ;
    rdfs:label 'Transporter Signature Captured Flag' ;
    rdfs:comment 'Indicates whether the transporter (driver) signature was captured on the manifest or BOL for chain-of-custody compliance.' ;
    rdfs:domain ind:OutboundHaul ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:haulManifestId rdf:type rdf:Property ;
    rdfs:label 'Haul Manifest Id' ;
    rdfs:comment 'Unique identifier for the haul manifest record. Primary key.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HaulManifest .

ind:originTransferStationId rdf:type rdf:Property ;
    rdfs:label 'Origin Transfer Station Id' ;
    rdfs:comment 'Transfer station facility from which this haul originated. Starting point of the outbound shipment.' ;
    rdfs:domain ind:HaulManifest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TransferStation .

ind:bolReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Bol Reference Number' ;
    rdfs:comment 'Bill of Lading reference number accompanying this haul manifest. Links manifest to shipping documentation.' ;
    rdfs:domain ind:HaulManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationSignatureName rdf:type rdf:Property ;
    rdfs:label 'Destination Signature Name' ;
    rdfs:comment 'Name of the destination facility representative who signed the manifest upon receipt, confirming delivery and acceptance.' ;
    rdfs:domain ind:HaulManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationSignatureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Destination Signature Timestamp' ;
    rdfs:comment 'Date and time when the destination facility representative signed the manifest acknowledging receipt.' ;
    rdfs:domain ind:HaulManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:driverSignatureCapturedFlag rdf:type rdf:Property ;
    rdfs:label 'Driver Signature Captured Flag' ;
    rdfs:comment 'Indicates whether the driver signature was captured on the manifest document. Required for DOT compliance.' ;
    rdfs:domain ind:HaulManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:manifestIssuedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Manifest Issued Timestamp' ;
    rdfs:comment 'Date and time when the manifest document was officially issued and became active for this haul.' ;
    rdfs:domain ind:HaulManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:originSignatureName rdf:type rdf:Property ;
    rdfs:label 'Origin Signature Name' ;
    rdfs:comment 'Name of the transfer station representative who signed the manifest at origin, certifying the shipment details.' ;
    rdfs:domain ind:HaulManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originSignatureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Origin Signature Timestamp' ;
    rdfs:comment 'Date and time when the origin facility representative signed the manifest.' ;
    rdfs:domain ind:HaulManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rcraManifestRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Rcra Manifest Required Flag' ;
    rdfs:comment 'Indicates whether this haul requires a formal RCRA hazardous waste manifest under federal regulations.' ;
    rdfs:domain ind:HaulManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sealNumbers rdf:type rdf:Property ;
    rdfs:label 'Seal Numbers' ;
    rdfs:comment 'Security seal identification numbers applied to containers or trailer doors. Multiple seals may be comma-separated. Required for chain-of-custody integrity.' ;
    rdfs:domain ind:HaulManifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityCapacityId rdf:type rdf:Property ;
    rdfs:label 'Facility Capacity Id' ;
    rdfs:comment 'Unique identifier for the facility capacity tracking record. Primary key for daily and period-level capacity and throughput tracking at transfer stations.' ;
    rdfs:domain ind:FacilityCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualInboundTonnage rdf:type rdf:Property ;
    rdfs:label 'Actual Inbound Tonnage' ;
    rdfs:comment 'Total tonnage of waste received at the transfer station during the record date or period. Represents all incoming waste streams before sorting or processing.' ;
    rdfs:domain ind:FacilityCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualOutboundTonnage rdf:type rdf:Property ;
    rdfs:label 'Actual Outbound Tonnage' ;
    rdfs:comment 'Total tonnage of waste dispatched from the transfer station to disposal or processing facilities during the record date or period.' ;
    rdfs:domain ind:FacilityCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityStatus rdf:type rdf:Property ;
    rdfs:label 'Capacity Status' ;
    rdfs:comment 'Operational status of the transfer station capacity. Normal indicates utilization within acceptable range, near_capacity indicates approaching permit limits, over_capacity indicates permit exceedance, under_capacity indicates significantly below normal throughput.' ;
    rdfs:domain ind:FacilityCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityUtilizationPercentage rdf:type rdf:Property ;
    rdfs:label 'Capacity Utilization Percentage' ;
    rdfs:comment 'Percentage of permitted daily capacity utilized, calculated as (actual_inbound_tonnage / permitted_daily_capacity_tpd) * 100. Key performance indicator for capacity management.' ;
    rdfs:domain ind:FacilityCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataQualityScore rdf:type rdf:Property ;
    rdfs:label 'Data Quality Score' ;
    rdfs:comment 'Quality score (0.00 to 1.00) indicating the completeness and accuracy of the capacity record. Based on presence of required fields, validation checks, and data source reliability.' ;
    rdfs:domain ind:FacilityCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:diversionRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Diversion Rate Percentage' ;
    rdfs:comment 'Percentage of waste diverted from landfill disposal through recycling, composting, or waste-to-energy. Calculated as ((outbound_mrf_tonnage + outbound_wte_tonnage + outbound_organics_tonnage) / actual_inbound_tonnage) * 100. Key sustainability metric.' ;
    rdfs:domain ind:FacilityCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exceedanceReason rdf:type rdf:Property ;
    rdfs:label 'Exceedance Reason' ;
    rdfs:comment 'Explanation for why the permitted capacity was exceeded, if applicable. Includes operational circumstances, emergency conditions, or unplanned events that led to the exceedance.' ;
    rdfs:domain ind:FacilityCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceedanceTonnage rdf:type rdf:Property ;
    rdfs:label 'Exceedance Tonnage' ;
    rdfs:comment 'Tonnage by which the actual inbound tonnage exceeded the permitted daily capacity. Null if no exceedance occurred. Used for regulatory violation reporting and corrective action planning.' ;
    rdfs:domain ind:FacilityCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:floorStorageTonnage rdf:type rdf:Property ;
    rdfs:label 'Floor Storage Tonnage' ;
    rdfs:comment 'Tonnage of waste remaining on the transfer station floor at the end of the record date. Represents inventory not yet dispatched for disposal or processing.' ;
    rdfs:domain ind:FacilityCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inboundCdTonnage rdf:type rdf:Property ;
    rdfs:label 'Inbound Cd Tonnage' ;
    rdfs:comment 'Tonnage of construction and demolition (C&D) waste received during the record date or period. C&D includes debris from building, renovation, and demolition activities.' ;
    rdfs:domain ind:FacilityCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inboundLoadCount rdf:type rdf:Property ;
    rdfs:label 'Inbound Load Count' ;
    rdfs:comment 'Total count of inbound collection vehicles or loads received at the transfer station during the record date or period. Used for operational throughput analysis.' ;
    rdfs:domain ind:FacilityCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inboundMswTonnage rdf:type rdf:Property ;
    rdfs:label 'Inbound Msw Tonnage' ;
    rdfs:comment 'Tonnage of municipal solid waste (MSW) received during the record date or period. MSW includes residential and commercial non-hazardous waste.' ;
    rdfs:domain ind:FacilityCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inboundOrganicsTonnage rdf:type rdf:Property ;
    rdfs:label 'Inbound Organics Tonnage' ;
    rdfs:comment 'Tonnage of organic waste (food waste, yard waste, compostables) received during the record date or period. Tracked separately for diversion rate calculation.' ;
    rdfs:domain ind:FacilityCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inboundRecyclableTonnage rdf:type rdf:Property ;
    rdfs:label 'Inbound Recyclable Tonnage' ;
    rdfs:comment 'Tonnage of recyclable materials received during the record date or period. Includes materials destined for Materials Recovery Facility (MRF) processing.' ;
    rdfs:domain ind:FacilityCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operationalNotes rdf:type rdf:Property ;
    rdfs:label 'Operational Notes' ;
    rdfs:comment 'Free-text notes documenting operational conditions, equipment issues, weather impacts, or other factors affecting capacity and throughput during the record date or period.' ;
    rdfs:domain ind:FacilityCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outboundHaulCount rdf:type rdf:Property ;
    rdfs:label 'Outbound Haul Count' ;
    rdfs:comment 'Total count of outbound haul trucks dispatched from the transfer station to disposal or processing facilities during the record date or period.' ;
    rdfs:domain ind:FacilityCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:outboundLandfillTonnage rdf:type rdf:Property ;
    rdfs:label 'Outbound Landfill Tonnage' ;
    rdfs:comment 'Tonnage of waste hauled to landfill disposal facilities during the record date or period. Used for diversion rate calculation.' ;
    rdfs:domain ind:FacilityCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outboundMrfTonnage rdf:type rdf:Property ;
    rdfs:label 'Outbound Mrf Tonnage' ;
    rdfs:comment 'Tonnage of recyclable materials sent to Materials Recovery Facility (MRF) for processing during the record date or period. Contributes to diversion rate.' ;
    rdfs:domain ind:FacilityCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outboundWteTonnage rdf:type rdf:Property ;
    rdfs:label 'Outbound Wte Tonnage' ;
    rdfs:comment 'Tonnage of waste sent to waste-to-energy (WTE) facilities for energy recovery during the record date or period. Contributes to diversion rate.' ;
    rdfs:domain ind:FacilityCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:peakHourThroughputTons rdf:type rdf:Property ;
    rdfs:label 'Peak Hour Throughput Tons' ;
    rdfs:comment 'Maximum tonnage processed during any single hour of the record date. Used to identify operational bottlenecks and peak demand periods.' ;
    rdfs:domain ind:FacilityCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:peakHourTimestamp rdf:type rdf:Property ;
    rdfs:label 'Peak Hour Timestamp' ;
    rdfs:comment 'Timestamp indicating when the peak hour throughput occurred during the record date. Supports operational planning and resource allocation.' ;
    rdfs:domain ind:FacilityCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:permitExceedanceFlag rdf:type rdf:Property ;
    rdfs:label 'Permit Exceedance Flag' ;
    rdfs:comment 'Boolean flag indicating whether the actual inbound tonnage exceeded the permitted daily capacity. True indicates a regulatory compliance issue requiring immediate attention and reporting.' ;
    rdfs:domain ind:FacilityCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:permittedDailyCapacityTpd rdf:type rdf:Property ;
    rdfs:label 'Permitted Daily Capacity Tpd' ;
    rdfs:comment 'The maximum daily throughput capacity in tons per day (TPD) as authorized by the facility\'s operating permit. This is the regulatory limit that cannot be exceeded without permit violation.' ;
    rdfs:domain ind:FacilityCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recordDate rdf:type rdf:Property ;
    rdfs:label 'Record Date' ;
    rdfs:comment 'The specific date for which this capacity record applies. Used for daily capacity tracking and regulatory reporting.' ;
    rdfs:domain ind:FacilityCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recordPeriod rdf:type rdf:Property ;
    rdfs:label 'Record Period' ;
    rdfs:comment 'The reporting period for aggregated capacity tracking (e.g., 2024-Q1, 2024-03). Supports both monthly and quarterly period-level reporting.' ;
    rdfs:domain ind:FacilityCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Validation Timestamp' ;
    rdfs:comment 'Timestamp when the capacity record was validated and approved for regulatory reporting. Part of the audit trail for compliance documentation.' ;
    rdfs:domain ind:FacilityCapacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:contractReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Reference Number' ;
    rdfs:comment 'Reference number for the disposal services contract or Service Level Agreement (SLA) governing the relationship with this destination facility.' ;
    rdfs:domain ind:DestinationFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalFeePerTon rdf:type rdf:Property ;
    rdfs:label 'Environmental Fee Per Ton' ;
    rdfs:comment 'Additional environmental surcharge per ton assessed by the destination facility for regulatory compliance and environmental programs.' ;
    rdfs:domain ind:DestinationFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedTravelTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Estimated Travel Time Minutes' ;
    rdfs:comment 'Average travel time in minutes from the primary transfer station to this destination facility under normal traffic conditions.' ;
    rdfs:domain ind:DestinationFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:haulDistanceMiles rdf:type rdf:Property ;
    rdfs:label 'Haul Distance Miles' ;
    rdfs:comment 'Estimated road distance in miles from the primary transfer station to this destination facility, used for route optimization and cost planning.' ;
    rdfs:domain ind:DestinationFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preferredFacilityFlag rdf:type rdf:Property ;
    rdfs:label 'Preferred Facility Flag' ;
    rdfs:comment 'Indicates whether this destination facility is designated as a preferred routing target for cost or operational efficiency. True if preferred, False otherwise.' ;
    rdfs:domain ind:DestinationFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresManifestFlag rdf:type rdf:Property ;
    rdfs:label 'Requires Manifest Flag' ;
    rdfs:comment 'Indicates whether the destination facility requires hazardous waste manifests or Bills of Lading (BOL) for incoming loads. True if manifests required, False otherwise.' ;
    rdfs:domain ind:DestinationFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scaleAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Scale Available Flag' ;
    rdfs:comment 'Indicates whether the destination facility has certified scales for weighing incoming loads. True if scales are available, False otherwise.' ;
    rdfs:domain ind:DestinationFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:amendmentId rdf:type rdf:Property ;
    rdfs:label 'Amendment Id' ;
    rdfs:comment 'Foreign key linking to contract.amendment. Business justification: Invoices generated after a contract amendment must reference the amendment that triggered rate or scope changes. Revenue recognition, customer dispute resolution, and audit trails in waste management ' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Amendment .

ind:arAccountId rdf:type rdf:Property ;
    rdfs:label 'Ar Account Id' ;
    rdfs:comment 'Foreign key linking to billing.ar_account. Business justification: An invoice posts to an AR sub-ledger account. The ar_account tracks the outstanding balance, aging buckets, and collection status for the customer. Adding ar_account_id to invoice creates the direct A' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ArAccount .

ind:performanceObligationId rdf:type rdf:Property ;
    rdfs:label 'Performance Obligation Id' ;
    rdfs:comment 'Foreign key linking to contract.performance_obligation. Business justification: ASC 606 revenue recognition compliance requires invoices to reference the performance obligation they satisfy. Waste management companies must allocate transaction prices to performance obligations an' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PerformanceObligation .

ind:runId rdf:type rdf:Property ;
    rdfs:label 'Run Id' ;
    rdfs:comment 'Foreign key linking to billing.billing_run. Business justification: Invoices are generated by batch billing runs, but invoice table currently has no FK to billing_run. Adding billing_run_id FK establishes audit trail of which batch execution created each invoice, enab' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Run .

ind:adjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Adjustment Amount' ;
    rdfs:comment 'Net adjustments applied to the invoice for credits, billing corrections, dispute resolutions, or service exceptions.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingModelType rdf:type rdf:Property ;
    rdfs:label 'Billing Model Type' ;
    rdfs:comment 'Classification of the billing approach used for this invoice: subscription (fixed recurring), transactional (per-pickup), tipping fee (per-ton disposal), usage-based (metered), hybrid, or one-time charge.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Billing Period End Date' ;
    rdfs:comment 'End date of the service period covered by this invoice.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Billing Period Start Date' ;
    rdfs:comment 'Start date of the service period covered by this invoice.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customerType rdf:type rdf:Property ;
    rdfs:label 'Customer Type' ;
    rdfs:comment 'Classification of the customer being billed: residential household, commercial business, industrial facility, municipal contract, or government entity.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Delivery Method' ;
    rdfs:comment 'Method by which the invoice was or will be delivered to the customer: email, postal mail, customer portal, or EDI.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountAmount rdf:type rdf:Property ;
    rdfs:label 'Discount Amount' ;
    rdfs:comment 'Total discounts applied to the invoice, including promotional discounts, volume discounts, or contractual rate reductions.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Date' ;
    rdfs:comment 'Date the customer initiated the dispute on this invoice.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disputeFlag rdf:type rdf:Property ;
    rdfs:label 'Dispute Flag' ;
    rdfs:comment 'Indicates whether the customer has disputed this invoice. True if disputed, false otherwise.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disputeReason rdf:type rdf:Property ;
    rdfs:label 'Dispute Reason' ;
    rdfs:comment 'Customer-provided or agent-recorded reason for disputing the invoice (e.g., service not provided, incorrect charges, billing error).' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dueDate rdf:type rdf:Property ;
    rdfs:label 'Due Date' ;
    rdfs:comment 'Date by which payment is expected from the customer. Used for aging buckets and collections prioritization.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:invoiceStatus rdf:type rdf:Property ;
    rdfs:label 'Invoice Status' ;
    rdfs:comment 'Current lifecycle status of the invoice in the billing and collections workflow. [ENUM-REF-CANDIDATE: draft|issued|sent|paid|partially_paid|overdue|void|disputed|cancelled — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outstandingBalance rdf:type rdf:Property ;
    rdfs:label 'Outstanding Balance' ;
    rdfs:comment 'Remaining unpaid amount on the invoice (total_amount minus paid_amount). Used for accounts receivable aging and collections.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paidAmount rdf:type rdf:Property ;
    rdfs:label 'Paid Amount' ;
    rdfs:comment 'Total amount paid by the customer against this invoice to date. Used to calculate outstanding balance.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueRecognitionDate rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Date' ;
    rdfs:comment 'Date on which revenue from this invoice is recognized in the general ledger per GAAP/IFRS standards.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revenueRecognitionPeriod rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Period' ;
    rdfs:comment 'Fiscal period (YYYY-MM format) in which revenue from this invoice is recognized for financial reporting.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemInvoiceReference rdf:type rdf:Property ;
    rdfs:label 'Source System Invoice Reference' ;
    rdfs:comment 'Original invoice identifier in the source system. Used for traceability and reconciliation.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subtotalAmount rdf:type rdf:Property ;
    rdfs:label 'Subtotal Amount' ;
    rdfs:comment 'Sum of all line item charges before taxes, fees, adjustments, and discounts.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalAmount rdf:type rdf:Property ;
    rdfs:label 'Total Amount' ;
    rdfs:comment 'Final amount due from the customer after applying subtotal, taxes, discounts, and adjustments. This is the amount the customer must pay.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateComponentId rdf:type rdf:Property ;
    rdfs:label 'Rate Component Id' ;
    rdfs:comment 'Foreign key linking to billing.rate_component. Business justification: Each invoice line represents a specific charge component priced using a rate component definition. While invoice_line already has billing_rate_schedule_id (the parent schedule), it should also referen' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RateComponent .

ind:serviceRateScheduleId rdf:type rdf:Property ;
    rdfs:label 'Service Rate Schedule Id' ;
    rdfs:comment 'Foreign key linking to service.service_rate_schedule. Business justification: Rate audit process: billing_rate_schedule (billing engine) and service_rate_schedule (service catalog) are distinct products. Invoice line must reference the service catalog rate to enable rate reconc' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceRateSchedule .

ind:taxRuleId rdf:type rdf:Property ;
    rdfs:label 'Tax Rule Id' ;
    rdfs:comment 'Foreign key linking to billing.tax_rule. Business justification: Invoice line items currently have tax_code (STRING) and tax_amount but no FK to the tax_rule master. Tax rules define jurisdiction-specific tax rates, calculation methods, and applicability. Adding ta' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TaxRule .

ind:adjustmentReasonCode rdf:type rdf:Property ;
    rdfs:label 'Adjustment Reason Code' ;
    rdfs:comment 'Code indicating the reason for any billing adjustment on this line (e.g., service credit, billing correction, dispute resolution, promotional discount). Used for audit trail and dispute management.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargeCategory rdf:type rdf:Property ;
    rdfs:label 'Charge Category' ;
    rdfs:comment 'Revenue category classification for this line item. Used for financial reporting and revenue recognition (e.g., service charge, rental fee, disposal fee, fuel surcharge, environmental levy, late fee).' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceLineDescription rdf:type rdf:Property ;
    rdfs:label 'Invoice Line Description' ;
    rdfs:comment 'Detailed textual description of the charge appearing on the customer invoice. Provides human-readable explanation of what is being billed.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDisputed rdf:type rdf:Property ;
    rdfs:label 'Is Disputed' ;
    rdfs:comment 'Boolean flag indicating whether this line item is under dispute by the customer. Used for accounts receivable management and dispute resolution tracking.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineAmount rdf:type rdf:Property ;
    rdfs:label 'Line Amount' ;
    rdfs:comment 'Extended amount for this line item before taxes and adjustments. Calculated as quantity multiplied by unit rate, representing the base charge.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netAmount rdf:type rdf:Property ;
    rdfs:label 'Net Amount' ;
    rdfs:comment 'Final net amount for this line item after applying discounts and adding taxes. Represents the total charge to the customer for this line.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueRecognitionRule rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Rule' ;
    rdfs:comment 'Rule governing when and how revenue from this line item is recognized. Supports GAAP/IFRS compliance (e.g., immediate, deferred, prorated over service period, milestone-based).' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRecognizedDate rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognized Date' ;
    rdfs:comment 'Date when revenue from this line item was recognized in the general ledger. Used for GAAP/IFRS compliance and financial period closing.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:servicePeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Service Period End Date' ;
    rdfs:comment 'End date of the service period covered by this charge. Defines the conclusion of the billing period for recurring or subscription services.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:servicePeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Service Period Start Date' ;
    rdfs:comment 'Start date of the service period covered by this charge. Used for subscription-based and recurring services to define the billing period.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tonnage rdf:type rdf:Property ;
    rdfs:label 'Tonnage' ;
    rdfs:comment 'Weight of waste in tons for this line item. Used for tonnage-based billing at landfills, transfer stations, and disposal facilities. Measured in short tons (US) or metric tonnes.' ;
    rdfs:domain ind:InvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitRate rdf:type rdf:Property ;
    rdfs:label 'Unit Rate' ;
    rdfs:comment 'Price per unit of measure for this line item. The rate charged per pickup, per ton, per day, etc., before applying quantity.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentId rdf:type rdf:Property ;
    rdfs:label 'Payment Id' ;
    rdfs:comment 'Unique identifier for the payment transaction. Primary key.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Payment .

ind:paymentPlanId rdf:type rdf:Property ;
    rdfs:label 'Payment Plan Id' ;
    rdfs:comment 'Foreign key linking to billing.payment_plan. Business justification: When a customer is on a payment plan, individual installment payments must reference the payment plan they satisfy. This FK enables tracking of which payments fulfill which installment obligations, su' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentPlan .

ind:amount rdf:type rdf:Property ;
    rdfs:label 'Amount' ;
    rdfs:comment 'Total amount of the payment received from the customer, in the payment currency.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:appliedAmount rdf:type rdf:Property ;
    rdfs:label 'Applied Amount' ;
    rdfs:comment 'Portion of the payment amount that has been applied to one or more invoices.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:arBatchReference rdf:type rdf:Property ;
    rdfs:label 'Ar Batch Reference' ;
    rdfs:comment 'Identifier of the accounts receivable batch in which this payment was processed, used for AR reconciliation and audit.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Bank Account Number' ;
    rdfs:comment 'Bank account number from which the payment was drawn (for ACH, EFT, wire transfers). Masked or tokenized for security.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankDepositBatchReference rdf:type rdf:Property ;
    rdfs:label 'Bank Deposit Batch Reference' ;
    rdfs:comment 'Identifier of the bank deposit batch in which this payment was deposited, used for cash management and reconciliation.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankRoutingNumber rdf:type rdf:Property ;
    rdfs:label 'Bank Routing Number' ;
    rdfs:comment 'Bank routing number (ABA number) for ACH, EFT, or wire transfer payments.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearedDate rdf:type rdf:Property ;
    rdfs:label 'Cleared Date' ;
    rdfs:comment 'The date the payment cleared the bank and funds became available.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditCardLastFour rdf:type rdf:Property ;
    rdfs:label 'Credit Card Last Four' ;
    rdfs:comment 'Last four digits of the credit or debit card used for payment, for reference and reconciliation purposes.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditCardType rdf:type rdf:Property ;
    rdfs:label 'Credit Card Type' ;
    rdfs:comment 'Type of credit or debit card used for payment (Visa, MasterCard, American Express, Discover, other).' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depositDate rdf:type rdf:Property ;
    rdfs:label 'Deposit Date' ;
    rdfs:comment 'The date the payment was deposited into the company bank account.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:glDate rdf:type rdf:Property ;
    rdfs:label 'Gl Date' ;
    rdfs:comment 'The accounting date on which the payment was posted to the general ledger for financial reporting purposes.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:glPeriod rdf:type rdf:Property ;
    rdfs:label 'Gl Period' ;
    rdfs:comment 'The accounting period (e.g., 2024-01, Q1-2024) in which the payment was posted to the general ledger.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lockboxBatchReference rdf:type rdf:Property ;
    rdfs:label 'Lockbox Batch Reference' ;
    rdfs:comment 'Identifier of the lockbox batch for payments received via bank lockbox service, used for automated payment processing and reconciliation.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nsfFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Nsf Fee Amount' ;
    rdfs:comment 'Fee charged to the customer for a returned payment due to non-sufficient funds.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Number' ;
    rdfs:comment 'Business-facing unique reference number for the payment transaction, used for customer communication and reconciliation.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentType rdf:type rdf:Property ;
    rdfs:label 'Payment Type' ;
    rdfs:comment 'Classification of the payment transaction: standard payment against invoice, prepayment, advance deposit, retainer, refund, or credit memo application.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prepaymentExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Prepayment Expiry Date' ;
    rdfs:comment 'Expiration date for prepayments or advance deposits, after which the unapplied amount may be refunded or forfeited per contract terms.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:processor rdf:type rdf:Property ;
    rdfs:label 'Processor' ;
    rdfs:comment 'Name of the third-party payment processor or gateway used to process the payment (e.g., Stripe, PayPal, Authorize.Net).' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processorTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Processor Transaction Reference' ;
    rdfs:comment 'Unique transaction identifier assigned by the payment processor or gateway for tracking and reconciliation.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reference rdf:type rdf:Property ;
    rdfs:label 'Reference' ;
    rdfs:comment 'External reference number provided by the customer or payment processor (check number, transaction ID, confirmation code).' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundAmount rdf:type rdf:Property ;
    rdfs:label 'Refund Amount' ;
    rdfs:comment 'Amount refunded to the customer from this payment, if applicable.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:refundDate rdf:type rdf:Property ;
    rdfs:label 'Refund Date' ;
    rdfs:comment 'The date the refund was issued to the customer.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:refundStatus rdf:type rdf:Property ;
    rdfs:label 'Refund Status' ;
    rdfs:comment 'Status of any refund associated with this payment: not refunded, refund requested, refund approved, refund issued, or refund rejected.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalReason rdf:type rdf:Property ;
    rdfs:label 'Reversal Reason' ;
    rdfs:comment 'Reason code or description for payment reversal (NSF, stop payment, customer dispute, processing error, fraud).' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unappliedAmount rdf:type rdf:Property ;
    rdfs:label 'Unapplied Amount' ;
    rdfs:comment 'Portion of the payment amount that remains unapplied and available for future invoice application or refund.' ;
    rdfs:domain ind:Payment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentApplicationId rdf:type rdf:Property ;
    rdfs:label 'Payment Application Id' ;
    rdfs:comment 'Unique identifier for the payment application record. Primary key.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountingPeriod rdf:type rdf:Property ;
    rdfs:label 'Accounting Period' ;
    rdfs:comment 'The fiscal period identifier (e.g., 2024-Q1, 2024-01) to which this payment application is assigned for financial reporting and period close processes.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationDate rdf:type rdf:Property ;
    rdfs:label 'Application Date' ;
    rdfs:comment 'The date when the payment was applied to the invoice. This is the business event date used for accounting period assignment and Accounts Receivable (AR) aging calculations.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:applicationNumber rdf:type rdf:Property ;
    rdfs:label 'Application Number' ;
    rdfs:comment 'Business identifier for the payment application transaction. Used for tracking and reference in customer service and accounting operations.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationSource rdf:type rdf:Property ;
    rdfs:label 'Application Source' ;
    rdfs:comment 'The system or process that originated this payment application. Manual applications are entered by AR staff; automatic applications are system-matched; lockbox applications come from bank lockbox processing; customer portal applications are self-service; batch imports are from external systems; API applications are from integrated systems.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationStatus rdf:type rdf:Property ;
    rdfs:label 'Application Status' ;
    rdfs:comment 'Current lifecycle status of the payment application. Pending applications are awaiting approval; applied applications are finalized; reversed applications have been undone; voided applications are cancelled; adjusted applications have been modified post-application.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Application Timestamp' ;
    rdfs:comment 'Precise date and time when the payment application was processed in the system. Used for audit trail and transaction sequencing.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:applicationType rdf:type rdf:Property ;
    rdfs:label 'Application Type' ;
    rdfs:comment 'Classification of how the payment is being applied. Standard applications reduce open AR balance; prepayments are applied to future invoices; credit memo offsets apply credits; dispute settlements resolve billing disputes; overpayment allocations handle excess payments; refund reversals correct previously issued refunds.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountDate rdf:type rdf:Property ;
    rdfs:label 'Discount Date' ;
    rdfs:comment 'The date by which payment must be received to qualify for early payment discount. Used to validate discount eligibility at application time.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exchangeRate rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate' ;
    rdfs:comment 'The currency exchange rate used to convert payment amount to invoice currency, if cross-currency application. Null for same-currency applications.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exchangeRateDate rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate Date' ;
    rdfs:comment 'The date for which the exchange rate was determined. Used for foreign exchange gain/loss calculations and audit trail.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exchangeRateType rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate Type' ;
    rdfs:comment 'The type of exchange rate used for cross-currency applications. Spot rates are market rates at transaction time; corporate rates are company-defined standard rates; user-defined rates are manually entered.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceBalanceAfter rdf:type rdf:Property ;
    rdfs:label 'Invoice Balance After' ;
    rdfs:comment 'The outstanding balance of the invoice immediately after this payment application was processed. Used for audit trail and to determine if invoice is fully paid.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceBalanceBefore rdf:type rdf:Property ;
    rdfs:label 'Invoice Balance Before' ;
    rdfs:comment 'The outstanding balance of the invoice immediately before this payment application was processed. Used for audit trail and reconciliation.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isCrossCurrency rdf:type rdf:Property ;
    rdfs:label 'Is Cross Currency' ;
    rdfs:comment 'Indicates whether this payment application involves currency conversion (payment currency differs from invoice currency). Used for foreign exchange gain/loss tracking.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOnAccount rdf:type rdf:Property ;
    rdfs:label 'Is On Account' ;
    rdfs:comment 'Indicates whether this payment application represents an on-account credit (payment received without a specific invoice to apply to). True for prepayments and overpayments held for future application.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:matchingRuleCode rdf:type rdf:Property ;
    rdfs:label 'Matching Rule Code' ;
    rdfs:comment 'The automated matching rule that was used to apply this payment to the invoice (e.g., exact amount match, invoice number match, customer account match). Used for automatic cash application processes.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalAppliedAmount rdf:type rdf:Property ;
    rdfs:label 'Original Applied Amount' ;
    rdfs:comment 'The initial applied amount before any subsequent adjustments or reversals. Used to track the history of changes to the payment application.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentMethodCode rdf:type rdf:Property ;
    rdfs:label 'Payment Method Code' ;
    rdfs:comment 'The payment instrument used for this payment (e.g., check, ACH, credit card, wire transfer, cash). Denormalized from payment record for application-level reporting.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Reference Number' ;
    rdfs:comment 'External reference number from the payment transaction (e.g., check number, ACH trace number, credit card authorization code). Denormalized for reconciliation and customer service.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remainingUnappliedAmount rdf:type rdf:Property ;
    rdfs:label 'Remaining Unapplied Amount' ;
    rdfs:comment 'The portion of the original payment that remains unapplied after this application. Used for tracking partial payment scenarios and multi-invoice applications.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reversalReasonCode rdf:type rdf:Property ;
    rdfs:label 'Reversal Reason Code' ;
    rdfs:comment 'Standardized code indicating why the payment application was reversed. Examples include payment error, incorrect invoice, customer dispute, NSF (Non-Sufficient Funds), or administrative correction.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Reversal Reason Description' ;
    rdfs:comment 'Detailed explanation of why the payment application was reversed. Provides context for audit and customer service inquiries.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:writeoffAmount rdf:type rdf:Property ;
    rdfs:label 'Writeoff Amount' ;
    rdfs:comment 'The amount of invoice balance written off as uncollectible at the time of this payment application. Used in partial payment scenarios where remaining balance is deemed uncollectible.' ;
    rdfs:domain ind:PaymentApplication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accountClosedDate rdf:type rdf:Property ;
    rdfs:label 'Account Closed Date' ;
    rdfs:comment 'Date when the AR account was closed or terminated. Null for active accounts. Used for churn analysis and account lifecycle tracking.' ;
    rdfs:domain ind:ArAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accountOpenedDate rdf:type rdf:Property ;
    rdfs:label 'Account Opened Date' ;
    rdfs:comment 'Date when the AR account was first established for the customer. Used to calculate customer tenure and lifetime value.' ;
    rdfs:domain ind:ArAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:agingBucket030Days rdf:type rdf:Property ;
    rdfs:label 'Aging Bucket 0 30 Days' ;
    rdfs:comment 'Outstanding balance for invoices aged 0 to 30 days past due date. Current receivables within normal payment terms. Expressed in USD.' ;
    rdfs:domain ind:ArAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:agingBucket3160Days rdf:type rdf:Property ;
    rdfs:label 'Aging Bucket 31 60 Days' ;
    rdfs:comment 'Outstanding balance for invoices aged 31 to 60 days past due date. Moderately overdue receivables requiring follow-up. Expressed in USD.' ;
    rdfs:domain ind:ArAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:agingBucket6190Days rdf:type rdf:Property ;
    rdfs:label 'Aging Bucket 61 90 Days' ;
    rdfs:comment 'Outstanding balance for invoices aged 61 to 90 days past due date. Significantly overdue receivables requiring escalated collection efforts. Expressed in USD.' ;
    rdfs:domain ind:ArAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:agingBucketOver90Days rdf:type rdf:Property ;
    rdfs:label 'Aging Bucket Over 90 Days' ;
    rdfs:comment 'Outstanding balance for invoices aged more than 90 days past due date. Severely overdue receivables at high risk of uncollectibility, may require legal action or write-off consideration. Expressed in USD.' ;
    rdfs:domain ind:ArAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:arAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Ar Account Number' ;
    rdfs:comment 'Business identifier for the AR account, typically the customer account number used in billing and collections. May align with SAP FI AR account number or Oracle Revenue Management customer account number.' ;
    rdfs:domain ind:ArAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoPayEnrolledFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Pay Enrolled Flag' ;
    rdfs:comment 'Indicates whether the customer is enrolled in automatic payment processing. True means payments are automatically processed on due date; false means manual payment required.' ;
    rdfs:domain ind:ArAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:availableCredit rdf:type rdf:Property ;
    rdfs:label 'Available Credit' ;
    rdfs:comment 'Remaining credit available to the customer, calculated as credit limit minus current balance. Expressed in USD.' ;
    rdfs:domain ind:ArAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:badDebtReserve rdf:type rdf:Property ;
    rdfs:label 'Bad Debt Reserve' ;
    rdfs:comment 'Amount reserved for potential uncollectible receivables based on aging analysis and credit risk assessment. Used for allowance for doubtful accounts calculation. Expressed in USD.' ;
    rdfs:domain ind:ArAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingCurrency rdf:type rdf:Property ;
    rdfs:label 'Billing Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for invoicing and payments. Typically USD for US operations but may vary for international customers.' ;
    rdfs:domain ind:ArAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCycle rdf:type rdf:Property ;
    rdfs:label 'Billing Cycle' ;
    rdfs:comment 'Frequency at which the customer is billed for services. Monthly is standard residential; quarterly/annual are common for commercial; on-demand is for transactional services; custom is negotiated frequency.' ;
    rdfs:domain ind:ArAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionStatus rdf:type rdf:Property ;
    rdfs:label 'Collection Status' ;
    rdfs:comment 'Current stage in the collections process. Current indicates no collection activity; reminder/notices indicate escalating communication; collections-agency indicates third-party involvement; legal-action indicates court proceedings; payment-plan indicates negotiated repayment; settled indicates resolved. [ENUM-REF-CANDIDATE: current|reminder_sent|first_notice|second_notice|final_notice|collections_agency|legal_action|payment_plan|settled — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ArAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditHoldFlag rdf:type rdf:Property ;
    rdfs:label 'Credit Hold Flag' ;
    rdfs:comment 'Indicates whether the account is on credit hold. True means services are suspended due to credit issues; false means account is in good standing.' ;
    rdfs:domain ind:ArAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditHoldReason rdf:type rdf:Property ;
    rdfs:label 'Credit Hold Reason' ;
    rdfs:comment 'Reason code for why the account is on credit hold. Over-limit indicates balance exceeds credit limit; past-due indicates overdue invoices; bankruptcy indicates legal proceedings; fraud indicates suspected fraudulent activity; dispute indicates billing dispute; manual-hold indicates administrative hold; none indicates no hold. [ENUM-REF-CANDIDATE: over_limit|past_due|bankruptcy|fraud|dispute|manual_hold|none — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ArAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentBalance rdf:type rdf:Property ;
    rdfs:label 'Current Balance' ;
    rdfs:comment 'Total outstanding balance owed by the customer across all invoices. Represents the sum of all unpaid charges, fees, and adjustments. Expressed in USD.' ;
    rdfs:domain ind:ArAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:daysSalesOutstanding rdf:type rdf:Property ;
    rdfs:label 'Days Sales Outstanding' ;
    rdfs:comment 'Average number of days it takes the customer to pay invoices. Key metric for assessing payment behavior and credit risk. Calculated as (current balance / average daily sales).' ;
    rdfs:domain ind:ArAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:disputedAmount rdf:type rdf:Property ;
    rdfs:label 'Disputed Amount' ;
    rdfs:comment 'Total amount of charges currently under dispute by the customer. Expressed in USD.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dunningLevel rdf:type rdf:Property ;
    rdfs:label 'Dunning Level' ;
    rdfs:comment 'Current collection escalation level for overdue accounts. 0 indicates no dunning; 1-3 indicate progressive collection notice levels; higher numbers indicate more aggressive collection actions including legal proceedings.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastInvoiceAmount rdf:type rdf:Property ;
    rdfs:label 'Last Invoice Amount' ;
    rdfs:comment 'Amount of the most recent invoice issued to the customer. Expressed in USD.' ;
    rdfs:domain ind:ArAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastInvoiceDate rdf:type rdf:Property ;
    rdfs:label 'Last Invoice Date' ;
    rdfs:comment 'Date of the most recent invoice issued to the customer. Used to track billing activity and calculate days since last invoice.' ;
    rdfs:domain ind:ArAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Last Payment Amount' ;
    rdfs:comment 'Amount of the most recent payment received from the customer. Expressed in USD.' ;
    rdfs:domain ind:ArAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Last Payment Date' ;
    rdfs:comment 'Date of the most recent payment received from the customer. Used to track payment history and calculate days since last payment.' ;
    rdfs:domain ind:ArAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paperlessBillingFlag rdf:type rdf:Property ;
    rdfs:label 'Paperless Billing Flag' ;
    rdfs:comment 'Indicates whether the customer has opted for electronic invoicing instead of paper statements. True means electronic delivery only; false means paper statements are sent.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentPlanFlag rdf:type rdf:Property ;
    rdfs:label 'Payment Plan Flag' ;
    rdfs:comment 'Indicates whether the customer is on a negotiated payment plan for overdue balances. True means payment plan is active; false means no payment plan.' ;
    rdfs:domain ind:ArAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sapFiArAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Fi Ar Account Number' ;
    rdfs:comment 'The SAP FI customer account number in the accounts receivable sub-ledger. Used for integration and reconciliation with the SAP S/4HANA FI module.' ;
    rdfs:domain ind:ArAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExemptCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Exempt Certificate Number' ;
    rdfs:comment 'Government-issued tax exemption certificate number for tax-exempt customers. Required for audit compliance when tax-exempt flag is true.' ;
    rdfs:domain ind:ArAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalAdjustmentsYtd rdf:type rdf:Property ;
    rdfs:label 'Total Adjustments Ytd' ;
    rdfs:comment 'Total amount of billing adjustments (credits, write-offs, discounts) applied to the customer account in the current fiscal year. Expressed in USD.' ;
    rdfs:domain ind:ArAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalInvoicedYtd rdf:type rdf:Property ;
    rdfs:label 'Total Invoiced Ytd' ;
    rdfs:comment 'Total amount invoiced to the customer in the current fiscal year. Used for revenue analysis and customer value assessment. Expressed in USD.' ;
    rdfs:domain ind:ArAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPaymentsYtd rdf:type rdf:Property ;
    rdfs:label 'Total Payments Ytd' ;
    rdfs:comment 'Total amount of payments received from the customer in the current fiscal year. Used for cash flow analysis and payment behavior assessment. Expressed in USD.' ;
    rdfs:domain ind:ArAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:writeOffAmountYtd rdf:type rdf:Property ;
    rdfs:label 'Write Off Amount Ytd' ;
    rdfs:comment 'Total amount of receivables written off as uncollectible in the current fiscal year. Used for bad debt expense tracking and financial reporting. Expressed in USD.' ;
    rdfs:domain ind:ArAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:agreementTypeId rdf:type rdf:Property ;
    rdfs:label 'Agreement Type Id' ;
    rdfs:comment 'Foreign key linking to contract.agreement_type. Business justification: billing_rate_schedule.contract_type is a denormalized reference to contract.agreement_type. Normalizing this supports rate schedule management by agreement type, enables filtering rate schedules by cu' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AgreementType .

ind:baseRateAmount rdf:type rdf:Property ;
    rdfs:label 'Base Rate Amount' ;
    rdfs:comment 'Primary charge amount for the service before surcharges, fees, or adjustments. Unit of measure depends on billing model.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:billingModel rdf:type rdf:Property ;
    rdfs:label 'Billing Model' ;
    rdfs:comment 'Pricing methodology applied to calculate charges. Defines whether billing is fixed, usage-based, or hybrid.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerRentalFee rdf:type rdf:Property ;
    rdfs:label 'Container Rental Fee' ;
    rdfs:comment 'Monthly or periodic charge for rental of waste containers, dumpsters, or roll-off boxes. Separate from service pickup charges.' ;
    rdfs:domain ind:BillingRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disposalSurcharge rdf:type rdf:Property ;
    rdfs:label 'Disposal Surcharge' ;
    rdfs:comment 'Additional charge applied for disposal at landfill or processing facility. May vary by waste type or facility capacity.' ;
    rdfs:domain ind:BillingRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:glCostCenter rdf:type rdf:Property ;
    rdfs:label 'Gl Cost Center' ;
    rdfs:comment 'Cost center code for internal cost allocation and profitability analysis. Used for transfer pricing and divisional reporting.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glRevenueAccount rdf:type rdf:Property ;
    rdfs:label 'Gl Revenue Account' ;
    rdfs:comment 'General ledger account code where revenue from this rate schedule is recognized. Supports financial reporting and SOX compliance.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indexationFormula rdf:type rdf:Property ;
    rdfs:label 'Indexation Formula' ;
    rdfs:comment 'Formula or reference index used for automatic rate adjustments. May reference CPI, fuel price index, or commodity pricing.' ;
    rdfs:domain ind:BillingRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overageRate rdf:type rdf:Property ;
    rdfs:label 'Overage Rate' ;
    rdfs:comment 'Rate charged for usage exceeding contracted or included quantities. Applies to weight, volume, or pickup frequency overages.' ;
    rdfs:domain ind:BillingRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Rate Calculation Method' ;
    rdfs:comment 'Methodology used to compute the final charge. Defines whether rate is static, variable, or formula-driven.' ;
    rdfs:domain ind:BillingRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Rate Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the base rate amount. Defines the quantity basis for billing calculations. [ENUM-REF-CANDIDATE: ton|cubic_yard|pickup|month|gallon|container|pound — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BillingRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationClauseId rdf:type rdf:Property ;
    rdfs:label 'Escalation Clause Id' ;
    rdfs:comment 'Foreign key linking to contract.escalation_clause. Business justification: Rate components subject to contractual escalation (base rate, fuel surcharge) must reference the escalation clause governing their periodic adjustment. Automated escalation processing and contract com' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EscalationClause .

ind:supersededByComponentRateComponentId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Component Rate Component Id' ;
    rdfs:comment 'Reference to the rate component that replaces this one when a new version is created. Null if this is the current version.' ;
    rdfs:domain ind:RateComponent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RateComponent .

ind:appliesToContainerType rdf:type rdf:Property ;
    rdfs:label 'Applies To Container Type' ;
    rdfs:comment 'Container type(s) to which this component applies (e.g., 96-gallon cart, 2-yard dumpster, 40-yard rolloff). Pipe-separated list for multiple types. [ENUM-REF-CANDIDATE: 32_gal_cart|64_gal_cart|96_gal_cart|1_yard_dumpster|2_yard_dumpster|4_yard_dumpster|6_yard_dumpster|8_yard_dumpster|10_yard_rolloff|20_yard_rolloff|30_yard_rolloff|40_yard_rolloff|compactor — promote to reference product]' ;
    rdfs:domain ind:RateComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appliesToServiceType rdf:type rdf:Property ;
    rdfs:label 'Applies To Service Type' ;
    rdfs:comment 'Service type(s) to which this component applies (e.g., residential collection, commercial hauling, recycling). Pipe-separated list for multiple types. [ENUM-REF-CANDIDATE: residential_collection|commercial_collection|recycling|landfill_disposal|hazardous_waste|rolloff|compactor_rental|transfer_station — promote to reference product]' ;
    rdfs:domain ind:RateComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculationMethod rdf:type rdf:Property ;
    rdfs:label 'Calculation Method' ;
    rdfs:comment 'Method used to calculate the charge: fixed amount, percentage of base, per-unit rate, tiered pricing, or custom formula.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentCode rdf:type rdf:Property ;
    rdfs:label 'Component Code' ;
    rdfs:comment 'Unique business identifier code for the rate component (e.g., BASE_FEE, FUEL_SRCHG, ENV_FEE).' ;
    rdfs:domain ind:RateComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentName rdf:type rdf:Property ;
    rdfs:label 'Component Name' ;
    rdfs:comment 'Human-readable name of the rate component (e.g., Base Service Fee, Fuel Surcharge, Environmental Fee).' ;
    rdfs:domain ind:RateComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentStatus rdf:type rdf:Property ;
    rdfs:label 'Component Status' ;
    rdfs:comment 'Current lifecycle status of the rate component.' ;
    rdfs:domain ind:RateComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deferralPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Deferral Period Months' ;
    rdfs:comment 'Number of months over which revenue should be deferred when revenue_recognition_rule is deferred or over_service_period.' ;
    rdfs:domain ind:RateComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:formulaExpression rdf:type rdf:Property ;
    rdfs:label 'Formula Expression' ;
    rdfs:comment 'Custom calculation formula expression when calculation_method is formula. Uses Oracle Revenue Management formula syntax.' ;
    rdfs:domain ind:RateComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceLabel rdf:type rdf:Property ;
    rdfs:label 'Invoice Label' ;
    rdfs:comment 'Customer-facing label text to display on invoices when print_on_invoice_flag is true.' ;
    rdfs:domain ind:RateComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passThroughFlag rdf:type rdf:Property ;
    rdfs:label 'Pass Through Flag' ;
    rdfs:comment 'Indicates whether this component is a pass-through charge (collected from customer and remitted to third party) versus company revenue.' ;
    rdfs:domain ind:RateComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:printOnInvoiceFlag rdf:type rdf:Property ;
    rdfs:label 'Print On Invoice Flag' ;
    rdfs:comment 'Indicates whether this component should be displayed as a separate line item on customer invoices.' ;
    rdfs:domain ind:RateComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:profitCenter rdf:type rdf:Property ;
    rdfs:label 'Profit Center' ;
    rdfs:comment 'Profit center code for segment reporting and profitability analysis.' ;
    rdfs:domain ind:RateComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prorationMethod rdf:type rdf:Property ;
    rdfs:label 'Proration Method' ;
    rdfs:comment 'Method for prorating charges when service period is partial (e.g., mid-month start/stop).' ;
    rdfs:domain ind:RateComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateValue rdf:type rdf:Property ;
    rdfs:label 'Rate Value' ;
    rdfs:comment 'Numeric value of the rate component. Interpretation depends on calculation_method (e.g., dollar amount for fixed, percentage for percentage-based, rate per unit for per-unit).' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryFeeFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Fee Flag' ;
    rdfs:comment 'Indicates whether this component represents a government-mandated or regulatory fee that must be separately tracked for compliance reporting.' ;
    rdfs:domain ind:RateComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:roundingRule rdf:type rdf:Property ;
    rdfs:label 'Rounding Rule' ;
    rdfs:comment 'Rounding rule applied to calculated component amount.' ;
    rdfs:domain ind:RateComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCategory rdf:type rdf:Property ;
    rdfs:label 'Tax Category' ;
    rdfs:comment 'Tax treatment category for this component when taxable_flag is true.' ;
    rdfs:domain ind:RateComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxableFlag rdf:type rdf:Property ;
    rdfs:label 'Taxable Flag' ;
    rdfs:comment 'Indicates whether this rate component is subject to sales tax or other applicable taxes.' ;
    rdfs:domain ind:RateComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerTier rdf:type rdf:Property ;
    rdfs:label 'Customer Tier' ;
    rdfs:comment 'Customer segment or tier to which this tipping fee schedule applies, enabling tiered pricing strategies.' ;
    rdfs:domain ind:BillingTippingFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feePerTon rdf:type rdf:Property ;
    rdfs:label 'Fee Per Ton' ;
    rdfs:comment 'Base tipping fee charged per ton of waste disposed. Primary pricing component for tonnage-based billing.' ;
    rdfs:domain ind:BillingTippingFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hostCommunityFee rdf:type rdf:Property ;
    rdfs:label 'Host Community Fee' ;
    rdfs:comment 'Fee per ton paid to the host municipality or community as part of landfill operating agreements.' ;
    rdfs:domain ind:BillingTippingFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:internalTransferPricingFlag rdf:type rdf:Property ;
    rdfs:label 'Internal Transfer Pricing Flag' ;
    rdfs:comment 'Indicates whether this schedule is used for internal transfer pricing between operational units (True) or external customer billing (False).' ;
    rdfs:domain ind:BillingTippingFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:localTaxRate rdf:type rdf:Property ;
    rdfs:label 'Local Tax Rate' ;
    rdfs:comment 'Local jurisdiction tax rate applied to tipping fees, expressed as a decimal.' ;
    rdfs:domain ind:BillingTippingFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumLoadFee rdf:type rdf:Property ;
    rdfs:label 'Minimum Load Fee' ;
    rdfs:comment 'Minimum charge applied per load regardless of tonnage, ensuring cost recovery for small loads.' ;
    rdfs:domain ind:BillingTippingFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricingModel rdf:type rdf:Property ;
    rdfs:label 'Pricing Model' ;
    rdfs:comment 'Pricing methodology applied by this schedule (flat rate per ton, tiered pricing based on volume thresholds, time-of-day pricing).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateTaxRate rdf:type rdf:Property ;
    rdfs:label 'State Tax Rate' ;
    rdfs:comment 'State-level tax rate applied to tipping fees, expressed as a decimal (e.g., 0.0650 for 6.5%).' ;
    rdfs:domain ind:BillingTippingFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:advanceBillingEnabled rdf:type rdf:Property ;
    rdfs:label 'Advance Billing Enabled' ;
    rdfs:comment 'Indicates whether invoices are generated in advance of the service period (prepaid model) or after service delivery (arrears model). True for advance billing (invoice before service), False for arrears billing (invoice after service).' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:arAgingBucketDays rdf:type rdf:Property ;
    rdfs:label 'Ar Aging Bucket Days' ;
    rdfs:comment 'Comma-separated list of day thresholds for AR aging bucket calculations (e.g., 30,60,90,120 for standard 30-day buckets). Used to categorize outstanding receivables by age for collections prioritization and financial reporting.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoRenewalEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Enabled' ;
    rdfs:comment 'Indicates whether accounts in this billing cycle automatically renew at the end of each period without requiring manual intervention. True for ongoing subscription services, False for term-limited contracts requiring explicit renewal.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:billingPeriodDay rdf:type rdf:Property ;
    rdfs:label 'Billing Period Day' ;
    rdfs:comment 'Day of the month when the billing period closes and invoices are generated (1-31). For monthly cycles, this is the cutoff day. For bi-monthly or quarterly, this represents the anchor day.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:consolidationLevel rdf:type rdf:Property ;
    rdfs:label 'Consolidation Level' ;
    rdfs:comment 'Defines how invoices are consolidated for multi-site or hierarchical accounts. Account-level generates one invoice per account, site-level generates separate invoices per service location, parent-account rolls up all child accounts, consolidated combines all services into single invoice.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleCode rdf:type rdf:Property ;
    rdfs:label 'Cycle Code' ;
    rdfs:comment 'Short alphanumeric code identifying the billing cycle (e.g., MC01 for Monthly Cycle 01, BC15 for Bi-Monthly Cycle 15). Used as business identifier in Oracle Revenue Management.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleDescription rdf:type rdf:Property ;
    rdfs:label 'Cycle Description' ;
    rdfs:comment 'Detailed description of the billing cycle purpose, scope, and applicable customer segments.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleName rdf:type rdf:Property ;
    rdfs:label 'Cycle Name' ;
    rdfs:comment 'Descriptive name of the billing cycle for business user identification (e.g., Monthly Residential East, Quarterly Commercial West).' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleStatus rdf:type rdf:Property ;
    rdfs:label 'Cycle Status' ;
    rdfs:comment 'Current operational status of the billing cycle. Active for cycles currently in use, inactive for cycles not yet activated, suspended for temporarily disabled cycles, archived for historical cycles no longer in use but retained for audit purposes.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountEligibilityEnabled rdf:type rdf:Property ;
    rdfs:label 'Discount Eligibility Enabled' ;
    rdfs:comment 'Indicates whether accounts in this billing cycle are eligible for early payment discounts, volume discounts, or promotional pricing. True enables discount application rules, False excludes cycle from discount programs.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dunningProcessEnabled rdf:type rdf:Property ;
    rdfs:label 'Dunning Process Enabled' ;
    rdfs:comment 'Indicates whether automated dunning (collections reminder) process is enabled for overdue accounts in this billing cycle. True triggers escalating reminder notices and collection actions, False requires manual collections management.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:earlyPaymentDiscountDays rdf:type rdf:Property ;
    rdfs:label 'Early Payment Discount Days' ;
    rdfs:comment 'Number of days from invoice date within which payment must be received to qualify for early payment discount. Typically 10 days for 2/10 net-30 terms.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:earlyPaymentDiscountPercentage rdf:type rdf:Property ;
    rdfs:label 'Early Payment Discount Percentage' ;
    rdfs:comment 'Percentage discount offered for payment within specified early payment window (e.g., 2% discount if paid within 10 days). Common for commercial accounts to incentivize faster payment and improve cash flow.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:frequency rdf:type rdf:Property ;
    rdfs:label 'Frequency' ;
    rdfs:comment 'Recurrence pattern for invoice generation. Monthly for standard residential/commercial, bi-monthly for certain municipal contracts, quarterly for large commercial accounts, annual for prepaid contracts, per-haul for roll-off containers, on-demand for special services.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glArAccountCode rdf:type rdf:Property ;
    rdfs:label 'Gl Ar Account Code' ;
    rdfs:comment 'Default GL account code for posting accounts receivable from invoices in this billing cycle. Maps to SAP FI/CO chart of accounts for balance sheet reporting.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glRevenueAccountCode rdf:type rdf:Property ;
    rdfs:label 'Gl Revenue Account Code' ;
    rdfs:comment 'Default GL account code for posting revenue from invoices in this billing cycle. Maps to SAP FI/CO chart of accounts for financial reporting and revenue recognition.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gracePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Grace Period Days' ;
    rdfs:comment 'Number of days after payment due date before late fees are assessed or collection actions begin. Typically 5-10 days to accommodate payment processing delays.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:invoiceDeliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Invoice Delivery Method' ;
    rdfs:comment 'Primary method for delivering invoices to customers in this billing cycle. Email for electronic delivery, postal-mail for paper invoices, portal for customer self-service access, EDI for electronic data interchange with large commercial accounts, both for dual delivery.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceGenerationDate rdf:type rdf:Property ;
    rdfs:label 'Invoice Generation Date' ;
    rdfs:comment 'The date when invoices for this billing cycle are generated and made available to customers. Typically 1-3 days after billing period closes.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lateFeeFlatAmount rdf:type rdf:Property ;
    rdfs:label 'Late Fee Flat Amount' ;
    rdfs:comment 'Fixed dollar amount charged as late fee regardless of balance, used as alternative or supplement to percentage-based late fees. Common for residential accounts ($5-$25 flat fee).' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lateFeePercentage rdf:type rdf:Property ;
    rdfs:label 'Late Fee Percentage' ;
    rdfs:comment 'Percentage of outstanding balance charged as late fee when payment is overdue beyond grace period. Typically 1.5% to 3% per month, subject to state usury laws.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lateFeeTriggerEnabled rdf:type rdf:Property ;
    rdfs:label 'Late Fee Trigger Enabled' ;
    rdfs:comment 'Indicates whether late fees are automatically triggered for overdue invoices in this billing cycle. True enables automatic late fee assessment, False requires manual review.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentDueDateOffsetDays rdf:type rdf:Property ;
    rdfs:label 'Payment Due Date Offset Days' ;
    rdfs:comment 'Number of days after invoice generation date when payment is due. Typically 15, 30, or 45 days representing net-15, net-30, or net-45 payment terms.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:prorationEnabled rdf:type rdf:Property ;
    rdfs:label 'Proration Enabled' ;
    rdfs:comment 'Indicates whether charges are prorated for partial billing periods when accounts are activated or terminated mid-cycle. True enables daily proration calculations, False bills full period regardless of start/end dates.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revenueRecognitionMethod rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Method' ;
    rdfs:comment 'Accounting method for recognizing revenue from invoices in this billing cycle per GAAP/IFRS standards. Point-in-time for transactional services (per-haul), over-time for subscription services (monthly collection), milestone-based for project-based contracts.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statementGenerationEnabled rdf:type rdf:Property ;
    rdfs:label 'Statement Generation Enabled' ;
    rdfs:comment 'Indicates whether monthly account statements are generated in addition to individual invoices. True for accounts requiring consolidated statements showing all activity, False for invoice-only delivery.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Tax Calculation Method' ;
    rdfs:comment 'Method for calculating sales tax or VAT on invoices in this billing cycle. Standard applies jurisdiction-based tax rates, exempt for tax-exempt customers (municipalities, non-profits), reverse-charge for certain B2B transactions, mixed for accounts with both taxable and exempt services.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:writeOffThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Write Off Threshold Amount' ;
    rdfs:comment 'Maximum dollar amount that can be written off as bad debt without requiring executive approval. Balances below this threshold can be written off by collections team, amounts above require CFO or controller authorization per SOX controls.' ;
    rdfs:domain ind:Cycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accountsOnHold rdf:type rdf:Property ;
    rdfs:label 'Accounts On Hold' ;
    rdfs:comment 'Count of customer accounts excluded from billing due to hold status (e.g., payment dispute, account under review, service suspension).' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountsWithErrors rdf:type rdf:Property ;
    rdfs:label 'Accounts With Errors' ;
    rdfs:comment 'Count of customer accounts that encountered errors during billing run processing. Requires manual review and correction.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:arPostingStatus rdf:type rdf:Property ;
    rdfs:label 'Ar Posting Status' ;
    rdfs:comment 'Status of the accounts receivable posting for this billing run. Pending indicates awaiting posting; posted indicates successfully recorded in AR; failed indicates posting error; reversed indicates posting was reversed due to correction.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationSeconds rdf:type rdf:Property ;
    rdfs:label 'Duration Seconds' ;
    rdfs:comment 'Total elapsed time in seconds from run start to run end. Used for performance analysis and capacity planning.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:errorLogSummary rdf:type rdf:Property ;
    rdfs:label 'Error Log Summary' ;
    rdfs:comment 'High-level summary of errors encountered during billing run execution. Detailed error records are stored in separate error log tables.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glBatchNumber rdf:type rdf:Property ;
    rdfs:label 'Gl Batch Number' ;
    rdfs:comment 'SAP FI/CO batch identifier for the general ledger posting of this billing run revenue. Used for financial reconciliation and audit trail.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glPostingDate rdf:type rdf:Property ;
    rdfs:label 'Gl Posting Date' ;
    rdfs:comment 'Date when revenue from this billing run was posted to the general ledger in SAP FI/CO. Used for financial period close and revenue recognition.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:invoiceReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Invoice Release Date' ;
    rdfs:comment 'Date when invoices from this billing run were released to customers. May differ from run completion date if approval or review was required.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:runNumber rdf:type rdf:Property ;
    rdfs:label 'Run Number' ;
    rdfs:comment 'Business-friendly identifier for the billing run, typically formatted as cycle-sequence (e.g., 2024-01-001). Used for operational tracking and audit trail.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runStatus rdf:type rdf:Property ;
    rdfs:label 'Run Status' ;
    rdfs:comment 'Current lifecycle state of the billing run. Pending indicates queued for execution; in-progress indicates active processing; completed indicates successful finish; failed indicates error termination; cancelled indicates operator abort; suspended indicates paused awaiting intervention.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runType rdf:type rdf:Property ;
    rdfs:label 'Run Type' ;
    rdfs:comment 'Classification of the billing run execution mode. Scheduled runs are automated per billing cycle calendar; manual runs are operator-initiated; correction runs address prior errors; supplemental runs handle mid-cycle adjustments; final runs close the cycle; interim runs are preliminary.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalAccountsProcessed rdf:type rdf:Property ;
    rdfs:label 'Total Accounts Processed' ;
    rdfs:comment 'Count of distinct customer accounts included in this billing run. Used for reconciliation and completeness validation.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalAdjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Total Adjustment Amount' ;
    rdfs:comment 'Sum of all billing adjustments (credits, discounts, dispute resolutions) applied in this run, in USD. Negative values represent credits to customers.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalBilledAmount rdf:type rdf:Property ;
    rdfs:label 'Total Billed Amount' ;
    rdfs:comment 'Sum of all invoice amounts generated by this billing run, in USD. Represents gross revenue recognized for the billing period before payments and adjustments.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalInvoicesGenerated rdf:type rdf:Property ;
    rdfs:label 'Total Invoices Generated' ;
    rdfs:comment 'Count of invoices created by this billing run. May differ from accounts processed if some accounts have zero balance or are on hold.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalServiceChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Total Service Charge Amount' ;
    rdfs:comment 'Sum of all recurring service charges (container rentals, subscription fees) included in this run, in USD. Excludes usage-based charges and taxes.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Total Tax Amount' ;
    rdfs:comment 'Sum of all tax charges included in the invoices generated by this run, in USD. Includes sales tax, environmental fees, and regulatory surcharges.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalUsageChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Total Usage Charge Amount' ;
    rdfs:comment 'Sum of all usage-based charges (tonnage, pickups, tipping fees) included in this run, in USD. Excludes recurring service charges and taxes.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:zeroBalanceAccounts rdf:type rdf:Property ;
    rdfs:label 'Zero Balance Accounts' ;
    rdfs:comment 'Count of customer accounts processed that resulted in zero invoice amount due to no usage or offsetting credits.' ;
    rdfs:domain ind:Run ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adjustmentId rdf:type rdf:Property ;
    rdfs:label 'Adjustment Id' ;
    rdfs:comment 'Unique identifier for the billing adjustment record. Primary key.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:disputeId rdf:type rdf:Property ;
    rdfs:label 'Dispute Id' ;
    rdfs:comment 'Reference to the billing dispute case that triggered this adjustment. Links adjustments to customer dispute resolution workflows.' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Dispute .

ind:reversedAdjustmentId rdf:type rdf:Property ;
    rdfs:label 'Reversed Adjustment Id' ;
    rdfs:comment 'Reference to the original adjustment being reversed by this adjustment. Maintains bidirectional linkage for audit trail and correction tracking.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Adjustment .

ind:adjustmentNumber rdf:type rdf:Property ;
    rdfs:label 'Adjustment Number' ;
    rdfs:comment 'Externally visible unique business identifier for the adjustment. Used for customer communication, dispute tracking, and audit trails.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentStatus rdf:type rdf:Property ;
    rdfs:label 'Adjustment Status' ;
    rdfs:comment 'Current lifecycle state of the adjustment in the approval and posting workflow. Determines whether the adjustment has impacted financial statements and customer balances. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|rejected|posted|reversed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentType rdf:type rdf:Property ;
    rdfs:label 'Adjustment Type' ;
    rdfs:comment 'Classification of the adjustment indicating the nature of the correction or modification. Determines accounting treatment and approval workflow requirements. [ENUM-REF-CANDIDATE: credit_memo|debit_memo|service_credit|write_off|bad_debt|rate_correction|small_balance_write_off|promotional_discount|dispute_settlement|billing_error_correction — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:badDebtFlag rdf:type rdf:Property ;
    rdfs:label 'Bad Debt Flag' ;
    rdfs:comment 'Indicates whether this adjustment represents a bad debt write-off or uncollectible balance. Used for bad debt reserve calculations per ASC 326 Current Expected Credit Loss (CECL) standard.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:correctedChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Corrected Charge Amount' ;
    rdfs:comment 'Corrected invoice line item amount after adjustment. Used for billing error analysis and process improvement initiatives.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Date' ;
    rdfs:comment 'Date on which the customer was notified of the adjustment. Tracks communication timeliness and customer service performance.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customerNotificationFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Notification Flag' ;
    rdfs:comment 'Indicates whether the customer has been notified of this adjustment. Supports customer communication tracking and service quality management.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:externalReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'External Reference Number' ;
    rdfs:comment 'External reference identifier from the source system or third-party system. Supports cross-system reconciliation and audit trail linkage.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Original Charge Amount' ;
    rdfs:comment 'Original invoice line item amount before adjustment. Provides context for variance analysis and billing accuracy metrics.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Posted Timestamp' ;
    rdfs:comment 'Date and time when the adjustment was posted to the general ledger and customer account balance. Marks the point at which the adjustment impacts financial statements.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recoveryAmount rdf:type rdf:Property ;
    rdfs:label 'Recovery Amount' ;
    rdfs:comment 'Amount recovered from a previously written-off balance. Tracks bad debt recoveries for financial reporting and collections performance metrics.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recoveryDate rdf:type rdf:Property ;
    rdfs:label 'Recovery Date' ;
    rdfs:comment 'Date on which a previously written-off amount was recovered. Used for bad debt recovery reporting and collections analytics.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recoveryEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Recovery Eligible Flag' ;
    rdfs:comment 'Indicates whether a written-off balance is eligible for future recovery attempts. Used by collections teams to prioritize recovery efforts.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revenueImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Revenue Impact Amount' ;
    rdfs:comment 'Amount by which this adjustment impacts recognized revenue in the current accounting period. Used for revenue recognition reporting per ASC 606 and IFRS 15.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reversalFlag rdf:type rdf:Property ;
    rdfs:label 'Reversal Flag' ;
    rdfs:comment 'Indicates whether this adjustment reverses a previous adjustment. Used to track adjustment corrections and maintain audit trail integrity.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:writeOffFlag rdf:type rdf:Property ;
    rdfs:label 'Write Off Flag' ;
    rdfs:comment 'Indicates whether this adjustment represents a write-off of an uncollectible or immaterial balance. Supports accounts receivable aging and collections management.' ;
    rdfs:domain ind:Adjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerSatisfactionRating rdf:type rdf:Property ;
    rdfs:label 'Customer Satisfaction Rating' ;
    rdfs:comment 'Post-resolution customer satisfaction score (1-5 scale) collected via survey to measure dispute handling quality.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:disputeNumber rdf:type rdf:Property ;
    rdfs:label 'Dispute Number' ;
    rdfs:comment 'Human-readable business identifier for the dispute, used in customer communications and internal tracking.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeStatus rdf:type rdf:Property ;
    rdfs:label 'Dispute Status' ;
    rdfs:comment 'Current lifecycle status of the dispute in the resolution workflow.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationDate rdf:type rdf:Property ;
    rdfs:label 'Escalation Date' ;
    rdfs:comment 'The date the dispute was escalated to a higher authority for resolution.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:escalationLevel rdf:type rdf:Property ;
    rdfs:label 'Escalation Level' ;
    rdfs:comment 'Numeric indicator of how many times the dispute has been escalated to higher management tiers (0 = no escalation, 1 = first escalation, etc.).' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:financialImpactCategory rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Category' ;
    rdfs:comment 'Classification of the financial impact of the dispute and its resolution on the business.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionDate rdf:type rdf:Property ;
    rdfs:label 'Resolution Date' ;
    rdfs:comment 'The date the dispute was formally resolved and closed.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:resolutionType rdf:type rdf:Property ;
    rdfs:label 'Resolution Type' ;
    rdfs:comment 'The outcome classification of the dispute resolution indicating how the dispute was settled. [ENUM-REF-CANDIDATE: credit issued|charge upheld|partial credit|invoice corrected|waived|refund issued|adjustment applied — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTargetResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Sla Target Resolution Date' ;
    rdfs:comment 'The target date by which the dispute should be resolved per service level agreement commitments.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:soxComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Sox Compliance Flag' ;
    rdfs:comment 'Indicator of whether the dispute resolution followed SOX-compliant approval and documentation procedures for financial adjustments.' ;
    rdfs:domain ind:Dispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:autoPayEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Pay Enabled Flag' ;
    rdfs:comment 'Indicates whether automatic payment processing is enabled for this plan. When true, installments are automatically charged to the customers payment method on file on each due date.' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bankruptcyCaseNumber rdf:type rdf:Property ;
    rdfs:label 'Bankruptcy Case Number' ;
    rdfs:comment 'Court-assigned bankruptcy case number if this payment plan is part of a bankruptcy arrangement. Null for non-bankruptcy plans.' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankruptcyChapter rdf:type rdf:Property ;
    rdfs:label 'Bankruptcy Chapter' ;
    rdfs:comment 'Type of bankruptcy filing if this payment plan is part of a bankruptcy arrangement. Chapter 7 is liquidation; Chapter 11 is business reorganization; Chapter 13 is individual debt adjustment. Null for non-bankruptcy plans.' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultThresholdCount rdf:type rdf:Property ;
    rdfs:label 'Default Threshold Count' ;
    rdfs:comment 'Number of missed installments allowed before the plan is automatically moved to defaulted status. Typically 2 for standard plans, may be higher for hardship programs.' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:downPaymentAmount rdf:type rdf:Property ;
    rdfs:label 'Down Payment Amount' ;
    rdfs:comment 'Initial payment required at plan setup before installment schedule begins. May be zero for certain hardship programs.' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:downPaymentReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Down Payment Received Date' ;
    rdfs:comment 'Date the down payment was received and processed. Null if no down payment was required or if down payment is still outstanding.' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enrolledBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Enrolled Balance Amount' ;
    rdfs:comment 'The portion of the original balance that was enrolled into this payment plan. May be less than original balance if customer made partial payment or if certain charges were excluded from the plan.' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:finalInstallmentDueDate rdf:type rdf:Property ;
    rdfs:label 'Final Installment Due Date' ;
    rdfs:comment 'Scheduled due date for the last installment payment. Represents the planned completion date of the payment plan.' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:firstInstallmentDueDate rdf:type rdf:Property ;
    rdfs:label 'First Installment Due Date' ;
    rdfs:comment 'Scheduled due date for the first installment payment. Subsequent installments are calculated based on this date and the installment frequency.' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:installmentAmount rdf:type rdf:Property ;
    rdfs:label 'Installment Amount' ;
    rdfs:comment 'Standard amount due for each installment payment. Calculated as (enrolled_balance_amount - down_payment_amount) / total_installment_count. Final installment may differ to account for rounding.' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:installmentFrequency rdf:type rdf:Property ;
    rdfs:label 'Installment Frequency' ;
    rdfs:comment 'Cadence at which installment payments are scheduled. Monthly is most common; weekly and biweekly are used for residential hardship programs; quarterly may be used for large commercial accounts.' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interestAccruedAmount rdf:type rdf:Property ;
    rdfs:label 'Interest Accrued Amount' ;
    rdfs:comment 'Total interest charges accrued on this payment plan to date. Zero for interest-free plans.' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interestRatePercent rdf:type rdf:Property ;
    rdfs:label 'Interest Rate Percent' ;
    rdfs:comment 'Annual interest rate applied to the enrolled balance, if any. Most residential hardship plans have zero interest; commercial workout agreements may include interest. Expressed as percentage (e.g., 5.00 for 5%).' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lateFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Late Fee Amount' ;
    rdfs:comment 'Standard late fee charged for each missed installment payment. May be waived for hardship programs.' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:missedInstallmentCount rdf:type rdf:Property ;
    rdfs:label 'Missed Installment Count' ;
    rdfs:comment 'Number of scheduled installments that were not paid by their due date. Used to determine default status and trigger collections escalation.' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Original Balance Amount' ;
    rdfs:comment 'Total outstanding accounts receivable (AR) balance at the time the payment plan was established. Represents the full amount owed before any plan payments were made.' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planEndDate rdf:type rdf:Property ;
    rdfs:label 'Plan End Date' ;
    rdfs:comment 'Actual date the payment plan was completed, defaulted, or cancelled. Null for active or suspended plans. For completed plans, this is the date the final payment was received; for defaulted or cancelled plans, this is the date the plan was terminated.' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planStartDate rdf:type rdf:Property ;
    rdfs:label 'Plan Start Date' ;
    rdfs:comment 'Effective date when the payment plan became active and the installment schedule began. Typically the date the plan was approved and down payment (if required) was received.' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remainingBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Remaining Balance Amount' ;
    rdfs:comment 'Current outstanding balance remaining on the payment plan after all payments received to date. Calculated as enrolled_balance_amount minus sum of all installment payments received.' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementDiscountAmount rdf:type rdf:Property ;
    rdfs:label 'Settlement Discount Amount' ;
    rdfs:comment 'Dollar amount of discount applied to the original balance as part of a settlement agreement. Zero for standard payment plans.' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementDiscountPercent rdf:type rdf:Property ;
    rdfs:label 'Settlement Discount Percent' ;
    rdfs:comment 'Percentage discount applied to the original balance as part of a settlement agreement. Zero for standard payment plans. Expressed as percentage (e.g., 20.00 for 20% discount).' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalInstallmentCount rdf:type rdf:Property ;
    rdfs:label 'Total Installment Count' ;
    rdfs:comment 'Total number of scheduled installment payments in this plan. Typically ranges from 3 to 24 installments depending on plan type and balance amount.' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalLateFeesAssessed rdf:type rdf:Property ;
    rdfs:label 'Total Late Fees Assessed' ;
    rdfs:comment 'Cumulative sum of all late fees assessed on this payment plan due to missed installments.' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPaidAmount rdf:type rdf:Property ;
    rdfs:label 'Total Paid Amount' ;
    rdfs:comment 'Cumulative sum of all payments received against this payment plan, including down payment and all installment payments to date.' ;
    rdfs:domain ind:PaymentPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:applicabilityCustomerType rdf:type rdf:Property ;
    rdfs:label 'Applicability Customer Type' ;
    rdfs:comment 'Pipe-separated list of customer types to which this surcharge applies (e.g., residential|commercial|industrial|municipal). Empty if applicable to all customer types. [ENUM-REF-CANDIDATE: residential|commercial|industrial|municipal|government|non_profit|construction — promote to reference product]' ;
    rdfs:domain ind:Surcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicabilityServiceType rdf:type rdf:Property ;
    rdfs:label 'Applicability Service Type' ;
    rdfs:comment 'Pipe-separated list of service types to which this surcharge applies (e.g., collection|disposal|recycling|hazardous_waste|roll_off). Empty if applicable to all service types. [ENUM-REF-CANDIDATE: collection|disposal|recycling|hazardous_waste|roll_off|compactor|special_waste|medical_waste — promote to reference product]' ;
    rdfs:domain ind:Surcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalRequired rdf:type rdf:Property ;
    rdfs:label 'Approval Required' ;
    rdfs:comment 'Indicates whether application of this surcharge to a customer invoice requires managerial approval. True if approval required, False if can be applied automatically.' ;
    rdfs:domain ind:Surcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:calculationBasis rdf:type rdf:Property ;
    rdfs:label 'Calculation Basis' ;
    rdfs:comment 'Method used to calculate the surcharge amount: percentage_of_base (percentage of base service charge), flat_fee (fixed dollar amount), per_ton (rate per ton of waste), per_yard (rate per cubic yard), per_pickup (rate per pickup event), per_container (rate per container), tiered (tiered rate structure), formula (custom formula-based calculation). [ENUM-REF-CANDIDATE: percentage_of_base|flat_fee|per_ton|per_yard|per_pickup|per_container|tiered|formula — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Surcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceDescription rdf:type rdf:Property ;
    rdfs:label 'Invoice Description' ;
    rdfs:comment 'Customer-facing description of the surcharge as it appears on invoices. May differ from internal surcharge_name to provide clearer customer communication.' ;
    rdfs:domain ind:Surcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceDisplayOrder rdf:type rdf:Property ;
    rdfs:label 'Invoice Display Order' ;
    rdfs:comment 'Numeric sequence order in which this surcharge should appear on customer invoices. Lower numbers appear first. Used to control invoice line item presentation.' ;
    rdfs:domain ind:Surcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isProrated rdf:type rdf:Property ;
    rdfs:label 'Is Prorated' ;
    rdfs:comment 'Indicates whether this surcharge should be prorated for partial billing periods (e.g., mid-month service start/stop). True if prorated, False if charged in full regardless of period.' ;
    rdfs:domain ind:Surcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRecurring rdf:type rdf:Property ;
    rdfs:label 'Is Recurring' ;
    rdfs:comment 'Indicates whether this surcharge is applied on a recurring basis (e.g., monthly fuel surcharge) or is a one-time charge. True if recurring, False if one-time.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRegulatoryMandated rdf:type rdf:Property ;
    rdfs:label 'Is Regulatory Mandated' ;
    rdfs:comment 'Indicates whether this surcharge is mandated by regulatory authority (EPA, state environmental agency, local solid waste authority) or is a discretionary business charge. True if regulatory-mandated, False if discretionary.' ;
    rdfs:domain ind:Surcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTaxable rdf:type rdf:Property ;
    rdfs:label 'Is Taxable' ;
    rdfs:comment 'Indicates whether this surcharge is subject to sales tax or other applicable taxes. True if taxable, False if tax-exempt.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recurrenceFrequency rdf:type rdf:Property ;
    rdfs:label 'Recurrence Frequency' ;
    rdfs:comment 'Frequency at which this surcharge recurs: monthly (every month), quarterly (every quarter), annually (every year), per_service (each service event), one_time (single occurrence). Populated only when is_recurring is True.' ;
    rdfs:domain ind:Surcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueCategory rdf:type rdf:Property ;
    rdfs:label 'Revenue Category' ;
    rdfs:comment 'High-level revenue classification for financial reporting: service_revenue (core service charges), surcharge_revenue (fuel and environmental surcharges), fee_revenue (administrative and regulatory fees), penalty_revenue (late payment and violation penalties), other_revenue (miscellaneous revenue).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surchargeCode rdf:type rdf:Property ;
    rdfs:label 'Surcharge Code' ;
    rdfs:comment 'Unique business identifier code for the surcharge (e.g., FUEL_SUR, ENV_FEE, REG_REC, ADMIN_FEE, LATE_PAY). Used in billing systems and customer communications.' ;
    rdfs:domain ind:Surcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surchargeName rdf:type rdf:Property ;
    rdfs:label 'Surcharge Name' ;
    rdfs:comment 'Full descriptive name of the surcharge as it appears on customer invoices (e.g., Fuel Surcharge, Environmental Fee, Regulatory Recovery Fee, Administrative Fee, Late Payment Fee).' ;
    rdfs:domain ind:Surcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surchargeStatus rdf:type rdf:Property ;
    rdfs:label 'Surcharge Status' ;
    rdfs:comment 'Current lifecycle status of the surcharge definition: active (currently in use), inactive (not in use), pending (approved but not yet effective), expired (past effective end date), suspended (temporarily disabled).' ;
    rdfs:domain ind:Surcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surchargeType rdf:type rdf:Property ;
    rdfs:label 'Surcharge Type' ;
    rdfs:comment 'Classification of the surcharge by business purpose: fuel (fuel cost recovery), environmental (environmental compliance fees), regulatory (regulatory recovery fees), administrative (administrative processing fees), late_payment (late payment penalties), disposal (special disposal fees), contamination (contamination processing fees), distance (distance-based fees), special_handling (special handling fees), other (miscellaneous surcharges). [ENUM-REF-CANDIDATE: fuel|environmental|regulatory|administrative|late_payment|disposal|contamination|distance|special_handling|other — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Surcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratedUsageId rdf:type rdf:Property ;
    rdfs:label 'Rated Usage Id' ;
    rdfs:comment 'Unique identifier for the rated usage record. Primary key for the rated usage entity.' ;
    rdfs:domain ind:RatedUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:appliedSurchargeId rdf:type rdf:Property ;
    rdfs:label 'Applied Surcharge Id' ;
    rdfs:comment 'Foreign key linking to billing.surcharge. Business justification: Rated usage records capture priced usage events with fuel_surcharge_amount, environmental_fee_amount, and other_surcharge_amount. Adding applied_surcharge_id FK links to the surcharge master definitio' ;
    rdfs:domain ind:RatedUsage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Surcharge .

ind:baseChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Base Charge Amount' ;
    rdfs:comment 'Calculated charge amount before surcharges, fees, and taxes. Computed as usage_quantity multiplied by unit_rate.' ;
    rdfs:domain ind:RatedUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelSurchargeAmount rdf:type rdf:Property ;
    rdfs:label 'Fuel Surcharge Amount' ;
    rdfs:comment 'Additional charge applied to cover fuel cost fluctuations. Calculated based on fuel surcharge rate schedule and usage quantity.' ;
    rdfs:domain ind:RatedUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overrideFlag rdf:type rdf:Property ;
    rdfs:label 'Override Flag' ;
    rdfs:comment 'Indicates whether this rated usage was manually overridden by a billing analyst. True if rates or amounts were manually adjusted, false for standard rating engine output.' ;
    rdfs:domain ind:RatedUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overrideReasonCode rdf:type rdf:Property ;
    rdfs:label 'Override Reason Code' ;
    rdfs:comment 'Reason code for manual override if override_flag is true. Null for non-overridden records. Supports audit trail and dispute resolution.' ;
    rdfs:domain ind:RatedUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideTimestamp rdf:type rdf:Property ;
    rdfs:label 'Override Timestamp' ;
    rdfs:comment 'Date and time when the manual override was performed. Null for non-overridden records.' ;
    rdfs:domain ind:RatedUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ratedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Rated Timestamp' ;
    rdfs:comment 'Date and time when the rating engine processed and priced this usage event. Represents the rating execution time, not the usage occurrence time.' ;
    rdfs:domain ind:RatedUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ratingErrorCode rdf:type rdf:Property ;
    rdfs:label 'Rating Error Code' ;
    rdfs:comment 'Error code if rating failed or encountered issues. Null for successfully rated records. Used for troubleshooting and reprocessing.' ;
    rdfs:domain ind:RatedUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingErrorMessage rdf:type rdf:Property ;
    rdfs:label 'Rating Error Message' ;
    rdfs:comment 'Detailed error message describing why rating failed or what issue was encountered. Null for successfully rated records.' ;
    rdfs:domain ind:RatedUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingStatus rdf:type rdf:Property ;
    rdfs:label 'Rating Status' ;
    rdfs:comment 'Current status of the rating process for this usage event. Indicates whether rating completed successfully or requires intervention.' ;
    rdfs:domain ind:RatedUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceTypeCode rdf:type rdf:Property ;
    rdfs:label 'Service Type Code' ;
    rdfs:comment 'Type of waste management service for which usage was rated. Categorizes the billable service line.' ;
    rdfs:domain ind:RatedUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageDate rdf:type rdf:Property ;
    rdfs:label 'Usage Date' ;
    rdfs:comment 'Date when the actual usage event occurred (pickup date, disposal date, rental day). Business event date for revenue recognition and reporting.' ;
    rdfs:domain ind:RatedUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:usageQuantity rdf:type rdf:Property ;
    rdfs:label 'Usage Quantity' ;
    rdfs:comment 'Measured quantity of usage that was rated. Value depends on usage type: number of pickups, tons of waste, days of container rental, etc.' ;
    rdfs:domain ind:RatedUsage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supersededByRuleTaxRuleId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Rule Tax Rule Id' ;
    rdfs:comment 'Identifier of the tax rule that replaces this rule when it expires or is updated, maintaining audit trail of rule changes.' ;
    rdfs:domain ind:TaxRule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TaxRule .

ind:applicableServiceTypes rdf:type rdf:Property ;
    rdfs:label 'Applicable Service Types' ;
    rdfs:comment 'Comma-separated list of waste management service types to which this tax rule applies (e.g., residential collection, commercial hauling, landfill disposal, recycling, hazardous waste). [ENUM-REF-CANDIDATE: residential_collection|commercial_collection|landfill_disposal|recycling|hazardous_waste|transfer_station|waste_to_energy|rolloff_service — promote to reference product]' ;
    rdfs:domain ind:TaxRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compoundingSequence rdf:type rdf:Property ;
    rdfs:label 'Compounding Sequence' ;
    rdfs:comment 'Order in which this tax is applied when multiple taxes compound on each other. Lower numbers are applied first.' ;
    rdfs:domain ind:TaxRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:customerTypeApplicability rdf:type rdf:Property ;
    rdfs:label 'Customer Type Applicability' ;
    rdfs:comment 'Customer segments to which this tax rule applies (all, residential, commercial, industrial, municipal, government).' ;
    rdfs:domain ind:TaxRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exemptionCategories rdf:type rdf:Property ;
    rdfs:label 'Exemption Categories' ;
    rdfs:comment 'Comma-separated list of exemption categories that exclude customers or transactions from this tax (e.g., nonprofit, government, recycling-only, tax-exempt certificate holders).' ;
    rdfs:domain ind:TaxRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exemptionCertificateRequired rdf:type rdf:Property ;
    rdfs:label 'Exemption Certificate Required' ;
    rdfs:comment 'Indicates whether a valid tax exemption certificate must be on file to apply the exemption (True/False).' ;
    rdfs:domain ind:TaxRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:flatFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Flat Fee Amount' ;
    rdfs:comment 'Fixed dollar amount charged per transaction or unit when tax is assessed as a flat fee rather than a percentage rate.' ;
    rdfs:domain ind:TaxRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:jurisdictionState rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction State' ;
    rdfs:comment 'Two-letter state code where the tax rule applies (ISO 3166-2:US format).' ;
    rdfs:domain ind:TaxRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Tax Amount' ;
    rdfs:comment 'Maximum tax amount cap per transaction or billing period, limiting tax liability for high-value transactions.' ;
    rdfs:domain ind:TaxRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Tax Amount' ;
    rdfs:comment 'Minimum tax amount to be charged regardless of calculated tax, ensuring a floor for tax collection.' ;
    rdfs:domain ind:TaxRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remittanceDueDay rdf:type rdf:Property ;
    rdfs:label 'Remittance Due Day' ;
    rdfs:comment 'Day of the month (1-31) or days after period end when tax remittance payment is due to the authority.' ;
    rdfs:domain ind:TaxRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:remittanceFrequency rdf:type rdf:Property ;
    rdfs:label 'Remittance Frequency' ;
    rdfs:comment 'Frequency at which collected taxes must be remitted to the tax authority: monthly, quarterly, annually, or on-demand.' ;
    rdfs:domain ind:TaxRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingCode rdf:type rdf:Property ;
    rdfs:label 'Reporting Code' ;
    rdfs:comment 'Code used for regulatory tax reporting and filing with state or local authorities (e.g., sales tax jurisdiction code, waste tax category code).' ;
    rdfs:domain ind:TaxRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleCode rdf:type rdf:Property ;
    rdfs:label 'Rule Code' ;
    rdfs:comment 'Business identifier code for the tax rule, used for external reference and system integration.' ;
    rdfs:domain ind:TaxRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleDescription rdf:type rdf:Property ;
    rdfs:label 'Rule Description' ;
    rdfs:comment 'Detailed description of the tax rule including applicability conditions, exemptions, and business context.' ;
    rdfs:domain ind:TaxRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleName rdf:type rdf:Property ;
    rdfs:label 'Rule Name' ;
    rdfs:comment 'Descriptive name of the tax rule for business user identification and reporting purposes.' ;
    rdfs:domain ind:TaxRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleStatus rdf:type rdf:Property ;
    rdfs:label 'Rule Status' ;
    rdfs:comment 'Current lifecycle status of the tax rule: draft, pending approval, active, suspended, expired, or superseded.' ;
    rdfs:domain ind:TaxRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxAuthorityCode rdf:type rdf:Property ;
    rdfs:label 'Tax Authority Code' ;
    rdfs:comment 'Standardized code identifying the tax authority (e.g., state FIPS code, county code, municipality tax ID).' ;
    rdfs:domain ind:TaxRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Tax Authority Name' ;
    rdfs:comment 'Name of the governmental entity or tax authority imposing the tax (e.g., State of California, Cook County, City of Houston).' ;
    rdfs:domain ind:TaxRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxAuthorityType rdf:type rdf:Property ;
    rdfs:label 'Tax Authority Type' ;
    rdfs:comment 'Level of government or jurisdiction imposing the tax (state, county, municipality, special district, federal, tribal).' ;
    rdfs:domain ind:TaxRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxBase rdf:type rdf:Property ;
    rdfs:label 'Tax Base' ;
    rdfs:comment 'The base amount or unit upon which the tax is calculated: gross invoice amount, net amount after discounts, tonnage disposed, number of pickups, container count, or service days.' ;
    rdfs:domain ind:TaxRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxRate rdf:type rdf:Property ;
    rdfs:label 'Tax Rate' ;
    rdfs:comment 'Tax rate expressed as a decimal (e.g., 0.0825 for 8.25% tax rate). Supports up to six decimal places for precision.' ;
    rdfs:domain ind:TaxRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Tax Rate Percentage' ;
    rdfs:comment 'Tax rate expressed as a percentage (e.g., 8.25 for 8.25% tax). Used for display and reporting purposes.' ;
    rdfs:domain ind:TaxRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxType rdf:type rdf:Property ;
    rdfs:label 'Tax Type' ;
    rdfs:comment 'Category of tax being applied: sales tax, excise tax, solid waste tax, environmental surcharge, tipping fee tax, or franchise fee.' ;
    rdfs:domain ind:TaxRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingContactId rdf:type rdf:Property ;
    rdfs:label 'Billing Contact Id' ;
    rdfs:comment 'Foreign key linking to customer.contact. Business justification: The billing account must reference the designated billing contact for invoice delivery, payment reminders, and dunning communications. billing_contact_name, billing_contact_email, billing_contact_phon' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contact .

ind:autopayEnrolledFlag rdf:type rdf:Property ;
    rdfs:label 'Autopay Enrolled Flag' ;
    rdfs:comment 'Indicates whether the account is enrolled in automatic payment processing on invoice due date.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:autopayEnrollmentDate rdf:type rdf:Property ;
    rdfs:label 'Autopay Enrollment Date' ;
    rdfs:comment 'Date when the customer enrolled in automatic payment processing.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:businessUnitCode rdf:type rdf:Property ;
    rdfs:label 'Business Unit Code' ;
    rdfs:comment 'Business unit or division code for organizational hierarchy and reporting segmentation.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closeDate rdf:type rdf:Property ;
    rdfs:label 'Close Date' ;
    rdfs:comment 'Date when the billing account was closed and billing operations ceased.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:closeReasonCode rdf:type rdf:Property ;
    rdfs:label 'Close Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for account closure (e.g., customer request, non-payment, service termination).' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditRating rdf:type rdf:Property ;
    rdfs:label 'Credit Rating' ;
    rdfs:comment 'Internal or external credit assessment classification used for credit limit determination and collections risk management.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastDunningDate rdf:type rdf:Property ;
    rdfs:label 'Last Dunning Date' ;
    rdfs:comment 'Most recent date when a dunning notice or collection communication was sent to the customer.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:oracleAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Oracle Account Number' ;
    rdfs:comment 'External account identifier in Oracle Revenue Management system used for billing and invoicing integration.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paperlessEnrollmentDate rdf:type rdf:Property ;
    rdfs:label 'Paperless Enrollment Date' ;
    rdfs:comment 'Date when the customer enrolled in paperless billing.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:profitCenterCode rdf:type rdf:Property ;
    rdfs:label 'Profit Center Code' ;
    rdfs:comment 'Profit center code for segment reporting and business unit performance tracking.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExemptionCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Exemption Certificate Number' ;
    rdfs:comment 'Government-issued certificate number validating the tax-exempt status of the account.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExemptionExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Tax Exemption Expiration Date' ;
    rdfs:comment 'Date when the tax exemption certificate expires and requires renewal.' ;
    rdfs:domain ind:BillingAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:parentAgreementContractId rdf:type rdf:Property ;
    rdfs:label 'Parent Agreement Contract Id' ;
    rdfs:comment 'Identifier of the master or umbrella agreement under which this contract is subordinated. Used for multi-site or multi-service contract hierarchies. Nullable for standalone contracts.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Contract .

ind:amendmentCount rdf:type rdf:Property ;
    rdfs:label 'Amendment Count' ;
    rdfs:comment 'Number of formal amendments executed against this contract since origination. Used to track contract change history and version control.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:annualEscalationPercentage rdf:type rdf:Property ;
    rdfs:label 'Annual Escalation Percentage' ;
    rdfs:comment 'Fixed percentage rate increase applied annually to the base service rate. Expressed as a percentage (e.g., 3.00 for 3% annual increase). Nullable if escalation is CPI-based or not applicable.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseServiceRate rdf:type rdf:Property ;
    rdfs:label 'Base Service Rate' ;
    rdfs:comment 'Primary recurring charge amount for the contracted service. Currency is USD unless otherwise specified in contract terms. Excludes variable charges, surcharges, and taxes.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:earlyTerminationPenalty rdf:type rdf:Property ;
    rdfs:label 'Early Termination Penalty' ;
    rdfs:comment 'Financial penalty amount charged if the customer terminates the contract before the expiration date. May be a fixed amount or calculated as a percentage of remaining contract value.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalComplianceRequirement rdf:type rdf:Property ;
    rdfs:label 'Environmental Compliance Requirement' ;
    rdfs:comment 'Description of environmental regulations and compliance obligations specified in the contract. May reference Resource Conservation and Recovery Act (RCRA), Clean Air Act (CAA), or state-specific environmental requirements.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Governing Jurisdiction' ;
    rdfs:comment 'Legal jurisdiction whose laws govern the contract interpretation and dispute resolution. Typically a state or province code (e.g., TX, CA, ON) or country code for international contracts.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indemnificationClause rdf:type rdf:Property ;
    rdfs:label 'Indemnification Clause' ;
    rdfs:comment 'Description of the indemnification obligations where one party agrees to protect the other from specified liabilities, claims, or damages arising from contract performance.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceRequirement rdf:type rdf:Property ;
    rdfs:label 'Insurance Requirement' ;
    rdfs:comment 'Description of the insurance coverage types and minimum limits required under the contract. Typically includes general liability, auto liability, workers compensation, and environmental impairment liability.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAmendmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Amendment Date' ;
    rdfs:comment 'Date of the most recent contract amendment execution. Nullable if no amendments have been executed.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:latePaymentPenaltyRate rdf:type rdf:Property ;
    rdfs:label 'Late Payment Penalty Rate' ;
    rdfs:comment 'Percentage rate charged on overdue balances per month or per annum as specified in contract terms. Expressed as a percentage (e.g., 1.50 for 1.5% monthly).' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumTonnageLimit rdf:type rdf:Property ;
    rdfs:label 'Maximum Tonnage Limit' ;
    rdfs:comment 'Maximum volume of waste in tons that the facility or service provider will accept under the contract. Common in landfill disposal agreements. Nullable for unlimited contracts.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumTonnageCommitment rdf:type rdf:Property ;
    rdfs:label 'Minimum Tonnage Commitment' ;
    rdfs:comment 'Minimum volume of waste in tons that the customer commits to deliver under the contract term. Common in disposal and hauling agreements. Nullable for contracts without volume commitments.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ownerName rdf:type rdf:Property ;
    rdfs:label 'Owner Name' ;
    rdfs:comment 'Name of the Waste Management employee responsible for managing this contract relationship. Typically a sales representative, account manager, or municipal services manager.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceBondAmount rdf:type rdf:Property ;
    rdfs:label 'Performance Bond Amount' ;
    rdfs:comment 'Dollar amount of the performance bond required under the contract. Nullable if no bond is required.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceBondRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Performance Bond Required Flag' ;
    rdfs:comment 'Indicates whether the contract requires the service provider to post a performance bond to guarantee service delivery. Common in municipal and franchise agreements.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rateEscalationClause rdf:type rdf:Property ;
    rdfs:label 'Rate Escalation Clause' ;
    rdfs:comment 'Description of the pricing adjustment mechanism over the contract term. May reference Consumer Price Index (CPI), fixed percentage increases, or fuel surcharge formulas.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesforceOpportunityCode rdf:type rdf:Property ;
    rdfs:label 'Salesforce Opportunity Code' ;
    rdfs:comment 'Salesforce CRM opportunity identifier that originated this contract. Links contract to the sales pipeline and opportunity record for revenue attribution and sales performance tracking.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapContractNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Contract Number' ;
    rdfs:comment 'SAP S/4HANA Sales and Distribution (SD) module contract document number. Used for integration with SAP billing, order management, and financial accounting.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceLevelAgreement rdf:type rdf:Property ;
    rdfs:label 'Service Level Agreement' ;
    rdfs:comment 'Description of the performance obligations and service commitments defined in the contract. May include pickup frequency, response times, container delivery standards, and quality metrics.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signedDate rdf:type rdf:Property ;
    rdfs:label 'Signed Date' ;
    rdfs:comment 'Date when all parties executed the contract. Used for legal enforceability and contract lifecycle tracking. May differ from effective date.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:terminationClause rdf:type rdf:Property ;
    rdfs:label 'Termination Clause' ;
    rdfs:comment 'Description of the conditions and procedures under which either party may terminate the contract prior to expiration. Includes notice requirements, cause provisions, and early termination penalties.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Termination Notice Days' ;
    rdfs:comment 'Number of days advance notice required for contract termination. Typically 30, 60, or 90 days depending on contract type and jurisdiction.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:valueTotal rdf:type rdf:Property ;
    rdfs:label 'Value Total' ;
    rdfs:comment 'Total estimated revenue value of the contract over its full term. Calculated from base rates, estimated volumes, and contract duration. Used for revenue forecasting and sales performance metrics.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allowsEarlyTermination rdf:type rdf:Property ;
    rdfs:label 'Allows Early Termination' ;
    rdfs:comment 'Indicates whether agreements of this type permit early termination by either party, typically subject to notice periods and potential penalties.' ;
    rdfs:domain ind:AgreementType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:amendmentApprovalLevel rdf:type rdf:Property ;
    rdfs:label 'Amendment Approval Level' ;
    rdfs:comment 'Organizational approval authority level required to amend or modify agreements of this type. Drives contract workflow routing in Salesforce CRM.' ;
    rdfs:domain ind:AgreementType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoRenewalEligible rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Eligible' ;
    rdfs:comment 'Indicates whether agreements of this type are eligible for automatic renewal upon expiration, subject to notice periods and customer consent.' ;
    rdfs:domain ind:AgreementType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceFramework rdf:type rdf:Property ;
    rdfs:label 'Compliance Framework' ;
    rdfs:comment 'Primary regulatory compliance framework governing agreements of this type (e.g., RCRA for hazardous waste, local franchise ordinances for MSW, CERCLA for remediation contracts).' ;
    rdfs:domain ind:AgreementType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractDurationType rdf:type rdf:Property ;
    rdfs:label 'Contract Duration Type' ;
    rdfs:comment 'Typical duration classification for agreements of this type. Short-term (under 1 year), long-term (multi-year), evergreen (auto-renewing), project-based (tied to specific project completion), or indefinite (no fixed end date).' ;
    rdfs:domain ind:AgreementType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultBillingFrequency rdf:type rdf:Property ;
    rdfs:label 'Default Billing Frequency' ;
    rdfs:comment 'Standard billing cycle frequency for agreements of this type. Drives invoice generation scheduling in Oracle Revenue Management.' ;
    rdfs:domain ind:AgreementType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defaultTermMonths rdf:type rdf:Property ;
    rdfs:label 'Default Term Months' ;
    rdfs:comment 'Standard initial contract term length in months for agreements of this type. Null if term is project-based or indefinite.' ;
    rdfs:domain ind:AgreementType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hazmatClassificationRequired rdf:type rdf:Property ;
    rdfs:label 'Hazmat Classification Required' ;
    rdfs:comment 'Indicates whether agreements of this type require hazardous material classification and manifest tracking per Resource Conservation and Recovery Act (RCRA) and Department of Transportation (DOT) regulations.' ;
    rdfs:domain ind:AgreementType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresFranchiseApproval rdf:type rdf:Property ;
    rdfs:label 'Requires Franchise Approval' ;
    rdfs:comment 'Indicates whether agreements of this type require municipal or local government franchise approval before execution. Critical for Municipal Solid Waste (MSW) franchise agreements.' ;
    rdfs:domain ind:AgreementType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresInsuranceCertificate rdf:type rdf:Property ;
    rdfs:label 'Requires Insurance Certificate' ;
    rdfs:comment 'Indicates whether agreements of this type require the service provider to maintain and provide proof of general liability, environmental liability, and workers compensation insurance.' ;
    rdfs:domain ind:AgreementType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresPerformanceBond rdf:type rdf:Property ;
    rdfs:label 'Requires Performance Bond' ;
    rdfs:comment 'Indicates whether agreements of this type require the service provider to post a performance bond or financial guarantee to ensure contract obligations are met. Common for municipal franchise agreements.' ;
    rdfs:domain ind:AgreementType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresPermit rdf:type rdf:Property ;
    rdfs:label 'Requires Permit' ;
    rdfs:comment 'Indicates whether this agreement type requires an active operating permit (e.g., Resource Conservation and Recovery Act (RCRA) permit for hazardous waste, landfill operating permit, Treatment Storage and Disposal Facility (TSDF) permit).' ;
    rdfs:domain ind:AgreementType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaTemplateRequired rdf:type rdf:Property ;
    rdfs:label 'Sla Template Required' ;
    rdfs:comment 'Indicates whether agreements of this type must include a formal Service Level Agreement (SLA) defining performance obligations, response times, and service quality metrics.' ;
    rdfs:domain ind:AgreementType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supportsRateEscalation rdf:type rdf:Property ;
    rdfs:label 'Supports Rate Escalation' ;
    rdfs:comment 'Indicates whether agreements of this type typically include automatic rate escalation clauses tied to Consumer Price Index (CPI), fuel surcharges, or other economic indices.' ;
    rdfs:domain ind:AgreementType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:activatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Activated Timestamp' ;
    rdfs:comment 'Timestamp when the service commitment transitioned to active status and service delivery commenced.' ;
    rdfs:domain ind:ServiceCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cancellationNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Cancellation Notice Days' ;
    rdfs:comment 'Number of days advance notice required for customer to cancel this service commitment.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:commitmentNumber rdf:type rdf:Property ;
    rdfs:label 'Commitment Number' ;
    rdfs:comment 'Business-readable unique identifier for the service commitment, often used in customer communications and operational systems.' ;
    rdfs:domain ind:ServiceCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commitmentStatus rdf:type rdf:Property ;
    rdfs:label 'Commitment Status' ;
    rdfs:comment 'Current lifecycle status of the service commitment.' ;
    rdfs:domain ind:ServiceCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monthlyServiceCharge rdf:type rdf:Property ;
    rdfs:label 'Monthly Service Charge' ;
    rdfs:comment 'Base monthly recurring charge for this service commitment, excluding usage-based fees.' ;
    rdfs:domain ind:ServiceCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overageChargeRate rdf:type rdf:Property ;
    rdfs:label 'Overage Charge Rate' ;
    rdfs:comment 'Rate charged for service usage exceeding the committed volume or frequency.' ;
    rdfs:domain ind:ServiceCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:perPickupCharge rdf:type rdf:Property ;
    rdfs:label 'Per Pickup Charge' ;
    rdfs:comment 'Additional charge applied per individual pickup event, if applicable.' ;
    rdfs:domain ind:ServiceCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Service Address Line1' ;
    rdfs:comment 'Primary street address line where the service is delivered.' ;
    rdfs:domain ind:ServiceCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Service Address Line2' ;
    rdfs:comment 'Secondary address line (suite, unit, building) where the service is delivered.' ;
    rdfs:domain ind:ServiceCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceCity rdf:type rdf:Property ;
    rdfs:label 'Service City' ;
    rdfs:comment 'City where the service is delivered.' ;
    rdfs:domain ind:ServiceCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceCountryCode rdf:type rdf:Property ;
    rdfs:label 'Service Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code where the service is delivered.' ;
    rdfs:domain ind:ServiceCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceLatitude rdf:type rdf:Property ;
    rdfs:label 'Service Latitude' ;
    rdfs:comment 'Geographic latitude coordinate of the service delivery location for route optimization and GPS tracking.' ;
    rdfs:domain ind:ServiceCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceLongitude rdf:type rdf:Property ;
    rdfs:label 'Service Longitude' ;
    rdfs:comment 'Geographic longitude coordinate of the service delivery location for route optimization and GPS tracking.' ;
    rdfs:domain ind:ServiceCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:servicePostalCode rdf:type rdf:Property ;
    rdfs:label 'Service Postal Code' ;
    rdfs:comment 'Postal or ZIP code where the service is delivered.' ;
    rdfs:domain ind:ServiceCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceStartTime rdf:type rdf:Property ;
    rdfs:label 'Service Start Time' ;
    rdfs:comment 'Preferred or contracted start time window for service delivery (e.g., 06:00-08:00).' ;
    rdfs:domain ind:ServiceCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:serviceStateProvince rdf:type rdf:Property ;
    rdfs:label 'Service State Province' ;
    rdfs:comment 'State or province where the service is delivered.' ;
    rdfs:domain ind:ServiceCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Terminated Timestamp' ;
    rdfs:comment 'Timestamp when the service commitment was terminated or cancelled.' ;
    rdfs:domain ind:ServiceCommitment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:environmentalFeeApplicable rdf:type rdf:Property ;
    rdfs:label 'Environmental Fee Applicable' ;
    rdfs:comment 'Indicates whether environmental recovery fees are applied to recover costs of environmental compliance, recycling programs, or sustainability initiatives.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:escalationFrequency rdf:type rdf:Property ;
    rdfs:label 'Escalation Frequency' ;
    rdfs:comment 'How often the rate escalation is applied (e.g., annually on contract anniversary, quarterly based on fuel index).' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationRate rdf:type rdf:Property ;
    rdfs:label 'Escalation Rate' ;
    rdfs:comment 'The percentage rate at which pricing increases during escalation events. Used for fixed-percentage escalation types.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:escalationType rdf:type rdf:Property ;
    rdfs:label 'Escalation Type' ;
    rdfs:comment 'Method by which the pricing rate increases over time. Supports automatic rate adjustments per contract terms (e.g., annual CPI adjustment, fixed 3% increase).' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelSurchargeApplicable rdf:type rdf:Property ;
    rdfs:label 'Fuel Surcharge Applicable' ;
    rdfs:comment 'Indicates whether a variable fuel surcharge is applied to this pricing component based on diesel fuel price indices.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextEscalationDate rdf:type rdf:Property ;
    rdfs:label 'Next Escalation Date' ;
    rdfs:comment 'The scheduled date for the next automatic rate increase. Used for proactive rate change notifications and billing system updates.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pricingCode rdf:type rdf:Property ;
    rdfs:label 'Pricing Code' ;
    rdfs:comment 'Business identifier for the pricing structure, used for external reference and reporting.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingStatus rdf:type rdf:Property ;
    rdfs:label 'Pricing Status' ;
    rdfs:comment 'Current lifecycle state of this pricing record. Controls whether the pricing is used in billing calculations.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingType rdf:type rdf:Property ;
    rdfs:label 'Pricing Type' ;
    rdfs:comment 'Category of pricing component. Defines the nature of the charge applied to the contract. [ENUM-REF-CANDIDATE: base_service_rate|tipping_fee|container_rental|fuel_surcharge|environmental_recovery_fee|regulatory_cost_recovery|disposal_fee|hauling_fee|processing_fee|administrative_fee — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prorationAllowed rdf:type rdf:Property ;
    rdfs:label 'Proration Allowed' ;
    rdfs:comment 'Indicates whether partial-period charges are calculated when service starts or ends mid-cycle. Supports accurate billing for contract changes.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryFeeApplicable rdf:type rdf:Property ;
    rdfs:label 'Regulatory Fee Applicable' ;
    rdfs:comment 'Indicates whether regulatory cost recovery charges are applied to recover costs of permits, compliance monitoring, or mandated reporting.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceRecordCode rdf:type rdf:Property ;
    rdfs:label 'Source Record Code' ;
    rdfs:comment 'The unique identifier of this pricing record in the source system. Enables traceability and cross-system reconciliation.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierLevel rdf:type rdf:Property ;
    rdfs:label 'Tier Level' ;
    rdfs:comment 'Sequence number for tiered pricing structures. Used when pricing varies by volume thresholds (e.g., tier 1 for 0-10 tons, tier 2 for 10-50 tons). Null for non-tiered pricing.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tierMaximumQuantity rdf:type rdf:Property ;
    rdfs:label 'Tier Maximum Quantity' ;
    rdfs:comment 'The maximum quantity threshold for this pricing tier. Nullable for the highest tier with no upper limit.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tierMinimumQuantity rdf:type rdf:Property ;
    rdfs:label 'Tier Minimum Quantity' ;
    rdfs:comment 'The minimum quantity threshold for this pricing tier. Used in volume-based pricing models to define tier breakpoints.' ;
    rdfs:domain ind:Pricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateLineId rdf:type rdf:Property ;
    rdfs:label 'Rate Line Id' ;
    rdfs:comment 'Unique identifier for the rate line item within the rate schedule. Primary key.' ;
    rdfs:domain ind:RateLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:arrearsAdvanceIndicator rdf:type rdf:Property ;
    rdfs:label 'Arrears Advance Indicator' ;
    rdfs:comment 'Indicates whether this rate line is billed in arrears (after service delivery) or in advance (before service delivery). Affects revenue recognition timing.' ;
    rdfs:domain ind:RateLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargeDescription rdf:type rdf:Property ;
    rdfs:label 'Charge Description' ;
    rdfs:comment 'Detailed business description of the charge component. Provides clarity on what this rate line represents for billing transparency and customer communication.' ;
    rdfs:domain ind:RateLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargeType rdf:type rdf:Property ;
    rdfs:label 'Charge Type' ;
    rdfs:comment 'Category of charge represented by this rate line. Defines the nature of the pricing component (e.g., base collection rate, tipping fee, fuel surcharge, environmental fee, container rental, overage charge, special handling fee).' ;
    rdfs:domain ind:RateLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isMandatory rdf:type rdf:Property ;
    rdfs:label 'Is Mandatory' ;
    rdfs:comment 'Boolean flag indicating whether this rate line is a mandatory charge that cannot be waived or removed from the contract. True means mandatory, false means optional.' ;
    rdfs:domain ind:RateLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Line Sequence Number' ;
    rdfs:comment 'Sequential ordering of this rate line within the parent rate schedule. Used for display and processing order.' ;
    rdfs:domain ind:RateLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:prorationRule rdf:type rdf:Property ;
    rdfs:label 'Proration Rule' ;
    rdfs:comment 'Rule for prorating charges when service starts or ends mid-period. Options include daily proration, monthly proration, no proration, or custom calculation method.' ;
    rdfs:domain ind:RateLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateLineStatus rdf:type rdf:Property ;
    rdfs:label 'Rate Line Status' ;
    rdfs:comment 'Current lifecycle status of this rate line. Active means currently in use for billing, inactive means not applied, pending means scheduled for future activation, superseded means replaced by a newer rate line.' ;
    rdfs:domain ind:RateLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierThresholdLower rdf:type rdf:Property ;
    rdfs:label 'Tier Threshold Lower' ;
    rdfs:comment 'Lower bound threshold for tiered pricing. Defines the minimum quantity or usage level at which this rate line applies. Used in conjunction with tiered rate structures.' ;
    rdfs:domain ind:RateLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tierThresholdUpper rdf:type rdf:Property ;
    rdfs:label 'Tier Threshold Upper' ;
    rdfs:comment 'Upper bound threshold for tiered pricing. Defines the maximum quantity or usage level at which this rate line applies. Null indicates no upper limit for the tier.' ;
    rdfs:domain ind:RateLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitPrice rdf:type rdf:Property ;
    rdfs:label 'Unit Price' ;
    rdfs:comment 'Price per unit of measure for this rate line. The base rate applied to calculate the charge amount based on quantity consumed or service frequency.' ;
    rdfs:domain ind:RateLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amendmentReference rdf:type rdf:Property ;
    rdfs:label 'Amendment Reference' ;
    rdfs:comment 'Reference number or identifier of the contract amendment that introduced or modified this escalation clause. Null for clauses in original contract.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appliesToServiceTypes rdf:type rdf:Property ;
    rdfs:label 'Applies To Service Types' ;
    rdfs:comment 'Comma-separated list of service types to which this escalation clause applies (e.g., residential_collection, commercial_hauling, disposal_fees, recycling_processing). Allows selective application of escalation to specific contract line items.' ;
    rdfs:domain ind:EscalationClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseIndexDate rdf:type rdf:Property ;
    rdfs:label 'Base Index Date' ;
    rdfs:comment 'The date on which the base index value was established, typically the contract effective date or last escalation reset date.' ;
    rdfs:domain ind:EscalationClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:baseIndexValue rdf:type rdf:Property ;
    rdfs:label 'Base Index Value' ;
    rdfs:comment 'The baseline index value established at contract origination or last reset, against which future index values are compared to calculate escalation percentage.' ;
    rdfs:domain ind:EscalationClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calculationMethodology rdf:type rdf:Property ;
    rdfs:label 'Calculation Methodology' ;
    rdfs:comment 'Detailed description of how the escalation percentage is calculated, including formulas, rounding rules, and any special provisions (e.g., \'Calculate percentage change from base index to current index, round to two decimal places, apply cap if exceeded\').' ;
    rdfs:domain ind:EscalationClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clauseNumber rdf:type rdf:Property ;
    rdfs:label 'Clause Number' ;
    rdfs:comment 'Business identifier for the escalation clause within the contract (e.g., Section 4.2, Clause E-1).' ;
    rdfs:domain ind:EscalationClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compoundingMethod rdf:type rdf:Property ;
    rdfs:label 'Compounding Method' ;
    rdfs:comment 'How escalations are calculated over multiple periods. Simple = each escalation applies to original base rate; compound = each escalation applies to previously escalated rate; reset_to_base = rate resets to base and new escalation calculated from current index.' ;
    rdfs:domain ind:EscalationClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerApprovalRequired rdf:type rdf:Property ;
    rdfs:label 'Customer Approval Required' ;
    rdfs:comment 'Indicates whether customer approval or acceptance is required before escalated rates take effect. True for some municipal contracts with board approval requirements; false for automatic escalations.' ;
    rdfs:domain ind:EscalationClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disputePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Dispute Period Days' ;
    rdfs:comment 'Number of days after notification during which customer may dispute the escalation calculation or request review. Null if no dispute period is contractually defined.' ;
    rdfs:domain ind:EscalationClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:escalationCapPercentage rdf:type rdf:Property ;
    rdfs:label 'Escalation Cap Percentage' ;
    rdfs:comment 'Maximum allowable rate increase percentage in any single escalation period, protecting customers from excessive increases during high inflation periods (e.g., 5.00 represents 5% cap).' ;
    rdfs:domain ind:EscalationClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:escalationClauseStatus rdf:type rdf:Property ;
    rdfs:label 'Escalation Clause Status' ;
    rdfs:comment 'Current lifecycle status of the escalation clause. Active = currently in effect; suspended = temporarily not applied; expired = past expiration date; superseded = replaced by amendment; pending_approval = awaiting customer or internal approval.' ;
    rdfs:domain ind:EscalationClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationFloorPercentage rdf:type rdf:Property ;
    rdfs:label 'Escalation Floor Percentage' ;
    rdfs:comment 'Minimum rate increase percentage guaranteed in any escalation period, ensuring revenue growth even during deflationary periods (e.g., 1.00 represents 1% floor). Null if no floor applies.' ;
    rdfs:domain ind:EscalationClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fixedEscalationPercentage rdf:type rdf:Property ;
    rdfs:label 'Fixed Escalation Percentage' ;
    rdfs:comment 'The predetermined annual percentage increase applied to rates for fixed percentage escalation clauses (e.g., 3.00 represents 3% annual increase). Null for index-based escalations.' ;
    rdfs:domain ind:EscalationClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:indexReference rdf:type rdf:Property ;
    rdfs:label 'Index Reference' ;
    rdfs:comment 'Specific economic index or benchmark used for escalation calculation (e.g., CPI-U All Urban Consumers, PPI Waste Management Services, DOE Diesel Fuel Index, Regional CPI). Null for fixed percentage escalations.' ;
    rdfs:domain ind:EscalationClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastEscalationDate rdf:type rdf:Property ;
    rdfs:label 'Last Escalation Date' ;
    rdfs:comment 'The date when the most recent rate escalation was applied under this clause. Null if no escalation has occurred yet.' ;
    rdfs:domain ind:EscalationClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastEscalationPercentage rdf:type rdf:Property ;
    rdfs:label 'Last Escalation Percentage' ;
    rdfs:comment 'The actual percentage increase applied during the most recent escalation event (e.g., 2.75 represents 2.75% increase). Used for historical tracking and forecasting.' ;
    rdfs:domain ind:EscalationClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:notificationDaysAdvance rdf:type rdf:Property ;
    rdfs:label 'Notification Days Advance' ;
    rdfs:comment 'Number of days prior to rate change effective date that customer must be notified, as stipulated in contract terms (e.g., 30, 60, 90 days). Required for compliance with municipal contract notification requirements.' ;
    rdfs:domain ind:EscalationClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reviewFrequency rdf:type rdf:Property ;
    rdfs:label 'Review Frequency' ;
    rdfs:comment 'How often the escalation clause is reviewed and rates are adjusted (annual = once per year, semi-annual = twice per year, quarterly = four times per year, biennial = every two years, monthly = every month).' ;
    rdfs:domain ind:EscalationClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportingDocumentationRequired rdf:type rdf:Property ;
    rdfs:label 'Supporting Documentation Required' ;
    rdfs:comment 'Indicates whether supporting documentation (index reports, cost data, calculations) must be provided to customer with escalation notification. True for municipal contracts requiring transparency; false for standard commercial agreements.' ;
    rdfs:domain ind:EscalationClause ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:baselinePeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Baseline Period End Date' ;
    rdfs:comment 'The end date of the period used to establish the baseline performance value.' ;
    rdfs:domain ind:SlaTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:baselinePeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Baseline Period Start Date' ;
    rdfs:comment 'The start date of the period used to establish the baseline performance value.' ;
    rdfs:domain ind:SlaTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:baselineValue rdf:type rdf:Property ;
    rdfs:label 'Baseline Value' ;
    rdfs:comment 'The historical or initial performance level used as a reference point for measuring improvement or setting targets.' ;
    rdfs:domain ind:SlaTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:escalationProcedure rdf:type rdf:Property ;
    rdfs:label 'Escalation Procedure' ;
    rdfs:comment 'Description of the escalation process when performance falls below the escalation threshold (e.g., notify regional manager, schedule customer meeting, initiate corrective action plan).' ;
    rdfs:domain ind:SlaTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationThresholdValue rdf:type rdf:Property ;
    rdfs:label 'Escalation Threshold Value' ;
    rdfs:comment 'The performance level that triggers escalation procedures or management notification (typically worse than the target threshold).' ;
    rdfs:domain ind:SlaTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exclusionConditions rdf:type rdf:Property ;
    rdfs:label 'Exclusion Conditions' ;
    rdfs:comment 'Circumstances under which the SLA obligation does not apply (e.g., force majeure events, customer-caused delays, extreme weather, equipment failure beyond control, regulatory shutdowns).' ;
    rdfs:domain ind:SlaTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementFrequency rdf:type rdf:Property ;
    rdfs:label 'Measurement Frequency' ;
    rdfs:comment 'How often the SLA metric is measured and evaluated (daily, weekly, monthly, quarterly, annually, per incident, continuous). [ENUM-REF-CANDIDATE: daily|weekly|monthly|quarterly|annually|per_incident|continuous — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SlaTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementMethodology rdf:type rdf:Property ;
    rdfs:label 'Measurement Methodology' ;
    rdfs:comment 'Detailed description of how the SLA metric is calculated, including data sources, calculation formulas, and any adjustments or exclusions applied.' ;
    rdfs:domain ind:SlaTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Measurement Period Days' ;
    rdfs:comment 'The rolling or fixed period in days over which the SLA metric is calculated (e.g., 30 for monthly rolling average, 90 for quarterly).' ;
    rdfs:domain ind:SlaTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:penaltyCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Penalty Calculation Method' ;
    rdfs:comment 'Description of how the penalty is calculated (e.g., flat fee per incident, percentage of monthly service fee, tiered based on severity, prorated by days of non-compliance).' ;
    rdfs:domain ind:SlaTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Penalty Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the penalty amount (e.g., USD, CAD, MXN).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyProvisionFlag rdf:type rdf:Property ;
    rdfs:label 'Penalty Provision Flag' ;
    rdfs:comment 'Indicates whether financial penalties or service credits apply for non-compliance with this SLA term (True if penalties exist, False otherwise).' ;
    rdfs:domain ind:SlaTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:penaltyType rdf:type rdf:Property ;
    rdfs:label 'Penalty Type' ;
    rdfs:comment 'The type of penalty or remedy applied when the SLA is not met (service credit, financial penalty, rate reduction, contract termination right, none).' ;
    rdfs:domain ind:SlaTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingFormat rdf:type rdf:Property ;
    rdfs:label 'Reporting Format' ;
    rdfs:comment 'The format in which SLA performance must be reported (e.g., PDF dashboard, Excel spreadsheet, online portal, email summary, API feed).' ;
    rdfs:domain ind:SlaTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Reporting Requirement Flag' ;
    rdfs:comment 'Indicates whether formal reporting of this SLA metric to the customer is required (True if reporting is mandatory, False otherwise).' ;
    rdfs:domain ind:SlaTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaCategory rdf:type rdf:Property ;
    rdfs:label 'Sla Category' ;
    rdfs:comment 'The category of SLA term grouping related performance obligations (collection performance, response time, service quality, safety compliance, environmental compliance, customer satisfaction).' ;
    rdfs:domain ind:SlaTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaMetricCode rdf:type rdf:Property ;
    rdfs:label 'Sla Metric Code' ;
    rdfs:comment 'Standardized code for the SLA metric to enable consistent tracking and reporting across contracts.' ;
    rdfs:domain ind:SlaTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaMetricName rdf:type rdf:Property ;
    rdfs:label 'Sla Metric Name' ;
    rdfs:comment 'The name of the performance metric being measured (e.g., On-Time Collection Rate, Missed Pickup Response Time, Container Delivery Lead Time, Complaint Resolution Time, Contamination Notification Time).' ;
    rdfs:domain ind:SlaTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTermStatus rdf:type rdf:Property ;
    rdfs:label 'Sla Term Status' ;
    rdfs:comment 'Current lifecycle status of the SLA term (active, suspended, expired, superseded, draft, cancelled).' ;
    rdfs:domain ind:SlaTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetThresholdValue rdf:type rdf:Property ;
    rdfs:label 'Target Threshold Value' ;
    rdfs:comment 'The numeric target value that must be met or exceeded to satisfy the SLA obligation (e.g., 98.5 for 98.5% on-time rate, 4 for 4-hour response time).' ;
    rdfs:domain ind:SlaTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:thresholdOperator rdf:type rdf:Property ;
    rdfs:label 'Threshold Operator' ;
    rdfs:comment 'The comparison operator defining how actual performance is evaluated against the target (greater than or equal, less than or equal, equal, greater than, less than).' ;
    rdfs:domain ind:SlaTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Threshold Unit Of Measure' ;
    rdfs:comment 'The unit of measurement for the target threshold (percentage, hours, days, minutes, count, tons, cubic yards). [ENUM-REF-CANDIDATE: percentage|hours|days|minutes|count|tons|cubic_yards — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SlaTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByAmendmentId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Amendment Id' ;
    rdfs:comment 'Reference to a subsequent amendment that supersedes or replaces this amendment. Null if this is the current active amendment.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Amendment .

ind:amendmentDescription rdf:type rdf:Property ;
    rdfs:label 'Amendment Description' ;
    rdfs:comment 'Detailed narrative description of the changes being made to the contract, including business rationale and scope of modifications.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentNumber rdf:type rdf:Property ;
    rdfs:label 'Amendment Number' ;
    rdfs:comment 'Business identifier for the amendment, typically sequential or hierarchical (e.g., A-001, A-002). Used for external reference and tracking.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentStatus rdf:type rdf:Property ;
    rdfs:label 'Amendment Status' ;
    rdfs:comment 'Current lifecycle status of the amendment in the approval and execution workflow. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|rejected|executed|cancelled|superseded — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentType rdf:type rdf:Property ;
    rdfs:label 'Amendment Type' ;
    rdfs:comment 'Classification of the amendment based on the nature of the change being made to the contract. [ENUM-REF-CANDIDATE: scope_change|rate_adjustment|service_addition|service_removal|term_extension|sla_revision|pricing_structure_change|volume_adjustment|equipment_change|other — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerSignatureRequired rdf:type rdf:Property ;
    rdfs:label 'Customer Signature Required' ;
    rdfs:comment 'Indicates whether customer signature is required for this amendment to be legally binding.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerSignedDate rdf:type rdf:Property ;
    rdfs:label 'Customer Signed Date' ;
    rdfs:comment 'Date when the customer signed the amendment, if customer signature was required.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:executedDate rdf:type rdf:Property ;
    rdfs:label 'Executed Date' ;
    rdfs:comment 'Date when the amendment was formally executed or signed by all parties.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:financialImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Amount' ;
    rdfs:comment 'Estimated total financial impact of the amendment over its effective period. Positive for revenue increases, negative for decreases.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:legalReviewRequired rdf:type rdf:Property ;
    rdfs:label 'Legal Review Required' ;
    rdfs:comment 'Indicates whether legal department review and approval is required for this amendment based on materiality thresholds.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalReviewedBy rdf:type rdf:Property ;
    rdfs:label 'Legal Reviewed By' ;
    rdfs:comment 'Name or identifier of the legal counsel who reviewed the amendment, if legal review was required.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalReviewedDate rdf:type rdf:Property ;
    rdfs:label 'Legal Reviewed Date' ;
    rdfs:comment 'Date when legal review was completed and the amendment was cleared by legal counsel.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rateChangeAmount rdf:type rdf:Property ;
    rdfs:label 'Rate Change Amount' ;
    rdfs:comment 'Monetary value of rate adjustment if the amendment involves pricing changes. Positive for increases, negative for decreases.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateChangePercentage rdf:type rdf:Property ;
    rdfs:label 'Rate Change Percentage' ;
    rdfs:comment 'Percentage change in rates if the amendment involves pricing adjustments. Expressed as a decimal (e.g., 5.00 for 5%).' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requestedBy rdf:type rdf:Property ;
    rdfs:label 'Requested By' ;
    rdfs:comment 'Name or identifier of the individual or department who initiated the amendment request.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeChangeDescription rdf:type rdf:Property ;
    rdfs:label 'Scope Change Description' ;
    rdfs:comment 'Detailed description of changes to the scope of services, including additions, removals, or modifications to service offerings.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceLevelChangeDescription rdf:type rdf:Property ;
    rdfs:label 'Service Level Change Description' ;
    rdfs:comment 'Detailed description of changes to service level commitments, performance obligations, or SLA metrics.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termExtensionMonths rdf:type rdf:Property ;
    rdfs:label 'Term Extension Months' ;
    rdfs:comment 'Number of months by which the contract term is extended, if applicable. Null if amendment does not affect contract duration.' ;
    rdfs:domain ind:Amendment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:renewalId rdf:type rdf:Property ;
    rdfs:label 'Renewal Id' ;
    rdfs:comment 'Unique identifier for the contract renewal event. Primary key.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:amendmentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Amendment Required Flag' ;
    rdfs:comment 'Indicates whether renewal resulted in formal contract amendment documentation due to material changes in terms, pricing, or service scope. True if amendment executed; False if renewal proceeded under existing contract framework.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:autoRenewalEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Eligible Flag' ;
    rdfs:comment 'Indicates whether the contract is eligible for automatic renewal based on original contract terms. True if auto-renewal clause exists and conditions are met; False if manual renewal process required.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:churnRiskScore rdf:type rdf:Property ;
    rdfs:label 'Churn Risk Score' ;
    rdfs:comment 'Predictive score (0.00 to 1.00) indicating likelihood of customer not renewing, calculated at renewal notice date. Higher scores indicate greater risk of churn. Derived from customer payment history, service complaints, competitive activity, and engagement metrics.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:competitorName rdf:type rdf:Property ;
    rdfs:label 'Competitor Name' ;
    rdfs:comment 'Name of competing waste management company that customer was considering during renewal, if disclosed. Used for competitive analysis and market intelligence.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitorThreatFlag rdf:type rdf:Property ;
    rdfs:label 'Competitor Threat Flag' ;
    rdfs:comment 'Indicates whether customer indicated they were considering or received offers from competing waste management providers during renewal process. True if competitive threat identified; False otherwise.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:customerResponseDate rdf:type rdf:Property ;
    rdfs:label 'Customer Response Date' ;
    rdfs:comment 'Date when the customer provided their decision on the renewal offer (accepted, declined, or requested renegotiation).' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:escalationBasis rdf:type rdf:Property ;
    rdfs:label 'Escalation Basis' ;
    rdfs:comment 'Method used to calculate rate increase at renewal. CPI: Consumer Price Index adjustment. Fixed Percentage: predetermined annual increase. Market Rate: adjustment to current market pricing. Negotiated: custom rate agreed during renewal discussion. None: no escalation applied.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noticeDate rdf:type rdf:Property ;
    rdfs:label 'Notice Date' ;
    rdfs:comment 'Date when the renewal notice was sent to the customer, typically 60-90 days before contract expiration per Service Level Agreement (SLA) terms.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:offerDate rdf:type rdf:Property ;
    rdfs:label 'Offer Date' ;
    rdfs:comment 'Date when formal renewal terms and pricing were presented to the customer. May differ from notice date if negotiation occurred.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:optOutDate rdf:type rdf:Property ;
    rdfs:label 'Opt Out Date' ;
    rdfs:comment 'Date when customer submitted formal opt-out notice for auto-renewal. Must be received within notice period specified in contract (typically 30-90 days before expiration). Null if no opt-out received.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:optOutReceivedFlag rdf:type rdf:Property ;
    rdfs:label 'Opt Out Received Flag' ;
    rdfs:comment 'Indicates whether customer provided written notice to opt out of auto-renewal within the required notice period. True if opt-out notice received; False otherwise. Relevant only for contracts with auto-renewal clauses.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:outcome rdf:type rdf:Property ;
    rdfs:label 'Outcome' ;
    rdfs:comment 'Business result of the renewal process. Retained: customer renewed at similar service level. Lost: customer declined renewal and terminated service. Expanded: customer renewed with increased service scope or value. Downsized: customer renewed with reduced service scope or value.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousAnnualValue rdf:type rdf:Property ;
    rdfs:label 'Previous Annual Value' ;
    rdfs:comment 'Total annual revenue from the contract term prior to renewal, expressed in USD. Used as baseline for rate change calculation.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:previousTermEndDate rdf:type rdf:Property ;
    rdfs:label 'Previous Term End Date' ;
    rdfs:comment 'End date of the contract term that preceded this renewal. Typically one day before renewal_effective_date.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:previousTermStartDate rdf:type rdf:Property ;
    rdfs:label 'Previous Term Start Date' ;
    rdfs:comment 'Start date of the contract term that preceded this renewal. Used for historical tracking and term comparison.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rateEscalationClauseApplied rdf:type rdf:Property ;
    rdfs:label 'Rate Escalation Clause Applied' ;
    rdfs:comment 'Indicates whether a contractual rate escalation clause (e.g., Consumer Price Index (CPI) adjustment, fixed percentage increase) was applied at renewal. True if escalation clause triggered; False if rates remained flat or were manually adjusted.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalNumber rdf:type rdf:Property ;
    rdfs:label 'Renewal Number' ;
    rdfs:comment 'Business-facing unique identifier for the renewal event. Format: RNW-YYYYMMDD followed by sequence. Used in customer communications and internal tracking.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalStatus rdf:type rdf:Property ;
    rdfs:label 'Renewal Status' ;
    rdfs:comment 'Current lifecycle state of the renewal. Pending: renewal window opened but no action taken. Offered: renewal terms presented to customer. Accepted: customer agreed to renew. Declined: customer rejected renewal. Renegotiated: terms modified during renewal. Lapsed: renewal window closed without action. Cancelled: renewal process terminated. [ENUM-REF-CANDIDATE: pending|offered|accepted|declined|renegotiated|lapsed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalType rdf:type rdf:Property ;
    rdfs:label 'Renewal Type' ;
    rdfs:comment 'Classification of the renewal mechanism. Auto-renewal executes automatically per contract terms; negotiated renewal requires active renegotiation; evergreen continues indefinitely until terminated; manual renewal requires explicit customer action.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewedAnnualValue rdf:type rdf:Property ;
    rdfs:label 'Renewed Annual Value' ;
    rdfs:comment 'Total annual revenue from the renewed contract term, expressed in USD. Reflects any rate escalation or service changes applied at renewal.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retentionStrategy rdf:type rdf:Property ;
    rdfs:label 'Retention Strategy' ;
    rdfs:comment 'Proactive retention approach applied during renewal process. Standard: normal renewal process. Discount Offered: pricing concession to retain customer. Service Upgrade: enhanced service at no additional cost. Executive Engagement: senior leadership involvement. None: no special retention effort required.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceLevelChangeFlag rdf:type rdf:Property ;
    rdfs:label 'Service Level Change Flag' ;
    rdfs:comment 'Indicates whether Service Level Agreement (SLA) terms or service scope changed at renewal. True if service frequency, container count, or performance commitments were modified; False if service levels remained unchanged.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:termLengthMonths rdf:type rdf:Property ;
    rdfs:label 'Term Length Months' ;
    rdfs:comment 'Duration of the renewed contract term expressed in months. Common values: 12, 24, 36, 60 months.' ;
    rdfs:domain ind:Renewal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:terminationId rdf:type rdf:Property ;
    rdfs:label 'Termination Id' ;
    rdfs:comment 'Unique identifier for the contract termination event. Primary key.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractValueLost rdf:type rdf:Property ;
    rdfs:label 'Contract Value Lost' ;
    rdfs:comment 'Estimated annual recurring revenue lost due to contract termination in USD. Calculated from contract billing rate and service frequency. Used for revenue loss analysis and churn impact reporting.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:earlyTerminationFlag rdf:type rdf:Property ;
    rdfs:label 'Early Termination Flag' ;
    rdfs:comment 'Indicates whether the contract is being terminated before its natural expiration date. True: early termination (may trigger penalties). False: termination at contract end date.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:earlyTerminationPenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Early Termination Penalty Amount' ;
    rdfs:comment 'Financial penalty assessed for early contract termination per contract terms. Amount in USD. Null if no penalty applies or termination is at natural contract end.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:effectiveTerminationDate rdf:type rdf:Property ;
    rdfs:label 'Effective Termination Date' ;
    rdfs:comment 'Date when the contract termination becomes legally effective and service obligations cease. Calculated from notice date plus required notice period, or as mutually agreed.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:equipmentRetrievalDate rdf:type rdf:Property ;
    rdfs:label 'Equipment Retrieval Date' ;
    rdfs:comment 'Date when company-owned equipment was retrieved from customer site. Used to track asset recovery and close out termination process. Null if no equipment retrieval required.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:equipmentRetrievalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Equipment Retrieval Required Flag' ;
    rdfs:comment 'Indicates whether company-owned equipment (containers, compactors, bins) must be retrieved from customer site. True: retrieval required. False: no equipment to retrieve or customer-owned equipment.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:equipmentRetrievalStatus rdf:type rdf:Property ;
    rdfs:label 'Equipment Retrieval Status' ;
    rdfs:comment 'Current status of equipment retrieval process. Not required: no equipment to retrieve. Scheduled: retrieval appointment set. In progress: retrieval underway. Completed: all equipment recovered. Customer retained: customer purchased equipment. Lost: equipment not recoverable.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exitFeedbackSummary rdf:type rdf:Property ;
    rdfs:label 'Exit Feedback Summary' ;
    rdfs:comment 'Summary of customer feedback from exit interview. Captures key concerns, service issues, and improvement suggestions. Used for service quality improvement and retention strategy development.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exitInterviewCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Exit Interview Completed Flag' ;
    rdfs:comment 'Indicates whether an exit interview or customer feedback survey was completed. True: feedback collected. False: no feedback obtained. Used to assess data quality for churn analysis.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exitInterviewDate rdf:type rdf:Property ;
    rdfs:label 'Exit Interview Date' ;
    rdfs:comment 'Date when exit interview or customer feedback survey was conducted. Null if no exit interview completed.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:finalBillingDate rdf:type rdf:Property ;
    rdfs:label 'Final Billing Date' ;
    rdfs:comment 'Date when the final invoice for the terminated contract was generated. Includes prorated charges, outstanding balances, and any termination penalties.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:finalInvoiceAmount rdf:type rdf:Property ;
    rdfs:label 'Final Invoice Amount' ;
    rdfs:comment 'Total amount of the final invoice for the terminated contract in USD. Includes prorated service charges, outstanding balances, penalties, and any credits or adjustments.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:finalPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Final Payment Date' ;
    rdfs:comment 'Date when final payment was received and account was settled. Null if final payment not yet received or account written off.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:finalPaymentReceivedFlag rdf:type rdf:Property ;
    rdfs:label 'Final Payment Received Flag' ;
    rdfs:comment 'Indicates whether final payment has been received and account is settled. True: final payment received, account closed. False: outstanding balance remains.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:initiatedBy rdf:type rdf:Property ;
    rdfs:label 'Initiated By' ;
    rdfs:comment 'Party that initiated the contract termination. Customer: customer requested termination. Waste Management: company initiated termination. Mutual: both parties agreed to terminate. Regulatory authority: termination mandated by regulatory body.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noticePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Notice Period Days' ;
    rdfs:comment 'Number of days notice required per contract terms before termination becomes effective. Typically 30, 60, or 90 days for commercial contracts. Used to validate notice compliance.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:outstandingBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Outstanding Balance Amount' ;
    rdfs:comment 'Total unpaid balance on the customer account at time of termination in USD. Includes past due invoices and current charges. Used for collections and write-off decisions.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyWaivedFlag rdf:type rdf:Property ;
    rdfs:label 'Penalty Waived Flag' ;
    rdfs:comment 'Indicates whether early termination penalty was waived by management approval. True: penalty waived. False: penalty enforced. Used for revenue impact analysis and customer retention decisions.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:penaltyWaiverReason rdf:type rdf:Property ;
    rdfs:label 'Penalty Waiver Reason' ;
    rdfs:comment 'Business justification for waiving early termination penalty. Examples: customer hardship, service failure, competitive retention, regulatory requirement. Null if penalty not waived.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedTerminationDate rdf:type rdf:Property ;
    rdfs:label 'Requested Termination Date' ;
    rdfs:comment 'Date requested by the customer or initiating party for contract termination. May differ from effective termination date due to notice period requirements or mutual negotiation.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:terminationNumber rdf:type rdf:Property ;
    rdfs:label 'Termination Number' ;
    rdfs:comment 'Business-facing unique identifier for the termination event. Format: TRM-YYYYMMDD sequence. Used in customer communications and internal tracking.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationStatus rdf:type rdf:Property ;
    rdfs:label 'Termination Status' ;
    rdfs:comment 'Current lifecycle status of the termination process. Pending: termination request received, under review. Notice given: formal termination notice issued. Approved: termination approved by management. Equipment retrieved: containers and equipment returned. Final billed: final invoice generated. Completed: all termination activities finished. Cancelled: termination request withdrawn. [ENUM-REF-CANDIDATE: pending|notice_given|approved|equipment_retrieved|final_billed|completed|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationType rdf:type rdf:Property ;
    rdfs:label 'Termination Type' ;
    rdfs:comment 'Classification of the termination event by initiating party and legal basis. Voluntary cancellation: customer-initiated. Non-renewal expiration: contract expired without renewal. Breach termination: terminated due to contract violation. Regulatory termination: ended due to regulatory requirement. Mutual agreement: both parties agreed to end. Convenience termination: terminated per convenience clause.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:winBackCampaignCode rdf:type rdf:Property ;
    rdfs:label 'Win Back Campaign Code' ;
    rdfs:comment 'Reference to the marketing campaign targeting this churned customer for re-acquisition. Null if no win-back campaign assigned or customer not eligible.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:winBackEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Win Back Eligible Flag' ;
    rdfs:comment 'Indicates whether the customer is eligible for win-back marketing programs. True: eligible for retention offers. False: not eligible (breach, fraud, regulatory). Used to target re-acquisition campaigns.' ;
    rdfs:domain ind:Termination ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:agreementName rdf:type rdf:Property ;
    rdfs:label 'Agreement Name' ;
    rdfs:comment 'Descriptive name of the franchise agreement, typically including municipality name and service type.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementNumber rdf:type rdf:Property ;
    rdfs:label 'Agreement Number' ;
    rdfs:comment 'Externally-known unique business identifier for the franchise agreement, typically formatted as FA-[STATE]-[NUMBER].' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementStatus rdf:type rdf:Property ;
    rdfs:label 'Agreement Status' ;
    rdfs:comment 'Current lifecycle status of the franchise agreement.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diversionRateRequirement rdf:type rdf:Property ;
    rdfs:label 'Diversion Rate Requirement' ;
    rdfs:comment 'Minimum percentage of waste that must be diverted from landfill through recycling, composting, or waste-to-energy programs as mandated by the municipality.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exclusivityType rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Type' ;
    rdfs:comment 'Indicates whether Waste Management has exclusive, non-exclusive, or semi-exclusive rights to provide waste collection services within the franchise territory.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fleetCompositionRequirements rdf:type rdf:Property ;
    rdfs:label 'Fleet Composition Requirements' ;
    rdfs:comment 'Requirements for fleet composition serving the franchise territory, including minimum percentages of CNG, RNG, electric, or other alternative fuel vehicles.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:franchiseFeeFixedAmount rdf:type rdf:Property ;
    rdfs:label 'Franchise Fee Fixed Amount' ;
    rdfs:comment 'Fixed annual franchise fee amount paid to the municipality, applicable when franchise_fee_type is fixed_annual or hybrid.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:franchiseFeePerTonRate rdf:type rdf:Property ;
    rdfs:label 'Franchise Fee Per Ton Rate' ;
    rdfs:comment 'Per-ton franchise fee rate charged for waste disposed within the franchise territory, applicable when franchise_fee_type is per_ton or hybrid.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:franchiseFeePercentage rdf:type rdf:Property ;
    rdfs:label 'Franchise Fee Percentage' ;
    rdfs:comment 'Percentage of gross revenue paid to the municipality as franchise fee, applicable when franchise_fee_type is percentage_of_revenue or hybrid.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:franchiseFeeType rdf:type rdf:Property ;
    rdfs:label 'Franchise Fee Type' ;
    rdfs:comment 'Structure of the franchise fee payment to the municipality: percentage of gross revenue, fixed annual amount, per-ton disposal fee, or hybrid model.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ghgReductionTargetPercentage rdf:type rdf:Property ;
    rdfs:label 'Ghg Reduction Target Percentage' ;
    rdfs:comment 'Target percentage reduction in greenhouse gas emissions required under the franchise agreement, typically measured in CO2e.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:governingLawJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Governing Law Jurisdiction' ;
    rdfs:comment 'State or jurisdiction whose laws govern the interpretation and enforcement of the franchise agreement.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initialTermYears rdf:type rdf:Property ;
    rdfs:label 'Initial Term Years' ;
    rdfs:comment 'Number of years in the initial term of the franchise agreement before any renewal options.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:insuranceRequirementDescription rdf:type rdf:Property ;
    rdfs:label 'Insurance Requirement Description' ;
    rdfs:comment 'Description of the insurance coverage types and minimum limits required under the franchise agreement, including general liability, auto liability, and environmental liability.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Lea Reference Number' ;
    rdfs:comment 'Reference number assigned by the Local Enforcement Agency responsible for solid waste regulatory oversight in the franchise territory.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceBondRequired rdf:type rdf:Property ;
    rdfs:label 'Performance Bond Required' ;
    rdfs:comment 'Indicates whether Waste Management is required to maintain a performance bond to guarantee service delivery under this franchise agreement.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rateAdjustmentMechanism rdf:type rdf:Property ;
    rdfs:label 'Rate Adjustment Mechanism' ;
    rdfs:comment 'Description of the methodology for adjusting service rates over the term of the franchise agreement, including CPI escalation, fuel surcharge formulas, or other adjustment triggers.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalOptionYears rdf:type rdf:Property ;
    rdfs:label 'Renewal Option Years' ;
    rdfs:comment 'Number of years in each renewal option period, if the franchise agreement includes renewal provisions.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:terminationForCauseAllowed rdf:type rdf:Property ;
    rdfs:label 'Termination For Cause Allowed' ;
    rdfs:comment 'Indicates whether the municipality has the right to terminate the franchise agreement for cause due to performance failures or regulatory violations.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:territoryGeojson rdf:type rdf:Property ;
    rdfs:label 'Territory Geojson' ;
    rdfs:comment 'GeoJSON representation of the franchise territory boundaries for mapping and spatial analysis.' ;
    rdfs:domain ind:FranchiseAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designatedCellId rdf:type rdf:Property ;
    rdfs:label 'Designated Cell Id' ;
    rdfs:comment 'Foreign key linking to landfill.cell. Business justification: Some disposal agreements specify designated cells for particular waste streams (e.g., industrial waste, C&D). Supports cell-specific capacity allocation, waste stream segregation requirements, and per' ;
    rdfs:domain ind:DisposalAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Cell .

ind:facilityPermitId rdf:type rdf:Property ;
    rdfs:label 'Facility Permit Id' ;
    rdfs:comment 'Foreign key linking to compliance.permit. Business justification: Disposal agreements with landfills/transfer stations must reference facility operating permits to verify accepted waste streams, capacity limits, and regulatory authorization. Procurement teams valida' ;
    rdfs:domain ind:DisposalAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Permit .

ind:baseTippingFeeRate rdf:type rdf:Property ;
    rdfs:label 'Base Tipping Fee Rate' ;
    rdfs:comment 'Base rate charged per ton for waste disposal at the facility, measured in currency per ton. Excludes surcharges and adjustments.' ;
    rdfs:domain ind:DisposalAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractedAnnualTonnage rdf:type rdf:Property ;
    rdfs:label 'Contracted Annual Tonnage' ;
    rdfs:comment 'Total tonnage volume contracted per year under this disposal agreement, measured in tons.' ;
    rdfs:domain ind:DisposalAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:facilityOperator rdf:type rdf:Property ;
    rdfs:label 'Facility Operator' ;
    rdfs:comment 'Name of the organization or entity that operates the disposal facility.' ;
    rdfs:domain ind:DisposalAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumTonnageGuarantee rdf:type rdf:Property ;
    rdfs:label 'Minimum Tonnage Guarantee' ;
    rdfs:comment 'Minimum tonnage volume that must be delivered annually to meet contractual obligations, measured in tons. Nullable if no minimum is required.' ;
    rdfs:domain ind:DisposalAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performancePenaltyClause rdf:type rdf:Property ;
    rdfs:label 'Performance Penalty Clause' ;
    rdfs:comment 'Description of penalties or liquidated damages for failure to meet contracted tonnage, SLA, or other performance obligations.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rcraComplianceRequired rdf:type rdf:Property ;
    rdfs:label 'Rcra Compliance Required' ;
    rdfs:comment 'Indicates whether this disposal agreement requires compliance with RCRA regulations for hazardous waste handling and disposal.' ;
    rdfs:domain ind:DisposalAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tippingFeeCurrency rdf:type rdf:Property ;
    rdfs:label 'Tipping Fee Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for tipping fee rates (e.g., USD, CAD).' ;
    rdfs:domain ind:DisposalAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tpdCapacity rdf:type rdf:Property ;
    rdfs:label 'Tpd Capacity' ;
    rdfs:comment 'Daily tonnage capacity allocated under this disposal agreement, measured in Tons Per Day (TPD).' ;
    rdfs:domain ind:DisposalAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorContactEmail rdf:type rdf:Property ;
    rdfs:label 'Vendor Contact Email' ;
    rdfs:comment 'Email address for the vendor contact at the disposal facility.' ;
    rdfs:domain ind:DisposalAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorContactName rdf:type rdf:Property ;
    rdfs:label 'Vendor Contact Name' ;
    rdfs:comment 'Primary contact name at the disposal facility vendor for operational coordination.' ;
    rdfs:domain ind:DisposalAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorContactPhone rdf:type rdf:Property ;
    rdfs:label 'Vendor Contact Phone' ;
    rdfs:comment 'Primary phone number for the vendor contact at the disposal facility.' ;
    rdfs:domain ind:DisposalAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationLandfillSiteId rdf:type rdf:Property ;
    rdfs:label 'Destination Landfill Site Id' ;
    rdfs:comment 'Foreign key linking to landfill.site. Business justification: Hauling agreements designating landfill sites as destinations require direct linkage to landfill.site for permit compliance verification, daily tonnage cap enforcement, and waste stream eligibility ch' ;
    rdfs:domain ind:HaulingAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Site .

ind:originFacilityId rdf:type rdf:Property ;
    rdfs:label 'Origin Facility Id' ;
    rdfs:comment 'Identifier for the facility or location where waste is collected or loaded for transport. May be collection point, transfer station, or customer site.' ;
    rdfs:domain ind:HaulingAgreement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:bolRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Bol Requirement Flag' ;
    rdfs:comment 'Indicates whether a BOL document is required for each haul under this agreement. True if BOL is mandatory.' ;
    rdfs:domain ind:HaulingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractedRate rdf:type rdf:Property ;
    rdfs:label 'Contracted Rate' ;
    rdfs:comment 'Base rate amount per unit as defined by rate structure type. Expressed in USD unless otherwise specified in currency code.' ;
    rdfs:domain ind:HaulingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalComplianceCertifications rdf:type rdf:Property ;
    rdfs:label 'Environmental Compliance Certifications' ;
    rdfs:comment 'List of environmental certifications and permits held by the hauler relevant to this agreement (e.g., EPA ID, state permits, ISO 14001).' ;
    rdfs:domain ind:HaulingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelSurchargeFormula rdf:type rdf:Property ;
    rdfs:label 'Fuel Surcharge Formula' ;
    rdfs:comment 'Mathematical formula or index reference used to calculate fuel surcharge adjustments. Typically references DOE diesel price index.' ;
    rdfs:domain ind:HaulingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Insurance Certificate Number' ;
    rdfs:comment 'Reference number for the haulers liability and cargo insurance certificate on file. Required for risk management and compliance.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Insurance Expiration Date' ;
    rdfs:comment 'Date when the haulers insurance certificate expires. Triggers renewal verification process.' ;
    rdfs:domain ind:Contract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:manifestRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Manifest Requirement Flag' ;
    rdfs:comment 'Indicates whether hazardous waste manifest tracking is required per RCRA regulations. True for hazardous waste streams.' ;
    rdfs:domain ind:HaulingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maximumVolumeCapacityTons rdf:type rdf:Property ;
    rdfs:label 'Maximum Volume Capacity Tons' ;
    rdfs:comment 'Maximum tonnage the hauler commits to transport over the contract period. Defines capacity ceiling.' ;
    rdfs:domain ind:HaulingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumVolumeCommitmentTons rdf:type rdf:Property ;
    rdfs:label 'Minimum Volume Commitment Tons' ;
    rdfs:comment 'Minimum tonnage the customer commits to provide for hauling over the contract period. Nullable if no minimum applies.' ;
    rdfs:domain ind:HaulingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateStructureType rdf:type rdf:Property ;
    rdfs:label 'Rate Structure Type' ;
    rdfs:comment 'Pricing model used to calculate hauling charges. Defines the unit basis for rate application.' ;
    rdfs:domain ind:HaulingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalTerms rdf:type rdf:Property ;
    rdfs:label 'Renewal Terms' ;
    rdfs:comment 'Contractual provisions governing automatic renewal, renewal notice periods, and renegotiation requirements.' ;
    rdfs:domain ind:HaulingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeLaneDescription rdf:type rdf:Property ;
    rdfs:label 'Route Lane Description' ;
    rdfs:comment 'Textual description of the hauling route or lane including key waypoints, geographic coverage, and operational constraints.' ;
    rdfs:domain ind:HaulingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationForCauseClause rdf:type rdf:Property ;
    rdfs:label 'Termination For Cause Clause' ;
    rdfs:comment 'Contractual terms defining conditions under which either party may terminate immediately for material breach or non-performance.' ;
    rdfs:domain ind:HaulingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocatedTransactionPrice rdf:type rdf:Property ;
    rdfs:label 'Allocated Transaction Price' ;
    rdfs:comment 'Portion of the total contract transaction price allocated to this specific performance obligation based on relative standalone selling prices.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:constraintApplied rdf:type rdf:Property ;
    rdfs:label 'Constraint Applied' ;
    rdfs:comment 'Indicates whether a constraint has been applied to variable consideration to prevent significant revenue reversal.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractAssetLiabilityIndicator rdf:type rdf:Property ;
    rdfs:label 'Contract Asset Liability Indicator' ;
    rdfs:comment 'Indicates whether this obligation creates a contract asset (revenue recognized before billing) or contract liability (billing before revenue recognition) on the balance sheet.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costOfService rdf:type rdf:Property ;
    rdfs:label 'Cost Of Service' ;
    rdfs:comment 'Estimated or actual cost to fulfill this performance obligation, used for profitability analysis.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isDistinct rdf:type rdf:Property ;
    rdfs:label 'Is Distinct' ;
    rdfs:comment 'Indicates whether this obligation is distinct and separately identifiable from other promises in the contract per ASC 606 criteria.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVariableConsideration rdf:type rdf:Property ;
    rdfs:label 'Is Variable Consideration' ;
    rdfs:comment 'Indicates whether this obligation includes variable consideration (e.g., usage-based pricing, performance bonuses, penalties) that may affect the transaction price.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:obligationDescription rdf:type rdf:Property ;
    rdfs:label 'Obligation Description' ;
    rdfs:comment 'Detailed description of the distinct service promise represented by this obligation (e.g., weekly residential collection, monthly roll-off swap, annual container maintenance).' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationNumber rdf:type rdf:Property ;
    rdfs:label 'Obligation Number' ;
    rdfs:comment 'Business-readable identifier for the performance obligation, typically formatted as PO-NNNNNN.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationStatus rdf:type rdf:Property ;
    rdfs:label 'Obligation Status' ;
    rdfs:comment 'Current lifecycle status of the performance obligation indicating whether it is active, satisfied, or terminated.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:percentageComplete rdf:type rdf:Property ;
    rdfs:label 'Percentage Complete' ;
    rdfs:comment 'Percentage of completion for obligations satisfied over time, used to calculate revenue recognition (0.00 to 100.00).' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceMilestone rdf:type rdf:Property ;
    rdfs:label 'Performance Milestone' ;
    rdfs:comment 'Description of key milestone or deliverable that triggers satisfaction of this obligation (applicable for milestone-based recognition).' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remainingRevenue rdf:type rdf:Property ;
    rdfs:label 'Remaining Revenue' ;
    rdfs:comment 'Remaining revenue to be recognized for this performance obligation (allocated transaction price minus revenue recognized to date).' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueRecognitionPattern rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Pattern' ;
    rdfs:comment 'The pattern used to recognize revenue for this obligation (e.g., straight-line over contract term, usage-based per service event, milestone completion).' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRecognizedToDate rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognized To Date' ;
    rdfs:comment 'Cumulative revenue recognized for this performance obligation as of the current reporting period.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:satisfactionDate rdf:type rdf:Property ;
    rdfs:label 'Satisfaction Date' ;
    rdfs:comment 'Actual date when the performance obligation was fully satisfied. Null if not yet satisfied.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:satisfactionMethod rdf:type rdf:Property ;
    rdfs:label 'Satisfaction Method' ;
    rdfs:comment 'Indicates whether the performance obligation is satisfied over time (e.g., ongoing collection service) or at a point in time (e.g., one-time container delivery).' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceQuantity rdf:type rdf:Property ;
    rdfs:label 'Service Quantity' ;
    rdfs:comment 'Quantity of service units promised under this obligation (e.g., number of pickups, number of containers, tons of waste).' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Service Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the service quantity (e.g., pickups, containers, tons, cubic yards). [ENUM-REF-CANDIDATE: pickup|container|ton|cubic_yard|gallon|service_event|month — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standaloneSellingPrice rdf:type rdf:Property ;
    rdfs:label 'Standalone Selling Price' ;
    rdfs:comment 'The price at which the entity would sell the promised good or service separately to a customer, used for transaction price allocation under ASC 606.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:variableConsiderationEstimate rdf:type rdf:Property ;
    rdfs:label 'Variable Consideration Estimate' ;
    rdfs:comment 'Estimated amount of variable consideration expected to be received for this obligation, subject to constraint requirements.' ;
    rdfs:domain ind:PerformanceObligation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acceptedPaymentMethods rdf:type rdf:Property ;
    rdfs:label 'Accepted Payment Methods' ;
    rdfs:comment 'Comma-separated list of payment methods accepted under this billing term (e.g., \'check, ACH, credit_card, wire_transfer\'). Defines customer payment options.' ;
    rdfs:domain ind:BillingTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoPayEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Pay Enabled' ;
    rdfs:comment 'Indicates whether automatic payment processing is enabled for this billing term. True if customer has authorized automatic payment deduction.' ;
    rdfs:domain ind:BillingTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:billingContactEmail rdf:type rdf:Property ;
    rdfs:label 'Billing Contact Email' ;
    rdfs:comment 'Primary email address for billing-related communications and invoice delivery. Used for electronic invoice distribution.' ;
    rdfs:domain ind:BillingTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingContactPhone rdf:type rdf:Property ;
    rdfs:label 'Billing Contact Phone' ;
    rdfs:comment 'Primary phone number for billing inquiries and payment-related communications.' ;
    rdfs:domain ind:BillingTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCycleDay rdf:type rdf:Property ;
    rdfs:label 'Billing Cycle Day' ;
    rdfs:comment 'Day of the month when the billing cycle closes and invoice is generated (e.g., 1 for first of month, 15 for mid-month). Null for event-based billing.' ;
    rdfs:domain ind:BillingTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:billingTermStatus rdf:type rdf:Property ;
    rdfs:label 'Billing Term Status' ;
    rdfs:comment 'Current lifecycle status of the billing term configuration. Active terms are in use for billing operations.' ;
    rdfs:domain ind:BillingTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountTerms rdf:type rdf:Property ;
    rdfs:label 'Discount Terms' ;
    rdfs:comment 'Early payment discount terms (e.g., \'2/10 Net 30\' means 2% discount if paid within 10 days, otherwise net 30). Null if no early payment discount applies.' ;
    rdfs:domain ind:BillingTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dunningProcedure rdf:type rdf:Property ;
    rdfs:label 'Dunning Procedure' ;
    rdfs:comment 'Collections procedure applied for overdue invoices. Defines escalation steps and timing for collection actions.' ;
    rdfs:domain ind:BillingTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:electronicInvoiceFormat rdf:type rdf:Property ;
    rdfs:label 'Electronic Invoice Format' ;
    rdfs:comment 'File format for electronic invoice delivery. EDI 810 is the standard Electronic Data Interchange (EDI) invoice transaction set.' ;
    rdfs:domain ind:BillingTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceConsolidation rdf:type rdf:Property ;
    rdfs:label 'Invoice Consolidation' ;
    rdfs:comment 'Indicates whether multiple service charges should be consolidated into a single invoice. True for consolidated billing, False for separate invoices per service.' ;
    rdfs:domain ind:BillingTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minimumInvoiceAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Invoice Amount' ;
    rdfs:comment 'Minimum monetary amount required to generate an invoice. Charges below this threshold may be carried forward to next billing cycle. Null if no minimum applies.' ;
    rdfs:domain ind:BillingTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentDueDay rdf:type rdf:Property ;
    rdfs:label 'Payment Due Day' ;
    rdfs:comment 'Specific day of the month when payment is due, if applicable. Used for fixed-date payment schedules (e.g., payment always due on the 15th of the month).' ;
    rdfs:domain ind:BillingTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:securityDepositAmount rdf:type rdf:Property ;
    rdfs:label 'Security Deposit Amount' ;
    rdfs:comment 'Monetary amount of the security deposit required, if applicable. Null if no deposit is required.' ;
    rdfs:domain ind:BillingTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:securityDepositRequired rdf:type rdf:Property ;
    rdfs:label 'Security Deposit Required' ;
    rdfs:comment 'Indicates whether a security deposit is required under this billing term. True if deposit is mandatory, False otherwise.' ;
    rdfs:domain ind:BillingTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:statementFrequency rdf:type rdf:Property ;
    rdfs:label 'Statement Frequency' ;
    rdfs:comment 'Frequency at which account statements are generated and sent to the customer. Separate from invoice frequency.' ;
    rdfs:domain ind:BillingTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termCode rdf:type rdf:Property ;
    rdfs:label 'Term Code' ;
    rdfs:comment 'Unique business identifier code for the billing term configuration. Used for external reference and integration with Oracle Revenue Management.' ;
    rdfs:domain ind:BillingTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termName rdf:type rdf:Property ;
    rdfs:label 'Term Name' ;
    rdfs:comment 'Human-readable name describing the billing term arrangement (e.g., \'Monthly Net 30\', \'Quarterly Prepaid\', \'Per-Service Event\').' ;
    rdfs:domain ind:BillingTerm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codeId rdf:type rdf:Property ;
    rdfs:label 'Code Id' ;
    rdfs:comment 'Foreign key linking to service.service_code. Business justification: Offering should reference the standardized service_code registry for code assignment. The offering table currently has a \'service_code\' STRING attribute that should be replaced with a FK to the servic' ;
    rdfs:domain ind:Service ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Code .

ind:defaultContainerTypeId rdf:type rdf:Property ;
    rdfs:label 'Default Container Type Id' ;
    rdfs:comment 'Foreign key linking to service.container_type. Business justification: Offering references a default container type. The offering table has a STRING column \'default_container_type\' that should be replaced with a proper FK to container_type.container_type_id. This normali' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContainerType .

ind:defaultFrequencyPlanId rdf:type rdf:Property ;
    rdfs:label 'Default Frequency Plan Id' ;
    rdfs:comment 'Foreign key linking to service.frequency_plan. Business justification: Offering references a default frequency plan. The offering table has a STRING column \'default_service_frequency\' that should be replaced with a proper FK to frequency_plan.frequency_plan_id. This norm' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FrequencyPlan .

ind:requiredAssetClassId rdf:type rdf:Property ;
    rdfs:label 'Required Asset Class Id' ;
    rdfs:comment 'Foreign key linking to asset.asset_class. Business justification: Service offerings specify required asset class for delivery (e.g., hazmat service requires hazmat-certified container class, compaction service requires compactor-class assets). Drives asset eligibili' ;
    rdfs:domain ind:Service ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Class .

ind:requiredInspectionChecklistId rdf:type rdf:Property ;
    rdfs:label 'Required Inspection Checklist Id' ;
    rdfs:comment 'Foreign key linking to asset.inspection_checklist. Business justification: Hazmat, medical, and special-waste offerings mandate specific DOT/RCRA container inspection protocols. Linking offering to the required inspection checklist enables compliance auditing, ensures correc' ;
    rdfs:domain ind:Service ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InspectionChecklist .

ind:amcsServiceCode rdf:type rdf:Property ;
    rdfs:label 'Amcs Service Code' ;
    rdfs:comment 'AMCS Platform service code used for route optimization, dispatching, and container tracking integration.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:basePriceAmount rdf:type rdf:Property ;
    rdfs:label 'Base Price Amount' ;
    rdfs:comment 'Standard base price for the service offering before adjustments, surcharges, or discounts. Currency is USD for all operations.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carbonOffsetEligible rdf:type rdf:Property ;
    rdfs:label 'Carbon Offset Eligible' ;
    rdfs:comment 'Indicates whether this service qualifies for carbon offset credits or greenhouse gas (GHG) reduction reporting (e.g., WTE, RNG, landfill gas capture services).' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:epaWasteCode rdf:type rdf:Property ;
    rdfs:label 'Epa Waste Code' ;
    rdfs:comment 'EPA hazardous waste code(s) applicable to this service offering if it handles RCRA-regulated materials (e.g., D001, F001, K001, P001, U001). Null for non-hazardous services.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumContractTermMonths rdf:type rdf:Property ;
    rdfs:label 'Minimum Contract Term Months' ;
    rdfs:comment 'Minimum contract duration in months required for this service offering. Null for services with no minimum term.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:oracleRateCode rdf:type rdf:Property ;
    rdfs:label 'Oracle Rate Code' ;
    rdfs:comment 'Oracle Revenue Management system rate code identifier used for billing and invoicing.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingUnit rdf:type rdf:Property ;
    rdfs:label 'Pricing Unit' ;
    rdfs:comment 'Unit of measure for pricing calculation (e.g., per month, per pickup, per ton, per yard, per event, per gallon, per container, flat rate). [ENUM-REF-CANDIDATE: per_month|per_pickup|per_ton|per_yard|per_event|per_gallon|per_container|flat_rate — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryClassification rdf:type rdf:Property ;
    rdfs:label 'Regulatory Classification' ;
    rdfs:comment 'Regulatory status of the service offering indicating compliance requirements (e.g., non-regulated, RCRA-regulated, DOT-regulated, TSDF-required, universal waste, state-regulated).' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresCustomerTraining rdf:type rdf:Property ;
    rdfs:label 'Requires Customer Training' ;
    rdfs:comment 'Indicates whether this service requires customer training on proper waste segregation, container usage, or safety procedures.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresManifest rdf:type rdf:Property ;
    rdfs:label 'Requires Manifest' ;
    rdfs:comment 'Indicates whether this service requires hazardous waste tracking manifest documentation per RCRA regulations.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresSiteAssessment rdf:type rdf:Property ;
    rdfs:label 'Requires Site Assessment' ;
    rdfs:comment 'Indicates whether this service requires an on-site assessment before service initiation (common for commercial, industrial, and hazardous waste services).' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresSpecialPermit rdf:type rdf:Property ;
    rdfs:label 'Requires Special Permit' ;
    rdfs:comment 'Indicates whether this service requires special permits or licenses from regulatory authorities (EPA, state, or local).' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:salesforceProductCode rdf:type rdf:Property ;
    rdfs:label 'Salesforce Product Code' ;
    rdfs:comment 'Salesforce CRM product record identifier (18-character Salesforce ID) used in opportunity and contract management.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapSdConditionType rdf:type rdf:Property ;
    rdfs:label 'Sap Sd Condition Type' ;
    rdfs:comment 'SAP S/4HANA SD pricing condition type code used for rate calculation and billing (e.g., ZPR0 for base price, ZFEE for fees, ZSUR for surcharges).' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapSdMaterialNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Sd Material Number' ;
    rdfs:comment 'SAP S/4HANA SD module material master number for this service offering used in sales orders and billing.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceAreaRestriction rdf:type rdf:Property ;
    rdfs:label 'Service Area Restriction' ;
    rdfs:comment 'Geographic or operational restrictions on where this service can be delivered (e.g., specific districts, municipalities, or facility service areas). Null if no restrictions apply.' ;
    rdfs:domain ind:Offering ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceCategory rdf:type rdf:Property ;
    rdfs:label 'Service Category' ;
    rdfs:comment 'High-level classification of the service offering by customer segment.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceCode rdf:type rdf:Property ;
    rdfs:label 'Service Code' ;
    rdfs:comment 'Unique business identifier for the service offering used across operational systems. Externally-known code used in contracts, billing, and customer communications.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceDescription rdf:type rdf:Property ;
    rdfs:label 'Service Description' ;
    rdfs:comment 'Detailed description of the service offering including scope, inclusions, exclusions, and operational details.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceName rdf:type rdf:Property ;
    rdfs:label 'Service Name' ;
    rdfs:comment 'Human-readable name of the waste management service offering (e.g., \'Residential Curbside Pickup - Weekly\', \'Commercial Front-End-Load 8-Yard\', \'Roll-Off 30-Yard Rental\').' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityProgramFlag rdf:type rdf:Property ;
    rdfs:label 'Sustainability Program Flag' ;
    rdfs:comment 'Indicates whether this service is part of a sustainability or environmental stewardship program (e.g., recycling, WTE, RNG, carbon offset programs).' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentServiceLineId rdf:type rdf:Property ;
    rdfs:label 'Parent Service Line Id' ;
    rdfs:comment 'Reference to a parent service line if this service line is a sub-category or specialization. Enables hierarchical service line taxonomy. Null for top-level service lines.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Line .

ind:basePriceUsd rdf:type rdf:Property ;
    rdfs:label 'Base Price Usd' ;
    rdfs:comment 'Standard base price or starting price point for this service line in USD. Actual customer pricing may vary based on contract terms, volume commitments, and market conditions. Used for financial planning and margin analysis.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:businessUnit rdf:type rdf:Property ;
    rdfs:label 'Business Unit' ;
    rdfs:comment 'Primary business unit or customer segment this service line serves. Aligns with organizational structure and market segmentation strategy.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carbonOffsetEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Carbon Offset Eligible Flag' ;
    rdfs:comment 'Indicates whether this service line generates activities eligible for carbon offset credits or renewable energy certificates. True for LFG-to-energy, RNG production, and WTE operations.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:collectionFrequencyStandard rdf:type rdf:Property ;
    rdfs:label 'Collection Frequency Standard' ;
    rdfs:comment 'Standard or default collection frequency for this service line. Actual customer frequency may vary based on contract terms. On-demand applies to roll-off and specialty services; scheduled event applies to hazardous waste collection events.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerTypeCategory rdf:type rdf:Property ;
    rdfs:label 'Container Type Category' ;
    rdfs:comment 'Primary container or equipment types used to deliver this service line. Examples: carts (residential), dumpsters (commercial front-load), compactors (high-volume commercial), roll-off containers (construction), specialized containers (hazardous waste). Supports operational planning and asset allocation. [ENUM-REF-CANDIDATE: cart|dumpster|compactor|roll_off|specialized_container|bulk_pickup|curbside|drop_off_center — promote to reference product]' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractTemplateCode rdf:type rdf:Property ;
    rdfs:label 'Contract Template Code' ;
    rdfs:comment 'Reference to the standard contract template used for this service line in Salesforce CRM. Supports contract generation and legal compliance.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerPortalEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Portal Enabled Flag' ;
    rdfs:comment 'Indicates whether customers can self-service this service line through the online customer portal (Waste Logics). True for standard services with online scheduling and account management; false for specialized services requiring direct sales engagement.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:displayOrder rdf:type rdf:Property ;
    rdfs:label 'Display Order' ;
    rdfs:comment 'Numeric sort order for displaying service lines in customer-facing interfaces, reports, and catalogs. Lower numbers appear first.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:diversionRateTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Diversion Rate Target Percent' ;
    rdfs:comment 'Target percentage of waste diverted from landfill for this service line. Applicable to recycling, composting, and WTE programs. Expressed as percentage (e.g., 75.00 for 75% diversion). Null for non-diversion service lines.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dotHazmatClass rdf:type rdf:Property ;
    rdfs:label 'Dot Hazmat Class' ;
    rdfs:comment 'DOT hazardous materials classification if this service line involves transportation of regulated materials. Examples: Class 3 (flammable liquids), Class 6 (toxic substances), Class 9 (miscellaneous). Empty for non-hazmat service lines.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:driverCdlRequirement rdf:type rdf:Property ;
    rdfs:label 'Driver Cdl Requirement' ;
    rdfs:comment 'Minimum CDL class and endorsements required for drivers operating this service line. Class A for combination vehicles, Class B for heavy straight trucks, HAZMAT endorsement for hazardous waste transport.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:epaWasteCodeCategory rdf:type rdf:Property ;
    rdfs:label 'Epa Waste Code Category' ;
    rdfs:comment 'Primary EPA waste code category or categories applicable to this service line. Examples: D-list (characteristic hazardous), F-list (non-specific source), K-list (specific source), P/U-list (discarded commercial products). Empty for non-hazardous service lines.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fleetTypeRequirement rdf:type rdf:Property ;
    rdfs:label 'Fleet Type Requirement' ;
    rdfs:comment 'Primary fleet vehicle types required to deliver this service line. Examples: ASL (Automated Side Loader) for residential carts, FEL (Front End Loader) for commercial dumpsters, REL (Rear End Loader) for manual collection, roll-off trucks, specialized hazmat vehicles. Supports fleet planning and maintenance scheduling. [ENUM-REF-CANDIDATE: asl|fel|rel|roll_off_truck|hazmat_vehicle|transfer_trailer|specialty_equipment — promote to reference product]' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ghgReductionContributionFlag rdf:type rdf:Property ;
    rdfs:label 'Ghg Reduction Contribution Flag' ;
    rdfs:comment 'Indicates whether this service line contributes to greenhouse gas emission reduction goals. True for WTE, RNG, recycling, and CNG fleet operations.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insuranceRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Insurance Requirement Flag' ;
    rdfs:comment 'Indicates whether this service line requires specialized insurance coverage beyond standard general liability. True for hazardous waste, high-value assets, and environmental liability exposures.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:permitRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Permit Requirement Flag' ;
    rdfs:comment 'Indicates whether this service line requires specific environmental permits, licenses, or certifications to operate. True for hazardous waste, WTE, TSDF operations; false for standard residential collection.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ppeRequirementLevel rdf:type rdf:Property ;
    rdfs:label 'Ppe Requirement Level' ;
    rdfs:comment 'Level of PPE required for workers delivering this service line. Standard for routine collection, enhanced for heavy industrial, HAZMAT for hazardous waste handling, specialized for WTE or TSDF operations.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitMarginTargetPercent rdf:type rdf:Property ;
    rdfs:label 'Profit Margin Target Percent' ;
    rdfs:comment 'Target profit margin percentage for this service line. Used for pricing strategy, contract negotiations, and performance evaluation. Expressed as percentage (e.g., 25.00 for 25%).' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueAccountCode rdf:type rdf:Property ;
    rdfs:label 'Revenue Account Code' ;
    rdfs:comment 'General Ledger (GL) revenue account code for posting revenue from this service line. Supports financial reporting, revenue recognition, and EBITDA analysis.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeOptimizationEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Route Optimization Eligible Flag' ;
    rdfs:comment 'Indicates whether this service line is eligible for automated route optimization and dynamic dispatching. True for scheduled collection services; false for on-demand or event-based services.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceLineCode rdf:type rdf:Property ;
    rdfs:label 'Service Line Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the service line for external reference and system integration. Examples: RES-COL, COM-COL, ROLL-OFF, RECYCLE, HAZ-WASTE, WTE.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceLineDescription rdf:type rdf:Property ;
    rdfs:label 'Service Line Description' ;
    rdfs:comment 'Detailed description of the service line, including scope, target customer segments, and key service characteristics.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceLineName rdf:type rdf:Property ;
    rdfs:label 'Service Line Name' ;
    rdfs:comment 'Full business name of the service line. Examples: Residential Collection, Commercial Collection, Roll-Off Services, Recycling Programs, Hazardous Waste Management, Waste-to-Energy (WTE), Specialty Services.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceLineStatus rdf:type rdf:Property ;
    rdfs:label 'Service Line Status' ;
    rdfs:comment 'Current lifecycle status of the service line. Active lines are available for sale and delivery; inactive lines are discontinued; pilot lines are in testing; sunset lines are being phased out; seasonal lines operate during specific periods.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceLineType rdf:type rdf:Property ;
    rdfs:label 'Service Line Type' ;
    rdfs:comment 'High-level classification of the service line by operational category. Determines operational model, resource requirements, and regulatory framework.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaResponseTimeHours rdf:type rdf:Property ;
    rdfs:label 'Sla Response Time Hours' ;
    rdfs:comment 'Standard response time commitment in hours for service requests or issues related to this service line. Used for customer service performance tracking and contract compliance.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trainingCertificationRequired rdf:type rdf:Property ;
    rdfs:label 'Training Certification Required' ;
    rdfs:comment 'Specific training certifications or qualifications required for personnel delivering this service line. Examples: HAZWOPER 40-hour, DOT HAZMAT, OSHA confined space, forklift operator. Empty for services with no specialized training requirements.' ;
    rdfs:domain ind:Line ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cogsAccount rdf:type rdf:Property ;
    rdfs:label 'Cogs Account' ;
    rdfs:comment 'General Ledger account number for Cost of Goods Sold associated with delivering this service.' ;
    rdfs:domain ind:Code ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerPortalVisibleFlag rdf:type rdf:Property ;
    rdfs:label 'Customer Portal Visible Flag' ;
    rdfs:comment 'Indicates whether this service is visible and available for self-service ordering in the customer portal (True) or restricted to internal sales channels only (False).' ;
    rdfs:domain ind:Code ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:diversionCreditEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Diversion Credit Eligible Flag' ;
    rdfs:comment 'Indicates whether tonnage from this service counts toward landfill diversion rate calculations (True) or not (False). True for recycling, composting, and waste-to-energy services.' ;
    rdfs:domain ind:Code ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:epaWasteCategory rdf:type rdf:Property ;
    rdfs:label 'Epa Waste Category' ;
    rdfs:comment 'EPA waste category classification for reporting and compliance purposes (e.g., MSW, C&D, industrial non-hazardous, hazardous).' ;
    rdfs:domain ind:Code ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ghgReductionEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Ghg Reduction Eligible Flag' ;
    rdfs:comment 'Indicates whether this service contributes to greenhouse gas (GHG) emission reductions and is eligible for carbon credit or offset programs (True) or not (False). Applies to recycling, composting, and WTE services.' ;
    rdfs:domain ind:Code ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minimumServiceTermMonths rdf:type rdf:Property ;
    rdfs:label 'Minimum Service Term Months' ;
    rdfs:comment 'Minimum contract term required for this service, expressed in months. Zero indicates no minimum term (month-to-month service).' ;
    rdfs:domain ind:Code ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pickupDaysPerWeek rdf:type rdf:Property ;
    rdfs:label 'Pickup Days Per Week' ;
    rdfs:comment 'Number of scheduled pickup days per week for this service (0-7). Zero indicates on-call or non-recurring services.' ;
    rdfs:domain ind:Code ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rateUnit rdf:type rdf:Property ;
    rdfs:label 'Rate Unit' ;
    rdfs:comment 'Unit of measure for the base rate: per month, per pickup, per ton, per cubic yard, per gallon, or per event.' ;
    rdfs:domain ind:Code ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rcraWasteCode rdf:type rdf:Property ;
    rdfs:label 'Rcra Waste Code' ;
    rdfs:comment 'RCRA hazardous waste code(s) applicable to this service, if regulated under RCRA (e.g., D001 for ignitable waste, F001-F005 for spent solvents). Null for non-RCRA services.' ;
    rdfs:domain ind:Code ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceStatus rdf:type rdf:Property ;
    rdfs:label 'Service Status' ;
    rdfs:comment 'Current lifecycle status of the service code: active (available for sale), inactive (temporarily unavailable), suspended (on hold), discontinued (no longer offered), or pending approval (awaiting activation).' ;
    rdfs:domain ind:Code ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceAssetClassId rdf:type rdf:Property ;
    rdfs:label 'Reference Asset Class Id' ;
    rdfs:comment 'Foreign key linking to asset.asset_class. Business justification: Container types in service catalog map to asset classes for financial tracking (depreciation, capitalization thresholds, GL accounts). Links service catalog specifications to asset accounting rules, e' ;
    rdfs:domain ind:ContainerType ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Class .

ind:certificationStandards rdf:type rdf:Property ;
    rdfs:label 'Certification Standards' ;
    rdfs:comment 'Industry certifications and standards this container type meets (e.g., ANSI Z245.60, ISO 14001, RCRA compliance). Comma-separated list.' ;
    rdfs:domain ind:ContainerType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorStandard rdf:type rdf:Property ;
    rdfs:label 'Color Standard' ;
    rdfs:comment 'Standard color designation for this container type. Often used for waste stream identification (e.g., blue for recycling, green for organics, black for MSW).' ;
    rdfs:domain ind:ContainerType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commercialUseFlag rdf:type rdf:Property ;
    rdfs:label 'Commercial Use Flag' ;
    rdfs:comment 'Indicates whether this container type is designed and approved for commercial service delivery.' ;
    rdfs:domain ind:ContainerType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:compactionCapableFlag rdf:type rdf:Property ;
    rdfs:label 'Compaction Capable Flag' ;
    rdfs:comment 'Indicates whether this container type includes or supports compaction mechanisms to increase waste density and reduce collection frequency.' ;
    rdfs:domain ind:ContainerType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:containerCategory rdf:type rdf:Property ;
    rdfs:label 'Container Category' ;
    rdfs:comment 'High-level classification of the container type by form factor and use case.' ;
    rdfs:domain ind:ContainerType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerTypeCode rdf:type rdf:Property ;
    rdfs:label 'Container Type Code' ;
    rdfs:comment 'Unique alphanumeric code identifying the container type in operational systems. Used for Container Identification (CID) classification and cross-system reference.' ;
    rdfs:domain ind:ContainerType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerTypeName rdf:type rdf:Property ;
    rdfs:label 'Container Type Name' ;
    rdfs:comment 'Business-friendly name of the container type (e.g., \'10 Yard Roll-Off\', \'96 Gallon Residential Cart\', \'40 Yard Compactor\').' ;
    rdfs:domain ind:ContainerType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:containerTypeStatus rdf:type rdf:Property ;
    rdfs:label 'Container Type Status' ;
    rdfs:comment 'Current lifecycle status of this container type in the service catalog. Active types are available for new service orders.' ;
    rdfs:domain ind:ContainerType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedUsefulLifeYears rdf:type rdf:Property ;
    rdfs:label 'Estimated Useful Life Years' ;
    rdfs:comment 'Expected service life of this container type in years under normal operating conditions. Used for depreciation and replacement planning.' ;
    rdfs:domain ind:ContainerType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gpsTrackingCompatibleFlag rdf:type rdf:Property ;
    rdfs:label 'Gps Tracking Compatible Flag' ;
    rdfs:comment 'Indicates whether this container type supports GPS tracking devices for real-time location monitoring.' ;
    rdfs:domain ind:ContainerType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazmatCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Certified Flag' ;
    rdfs:comment 'Indicates whether this container type is certified for hazardous waste handling per RCRA and DOT regulations.' ;
    rdfs:domain ind:ContainerType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:industrialUseFlag rdf:type rdf:Property ;
    rdfs:label 'Industrial Use Flag' ;
    rdfs:comment 'Indicates whether this container type is designed and approved for industrial facility service delivery.' ;
    rdfs:domain ind:ContainerType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leakProofFlag rdf:type rdf:Property ;
    rdfs:label 'Leak Proof Flag' ;
    rdfs:comment 'Indicates whether the container is designed with leak-proof seals and construction to prevent leachate or liquid waste escape.' ;
    rdfs:domain ind:ContainerType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:liftMechanismCompatibility rdf:type rdf:Property ;
    rdfs:label 'Lift Mechanism Compatibility' ;
    rdfs:comment 'Type of truck lift mechanism compatible with this container. ASL = Automated Side Loader, FEL = Front End Loader, REL = Rear End Loader. Critical for route planning and fleet assignment.' ;
    rdfs:domain ind:ContainerType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceIntervalMonths rdf:type rdf:Property ;
    rdfs:label 'Maintenance Interval Months' ;
    rdfs:comment 'Recommended preventive maintenance interval in months for this container type. Used for asset maintenance scheduling.' ;
    rdfs:domain ind:ContainerType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:materialConstruction rdf:type rdf:Property ;
    rdfs:label 'Material Construction' ;
    rdfs:comment 'Primary material used in container construction. Impacts durability, weight, and lifecycle cost.' ;
    rdfs:domain ind:ContainerType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Purchase Eligible Flag' ;
    rdfs:comment 'Indicates whether this container type is available for customer purchase rather than rental or service-included provision.' ;
    rdfs:domain ind:ContainerType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rentalEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Rental Eligible Flag' ;
    rdfs:comment 'Indicates whether this container type is available for temporary rental services (e.g., roll-off rentals for construction projects).' ;
    rdfs:domain ind:ContainerType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:residentialUseFlag rdf:type rdf:Property ;
    rdfs:label 'Residential Use Flag' ;
    rdfs:comment 'Indicates whether this container type is designed and approved for residential service delivery.' ;
    rdfs:domain ind:ContainerType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rfidCompatibleFlag rdf:type rdf:Property ;
    rdfs:label 'Rfid Compatible Flag' ;
    rdfs:comment 'Indicates whether this container type is designed to accommodate RFID tags for automated tracking and identification.' ;
    rdfs:domain ind:ContainerType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceFrequencyDefault rdf:type rdf:Property ;
    rdfs:label 'Service Frequency Default' ;
    rdfs:comment 'Default collection frequency typically associated with this container type. Used for service planning and contract setup.' ;
    rdfs:domain ind:ContainerType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standardUnitCost rdf:type rdf:Property ;
    rdfs:label 'Standard Unit Cost' ;
    rdfs:comment 'Standard acquisition or replacement cost per unit for this container type. Used for asset valuation and capital planning.' ;
    rdfs:domain ind:ContainerType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unPackagingCode rdf:type rdf:Property ;
    rdfs:label 'Un Packaging Code' ;
    rdfs:comment 'UN packaging identification code for hazmat-certified containers (e.g., 1A1 for steel drums). Null for non-hazmat containers.' ;
    rdfs:domain ind:ContainerType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weatherResistantFlag rdf:type rdf:Property ;
    rdfs:label 'Weather Resistant Flag' ;
    rdfs:comment 'Indicates whether the container is designed to withstand outdoor weather conditions including rain, snow, UV exposure, and temperature extremes.' ;
    rdfs:domain ind:ContainerType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:weightCapacityLbs rdf:type rdf:Property ;
    rdfs:label 'Weight Capacity Lbs' ;
    rdfs:comment 'Maximum safe working load capacity of the container in pounds. Critical for DOT compliance and fleet safety.' ;
    rdfs:domain ind:ContainerType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wheelConfiguration rdf:type rdf:Property ;
    rdfs:label 'Wheel Configuration' ;
    rdfs:comment 'Wheel configuration for container mobility. Relevant for residential carts and smaller commercial bins.' ;
    rdfs:domain ind:ContainerType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:extraPickupAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Extra Pickup Allowed Flag' ;
    rdfs:comment 'Indicates whether customers can request additional pickups beyond the standard frequency under this plan. True if extra pickups are permitted (typically with additional charges), False otherwise.' ;
    rdfs:domain ind:FrequencyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:frequencyPlanStatus rdf:type rdf:Property ;
    rdfs:label 'Frequency Plan Status' ;
    rdfs:comment 'Current lifecycle status of the frequency plan: active (available for new contracts), inactive (not available but existing contracts continue), deprecated (being phased out), pending approval (awaiting management approval), or suspended (temporarily unavailable).' ;
    rdfs:domain ind:FrequencyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frequencyType rdf:type rdf:Property ;
    rdfs:label 'Frequency Type' ;
    rdfs:comment 'The base frequency pattern for service pickups: daily, weekly, bi-weekly (every two weeks), monthly, on-call (customer-initiated), or event-based (scheduled events).' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fridayServiceFlag rdf:type rdf:Property ;
    rdfs:label 'Friday Service Flag' ;
    rdfs:comment 'Indicates whether this frequency plan includes service pickups on Fridays. True if Friday is an eligible service day, False otherwise.' ;
    rdfs:domain ind:FrequencyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:holidayAdjustmentRule rdf:type rdf:Property ;
    rdfs:label 'Holiday Adjustment Rule' ;
    rdfs:comment 'Defines how service is adjusted when a scheduled pickup falls on a recognized holiday: no service provided, shifted to next business day, shifted to prior business day, service on same day regardless, or customer chooses adjustment method.' ;
    rdfs:domain ind:FrequencyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumCommitmentPeriod rdf:type rdf:Property ;
    rdfs:label 'Maximum Commitment Period' ;
    rdfs:comment 'The maximum number of months a customer can commit to this frequency plan in a single contract term. Null indicates no maximum limit.' ;
    rdfs:domain ind:FrequencyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maximumSkipsPerYear rdf:type rdf:Property ;
    rdfs:label 'Maximum Skips Per Year' ;
    rdfs:comment 'The maximum number of scheduled pickups a customer can skip in a 12-month period under this frequency plan. Null indicates no limit or skip_allowed_flag is False.' ;
    rdfs:domain ind:FrequencyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumCommitmentPeriod rdf:type rdf:Property ;
    rdfs:label 'Minimum Commitment Period' ;
    rdfs:comment 'The minimum number of months a customer must commit to this frequency plan when entering a service contract. Used for contract term enforcement and early termination calculations.' ;
    rdfs:domain ind:FrequencyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mondayServiceFlag rdf:type rdf:Property ;
    rdfs:label 'Monday Service Flag' ;
    rdfs:comment 'Indicates whether this frequency plan includes service pickups on Mondays. True if Monday is an eligible service day, False otherwise.' ;
    rdfs:domain ind:FrequencyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:periodUnit rdf:type rdf:Property ;
    rdfs:label 'Period Unit' ;
    rdfs:comment 'The time unit that defines the frequency period: day, week, month, quarter, or year. Used in conjunction with pickups_per_period to calculate service frequency.' ;
    rdfs:domain ind:FrequencyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickupsPerPeriod rdf:type rdf:Property ;
    rdfs:label 'Pickups Per Period' ;
    rdfs:comment 'The number of pickups scheduled within the defined frequency period. For weekly service this is typically 1, for bi-weekly this is 1 per two-week period, for daily this is 5-7 depending on operating days.' ;
    rdfs:domain ind:FrequencyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:planCode rdf:type rdf:Property ;
    rdfs:label 'Plan Code' ;
    rdfs:comment 'Business identifier code for the frequency plan used in billing, contracts, and operational systems. Externally visible unique code.' ;
    rdfs:domain ind:FrequencyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planDescription rdf:type rdf:Property ;
    rdfs:label 'Plan Description' ;
    rdfs:comment 'Detailed description of the frequency plan including service scope, pickup schedule details, and any special conditions or restrictions.' ;
    rdfs:domain ind:FrequencyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prorationAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Proration Allowed Flag' ;
    rdfs:comment 'Indicates whether billing can be prorated for partial periods when service starts or ends mid-cycle. True if proration is allowed, False if full-period billing applies.' ;
    rdfs:domain ind:FrequencyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:saturdayServiceFlag rdf:type rdf:Property ;
    rdfs:label 'Saturday Service Flag' ;
    rdfs:comment 'Indicates whether this frequency plan includes service pickups on Saturdays. True if Saturday is an eligible service day, False otherwise.' ;
    rdfs:domain ind:FrequencyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:skipAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Skip Allowed Flag' ;
    rdfs:comment 'Indicates whether customers can request to skip scheduled pickups under this frequency plan (e.g., for vacation holds). True if skips are permitted, False otherwise.' ;
    rdfs:domain ind:FrequencyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sundayServiceFlag rdf:type rdf:Property ;
    rdfs:label 'Sunday Service Flag' ;
    rdfs:comment 'Indicates whether this frequency plan includes service pickups on Sundays. True if Sunday is an eligible service day, False otherwise.' ;
    rdfs:domain ind:FrequencyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:thursdayServiceFlag rdf:type rdf:Property ;
    rdfs:label 'Thursday Service Flag' ;
    rdfs:comment 'Indicates whether this frequency plan includes service pickups on Thursdays. True if Thursday is an eligible service day, False otherwise.' ;
    rdfs:domain ind:FrequencyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tuesdayServiceFlag rdf:type rdf:Property ;
    rdfs:label 'Tuesday Service Flag' ;
    rdfs:comment 'Indicates whether this frequency plan includes service pickups on Tuesdays. True if Tuesday is an eligible service day, False otherwise.' ;
    rdfs:domain ind:FrequencyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:wednesdayServiceFlag rdf:type rdf:Property ;
    rdfs:label 'Wednesday Service Flag' ;
    rdfs:comment 'Indicates whether this frequency plan includes service pickups on Wednesdays. True if Wednesday is an eligible service day, False otherwise.' ;
    rdfs:domain ind:FrequencyPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:supersededByScheduleServiceRateScheduleId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Schedule Service Rate Schedule Id' ;
    rdfs:comment 'Reference to the newer rate schedule that replaces this one. Null if this is the current active version.' ;
    rdfs:domain ind:ServiceRateSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceRateSchedule .

ind:baseRateUnit rdf:type rdf:Property ;
    rdfs:label 'Base Rate Unit' ;
    rdfs:comment 'Unit of measure for the base rate amount. Defines how the service is priced (monthly subscription, per-pickup, tonnage-based, volume-based). [ENUM-REF-CANDIDATE: per_month|per_pickup|per_ton|per_yard|per_gallon|per_event|per_container — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ServiceRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contaminationThresholdPercentage rdf:type rdf:Property ;
    rdfs:label 'Contamination Threshold Percentage' ;
    rdfs:comment 'Maximum allowable contamination percentage in recycling or waste stream before contamination surcharge applies. Typically 5-10% for recycling programs.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:environmentalFeeMethod rdf:type rdf:Property ;
    rdfs:label 'Environmental Fee Method' ;
    rdfs:comment 'Method used to calculate environmental recovery fee component. Fixed amount or percentage of base rate.' ;
    rdfs:domain ind:ServiceRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalRecoveryFee rdf:type rdf:Property ;
    rdfs:label 'Environmental Recovery Fee' ;
    rdfs:comment 'Fee charged to recover costs of environmental compliance, monitoring, and sustainability programs. May be fixed or calculated as percentage of base rate.' ;
    rdfs:domain ind:ServiceRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelIndexAdjustmentRate rdf:type rdf:Property ;
    rdfs:label 'Fuel Index Adjustment Rate' ;
    rdfs:comment 'Rate multiplier applied to the difference between current DOE diesel price and threshold to calculate surcharge. Used when fuel_surcharge_method is index_linked.' ;
    rdfs:domain ind:ServiceRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelIndexThreshold rdf:type rdf:Property ;
    rdfs:label 'Fuel Index Threshold' ;
    rdfs:comment 'DOE diesel price per gallon threshold above which index-linked fuel surcharge applies. Used when fuel_surcharge_method is index_linked.' ;
    rdfs:domain ind:ServiceRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelSurchargeBaseAmount rdf:type rdf:Property ;
    rdfs:label 'Fuel Surcharge Base Amount' ;
    rdfs:comment 'Fixed fuel surcharge amount when method is fixed_amount, or base amount for percentage calculation. Null when method is index_linked or none.' ;
    rdfs:domain ind:ServiceRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelSurchargeMethod rdf:type rdf:Property ;
    rdfs:label 'Fuel Surcharge Method' ;
    rdfs:comment 'Method used to calculate fuel surcharge component. Index-linked typically references DOE diesel price index with threshold and adjustment formula.' ;
    rdfs:domain ind:ServiceRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelSurchargePercentage rdf:type rdf:Property ;
    rdfs:label 'Fuel Surcharge Percentage' ;
    rdfs:comment 'Percentage of base rate applied as fuel surcharge when method is percentage. Null for other methods.' ;
    rdfs:domain ind:ServiceRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumServiceCharge rdf:type rdf:Property ;
    rdfs:label 'Minimum Service Charge' ;
    rdfs:comment 'Minimum monthly or per-service charge regardless of usage or volume. Ensures cost recovery for low-volume customers.' ;
    rdfs:domain ind:ServiceRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overweightFee rdf:type rdf:Property ;
    rdfs:label 'Overweight Fee' ;
    rdfs:comment 'Fee charged per unit (ton or pound) when container or load weight exceeds the standard weight limit included in base rate.' ;
    rdfs:domain ind:ServiceRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateScheduleCode rdf:type rdf:Property ;
    rdfs:label 'Rate Schedule Code' ;
    rdfs:comment 'Unique business identifier for the rate schedule used in billing systems and customer contracts. Typically follows format SERVICE-SEGMENT-GEO-VERSION.' ;
    rdfs:domain ind:ServiceRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateScheduleName rdf:type rdf:Property ;
    rdfs:label 'Rate Schedule Name' ;
    rdfs:comment 'Human-readable descriptive name of the rate schedule for business user identification and reporting purposes.' ;
    rdfs:domain ind:ServiceRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateScheduleStatus rdf:type rdf:Property ;
    rdfs:label 'Rate Schedule Status' ;
    rdfs:comment 'Current lifecycle status of the rate schedule. Active schedules are available for new contracts; expired or superseded schedules are retained for historical billing.' ;
    rdfs:domain ind:ServiceRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateVersion rdf:type rdf:Property ;
    rdfs:label 'Rate Version' ;
    rdfs:comment 'Version number for this rate schedule. Increments with each revision to support time-bound rate versioning for annual adjustments.' ;
    rdfs:domain ind:ServiceRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryComplianceFee rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Fee' ;
    rdfs:comment 'Fee charged to cover costs of regulatory compliance including RCRA, CERCLA, state and local permit requirements, and reporting obligations.' ;
    rdfs:domain ind:ServiceRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:salesTaxRate rdf:type rdf:Property ;
    rdfs:label 'Sales Tax Rate' ;
    rdfs:comment 'Applicable sales tax rate as decimal for this service area and customer segment. Null if tax_inclusive_flag is true or service is tax-exempt.' ;
    rdfs:domain ind:ServiceRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardWeightLimit rdf:type rdf:Property ;
    rdfs:label 'Standard Weight Limit' ;
    rdfs:comment 'Maximum weight in tons or pounds included in the base rate before overweight fees apply. Varies by service type and container size.' ;
    rdfs:domain ind:ServiceRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxInclusiveFlag rdf:type rdf:Property ;
    rdfs:label 'Tax Inclusive Flag' ;
    rdfs:comment 'Indicates whether the base rate and fees include applicable taxes (true) or taxes are calculated separately (false).' ;
    rdfs:domain ind:ServiceRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tippingFeeMethod rdf:type rdf:Property ;
    rdfs:label 'Tipping Fee Method' ;
    rdfs:comment 'Method for calculating and applying tipping fee charges. Fixed per ton, actual cost pass-through, included in base rate, or not applicable.' ;
    rdfs:domain ind:ServiceRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tippingFeePassthrough rdf:type rdf:Property ;
    rdfs:label 'Tipping Fee Passthrough' ;
    rdfs:comment 'Landfill or disposal facility tipping fee per ton passed through to customer. Reflects actual disposal costs at destination facility.' ;
    rdfs:domain ind:ServiceRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightUnit rdf:type rdf:Property ;
    rdfs:label 'Weight Unit' ;
    rdfs:comment 'Unit of measure for weight-based pricing components including standard weight limit and overweight fees.' ;
    rdfs:domain ind:ServiceRateSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:basePrice rdf:type rdf:Property ;
    rdfs:label 'Base Price' ;
    rdfs:comment 'Base price of the service bundle before any discounts, surcharges, or taxes. Expressed in USD.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bundleCategory rdf:type rdf:Property ;
    rdfs:label 'Bundle Category' ;
    rdfs:comment 'Primary service category that the bundle addresses (collection-only, recycling-focused, comprehensive waste management, etc.).' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundleCode rdf:type rdf:Property ;
    rdfs:label 'Bundle Code' ;
    rdfs:comment 'Externally-known unique code for the service bundle used in contracts, billing, and customer communications.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundleDescription rdf:type rdf:Property ;
    rdfs:label 'Bundle Description' ;
    rdfs:comment 'Detailed description of the service bundle, including what services are included and the value proposition for customers.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundleName rdf:type rdf:Property ;
    rdfs:label 'Bundle Name' ;
    rdfs:comment 'Human-readable name of the service bundle (e.g., \'Residential Complete Care Package\', \'Commercial Waste & Recycling Bundle\').' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundleType rdf:type rdf:Property ;
    rdfs:label 'Bundle Type' ;
    rdfs:comment 'Classification of the service bundle by customer segment and offering type.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:earlyTerminationFee rdf:type rdf:Property ;
    rdfs:label 'Early Termination Fee' ;
    rdfs:comment 'Fee charged if the customer terminates the bundle contract before the minimum term expires. Null if no early termination fee applies. Expressed in USD.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eligibilityCriteria rdf:type rdf:Property ;
    rdfs:label 'Eligibility Criteria' ;
    rdfs:comment 'Business rules defining which customers are eligible to purchase this bundle (e.g., \'Residential customers in service zones A-D\', \'Commercial accounts with minimum 2-yard container\').' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ghgReductionCo2eTons rdf:type rdf:Property ;
    rdfs:label 'Ghg Reduction Co2e Tons' ;
    rdfs:comment 'Estimated annual greenhouse gas reduction in CO2e tons achieved by customers using this bundle (e.g., through recycling diversion, waste-to-energy conversion). Null if not applicable.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marketingCampaignCode rdf:type rdf:Property ;
    rdfs:label 'Marketing Campaign Code' ;
    rdfs:comment 'Code identifying the marketing campaign associated with this bundle. Null if not part of a specific campaign.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productManagerName rdf:type rdf:Property ;
    rdfs:label 'Product Manager Name' ;
    rdfs:comment 'Name of the product manager responsible for this service bundle.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionEndDate rdf:type rdf:Property ;
    rdfs:label 'Promotion End Date' ;
    rdfs:comment 'Date when the promotional bundle is no longer available for new sales. Null if not a promotional bundle or if open-ended.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:promotionStartDate rdf:type rdf:Property ;
    rdfs:label 'Promotion Start Date' ;
    rdfs:comment 'Date when the promotional bundle becomes available for sale. Null if not a promotional bundle.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:promotionalFlag rdf:type rdf:Property ;
    rdfs:label 'Promotional Flag' ;
    rdfs:comment 'Indicates whether this bundle is a limited-time promotional offering (True) or a standard catalog offering (False).' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryComplianceNotes rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Notes' ;
    rdfs:comment 'Notes on regulatory compliance requirements or certifications associated with this bundle (e.g., RCRA compliance for hazardous waste components, EPA reporting requirements).' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Sustainability Certified Flag' ;
    rdfs:comment 'Indicates whether this bundle includes sustainability-certified services (e.g., carbon-neutral collection, renewable natural gas fleet, zero-waste-to-landfill programs).' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:acceptedContainerTypes rdf:type rdf:Property ;
    rdfs:label 'Accepted Container Types' ;
    rdfs:comment 'Comma-separated list of container types (Container Identification - CID codes) that are approved for this waste stream (e.g., 96-GAL-CART, 2-YD-DUMPSTER, 20-YD-ROLLOFF, COMPACTOR). References container master data.' ;
    rdfs:domain ind:WasteStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commodityValueFlag rdf:type rdf:Property ;
    rdfs:label 'Commodity Value Flag' ;
    rdfs:comment 'Indicates whether this waste stream has commodity market value (True) or represents a disposal cost (False). Applies to recyclable materials with resale value (paper, metal, plastic).' ;
    rdfs:domain ind:WasteStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:compactionRatioAvg rdf:type rdf:Property ;
    rdfs:label 'Compaction Ratio Avg' ;
    rdfs:comment 'Average compaction ratio (volume reduction factor) for this waste stream when compacted in collection vehicles or at disposal facilities. Used for capacity planning and route optimization.' ;
    rdfs:domain ind:WasteStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compostableFlag rdf:type rdf:Property ;
    rdfs:label 'Compostable Flag' ;
    rdfs:comment 'Indicates whether this waste stream is suitable for composting operations (True) or not (False). Applies to organic waste, food waste, and yard waste streams.' ;
    rdfs:domain ind:WasteStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:densityLbsPerCubicYard rdf:type rdf:Property ;
    rdfs:label 'Density Lbs Per Cubic Yard' ;
    rdfs:comment 'Average density of this waste stream measured in pounds per cubic yard. Used for weight estimation, capacity planning, and tipping fee calculations.' ;
    rdfs:domain ind:WasteStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disposalPathway rdf:type rdf:Property ;
    rdfs:label 'Disposal Pathway' ;
    rdfs:comment 'Primary disposal or processing pathway for this waste stream: Landfill, Materials Recovery Facility (MRF), Waste-to-Energy (WTE), Treatment Storage and Disposal Facility (TSDF), Composting, or Recycling.' ;
    rdfs:domain ind:WasteStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diversionCreditPercentage rdf:type rdf:Property ;
    rdfs:label 'Diversion Credit Percentage' ;
    rdfs:comment 'Percentage of this waste stream that counts toward landfill diversion rate calculations (0-100%). Reflects the portion that is recycled, composted, or converted to energy rather than landfilled.' ;
    rdfs:domain ind:WasteStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ghgEmissionFactorCo2ePerTon rdf:type rdf:Property ;
    rdfs:label 'Ghg Emission Factor Co2e Per Ton' ;
    rdfs:comment 'Greenhouse Gas (GHG) emission factor for this waste stream expressed as kilograms of Carbon Dioxide Equivalent (CO2e) per ton of waste. Used for sustainability reporting and carbon footprint calculations.' ;
    rdfs:domain ind:WasteStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rcraSubtitle rdf:type rdf:Property ;
    rdfs:label 'Rcra Subtitle' ;
    rdfs:comment 'RCRA subtitle classification: C for hazardous waste, D for non-hazardous solid waste, N/A for streams not regulated under RCRA.' ;
    rdfs:domain ind:WasteStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recyclableFlag rdf:type rdf:Property ;
    rdfs:label 'Recyclable Flag' ;
    rdfs:comment 'Indicates whether this waste stream contains recyclable materials (True) or is non-recyclable (False). Drives routing to MRF facilities and recycling programs.' ;
    rdfs:domain ind:WasteStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryNotes rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notes' ;
    rdfs:comment 'Free-text field capturing additional regulatory requirements, restrictions, or compliance notes specific to this waste stream (e.g., state-specific handling requirements, permit conditions, reporting obligations).' ;
    rdfs:domain ind:WasteStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonalVariationFlag rdf:type rdf:Property ;
    rdfs:label 'Seasonal Variation Flag' ;
    rdfs:comment 'Indicates whether this waste stream exhibits significant seasonal volume variations (True) or has consistent year-round volumes (False). Examples include yard waste (seasonal) and MSW (consistent).' ;
    rdfs:domain ind:WasteStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specialHandlingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Special Handling Required Flag' ;
    rdfs:comment 'Indicates whether this waste stream requires special handling procedures, equipment, or certifications (True) or can be handled through standard collection processes (False).' ;
    rdfs:domain ind:WasteStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:wasteStreamCategory rdf:type rdf:Property ;
    rdfs:label 'Waste Stream Category' ;
    rdfs:comment 'High-level classification of the waste stream: Municipal Solid Waste (MSW), Construction and Demolition (C&D), Recyclable, Organic, Hazardous, Universal Waste, or Electronic Waste (E-Waste). [ENUM-REF-CANDIDATE: MSW|C&D|Recyclable|Organic|Hazardous|Universal|E-Waste — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WasteStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteStreamCode rdf:type rdf:Property ;
    rdfs:label 'Waste Stream Code' ;
    rdfs:comment 'Business identifier code for the waste stream type (e.g., MSW-001, CD-002, RCY-PLT-01). Used across operational systems for waste classification.' ;
    rdfs:domain ind:WasteStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteStreamName rdf:type rdf:Property ;
    rdfs:label 'Waste Stream Name' ;
    rdfs:comment 'Full descriptive name of the waste stream (e.g., Municipal Solid Waste, Construction and Demolition Debris, Mixed Recyclables).' ;
    rdfs:domain ind:WasteStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wasteStreamStatus rdf:type rdf:Property ;
    rdfs:label 'Waste Stream Status' ;
    rdfs:comment 'Current operational status of this waste stream classification: Active (currently accepted), Inactive (temporarily not accepted), Restricted (accepted with limitations), or Phased Out (no longer accepted).' ;
    rdfs:domain ind:WasteStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wteFeedstockFlag rdf:type rdf:Property ;
    rdfs:label 'Wte Feedstock Flag' ;
    rdfs:comment 'Indicates whether this waste stream is acceptable as feedstock for Waste-to-Energy (WTE) or Solid Recovered Fuel (SRF) conversion processes (True) or not (False).' ;
    rdfs:domain ind:WasteStream ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:franchisePermitId rdf:type rdf:Property ;
    rdfs:label 'Franchise Permit Id' ;
    rdfs:comment 'Foreign key linking to compliance.permit. Business justification: Service areas operate under municipal franchise agreements that are formalized as permits. Franchise permit defines service obligations, rate structures, performance standards, and geographic boundari' ;
    rdfs:domain ind:Service ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Permit .

ind:primaryLandfillFacilityId rdf:type rdf:Property ;
    rdfs:label 'Primary Landfill Facility Id' ;
    rdfs:comment 'Identifier of the primary landfill or disposal facility serving this service area. Used for haul routing and tipping fee calculation.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:primaryMrfFacilityId rdf:type rdf:Property ;
    rdfs:label 'Primary Mrf Facility Id' ;
    rdfs:comment 'Identifier of the primary MRF processing recyclable materials from this service area.' ;
    rdfs:domain ind:Area ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:territoryId rdf:type rdf:Property ;
    rdfs:label 'Territory Id' ;
    rdfs:comment 'Foreign key linking to service.service_territory. Business justification: Service_territory and service_area represent a hierarchical geographic relationship. Territories are broader planning zones (franchise boundaries, municipal contracts), while service_areas are operati' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Territory .

ind:areaCode rdf:type rdf:Property ;
    rdfs:label 'Area Code' ;
    rdfs:comment 'Business identifier code for the service area used in operational systems and customer communications. Typically follows a regional or district-based naming convention.' ;
    rdfs:domain ind:Area ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:areaName rdf:type rdf:Property ;
    rdfs:label 'Area Name' ;
    rdfs:comment 'Human-readable name of the service area, typically reflecting the municipality, county, or region served (e.g., \'Downtown Chicago\', \'Orange County North\').' ;
    rdfs:domain ind:Area ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:areaType rdf:type rdf:Property ;
    rdfs:label 'Area Type' ;
    rdfs:comment 'Classification of the service area based on the predominant customer segment and waste generation profile. Determines service offerings, equipment types, and routing strategies.' ;
    rdfs:domain ind:Area ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:censusTractList rdf:type rdf:Property ;
    rdfs:label 'Census Tract List' ;
    rdfs:comment 'Comma-separated list of U.S. Census tract identifiers covered by this service area. Used for demographic analysis and environmental justice reporting.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countyFipsCode rdf:type rdf:Property ;
    rdfs:label 'County Fips Code' ;
    rdfs:comment 'Five-digit FIPS code identifying the county in which the service area is located. Used for geographic analysis and regulatory reporting.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:franchiseAgreementNumber rdf:type rdf:Property ;
    rdfs:label 'Franchise Agreement Number' ;
    rdfs:comment 'Reference number of the franchise or municipal contract authorizing waste collection services in this area. Links to the master contract repository.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:franchiseExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Franchise Expiration Date' ;
    rdfs:comment 'Date on which the current franchise agreement expires. Critical for contract renewal planning and service continuity.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:geographicBoundaryWkt rdf:type rdf:Property ;
    rdfs:label 'Geographic Boundary Wkt' ;
    rdfs:comment 'Well-Known Text representation of the service area polygon boundary. Used for GIS mapping, route optimization, and spatial eligibility checks.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gpsTrackingRequired rdf:type rdf:Property ;
    rdfs:label 'Gps Tracking Required' ;
    rdfs:comment 'Indicates whether GPS tracking is mandated for all collection vehicles operating in this service area (may be required by franchise agreement).' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazmatCollectionAvailable rdf:type rdf:Property ;
    rdfs:label 'Hazmat Collection Available' ;
    rdfs:comment 'Indicates whether hazardous waste collection events or services are offered in this service area.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:householdCountEstimate rdf:type rdf:Property ;
    rdfs:label 'Household Count Estimate' ;
    rdfs:comment 'Estimated number of residential households in the service area. Key metric for residential service planning and revenue forecasting.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:leaAgencyName rdf:type rdf:Property ;
    rdfs:label 'Lea Agency Name' ;
    rdfs:comment 'Name of the Local Enforcement Agency responsible for solid waste compliance oversight in this service area.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organicsProgramAvailable rdf:type rdf:Property ;
    rdfs:label 'Organics Program Available' ;
    rdfs:comment 'Indicates whether organic waste collection (yard waste, food scraps) is available in this service area.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:populationEstimate rdf:type rdf:Property ;
    rdfs:label 'Population Estimate' ;
    rdfs:comment 'Estimated total population residing within the service area boundaries. Used for capacity planning and market analysis.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recyclingProgramAvailable rdf:type rdf:Property ;
    rdfs:label 'Recycling Program Available' ;
    rdfs:comment 'Indicates whether curbside recycling services are available to customers in this service area.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:routeOptimizationEnabled rdf:type rdf:Property ;
    rdfs:label 'Route Optimization Enabled' ;
    rdfs:comment 'Indicates whether automated route optimization algorithms are applied to collection routes in this service area.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceFrequencyResidential rdf:type rdf:Property ;
    rdfs:label 'Service Frequency Residential' ;
    rdfs:comment 'Standard collection frequency for residential customers in this service area. Determines route scheduling and capacity requirements.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:squareMiles rdf:type rdf:Property ;
    rdfs:label 'Square Miles' ;
    rdfs:comment 'Total geographic area covered by this service area in square miles. Used for density analysis and resource planning.' ;
    rdfs:domain ind:Area ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:updatedByUser rdf:type rdf:Property ;
    rdfs:label 'Updated By User' ;
    rdfs:comment 'Username or identifier of the user who last modified this service area record.' ;
    rdfs:domain ind:Area ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zipCodeList rdf:type rdf:Property ;
    rdfs:label 'Zip Code List' ;
    rdfs:comment 'Comma-separated list of ZIP codes fully or partially covered by this service area. Used for customer address validation and service eligibility determination.' ;
    rdfs:domain ind:Service ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoCreditEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Credit Enabled Flag' ;
    rdfs:comment 'Indicates whether SLA breach credits are automatically applied to customer accounts (true) or require manual approval (false).' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complaintResolutionWindowHours rdf:type rdf:Property ;
    rdfs:label 'Complaint Resolution Window Hours' ;
    rdfs:comment 'Maximum time in hours to resolve a customer complaint or service issue to customer satisfaction.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:containerDeliveryLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Container Delivery Lead Time Days' ;
    rdfs:comment 'Maximum number of business days to deliver a container after order placement (e.g., 2 days for roll-off, 1 day for commercial dumpster).' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:containerPickupLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Container Pickup Lead Time Days' ;
    rdfs:comment 'Maximum number of business days to pick up a container after customer request (e.g., 1 day for standard service, same-day for premium).' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:escalationThresholdHours rdf:type rdf:Property ;
    rdfs:label 'Escalation Threshold Hours' ;
    rdfs:comment 'Time in hours after which an unresolved service issue is automatically escalated to management or specialized team.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lateDeliveryPenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Late Delivery Penalty Amount' ;
    rdfs:comment 'Fixed dollar amount credited or refunded for late container delivery beyond committed lead time.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lateDeliveryPenaltyPct rdf:type rdf:Property ;
    rdfs:label 'Late Delivery Penalty Pct' ;
    rdfs:comment 'Percentage of service charge credited or refunded for late container delivery beyond committed lead time.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementMethod rdf:type rdf:Property ;
    rdfs:label 'Measurement Method' ;
    rdfs:comment 'Description of how SLA compliance is measured and calculated (e.g., GPS timestamp validation, driver confirmation, customer acknowledgment).' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:missedPickupCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Missed Pickup Credit Amount' ;
    rdfs:comment 'Fixed dollar amount credited to customer account for each missed pickup that breaches SLA.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:missedPickupCreditPct rdf:type rdf:Property ;
    rdfs:label 'Missed Pickup Credit Pct' ;
    rdfs:comment 'Percentage of service charge credited to customer account for each missed pickup that breaches SLA (alternative to fixed amount).' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:notificationEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Notification Enabled Flag' ;
    rdfs:comment 'Indicates whether customers receive automated notifications for SLA breaches or service delays (true/false).' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:onTimeServiceRateTargetPct rdf:type rdf:Property ;
    rdfs:label 'On Time Service Rate Target Pct' ;
    rdfs:comment 'Target percentage for on-time service delivery (e.g., 98.5% for premium tier). Measured as percentage of scheduled pickups completed within service window.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:resolutionTimeHours rdf:type rdf:Property ;
    rdfs:label 'Resolution Time Hours' ;
    rdfs:comment 'Maximum time in hours to resolve a service issue or complaint (e.g., 48 hours for missed pickup resolution).' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceWindowToleranceMinutes rdf:type rdf:Property ;
    rdfs:label 'Service Window Tolerance Minutes' ;
    rdfs:comment 'Allowable grace period in minutes beyond the service window end time before SLA breach is recorded (e.g., 30 minutes).' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaCode rdf:type rdf:Property ;
    rdfs:label 'Sla Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the SLA definition for system integration and reporting.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaDefinitionDescription rdf:type rdf:Property ;
    rdfs:label 'Sla Definition Description' ;
    rdfs:comment 'Detailed description of the SLA terms, commitments, and conditions. Includes any special provisions or exclusions.' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaDefinitionStatus rdf:type rdf:Property ;
    rdfs:label 'Sla Definition Status' ;
    rdfs:comment 'Current lifecycle status of the SLA definition (active, inactive, draft, retired).' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaName rdf:type rdf:Property ;
    rdfs:label 'Sla Name' ;
    rdfs:comment 'Business-friendly name of the SLA definition (e.g., \'Standard Residential Pickup SLA\', \'Premium Commercial Service SLA\').' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaType rdf:type rdf:Property ;
    rdfs:label 'Sla Type' ;
    rdfs:comment 'Classification of the SLA tier (standard, premium, enterprise, custom).' ;
    rdfs:domain ind:SlaDefinition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceOfficerEmail rdf:type rdf:Property ;
    rdfs:label 'Compliance Officer Email' ;
    rdfs:comment 'Email address of the compliance officer responsible for this permit. Used for regulatory correspondence and internal compliance tracking.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceOfficerName rdf:type rdf:Property ;
    rdfs:label 'Compliance Officer Name' ;
    rdfs:comment 'Name of the Waste Management employee responsible for ensuring compliance with this permit. Primary point of contact for regulatory agency communications.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceOfficerPhone rdf:type rdf:Property ;
    rdfs:label 'Compliance Officer Phone' ;
    rdfs:comment 'Phone number of the compliance officer responsible for this permit. Enables direct communication with the regulatory agency and internal stakeholders.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditions rdf:type rdf:Property ;
    rdfs:label 'Conditions' ;
    rdfs:comment 'Specific conditions, limitations, and operational requirements imposed by the regulatory agency as part of the permit. Includes monitoring frequencies, reporting obligations, and operational constraints.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialAssuranceType rdf:type rdf:Property ;
    rdfs:label 'Financial Assurance Type' ;
    rdfs:comment 'Type of financial assurance instrument used to meet the permit requirement. Determines the mechanism by which closure and post-closure funds are secured.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionFrequency rdf:type rdf:Property ;
    rdfs:label 'Inspection Frequency' ;
    rdfs:comment 'Frequency at which the regulatory agency conducts inspections of the permitted facility. Determines the cadence of regulatory oversight and compliance verification.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingAgencyJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Issuing Agency Jurisdiction' ;
    rdfs:comment 'Jurisdictional level of the issuing regulatory agency. Determines the hierarchy of regulatory oversight and appeal processes.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastViolationDate rdf:type rdf:Property ;
    rdfs:label 'Last Violation Date' ;
    rdfs:comment 'Date of the most recent violation or notice of non-compliance issued against this permit. Nullable if no violations have occurred.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:monitoringRequirements rdf:type rdf:Property ;
    rdfs:label 'Monitoring Requirements' ;
    rdfs:comment 'Description of the environmental monitoring and testing requirements mandated by the permit. Includes parameters to be monitored, sampling frequencies, and analytical methods.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Next Inspection Date' ;
    rdfs:comment 'Anticipated date of the next regulatory inspection. May be scheduled by the agency or estimated based on historical inspection frequency.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:permitStatus rdf:type rdf:Property ;
    rdfs:label 'Permit Status' ;
    rdfs:comment 'Current lifecycle status of the permit. Indicates whether the permit is in force, awaiting approval, or has been terminated or suspended by the regulatory authority.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitTier rdf:type rdf:Property ;
    rdfs:label 'Permit Tier' ;
    rdfs:comment 'Regulatory classification of the permit based on the scale and environmental impact of the permitted activities. Major permits typically require more stringent monitoring and reporting.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitType rdf:type rdf:Property ;
    rdfs:label 'Permit Type' ;
    rdfs:comment 'Classification of the permit based on the environmental or operational domain it regulates. Determines applicable regulatory framework and compliance requirements.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permittedActivities rdf:type rdf:Property ;
    rdfs:label 'Permitted Activities' ;
    rdfs:comment 'Detailed description of the activities authorized under this permit. May include waste acceptance types, treatment processes, discharge points, emission sources, or operational constraints.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permittedCapacity rdf:type rdf:Property ;
    rdfs:label 'Permitted Capacity' ;
    rdfs:comment 'Maximum operational capacity authorized by the permit. Units vary by permit type: TPD (Tons Per Day) for waste facilities, gallons per day for water discharge, tons per year for air emissions.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:publicNoticeDate rdf:type rdf:Property ;
    rdfs:label 'Public Notice Date' ;
    rdfs:comment 'Date on which public notice of the permit action was published. Marks the start of the public comment period.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:publicNoticeRequired rdf:type rdf:Property ;
    rdfs:label 'Public Notice Required' ;
    rdfs:comment 'Indicates whether the permit issuance, renewal, or modification requires public notice and comment period. Common for major permits and significant permit modifications.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryProgram rdf:type rdf:Property ;
    rdfs:label 'Regulatory Program' ;
    rdfs:comment 'Name of the specific regulatory program under which the permit is issued. Examples include RCRA Subtitle C, RCRA Subtitle D, Title V Operating Permit, NPDES, or state-specific programs.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalDueDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Due Date' ;
    rdfs:comment 'Date by which the permit renewal application must be submitted to the regulatory agency to avoid lapse of authorization. Typically set months in advance of the expiration date.' ;
    rdfs:domain ind:Permit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:averagingPeriod rdf:type rdf:Property ;
    rdfs:label 'Averaging Period' ;
    rdfs:comment 'The time period over which the limit is calculated or averaged (e.g., hourly, daily, monthly, annual, 30-day rolling). Null for instantaneous limits.' ;
    rdfs:domain ind:PermitCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceSchedule rdf:type rdf:Property ;
    rdfs:label 'Compliance Schedule' ;
    rdfs:comment 'Description of any phased compliance schedule or milestone dates specified in the condition (e.g., interim limits, construction deadlines, operational milestones).' ;
    rdfs:domain ind:PermitCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionCategory rdf:type rdf:Property ;
    rdfs:label 'Condition Category' ;
    rdfs:comment 'Broad environmental or operational category to which the condition applies. Used for grouping and reporting. [ENUM-REF-CANDIDATE: air_quality|water_quality|waste_management|hazardous_materials|noise|odor|safety|operational|administrative — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PermitCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionDescription rdf:type rdf:Property ;
    rdfs:label 'Condition Description' ;
    rdfs:comment 'Full text description of the permit condition as written in the permit document. Specifies the enforceable requirement in detail.' ;
    rdfs:domain ind:PermitCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionNumber rdf:type rdf:Property ;
    rdfs:label 'Condition Number' ;
    rdfs:comment 'The official condition number or identifier as specified in the permit document. Used for regulatory citation and tracking.' ;
    rdfs:domain ind:PermitCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionType rdf:type rdf:Property ;
    rdfs:label 'Condition Type' ;
    rdfs:comment 'Classification of the permit condition by regulatory purpose. Determines the nature of the enforceable requirement. [ENUM-REF-CANDIDATE: emission_limit|discharge_limit|operational_restriction|monitoring_requirement|reporting_requirement|compliance_schedule|record_keeping|best_management_practice — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PermitCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviationThreshold rdf:type rdf:Property ;
    rdfs:label 'Deviation Threshold' ;
    rdfs:comment 'The numeric threshold at which a deviation or exceedance must be reported or triggers corrective action. May differ from the limit_value.' ;
    rdfs:domain ind:PermitCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deviationThresholdUnit rdf:type rdf:Property ;
    rdfs:label 'Deviation Threshold Unit' ;
    rdfs:comment 'Unit of measure for the deviation threshold. Required when deviation_threshold is populated.' ;
    rdfs:domain ind:PermitCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enforcementPriority rdf:type rdf:Property ;
    rdfs:label 'Enforcement Priority' ;
    rdfs:comment 'The regulatory enforcement priority level assigned to this condition. High-priority conditions receive heightened scrutiny and faster enforcement response.' ;
    rdfs:domain ind:PermitCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCritical rdf:type rdf:Property ;
    rdfs:label 'Is Critical' ;
    rdfs:comment 'Indicates whether this condition is designated as critical or high-priority for compliance tracking. Violations of critical conditions may trigger immediate enforcement action.' ;
    rdfs:domain ind:PermitCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastComplianceCheckDate rdf:type rdf:Property ;
    rdfs:label 'Last Compliance Check Date' ;
    rdfs:comment 'The date of the most recent compliance verification, monitoring event, or inspection for this condition.' ;
    rdfs:domain ind:PermitCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:limitType rdf:type rdf:Property ;
    rdfs:label 'Limit Type' ;
    rdfs:comment 'Specifies whether the limit is a maximum allowable value, minimum required value, range, or time-averaged value. Defines how compliance is measured.' ;
    rdfs:domain ind:PermitCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limitUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Limit Unit Of Measure' ;
    rdfs:comment 'The unit of measure for the limit value (e.g., ppm, mg/L, tons per day, decibels, cubic meters per hour). Required when limit_value is populated.' ;
    rdfs:domain ind:PermitCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limitValue rdf:type rdf:Property ;
    rdfs:label 'Limit Value' ;
    rdfs:comment 'The numeric threshold, limit, or target value specified in the condition (e.g., emission rate, discharge concentration, operational parameter). Null if the condition is qualitative.' ;
    rdfs:domain ind:PermitCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextComplianceCheckDate rdf:type rdf:Property ;
    rdfs:label 'Next Compliance Check Date' ;
    rdfs:comment 'The scheduled date for the next compliance verification, monitoring event, or inspection for this condition. Used for proactive compliance management.' ;
    rdfs:domain ind:PermitCondition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryCitation rdf:type rdf:Property ;
    rdfs:label 'Regulatory Citation' ;
    rdfs:comment 'The specific regulation, statute, or code section that mandates this condition (e.g., 40 CFR 258.40, Clean Air Act Section 112). Provides legal basis for enforcement.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingDeadlineDays rdf:type rdf:Property ;
    rdfs:label 'Reporting Deadline Days' ;
    rdfs:comment 'Number of days after the monitoring period or event by which the report must be submitted. Null if no specific deadline is defined.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicabilityScope rdf:type rdf:Property ;
    rdfs:label 'Applicability Scope' ;
    rdfs:comment 'Describes the scope of operations, facility types, waste streams, or activities to which this regulatory requirement applies (e.g., \'All MSW landfills\', \'Hazardous waste TSDFs\', \'Commercial vehicle operators with CDL\', \'MRF operations handling recyclables\').' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:citationNumber rdf:type rdf:Property ;
    rdfs:label 'Citation Number' ;
    rdfs:comment 'The official citation or reference number of the regulation (e.g., 40 CFR 258.40, 29 CFR 1910.120, 49 CFR 172.101). This is the externally-known unique identifier for the regulatory requirement.' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceFrequency rdf:type rdf:Property ;
    rdfs:label 'Compliance Frequency' ;
    rdfs:comment 'The frequency at which compliance with this requirement must be demonstrated or reported (e.g., Annual, Quarterly, Continuous, Event-Driven). [ENUM-REF-CANDIDATE: One-Time|Daily|Weekly|Monthly|Quarterly|Semi-Annual|Annual|Biennial|Event-Driven|Continuous — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceObligationSummary rdf:type rdf:Property ;
    rdfs:label 'Compliance Obligation Summary' ;
    rdfs:comment 'A concise summary of the key compliance obligations imposed by this requirement, written for operational and compliance teams.' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentationRequired rdf:type rdf:Property ;
    rdfs:label 'Documentation Required' ;
    rdfs:comment 'Indicates whether this requirement mandates the creation and retention of specific documentation or records (True/False).' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:facilityTypeApplicability rdf:type rdf:Property ;
    rdfs:label 'Facility Type Applicability' ;
    rdfs:comment 'The specific facility types to which this requirement applies (e.g., Landfill, MRF, Transfer Station, WTE Facility, TSDF, Fleet Maintenance Facility). Pipe-separated list if multiple types apply.' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionRequired rdf:type rdf:Property ;
    rdfs:label 'Inspection Required' ;
    rdfs:comment 'Indicates whether this requirement mandates periodic inspections by regulatory authorities or third parties (True/False).' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:internalPolicyReference rdf:type rdf:Property ;
    rdfs:label 'Internal Policy Reference' ;
    rdfs:comment 'Reference to the internal company policy, procedure, or standard operating procedure (SOP) that implements this regulatory requirement.' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isoClauseReference rdf:type rdf:Property ;
    rdfs:label 'Iso Clause Reference' ;
    rdfs:comment 'The specific ISO 14001 or ISO 45001 clause or requirement that this regulatory requirement supports or maps to, if applicable.' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdiction rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction' ;
    rdfs:comment 'The jurisdictional level at which this regulatory requirement applies (Federal, State, Local, or International).' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionGeography rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Geography' ;
    rdfs:comment 'The specific geographic area or political subdivision where this requirement applies (e.g., USA, California, Harris County). Uses 3-letter country codes for national jurisdictions.' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumPenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Penalty Amount' ;
    rdfs:comment 'The maximum monetary penalty amount (in USD) that can be assessed for a single violation of this requirement, if defined by the regulation.' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:monitoringRequired rdf:type rdf:Property ;
    rdfs:label 'Monitoring Required' ;
    rdfs:comment 'Indicates whether this requirement mandates ongoing environmental or operational monitoring (e.g., air quality, groundwater, LFG, LEL) (True/False).' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operationTypeApplicability rdf:type rdf:Property ;
    rdfs:label 'Operation Type Applicability' ;
    rdfs:comment 'The operational activities to which this requirement applies (e.g., Collection, Hauling, Processing, Disposal, Treatment, Storage, Transport). Pipe-separated list if multiple operations apply.' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltySeverity rdf:type rdf:Property ;
    rdfs:label 'Penalty Severity' ;
    rdfs:comment 'The severity classification of penalties or enforcement actions associated with non-compliance with this requirement (Low, Medium, High, Critical).' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitRequired rdf:type rdf:Property ;
    rdfs:label 'Permit Required' ;
    rdfs:comment 'Indicates whether this requirement mandates obtaining a specific permit or authorization (e.g., air permit, water discharge permit, waste handling permit) (True/False).' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulationTitle rdf:type rdf:Property ;
    rdfs:label 'Regulation Title' ;
    rdfs:comment 'The full official title or name of the regulation or regulatory requirement.' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryBody rdf:type rdf:Property ;
    rdfs:label 'Regulatory Body' ;
    rdfs:comment 'The governing body or agency that issued and enforces this regulatory requirement (e.g., EPA, OSHA, DOT, State Environmental Quality Department, Local Solid Waste Authority). [ENUM-REF-CANDIDATE: EPA|OSHA|DOT|State Environmental Agency|Local Enforcement Agency|SWANA|NWRA|ISO — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryFramework rdf:type rdf:Property ;
    rdfs:label 'Regulatory Framework' ;
    rdfs:comment 'The overarching regulatory framework or act under which this requirement falls (e.g., RCRA, CERCLA, Clean Air Act, Clean Water Act, ISO 14001, ISO 45001). [ENUM-REF-CANDIDATE: RCRA|CERCLA|CAA|CWA|TSCA|OSHA|DOT HAZMAT|ISO 14001|ISO 45001|State Solid Waste Code — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryRequirementDescription rdf:type rdf:Property ;
    rdfs:label 'Regulatory Requirement Description' ;
    rdfs:comment 'A detailed textual description of the regulatory requirement, including the specific obligations, standards, or actions mandated by the regulation.' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryRequirementStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Requirement Status' ;
    rdfs:comment 'The current lifecycle status of this regulatory requirement (Active, Proposed, Superseded, Repealed, Under Review, Pending).' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingRequired rdf:type rdf:Property ;
    rdfs:label 'Reporting Required' ;
    rdfs:comment 'Indicates whether this requirement mandates periodic or event-driven reporting to regulatory authorities (e.g., SWIS submissions, CERCLA notifications, incident reports) (True/False).' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requirementType rdf:type rdf:Property ;
    rdfs:label 'Requirement Type' ;
    rdfs:comment 'The category or type of compliance obligation imposed by this requirement (e.g., Permit, Inspection, Monitoring, Reporting, Training, Record Keeping, Operational Standard, Emission Limit). [ENUM-REF-CANDIDATE: Permit|Inspection|Monitoring|Reporting|Training|Record Keeping|Operational Standard|Design Standard|Emission Limit|Discharge Limit — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Source Document Url' ;
    rdfs:comment 'The web URL or hyperlink to the official source document or regulatory text (e.g., Federal Register, EPA website, state regulatory portal).' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingRequired rdf:type rdf:Property ;
    rdfs:label 'Training Required' ;
    rdfs:comment 'Indicates whether this requirement mandates specific training or certification for personnel (e.g., CDL, HAZWOPER, OSHA 40-hour) (True/False).' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:wasteStreamApplicability rdf:type rdf:Property ;
    rdfs:label 'Waste Stream Applicability' ;
    rdfs:comment 'The waste stream categories to which this requirement applies (e.g., MSW, C&D, Hazardous Waste, Recyclables, LFG, Leachate). Pipe-separated list if multiple streams apply.' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Inspection Date' ;
    rdfs:comment 'Date on which the inspection was actually conducted. This is the primary business event date for the inspection.' ;
    rdfs:domain ind:ComplianceInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:checklistUsed rdf:type rdf:Property ;
    rdfs:label 'Checklist Used' ;
    rdfs:comment 'Name or identifier of the standardized inspection checklist or audit protocol used during the inspection. Ensures consistency and completeness of inspection coverage.' ;
    rdfs:domain ind:ComplianceInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Critical Findings Count' ;
    rdfs:comment 'Number of findings classified as critical or high-severity, requiring immediate corrective action. Subset of total findings.' ;
    rdfs:domain ind:ComplianceInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:facilityEpaNumber rdf:type rdf:Property ;
    rdfs:label 'Facility Epa Number' ;
    rdfs:comment 'EPA-assigned unique 12-character identifier for the facility, required for RCRA-regulated facilities. Format: 2-letter state code + 9-digit number.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpDueDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Due Date' ;
    rdfs:comment 'Date by which corrective actions must be completed and documented, or by which a follow-up inspection is required. Null if no follow-up is needed.' ;
    rdfs:domain ind:ComplianceInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:frequencyRequirement rdf:type rdf:Property ;
    rdfs:label 'Frequency Requirement' ;
    rdfs:comment 'Required frequency for this type of inspection based on regulatory requirements or internal policy. Supports compliance calendar planning.' ;
    rdfs:domain ind:ComplianceInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectingAuthority rdf:type rdf:Property ;
    rdfs:label 'Inspecting Authority' ;
    rdfs:comment 'Name of the regulatory agency, local enforcement body, or designation of internal audit team conducting the inspection (e.g., U.S. EPA Region 5, California DTSC, Internal EHS Audit Team).' ;
    rdfs:domain ind:ComplianceInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iso14001Audit rdf:type rdf:Property ;
    rdfs:label 'Iso 14001 Audit' ;
    rdfs:comment 'Indicates whether this inspection was conducted as part of an ISO 14001 Environmental Management System audit or certification process.' ;
    rdfs:domain ind:ComplianceInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iso45001Audit rdf:type rdf:Property ;
    rdfs:label 'Iso 45001 Audit' ;
    rdfs:comment 'Indicates whether this inspection was conducted as part of an ISO 45001 Occupational Health and Safety Management System audit or certification process.' ;
    rdfs:domain ind:ComplianceInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:majorFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Major Findings Count' ;
    rdfs:comment 'Number of findings classified as major or medium-severity, requiring corrective action within a defined timeframe. Subset of total findings.' ;
    rdfs:domain ind:ComplianceInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minorFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Minor Findings Count' ;
    rdfs:comment 'Number of findings classified as minor or low-severity, requiring corrective action but not posing immediate risk. Subset of total findings.' ;
    rdfs:domain ind:ComplianceInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:noticeOfViolationIssued rdf:type rdf:Property ;
    rdfs:label 'Notice Of Violation Issued' ;
    rdfs:comment 'Indicates whether a formal Notice of Violation was issued by the regulatory authority as a result of the inspection findings.' ;
    rdfs:domain ind:ComplianceInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:numberOfFindings rdf:type rdf:Property ;
    rdfs:label 'Number Of Findings' ;
    rdfs:comment 'Total count of deficiencies, violations, observations, or non-conformances identified during the inspection. Zero indicates no issues found.' ;
    rdfs:domain ind:ComplianceInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reportUrl rdf:type rdf:Property ;
    rdfs:label 'Report Url' ;
    rdfs:comment 'URL or file path to the official inspection report document stored in the document management system. Provides access to the full inspection findings and recommendations.' ;
    rdfs:domain ind:ComplianceInspection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousFindingInspectionFindingId rdf:type rdf:Property ;
    rdfs:label 'Previous Finding Inspection Finding Id' ;
    rdfs:comment 'Reference to the prior finding record if this is a repeat finding. Enables tracking of recurrence patterns and corrective action effectiveness.' ;
    rdfs:domain ind:InspectionFinding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InspectionFinding .

ind:environmentalImpact rdf:type rdf:Property ;
    rdfs:label 'Environmental Impact' ;
    rdfs:comment 'Assessment of the actual or potential environmental impact of the condition identified in the finding. None indicates no environmental consequence; low indicates minimal impact; medium indicates localized impact; high indicates significant impact; severe indicates widespread or long-term environmental harm.' ;
    rdfs:domain ind:InspectionFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityArea rdf:type rdf:Property ;
    rdfs:label 'Facility Area' ;
    rdfs:comment 'Specific location, department, or operational area within the facility where the finding was identified (e.g., Landfill Cell 3, MRF Sorting Line, Fleet Maintenance Bay, Leachate Collection System). Enables spatial tracking and accountability.' ;
    rdfs:domain ind:InspectionFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingNumber rdf:type rdf:Property ;
    rdfs:label 'Finding Number' ;
    rdfs:comment 'Business identifier for the finding, typically a sequential or hierarchical number within the parent inspection (e.g., F-001, 1.1, 2.3). Used for external reference and reporting.' ;
    rdfs:domain ind:InspectionFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingType rdf:type rdf:Property ;
    rdfs:label 'Finding Type' ;
    rdfs:comment 'Classification of the finding based on its regulatory or operational significance. Violation indicates a regulatory breach; observation is a noted condition without immediate compliance impact; recommendation suggests improvement; non-conformance indicates deviation from internal standards; opportunity for improvement highlights process enhancement areas; best practice recognizes exemplary performance.' ;
    rdfs:domain ind:InspectionFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:healthSafetyImpact rdf:type rdf:Property ;
    rdfs:label 'Health Safety Impact' ;
    rdfs:comment 'Assessment of the actual or potential health and safety impact of the condition identified in the finding. None indicates no health/safety consequence; low indicates minimal risk; medium indicates manageable risk; high indicates significant risk; severe indicates imminent danger.' ;
    rdfs:domain ind:InspectionFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionFindingDescription rdf:type rdf:Property ;
    rdfs:label 'Inspection Finding Description' ;
    rdfs:comment 'Detailed narrative description of the deficiency, observation, or condition identified during the inspection. Includes context, evidence observed, and specific circumstances. Critical for understanding the nature and scope of the finding.' ;
    rdfs:domain ind:InspectionFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionFindingStatus rdf:type rdf:Property ;
    rdfs:label 'Inspection Finding Status' ;
    rdfs:comment 'Current lifecycle status of the finding. Open indicates newly identified and not yet addressed; in progress indicates corrective action underway; pending verification indicates action completed awaiting validation; closed indicates verified resolution; deferred indicates postponed resolution with documented justification.' ;
    rdfs:domain ind:InspectionFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectorOrganization rdf:type rdf:Property ;
    rdfs:label 'Inspector Organization' ;
    rdfs:comment 'Organization or agency the inspector represents (e.g., EPA Region 5, State DEQ, Internal EHS Team, Third-Party Auditor). Provides context for the findings authority and follow-up requirements.' ;
    rdfs:domain ind:InspectionFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationDate rdf:type rdf:Property ;
    rdfs:label 'Notification Date' ;
    rdfs:comment 'Date on which formal notification of the finding was sent. Used to track compliance with notification timelines.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:photographicEvidenceUrl rdf:type rdf:Property ;
    rdfs:label 'Photographic Evidence Url' ;
    rdfs:comment 'Reference URL or file path to photographic or video evidence documenting the finding. Supports objective verification and audit trail.' ;
    rdfs:domain ind:InspectionFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:potentialPenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Potential Penalty Amount' ;
    rdfs:comment 'Estimated or assessed monetary penalty associated with this finding if it results in a regulatory violation. Used for financial risk assessment and reserve planning.' ;
    rdfs:domain ind:InspectionFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulationCategory rdf:type rdf:Property ;
    rdfs:label 'Regulation Category' ;
    rdfs:comment 'High-level categorization of the regulatory domain to which this finding pertains. Enables grouping and analysis of findings by compliance area. [ENUM-REF-CANDIDATE: air_quality|water_quality|waste_management|hazardous_materials|occupational_safety|environmental_monitoring|permit_compliance|reporting|other — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:InspectionFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repeatFinding rdf:type rdf:Property ;
    rdfs:label 'Repeat Finding' ;
    rdfs:comment 'Indicates whether this finding is a recurrence of a previously identified and closed issue. Repeat findings may trigger escalated enforcement or management review.' ;
    rdfs:domain ind:InspectionFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rootCauseAnalysisCompleted rdf:type rdf:Property ;
    rdfs:label 'Root Cause Analysis Completed' ;
    rdfs:comment 'Indicates whether a formal root cause analysis has been conducted for this finding. Typically required for major or critical findings to prevent recurrence.' ;
    rdfs:domain ind:InspectionFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:severity rdf:type rdf:Property ;
    rdfs:label 'Severity' ;
    rdfs:comment 'Severity classification of the finding. Critical indicates immediate threat to health, safety, or environment requiring urgent action; major indicates significant regulatory or operational risk; moderate indicates manageable risk with defined timeline; minor indicates low-impact issue; informational indicates no immediate action required.' ;
    rdfs:domain ind:InspectionFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationMethod rdf:type rdf:Property ;
    rdfs:label 'Verification Method' ;
    rdfs:comment 'Method used to verify closure of the finding (e.g., follow-up inspection, document review, photographic evidence, testing results). Documents the evidence basis for closure.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verifiedBy rdf:type rdf:Property ;
    rdfs:label 'Verified By' ;
    rdfs:comment 'Name or identifier of the individual who verified the closure of the finding. Provides accountability for closure decisions.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyOffice rdf:type rdf:Property ;
    rdfs:label 'Agency Office' ;
    rdfs:comment 'Specific office, region, or district within the issuing agency responsible for the enforcement action.' ;
    rdfs:domain ind:ViolationNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:appealFiledDate rdf:type rdf:Property ;
    rdfs:label 'Appeal Filed Date' ;
    rdfs:comment 'Date on which the company filed a formal appeal or contest of the violation notice.' ;
    rdfs:domain ind:ViolationNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:appealFiledFlag rdf:type rdf:Property ;
    rdfs:label 'Appeal Filed Flag' ;
    rdfs:comment 'Indicates whether the company filed a formal appeal or contested the violation notice with the regulatory agency or administrative law body.' ;
    rdfs:domain ind:ViolationNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appealOutcome rdf:type rdf:Property ;
    rdfs:label 'Appeal Outcome' ;
    rdfs:comment 'Final outcome of the appeal process, if an appeal was filed.' ;
    rdfs:domain ind:ViolationNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalCounselAssigned rdf:type rdf:Property ;
    rdfs:label 'Legal Counsel Assigned' ;
    rdfs:comment 'Name of the internal or external legal counsel assigned to manage the violation notice and enforcement action.' ;
    rdfs:domain ind:ViolationNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noticeIssuedDate rdf:type rdf:Property ;
    rdfs:label 'Notice Issued Date' ;
    rdfs:comment 'Date on which the regulatory agency officially issued the notice of violation to the company.' ;
    rdfs:domain ind:ViolationNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:noticeNumber rdf:type rdf:Property ;
    rdfs:label 'Notice Number' ;
    rdfs:comment 'Official notice number assigned by the issuing regulatory agency. This is the externally-known identifier for the enforcement action.' ;
    rdfs:domain ind:ViolationNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noticeReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Notice Received Date' ;
    rdfs:comment 'Date on which the company received the violation notice from the regulatory agency.' ;
    rdfs:domain ind:ViolationNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:noticeType rdf:type rdf:Property ;
    rdfs:label 'Notice Type' ;
    rdfs:comment 'Classification of the enforcement action type issued by the regulatory agency.' ;
    rdfs:domain ind:ViolationNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyAssessedAmount rdf:type rdf:Property ;
    rdfs:label 'Penalty Assessed Amount' ;
    rdfs:comment 'Monetary penalty amount assessed by the regulatory agency for the violation, in USD.' ;
    rdfs:domain ind:ViolationNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyPaidAmount rdf:type rdf:Property ;
    rdfs:label 'Penalty Paid Amount' ;
    rdfs:comment 'Actual monetary penalty amount paid by the company to the regulatory agency, in USD. May differ from assessed amount due to settlement or negotiation.' ;
    rdfs:domain ind:ViolationNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyPaymentDate rdf:type rdf:Property ;
    rdfs:label 'Penalty Payment Date' ;
    rdfs:comment 'Date on which the penalty payment was made to the regulatory agency.' ;
    rdfs:domain ind:ViolationNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:publicDisclosureFlag rdf:type rdf:Property ;
    rdfs:label 'Public Disclosure Flag' ;
    rdfs:comment 'Indicates whether the violation notice is subject to public disclosure or has been publicly reported by the regulatory agency.' ;
    rdfs:domain ind:ViolationNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responseDueDate rdf:type rdf:Property ;
    rdfs:label 'Response Due Date' ;
    rdfs:comment 'Deadline by which the company must submit a formal response or corrective action plan to the regulatory agency.' ;
    rdfs:domain ind:ViolationNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responseSubmittedDate rdf:type rdf:Property ;
    rdfs:label 'Response Submitted Date' ;
    rdfs:comment 'Date on which the company submitted its formal response or corrective action plan to the regulatory agency.' ;
    rdfs:domain ind:ViolationNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:settlementAgreementFlag rdf:type rdf:Property ;
    rdfs:label 'Settlement Agreement Flag' ;
    rdfs:comment 'Indicates whether the violation was resolved through a formal settlement agreement or consent decree with the regulatory agency.' ;
    rdfs:domain ind:ViolationNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:settlementAgreementNumber rdf:type rdf:Property ;
    rdfs:label 'Settlement Agreement Number' ;
    rdfs:comment 'Official reference number or identifier for the settlement agreement or consent decree, if applicable.' ;
    rdfs:domain ind:ViolationNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationCategory rdf:type rdf:Property ;
    rdfs:label 'Violation Category' ;
    rdfs:comment 'High-level classification of the violation type based on the environmental, health, or safety domain. [ENUM-REF-CANDIDATE: air_quality|water_quality|waste_management|hazardous_materials|occupational_safety|transportation|permit_compliance|reporting — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ViolationNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationDate rdf:type rdf:Property ;
    rdfs:label 'Violation Date' ;
    rdfs:comment 'Date on which the violation or non-compliance event occurred as documented by the regulatory agency.' ;
    rdfs:domain ind:ViolationNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:violationSeverity rdf:type rdf:Property ;
    rdfs:label 'Violation Severity' ;
    rdfs:comment 'Severity level of the violation as assessed by the regulatory agency or internal EHS team.' ;
    rdfs:domain ind:ViolationNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationStatus rdf:type rdf:Property ;
    rdfs:label 'Violation Status' ;
    rdfs:comment 'Current lifecycle status of the violation notice and enforcement action. [ENUM-REF-CANDIDATE: open|under_review|response_submitted|resolved|settled|appealed|closed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ViolationNotice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionDescription rdf:type rdf:Property ;
    rdfs:label 'Action Description' ;
    rdfs:comment 'Detailed description of the corrective or preventive action required, including specific steps, procedures, or changes to be implemented.' ;
    rdfs:domain ind:RegulatoryCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionNumber rdf:type rdf:Property ;
    rdfs:label 'Action Number' ;
    rdfs:comment 'Business identifier for the corrective or preventive action, typically generated by the EHS system (Enviance) or SAP EHS module. Used for tracking and reporting.' ;
    rdfs:domain ind:RegulatoryCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionStatus rdf:type rdf:Property ;
    rdfs:label 'Action Status' ;
    rdfs:comment 'Current lifecycle status of the corrective or preventive action. Tracks progression from identification through closure.' ;
    rdfs:domain ind:RegulatoryCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionTitle rdf:type rdf:Property ;
    rdfs:label 'Action Title' ;
    rdfs:comment 'Brief, descriptive title summarizing the corrective or preventive action.' ;
    rdfs:domain ind:RegulatoryCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionType rdf:type rdf:Property ;
    rdfs:label 'Action Type' ;
    rdfs:comment 'Indicates whether the action is corrective (addressing an existing nonconformity), preventive (addressing a potential nonconformity), or both.' ;
    rdfs:domain ind:RegulatoryCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureNotes rdf:type rdf:Property ;
    rdfs:label 'Closure Notes' ;
    rdfs:comment 'Notes or comments documenting the closure of the action, including any final observations, lessons learned, or follow-up recommendations.' ;
    rdfs:domain ind:RegulatoryCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managementReviewDate rdf:type rdf:Property ;
    rdfs:label 'Management Review Date' ;
    rdfs:comment 'Date when the corrective or preventive action was reviewed by management. Null if management review has not occurred or is not required.' ;
    rdfs:domain ind:RegulatoryCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:managementReviewRequired rdf:type rdf:Property ;
    rdfs:label 'Management Review Required' ;
    rdfs:comment 'Indicates whether the corrective or preventive action requires formal management review before closure, typically for high-priority or high-cost actions.' ;
    rdfs:domain ind:RegulatoryCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responsibleDepartment rdf:type rdf:Property ;
    rdfs:label 'Responsible Department' ;
    rdfs:comment 'Department or functional area responsible for implementing the action (e.g., Operations, Maintenance, EHS, Fleet, Engineering).' ;
    rdfs:domain ind:RegulatoryCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseAnalysis rdf:type rdf:Property ;
    rdfs:label 'Root Cause Analysis' ;
    rdfs:comment 'Summary of the root cause analysis performed to identify the underlying cause of the nonconformity or potential nonconformity. May reference methodologies such as 5 Whys, Fishbone Diagram, or Fault Tree Analysis.' ;
    rdfs:domain ind:RegulatoryCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyImpactCategory rdf:type rdf:Property ;
    rdfs:label 'Safety Impact Category' ;
    rdfs:comment 'Category of occupational health and safety impact addressed by the action (e.g., hazardous waste exposure, equipment safety, PPE compliance, confined space, fall protection, vehicle safety).' ;
    rdfs:domain ind:RegulatoryCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Target Completion Date' ;
    rdfs:comment 'Planned or required date by which the corrective or preventive action must be completed. May be driven by regulatory deadlines or internal commitments.' ;
    rdfs:domain ind:RegulatoryCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:triggeringEventReference rdf:type rdf:Property ;
    rdfs:label 'Triggering Event Reference' ;
    rdfs:comment 'Reference identifier to the source event that triggered this action (e.g., inspection ID, incident ID, audit finding ID, violation notice number). Enables traceability to the root cause.' ;
    rdfs:domain ind:RegulatoryCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggeringEventType rdf:type rdf:Property ;
    rdfs:label 'Triggering Event Type' ;
    rdfs:comment 'The type of event that initiated this corrective or preventive action (e.g., regulatory inspection, violation notice, environmental incident, internal audit finding, customer complaint, or proactive self-identification).' ;
    rdfs:domain ind:RegulatoryCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verifiedByName rdf:type rdf:Property ;
    rdfs:label 'Verified By Name' ;
    rdfs:comment 'Name of the individual who verified the effectiveness of the corrective or preventive action.' ;
    rdfs:domain ind:RegulatoryCorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bodyPartAffected rdf:type rdf:Property ;
    rdfs:label 'Body Part Affected' ;
    rdfs:comment 'Specific body part(s) injured in the incident (e.g., left hand, lower back, eyes). Null if no personal injury occurred.' ;
    rdfs:domain ind:EhsIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daysAwayFromWork rdf:type rdf:Property ;
    rdfs:label 'Days Away From Work' ;
    rdfs:comment 'Number of calendar days the injured employee was unable to work as a result of the incident. Zero if no time lost. Used for OSHA DART rate calculation.' ;
    rdfs:domain ind:EhsIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:daysOfJobTransfer rdf:type rdf:Property ;
    rdfs:label 'Days Of Job Transfer' ;
    rdfs:comment 'Number of calendar days the injured employee was transferred to another job as a result of the incident. Zero if no transfer occurred.' ;
    rdfs:domain ind:EhsIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:daysOfRestrictedWork rdf:type rdf:Property ;
    rdfs:label 'Days Of Restricted Work' ;
    rdfs:comment 'Number of calendar days the injured employee was on restricted or light duty as a result of the incident. Zero if no restriction. Used for OSHA DART rate calculation.' ;
    rdfs:domain ind:EhsIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:environmentalMediaAffected rdf:type rdf:Property ;
    rdfs:label 'Environmental Media Affected' ;
    rdfs:comment 'The environmental medium impacted by a release or spill incident. Applicable only to environmental release incidents.' ;
    rdfs:domain ind:EhsIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:immediateCause rdf:type rdf:Property ;
    rdfs:label 'Immediate Cause' ;
    rdfs:comment 'The direct, proximate cause of the incident as observed at the time of occurrence (e.g., equipment failure, slip and fall, vehicle collision).' ;
    rdfs:domain ind:EhsIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentDescription rdf:type rdf:Property ;
    rdfs:label 'Incident Description' ;
    rdfs:comment 'Comprehensive narrative description of what happened during the incident, including sequence of events, conditions, and immediate observations.' ;
    rdfs:domain ind:EhsIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentNumber rdf:type rdf:Property ;
    rdfs:label 'Incident Number' ;
    rdfs:comment 'Business-facing unique incident tracking number assigned by the EHS system for external reference and reporting.' ;
    rdfs:domain ind:EhsIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentStatus rdf:type rdf:Property ;
    rdfs:label 'Incident Status' ;
    rdfs:comment 'Current lifecycle status of the incident record. Open indicates initial reporting; under investigation means root cause analysis in progress; corrective action pending means investigation complete but actions not yet implemented; closed means all actions complete and incident resolved.' ;
    rdfs:domain ind:EhsIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:injuredPartyName rdf:type rdf:Property ;
    rdfs:label 'Injured Party Name' ;
    rdfs:comment 'Full name of the person injured or affected by the incident. Null if incident did not involve personal injury.' ;
    rdfs:domain ind:EhsIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:injuryType rdf:type rdf:Property ;
    rdfs:label 'Injury Type' ;
    rdfs:comment 'Classification of the physical injury sustained. Null if incident did not result in personal injury. [ENUM-REF-CANDIDATE: laceration|fracture|sprain|burn|contusion|amputation|respiratory|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:EhsIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigatorName rdf:type rdf:Property ;
    rdfs:label 'Investigator Name' ;
    rdfs:comment 'Name of the EHS professional or manager who led the incident investigation.' ;
    rdfs:domain ind:EhsIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialReleased rdf:type rdf:Property ;
    rdfs:label 'Material Released' ;
    rdfs:comment 'Description of the hazardous or non-hazardous material released during an environmental incident (e.g., diesel fuel, leachate, hydraulic fluid). Null if not an environmental release.' ;
    rdfs:domain ind:EhsIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationMethod rdf:type rdf:Property ;
    rdfs:label 'Notification Method' ;
    rdfs:comment 'Method used to notify the regulatory agency (phone, email, online portal, written report, in-person). Null if no notification required.' ;
    rdfs:domain ind:EhsIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oshaRecordableFlag rdf:type rdf:Property ;
    rdfs:label 'Osha Recordable Flag' ;
    rdfs:comment 'Indicates whether the incident meets OSHA criteria for recordability on the OSHA 300 log (death, days away from work, restricted work, medical treatment beyond first aid, loss of consciousness, or significant injury/illness diagnosed by healthcare professional).' ;
    rdfs:domain ind:EhsIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ppeInUseFlag rdf:type rdf:Property ;
    rdfs:label 'Ppe In Use Flag' ;
    rdfs:comment 'Indicates whether the injured party was wearing required personal protective equipment at the time of the incident. Null if not applicable.' ;
    rdfs:domain ind:EhsIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ppeType rdf:type rdf:Property ;
    rdfs:label 'Ppe Type' ;
    rdfs:comment 'Description of the PPE that was (or should have been) in use at the time of the incident (e.g., hard hat, safety glasses, gloves, respirator, steel-toed boots). Null if not applicable.' ;
    rdfs:domain ind:EhsIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:propertyDamageAmount rdf:type rdf:Property ;
    rdfs:label 'Property Damage Amount' ;
    rdfs:comment 'Estimated monetary value of property damage resulting from the incident in USD. Null if no property damage occurred.' ;
    rdfs:domain ind:EhsIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryAgencyNotified rdf:type rdf:Property ;
    rdfs:label 'Regulatory Agency Notified' ;
    rdfs:comment 'Name of the regulatory agency (EPA, OSHA, DOT, state environmental agency, local fire department) that was notified of the incident. Null if no notification required.' ;
    rdfs:domain ind:EhsIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Required Flag' ;
    rdfs:comment 'Indicates whether the incident triggers a mandatory regulatory reporting obligation to EPA, OSHA, DOT, or state/local agencies.' ;
    rdfs:domain ind:EhsIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:releaseQuantity rdf:type rdf:Property ;
    rdfs:label 'Release Quantity' ;
    rdfs:comment 'Estimated quantity of material released during an environmental incident. Null if not an environmental release.' ;
    rdfs:domain ind:EhsIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:releaseQuantityUnit rdf:type rdf:Property ;
    rdfs:label 'Release Quantity Unit' ;
    rdfs:comment 'Unit of measure for the release quantity (gallons, liters, pounds, kilograms, cubic yards, tons).' ;
    rdfs:domain ind:EhsIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportedByName rdf:type rdf:Property ;
    rdfs:label 'Reported By Name' ;
    rdfs:comment 'Name of the individual who initially reported the incident to the EHS department or management.' ;
    rdfs:domain ind:EhsIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseClassification rdf:type rdf:Property ;
    rdfs:label 'Root Cause Classification' ;
    rdfs:comment 'High-level classification of the underlying root cause determined through incident investigation. Human error includes training gaps or procedural non-compliance; equipment failure is mechanical breakdown; process deficiency is inadequate procedure; environmental condition is weather or site hazard; management system is organizational control weakness.' ;
    rdfs:domain ind:EhsIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:witnessNames rdf:type rdf:Property ;
    rdfs:label 'Witness Names' ;
    rdfs:comment 'Comma-separated list of names of individuals who witnessed the incident. Used for investigation purposes. Null if no witnesses.' ;
    rdfs:domain ind:EhsIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analysisCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Analysis Completion Date' ;
    rdfs:comment 'Date when the laboratory analysis was completed and results were finalized.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dataQualifier rdf:type rdf:Property ;
    rdfs:label 'Data Qualifier' ;
    rdfs:comment 'Code or flag indicating special conditions affecting the measurement result, such as J (estimated value), U (non-detect), B (blank contamination), or other EPA-standard qualifiers.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionLimit rdf:type rdf:Property ;
    rdfs:label 'Detection Limit' ;
    rdfs:comment 'The minimum concentration or value that the analytical method can reliably detect for this parameter. Values below this threshold may be reported as non-detect or below detection limit.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:laboratoryCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Laboratory Certification Number' ;
    rdfs:comment 'The certification or accreditation number of the laboratory that performed the analysis, demonstrating compliance with quality assurance requirements.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measuredValue rdf:type rdf:Property ;
    rdfs:label 'Measured Value' ;
    rdfs:comment 'The numeric value of the environmental parameter measured during the monitoring event.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:monitoringEventNumber rdf:type rdf:Property ;
    rdfs:label 'Monitoring Event Number' ;
    rdfs:comment 'Business identifier for the monitoring event, used for tracking and reporting purposes.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parameterMeasured rdf:type rdf:Property ;
    rdfs:label 'Parameter Measured' ;
    rdfs:comment 'The specific environmental parameter or pollutant measured in this monitoring event. Examples include CO2e (Carbon Dioxide Equivalent), methane, BOD (Biochemical Oxygen Demand), pH, VOCs (Volatile Organic Compounds), TSS (Total Suspended Solids), heavy metals, nitrogen oxides, sulfur dioxide, particulate matter, and other regulated substances.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityAssuranceFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Assurance Flag' ;
    rdfs:comment 'Indicates whether the measurement passed quality assurance and quality control (QA/QC) checks including calibration verification, blank analysis, duplicate samples, and spike recoveries.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryLimit rdf:type rdf:Property ;
    rdfs:label 'Regulatory Limit' ;
    rdfs:comment 'The maximum allowable concentration or value for this parameter as specified by the applicable environmental permit, regulation, or standard. Used for compliance comparison.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryReportingRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Required' ;
    rdfs:comment 'Indicates whether this monitoring result must be included in regulatory reports submitted to EPA, state agencies, or local authorities (e.g., SWIS, air quality reports, discharge monitoring reports).' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportingPeriod rdf:type rdf:Property ;
    rdfs:label 'Reporting Period' ;
    rdfs:comment 'The regulatory reporting period to which this monitoring result applies, typically expressed as a month, quarter, or year (e.g., 2024-Q1, January 2024).' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleCollectionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sample Collection Timestamp' ;
    rdfs:comment 'Date and time when the environmental sample was collected or the measurement was taken in the field.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:samplerName rdf:type rdf:Property ;
    rdfs:label 'Sampler Name' ;
    rdfs:comment 'Name of the individual or team who collected the environmental sample or performed the field measurement.' ;
    rdfs:domain ind:EnvironmentalMonitoring ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessRestrictions rdf:type rdf:Property ;
    rdfs:label 'Access Restrictions' ;
    rdfs:comment 'Description of any physical access restrictions, safety requirements, or special procedures needed to reach or service this monitoring station (e.g., \'Requires confined space entry permit\', \'Active landfill area - escort required\', \'Locked enclosure\').' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activationDate rdf:type rdf:Property ;
    rdfs:label 'Activation Date' ;
    rdfs:comment 'Date when the monitoring station was activated and began collecting compliance data. May differ from installation date if there was a commissioning period.' ;
    rdfs:domain ind:MonitoringStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:analyteList rdf:type rdf:Property ;
    rdfs:label 'Analyte List' ;
    rdfs:comment 'Comma-separated list or reference to the suite of parameters, chemicals, or constituents monitored at this station (e.g., \'Appendix I VOCs\', \'Appendix II metals\', \'LFG composition\', \'pH, conductivity, turbidity\'). Defines the scope of environmental monitoring.' ;
    rdfs:domain ind:MonitoringStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communicationMethod rdf:type rdf:Property ;
    rdfs:label 'Communication Method' ;
    rdfs:comment 'Method by which monitoring data is transmitted from the station to central systems (cellular modem, satellite uplink, radio telemetry, hardwired connection, or manual collection).' ;
    rdfs:domain ind:MonitoringStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataLoggerCode rdf:type rdf:Property ;
    rdfs:label 'Data Logger Code' ;
    rdfs:comment 'Identifier for the electronic data logger or telemetry device that collects and transmits measurements from this station. Used for data integration and troubleshooting.' ;
    rdfs:domain ind:MonitoringStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deactivationDate rdf:type rdf:Property ;
    rdfs:label 'Deactivation Date' ;
    rdfs:comment 'Date when the monitoring station was deactivated, abandoned, or decommissioned. Null for active stations. Marks the end of the station\'s operational lifecycle.' ;
    rdfs:domain ind:MonitoringStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deactivationReason rdf:type rdf:Property ;
    rdfs:label 'Deactivation Reason' ;
    rdfs:comment 'Explanation for why the monitoring station was deactivated (e.g., \'Permit requirement ended\', \'Well damaged beyond repair\', \'Facility closure\', \'Replaced by new station\'). Null for active stations.' ;
    rdfs:domain ind:MonitoringStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Equipment Serial Number' ;
    rdfs:comment 'Manufacturer serial number of the primary monitoring equipment at this station. Used for warranty tracking, calibration records, and maintenance history.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:installationContractor rdf:type rdf:Property ;
    rdfs:label 'Installation Contractor' ;
    rdfs:comment 'Name of the contractor or vendor who installed the monitoring station. Used for warranty tracking and quality assurance.' ;
    rdfs:domain ind:MonitoringStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastCalibrationDate rdf:type rdf:Property ;
    rdfs:label 'Last Calibration Date' ;
    rdfs:comment 'Date of the most recent calibration or verification of monitoring equipment at this station. Critical for data quality assurance and regulatory compliance.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:monitoringPurpose rdf:type rdf:Property ;
    rdfs:label 'Monitoring Purpose' ;
    rdfs:comment 'Primary purpose or phase of the monitoring program this station supports (detection monitoring, assessment monitoring, corrective action, etc.). Determines sampling frequency and analyte list.' ;
    rdfs:domain ind:MonitoringStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringStationStatus rdf:type rdf:Property ;
    rdfs:label 'Monitoring Station Status' ;
    rdfs:comment 'Current operational status of the monitoring station. Determines whether the station is included in active monitoring schedules and compliance reporting.' ;
    rdfs:domain ind:MonitoringStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monitoringZone rdf:type rdf:Property ;
    rdfs:label 'Monitoring Zone' ;
    rdfs:comment 'Designated monitoring zone or area within the facility (e.g., \'Upgradient\', \'Downgradient\', \'Cell 3 Perimeter\', \'North Boundary\'). Used for spatial grouping and compliance zone tracking.' ;
    rdfs:domain ind:MonitoringStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextCalibrationDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Calibration Due Date' ;
    rdfs:comment 'Scheduled date for the next required calibration or verification of monitoring equipment. Used for preventive maintenance scheduling and compliance tracking.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryDesignation rdf:type rdf:Property ;
    rdfs:label 'Regulatory Designation' ;
    rdfs:comment 'Official regulatory identifier or designation assigned by permitting authority (e.g., NPDES outfall number, well ID per state permit, EPA monitoring point ID). Used in compliance reporting and permit tracking.' ;
    rdfs:domain ind:MonitoringStation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screenIntervalBottomFt rdf:type rdf:Property ;
    rdfs:label 'Screen Interval Bottom Ft' ;
    rdfs:comment 'Depth to the bottom of the well screen interval from ground surface in feet. Defines the lower boundary of the monitored zone. Applicable to wells only.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:screenIntervalTopFt rdf:type rdf:Property ;
    rdfs:label 'Screen Interval Top Ft' ;
    rdfs:comment 'Depth to the top of the well screen interval from ground surface in feet. Defines the upper boundary of the monitored zone. Applicable to wells only.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:wellDepthFt rdf:type rdf:Property ;
    rdfs:label 'Well Depth Ft' ;
    rdfs:comment 'Total depth of the monitoring well from ground surface to bottom in feet. Applicable only to groundwater wells and LFG extraction wells. Null for other station types.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalSubmissionRegulatorySubmissionId rdf:type rdf:Property ;
    rdfs:label 'Original Submission Regulatory Submission Id' ;
    rdfs:comment 'Identifier of the original regulatory submission that this record amends, if applicable. Links amended submissions to their original filing.' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatorySubmission .

ind:agencyComments rdf:type rdf:Property ;
    rdfs:label 'Agency Comments' ;
    rdfs:comment 'Comments or feedback provided by the regulatory agency regarding the submission. Captures agency instructions, deficiency notices, or acceptance notes.' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyResponseDate rdf:type rdf:Property ;
    rdfs:label 'Agency Response Date' ;
    rdfs:comment 'Date on which the regulatory agency provided a formal response to the submission (acceptance, rejection, or request for additional information).' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:agencyResponseStatus rdf:type rdf:Property ;
    rdfs:label 'Agency Response Status' ;
    rdfs:comment 'Status of the regulatory agency\'s response to the submission. Tracks whether the filing was accepted, rejected, or requires follow-up.' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentFlag rdf:type rdf:Property ;
    rdfs:label 'Amendment Flag' ;
    rdfs:comment 'Indicates whether this submission is an amendment to a previously filed report. True if this is an amended submission, false if original.' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificationStatement rdf:type rdf:Property ;
    rdfs:label 'Certification Statement' ;
    rdfs:comment 'Text of the certification statement signed by the authorized representative, attesting to the accuracy and completeness of the submission under penalty of law.' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifyingOfficialName rdf:type rdf:Property ;
    rdfs:label 'Certifying Official Name' ;
    rdfs:comment 'Name of the authorized company official who certified the regulatory submission. Typically a facility manager, environmental manager, or corporate officer.' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifyingOfficialTitle rdf:type rdf:Property ;
    rdfs:label 'Certifying Official Title' ;
    rdfs:comment 'Job title of the authorized official who certified the submission (e.g., Environmental Manager, Facility Manager, Vice President of EHS).' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceYear rdf:type rdf:Property ;
    rdfs:label 'Compliance Year' ;
    rdfs:comment 'Calendar year for which compliance is being reported. Facilitates year-over-year compliance tracking and trend analysis.' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:confirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Confirmation Number' ;
    rdfs:comment 'Confirmation or tracking number issued by the regulatory agency upon receipt of the submission. Serves as proof of filing.' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentFilePath rdf:type rdf:Property ;
    rdfs:label 'Document File Path' ;
    rdfs:comment 'File path or storage location of the submitted regulatory report document. Enables retrieval of the original submission for audit and reference.' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentFormat rdf:type rdf:Property ;
    rdfs:label 'Document Format' ;
    rdfs:comment 'File format of the submitted regulatory report (PDF, XML, Excel, etc.). Identifies the technical format used for submission.' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingAgency rdf:type rdf:Property ;
    rdfs:label 'Filing Agency' ;
    rdfs:comment 'Name of the government agency or regulatory body to which the report is submitted (e.g., EPA, state environmental quality department, local enforcement agency).' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lateSubmissionFlag rdf:type rdf:Property ;
    rdfs:label 'Late Submission Flag' ;
    rdfs:comment 'Indicates whether the submission was filed after the regulatory deadline. True if late, false if on time. Used to track compliance with filing timelines.' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lateSubmissionReason rdf:type rdf:Property ;
    rdfs:label 'Late Submission Reason' ;
    rdfs:comment 'Explanation for why the submission was filed late, if applicable. Documents the circumstances that caused the delay.' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportType rdf:type rdf:Property ;
    rdfs:label 'Report Type' ;
    rdfs:comment 'Classification of the regulatory report being submitted. Identifies the specific regulatory program and reporting requirement. [ENUM-REF-CANDIDATE: RCRA Biennial Report|SWIS Report|NPDES DMR|Title V Certification|CERCLA Tier II|EPCRA Tier II|OSHA 300A Summary|GHG Emissions Report|State Environmental Report|Air Quality Report|Water Discharge Report|Hazardous Waste Manifest|LFG Monitoring Report|Leachate Analysis Report — promote to reference product]' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Reporting Period End' ;
    rdfs:comment 'End date of the period covered by this regulatory submission. Defines the close of the compliance reporting window.' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Start' ;
    rdfs:comment 'Start date of the period covered by this regulatory submission. Defines the beginning of the compliance reporting window.' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:submissionDate rdf:type rdf:Property ;
    rdfs:label 'Submission Date' ;
    rdfs:comment 'Date on which the regulatory report was submitted to the filing agency. Principal business event timestamp for this transaction.' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:submissionMethod rdf:type rdf:Property ;
    rdfs:label 'Submission Method' ;
    rdfs:comment 'Method by which the report was submitted to the regulatory agency (electronic portal, paper mail, email, etc.).' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionNumber rdf:type rdf:Property ;
    rdfs:label 'Submission Number' ;
    rdfs:comment 'Business identifier for the regulatory submission, typically assigned by the submitting organization or regulatory agency. Used for external reference and tracking.' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionStatus rdf:type rdf:Property ;
    rdfs:label 'Submission Status' ;
    rdfs:comment 'Current lifecycle status of the regulatory submission. Tracks the submission through preparation, filing, and agency review stages. [ENUM-REF-CANDIDATE: Draft|Submitted|Accepted|Rejected|Under Review|Amended|Withdrawn — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RegulatorySubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attachmentUrl rdf:type rdf:Property ;
    rdfs:label 'Attachment Url' ;
    rdfs:comment 'The file path or URL to the scanned copy of the certification document stored in the document management system. Used for audit and verification purposes.' ;
    rdfs:domain ind:TrainingCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationType rdf:type rdf:Property ;
    rdfs:label 'Certification Type' ;
    rdfs:comment 'The category of training or certification. Includes Commercial Driver License (CDL), Hazardous Waste Operations and Emergency Response (HAZWOPER) 40-hour initial and 8-hour refresher, Department of Transportation (DOT) hazmat transport, Occupational Safety and Health Administration (OSHA) 10-hour and 30-hour safety, confined space entry, forklift operator, Environmental Protection Agency (EPA) Risk Management Plan (RMP), and ISO 14001/45001 internal auditor certifications. [ENUM-REF-CANDIDATE: CDL|HAZWOPER_40HR|HAZWOPER_8HR_REFRESHER|DOT_HAZMAT|OSHA_10HR|OSHA_30HR|CONFINED_SPACE|FORKLIFT_OPERATOR|EPA_RMP|ISO_14001_AUDITOR|ISO_45001_AUDITOR|FIRST_AID_CPR — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TrainingCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionDate rdf:type rdf:Property ;
    rdfs:label 'Completion Date' ;
    rdfs:comment 'The date on which the employee successfully completed the training or certification program.' ;
    rdfs:domain ind:TrainingCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Requirement Flag' ;
    rdfs:comment 'Indicates whether this certification is a mandatory regulatory or company compliance requirement for the employees role. True for required certifications (e.g., CDL for drivers, HAZWOPER for hazmat handlers); False for optional professional development.' ;
    rdfs:domain ind:TrainingCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:endorsementCodes rdf:type rdf:Property ;
    rdfs:label 'Endorsement Codes' ;
    rdfs:comment 'For CDL certifications, the endorsement codes indicating specialized vehicle or cargo authorization. Examples: H (Hazardous Materials), N (Tank Vehicle), T (Double/Triple Trailers), P (Passenger). Pipe-separated if multiple endorsements.' ;
    rdfs:domain ind:TrainingCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instructorName rdf:type rdf:Property ;
    rdfs:label 'Instructor Name' ;
    rdfs:comment 'The name of the instructor or trainer who conducted the training session, if applicable.' ;
    rdfs:domain ind:TrainingCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingBody rdf:type rdf:Property ;
    rdfs:label 'Issuing Body' ;
    rdfs:comment 'The organization or regulatory authority that issued the certification. Examples include state Department of Motor Vehicles (DMV), OSHA Training Institute Education Centers, EPA-approved training providers, ISO registrars.' ;
    rdfs:domain ind:TrainingCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passFailStatus rdf:type rdf:Property ;
    rdfs:label 'Pass Fail Status' ;
    rdfs:comment 'Indicates whether the employee passed, failed, is currently in progress, or did not complete the certification assessment.' ;
    rdfs:domain ind:TrainingCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Renewal Frequency Months' ;
    rdfs:comment 'The number of months between required renewals. Examples: 12 months for HAZWOPER refresher, 24 months for First Aid/CPR, 60 months for CDL renewal. Null if no renewal required.' ;
    rdfs:domain ind:TrainingCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:renewalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Renewal Required Flag' ;
    rdfs:comment 'Indicates whether this certification requires periodic renewal. True for CDL, HAZWOPER refresher, DOT hazmat; False for one-time certifications.' ;
    rdfs:domain ind:TrainingCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:restrictionCodes rdf:type rdf:Property ;
    rdfs:label 'Restriction Codes' ;
    rdfs:comment 'For CDL certifications, the restriction codes limiting driving privileges. Examples: L (No Air Brake Equipped CMV), Z (No Full Air Brake Equipped CMV), E (No Manual Transmission). Pipe-separated if multiple restrictions.' ;
    rdfs:domain ind:TrainingCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:score rdf:type rdf:Property ;
    rdfs:label 'Score' ;
    rdfs:comment 'The numerical score or percentage achieved on the certification exam or assessment, if applicable. Null for certifications without scored assessments.' ;
    rdfs:domain ind:TrainingCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingDeliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Training Delivery Method' ;
    rdfs:comment 'The method by which the training was delivered. In-person classroom, online e-learning, blended (combination), or on-the-job practical training.' ;
    rdfs:domain ind:TrainingCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingHours rdf:type rdf:Property ;
    rdfs:label 'Training Hours' ;
    rdfs:comment 'The total number of instructional hours completed for this certification. Examples: 40 hours for HAZWOPER initial, 8 hours for HAZWOPER refresher, 10 or 30 hours for OSHA safety training.' ;
    rdfs:domain ind:TrainingCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingLocation rdf:type rdf:Property ;
    rdfs:label 'Training Location' ;
    rdfs:comment 'The physical location or facility where the training was conducted. May be a Waste Management facility, training center, or external provider location. Null for online training.' ;
    rdfs:domain ind:TrainingCertification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByRequirementTrainingRequirementId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Requirement Training Requirement Id' ;
    rdfs:comment 'Reference to the training_requirement_id that replaces this requirement when regulatory standards change or training programs are updated. Null if not superseded.' ;
    rdfs:domain ind:TrainingRequirement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TrainingRequirement .

ind:accreditationBody rdf:type rdf:Property ;
    rdfs:label 'Accreditation Body' ;
    rdfs:comment 'Name of the organization that must accredit the training provider (e.g., OSHA, EPA, State DMV, IACET, ANSI). Null if no specific accreditation required.' ;
    rdfs:domain ind:TrainingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableFacilityTypes rdf:type rdf:Property ;
    rdfs:label 'Applicable Facility Types' ;
    rdfs:comment 'Comma-separated list or description of facility types where this training is mandatory (e.g., Landfill, MRF, TSDF, Transfer Station, WTE Facility, Fleet Maintenance Yard, Hazardous Waste Storage).' ;
    rdfs:domain ind:TrainingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableJobRoles rdf:type rdf:Property ;
    rdfs:label 'Applicable Job Roles' ;
    rdfs:comment 'Comma-separated list or description of job roles/positions to which this training requirement applies (e.g., CDL Driver, Hazmat Handler, MRF Sorter, Landfill Operator, Maintenance Technician, Environmental Compliance Manager).' ;
    rdfs:domain ind:TrainingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableRegulatoryPrograms rdf:type rdf:Property ;
    rdfs:label 'Applicable Regulatory Programs' ;
    rdfs:comment 'Comma-separated list of regulatory programs or permits that trigger this training requirement (e.g., RCRA Part B Permit, Air Quality Permit, NPDES Permit, DOT Hazmat Transportation, OSHA PSM).' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessJustification rdf:type rdf:Property ;
    rdfs:label 'Business Justification' ;
    rdfs:comment 'Narrative explanation of why this training is required, including regulatory mandate, risk mitigation, operational necessity, or industry best practice rationale.' ;
    rdfs:domain ind:TrainingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Certification Required Flag' ;
    rdfs:comment 'Indicates whether successful completion must result in a formal certification or credential (True) or if attendance/completion record is sufficient (False).' ;
    rdfs:domain ind:TrainingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:competencyAssessmentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Competency Assessment Required Flag' ;
    rdfs:comment 'Indicates whether a formal competency assessment (exam, practical demonstration, skills test) is required in addition to training attendance.' ;
    rdfs:domain ind:TrainingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costEstimateUsd rdf:type rdf:Property ;
    rdfs:label 'Cost Estimate Usd' ;
    rdfs:comment 'Estimated cost per employee to complete this training requirement, including tuition, materials, travel, and lost productivity. Used for compliance budget planning.' ;
    rdfs:domain ind:TrainingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:documentationRetentionYears rdf:type rdf:Property ;
    rdfs:label 'Documentation Retention Years' ;
    rdfs:comment 'Minimum number of years training records must be retained to satisfy regulatory and audit requirements (e.g., OSHA requires 3 years for most training, EPA RCRA requires duration of employment plus 3 years).' ;
    rdfs:domain ind:TrainingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:frequencyIntervalMonths rdf:type rdf:Property ;
    rdfs:label 'Frequency Interval Months' ;
    rdfs:comment 'Number of months between required training completions for recurring requirements. Null for one-time or event-driven training.' ;
    rdfs:domain ind:TrainingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:iso14001CompetenceFlag rdf:type rdf:Property ;
    rdfs:label 'Iso 14001 Competence Flag' ;
    rdfs:comment 'Indicates whether this training requirement is part of the ISO 14001 Environmental Management System competence framework.' ;
    rdfs:domain ind:TrainingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iso45001CompetenceFlag rdf:type rdf:Property ;
    rdfs:label 'Iso 45001 Competence Flag' ;
    rdfs:comment 'Indicates whether this training requirement is part of the ISO 45001 Occupational Health and Safety Management System competence framework.' ;
    rdfs:domain ind:TrainingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:languageRequirements rdf:type rdf:Property ;
    rdfs:label 'Language Requirements' ;
    rdfs:comment 'Languages in which training must be available to ensure comprehension by all applicable employees (e.g., English, Spanish). OSHA requires training in language understood by employee.' ;
    rdfs:domain ind:TrainingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumPassingScorePercent rdf:type rdf:Property ;
    rdfs:label 'Minimum Passing Score Percent' ;
    rdfs:comment 'Minimum percentage score required on competency assessment to satisfy the training requirement. Null if no assessment or no minimum score defined.' ;
    rdfs:domain ind:TrainingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumTrainingHours rdf:type rdf:Property ;
    rdfs:label 'Minimum Training Hours' ;
    rdfs:comment 'Minimum contact hours required to satisfy the training obligation (e.g., 40 hours for HAZWOPER initial, 8 hours for annual refresher, 10 hours for OSHA General Industry).' ;
    rdfs:domain ind:TrainingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prerequisiteTrainingCodes rdf:type rdf:Property ;
    rdfs:label 'Prerequisite Training Codes' ;
    rdfs:comment 'Comma-separated list of training_type_code values that must be completed before this training can be taken (e.g., HAZWOPER_40HR must precede HAZWOPER_SUPERVISOR).' ;
    rdfs:domain ind:TrainingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requirementStatus rdf:type rdf:Property ;
    rdfs:label 'Requirement Status' ;
    rdfs:comment 'Current lifecycle state of the training requirement. Active requirements are enforced in compliance gap analysis.' ;
    rdfs:domain ind:TrainingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPartyCertificationFlag rdf:type rdf:Property ;
    rdfs:label 'Third Party Certification Flag' ;
    rdfs:comment 'Indicates whether the certification must be issued by an external accredited body (True) or can be issued internally (False). Examples: CDL requires state DMV, HAZWOPER may require accredited training provider.' ;
    rdfs:domain ind:TrainingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trainingCategory rdf:type rdf:Property ;
    rdfs:label 'Training Category' ;
    rdfs:comment 'High-level classification of the training requirement domain.' ;
    rdfs:domain ind:TrainingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingDeliveryMethods rdf:type rdf:Property ;
    rdfs:label 'Training Delivery Methods' ;
    rdfs:comment 'Comma-separated list of acceptable delivery formats (e.g., classroom, online, blended, hands-on, on-the-job, simulator). Some regulatory training may restrict delivery methods.' ;
    rdfs:domain ind:TrainingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingName rdf:type rdf:Property ;
    rdfs:label 'Training Name' ;
    rdfs:comment 'Full descriptive name of the training program (e.g., 40-Hour HAZWOPER Initial Training, Commercial Driver License Class A Certification, OSHA 10-Hour General Industry Safety).' ;
    rdfs:domain ind:TrainingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingProviderType rdf:type rdf:Property ;
    rdfs:label 'Training Provider Type' ;
    rdfs:comment 'Classification of acceptable training provider sources for this requirement.' ;
    rdfs:domain ind:TrainingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingTypeCode rdf:type rdf:Property ;
    rdfs:label 'Training Type Code' ;
    rdfs:comment 'Standardized code identifying the specific training program (e.g., HAZWOPER_40HR, CDL_CLASS_A, OSHA_10HR, DOT_HAZMAT, RCRA_HANDLER, CONFINED_SPACE, FORKLIFT_CERT).' ;
    rdfs:domain ind:TrainingRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryRegulatedEpaFacilityId rdf:type rdf:Property ;
    rdfs:label 'Primary Regulated Epa Facility Id' ;
    rdfs:comment 'EPA Facility Registry Service (FRS) identifier. Unique federal identifier assigned by EPA for tracking environmental compliance across all federal programs.' ;
    rdfs:domain ind:RegulatedFacility ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Facility .

ind:activeViolationsCount rdf:type rdf:Property ;
    rdfs:label 'Active Violations Count' ;
    rdfs:comment 'Current number of unresolved regulatory violations at this facility. Calculated from violation_notice records with status = open or pending. Used for compliance risk assessment.' ;
    rdfs:domain ind:RegulatedFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capacityUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Capacity Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the design capacity value. TPD = Tons Per Day (common for landfills and WTE), cubic yards (transfer stations), tons per hour (MRFs).' ;
    rdfs:domain ind:RegulatedFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Compliance Risk Level' ;
    rdfs:comment 'Overall compliance risk assessment for the facility. Low = no violations, good compliance history; Medium = minor violations or aging permits; High = multiple violations or major non-compliance; Critical = enforcement action pending or operations at risk. Used for prioritizing compliance resources.' ;
    rdfs:domain ind:RegulatedFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designCapacity rdf:type rdf:Property ;
    rdfs:label 'Design Capacity' ;
    rdfs:comment 'Maximum permitted operational capacity of the facility. Units vary by facility type: TPD (Tons Per Day) for landfills and WTE plants, cubic yards for transfer stations, tons per hour for MRFs. Used for permit compliance and capacity planning.' ;
    rdfs:domain ind:RegulatedFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:facilityClosureDate rdf:type rdf:Property ;
    rdfs:label 'Facility Closure Date' ;
    rdfs:comment 'Date the facility permanently ceased operations. Null for active facilities. Used for post-closure monitoring and long-term stewardship tracking.' ;
    rdfs:domain ind:RegulatedFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:facilityOpenedDate rdf:type rdf:Property ;
    rdfs:label 'Facility Opened Date' ;
    rdfs:comment 'Date the facility first began operations. Used for facility age analysis, permit history tracking, and closure planning.' ;
    rdfs:domain ind:RegulatedFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operatingPermitNumber rdf:type rdf:Property ;
    rdfs:label 'Operating Permit Number' ;
    rdfs:comment 'Primary operating permit number issued by the state or local regulatory agency. Required for legal operation of the facility. Links to detailed permit records in Enviance EHS.' ;
    rdfs:domain ind:RegulatedFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postClosureMonitoringEndDate rdf:type rdf:Property ;
    rdfs:label 'Post Closure Monitoring End Date' ;
    rdfs:comment 'Date when post-closure monitoring obligations end. Typically 30 years after closure for landfills. Null if monitoring not required or facility still active.' ;
    rdfs:domain ind:RegulatedFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:postClosureMonitoringRequired rdf:type rdf:Property ;
    rdfs:label 'Post Closure Monitoring Required' ;
    rdfs:comment 'Indicates whether the facility requires post-closure environmental monitoring after operations cease. True = monitoring required (typical for landfills), False = no monitoring required. Determines long-term compliance obligations.' ;
    rdfs:domain ind:RegulatedFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:primaryRegulatoryContactEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Regulatory Contact Email' ;
    rdfs:comment 'Email address of the primary regulatory contact. Used for regulatory correspondence, inspection notifications, and compliance alerts.' ;
    rdfs:domain ind:RegulatedFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryRegulatoryContactName rdf:type rdf:Property ;
    rdfs:label 'Primary Regulatory Contact Name' ;
    rdfs:comment 'Full name of the primary internal contact responsible for regulatory compliance at this facility. Typically the facility manager, EHS manager, or compliance officer.' ;
    rdfs:domain ind:RegulatedFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryRegulatoryContactPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Regulatory Contact Phone' ;
    rdfs:comment 'Phone number of the primary regulatory contact. Used for urgent regulatory communications and emergency response coordination.' ;
    rdfs:domain ind:RegulatedFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rcraGeneratorStatus rdf:type rdf:Property ;
    rdfs:label 'Rcra Generator Status' ;
    rdfs:comment 'RCRA hazardous waste generator classification. LQG = Large Quantity Generator (≥1000 kg/month), SQG = Small Quantity Generator (100-1000 kg/month), VSQG = Very Small Quantity Generator (<100 kg/month). Determines hazardous waste management requirements.' ;
    rdfs:domain ind:RegulatedFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionalEpaOffice rdf:type rdf:Property ;
    rdfs:label 'Regional Epa Office' ;
    rdfs:comment 'EPA regional office with jurisdiction over this facility. Determines which EPA regional office handles permits, inspections, and enforcement actions. [ENUM-REF-CANDIDATE: region_1|region_2|region_3|region_4|region_5|region_6|region_7|region_8|region_9|region_10 — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RegulatedFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Status' ;
    rdfs:comment 'Current regulatory compliance status of the facility. Active = operational and compliant, Inactive = temporarily non-operational, Pending closure = in closure process, Closed = permanently closed, Suspended = operations halted due to violations, Under review = regulatory investigation in progress.' ;
    rdfs:domain ind:RegulatedFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:titleVDesignation rdf:type rdf:Property ;
    rdfs:label 'Title V Designation' ;
    rdfs:comment 'Clean Air Act Title V operating permit classification. Major source = emissions exceed threshold limits, Minor source = below thresholds, Synthetic minor = voluntarily limited emissions. Determines air quality monitoring and reporting requirements.' ;
    rdfs:domain ind:RegulatedFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partyId rdf:type rdf:Property ;
    rdfs:label 'Party Id' ;
    rdfs:comment 'Unique identifier for the contract party record. Primary key.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentPartyId rdf:type rdf:Property ;
    rdfs:label 'Parent Party Id' ;
    rdfs:comment 'Self-referencing FK on party (parent_party_id)' ;
    rdfs:domain ind:Party ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Party .

ind:authorityLevel rdf:type rdf:Property ;
    rdfs:label 'Authority Level' ;
    rdfs:comment 'The level of authority this party holds in contract execution and administration. Signatory can execute amendments; approver can authorize changes; administrator manages day-to-day operations; observer receives notifications only; beneficiary receives services or payments.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dbaName rdf:type rdf:Property ;
    rdfs:label 'Dba Name' ;
    rdfs:comment 'The trade name or doing-business-as name if different from the legal name. Common for franchises and subsidiaries.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guaranteeAmount rdf:type rdf:Property ;
    rdfs:label 'Guarantee Amount' ;
    rdfs:comment 'Maximum financial liability or guarantee amount this party has committed to under the contract. Applicable when guarantor_flag is true.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:guaranteeCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Guarantee Currency Code' ;
    rdfs:comment 'Three-letter ISO currency code for the guarantee amount. Typically USD for US operations, CAD for Canada, MXN for Mexico.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guarantorFlag rdf:type rdf:Property ;
    rdfs:label 'Guarantor Flag' ;
    rdfs:comment 'Indicates whether this party serves as a financial or performance guarantor for the contract. True for guarantors who assume liability; false otherwise.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalName rdf:type rdf:Property ;
    rdfs:label 'Legal Name' ;
    rdfs:comment 'The full legal name of the party as it appears on official documents and contracts. Used for contract execution and legal correspondence.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partyStatus rdf:type rdf:Property ;
    rdfs:label 'Party Status' ;
    rdfs:comment 'Current lifecycle status of the party\'s participation in the contract. Active indicates the party is currently engaged; inactive indicates the party role has ended; suspended indicates temporary hold; pending_approval indicates awaiting authorization; terminated indicates formal removal from contract.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partyType rdf:type rdf:Property ;
    rdfs:label 'Party Type' ;
    rdfs:comment 'Legal classification of the party entity. Distinguishes between individual persons, corporations, partnerships, government entities, nonprofit organizations, trusts, and joint ventures. [ENUM-REF-CANDIDATE: individual|corporation|partnership|government|nonprofit|trust|joint_venture — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceCode rdf:type rdf:Property ;
    rdfs:label 'Reference Code' ;
    rdfs:comment 'Foreign key reference to the master data record for this party. The target table is determined by party_reference_type (e.g., customer_id, vendor_id, municipality_id).' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:referenceType rdf:type rdf:Property ;
    rdfs:label 'Reference Type' ;
    rdfs:comment 'Indicates which master data domain this party references. Determines whether the party_reference_id points to customer master, vendor master, employee master, municipality registry, regulatory agency registry, or internal WM entity.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roleCode rdf:type rdf:Property ;
    rdfs:label 'Role Code' ;
    rdfs:comment 'The role this party plays in the contract relationship. Common roles include customer (service recipient), provider (WM contracting entity), guarantor (financial guarantor), regulator (municipal or environmental authority), subcontractor (third-party hauler or processor), insurer (insurance provider), municipal_authority (local government entity), franchise_authority (franchising body), hauler (transportation provider), disposal_facility (landfill or processing facility operator), broker (intermediary), consultant (advisory party). [ENUM-REF-CANDIDATE: customer|provider|guarantor|regulator|subcontractor|insurer|municipal_authority|franchise_authority|hauler|disposal_facility|broker|consultant — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatoryName rdf:type rdf:Property ;
    rdfs:label 'Signatory Name' ;
    rdfs:comment 'Full name of the individual who signed on behalf of this party. May differ from primary contact if an officer or authorized representative signed.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatoryTitle rdf:type rdf:Property ;
    rdfs:label 'Signatory Title' ;
    rdfs:comment 'Official title of the signatory (e.g., Chief Executive Officer, City Manager, Authorized Representative). Establishes legal authority to bind the party.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signatureDate rdf:type rdf:Property ;
    rdfs:label 'Signature Date' ;
    rdfs:comment 'Date on which this party signed the contract or amendment. Used to establish binding agreement and effective dates.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:signatureRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Signature Required Flag' ;
    rdfs:comment 'Indicates whether this party\'s signature is required for contract execution and amendments. True for signatories and guarantors; false for observers and administrators.' ;
    rdfs:domain ind:WasteManagement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxIdentificationNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Identification Number' ;
    rdfs:comment 'Federal tax identification number (EIN for entities, SSN for individuals) used for tax reporting and compliance. Required for payment processing and 1099 reporting.' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationReasonCode rdf:type rdf:Property ;
    rdfs:label 'Termination Reason Code' ;
    rdfs:comment 'Reason code for why this party\'s participation ended. Applicable when effective_end_date is populated. Used for churn analysis and risk assessment. [ENUM-REF-CANDIDATE: contract_expiration|mutual_agreement|breach|bankruptcy|merger_acquisition|regulatory_change|non_performance — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Party ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentVehicleClassId rdf:type rdf:Property ;
    rdfs:label 'Parent Vehicle Class Id' ;
    rdfs:comment 'Self-referencing FK on vehicle_class (parent_vehicle_class_id)' ;
    rdfs:domain ind:VehicleClass ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VehicleClass .

ind:annualInspectionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Annual Inspection Required Flag' ;
    rdfs:comment 'Indicates whether vehicles in this class require annual DOT safety inspections. True if required, False if not.' ;
    rdfs:domain ind:VehicleClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:averageAcquisitionCostUsd rdf:type rdf:Property ;
    rdfs:label 'Average Acquisition Cost Usd' ;
    rdfs:comment 'Average acquisition cost for a new vehicle in this class, measured in US dollars. Used for capital planning and budgeting.' ;
    rdfs:domain ind:VehicleClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageAnnualOperatingCostUsd rdf:type rdf:Property ;
    rdfs:label 'Average Annual Operating Cost Usd' ;
    rdfs:comment 'Average annual operating cost for vehicles in this class including fuel, maintenance, insurance, and depreciation, measured in US dollars.' ;
    rdfs:domain ind:VehicleClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageStopsPerShift rdf:type rdf:Property ;
    rdfs:label 'Average Stops Per Shift' ;
    rdfs:comment 'Typical number of service stops this vehicle class can complete in a standard shift. Used for route planning and capacity modeling.' ;
    rdfs:domain ind:VehicleClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:averageTonsPerDay rdf:type rdf:Property ;
    rdfs:label 'Average Tons Per Day' ;
    rdfs:comment 'Average tonnage of waste this vehicle class typically collects per operating day. TPD = Tons Per Day.' ;
    rdfs:domain ind:VehicleClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:backupCameraRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Backup Camera Required Flag' ;
    rdfs:comment 'Indicates whether backup cameras are required safety equipment for this vehicle class. True if required, False if not.' ;
    rdfs:domain ind:VehicleClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bodyManufacturer rdf:type rdf:Property ;
    rdfs:label 'Body Manufacturer' ;
    rdfs:comment 'Typical or preferred body manufacturer for vehicles in this class (e.g., McNeilus, Heil, Labrie, New Way).' ;
    rdfs:domain ind:VehicleClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classCode rdf:type rdf:Property ;
    rdfs:label 'Class Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the vehicle class (e.g., ASL-20, FEL-30, REL-25, ROLLOFF-40). Used as the business identifier for classification.' ;
    rdfs:domain ind:VehicleClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:className rdf:type rdf:Property ;
    rdfs:label 'Class Name' ;
    rdfs:comment 'Full descriptive name of the vehicle class (e.g., Automated Side Loader 20-Yard, Front End Loader 30-Yard, Rear End Loader 25-Yard, Roll-Off Truck 40-Yard).' ;
    rdfs:domain ind:VehicleClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crewSize rdf:type rdf:Property ;
    rdfs:label 'Crew Size' ;
    rdfs:comment 'Standard crew size for vehicles in this class (e.g., 1 for automated side loaders, 2-3 for rear loaders with helpers).' ;
    rdfs:domain ind:VehicleClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dotVehicleClass rdf:type rdf:Property ;
    rdfs:label 'Dot Vehicle Class' ;
    rdfs:comment 'DOT vehicle classification number (1-8) based on GVWR. Class 1-2: light duty, 3-6: medium duty, 7-8: heavy duty.' ;
    rdfs:domain ind:VehicleClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emissionsStandard rdf:type rdf:Property ;
    rdfs:label 'Emissions Standard' ;
    rdfs:comment 'EPA emissions standard certification level for this vehicle class (e.g., EPA 2010, EPA 2021, CARB Ultra-Low NOx).' ;
    rdfs:domain ind:VehicleClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endorsementsRequired rdf:type rdf:Property ;
    rdfs:label 'Endorsements Required' ;
    rdfs:comment 'Comma-separated list of CDL endorsements required for this vehicle class (e.g., H for hazmat, N for tank, X for hazmat+tank). Null if no endorsements required.' ;
    rdfs:domain ind:VehicleClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedUsefulLifeMiles rdf:type rdf:Property ;
    rdfs:label 'Expected Useful Life Miles' ;
    rdfs:comment 'Expected useful life of vehicles in this class measured in miles before replacement is typically required.' ;
    rdfs:domain ind:VehicleClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:expectedUsefulLifeYears rdf:type rdf:Property ;
    rdfs:label 'Expected Useful Life Years' ;
    rdfs:comment 'Expected useful life of vehicles in this class measured in years before replacement is typically required.' ;
    rdfs:domain ind:VehicleClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gvwrLbs rdf:type rdf:Property ;
    rdfs:label 'Gvwr Lbs' ;
    rdfs:comment 'Gross Vehicle Weight Rating in pounds. Maximum total weight of the vehicle including chassis, body, fuel, and payload as specified by the manufacturer.' ;
    rdfs:domain ind:VehicleClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:manufacturerMake rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Make' ;
    rdfs:comment 'Typical or preferred manufacturer make for vehicles in this class (e.g., Peterbilt, Mack, Freightliner, Autocar).' ;
    rdfs:domain ind:VehicleClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pmIntervalDays rdf:type rdf:Property ;
    rdfs:label 'Pm Interval Days' ;
    rdfs:comment 'Standard preventive maintenance interval in calendar days for vehicles in this class. PM = Preventive Maintenance.' ;
