    rdfs:comment 'Master reference table for cash_pool. Referenced by cash_pool_id.' .

ind:LegalEntity rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Legal Entity' ;
    rdfs:comment 'Master reference table for legal_entity. Referenced by lessee_entity_id.' .

ind:Lessor rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fleet ;
    rdfs:label 'Lessor' ;
    rdfs:comment 'Master reference table for lessor. Referenced by lessor_id.' .

ind:Carrier rdf:type rdfs:Class ;
