    rdfs:comment 'Master reference table for bank. Referenced by bank_id.' .

# --- Attribute Properties ---
ind:airportIropEventId rdf:type rdf:Property ;
    rdfs:label 'Airport Irop Event Id' ;
    rdfs:comment 'Unique identifier for the airport IROP event record. Primary key for the airport_irop_event product.' ;
    rdfs:domain ind:AirportIropEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:employeeId rdf:type rdf:Property ;
    rdfs:label 'Employee Id' ;
    rdfs:comment 'Identifier of the airport operations manager or duty manager responsible for coordinating the IROP response at the affected station.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:occurrenceId rdf:type rdf:Property ;
    rdfs:label 'Occurrence Id' ;
    rdfs:comment 'Foreign key linking to safety.occurrence. Business justification: IROPs often involve or trigger safety occurrences (emergency evacuations, passenger injuries, operational deviations under pressure). IROP context is essential for understanding safety events during i' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Occurrence .

ind:stationId rdf:type rdf:Property ;
    rdfs:label 'Station Id' ;
    rdfs:comment 'Foreign key linking to airport.station. Business justification: airport_irop_event affects a specific station. Currently stores affected_station_code (STRING). FK to station provides access to station details, operational capabilities, and ground handler informati' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Station .

ind:atcRestrictionType rdf:type rdf:Property ;
    rdfs:label 'Atc Restriction Type' ;
    rdfs:comment 'Type of ATC restriction imposed during the IROP event if ATC-related. Examples: ground stop, ground delay program, flow control, airspace closure, reduced arrival rate, departure spacing.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancelledFlightCount rdf:type rdf:Property ;
    rdfs:label 'Cancelled Flight Count' ;
    rdfs:comment 'Number of flights cancelled as a direct result of this IROP event.' ;
    rdfs:domain ind:AirportIropEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cdmCoordinationFlag rdf:type rdf:Property ;
    rdfs:label 'Cdm Coordination Flag' ;
    rdfs:comment 'Indicates whether this IROP event required CDM coordination with airport authority, ATC, and other stakeholders. True if CDM messages were exchanged for collaborative recovery planning.' ;
    rdfs:domain ind:AirportIropEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:createdTimestamp rdf:type rdf:Property ;
    rdfs:label 'Created Timestamp' ;
    rdfs:comment 'Date and time when this IROP event record was first created in the system. Represents initial event detection and logging.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:delayedFlightCount rdf:type rdf:Property ;
    rdfs:label 'Delayed Flight Count' ;
    rdfs:comment 'Number of flights delayed beyond scheduled departure or arrival time as a result of this IROP event.' ;
    rdfs:domain ind:AirportIropEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:divertedFlightCount rdf:type rdf:Property ;
    rdfs:label 'Diverted Flight Count' ;
    rdfs:comment 'Number of flights diverted to alternate airports as a result of this IROP event.' ;
    rdfs:domain ind:AirportIropEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:durationMinutes rdf:type rdf:Property ;
    rdfs:label 'Duration Minutes' ;
    rdfs:comment 'Total duration of the IROP event in minutes, calculated from start to end timestamp. Null if event is still active.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedCostCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Estimated Cost Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the estimated cost impact amount.' ;
    rdfs:domain ind:AirportIropEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedCostImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Cost Impact Amount' ;
    rdfs:comment 'Estimated total financial impact of the IROP event in the airline\'s reporting currency, including passenger compensation, crew costs, fuel, rebooking, catering, and ground handling expenses.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eventNarrative rdf:type rdf:Property ;
    rdfs:label 'Event Narrative' ;
    rdfs:comment 'Free-text narrative describing the IROP event circumstances, operational response, challenges encountered, and lessons learned. Provides qualitative context for post-event analysis.' ;
    rdfs:domain ind:AirportIropEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateReassignmentCount rdf:type rdf:Property ;
    rdfs:label 'Gate Reassignment Count' ;
    rdfs:comment 'Number of gate reassignments executed as a result of this IROP event to accommodate delayed, diverted, or rescheduled flights.' ;
    rdfs:domain ind:AirportIropEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:impactedFlightCount rdf:type rdf:Property ;
    rdfs:label 'Impacted Flight Count' ;
    rdfs:comment 'Total number of flight legs affected by this IROP event, including delayed, cancelled, diverted, and returned flights.' ;
    rdfs:domain ind:AirportIropEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:impactedPaxCount rdf:type rdf:Property ;
    rdfs:label 'Impacted Pax Count' ;
    rdfs:comment 'Total number of passengers affected by this IROP event across all impacted flights. Includes passengers requiring reaccommodation, rebooking, or compensation.' ;
    rdfs:domain ind:AirportIropEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:iropEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Irop End Timestamp' ;
    rdfs:comment 'Date and time when the IROP event was resolved and normal operations resumed. Null if the event is still active.' ;
    rdfs:domain ind:AirportIropEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:iropReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Irop Reference Number' ;
    rdfs:comment 'Business identifier for the IROP event, formatted as IROP-{station}-{date}-{sequence}. Used for cross-system coordination and operational communication.' ;
    rdfs:domain ind:AirportIropEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iropStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Irop Start Timestamp' ;
    rdfs:comment 'Date and time when the IROP event began affecting airport operations. Represents the initial detection or onset of the irregular condition.' ;
    rdfs:domain ind:AirportIropEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:iropSubtypeCode rdf:type rdf:Property ;
    rdfs:label 'Irop Subtype Code' ;
    rdfs:comment 'Detailed classification within the IROP type. Examples: for WEATHER - thunderstorm, fog, snow, ice, wind; for ATC - flow control, airspace closure, slot restriction; for MECHANICAL - engine, hydraulic, avionics, APU; for SECURITY - threat, incident, screening delay; for CREW - sick call, duty time, positioning; for AIRPORT_CLOSURE - runway closure, terminal evacuation, equipment failure.' ;
    rdfs:domain ind:AirportIropEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iropTypeCode rdf:type rdf:Property ;
    rdfs:label 'Irop Type Code' ;
    rdfs:comment 'Classification of the IROP event cause. Weather includes storms, fog, snow, ice; ATC includes air traffic control delays and restrictions; Mechanical includes aircraft technical issues; Security includes security incidents and threats; Crew includes crew availability and legality issues; Airport Closure includes runway closures and facility shutdowns.' ;
    rdfs:domain ind:AirportIropEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Modified Timestamp' ;
    rdfs:comment 'Date and time when this IROP event record was last updated. Tracks ongoing event management and status changes.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lessonsLearnedDocumentedFlag rdf:type rdf:Property ;
    rdfs:label 'Lessons Learned Documented Flag' ;
    rdfs:comment 'Indicates whether lessons learned from this IROP event have been documented and shared with operations teams for continuous improvement.' ;
    rdfs:domain ind:AirportIropEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notamReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Notam Reference Number' ;
    rdfs:comment 'Reference number of the NOTAM issued in connection with this IROP event, if applicable. Links to official airspace or airport facility notifications.' ;
    rdfs:domain ind:AirportIropEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationalStatus rdf:type rdf:Property ;
    rdfs:label 'Operational Status' ;
    rdfs:comment 'Current lifecycle status of the IROP event. ACTIVE: event is ongoing and impacting operations; MONITORING: event conditions present but not yet impacting; RECOVERING: event ended, recovery actions in progress; RESOLVED: all recovery actions complete; CLOSED: event fully documented and archived.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationsControlCenterCode rdf:type rdf:Property ;
    rdfs:label 'Operations Control Center Code' ;
    rdfs:comment 'Three-letter code identifying the airline operations control center responsible for managing this IROP event and coordinating recovery actions.' ;
    rdfs:domain ind:AirportIropEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passengerCompensationTriggeredFlag rdf:type rdf:Property ;
    rdfs:label 'Passenger Compensation Triggered Flag' ;
    rdfs:comment 'Indicates whether this IROP event triggered passenger compensation obligations under EU261, DOT regulations, or airline policy due to delay duration, cancellation, or denied boarding.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reaccommodationActionCount rdf:type rdf:Property ;
    rdfs:label 'Reaccommodation Action Count' ;
    rdfs:comment 'Number of passenger reaccommodation actions (rebooking, rerouting, refund) processed as a result of this IROP event.' ;
    rdfs:domain ind:AirportIropEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recoveryPlanReference rdf:type rdf:Property ;
    rdfs:label 'Recovery Plan Reference' ;
    rdfs:comment 'Reference identifier for the operational recovery plan document or system record created to manage this IROP event. Links to detailed recovery actions, resource allocation, and timeline.' ;
    rdfs:domain ind:AirportIropEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryNotificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Required Flag' ;
    rdfs:comment 'Indicates whether this IROP event requires notification to regulatory authorities (FAA, EASA, DOT, national CAA) due to severity, passenger rights implications, or safety concerns.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryNotificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Timestamp' ;
    rdfs:comment 'Date and time when regulatory authorities were notified of this IROP event. Null if notification was not required or not yet completed.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rootCauseAnalysisCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'Root Cause Analysis Completed Flag' ;
    rdfs:comment 'Indicates whether a formal root cause analysis has been completed for this IROP event. True if RCA documentation exists.' ;
    rdfs:domain ind:AirportIropEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:severityLevel rdf:type rdf:Property ;
    rdfs:label 'Severity Level' ;
    rdfs:comment 'Classification of the IROP event impact severity. MINOR: 1-5 flights affected, minimal passenger impact; MODERATE: 6-15 flights, localized disruption; MAJOR: 16-50 flights, significant operational impact; CRITICAL: 50+ flights, widespread disruption requiring executive coordination.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:turnaroundDelayCount rdf:type rdf:Property ;
    rdfs:label 'Turnaround Delay Count' ;
    rdfs:comment 'Number of aircraft turnarounds delayed beyond target turnaround time as a result of this IROP event.' ;
    rdfs:domain ind:AirportIropEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:weatherConditionDescription rdf:type rdf:Property ;
    rdfs:label 'Weather Condition Description' ;
    rdfs:comment 'Detailed description of weather conditions during the IROP event if weather-related. Includes visibility, ceiling, wind speed/direction, precipitation type, temperature, and relevant METAR/TAF information.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baggageIrregularityId rdf:type rdf:Property ;
    rdfs:label 'Baggage Irregularity Id' ;
    rdfs:comment 'Unique identifier for the baggage irregularity record. Primary key for this entity.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BaggageIrregularity .

ind:baggageItemId rdf:type rdf:Property ;
    rdfs:label 'Baggage Item Id' ;
    rdfs:comment 'Foreign key linking to airport.baggage_item. Business justification: baggage_irregularity is about a specific baggage_item. Currently stores bag_tag_number (STRING) for lookup. FK to baggage_item provides direct access to bag details, routing, passenger, and flight inf' ;
    rdfs:domain ind:Airport ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BaggageItem .

ind:flightLegId rdf:type rdf:Property ;
    rdfs:label 'Flight Leg Id' ;
    rdfs:comment 'Reference to the flight on which the baggage irregularity occurred or was discovered.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FlightLeg .

ind:generalLedgerId rdf:type rdf:Property ;
    rdfs:label 'General Ledger Id' ;
    rdfs:comment 'Foreign key linking to finance.general_ledger. Business justification: Baggage compensation liability and interim expenses are posted to general ledger for financial statement reporting, accrual accounting, and DOT baggage mishandling cost reporting. Essential for accura' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GeneralLedger .

ind:handlerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Handler Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: PIR cases assigned to specific workforce customer service agents for passenger communication, WorldTracer updates, and resolution tracking. Required for case accountability and performance metrics.' ;
    rdfs:domain ind:BaggageIrregularity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:paxProfileId rdf:type rdf:Property ;
    rdfs:label 'Pax Profile Id' ;
    rdfs:comment 'Reference to the passenger who owns the mishandled baggage.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Profile .

ind:reportStationId rdf:type rdf:Property ;
    rdfs:label 'Report Station Id' ;
    rdfs:comment 'Foreign key linking to airport.station. Business justification: baggage_irregularity is reported at a specific station. Currently stores report_station_code (STRING). FK to station provides access to station details and ground handler responsible. The report_stati' ;
    rdfs:domain ind:BaggageIrregularity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Station .

ind:bagColor rdf:type rdf:Property ;
    rdfs:label 'Bag Color' ;
    rdfs:comment 'Primary color of the mishandled bag as reported by the passenger.' ;
    rdfs:domain ind:BaggageIrregularity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bagDescription rdf:type rdf:Property ;
    rdfs:label 'Bag Description' ;
    rdfs:comment 'Detailed physical description of the mishandled bag including color, brand, size, type, and distinguishing features to aid in identification and recovery.' ;
    rdfs:domain ind:BaggageIrregularity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bagType rdf:type rdf:Property ;
    rdfs:label 'Bag Type' ;
    rdfs:comment 'Type or category of the mishandled bag (e.g., suitcase, duffel, backpack, garment bag, sports equipment).' ;
    rdfs:domain ind:Airport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Closure Timestamp' ;
    rdfs:comment 'Date and time when the baggage irregularity case was officially closed, either due to successful delivery or final settlement.' ;
    rdfs:domain ind:BaggageIrregularity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:compensationAmount rdf:type rdf:Property ;
    rdfs:label 'Compensation Amount' ;
    rdfs:comment 'Actual compensation amount paid to the passenger for the baggage irregularity, including interim expenses and final settlement.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compensationCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Compensation Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the compensation amount.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentsDescription rdf:type rdf:Property ;
    rdfs:label 'Contents Description' ;
    rdfs:comment 'Description of the bag contents as declared by the passenger, used for identification and liability assessment.' ;
    rdfs:domain ind:BaggageIrregularity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declaredValueAmount rdf:type rdf:Property ;
    rdfs:label 'Declared Value Amount' ;
    rdfs:comment 'Monetary value of the bag contents as declared by the passenger for liability and compensation purposes.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:declaredValueCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Declared Value Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the declared value amount.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveredTimestamp rdf:type rdf:Property ;
    rdfs:label 'Delivered Timestamp' ;
    rdfs:comment 'Date and time when the recovered bag was successfully delivered to the passenger or their designated location.' ;
    rdfs:domain ind:BaggageIrregularity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:destinationStationCode rdf:type rdf:Property ;
    rdfs:label 'Destination Station Code' ;
    rdfs:comment 'Three-letter IATA airport code of the passenger\'s final destination where the bag should have arrived.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dotReportableFlag rdf:type rdf:Property ;
    rdfs:label 'Dot Reportable Flag' ;
    rdfs:comment 'Indicates whether this irregularity qualifies as a mishandled bag under DOT reporting requirements (delayed, damaged, lost, or pilfered).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:flightDate rdf:type rdf:Property ;
    rdfs:label 'Flight Date' ;
    rdfs:comment 'Scheduled departure date of the flight associated with the baggage irregularity.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:flightNumber rdf:type rdf:Property ;
    rdfs:label 'Flight Number' ;
    rdfs:comment 'Flight number on which the baggage irregularity occurred. Includes carrier code and flight number (e.g., AA1234).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forwardingInstructions rdf:type rdf:Property ;
    rdfs:label 'Forwarding Instructions' ;
    rdfs:comment 'Detailed instructions for forwarding the recovered bag to the passenger, including delivery address, contact information, and special handling requirements.' ;
    rdfs:domain ind:BaggageIrregularity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forwardingStationCode rdf:type rdf:Property ;
    rdfs:label 'Forwarding Station Code' ;
    rdfs:comment 'Three-letter IATA airport code of the station to which the recovered bag will be forwarded for delivery to the passenger.' ;
    rdfs:domain ind:BaggageIrregularity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handlingCarrierCode rdf:type rdf:Property ;
    rdfs:label 'Handling Carrier Code' ;
    rdfs:comment 'Two or three-character IATA airline code of the carrier currently handling the baggage irregularity case and recovery efforts.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interimExpenseAmount rdf:type rdf:Property ;
    rdfs:label 'Interim Expense Amount' ;
    rdfs:comment 'Amount reimbursed to passenger for interim expenses incurred due to delayed baggage (e.g., toiletries, clothing purchases).' ;
    rdfs:domain ind:BaggageIrregularity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:irregularityTypeCode rdf:type rdf:Property ;
    rdfs:label 'Irregularity Type Code' ;
    rdfs:comment 'IATA standard code classifying the type of baggage irregularity. DL=Delayed, MS=Misrouted, DF=Defaced, PL=Pilfered, DM=Damaged, RT=Retained, FD=Fraud, OV=Overage, RU=Rush, LT=Lost. [ENUM-REF-CANDIDATE: DL|MS|DF|PL|DM|RT|FD|OV|RU|LT — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BaggageIrregularity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irregularityTypeDescription rdf:type rdf:Property ;
    rdfs:label 'Irregularity Type Description' ;
    rdfs:comment 'Detailed description of the baggage irregularity type providing additional context beyond the standard code.' ;
    rdfs:domain ind:BaggageIrregularity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastKnownLocationCode rdf:type rdf:Property ;
    rdfs:label 'Last Known Location Code' ;
    rdfs:comment 'Three-letter IATA airport code of the last confirmed location where the bag was scanned or sighted in the baggage handling system.' ;
    rdfs:domain ind:BaggageIrregularity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastKnownLocationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Known Location Timestamp' ;
    rdfs:comment 'Date and time when the bag was last scanned or confirmed at the last known location.' ;
    rdfs:domain ind:BaggageIrregularity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:liabilityAmount rdf:type rdf:Property ;
    rdfs:label 'Liability Amount' ;
    rdfs:comment 'Calculated airline liability amount for the baggage irregularity based on applicable regulations and declared value.' ;
    rdfs:domain ind:BaggageIrregularity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:liabilityCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Liability Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the liability amount.' ;
    rdfs:domain ind:BaggageIrregularity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Located Timestamp' ;
    rdfs:comment 'Date and time when the mishandled bag was located and identified in the baggage handling system.' ;
    rdfs:domain ind:BaggageIrregularity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pirNumber rdf:type rdf:Property ;
    rdfs:label 'Pir Number' ;
    rdfs:comment 'Unique PIR number assigned to the baggage irregularity case. Format typically includes station code followed by sequential number. This is the externally-known business identifier for the irregularity.' ;
    rdfs:domain ind:BaggageIrregularity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pnrLocator rdf:type rdf:Property ;
    rdfs:label 'Pnr Locator' ;
    rdfs:comment 'Six-character alphanumeric PNR locator code associated with the passenger\'s booking. Used to link the irregularity to the reservation.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recoveryStatusCode rdf:type rdf:Property ;
    rdfs:label 'Recovery Status Code' ;
    rdfs:comment 'Current status of the baggage recovery process. OP=Open/In Progress, LO=Located, FD=Found and Delivered, DL=Delivered, CL=Closed.' ;
    rdfs:domain ind:BaggageIrregularity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recoveryStatusDescription rdf:type rdf:Property ;
    rdfs:label 'Recovery Status Description' ;
    rdfs:comment 'Detailed description of the current recovery status providing additional context and updates on recovery efforts.' ;
    rdfs:domain ind:BaggageIrregularity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Flag' ;
    rdfs:comment 'Indicates whether this baggage irregularity must be included in regulatory reporting to DOT, IATA, or other aviation authorities.' ;
    rdfs:domain ind:Airport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportTimestamp rdf:type rdf:Property ;
    rdfs:label 'Report Timestamp' ;
    rdfs:comment 'Date and time when the baggage irregularity was reported to airline staff. This is the principal business event timestamp for the irregularity lifecycle.' ;
    rdfs:domain ind:BaggageIrregularity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:responsibleCarrierCode rdf:type rdf:Property ;
    rdfs:label 'Responsible Carrier Code' ;
    rdfs:comment 'Two or three-character IATA airline code of the carrier determined to be responsible for the baggage irregularity.' ;
    rdfs:domain ind:BaggageIrregularity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:worldtracerReference rdf:type rdf:Property ;
    rdfs:label 'Worldtracer Reference' ;
    rdfs:comment 'Global baggage tracing reference number from IATA WorldTracer system used for international baggage tracking and recovery coordination across airlines.' ;
    rdfs:domain ind:BaggageIrregularity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acceptanceStationId rdf:type rdf:Property ;
    rdfs:label 'Acceptance Station Id' ;
    rdfs:comment 'Foreign key linking to airport.station. Business justification: baggage_item is accepted at a specific station. Currently stores acceptance_station_code (STRING). FK to station provides access to station details, time zone, and operational context. The acceptance_' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Station .

ind:acceptanceTimestamp rdf:type rdf:Property ;
    rdfs:label 'Acceptance Timestamp' ;
    rdfs:comment 'Date and time when the baggage item was accepted at check-in. Marks the start of airline custody and liability. Critical for baggage tracking and service level monitoring.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:bagTagNumber rdf:type rdf:Property ;
    rdfs:label 'Bag Tag Number' ;
    rdfs:comment 'IATA standard 10-digit bag tag number printed on the baggage label. Globally unique identifier used for tracking and tracing throughout the baggage journey.' ;
    rdfs:domain ind:Airport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentLocationStationCode rdf:type rdf:Property ;
    rdfs:label 'Current Location Station Code' ;
    rdfs:comment 'Three-letter IATA airport code of the current physical location of the baggage item. Updated at each scan point throughout the journey.' ;
    rdfs:domain ind:BaggageItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentStatus rdf:type rdf:Property ;
    rdfs:label 'Current Status' ;
    rdfs:comment 'Current lifecycle status of the baggage item in the handling process. Reflects the latest state in the baggage journey from acceptance through delivery. [ENUM-REF-CANDIDATE: accepted|loaded|in_transit|arrived|delivered|mishandled|delayed|damaged|lost — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BaggageItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declaredValueCurrency rdf:type rdf:Property ;
    rdfs:label 'Declared Value Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the declared value amount. Supports multi-currency operations across international route networks.' ;
    rdfs:domain ind:BaggageItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Delivery Timestamp' ;
    rdfs:comment 'Date and time when the baggage item was delivered to the passenger or authorized recipient at the final destination. Marks the end of airline custody and liability.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:excessBaggageChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Excess Baggage Charge Amount' ;
    rdfs:comment 'Additional charge amount collected for this baggage item if it exceeds the free baggage allowance. Null if no excess charge applies.' ;
    rdfs:domain ind:Airport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:excessBaggageChargeCurrency rdf:type rdf:Property ;
    rdfs:label 'Excess Baggage Charge Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the excess baggage charge amount. Null if no excess charge applies.' ;
    rdfs:domain ind:Airport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finalDestinationStationCode rdf:type rdf:Property ;
    rdfs:label 'Final Destination Station Code' ;
    rdfs:comment 'Three-letter IATA airport code of the final destination where the baggage item should be delivered to the passenger. End point for baggage routing.' ;
    rdfs:domain ind:BaggageItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:heightCm rdf:type rdf:Property ;
    rdfs:label 'Height Cm' ;
    rdfs:comment 'Height dimension of the baggage item in centimeters. Used for oversized baggage determination and ULD planning.' ;
    rdfs:domain ind:BaggageItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interlineIndicator rdf:type rdf:Property ;
    rdfs:label 'Interline Indicator' ;
    rdfs:comment 'Flag indicating whether this baggage item involves interline transfer between different carriers. True if the routing includes flights operated by partner airlines.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastScanTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Scan Timestamp' ;
    rdfs:comment 'Date and time of the most recent scan event for this baggage item. Used for real-time tracking and service level monitoring.' ;
    rdfs:domain ind:BaggageItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Updated Timestamp' ;
    rdfs:comment 'System timestamp when this baggage item record was most recently modified. Used for change tracking and data synchronization.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lengthCm rdf:type rdf:Property ;
    rdfs:label 'Length Cm' ;
    rdfs:comment 'Length dimension of the baggage item in centimeters. Used for oversized baggage determination and ULD (Unit Load Device) planning.' ;
    rdfs:domain ind:BaggageItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mishandlingCode rdf:type rdf:Property ;
    rdfs:label 'Mishandling Code' ;
    rdfs:comment 'Classification of baggage mishandling incident if applicable. Used for service recovery, compensation determination, and quality metrics reporting.' ;
    rdfs:domain ind:BaggageItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mishandlingReportNumber rdf:type rdf:Property ;
    rdfs:label 'Mishandling Report Number' ;
    rdfs:comment 'Unique identifier of the Property Irregularity Report (PIR) or baggage claim filed for this item if mishandled. Links to the baggage claims system.' ;
    rdfs:domain ind:BaggageItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pnr rdf:type rdf:Property ;
    rdfs:label 'Pnr' ;
    rdfs:comment 'Six-character alphanumeric Passenger Name Record identifier linking this baggage item to the booking. Used for reservation system integration and passenger association.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityHandlingCode rdf:type rdf:Property ;
    rdfs:label 'Priority Handling Code' ;
    rdfs:comment 'Special handling priority assigned to the baggage item. Determines expedited processing for tight connections, premium passengers, or operational requirements.' ;
    rdfs:domain ind:BaggageItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingSequence rdf:type rdf:Property ;
    rdfs:label 'Routing Sequence' ;
    rdfs:comment 'Planned routing path for the baggage item through connecting stations. Formatted as a sequence of IATA airport codes representing the complete journey.' ;
    rdfs:domain ind:BaggageItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityScreeningStatus rdf:type rdf:Property ;
    rdfs:label 'Security Screening Status' ;
    rdfs:comment 'Result of security screening process for this baggage item. Indicates whether the bag has been cleared for loading or requires additional inspection.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityScreeningTimestamp rdf:type rdf:Property ;
    rdfs:label 'Security Screening Timestamp' ;
    rdfs:comment 'Date and time when security screening was completed for this baggage item. Required for regulatory compliance and audit trail.' ;
    rdfs:domain ind:BaggageItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:specialServiceRequestCodes rdf:type rdf:Property ;
    rdfs:label 'Special Service Request Codes' ;
    rdfs:comment 'Comma-separated list of IATA SSR codes indicating special handling requirements for this baggage item (e.g., FRAG for fragile, BIKE for bicycle, PETC for pet in cabin).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uldNumber rdf:type rdf:Property ;
    rdfs:label 'Uld Number' ;
    rdfs:comment 'Identifier of the Unit Load Device (container or pallet) in which this baggage item is loaded for transport. Null if loaded as bulk baggage.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightKg rdf:type rdf:Property ;
    rdfs:label 'Weight Kg' ;
    rdfs:comment 'Actual weight of the baggage item measured in kilograms at acceptance. Used for load planning, excess baggage charge calculation, and regulatory compliance.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:widthCm rdf:type rdf:Property ;
    rdfs:label 'Width Cm' ;
    rdfs:comment 'Width dimension of the baggage item in centimeters. Used for oversized baggage determination and ULD planning.' ;
    rdfs:domain ind:BaggageItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baggageScanId rdf:type rdf:Property ;
    rdfs:label 'Baggage Scan Id' ;
    rdfs:comment 'Unique identifier for each baggage scan event in the baggage handling system. Primary key for the baggage scan transaction record.' ;
    rdfs:domain ind:BaggageScan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualConnectTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Actual Connect Time Minutes' ;
    rdfs:comment 'Actual elapsed time in minutes between the inbound flight arrival scan and the outbound flight departure scan for transfer baggage. Used for connection performance analysis.' ;
    rdfs:domain ind:BaggageScan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:baggageType rdf:type rdf:Property ;
    rdfs:label 'Baggage Type' ;
    rdfs:comment 'Classification of the baggage item based on handling requirements and passenger service level. Determines handling priority and routing logic.' ;
    rdfs:domain ind:BaggageScan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baggageWeightKg rdf:type rdf:Property ;
    rdfs:label 'Baggage Weight Kg' ;
    rdfs:comment 'Weight of the baggage item in kilograms as measured at check-in or during handling. Used for load planning and excess baggage charge calculation.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cdmMessageType rdf:type rdf:Property ;
    rdfs:label 'Cdm Message Type' ;
    rdfs:comment 'Type of Airport CDM message generated by this baggage scan event for sharing with airport collaborative decision-making systems and stakeholders.' ;
    rdfs:domain ind:BaggageScan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conveyorBeltCode rdf:type rdf:Property ;
    rdfs:label 'Conveyor Belt Code' ;
    rdfs:comment 'Identifier of the specific conveyor belt or carousel within the baggage handling system where the scan occurred or where the bag was routed.' ;
    rdfs:domain ind:BaggageScan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsStatus rdf:type rdf:Property ;
    rdfs:label 'Customs Status' ;
    rdfs:comment 'Customs clearance status for international baggage items indicating whether the bag has been cleared for entry or requires inspection by customs authorities.' ;
    rdfs:domain ind:BaggageScan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationAirportCode rdf:type rdf:Property ;
    rdfs:label 'Destination Airport Code' ;
    rdfs:comment 'Three-letter IATA code of the final destination airport for the baggage item as determined from the bag tag and flight routing information.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionFlag rdf:type rdf:Property ;
    rdfs:label 'Exception Flag' ;
    rdfs:comment 'Boolean indicator identifying whether this scan event represents an irregular or exception condition requiring manual intervention or investigation.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exceptionReasonCode rdf:type rdf:Property ;
    rdfs:label 'Exception Reason Code' ;
    rdfs:comment 'Standardized code describing the nature of the baggage handling exception such as misrouted, delayed, damaged, or security hold. Populated only when exception_flag is true.' ;
    rdfs:domain ind:BaggageScan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iata753ComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Iata 753 Compliance Flag' ;
    rdfs:comment 'Boolean indicator confirming whether this scan event meets IATA Resolution 753 baggage tracking requirements for mandatory scan point reporting.' ;
    rdfs:domain ind:BaggageScan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:makeupPosition rdf:type rdf:Property ;
    rdfs:label 'Makeup Position' ;
    rdfs:comment 'Specific location identifier within the baggage makeup area where bags are staged for loading onto the aircraft. Used for ground crew coordination.' ;
    rdfs:domain ind:BaggageScan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumConnectTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Minimum Connect Time Minutes' ;
    rdfs:comment 'Minimum connection time in minutes required for successful baggage transfer between the inbound and outbound flights. Used to identify at-risk connections.' ;
    rdfs:domain ind:BaggageScan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originAirportCode rdf:type rdf:Property ;
    rdfs:label 'Origin Airport Code' ;
    rdfs:comment 'Three-letter IATA code of the originating airport where the baggage item was first checked in by the passenger.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passengerName rdf:type rdf:Property ;
    rdfs:label 'Passenger Name' ;
    rdfs:comment 'Full name of the passenger who checked the baggage item. Used for baggage claim verification and irregular baggage handling.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Created Timestamp' ;
    rdfs:comment 'System timestamp when this baggage scan record was first inserted into the data platform. Used for data lineage and audit trail purposes.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Updated Timestamp' ;
    rdfs:comment 'System timestamp when this baggage scan record was last modified in the data platform. Supports change tracking and data quality monitoring.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scanDataSource rdf:type rdf:Property ;
    rdfs:label 'Scan Data Source' ;
    rdfs:comment 'Type of data capture device or system that generated the baggage scan record. Used for data quality assessment and system performance monitoring.' ;
    rdfs:domain ind:BaggageScan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scanDeviceCode rdf:type rdf:Property ;
    rdfs:label 'Scan Device Code' ;
    rdfs:comment 'Unique identifier of the physical scanning device or reader that captured the bag tag. Used for device performance tracking and maintenance scheduling.' ;
    rdfs:domain ind:BaggageScan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scanPointType rdf:type rdf:Property ;
    rdfs:label 'Scan Point Type' ;
    rdfs:comment 'Classification of the baggage handling process stage where the scan occurred. Identifies the functional area within the airport baggage system.' ;
    rdfs:domain ind:BaggageScan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scanResultStatus rdf:type rdf:Property ;
    rdfs:label 'Scan Result Status' ;
    rdfs:comment 'Outcome of the baggage tag scan attempt indicating whether the tag was successfully read by the automated system or required manual intervention.' ;
    rdfs:domain ind:Airport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scanSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Scan Sequence Number' ;
    rdfs:comment 'Sequential order number of this scan event within the complete baggage journey for the specific bag tag. Enables chronological reconstruction of bag movement.' ;
    rdfs:domain ind:BaggageScan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scanTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scan Timestamp' ;
    rdfs:comment 'Precise date and time when the baggage scan event occurred in the baggage handling system. Represents the real-world event time of the scan operation.' ;
    rdfs:domain ind:Airport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sortationDecision rdf:type rdf:Property ;
    rdfs:label 'Sortation Decision' ;
    rdfs:comment 'Routing decision made by the baggage handling system determining the next destination for the baggage item based on flight information and system logic.' ;
    rdfs:domain ind:BaggageScan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialServiceRequestCode rdf:type rdf:Property ;
    rdfs:label 'Special Service Request Code' ;
    rdfs:comment 'IATA standard code indicating special handling requirements for the baggage item such as fragile, perishable, live animals, or medical equipment.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferConnectionFlag rdf:type rdf:Property ;
    rdfs:label 'Transfer Connection Flag' ;
    rdfs:comment 'Boolean indicator identifying whether this baggage item is part of a connecting itinerary requiring transfer between flights at this airport.' ;
    rdfs:domain ind:BaggageScan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:boardingEventId rdf:type rdf:Property ;
    rdfs:label 'Boarding Event Id' ;
    rdfs:comment 'Unique identifier for the boarding event record. Primary key.' ;
    rdfs:domain ind:BoardingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ffpMemberId rdf:type rdf:Property ;
    rdfs:label 'Ffp Member Id' ;
    rdfs:comment 'Foreign key linking to loyalty.ffp_member. Business justification: Events capture frequent_flyer_number and tier (denormalized strings); FK enables real-time boarding analytics by tier, priority boarding enforcement validation, operational loyalty metrics, and member' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FfpMember .

ind:gateAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Gate Assignment Id' ;
    rdfs:comment 'Reference to the gate assignment where boarding took place.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GateAssignment .

ind:boardingActionTaken rdf:type rdf:Property ;
    rdfs:label 'Boarding Action Taken' ;
    rdfs:comment 'Description of any special action taken during boarding such as offload, reaccommodation, security hold, or manual verification.' ;
    rdfs:domain ind:BoardingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boardingDoorUsed rdf:type rdf:Property ;
    rdfs:label 'Boarding Door Used' ;
    rdfs:comment 'Identifier of the aircraft door or boarding method used (jetbridge door, remote stairs, bus gate).' ;
    rdfs:domain ind:BoardingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boardingMethod rdf:type rdf:Property ;
    rdfs:label 'Boarding Method' ;
    rdfs:comment 'Method by which the boarding event was captured: automated gate reader, agent-assisted scan, manual entry, mobile device scan, or biometric verification.' ;
    rdfs:domain ind:BoardingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boardingPassBarcode rdf:type rdf:Property ;
    rdfs:label 'Boarding Pass Barcode' ;
    rdfs:comment 'Barcode or QR code scanned from the passenger boarding pass (BCBP format).' ;
    rdfs:domain ind:Airport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boardingSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Boarding Sequence Number' ;
    rdfs:comment 'Sequential order in which the passenger boarded the aircraft relative to other passengers on the same flight.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:boardingZone rdf:type rdf:Property ;
    rdfs:label 'Boarding Zone' ;
    rdfs:comment 'Designated boarding zone or group assigned to the passenger for orderly boarding process.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cabinClass rdf:type rdf:Property ;
    rdfs:label 'Cabin Class' ;
    rdfs:comment 'Cabin class in which the passenger is seated for this flight leg.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carryOnBaggageCount rdf:type rdf:Property ;
    rdfs:label 'Carry On Baggage Count' ;
    rdfs:comment 'Number of carry-on baggage pieces the passenger brought to the gate.' ;
    rdfs:domain ind:BoardingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:checkedBaggageCount rdf:type rdf:Property ;
    rdfs:label 'Checked Baggage Count' ;
    rdfs:comment 'Number of checked baggage pieces associated with this passenger for this flight leg.' ;
    rdfs:domain ind:BoardingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:couponSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Coupon Sequence Number' ;
    rdfs:comment 'Sequential number of the flight coupon within the electronic ticket corresponding to this flight leg.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:frequentFlyerTier rdf:type rdf:Property ;
    rdfs:label 'Frequent Flyer Tier' ;
    rdfs:comment 'Current tier or status level of the passenger in the airline loyalty program.' ;
    rdfs:domain ind:BoardingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateReaderDeviceCode rdf:type rdf:Property ;
    rdfs:label 'Gate Reader Device Code' ;
    rdfs:comment 'Identifier of the automated gate reader or kiosk device that captured the boarding scan.' ;
    rdfs:domain ind:BoardingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irregularOperationFlag rdf:type rdf:Property ;
    rdfs:label 'Irregular Operation Flag' ;
    rdfs:comment 'Indicates whether this boarding event occurred during an irregular operation scenario such as delay, cancellation recovery, or diversion.' ;
    rdfs:domain ind:BoardingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:irregularOperationReason rdf:type rdf:Property ;
    rdfs:label 'Irregular Operation Reason' ;
    rdfs:comment 'Description of the irregular operation circumstance if irregular_operation_flag is true.' ;
    rdfs:domain ind:BoardingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCodesharePassenger rdf:type rdf:Property ;
    rdfs:label 'Is Codeshare Passenger' ;
    rdfs:comment 'Indicates whether the passenger booked through a codeshare partner airline.' ;
    rdfs:domain ind:BoardingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isInterlinePassenger rdf:type rdf:Property ;
    rdfs:label 'Is Interline Passenger' ;
    rdfs:comment 'Indicates whether the passenger is traveling on an interline itinerary involving multiple carriers.' ;
    rdfs:domain ind:BoardingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isStandbyPassenger rdf:type rdf:Property ;
    rdfs:label 'Is Standby Passenger' ;
    rdfs:comment 'Indicates whether the passenger was on standby status and cleared for boarding.' ;
    rdfs:domain ind:BoardingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isUpgradePassenger rdf:type rdf:Property ;
    rdfs:label 'Is Upgrade Passenger' ;
    rdfs:comment 'Indicates whether the passenger received a cabin class upgrade for this flight.' ;
    rdfs:domain ind:BoardingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketingCarrierCode rdf:type rdf:Property ;
    rdfs:label 'Marketing Carrier Code' ;
    rdfs:comment 'Two-character IATA airline code of the carrier under which the ticket was sold (may differ from operating carrier in codeshare scenarios).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingCarrierCode rdf:type rdf:Property ;
    rdfs:label 'Operating Carrier Code' ;
    rdfs:comment 'Two-character IATA airline code of the carrier operating the flight.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passengerTypeCode rdf:type rdf:Property ;
    rdfs:label 'Passenger Type Code' ;
    rdfs:comment 'IATA passenger type code indicating category such as adult, child, infant, military, senior, student, or youth. [ENUM-REF-CANDIDATE: ADT|CHD|INF|MIL|SRC|STU|YTH — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionReasonCode rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for boarding rejection if scan_result_status is rejected.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason Description' ;
    rdfs:comment 'Human-readable description of why the boarding was rejected or flagged.' ;
    rdfs:domain ind:BoardingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seatNumber rdf:type rdf:Property ;
    rdfs:label 'Seat Number' ;
    rdfs:comment 'Assigned seat number for the passenger on this flight (row and seat letter).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ticketNumber rdf:type rdf:Property ;
    rdfs:label 'Ticket Number' ;
    rdfs:comment 'Thirteen-digit electronic ticket number issued to the passenger.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdmMessageId rdf:type rdf:Property ;
    rdfs:label 'Cdm Message Id' ;
    rdfs:comment 'Unique identifier for the CDM message record. Primary key.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CdmMessage .

ind:aircraftId rdf:type rdf:Property ;
    rdfs:label 'Aircraft Id' ;
    rdfs:comment 'Foreign key linking to fleet.aircraft. Business justification: Airport Collaborative Decision Making (A-CDM) requires accurate aircraft tracking for TOBT calculation, turnaround monitoring, and departure sequencing. Critical for slot compliance and on-time perfor' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Aircraft .

ind:aobt rdf:type rdf:Property ;
    rdfs:label 'Aobt' ;
    rdfs:comment 'Actual time when the aircraft commenced pushback or taxi from the gate. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:CdmMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:atot rdf:type rdf:Property ;
    rdfs:label 'Atot' ;
    rdfs:comment 'Actual time when the aircraft became airborne. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:CdmMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cobt rdf:type rdf:Property ;
    rdfs:label 'Cobt' ;
    rdfs:comment 'Coordinated off-block time agreed upon by all CDM stakeholders (airline, airport, ATC, ground handler). Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:CdmMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:correlationReference rdf:type rdf:Property ;
    rdfs:label 'Correlation Reference' ;
    rdfs:comment 'Unique identifier used to correlate related CDM messages across multiple systems and message types for the same flight operation.' ;
    rdfs:domain ind:CdmMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ctot rdf:type rdf:Property ;
    rdfs:label 'Ctot' ;
    rdfs:comment 'Calculated take-off time assigned by the central flow management unit (e.g., EUROCONTROL Network Manager) for slot-controlled flights. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:CdmMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:delayCode rdf:type rdf:Property ;
    rdfs:label 'Delay Code' ;
    rdfs:comment 'IATA standard delay code associated with the flight at the time of the CDM message (e.g., 11-Aircraft defect, 81-Weather).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eobt rdf:type rdf:Property ;
    rdfs:label 'Eobt' ;
    rdfs:comment 'Estimated time when the aircraft will commence pushback or taxi, as estimated by the airline. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:CdmMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isSlotConstrained rdf:type rdf:Property ;
    rdfs:label 'Is Slot Constrained' ;
    rdfs:comment 'Indicates whether the flight is subject to slot constraints and requires CTOT coordination.' ;
    rdfs:domain ind:CdmMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:messagePriority rdf:type rdf:Property ;
    rdfs:label 'Message Priority' ;
    rdfs:comment 'Priority level assigned to the CDM message for processing and routing purposes.' ;
    rdfs:domain ind:CdmMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:messageTimestamp rdf:type rdf:Property ;
    rdfs:label 'Message Timestamp' ;
    rdfs:comment 'Date and time when the CDM message was created and transmitted. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:CdmMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:messageType rdf:type rdf:Property ;
    rdfs:label 'Message Type' ;
    rdfs:comment 'Type of CDM message: TOBT (Target Off-Block Time), TSAT (Target Start-Up Approval Time), TTOT (Target Take-Off Time), AOBT (Actual Off-Block Time), ATOT (Actual Take-Off Time), CTOT (Calculated Take-Off Time), DPI (Departure Planning Information), SRM (Slot Revision Message), EOBT (Estimated Off-Block Time), COBT (Coordinated Off-Block Time). [ENUM-REF-CANDIDATE: TOBT|TSAT|TTOT|AOBT|ATOT|CTOT|DPI|SRM|EOBT|COBT — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:messageVersion rdf:type rdf:Property ;
    rdfs:label 'Message Version' ;
    rdfs:comment 'Version number of the CDM message format or protocol used (e.g., CDM 1.0, CDM 2.0).' ;
    rdfs:domain ind:CdmMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originatingSystem rdf:type rdf:Property ;
    rdfs:label 'Originating System' ;
    rdfs:comment 'Name or identifier of the system that generated the CDM message (e.g., airline operations system, airport management platform, ATC system, ground handler system).' ;
    rdfs:domain ind:CdmMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingStatus rdf:type rdf:Property ;
    rdfs:label 'Processing Status' ;
    rdfs:comment 'Current processing status of the CDM message: received (message received by target system), validated (message passed validation checks), processed (message successfully processed and applied), rejected (message rejected due to validation errors), failed (message processing failed due to system error).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receiverOrganization rdf:type rdf:Property ;
    rdfs:label 'Receiver Organization' ;
    rdfs:comment 'Name or code of the organization intended to receive the CDM message.' ;
    rdfs:domain ind:CdmMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionReason rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason' ;
    rdfs:comment 'Detailed reason why the CDM message was rejected or failed processing, including error codes and descriptions.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Date' ;
    rdfs:comment 'Scheduled date of the flight operation. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:senderOrganization rdf:type rdf:Property ;
    rdfs:label 'Sender Organization' ;
    rdfs:comment 'Name or code of the organization that sent the CDM message (airline, airport authority, ATC, ground handler).' ;
    rdfs:domain ind:CdmMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Sequence Number' ;
    rdfs:comment 'Sequential number of the CDM message within a series of messages for the same flight, used to track message order and detect duplicates.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetSystem rdf:type rdf:Property ;
    rdfs:label 'Target System' ;
    rdfs:comment 'Name or identifier of the system intended to receive and process the CDM message.' ;
    rdfs:domain ind:CdmMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tobt rdf:type rdf:Property ;
    rdfs:label 'Tobt' ;
    rdfs:comment 'Target time when the aircraft is expected to commence pushback or taxi from the gate, provided by the airline. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:CdmMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:tsat rdf:type rdf:Property ;
    rdfs:label 'Tsat' ;
    rdfs:comment 'Target time provided by ATC for the aircraft to start engines and request pushback clearance. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:CdmMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ttot rdf:type rdf:Property ;
    rdfs:label 'Ttot' ;
    rdfs:comment 'Target time when the aircraft is expected to become airborne, calculated by the CDM system. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:CdmMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:turnaroundStatus rdf:type rdf:Property ;
    rdfs:label 'Turnaround Status' ;
    rdfs:comment 'Current status of the aircraft turnaround operation at the time of the CDM message.' ;
    rdfs:domain ind:Airport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Updated Timestamp' ;
    rdfs:comment 'Timestamp when this CDM message record was last updated in the data platform. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:checkinCounterId rdf:type rdf:Property ;
    rdfs:label 'Checkin Counter Id' ;
    rdfs:comment 'Unique identifier for the check-in counter or kiosk asset. Primary key for the check-in counter master record.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CheckinCounter .

ind:fixedAssetId rdf:type rdf:Property ;
    rdfs:label 'Fixed Asset Id' ;
    rdfs:comment 'Foreign key linking to finance.fixed_asset. Business justification: Check-in kiosks, CUTE/CUPPS workstations, and counter equipment are capitalized fixed assets requiring depreciation accounting, asset register tracking, and maintenance cost allocation. Required for f' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FixedAsset .

ind:terminalFacilityId rdf:type rdf:Property ;
    rdfs:label 'Terminal Facility Id' ;
    rdfs:comment 'Reference to the terminal facility where this check-in counter is located. Links to the terminal master record for facility-level attributes.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TerminalFacility .

ind:accessibilityCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Accessibility Compliant Flag' ;
    rdfs:comment 'Indicates whether the counter meets accessibility standards for passengers with reduced mobility (PRM). True if the counter has wheelchair-accessible height, clear approach space, and assistive technology per ADA/EASA regulations.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assignedAirlineCode rdf:type rdf:Property ;
    rdfs:label 'Assigned Airline Code' ;
    rdfs:comment 'Two or three-character IATA airline code for the carrier assigned to this counter. Null for common-use counters or when unassigned. Supports airline-specific counter allocation and billing.' ;
    rdfs:domain ind:CheckinCounter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedAllianceCode rdf:type rdf:Property ;
    rdfs:label 'Assigned Alliance Code' ;
    rdfs:comment 'Two-character code for the airline alliance assigned to this counter (e.g., *A for Star Alliance, ST for SkyTeam, OW for oneworld). Used for alliance-based counter pooling arrangements.' ;
    rdfs:domain ind:CheckinCounter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Availability Status' ;
    rdfs:comment 'Real-time availability state for resource scheduling. Available counters are ready for assignment; occupied counters are currently in use; closed counters are outside operating hours; blocked counters are reserved but not yet active.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageProcessingTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Average Processing Time Minutes' ;
    rdfs:comment 'Average time in minutes required to process one passenger at this counter. Used for capacity planning, staffing models, and passenger wait time estimation. Varies by counter type and service complexity.' ;
    rdfs:domain ind:CheckinCounter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baggageScaleIntegratedFlag rdf:type rdf:Property ;
    rdfs:label 'Baggage Scale Integrated Flag' ;
    rdfs:comment 'Indicates whether the counter has an integrated baggage weighing scale for checked baggage processing. True if scale hardware is present and connected to the departure control system.' ;
    rdfs:domain ind:CheckinCounter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:baggageTagPrinterAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Baggage Tag Printer Available Flag' ;
    rdfs:comment 'Indicates whether the counter has a baggage tag printer for printing IATA-compliant baggage tags. True if printer hardware is installed and operational for checked baggage processing.' ;
    rdfs:domain ind:CheckinCounter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:biometricCapabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Biometric Capability Flag' ;
    rdfs:comment 'Indicates whether the counter is equipped with biometric verification technology (facial recognition, fingerprint, iris scan). True if biometric hardware and software are installed and operational for identity verification.' ;
    rdfs:domain ind:Airport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:boardingPassPrinterType rdf:type rdf:Property ;
    rdfs:label 'Boarding Pass Printer Type' ;
    rdfs:comment 'Type of boarding pass printer installed at the counter. Thermal printers are common for self-service kiosks; laser printers are used at full-service counters; inkjet printers are rare; none indicates no printer (mobile boarding pass only).' ;
    rdfs:domain ind:CheckinCounter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterNumber rdf:type rdf:Property ;
    rdfs:label 'Counter Number' ;
    rdfs:comment 'The physical counter number or identifier displayed at the check-in position. Used for passenger wayfinding and operational coordination.' ;
    rdfs:domain ind:CheckinCounter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterPositionLatitude rdf:type rdf:Property ;
    rdfs:label 'Counter Position Latitude' ;
    rdfs:comment 'Geographic latitude coordinate of the counter location in decimal degrees. Supports indoor mapping, wayfinding applications, and spatial analytics for passenger flow optimization.' ;
    rdfs:domain ind:CheckinCounter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:counterPositionLongitude rdf:type rdf:Property ;
    rdfs:label 'Counter Position Longitude' ;
    rdfs:comment 'Geographic longitude coordinate of the counter location in decimal degrees. Supports indoor mapping, wayfinding applications, and spatial analytics for passenger flow optimization.' ;
    rdfs:domain ind:CheckinCounter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:counterType rdf:type rdf:Property ;
    rdfs:label 'Counter Type' ;
    rdfs:comment 'Classification of the check-in counter by service model. Full-service counters are staffed for full passenger processing; self-service kiosks enable passenger self-check-in; CUSS (Common Use Self-Service) are industry-standard kiosks; bag-drop counters accept pre-checked baggage; premium counters serve business/first class; group counters handle tour groups.' ;
    rdfs:domain ind:CheckinCounter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterZone rdf:type rdf:Property ;
    rdfs:label 'Counter Zone' ;
    rdfs:comment 'Logical zone or area designation within the terminal (e.g., Zone A, International Check-In, Domestic North). Used for capacity planning and passenger flow management.' ;
    rdfs:domain ind:CheckinCounter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cuteCuppsDeviceCode rdf:type rdf:Property ;
    rdfs:label 'Cute Cupps Device Code' ;
    rdfs:comment 'Device identifier for CUTE/CUPPS common-use systems. Enables multiple airlines to share the same counter infrastructure by dynamically switching airline applications on the workstation.' ;
    rdfs:domain ind:CheckinCounter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dcsWorkstationCode rdf:type rdf:Property ;
    rdfs:label 'Dcs Workstation Code' ;
    rdfs:comment 'Unique identifier for the DCS workstation or terminal assigned to this counter. Links the physical counter to the airline\'s passenger service system for check-in, boarding, and baggage processing.' ;
    rdfs:domain ind:CheckinCounter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveDate rdf:type rdf:Property ;
    rdfs:label 'Effective Date' ;
    rdfs:comment 'Date from which this counter configuration becomes active. Supports temporal tracking of counter assignments, configuration changes, and airline allocations for historical reporting and planning.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expiryDate rdf:type rdf:Property ;
    rdfs:label 'Expiry Date' ;
    rdfs:comment 'Date when this counter configuration expires or is superseded. Null for current active configurations. Enables temporal queries and historical analysis of counter utilization and assignments.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:installationDate rdf:type rdf:Property ;
    rdfs:label 'Installation Date' ;
    rdfs:comment 'Date when the counter was installed and commissioned for operational use. Supports asset lifecycle tracking, depreciation calculations, and replacement planning.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastMaintenanceDate rdf:type rdf:Property ;
    rdfs:label 'Last Maintenance Date' ;
    rdfs:comment 'Date of the most recent preventive or corrective maintenance performed on the counter equipment. Used for maintenance scheduling, compliance tracking, and equipment reliability analysis.' ;
    rdfs:domain ind:Airport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maximumQueueCapacity rdf:type rdf:Property ;
    rdfs:label 'Maximum Queue Capacity' ;
    rdfs:comment 'Maximum number of passengers that can be accommodated in the queue area for this counter. Used for queue management, passenger flow modeling, and capacity planning during peak periods.' ;
    rdfs:domain ind:CheckinCounter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:networkIpAddress rdf:type rdf:Property ;
    rdfs:label 'Network Ip Address' ;
    rdfs:comment 'IP address assigned to the counter workstation or kiosk for network connectivity. Used for system administration, troubleshooting, and security monitoring. Classified as confidential business infrastructure data.' ;
    rdfs:domain ind:CheckinCounter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextMaintenanceDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Maintenance Due Date' ;
    rdfs:comment 'Scheduled date for the next preventive maintenance activity. Supports proactive maintenance planning and ensures continuous operational availability of check-in resources.' ;
    rdfs:domain ind:Airport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operatingHoursEnd rdf:type rdf:Property ;
    rdfs:label 'Operating Hours End' ;
    rdfs:comment 'Daily end time for counter operations in HH:MM format (24-hour clock). Defines the close of the counter\'s operational window for capacity planning and staffing.' ;
    rdfs:domain ind:CheckinCounter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingHoursStart rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Start' ;
    rdfs:comment 'Daily start time for counter operations in HH:MM format (24-hour clock). Defines the beginning of the counter\'s operational window for capacity planning and staffing.' ;
    rdfs:domain ind:CheckinCounter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passportScannerAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Passport Scanner Available Flag' ;
    rdfs:comment 'Indicates whether the counter is equipped with a passport/travel document scanner for automated document verification. True if scanner hardware is installed and operational.' ;
    rdfs:domain ind:CheckinCounter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentTerminalAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Payment Terminal Available Flag' ;
    rdfs:comment 'Indicates whether the counter has a payment terminal for processing credit/debit card transactions (excess baggage, upgrades, ancillary services). True if PCI-compliant payment hardware is installed.' ;
    rdfs:domain ind:CheckinCounter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remarks rdf:type rdf:Property ;
    rdfs:label 'Remarks' ;
    rdfs:comment 'Free-text field for operational notes, special instructions, or additional context about the counter. May include temporary restrictions, equipment issues, or coordination notes for ground handling staff.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceMode rdf:type rdf:Property ;
    rdfs:label 'Service Mode' ;
    rdfs:comment 'Operational assignment model for the counter. Common-use counters are shared across multiple airlines via CUTE/CUPPS systems; dedicated counters are assigned to a single airline; hybrid counters support both modes based on schedule.' ;
    rdfs:domain ind:CheckinCounter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminalIdentifier rdf:type rdf:Property ;
    rdfs:label 'Terminal Identifier' ;
    rdfs:comment 'Terminal designation within the airport (e.g., T1, T2, Terminal A). Provides human-readable terminal context for operational staff.' ;
    rdfs:domain ind:Airport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkinSessionId rdf:type rdf:Property ;
    rdfs:label 'Checkin Session Id' ;
    rdfs:comment 'Unique identifier for the passenger check-in session transaction. Primary key.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CheckinSession .

ind:costCentreId rdf:type rdf:Property ;
    rdfs:label 'Cost Centre Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_centre. Business justification: Check-in operations (labor, equipment, counter space) are allocated to cost centers for passenger service cost tracking, station budgeting, and CASK calculation. Essential for operational expense mana' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCentre .

ind:scheduledFlightId rdf:type rdf:Property ;
    rdfs:label 'Scheduled Flight Id' ;
    rdfs:comment 'Reference to the scheduled flight for which the passenger is checking in.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ScheduledFlight .

ind:advanceCheckinFlag rdf:type rdf:Property ;
    rdfs:label 'Advance Checkin Flag' ;
    rdfs:comment 'Indicates whether the passenger checked in more than 24 hours before scheduled departure (advance/online check-in). True if advance check-in.' ;
    rdfs:domain ind:CheckinSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:apisDataTransmittedFlag rdf:type rdf:Property ;
    rdfs:label 'Apis Data Transmitted Flag' ;
    rdfs:comment 'Indicates whether APIS data (passport, nationality, date of birth) was transmitted to destination authorities during check-in. True if APIS transmitted.' ;
    rdfs:domain ind:CheckinSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:baggageTagNumbers rdf:type rdf:Property ;
    rdfs:label 'Baggage Tag Numbers' ;
    rdfs:comment 'Comma-separated list of 10-digit baggage tag numbers issued during check-in for tracked baggage pieces. Used for baggage tracing and reconciliation.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bagsCheckedCount rdf:type rdf:Property ;
    rdfs:label 'Bags Checked Count' ;
    rdfs:comment 'Number of checked baggage pieces accepted during this check-in session.' ;
    rdfs:domain ind:CheckinSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:boardingPassIssuanceMethod rdf:type rdf:Property ;
    rdfs:label 'Boarding Pass Issuance Method' ;
    rdfs:comment 'Method by which the boarding pass was delivered to the passenger. Paper = printed at counter, mobile = mobile app barcode, email = emailed PDF, SMS = SMS link, kiosk_print = printed at kiosk.' ;
    rdfs:domain ind:CheckinSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkinChannel rdf:type rdf:Property ;
    rdfs:label 'Checkin Channel' ;
    rdfs:comment 'Channel through which the passenger initiated check-in. Counter = airport counter, kiosk = self-service kiosk, CUSS = Common Use Self-Service, web = online web check-in, mobile = mobile app check-in, agent_assisted = call center or remote agent.' ;
    rdfs:domain ind:CheckinSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkinEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Checkin End Timestamp' ;
    rdfs:comment 'Timestamp when the check-in session was completed and boarding pass issued. Recorded in UTC.' ;
    rdfs:domain ind:CheckinSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:checkinLanguageCode rdf:type rdf:Property ;
    rdfs:label 'Checkin Language Code' ;
    rdfs:comment 'Two-letter ISO 639-1 language code indicating the language used during the check-in session (e.g., en, es, fr).' ;
    rdfs:domain ind:CheckinSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkinSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Checkin Sequence Number' ;
    rdfs:comment 'Sequential number assigned to the passenger within the flight check-in order. Used for boarding priority and operational sequencing.' ;
    rdfs:domain ind:CheckinSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:checkinStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Checkin Start Timestamp' ;
    rdfs:comment 'Timestamp when the passenger initiated the check-in session. Recorded in UTC and converted to local airport time for operational reporting.' ;
    rdfs:domain ind:CheckinSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:checkinStatus rdf:type rdf:Property ;
    rdfs:label 'Checkin Status' ;
    rdfs:comment 'Current status of the check-in session. Completed = boarding pass issued, incomplete = session started but not finished, cancelled = passenger cancelled check-in, no_show = passenger did not complete check-in and did not board.' ;
    rdfs:domain ind:CheckinSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:excessBaggageFlag rdf:type rdf:Property ;
    rdfs:label 'Excess Baggage Flag' ;
    rdfs:comment 'Indicates whether the passenger checked excess baggage beyond the standard allowance. True if excess baggage charges apply.' ;
    rdfs:domain ind:CheckinSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:groupCheckinFlag rdf:type rdf:Property ;
    rdfs:label 'Group Checkin Flag' ;
    rdfs:comment 'Indicates whether this check-in is part of a group booking check-in. True if group check-in.' ;
    rdfs:domain ind:CheckinSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:infantAccompanyingFlag rdf:type rdf:Property ;
    rdfs:label 'Infant Accompanying Flag' ;
    rdfs:comment 'Indicates whether the passenger is traveling with an infant (under 2 years) on lap. True if infant accompanying.' ;
    rdfs:domain ind:CheckinSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pnrReference rdf:type rdf:Property ;
    rdfs:label 'Pnr Reference' ;
    rdfs:comment 'Six-character alphanumeric reference to the Passenger Name Record in the reservation system. Links check-in to the booking.' ;
    rdfs:domain ind:CheckinSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityBoardingFlag rdf:type rdf:Property ;
    rdfs:label 'Priority Boarding Flag' ;
    rdfs:comment 'Indicates whether the passenger is eligible for priority boarding based on fare class, loyalty status, or purchased upgrade. True if priority boarding granted.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:seatAssigned rdf:type rdf:Property ;
    rdfs:label 'Seat Assigned' ;
    rdfs:comment 'Seat number assigned to the passenger during check-in (e.g., 12A, 34F). Format: row number followed by seat letter.' ;
    rdfs:domain ind:CheckinSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialServiceRequests rdf:type rdf:Property ;
    rdfs:label 'Special Service Requests' ;
    rdfs:comment 'Comma-separated list of SSR codes processed or confirmed during check-in (e.g., WCHR, VGML, PETC). Reflects special assistance, meal preferences, or service requests.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standbyStatus rdf:type rdf:Property ;
    rdfs:label 'Standby Status' ;
    rdfs:comment 'Indicates whether the passenger is confirmed, on standby, or waitlisted at check-in. Confirmed = seat guaranteed, standby = awaiting seat assignment, waitlisted = not yet cleared.' ;
    rdfs:domain ind:CheckinSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:travelDocumentVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Travel Document Verified Flag' ;
    rdfs:comment 'Indicates whether the passengers travel documents (passport, visa) were verified during check-in. True if documents verified.' ;
    rdfs:domain ind:CheckinSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:upgradeProcessedFlag rdf:type rdf:Property ;
    rdfs:label 'Upgrade Processed Flag' ;
    rdfs:comment 'Indicates whether a cabin upgrade (e.g., economy to business) was processed during check-in. True if upgrade applied.' ;
    rdfs:domain ind:CheckinSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deicingEventId rdf:type rdf:Property ;
    rdfs:label 'Deicing Event Id' ;
    rdfs:comment 'Unique identifier for the de-icing or anti-icing treatment event. Primary key.' ;
    rdfs:domain ind:DeicingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountsPayableId rdf:type rdf:Property ;
    rdfs:label 'Accounts Payable Id' ;
    rdfs:comment 'Foreign key linking to finance.accounts_payable. Business justification: Deicing vendor invoices are processed through AP for payment settlement. Airlines must match deicing events to vendor invoices for cost verification, dispute resolution, and seasonal winter operations' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccountsPayable .

ind:deicingCrewId rdf:type rdf:Property ;
    rdfs:label 'Deicing Crew Id' ;
    rdfs:comment 'Identifier for the ground crew or team that performed the de-icing treatment. Used for quality tracking and training purposes.' ;
    rdfs:domain ind:Airport ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DeicingCrew .

ind:supervisorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Supervisor Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Deicing operations require certified workforce supervision for safety compliance, fluid application oversight, and holdover time validation. Regulatory requirement for accountable supervisor beyond cr' ;
    rdfs:domain ind:DeicingEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:currencyCode rdf:type rdf:Property ;
    rdfs:label 'Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for all monetary amounts in this record (e.g., USD, EUR, CAD).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deicingLocationType rdf:type rdf:Property ;
    rdfs:label 'Deicing Location Type' ;
    rdfs:comment 'The type of location where de-icing was performed: dedicated de-icing pad, gate position, remote stand, or runway holding area.' ;
    rdfs:domain ind:DeicingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deicingVendorCode rdf:type rdf:Property ;
    rdfs:label 'Deicing Vendor Code' ;
    rdfs:comment 'Code identifying the third-party vendor or ground handling company that performed the de-icing service. Used for billing and performance tracking.' ;
    rdfs:domain ind:DeicingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Environmental Reporting Flag' ;
    rdfs:comment 'Indicates whether this de-icing event must be included in environmental compliance reporting (CORSIA, ISO 14001). True if glycol usage exceeds reporting thresholds.' ;
    rdfs:domain ind:DeicingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:equipmentIdentifier rdf:type rdf:Property ;
    rdfs:label 'Equipment Identifier' ;
    rdfs:comment 'Identifier for the specific de-icing truck or equipment unit used. Enables equipment maintenance correlation and utilization tracking.' ;
    rdfs:domain ind:DeicingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fluidConcentrationPrimaryPercent rdf:type rdf:Property ;
    rdfs:label 'Fluid Concentration Primary Percent' ;
    rdfs:comment 'Concentration percentage of the primary de-icing fluid mixture (glycol to water ratio). Affects freezing point and holdover time.' ;
    rdfs:domain ind:DeicingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fluidConcentrationSecondaryPercent rdf:type rdf:Property ;
    rdfs:label 'Fluid Concentration Secondary Percent' ;
    rdfs:comment 'Concentration percentage of the secondary anti-icing fluid mixture. Null if no secondary treatment was performed.' ;
    rdfs:domain ind:DeicingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fluidCostTotalAmount rdf:type rdf:Property ;
    rdfs:label 'Fluid Cost Total Amount' ;
    rdfs:comment 'Total cost of de-icing and anti-icing fluids used in this treatment event. Used for financial tracking and cost recovery.' ;
    rdfs:domain ind:DeicingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fluidTypePrimary rdf:type rdf:Property ;
    rdfs:label 'Fluid Type Primary' ;
    rdfs:comment 'The primary de-icing fluid type applied in the first treatment step. Type I is typically used for de-icing (removing contamination).' ;
    rdfs:domain ind:DeicingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fluidTypeSecondary rdf:type rdf:Property ;
    rdfs:label 'Fluid Type Secondary' ;
    rdfs:comment 'The secondary anti-icing fluid type applied in the second treatment step, if applicable. Types II, III, or IV provide longer holdover time protection.' ;
    rdfs:domain ind:DeicingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fluidVolumePrimaryLiters rdf:type rdf:Property ;
    rdfs:label 'Fluid Volume Primary Liters' ;
    rdfs:comment 'Volume of primary de-icing fluid applied, measured in liters. Used for cost tracking and environmental reporting.' ;
    rdfs:domain ind:DeicingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fluidVolumeSecondaryLiters rdf:type rdf:Property ;
    rdfs:label 'Fluid Volume Secondary Liters' ;
    rdfs:comment 'Volume of secondary anti-icing fluid applied, measured in liters. Null if no secondary treatment was performed.' ;
    rdfs:domain ind:DeicingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holdoverTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Holdover Time Minutes' ;
    rdfs:comment 'The estimated time in minutes that the anti-icing treatment will remain effective under current weather conditions. Critical for flight safety and departure timing.' ;
    rdfs:domain ind:DeicingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inspectionPerformedBy rdf:type rdf:Property ;
    rdfs:label 'Inspection Performed By' ;
    rdfs:comment 'Identifier of the person or crew who performed the post-treatment inspection. May be pilot, ground crew, or designated inspector.' ;
    rdfs:domain ind:DeicingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outsideAirTemperatureCelsius rdf:type rdf:Property ;
    rdfs:label 'Outside Air Temperature Celsius' ;
    rdfs:comment 'The outside air temperature in degrees Celsius at the time of treatment. Critical factor in determining holdover time and fluid effectiveness.' ;
    rdfs:domain ind:DeicingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postTreatmentInspectionResult rdf:type rdf:Property ;
    rdfs:label 'Post Treatment Inspection Result' ;
    rdfs:comment 'Result of the post-treatment inspection to verify aircraft surfaces are free of contamination. Critical safety check before departure.' ;
    rdfs:domain ind:DeicingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:precipitationIntensity rdf:type rdf:Property ;
    rdfs:label 'Precipitation Intensity' ;
    rdfs:comment 'The intensity of precipitation during treatment. Combined with precipitation type to determine holdover time from FAA/Transport Canada tables.' ;
    rdfs:domain ind:DeicingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:precipitationType rdf:type rdf:Property ;
    rdfs:label 'Precipitation Type' ;
    rdfs:comment 'The type of precipitation or frozen contamination present during treatment. Affects holdover time calculation and treatment requirements. [ENUM-REF-CANDIDATE: none|light_snow|moderate_snow|heavy_snow|freezing_rain|freezing_drizzle|ice_pellets|frost|mixed — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DeicingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Service Charge Amount' ;
    rdfs:comment 'Labor and equipment service charge for the de-icing treatment, separate from fluid costs. Used for vendor billing and cost allocation.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:treatmentDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Treatment Duration Minutes' ;
    rdfs:comment 'Total duration of the de-icing treatment in minutes, calculated from start to end timestamp. Used for operational efficiency analysis.' ;
    rdfs:domain ind:DeicingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:treatmentEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Treatment End Timestamp' ;
    rdfs:comment 'The date and time when de-icing treatment was completed. Marks the start of the holdover time window.' ;
    rdfs:domain ind:DeicingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:treatmentReasonCode rdf:type rdf:Property ;
    rdfs:label 'Treatment Reason Code' ;
    rdfs:comment 'The primary reason or trigger for performing the de-icing treatment. Used for operational analysis and cost allocation. [ENUM-REF-CANDIDATE: scheduled|frost|snow|ice|freezing_rain|preventive|regulatory_requirement — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DeicingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatmentStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Treatment Start Timestamp' ;
    rdfs:comment 'The date and time when de-icing treatment began. Used to calculate holdover time expiration and turnaround impact.' ;
    rdfs:domain ind:DeicingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:treatmentStatus rdf:type rdf:Property ;
    rdfs:label 'Treatment Status' ;
    rdfs:comment 'Current status of the de-icing treatment event in its lifecycle. Tracks operational workflow state.' ;
    rdfs:domain ind:DeicingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatmentType rdf:type rdf:Property ;
    rdfs:label 'Treatment Type' ;
    rdfs:comment 'The type of de-icing and anti-icing fluid treatment applied. Type I is heated de-icing fluid; Types II, III, IV are thickened anti-icing fluids with varying viscosities and holdover times. [ENUM-REF-CANDIDATE: type_i_only|type_i_and_ii|type_i_and_iii|type_i_and_iv|type_ii_only|type_iii_only|type_iv_only — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DeicingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visibilityMeters rdf:type rdf:Property ;
    rdfs:label 'Visibility Meters' ;
    rdfs:comment 'Visibility in meters at the time of treatment. Indicates severity of weather conditions.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:windSpeedKnots rdf:type rdf:Property ;
    rdfs:label 'Wind Speed Knots' ;
    rdfs:comment 'Wind speed in knots at the time of treatment. High winds can reduce holdover time effectiveness.' ;
    rdfs:domain ind:DeicingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gateId rdf:type rdf:Property ;
    rdfs:label 'Gate Id' ;
    rdfs:comment 'Unique identifier for the aircraft gate. Primary key for the gate master record.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Gate .

ind:aircraftSizeCodeMax rdf:type rdf:Property ;
    rdfs:label 'Aircraft Size Code Max' ;
    rdfs:comment 'Maximum ICAO aircraft size code (A through F) that this gate can accommodate based on wingspan, parking envelope, and structural limitations.' ;
    rdfs:domain ind:Gate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aircraftSizeCodeMin rdf:type rdf:Property ;
    rdfs:label 'Aircraft Size Code Min' ;
    rdfs:comment 'Minimum ICAO aircraft size code (A through F) that this gate can accommodate based on wingspan and parking envelope.' ;
    rdfs:domain ind:Gate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commonUseGate rdf:type rdf:Property ;
    rdfs:label 'Common Use Gate' ;
    rdfs:comment 'Indicates whether this gate is operated as a common-use facility available to multiple airlines through dynamic assignment, or is dedicated to a specific carrier.' ;
    rdfs:domain ind:Gate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:concourse rdf:type rdf:Property ;
    rdfs:label 'Concourse' ;
    rdfs:comment 'The concourse or pier designation within the terminal (e.g., A, B, C, D, International).' ;
    rdfs:domain ind:Gate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsFacility rdf:type rdf:Property ;
    rdfs:label 'Customs Facility' ;
    rdfs:comment 'Indicates whether this gate has direct access to customs and immigration facilities for international arrivals processing.' ;
    rdfs:domain ind:Gate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:domesticCapable rdf:type rdf:Property ;
    rdfs:label 'Domestic Capable' ;
    rdfs:comment 'Indicates whether this gate is equipped and authorized to handle domestic flights.' ;
    rdfs:domain ind:Gate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fuelHydrantAvailable rdf:type rdf:Property ;
    rdfs:label 'Fuel Hydrant Available' ;
    rdfs:comment 'Indicates whether underground fuel hydrant system is available at this gate position for aircraft refueling operations.' ;
    rdfs:domain ind:Gate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gateNumber rdf:type rdf:Property ;
    rdfs:label 'Gate Number' ;
    rdfs:comment 'The alphanumeric gate identifier displayed to passengers and used in operational systems (e.g., A12, B5, C23).' ;
    rdfs:domain ind:Gate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateType rdf:type rdf:Property ;
    rdfs:label 'Gate Type' ;
    rdfs:comment 'Classification of gate based on aircraft parking configuration: contact (jetbridge-connected), remote (apron position requiring bus), hardstand (unpaved remote stand), bus_gate (passenger bus boarding point), swing_gate (can serve domestic or international).' ;
    rdfs:domain ind:Airport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groundPowerUnitAvailable rdf:type rdf:Property ;
    rdfs:label 'Ground Power Unit Available' ;
    rdfs:comment 'Indicates whether fixed ground power unit (GPU) electrical supply is available at this gate for aircraft systems during turnaround.' ;
    rdfs:domain ind:Gate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:internationalCapable rdf:type rdf:Property ;
    rdfs:label 'International Capable' ;
    rdfs:comment 'Indicates whether this gate is equipped and authorized to handle international flights with customs, immigration, and border control requirements.' ;
    rdfs:domain ind:Gate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jetbridgeAvailable rdf:type rdf:Property ;
    rdfs:label 'Jetbridge Available' ;
    rdfs:comment 'Indicates whether a passenger boarding bridge (jetbridge/airbridge) is installed and operational at this gate.' ;
    rdfs:domain ind:Gate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jetbridgeCount rdf:type rdf:Property ;
    rdfs:label 'Jetbridge Count' ;
    rdfs:comment 'Number of passenger boarding bridges available at this gate (0 for remote stands, 1-3 for contact gates serving wide-body aircraft).' ;
    rdfs:domain ind:Gate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:latitude rdf:type rdf:Property ;
    rdfs:label 'Latitude' ;
    rdfs:comment 'Geographic latitude coordinate of the gate parking position in decimal degrees for Ground Support Equipment (GSE) navigation and airport mapping systems.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:longitude rdf:type rdf:Property ;
    rdfs:label 'Longitude' ;
    rdfs:comment 'Geographic longitude coordinate of the gate parking position in decimal degrees for Ground Support Equipment (GSE) navigation and airport mapping systems.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxAircraftLengthMeters rdf:type rdf:Property ;
    rdfs:label 'Max Aircraft Length Meters' ;
    rdfs:comment 'Maximum aircraft fuselage length in meters that can be accommodated at this gate position.' ;
    rdfs:domain ind:Gate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxWingspanMeters rdf:type rdf:Property ;
    rdfs:label 'Max Wingspan Meters' ;
    rdfs:comment 'Maximum aircraft wingspan in meters that can be safely accommodated at this gate position.' ;
    rdfs:domain ind:Gate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumTurnaroundTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Minimum Turnaround Time Minutes' ;
    rdfs:comment 'Minimum aircraft turnaround time in minutes required at this gate based on facility capabilities and Ground Support Equipment (GSE) availability.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:narrowBodyCapable rdf:type rdf:Property ;
    rdfs:label 'Narrow Body Capable' ;
    rdfs:comment 'Indicates whether this gate can accommodate narrow-body aircraft (typically ICAO codes B, C such as A320 family, B737 family).' ;
    rdfs:domain ind:Gate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operatingAirlineCode rdf:type rdf:Property ;
    rdfs:label 'Operating Airline Code' ;
    rdfs:comment 'IATA airline code of the carrier that has preferential or exclusive use rights to this gate under lease or operating agreement (null if common-use gate).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parkingStandDesignation rdf:type rdf:Property ;
    rdfs:label 'Parking Stand Designation' ;
    rdfs:comment 'The official apron parking stand identifier used in airport operations and ATC communications (may differ from passenger-facing gate number).' ;
    rdfs:domain ind:Gate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:potableWaterAvailable rdf:type rdf:Property ;
    rdfs:label 'Potable Water Available' ;
    rdfs:comment 'Indicates whether fixed potable water supply connection is available at this gate for aircraft water system servicing.' ;
    rdfs:domain ind:Gate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preconditionedAirAvailable rdf:type rdf:Property ;
    rdfs:label 'Preconditioned Air Available' ;
    rdfs:comment 'Indicates whether fixed preconditioned air system is available at this gate for aircraft cabin climate control during turnaround, reducing APU usage.' ;
    rdfs:domain ind:Gate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regionalJetCapable rdf:type rdf:Property ;
    rdfs:label 'Regional Jet Capable' ;
    rdfs:comment 'Indicates whether this gate can accommodate regional jet aircraft (typically ICAO code A such as CRJ, ERJ families).' ;
    rdfs:domain ind:Gate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:schengenCapable rdf:type rdf:Property ;
    rdfs:label 'Schengen Capable' ;
    rdfs:comment 'Indicates whether this gate can handle flights within the Schengen Area (European airports only) without passport control requirements.' ;
    rdfs:domain ind:Gate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:wideBodyCapable rdf:type rdf:Property ;
    rdfs:label 'Wide Body Capable' ;
    rdfs:comment 'Indicates whether this gate can accommodate wide-body aircraft (typically ICAO codes D, E, F such as B777, B787, A330, A350, A380).' ;
    rdfs:domain ind:Gate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:actualGateInTime rdf:type rdf:Property ;
    rdfs:label 'Actual Gate In Time' ;
    rdfs:comment 'Actual timestamp when aircraft arrived at gate and set parking brake (Actual On-block from OOOI). Captured via ACARS or manual entry. Critical for OTP calculation and turnaround tracking.' ;
    rdfs:domain ind:GateAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualGateOutTime rdf:type rdf:Property ;
    rdfs:label 'Actual Gate Out Time' ;
    rdfs:comment 'Actual timestamp when aircraft pushed back from gate and released parking brake (Actual Off-block from OOOI). Captured via ACARS or manual entry. Marks gate release and availability for next assignment.' ;
    rdfs:domain ind:GateAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:aircraftSizeCategory rdf:type rdf:Property ;
    rdfs:label 'Aircraft Size Category' ;
    rdfs:comment 'Size classification of aircraft assigned to gate, used for gate compatibility validation. Narrow-body: single aisle; Wide-body: twin aisle; Regional: small aircraft; Heavy: large aircraft; Super: A380 class.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:airportIataCode rdf:type rdf:Property ;
    rdfs:label 'Airport Iata Code' ;
    rdfs:comment 'Three-letter IATA airport code where this gate assignment occurs (e.g., JFK, LHR, DXB). Identifies the operational airport for multi-hub airline networks.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arrivalGate rdf:type rdf:Property ;
    rdfs:label 'Arrival Gate' ;
    rdfs:comment 'The gate number or stand identifier at the destination airport where the flight arrived. [Moved from flight_leg: arrival_gate is a STRING attribute in flight_leg that represents the gate assignment at arrival. This should be replaced by the gate_assignment association, as a flight can be reassigned to multiple gates during IROP. The actual gate used is determined by querying gate_assignment with assignment_type=\'arrival\' or \'turnaround\' and assignment_status=\'completed\'.]' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentEndTime rdf:type rdf:Property ;
    rdfs:label 'Assignment End Time' ;
    rdfs:comment 'Timestamp when the gate reservation expires and becomes available for next assignment, typically includes buffer after scheduled gate-out for cleanup and turnaround completion.' ;
    rdfs:domain ind:GateAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assignmentNumber rdf:type rdf:Property ;
    rdfs:label 'Assignment Number' ;
    rdfs:comment 'Business identifier for the gate assignment, formatted as GA followed by 8 digits. Used for operational reference and CDM messaging.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentSource rdf:type rdf:Property ;
    rdfs:label 'Assignment Source' ;
    rdfs:comment 'Origin of the gate assignment decision. CDM: Collaborative Decision Making system; Manual: dispatcher override; Auto-assign: automated allocation; Rescheduled: changed from original; IROP: irregular operations reassignment.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentStartTime rdf:type rdf:Property ;
    rdfs:label 'Assignment Start Time' ;
    rdfs:comment 'Timestamp when the gate was reserved for this flight, typically earlier than scheduled gate-in to allow for ground equipment setup and early arrival buffer.' ;
    rdfs:domain ind:GateAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assignmentStatus rdf:type rdf:Property ;
    rdfs:label 'Assignment Status' ;
    rdfs:comment 'Current lifecycle status of the gate assignment. Planned: initial assignment; Confirmed: verified by operations; Active: aircraft at gate; Completed: turnaround finished; Released: gate available; Cancelled: assignment voided.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assignment Timestamp' ;
    rdfs:comment 'Timestamp when this gate assignment record was initially created in the system. Represents the business event time of assignment decision, distinct from technical audit timestamps.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cdmMilestoneStatus rdf:type rdf:Property ;
    rdfs:label 'Cdm Milestone Status' ;
    rdfs:comment 'Current CDM milestone achieved for this gate assignment. TOBT: Target Off-Block Time set; TSAT: Target Start-Up Approval Time issued; AOBT: Actual Off-Block Time; AIBT: Actual In-Block Time; ALDT: Actual Landing Time.' ;
    rdfs:domain ind:Airport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conflictFlag rdf:type rdf:Property ;
    rdfs:label 'Conflict Flag' ;
    rdfs:comment 'Indicates whether this gate assignment has a scheduling conflict with another assignment (overlapping time windows). True when conflict detected; requires resolution by operations.' ;
    rdfs:domain ind:GateAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conflictResolutionNotes rdf:type rdf:Property ;
    rdfs:label 'Conflict Resolution Notes' ;
    rdfs:comment 'Free-text notes documenting how a gate assignment conflict was resolved, including dispatcher actions, alternative gate assignments, or operational adjustments made.' ;
    rdfs:domain ind:GateAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departureGate rdf:type rdf:Property ;
    rdfs:label 'Departure Gate' ;
    rdfs:comment 'The gate number or stand identifier at the origin airport from which the flight departed. [Moved from flight_leg: departure_gate is a STRING attribute in flight_leg that represents the gate assignment at departure. This should be replaced by the gate_assignment association, as a flight can be reassigned to multiple gates during IROP. The actual gate used is determined by querying gate_assignment with assignment_type=\'departure\' or \'turnaround\' and assignment_status=\'completed\'.]' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:domesticInternationalFlag rdf:type rdf:Property ;
    rdfs:label 'Domestic International Flag' ;
    rdfs:comment 'Indicates whether the flight assigned to this gate is domestic or international. Schengen applies to intra-European flights with no border control. Determines gate area assignment and customs/immigration requirements.' ;
    rdfs:domain ind:GateAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateHoldReason rdf:type rdf:Property ;
    rdfs:label 'Gate Hold Reason' ;
    rdfs:comment 'Free-text explanation for any gate hold or delay in releasing the gate assignment. Documents operational reasons such as late arriving aircraft, maintenance issues, or ATC delays.' ;
    rdfs:domain ind:GateAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groundPowerAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Ground Power Available Flag' ;
    rdfs:comment 'Indicates whether ground power unit (GPU) is available at this gate for this assignment. Required for aircraft electrical power during turnaround when APU is shut down.' ;
    rdfs:domain ind:GateAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hubSpokeIndicator rdf:type rdf:Property ;
    rdfs:label 'Hub Spoke Indicator' ;
    rdfs:comment 'Classification of airport operational role in airline network. Hub: major connecting airport; Spoke: destination from hub; Focus city: secondary hub; Outstation: remote station with limited operations.' ;
    rdfs:domain ind:GateAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jetBridgeAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Jet Bridge Available Flag' ;
    rdfs:comment 'Indicates whether a jet bridge (passenger boarding bridge) is available and operational at this gate for this assignment. Critical for passenger boarding operations and accessibility requirements.' ;
    rdfs:domain ind:GateAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:passengerFacilityChargeApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Passenger Facility Charge Applicable Flag' ;
    rdfs:comment 'Indicates whether Passenger Facility Charge applies to this gate assignment based on airport authority regulations. Used for financial settlement and regulatory reporting to DOT.' ;
    rdfs:domain ind:GateAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preconditionedAirAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Preconditioned Air Available Flag' ;
    rdfs:comment 'Indicates whether preconditioned air (PCA) system is available at this gate for cabin climate control during turnaround. Reduces APU usage and fuel burn.' ;
    rdfs:domain ind:GateAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorityOverrideFlag rdf:type rdf:Property ;
    rdfs:label 'Priority Override Flag' ;
    rdfs:comment 'Indicates whether this assignment received priority treatment overriding normal allocation rules. True for VIP flights, IROP recovery, or operational priority situations.' ;
    rdfs:domain ind:GateAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorityOverrideReason rdf:type rdf:Property ;
    rdfs:label 'Priority Override Reason' ;
    rdfs:comment 'Business reason for priority override of normal gate assignment rules. Documents justification for preferential gate allocation outside standard procedures. [ENUM-REF-CANDIDATE: vip_flight|irop_recovery|maintenance_priority|diplomatic|medical_emergency|operational_necessity|none — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GateAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledGateInTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Gate In Time' ;
    rdfs:comment 'Planned timestamp when aircraft is scheduled to arrive at the gate and set parking brake (On-block time from OOOI). Used for gate allocation planning and OTP reporting.' ;
    rdfs:domain ind:GateAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledGateOutTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Gate Out Time' ;
    rdfs:comment 'Planned timestamp when aircraft is scheduled to push back from gate and release parking brake (Off-block time from OOOI). Used for gate release planning and next assignment scheduling.' ;
    rdfs:domain ind:GateAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:slotCoordinationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Slot Coordination Required Flag' ;
    rdfs:comment 'Indicates whether this gate assignment requires coordination with airport slot allocation due to capacity constraints at slot-controlled airport. True for Level 3 coordinated airports.' ;
    rdfs:domain ind:GateAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specialHandlingCode rdf:type rdf:Property ;
    rdfs:label 'Special Handling Code' ;
    rdfs:comment 'Special Service Request code indicating special handling requirements for this gate assignment (e.g., WCHR for wheelchair, DEPA for deportee, MEDA for medical). Drives ground service and security coordination.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standCompatibilityCode rdf:type rdf:Property ;
    rdfs:label 'Stand Compatibility Code' ;
    rdfs:comment 'ICAO aerodrome reference code indicating maximum aircraft size the gate can accommodate (A through F). Ensures aircraft-gate physical compatibility for safe operations.' ;
    rdfs:domain ind:GateAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:turnaroundDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Turnaround Duration Minutes' ;
    rdfs:comment 'Planned duration in minutes for aircraft turnaround at the gate, from gate-in to gate-out. Varies by aircraft type, service level, and operational requirements.' ;
    rdfs:domain ind:GateAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:groundHandlerId rdf:type rdf:Property ;
    rdfs:label 'Ground Handler Id' ;
    rdfs:comment 'Unique identifier for the ground handling service provider record. Primary key.' ;
    rdfs:domain ind:Airport ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GroundHandler .

ind:vendorId rdf:type rdf:Property ;
    rdfs:label 'Vendor Id' ;
    rdfs:comment 'Foreign key linking to procurement.vendor. Business justification: Ground handlers are vendors providing contracted services (ramp, passenger, baggage handling). Linking ground_handler to vendor master unifies vendor management, enables procurement spend analysis, co' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:agreementEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Agreement Effective Date' ;
    rdfs:comment 'The date when the ground handling agreement becomes effective and services may commence.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:agreementExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Agreement Expiry Date' ;
    rdfs:comment 'The date when the ground handling agreement expires or is scheduled for renewal.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:aircraftDamageIncidentCount rdf:type rdf:Property ;
    rdfs:label 'Aircraft Damage Incident Count' ;
    rdfs:comment 'The total number of aircraft damage incidents caused by this handler during the current performance measurement period.' ;
    rdfs:domain ind:GroundHandler ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:averageBaggageDeliveryTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Average Baggage Delivery Time Minutes' ;
    rdfs:comment 'The average time in minutes from aircraft arrival to first baggage on carousel for flights handled by this provider.' ;
    rdfs:domain ind:GroundHandler ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baggageHandlingFlag rdf:type rdf:Property ;
    rdfs:label 'Baggage Handling Flag' ;
    rdfs:comment 'Indicates whether the handler provides baggage sorting, loading, unloading, and tracing services.' ;
    rdfs:domain ind:GroundHandler ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:baggageMishandlingRatePer1000 rdf:type rdf:Property ;
    rdfs:label 'Baggage Mishandling Rate Per 1000' ;
    rdfs:comment 'The number of mishandled baggage incidents per 1000 passengers handled, including delayed, damaged, and lost baggage.' ;
    rdfs:domain ind:GroundHandler ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cargoHandlingFlag rdf:type rdf:Property ;
    rdfs:label 'Cargo Handling Flag' ;
    rdfs:comment 'Indicates whether the handler provides cargo and freight handling services including loading, unloading, and warehouse operations.' ;
    rdfs:domain ind:GroundHandler ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cateringHandlingFlag rdf:type rdf:Property ;
    rdfs:label 'Catering Handling Flag' ;
    rdfs:comment 'Indicates whether the handler provides aircraft catering loading and unloading services.' ;
    rdfs:domain ind:GroundHandler ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractedStations rdf:type rdf:Property ;
    rdfs:label 'Contracted Stations' ;
    rdfs:comment 'Comma-separated list of IATA airport codes where this handler is contracted to provide services.' ;
    rdfs:domain ind:GroundHandler ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyContactPhone rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Phone' ;
    rdfs:comment 'The 24/7 emergency contact telephone number for urgent operational issues and Aircraft on Ground (AOG) situations.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelHandlingFlag rdf:type rdf:Property ;
    rdfs:label 'Fuel Handling Flag' ;
    rdfs:comment 'Indicates whether the handler provides aircraft refueling and defueling services.' ;
    rdfs:domain ind:GroundHandler ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:handlerName rdf:type rdf:Property ;
    rdfs:label 'Handler Name' ;
    rdfs:comment 'The legal registered name of the ground handling service provider organization.' ;
    rdfs:domain ind:GroundHandler ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handlerType rdf:type rdf:Property ;
    rdfs:label 'Handler Type' ;
    rdfs:comment 'Classification of the ground handler by ownership and operational model.' ;
    rdfs:domain ind:GroundHandler ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iataGroundHandlerCode rdf:type rdf:Property ;
    rdfs:label 'Iata Ground Handler Code' ;
    rdfs:comment 'The IATA-assigned unique code identifying this ground handling service provider globally.' ;
    rdfs:domain ind:GroundHandler ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceCoverageAmount rdf:type rdf:Property ;
    rdfs:label 'Insurance Coverage Amount' ;
    rdfs:comment 'The total liability coverage amount provided by the handler\'s insurance policy.' ;
    rdfs:domain ind:GroundHandler ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Insurance Currency Code' ;
    rdfs:comment 'The three-letter ISO 4217 currency code for the insurance coverage amount.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Insurance Expiry Date' ;
    rdfs:comment 'The date when the handler\'s liability insurance policy expires and must be renewed.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:insurancePolicyNumber rdf:type rdf:Property ;
    rdfs:label 'Insurance Policy Number' ;
    rdfs:comment 'The policy number of the handler\'s liability insurance coverage as required by the ground handling agreement.' ;
    rdfs:domain ind:Airport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isagoCertificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Isago Certification Expiry Date' ;
    rdfs:comment 'The date when the handler\'s ISAGO certification expires and must be renewed.' ;
    rdfs:domain ind:GroundHandler ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isagoCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Isago Certified Flag' ;
    rdfs:comment 'Indicates whether the handler holds current IATA Safety Audit for Ground Operations (ISAGO) certification.' ;
    rdfs:domain ind:GroundHandler ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastPerformanceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Performance Review Date' ;
    rdfs:comment 'The date of the most recent formal performance review conducted with this ground handler.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseExpiryDate rdf:type rdf:Property ;
    rdfs:label 'License Expiry Date' ;
    rdfs:comment 'The date when the ground handler\'s operating license expires and must be renewed.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseIssuingAuthority rdf:type rdf:Property ;
    rdfs:label 'License Issuing Authority' ;
    rdfs:comment 'The name of the civil aviation authority or regulatory body that issued the ground handling license.' ;
    rdfs:domain ind:GroundHandler ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseNumber rdf:type rdf:Property ;
    rdfs:label 'License Number' ;
    rdfs:comment 'The regulatory license or permit number issued by the civil aviation authority authorizing ground handling operations.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onTimeDepartureContributionPct rdf:type rdf:Property ;
    rdfs:label 'On Time Departure Contribution Pct' ;
    rdfs:comment 'The percentage of flights handled by this provider that departed on time, measuring contribution to overall On-Time Performance (OTP).' ;
    rdfs:domain ind:GroundHandler ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:passengerHandlingFlag rdf:type rdf:Property ;
    rdfs:label 'Passenger Handling Flag' ;
    rdfs:comment 'Indicates whether the handler provides passenger services including check-in, boarding, and gate operations.' ;
    rdfs:domain ind:GroundHandler ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:penaltyTriggeredFlag rdf:type rdf:Property ;
    rdfs:label 'Penalty Triggered Flag' ;
    rdfs:comment 'Indicates whether contractual penalties have been triggered due to performance failures during the current period.' ;
    rdfs:domain ind:GroundHandler ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:performanceScore rdf:type rdf:Property ;
    rdfs:label 'Performance Score' ;
    rdfs:comment 'The composite performance score (0-100) calculated from weighted Key Performance Indicators (KPIs) including on-time performance, baggage handling, safety, and SLA compliance.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceTier rdf:type rdf:Property ;
    rdfs:label 'Performance Tier' ;
    rdfs:comment 'The current performance tier classification of the handler based on historical Service Level Agreement (SLA) compliance and quality metrics.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Email' ;
    rdfs:comment 'The email address of the primary operational contact at the ground handler.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactName rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Name' ;
    rdfs:comment 'The full name of the primary operational contact person at the ground handler for day-to-day coordination.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Phone' ;
    rdfs:comment 'The telephone number of the primary operational contact at the ground handler.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rampHandlingFlag rdf:type rdf:Property ;
    rdfs:label 'Ramp Handling Flag' ;
    rdfs:comment 'Indicates whether the handler provides ramp services including aircraft marshalling, chocking, towing, and ground power.' ;
    rdfs:domain ind:GroundHandler ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sghaAgreementReference rdf:type rdf:Property ;
    rdfs:label 'Sgha Agreement Reference' ;
    rdfs:comment 'The unique reference number of the Standard Ground Handling Agreement contract governing the relationship with this handler.' ;
    rdfs:domain ind:GroundHandler ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaBreachCount rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Count' ;
    rdfs:comment 'The total number of Service Level Agreement breaches recorded against this handler during the current measurement period.' ;
    rdfs:domain ind:GroundHandler ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gseAssetId rdf:type rdf:Property ;
    rdfs:label 'Gse Asset Id' ;
    rdfs:comment 'Unique identifier for the ground support equipment asset record. Primary key for the GSE asset master.' ;
    rdfs:domain ind:Airport ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GseAsset .

ind:homeStationId rdf:type rdf:Property ;
    rdfs:label 'Home Station Id' ;
    rdfs:comment 'Foreign key linking to airport.station. Business justification: gse_asset has a home station where it is normally based. Currently stores home_station_code (STRING). FK to station provides access to station details and ground handler. The home_station_code becomes' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Station .

ind:leaseContractId rdf:type rdf:Property ;
    rdfs:label 'Lease Contract Id' ;
    rdfs:comment 'Foreign key linking to finance.lease_contract. Business justification: Leased GSE equipment requires IFRS 16 lease accounting for right-of-use asset recognition, lease liability calculation, and financial statement reporting. Essential for lease portfolio management and ' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LeaseContract .

ind:owningVendorId rdf:type rdf:Property ;
    rdfs:label 'Owning Vendor Id' ;
    rdfs:comment 'Foreign key linking to procurement.vendor. Business justification: GSE assets are purchased or leased from vendors. Linking to vendor master enables tracking of supplier performance, warranty claims, maintenance contracts, and asset acquisition costs. Critical for fl' ;
    rdfs:domain ind:GseAsset ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:acquisitionCostAmount rdf:type rdf:Property ;
    rdfs:label 'Acquisition Cost Amount' ;
    rdfs:comment 'Original purchase or acquisition cost of the equipment in the reporting currency, used for asset valuation and depreciation calculations.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acquisitionCostCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Acquisition Cost Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the acquisition cost amount.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acquisitionDate rdf:type rdf:Property ;
    rdfs:label 'Acquisition Date' ;
    rdfs:comment 'Date on which the equipment was acquired by the owning organization, either through purchase, lease, or transfer.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:availabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Availability Flag' ;
    rdfs:comment 'Boolean indicator of whether the equipment is currently available for assignment to flight turnaround operations. True indicates the asset can be scheduled; false indicates it is unavailable.' ;
    rdfs:domain ind:GseAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capacityUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Capacity Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the capacity value, defining whether capacity is expressed in weight, power, volume, or passenger count.' ;
    rdfs:domain ind:GseAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityValue rdf:type rdf:Property ;
    rdfs:label 'Capacity Value' ;
    rdfs:comment 'Primary quantitative capacity specification for the equipment, such as towing capacity for tugs, power output for GPUs, or volume for fluid trucks. The principal measurement defining the equipment\'s operational capability.' ;
    rdfs:domain ind:GseAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Certification Expiry Date' ;
    rdfs:comment 'Date on which the current safety certification expires, requiring recertification or inspection before continued operation. Critical for compliance tracking.' ;
    rdfs:domain ind:Airport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:certificationNumber rdf:type rdf:Property ;
    rdfs:label 'Certification Number' ;
    rdfs:comment 'Official certification or approval number issued by the relevant aviation authority or safety body, confirming the equipment meets operational safety standards.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentStationCode rdf:type rdf:Property ;
    rdfs:label 'Current Station Code' ;
    rdfs:comment 'Three-letter IATA airport code identifying the current physical location of the equipment, which may differ from home station during temporary deployments or repositioning.' ;
    rdfs:domain ind:GseAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depreciationMethod rdf:type rdf:Property ;
    rdfs:label 'Depreciation Method' ;
    rdfs:comment 'Accounting method used to calculate depreciation expense for the equipment asset over its useful life.' ;
    rdfs:domain ind:GseAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Environmental Compliance Flag' ;
    rdfs:comment 'Boolean indicator of whether the equipment meets current environmental standards and emissions regulations applicable at the operating stations.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:equipmentRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Equipment Registration Number' ;
    rdfs:comment 'Official registration or serial number assigned to the GSE unit by the manufacturer or regulatory authority. Serves as the external business identifier for the asset.' ;
    rdfs:domain ind:GseAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentSubtype rdf:type rdf:Property ;
    rdfs:label 'Equipment Subtype' ;
    rdfs:comment 'Secondary classification providing additional detail on the equipment variant or model family within the primary equipment type.' ;
    rdfs:domain ind:GseAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equipmentTypeCode rdf:type rdf:Property ;
    rdfs:label 'Equipment Type Code' ;
    rdfs:comment 'Classification code identifying the functional type of ground support equipment. Defines the primary operational role of the asset in ground handling operations. [ENUM-REF-CANDIDATE: PUSHBACK_TRACTOR|GPU|AIR_STARTER|BELT_LOADER|CATERING_TRUCK|LAVATORY_TRUCK|WATER_TRUCK|DEICING_VEHICLE|PASSENGER_BUS|BAGGAGE_TUG|ULD_LOADER — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GseAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelType rdf:type rdf:Property ;
    rdfs:label 'Fuel Type' ;
    rdfs:comment 'Type of fuel or power source used by the equipment, relevant for refueling logistics, environmental reporting, and operational cost tracking.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gpsTrackingEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Gps Tracking Enabled Flag' ;
    rdfs:comment 'Boolean indicator of whether the equipment is equipped with GPS tracking technology for real-time location monitoring and fleet management.' ;
    rdfs:domain ind:GseAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maintenanceStatus rdf:type rdf:Property ;
    rdfs:label 'Maintenance Status' ;
    rdfs:comment 'Current state of the equipment\'s maintenance compliance, indicating whether maintenance is up to date, overdue, or actively being performed.' ;
    rdfs:domain ind:GseAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturerName rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Name' ;
    rdfs:comment 'Name of the company that manufactured the ground support equipment unit.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumTowingWeightKg rdf:type rdf:Property ;
    rdfs:label 'Maximum Towing Weight Kg' ;
    rdfs:comment 'Maximum aircraft weight in kilograms that the equipment can safely tow or push, applicable to pushback tractors and tugs. Critical for matching equipment to aircraft type.' ;
    rdfs:domain ind:GseAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modelDesignation rdf:type rdf:Property ;
    rdfs:label 'Model Designation' ;
    rdfs:comment 'Manufacturer\'s model number or designation for the equipment unit, identifying the specific product line and configuration.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingHoursTotal rdf:type rdf:Property ;
    rdfs:label 'Operating Hours Total' ;
    rdfs:comment 'Cumulative total operating hours logged for the equipment since commissioning, used for maintenance scheduling and lifecycle management.' ;
    rdfs:domain ind:GseAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:telematicsDeviceCode rdf:type rdf:Property ;
    rdfs:label 'Telematics Device Code' ;
    rdfs:comment 'Unique identifier for the telematics or IoT device installed on the equipment for remote monitoring of location, usage, and performance metrics.' ;
    rdfs:domain ind:GseAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usefulLifeYears rdf:type rdf:Property ;
    rdfs:label 'Useful Life Years' ;
    rdfs:comment 'Expected useful life of the equipment in years, used for depreciation calculations and replacement planning.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:yearOfManufacture rdf:type rdf:Property ;
    rdfs:label 'Year Of Manufacture' ;
    rdfs:comment 'Calendar year in which the equipment unit was manufactured, used for age tracking and depreciation calculations.' ;
    rdfs:domain ind:GseAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gseDeploymentId rdf:type rdf:Property ;
    rdfs:label 'Gse Deployment Id' ;
    rdfs:comment 'Unique identifier for the GSE deployment record. Primary key.' ;
    rdfs:domain ind:Airport ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GseDeployment .

ind:operatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Operator Employee Id' ;
    rdfs:comment 'Reference to the ground handling employee assigned to operate the GSE during this deployment. Links to the employee master record.' ;
    rdfs:domain ind:GseDeployment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:turnaroundId rdf:type rdf:Property ;
    rdfs:label 'Turnaround Id' ;
    rdfs:comment 'Reference to the aircraft turnaround operation this GSE deployment supports. Links to the turnaround master record.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Turnaround .

ind:actualDeploymentEndTime rdf:type rdf:Property ;
    rdfs:label 'Actual Deployment End Time' ;
    rdfs:comment 'The actual date and time when the GSE deployment ended and the equipment was released from the task.' ;
    rdfs:domain ind:GseDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualDeploymentStartTime rdf:type rdf:Property ;
    rdfs:label 'Actual Deployment Start Time' ;
    rdfs:comment 'The actual date and time when the GSE deployment began, captured from GSE tracking systems or operator logs.' ;
    rdfs:domain ind:GseDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cdmMessageReference rdf:type rdf:Property ;
    rdfs:label 'Cdm Message Reference' ;
    rdfs:comment 'Reference to the CDM message or milestone that triggered or updated this GSE deployment (e.g., TOBT, TSAT, AOBT). Supports CDM compliance and coordination.' ;
    rdfs:domain ind:Airport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costAllocationCode rdf:type rdf:Property ;
    rdfs:label 'Cost Allocation Code' ;
    rdfs:comment 'The cost center or allocation code to which the GSE deployment costs (fuel, labor, depreciation) are charged. Supports financial reporting and cost recovery.' ;
    rdfs:domain ind:GseDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectDescription rdf:type rdf:Property ;
    rdfs:label 'Defect Description' ;
    rdfs:comment 'Free-text description of any equipment defect, malfunction, or performance issue observed during the deployment. Populated when defect_noted_flag is true.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectNotedFlag rdf:type rdf:Property ;
    rdfs:label 'Defect Noted Flag' ;
    rdfs:comment 'Boolean flag indicating whether any equipment defect or malfunction was noted during this deployment. Triggers maintenance workflow.' ;
    rdfs:domain ind:GseDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:defectSeverity rdf:type rdf:Property ;
    rdfs:label 'Defect Severity' ;
    rdfs:comment 'Severity classification of the noted defect (e.g., minor, moderate, major, critical). Determines maintenance priority and equipment availability.' ;
    rdfs:domain ind:GseDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:delayDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Delay Duration Minutes' ;
    rdfs:comment 'The duration in minutes of any delay in GSE deployment or task completion, measured against planned times. Used for OTP analysis and resource planning.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:delayReason rdf:type rdf:Property ;
    rdfs:label 'Delay Reason' ;
    rdfs:comment 'Free-text description of the reason for any delay in GSE deployment or task completion (e.g., equipment unavailable, operator unavailable, weather, aircraft delay).' ;
    rdfs:domain ind:GseDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deploymentLocation rdf:type rdf:Property ;
    rdfs:label 'Deployment Location' ;
    rdfs:comment 'The specific physical location where the GSE was deployed (e.g., gate number, ramp position, hangar bay). Supports spatial analysis and resource optimization.' ;
    rdfs:domain ind:GseDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deploymentStatus rdf:type rdf:Property ;
    rdfs:label 'Deployment Status' ;
    rdfs:comment 'Current lifecycle status of the GSE deployment (e.g., scheduled, dispatched, in progress, completed, cancelled, delayed, equipment failure). [ENUM-REF-CANDIDATE: scheduled|dispatched|in_progress|completed|cancelled|delayed|equipment_failure — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GseDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatchTime rdf:type rdf:Property ;
    rdfs:label 'Dispatch Time' ;
    rdfs:comment 'The date and time when the GSE was dispatched from the equipment pool or staging area to the deployment location.' ;
    rdfs:domain ind:GseDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:electricityConsumedKwh rdf:type rdf:Property ;
    rdfs:label 'Electricity Consumed Kwh' ;
    rdfs:comment 'The quantity of electricity consumed by electric GSE during this deployment, measured in kilowatt-hours. Used for cost allocation and sustainability tracking.' ;
    rdfs:domain ind:GseDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelConsumedLiters rdf:type rdf:Property ;
    rdfs:label 'Fuel Consumed Liters' ;
    rdfs:comment 'The quantity of fuel consumed by the GSE during this deployment, measured in liters. Used for cost allocation and environmental reporting.' ;
    rdfs:domain ind:GseDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:idleDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Idle Duration Minutes' ;
    rdfs:comment 'The duration in minutes that the GSE was idle or waiting during this deployment (e.g., waiting for aircraft arrival, waiting for clearance). Used for efficiency analysis.' ;
    rdfs:domain ind:GseDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operatorCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Operator Certification Number' ;
    rdfs:comment 'The certification or license number of the operator assigned to this GSE deployment. Ensures compliance with training and qualification requirements.' ;
    rdfs:domain ind:GseDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedDeploymentEndTime rdf:type rdf:Property ;
    rdfs:label 'Planned Deployment End Time' ;
    rdfs:comment 'The scheduled date and time when the GSE deployment is planned to end, based on turnaround schedule and task duration estimates.' ;
    rdfs:domain ind:GseDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedDeploymentStartTime rdf:type rdf:Property ;
    rdfs:label 'Planned Deployment Start Time' ;
    rdfs:comment 'The scheduled date and time when the GSE deployment is planned to begin, based on turnaround schedule and CDM messages.' ;
    rdfs:domain ind:GseDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:priorityLevel rdf:type rdf:Property ;
    rdfs:label 'Priority Level' ;
    rdfs:comment 'Priority classification of the GSE deployment task (e.g., routine, high, urgent, critical). Influences dispatch sequencing and resource allocation.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnTime rdf:type rdf:Property ;
    rdfs:label 'Return Time' ;
    rdfs:comment 'The date and time when the GSE was returned to the equipment pool or staging area after deployment completion.' ;
    rdfs:domain ind:GseDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:safetyIncidentDescription rdf:type rdf:Property ;
    rdfs:label 'Safety Incident Description' ;
    rdfs:comment 'Free-text description of any safety incident, near-miss, or hazard observed during the deployment. Populated when safety_incident_flag is true.' ;
    rdfs:domain ind:GseDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyIncidentFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Incident Flag' ;
    rdfs:comment 'Boolean flag indicating whether a safety incident or near-miss occurred during this GSE deployment. Triggers safety investigation and SMS reporting.' ;
    rdfs:domain ind:Airport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceProviderCode rdf:type rdf:Property ;
    rdfs:label 'Service Provider Code' ;
    rdfs:comment 'Code identifying the ground handling service provider responsible for this GSE deployment (e.g., airline self-handling, third-party handler). Supports vendor performance tracking.' ;
    rdfs:domain ind:Airport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystem rdf:type rdf:Property ;
    rdfs:label 'Source System' ;
    rdfs:comment 'The name or code of the operational system that originated this GSE deployment record (e.g., SITA Airport Management Platform, ground handling system). Supports data lineage and integration troubleshooting.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskType rdf:type rdf:Property ;
    rdfs:label 'Task Type' ;
    rdfs:comment 'The specific ground handling task type for which the GSE is deployed (e.g., aircraft towing, baggage loading, ground power, de-icing). [ENUM-REF-CANDIDATE: aircraft_towing|baggage_loading|baggage_unloading|cargo_loading|cargo_unloading|ground_power|air_conditioning|potable_water|lavatory_service|fueling|de_icing|pushback|cabin_cleaning|catering_service|passenger_boarding|passenger_deplaning|maintenance_support — promote to reference product]' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utilizationDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Utilization Duration Minutes' ;
    rdfs:comment 'The total duration in minutes that the GSE was actively utilized during this deployment, calculated from actual start and end times. Used for utilization rate analysis.' ;
    rdfs:domain ind:GseDeployment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:weatherCondition rdf:type rdf:Property ;
    rdfs:label 'Weather Condition' ;
    rdfs:comment 'Weather condition at the time of GSE deployment (e.g., clear, rain, snow, ice, fog). Impacts task duration, safety, and equipment performance.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handlingPerformanceId rdf:type rdf:Property ;
    rdfs:label 'Handling Performance Id' ;
    rdfs:comment 'Unique identifier for the ground handler performance measurement record.' ;
    rdfs:domain ind:HandlingPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rampServiceOrderId rdf:type rdf:Property ;
    rdfs:label 'Ramp Service Order Id' ;
    rdfs:comment 'Foreign key linking to airport.ramp_service_order. Business justification: handling_performance measures performance against a specific ramp_service_order. Currently stores ramp_service_order_number (STRING). FK to ramp_service_order provides access to ordered services, SLA ' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RampServiceOrder .

ind:airlineRemarks rdf:type rdf:Property ;
    rdfs:label 'Airline Remarks' ;
    rdfs:comment 'Free-text remarks or notes provided by airline operations or quality assurance regarding handler performance. Used for dispute resolution and contract management.' ;
    rdfs:domain ind:HandlingPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baggageDeliveryTargetMinutes rdf:type rdf:Property ;
    rdfs:label 'Baggage Delivery Target Minutes' ;
    rdfs:comment 'Contractual target time in minutes for first baggage delivery. Defined in the SGHA or service level agreement with the ground handler.' ;
    rdfs:domain ind:HandlingPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baggageDeliveryTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Baggage Delivery Time Minutes' ;
    rdfs:comment 'Actual time in minutes from aircraft block-in to first baggage delivered to carousel or claim area. Key KPI for passenger experience and SGHA compliance.' ;
    rdfs:domain ind:HandlingPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cdmMilestoneComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Cdm Milestone Compliance Flag' ;
    rdfs:comment 'Indicates whether the ground handler met all CDM milestone reporting requirements for this turnaround. Critical for airport slot management and A-CDM compliance.' ;
    rdfs:domain ind:HandlingPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:damageIncidentCount rdf:type rdf:Property ;
    rdfs:label 'Damage Incident Count' ;
    rdfs:comment 'Number of damage incidents (aircraft, baggage, cargo, or GSE) attributed to the ground handler during this turnaround. Used for safety and quality performance tracking.' ;
    rdfs:domain ind:HandlingPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:damageRatePerTurnaround rdf:type rdf:Property ;
    rdfs:label 'Damage Rate Per Turnaround' ;
    rdfs:comment 'Calculated damage rate for this turnaround, expressed as incidents per turnaround. Used for trend analysis and handler comparison.' ;
    rdfs:domain ind:HandlingPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:delayCodeAttributed rdf:type rdf:Property ;
    rdfs:label 'Delay Code Attributed' ;
    rdfs:comment 'IATA two-digit delay code attributed to the ground handler if their performance caused or contributed to flight delay. Used for OTP analysis and accountability.' ;
    rdfs:domain ind:HandlingPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:delayMinutesAttributed rdf:type rdf:Property ;
    rdfs:label 'Delay Minutes Attributed' ;
    rdfs:comment 'Number of delay minutes attributed to the ground handler. Used for OTP impact assessment and cost recovery calculations.' ;
    rdfs:domain ind:HandlingPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:handlerRemarks rdf:type rdf:Property ;
    rdfs:label 'Handler Remarks' ;
    rdfs:comment 'Free-text remarks or notes provided by the ground handler regarding this turnaround performance. May include explanations for delays or incidents.' ;
    rdfs:domain ind:HandlingPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Measurement Period End' ;
    rdfs:comment 'End timestamp of the performance measurement window. Typically aligned with aircraft block-out time or service order completion.' ;
    rdfs:domain ind:HandlingPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:measurementPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Measurement Period Start' ;
    rdfs:comment 'Start timestamp of the performance measurement window. Typically aligned with aircraft block-in time or service order activation.' ;
    rdfs:domain ind:HandlingPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:measurementRecordedBy rdf:type rdf:Property ;
    rdfs:label 'Measurement Recorded By' ;
    rdfs:comment 'Identifier of the system, user, or automated process that recorded this performance measurement. Supports audit trail and data quality validation.' ;
    rdfs:domain ind:HandlingPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Measurement Source System' ;
    rdfs:comment 'Name or code of the source system that generated this performance measurement. Typically SITA Airport Management Platform, CDM system, or airline operations control system.' ;
    rdfs:domain ind:HandlingPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mishandledBaggageCount rdf:type rdf:Property ;
    rdfs:label 'Mishandled Baggage Count' ;
    rdfs:comment 'Number of baggage pieces mishandled (delayed, damaged, or lost) during this turnaround attributed to ground handler error. Key metric for IATA Resolution 753 compliance.' ;
    rdfs:domain ind:HandlingPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:noShowBagCount rdf:type rdf:Property ;
    rdfs:label 'No Show Bag Count' ;
    rdfs:comment 'Number of bags that failed to arrive at the aircraft for loading despite being checked in. Indicates handler process failures in baggage sorting or transport.' ;
    rdfs:domain ind:HandlingPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:onTimeDepartureContributionFlag rdf:type rdf:Property ;
    rdfs:label 'On Time Departure Contribution Flag' ;
    rdfs:comment 'Indicates whether the ground handler contributed to achieving on-time departure. True if handler completed all services within target time and did not cause delay.' ;
    rdfs:domain ind:HandlingPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:penaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Penalty Amount' ;
    rdfs:comment 'Calculated financial penalty amount in the contract currency resulting from SLA breach. Null if no penalty applies. Used for accounts payable adjustment.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Penalty Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the penalty amount. Aligns with the ground handling contract currency.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyTriggerFlag rdf:type rdf:Property ;
    rdfs:label 'Penalty Trigger Flag' ;
    rdfs:comment 'Indicates whether this performance measurement triggers a contractual penalty or financial adjustment. Used for automated billing and contract enforcement.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:safetyIncidentSeverity rdf:type rdf:Property ;
    rdfs:label 'Safety Incident Severity' ;
    rdfs:comment 'Severity classification of the safety incident if one occurred. Determines investigation depth and regulatory reporting requirements.' ;
    rdfs:domain ind:HandlingPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaBreachCategory rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Category' ;
    rdfs:comment 'Category of SLA breach if applicable. Classifies the type of performance failure for root cause analysis and penalty calculation.' ;
    rdfs:domain ind:HandlingPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaBreachFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Flag' ;
    rdfs:comment 'Indicates whether any SLA threshold defined in the SGHA was breached during this turnaround. Triggers contract review and potential penalty assessment.' ;
    rdfs:domain ind:HandlingPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:turnaroundCompletionStatus rdf:type rdf:Property ;
    rdfs:label 'Turnaround Completion Status' ;
    rdfs:comment 'Overall completion status of the turnaround from the handlers perspective. Indicates whether all contracted services were successfully delivered.' ;
    rdfs:domain ind:HandlingPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pfcRecordId rdf:type rdf:Property ;
    rdfs:label 'Pfc Record Id' ;
    rdfs:comment 'Unique identifier for the PFC record. Primary key.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PfcRecord .

ind:accountsReceivableId rdf:type rdf:Property ;
    rdfs:label 'Accounts Receivable Id' ;
    rdfs:comment 'Foreign key linking to finance.accounts_receivable. Business justification: Passenger Facility Charges collected by airlines create receivables from airport authorities or payables to authorities depending on collection method. Required for regulatory remittance tracking, DOT' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccountsReceivable .

ind:originalPfcRecordId rdf:type rdf:Property ;
    rdfs:label 'Original Pfc Record Id' ;
    rdfs:comment 'Reference to the original PFC record if this is an adjustment or correction. Links to the superseded record for audit trail.' ;
    rdfs:domain ind:PfcRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PfcRecord .

ind:adjustmentReasonCode rdf:type rdf:Property ;
    rdfs:label 'Adjustment Reason Code' ;
    rdfs:comment 'Code indicating the reason for any adjustment to the PFC amount. Examples include ticket refunds, exchanges, schedule changes, or data corrections.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Adjustment Reason Description' ;
    rdfs:comment 'Detailed explanation of the adjustment made to this PFC record. Provides audit trail for compliance and reconciliation.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:airportAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Airport Authority Name' ;
    rdfs:comment 'Legal name of the airport authority or municipality that imposed the PFC. Required for DOT remittance reporting.' ;
    rdfs:domain ind:PfcRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:airportCode rdf:type rdf:Property ;
    rdfs:label 'Airport Code' ;
    rdfs:comment 'Three-letter IATA airport code identifying the US airport authority that imposed this PFC. The airport where the charge applies.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arcReportPeriod rdf:type rdf:Property ;
    rdfs:label 'Arc Report Period' ;
    rdfs:comment 'ARC reporting period (YYYY-MM format) in which this PFC collection was reported. Used for reconciliation with ARC settlement data.' ;
    rdfs:domain ind:PfcRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bspPeriod rdf:type rdf:Property ;
    rdfs:label 'Bsp Period' ;
    rdfs:comment 'BSP billing period (YYYY-MM format) in which this PFC collection was processed. Used for international settlement reconciliation.' ;
    rdfs:domain ind:PfcRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectingCarrierCode rdf:type rdf:Property ;
    rdfs:label 'Collecting Carrier Code' ;
    rdfs:comment 'Two-character IATA airline code of the carrier that collected the PFC on behalf of the airport authority. May differ from the operating carrier in codeshare scenarios.' ;
    rdfs:domain ind:PfcRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectionDate rdf:type rdf:Property ;
    rdfs:label 'Collection Date' ;
    rdfs:comment 'Date on which the PFC was collected from the passenger. Typically the ticket issuance date or payment date.' ;
    rdfs:domain ind:PfcRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:collectionStatus rdf:type rdf:Property ;
    rdfs:label 'Collection Status' ;
    rdfs:comment 'Current lifecycle status of the PFC transaction. Tracks the charge from collection through remittance to the airport authority or refund to the passenger.' ;
    rdfs:domain ind:PfcRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dotReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Dot Reporting Flag' ;
    rdfs:comment 'Indicates whether this PFC record must be included in the quarterly DOT PFC reporting submission. True for all collected and remitted charges.' ;
    rdfs:domain ind:PfcRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exemptionCode rdf:type rdf:Property ;
    rdfs:label 'Exemption Code' ;
    rdfs:comment 'Code indicating the reason for PFC exemption if the charge was not collected. Examples include connecting passenger exemptions, through-ticketing exemptions, or regulatory waivers.' ;
    rdfs:domain ind:PfcRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exemptionReason rdf:type rdf:Property ;
    rdfs:label 'Exemption Reason' ;
    rdfs:comment 'Detailed explanation of why the PFC was exempted or not collected. Supports audit and compliance review.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pfcAmount rdf:type rdf:Property ;
    rdfs:label 'Pfc Amount' ;
    rdfs:comment 'Monetary amount of the PFC collected for this segment. Typically $4.50 per eligible segment under current DOT regulations, but may vary by airport approval.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pointOfSaleCountry rdf:type rdf:Property ;
    rdfs:label 'Point Of Sale Country' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code where the ticket was sold. Used for revenue accounting and regulatory reporting.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundAmount rdf:type rdf:Property ;
    rdfs:label 'Refund Amount' ;
    rdfs:comment 'Monetary amount of the PFC refunded to the passenger. May differ from the original collection amount due to partial refunds or currency adjustments.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:refundDate rdf:type rdf:Property ;
    rdfs:label 'Refund Date' ;
    rdfs:comment 'Date on which the PFC was refunded to the passenger due to ticket cancellation, schedule change, or other qualifying event.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remittanceBatchNumber rdf:type rdf:Property ;
    rdfs:label 'Remittance Batch Number' ;
    rdfs:comment 'Identifier of the remittance batch in which this PFC was submitted to the airport authority. Links to the batch payment and DOT reporting cycle.' ;
    rdfs:domain ind:PfcRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remittanceDate rdf:type rdf:Property ;
    rdfs:label 'Remittance Date' ;
    rdfs:comment 'Date on which the PFC was remitted to the airport authority. Must occur within the DOT-mandated remittance period (typically monthly).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:salesChannel rdf:type rdf:Property ;
    rdfs:label 'Sales Channel' ;
    rdfs:comment 'Channel through which the ticket and PFC were sold. GDS (Global Distribution System), airline direct website, OTA (Online Travel Agency), traditional travel agent, corporate booking tool, or call center.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementMethod rdf:type rdf:Property ;
    rdfs:label 'Settlement Method' ;
    rdfs:comment 'Method by which the PFC was settled. ARC (Airlines Reporting Corporation) for US domestic, BSP (Billing and Settlement Plan) for international, direct for airline-direct sales, or interline for interline ticketing agreements.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:travelDate rdf:type rdf:Property ;
    rdfs:label 'Travel Date' ;
    rdfs:comment 'Scheduled date of travel for the flight segment on which this PFC applies. Used for eligibility validation and reporting.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:coordinatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Coordinator Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Ramp service orders issued and coordinated by workforce operations staff for ground handler dispatch, SLA monitoring, and turnaround coordination. Standard airport operations practice.' ;
    rdfs:domain ind:Airport ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualCompletionMinutes rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Minutes' ;
    rdfs:comment 'Actual elapsed time in minutes from service window start to completion. Used to measure ground handler performance against SLA targets.' ;
    rdfs:domain ind:RampServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:baggageHandlingRequired rdf:type rdf:Property ;
    rdfs:label 'Baggage Handling Required' ;
    rdfs:comment 'Indicates whether baggage loading and unloading services are included in this ramp service order.' ;
    rdfs:domain ind:RampServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cargoHandlingRequired rdf:type rdf:Property ;
    rdfs:label 'Cargo Handling Required' ;
    rdfs:comment 'Indicates whether cargo and freight loading/unloading service is included in this ramp service order.' ;
    rdfs:domain ind:RampServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cateringServiceRequired rdf:type rdf:Property ;
    rdfs:label 'Catering Service Required' ;
    rdfs:comment 'Indicates whether inflight catering service is included in this ramp service order.' ;
    rdfs:domain ind:RampServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cleaningServiceRequired rdf:type rdf:Property ;
    rdfs:label 'Cleaning Service Required' ;
    rdfs:comment 'Indicates whether cabin and/or exterior cleaning service is included in this ramp service order.' ;
    rdfs:domain ind:RampServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:completionStatus rdf:type rdf:Property ;
    rdfs:label 'Completion Status' ;
    rdfs:comment 'Final status indicating whether all ordered services were successfully completed and the timeliness of completion. Used for SLA measurement and performance tracking.' ;
    rdfs:domain ind:RampServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Completion Timestamp' ;
    rdfs:comment 'Date and time when all ordered ramp services were completed and the aircraft was released for departure or parking.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deicingServiceRequired rdf:type rdf:Property ;
    rdfs:label 'Deicing Service Required' ;
    rdfs:comment 'Indicates whether aircraft de-icing or anti-icing service is included in this ramp service order. Critical for winter operations and safety compliance.' ;
    rdfs:domain ind:RampServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:flightOperationType rdf:type rdf:Property ;
    rdfs:label 'Flight Operation Type' ;
    rdfs:comment 'Type of flight operation for which ramp services are ordered. Turnaround indicates both arrival and departure services for a continuing flight.' ;
    rdfs:domain ind:RampServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelingServiceRequired rdf:type rdf:Property ;
    rdfs:label 'Fueling Service Required' ;
    rdfs:comment 'Indicates whether aircraft refueling service is included in this ramp service order.' ;
    rdfs:domain ind:RampServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:groundHandlerAcknowledgementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ground Handler Acknowledgement Timestamp' ;
    rdfs:comment 'Date and time when the ground handler acknowledged receipt and acceptance of the ramp service order.' ;
    rdfs:domain ind:RampServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:groundPowerRequired rdf:type rdf:Property ;
    rdfs:label 'Ground Power Required' ;
    rdfs:comment 'Indicates whether ground electrical power supply service is included in this ramp service order.' ;
    rdfs:domain ind:RampServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lavatoryServiceRequired rdf:type rdf:Property ;
    rdfs:label 'Lavatory Service Required' ;
    rdfs:comment 'Indicates whether lavatory waste removal and servicing is included in this ramp service order.' ;
    rdfs:domain ind:RampServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orderIssuedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Order Issued Timestamp' ;
    rdfs:comment 'Date and time when the ramp service order was officially issued to the ground handler. Represents the principal business event timestamp for this transaction.' ;
    rdfs:domain ind:RampServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:orderPriority rdf:type rdf:Property ;
    rdfs:label 'Order Priority' ;
    rdfs:comment 'Priority level assigned to this ramp service order. Critical priority typically assigned to IROP recovery, VIP flights, or tight connection scenarios.' ;
    rdfs:domain ind:RampServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderStatus rdf:type rdf:Property ;
    rdfs:label 'Order Status' ;
    rdfs:comment 'Current lifecycle status of the ramp service order. Tracks progression from issuance through completion or cancellation. [ENUM-REF-CANDIDATE: draft|issued|acknowledged|in_progress|completed|cancelled|suspended — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passengerHandlingRequired rdf:type rdf:Property ;
    rdfs:label 'Passenger Handling Required' ;
    rdfs:comment 'Indicates whether passenger boarding and deplaning services are included in this ramp service order.' ;
    rdfs:domain ind:RampServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:potableWaterServiceRequired rdf:type rdf:Property ;
    rdfs:label 'Potable Water Service Required' ;
    rdfs:comment 'Indicates whether potable water replenishment service is included in this ramp service order.' ;
    rdfs:domain ind:RampServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preconditionedAirRequired rdf:type rdf:Property ;
    rdfs:label 'Preconditioned Air Required' ;
    rdfs:comment 'Indicates whether preconditioned air supply for cabin climate control is included in this ramp service order.' ;
    rdfs:domain ind:RampServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pushbackTowingRequired rdf:type rdf:Property ;
    rdfs:label 'Pushback Towing Required' ;
    rdfs:comment 'Indicates whether aircraft pushback or towing service is included in this ramp service order.' ;
    rdfs:domain ind:RampServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduledArrivalTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Arrival Time' ;
    rdfs:comment 'Planned arrival time of the aircraft at the gate. Used to coordinate service window timing for arrival-related services.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledDepartureTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Departure Time' ;
    rdfs:comment 'Planned departure time of the aircraft from the gate. Used to coordinate service window timing and ensure all services are completed before pushback.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:serviceDeviationFlag rdf:type rdf:Property ;
    rdfs:label 'Service Deviation Flag' ;
    rdfs:comment 'Indicates whether any deviations from the ordered services occurred during execution. Triggers review of deviation notes and potential SLA impact.' ;
    rdfs:domain ind:RampServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceDeviationNotes rdf:type rdf:Property ;
    rdfs:label 'Service Deviation Notes' ;
    rdfs:comment 'Detailed notes describing any deviations, exceptions, or issues encountered during ramp service execution. Includes reasons for incomplete services, delays, or quality issues.' ;
    rdfs:domain ind:RampServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Service Order Number' ;
    rdfs:comment 'Externally-known unique business identifier for the ramp service order. Used for tracking and communication with ground handlers.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceOrderType rdf:type rdf:Property ;
    rdfs:label 'Service Order Type' ;
    rdfs:comment 'Classification of the ramp service order indicating the nature and priority of services required. IROP indicates irregular operations requiring expedited or special handling.' ;
    rdfs:domain ind:RampServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceWindowEndTime rdf:type rdf:Property ;
    rdfs:label 'Service Window End Time' ;
    rdfs:comment 'Latest time by which all ramp services must be completed. Critical for ensuring on-time departure and compliance with slot times.' ;
    rdfs:domain ind:Airport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:serviceWindowStartTime rdf:type rdf:Property ;
    rdfs:label 'Service Window Start Time' ;
    rdfs:comment 'Earliest time when ramp services may commence. Defines the beginning of the operational window for ground handler access to the aircraft.' ;
    rdfs:domain ind:Airport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:slaTargetCompletionMinutes rdf:type rdf:Property ;
    rdfs:label 'Sla Target Completion Minutes' ;
    rdfs:comment 'Target turnaround time in minutes for completing all ramp services as defined in the ground handling service level agreement.' ;
    rdfs:domain ind:RampServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:specialServiceInstructions rdf:type rdf:Property ;
    rdfs:label 'Special Service Instructions' ;
    rdfs:comment 'Free-text field capturing any special instructions, requirements, or notes for the ground handler regarding service execution. May include VIP handling, hazmat cargo, oversized baggage, or IROP recovery instructions.' ;
    rdfs:domain ind:RampServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slotId rdf:type rdf:Property ;
    rdfs:label 'Slot Id' ;
    rdfs:comment 'Unique identifier for the airport slot record. Primary key.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Slot .

ind:aircraftTypeId rdf:type rdf:Property ;
    rdfs:label 'Aircraft Type Id' ;
    rdfs:comment 'Foreign key linking to fleet.aircraft_type. Business justification: Slot compliance monitoring (noise chapter restrictions, wake turbulence separation), coordinator reporting, and slot utilization analysis by aircraft type require aircraft_type linkage. Regulatory com' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AircraftType .

ind:actualFlightReference rdf:type rdf:Property ;
    rdfs:label 'Actual Flight Reference' ;
    rdfs:comment 'Reference to the actual flight that operated using this slot, typically the flight leg identifier or operational flight number. Used for post-operation reconciliation and compliance tracking. Null if slot was not used.' ;
    rdfs:domain ind:Slot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualOperationDate rdf:type rdf:Property ;
    rdfs:label 'Actual Operation Date' ;
    rdfs:comment 'The specific date on which this slot was actually used for a flight operation. Populated post-operation for utilization tracking. Null if not yet operated or if slot was not used.' ;
    rdfs:domain ind:Slot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualOperationTime rdf:type rdf:Property ;
    rdfs:label 'Actual Operation Time' ;
    rdfs:comment 'The actual timestamp when the flight operation occurred (actual takeoff time for departure slots, actual landing time for arrival slots). Used to calculate variance from allocated time. Null if not yet operated.' ;
    rdfs:domain ind:Slot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:airlineDesignator rdf:type rdf:Property ;
    rdfs:label 'Airline Designator' ;
    rdfs:comment 'Two or three-character IATA airline code of the carrier to whom this slot is allocated (e.g., BA, AA, LH).' ;
    rdfs:domain ind:Slot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocatedTime rdf:type rdf:Property ;
    rdfs:label 'Allocated Time' ;
    rdfs:comment 'The specific date and time allocated for this slot operation (takeoff or landing). This is the coordinated time assigned by the slot coordinator.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:allocationDate rdf:type rdf:Property ;
    rdfs:label 'Allocation Date' ;
    rdfs:comment 'Date when this slot was initially allocated to the airline by the slot coordinator.' ;
    rdfs:domain ind:Airport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Status' ;
    rdfs:comment 'Indicates whether the slot was used in compliance with allocation: used (operated within tolerance), missed (not operated without valid reason), cancelled (airline cancelled in advance), swapped (exchanged with another slot), not_yet_operated (future slot).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmationDate rdf:type rdf:Property ;
    rdfs:label 'Confirmation Date' ;
    rdfs:comment 'Date when the airline confirmed intention to use this slot. Null if not yet confirmed.' ;
    rdfs:domain ind:Airport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:coordinatorReference rdf:type rdf:Property ;
    rdfs:label 'Coordinator Reference' ;
    rdfs:comment 'Reference number or identifier assigned by the airport slot coordinator (e.g., Airport Coordination Limited, Flughafen-Koordinierung Deutschland) for tracking and correspondence.' ;
    rdfs:domain ind:Slot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:historicPrecedenceFlag rdf:type rdf:Property ;
    rdfs:label 'Historic Precedence Flag' ;
    rdfs:comment 'Indicates whether this slot carries historic precedence (grandfather rights) under IATA 80/20 rule, meaning the airline used the slot at least 80% of the time in the previous equivalent season and has priority for renewal.' ;
    rdfs:domain ind:Airport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iataSeason rdf:type rdf:Property ;
    rdfs:label 'Iata Season' ;
    rdfs:comment 'IATA scheduling season for which this slot is allocated, in format S## (summer) or W## (winter), e.g., S23, W23. IATA seasons run summer (last Sunday March to last Saturday October) and winter (last Sunday October to last Saturday March).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:justificationCategory rdf:type rdf:Property ;
    rdfs:label 'Justification Category' ;
    rdfs:comment 'Categorized reason for non-compliance or slot misuse. Weather: meteorological conditions; ATC delay: air traffic control restrictions; Technical: aircraft maintenance or defect; Operational: crew, ground handling, or airport issues; Commercial: passenger or cargo demand changes; Other: miscellaneous.' ;
    rdfs:domain ind:Slot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonComplianceReason rdf:type rdf:Property ;
    rdfs:label 'Non Compliance Reason' ;
    rdfs:comment 'Free-text explanation for why a slot was missed or operated outside tolerance. May reference weather, Air Traffic Control (ATC) delays, technical issues, or other justifiable causes. Used for regulatory reporting and historic precedence calculations.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notes rdf:type rdf:Property ;
    rdfs:label 'Notes' ;
    rdfs:comment 'Free-text field for additional comments, special conditions, or operational notes related to this slot allocation. May include coordinator instructions, special handling requirements, or historical context.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poolCategory rdf:type rdf:Property ;
    rdfs:label 'Pool Category' ;
    rdfs:comment 'Classification of the slot pool from which this slot was allocated. New entrant: reserved for new carriers; Domestic: domestic operations; International: international operations; General: unrestricted pool. Used for regulatory compliance and fair competition monitoring.' ;
    rdfs:domain ind:Slot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:series rdf:type rdf:Property ;
    rdfs:label 'Series' ;
    rdfs:comment 'Indicates whether this is a regular series slot (recurring throughout the season) or an ad-hoc slot (one-time or irregular operation).' ;
    rdfs:domain ind:Slot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seriesIdentifier rdf:type rdf:Property ;
    rdfs:label 'Series Identifier' ;
    rdfs:comment 'Unique identifier linking this slot to a series of recurring slots. Populated for regular series slots; null for ad-hoc slots.' ;
    rdfs:domain ind:Slot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceType rdf:type rdf:Property ;
    rdfs:label 'Service Type' ;
    rdfs:comment 'Type of flight service this slot is allocated for: passenger (revenue passenger service), cargo (freight service), ferry (non-revenue aircraft repositioning with no payload), positioning (deadhead crew or aircraft movement).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slotStatus rdf:type rdf:Property ;
    rdfs:label 'Slot Status' ;
    rdfs:comment 'Current lifecycle status of the slot allocation. Allocated: initially assigned; Confirmed: airline confirmed usage; Returned: handed back to coordinator; Swapped: exchanged with another carrier; Cancelled: withdrawn; Suspended: temporarily inactive.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slotType rdf:type rdf:Property ;
    rdfs:label 'Slot Type' ;
    rdfs:comment 'Indicates whether this slot is for an arrival or departure operation at the airport.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:swapDate rdf:type rdf:Property ;
    rdfs:label 'Swap Date' ;
    rdfs:comment 'Date when the slot swap transaction was executed and recorded with the slot coordinator. Null if no swap occurred.' ;
    rdfs:domain ind:Slot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:swapPartnerAirline rdf:type rdf:Property ;
    rdfs:label 'Swap Partner Airline' ;
    rdfs:comment 'IATA airline code of the carrier with whom this slot was swapped, if applicable. Null if no swap occurred.' ;
    rdfs:domain ind:Slot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeVarianceMinutes rdf:type rdf:Property ;
    rdfs:label 'Time Variance Minutes' ;
    rdfs:comment 'Difference in minutes between allocated slot time and actual operation time. Positive values indicate late operation, negative values indicate early operation. Used for compliance monitoring against tolerance thresholds (typically +/- 5 or 15 minutes depending on airport rules).' ;
    rdfs:domain ind:Slot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slotUtilizationId rdf:type rdf:Property ;
    rdfs:label 'Slot Utilization Id' ;
    rdfs:comment 'Unique identifier for the slot utilization transaction record.' ;
    rdfs:domain ind:SlotUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualArrivalTime rdf:type rdf:Property ;
    rdfs:label 'Actual Arrival Time' ;
    rdfs:comment 'The actual on-block or landing time recorded for the flight operation.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualDepartureTime rdf:type rdf:Property ;
    rdfs:label 'Actual Departure Time' ;
    rdfs:comment 'The actual off-block or takeoff time recorded for the flight operation.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:arrivalVarianceMinutes rdf:type rdf:Property ;
    rdfs:label 'Arrival Variance Minutes' ;
    rdfs:comment 'The difference in minutes between planned and actual arrival time, calculated as actual minus planned. Positive values indicate delay, negative values indicate early arrival.' ;
    rdfs:domain ind:SlotUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cdmMessageTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cdm Message Timestamp' ;
    rdfs:comment 'Timestamp of the Airport CDM message that confirmed the actual slot utilization, typically sourced from SITA Airport Management Platform or equivalent CDM system.' ;
    rdfs:domain ind:SlotUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:departureVarianceMinutes rdf:type rdf:Property ;
    rdfs:label 'Departure Variance Minutes' ;
    rdfs:comment 'The difference in minutes between planned and actual departure time, calculated as actual minus planned. Positive values indicate delay, negative values indicate early departure.' ;
    rdfs:domain ind:SlotUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:historicRightsProtectedFlag rdf:type rdf:Property ;
    rdfs:label 'Historic Rights Protected Flag' ;
    rdfs:comment 'Indicator of whether this slot utilization contributes to the airline\'s historic rights (grandfather rights) for future season slot allocation under the 80/20 use-it-or-lose-it rule.' ;
    rdfs:domain ind:SlotUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nonComplianceReasonCode rdf:type rdf:Property ;
    rdfs:label 'Non Compliance Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for slot non-compliance or variance, such as weather delay, technical issue, air traffic control restriction, or operational irregularity.' ;
    rdfs:domain ind:SlotUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonComplianceReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Non Compliance Reason Description' ;
    rdfs:comment 'Detailed narrative explanation of the circumstances that led to slot non-compliance or significant variance from the allocated time.' ;
    rdfs:domain ind:SlotUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatedDate rdf:type rdf:Property ;
    rdfs:label 'Operated Date' ;
    rdfs:comment 'The calendar date on which the slot was actually utilized by the flight operation.' ;
    rdfs:domain ind:SlotUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedArrivalTime rdf:type rdf:Property ;
    rdfs:label 'Planned Arrival Time' ;
    rdfs:comment 'The scheduled arrival time as allocated in the original slot assignment.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedDepartureTime rdf:type rdf:Property ;
    rdfs:label 'Planned Departure Time' ;
    rdfs:comment 'The scheduled departure time as allocated in the original slot assignment.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:seasonCode rdf:type rdf:Property ;
    rdfs:label 'Season Code' ;
    rdfs:comment 'IATA scheduling season identifier (e.g., S23 for Summer 2023, W23 for Winter 2023/24) during which the slot was allocated and utilized.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slotCoordinatorCode rdf:type rdf:Property ;
    rdfs:label 'Slot Coordinator Code' ;
    rdfs:comment 'Three-letter IATA airport code identifying the slot coordination authority responsible for this slot allocation.' ;
    rdfs:domain ind:Airport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slotReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Slot Reference Number' ;
    rdfs:comment 'External business identifier for the slot allocation as issued by the slot coordinator.' ;
    rdfs:domain ind:SlotUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slotSeriesIndicator rdf:type rdf:Property ;
    rdfs:label 'Slot Series Indicator' ;
    rdfs:comment 'Classification indicating whether this slot utilization is part of a recurring series allocation or an ad-hoc one-time slot request.' ;
    rdfs:domain ind:SlotUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:swapTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Swap Transaction Reference' ;
    rdfs:comment 'Reference to the slot swap transaction record if this slot utilization resulted from a slot exchange agreement between carriers.' ;
    rdfs:domain ind:SlotUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:utilizationRecordedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Utilization Recorded Timestamp' ;
    rdfs:comment 'System timestamp when this slot utilization record was first captured in the airport operations system.' ;
    rdfs:domain ind:SlotUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:managerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Station manager normalization from denormalized text fields. Essential for org hierarchy, performance reviews, cost center accountability, and operational escalation paths. High-value 3NF enforcement.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:regulatoryAuthorityId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_authority. Business justification: Stations operate under jurisdiction of specific regulatory authorities (FAA for US stations, EASA for EU, CAAC for China). Essential for determining applicable regulations, filing requirements, and au' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryAuthority .

ind:cargoHandlingCapableFlag rdf:type rdf:Property ;
    rdfs:label 'Cargo Handling Capable Flag' ;
    rdfs:comment 'Indicates whether the station has facilities and capability for cargo and freight handling operations. True if capable, false otherwise.' ;
    rdfs:domain ind:Station ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cdmEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Cdm Enabled Flag' ;
    rdfs:comment 'Indicates whether the station participates in Airport CDM processes for collaborative operational decision-making. True if CDM-enabled, false otherwise.' ;
    rdfs:domain ind:Airport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cityName rdf:type rdf:Property ;
    rdfs:label 'City Name' ;
    rdfs:comment 'Name of the city where the station is located, used for route planning and passenger information.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedDate rdf:type rdf:Property ;
    rdfs:label 'Closed Date' ;
    rdfs:comment 'Date when the airline ceased operations at this station, if applicable. Null for active stations.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:countryCode rdf:type rdf:Property ;
    rdfs:label 'Country Code' ;
    rdfs:comment 'Three-letter ISO country code identifying the country where the station operates.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsFacilityAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Customs Facility Available Flag' ;
    rdfs:comment 'Indicates whether customs clearance facilities are available at the station for international arrivals. True if available, false otherwise.' ;
    rdfs:domain ind:Station ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dangerousGoodsCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Dangerous Goods Certified Flag' ;
    rdfs:comment 'Indicates whether the station is certified to handle dangerous goods shipments per IATA regulations. True if certified, false otherwise.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:daylightSavingObservedFlag rdf:type rdf:Property ;
    rdfs:label 'Daylight Saving Observed Flag' ;
    rdfs:comment 'Indicates whether the station location observes daylight saving time adjustments. True if DST is observed, false otherwise.' ;
    rdfs:domain ind:Station ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:elevationMeters rdf:type rdf:Property ;
    rdfs:label 'Elevation Meters' ;
    rdfs:comment 'Airport elevation above mean sea level in meters, critical for aircraft performance calculations and flight planning.' ;
    rdfs:domain ind:Station ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fuelProviderCode rdf:type rdf:Property ;
    rdfs:label 'Fuel Provider Code' ;
    rdfs:comment 'Code identifying the primary aviation fuel supplier at this station.' ;
    rdfs:domain ind:Station ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hubClassification rdf:type rdf:Property ;
    rdfs:label 'Hub Classification' ;
    rdfs:comment 'Classification of the station within the airline\'s network topology. Hub: major connecting point with extensive operations. Focus city: secondary hub with significant operations. Spoke: destination served from hub. Outstation: remote station with limited operations.' ;
    rdfs:domain ind:Airport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iataAirportCode rdf:type rdf:Property ;
    rdfs:label 'Iata Airport Code' ;
    rdfs:comment 'Three-letter IATA airport code identifying the airport where this station operates. Standard industry identifier for airport locations.' ;
    rdfs:domain ind:Station ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icaoAirportCode rdf:type rdf:Property ;
    rdfs:label 'Icao Airport Code' ;
    rdfs:comment 'Four-letter ICAO airport code providing globally unique airport identification used in flight planning and air traffic control.' ;
    rdfs:domain ind:Station ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:immigrationFacilityAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Immigration Facility Available Flag' ;
    rdfs:comment 'Indicates whether immigration processing facilities are available at the station for international passengers. True if available, false otherwise.' ;
    rdfs:domain ind:Station ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maintenanceCapabilityLevel rdf:type rdf:Property ;
    rdfs:label 'Maintenance Capability Level' ;
    rdfs:comment 'Level of aircraft maintenance capability available at the station. None: no maintenance. Line: routine checks and minor repairs. Base: scheduled maintenance and component replacement. Heavy: major overhaul and structural work.' ;
    rdfs:domain ind:Station ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openedDate rdf:type rdf:Property ;
    rdfs:label 'Opened Date' ;
    rdfs:comment 'Date when the airline first began operations at this station.' ;
    rdfs:domain ind:Station ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operationalHoursDescription rdf:type rdf:Property ;
    rdfs:label 'Operational Hours Description' ;
    rdfs:comment 'Detailed description of station operating hours, including daily schedules, seasonal variations, and any restrictions.' ;
    rdfs:domain ind:Station ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationalHoursType rdf:type rdf:Property ;
    rdfs:label 'Operational Hours Type' ;
    rdfs:comment 'Classification of station operating hours. 24x7: continuous operations. Scheduled: fixed daily hours. Seasonal: varies by season or demand.' ;
    rdfs:domain ind:Station ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overnightParkingCapableFlag rdf:type rdf:Property ;
    rdfs:label 'Overnight Parking Capable Flag' ;
    rdfs:comment 'Indicates whether the station has facilities and authorization for overnight aircraft parking. True if capable, false otherwise.' ;
    rdfs:domain ind:Station ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slotCoordinatedFlag rdf:type rdf:Property ;
    rdfs:label 'Slot Coordinated Flag' ;
    rdfs:comment 'Indicates whether the airport is slot-coordinated, requiring advance allocation of takeoff and landing slots. True if slot-coordinated, false otherwise.' ;
    rdfs:domain ind:Airport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stationName rdf:type rdf:Property ;
    rdfs:label 'Station Name' ;
    rdfs:comment 'Official name of the airline operating station, typically matching the airport name or city served.' ;
    rdfs:domain ind:Station ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeZone rdf:type rdf:Property ;
    rdfs:label 'Time Zone' ;
    rdfs:comment 'IANA time zone identifier for the station location, used for flight scheduling and operational coordination.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utcOffsetHours rdf:type rdf:Property ;
    rdfs:label 'Utc Offset Hours' ;
    rdfs:comment 'Standard UTC offset in hours for the station location, excluding daylight saving time adjustments.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:facilityManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Facility Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Terminal facilities require operational managers from workforce for day-to-day operations, staff coordination, and incident response. Aviation operations standard practice to assign facility managers.' ;
    rdfs:domain ind:TerminalFacility ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accessibilityComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Accessibility Compliance Flag' ;
    rdfs:comment 'Indicates whether the terminal facility meets accessibility standards for passengers with reduced mobility (PRM) including wheelchair access, accessible counters, and assistance services.' ;
    rdfs:domain ind:TerminalFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:annualPassengerVolume rdf:type rdf:Property ;
    rdfs:label 'Annual Passenger Volume' ;
    rdfs:comment 'Total number of passengers processed through this terminal facility in the most recent full calendar year.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bagDropCounterCount rdf:type rdf:Property ;
    rdfs:label 'Bag Drop Counter Count' ;
    rdfs:comment 'Number of dedicated self-service bag drop counters for passengers who have completed online or kiosk check-in.' ;
    rdfs:domain ind:TerminalFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:checkInCounterCount rdf:type rdf:Property ;
    rdfs:label 'Check In Counter Count' ;
    rdfs:comment 'Total number of full-service check-in counters staffed by airline agents for passenger processing and baggage acceptance.' ;
    rdfs:domain ind:TerminalFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contactGateCount rdf:type rdf:Property ;
    rdfs:label 'Contact Gate Count' ;
    rdfs:comment 'Number of contact gates equipped with jet bridges for direct aircraft-to-terminal passenger boarding.' ;
    rdfs:domain ind:TerminalFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:counterZoneDesignation rdf:type rdf:Property ;
    rdfs:label 'Counter Zone Designation' ;
    rdfs:comment 'Alphanumeric designation of check-in counter zones within the terminal (e.g., Zone A, Rows 1-20, Island 3).' ;
    rdfs:domain ind:TerminalFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsFacilityFlag rdf:type rdf:Property ;
    rdfs:label 'Customs Facility Flag' ;
    rdfs:comment 'Indicates whether the terminal has customs and border control facilities for international passenger processing.' ;
    rdfs:domain ind:TerminalFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:facilityAddress rdf:type rdf:Property ;
    rdfs:label 'Facility Address' ;
    rdfs:comment 'Physical street address of the terminal facility for operational coordination and ground transportation routing.' ;
    rdfs:domain ind:TerminalFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityCity rdf:type rdf:Property ;
    rdfs:label 'Facility City' ;
    rdfs:comment 'City where the terminal facility is located.' ;
    rdfs:domain ind:TerminalFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityCountryCode rdf:type rdf:Property ;
    rdfs:label 'Facility Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code for the terminal facility location (e.g., USA, GBR, ARE).' ;
    rdfs:domain ind:TerminalFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityEmail rdf:type rdf:Property ;
    rdfs:label 'Facility Email' ;
    rdfs:comment 'Primary email address for terminal facility operational communications and coordination.' ;
    rdfs:domain ind:TerminalFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityPhone rdf:type rdf:Property ;
    rdfs:label 'Facility Phone' ;
    rdfs:comment 'Primary contact telephone number for terminal facility operations and coordination.' ;
    rdfs:domain ind:TerminalFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityPostalCode rdf:type rdf:Property ;
    rdfs:label 'Facility Postal Code' ;
    rdfs:comment 'Postal or ZIP code for the terminal facility address.' ;
    rdfs:domain ind:TerminalFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityType rdf:type rdf:Property ;
    rdfs:label 'Facility Type' ;
    rdfs:comment 'Classification of the terminal facility structure type.' ;
    rdfs:domain ind:TerminalFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastRenovationDate rdf:type rdf:Property ;
    rdfs:label 'Last Renovation Date' ;
    rdfs:comment 'Date of the most recent major renovation or modernization project completed for this terminal facility.' ;
    rdfs:domain ind:TerminalFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:loungeCount rdf:type rdf:Property ;
    rdfs:label 'Lounge Count' ;
    rdfs:comment 'Number of airline lounges operated within this terminal facility for premium passengers and Frequent Flyer Program (FFP) members.' ;
    rdfs:domain ind:TerminalFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:openingDate rdf:type rdf:Property ;
    rdfs:label 'Opening Date' ;
    rdfs:comment 'Date when the terminal facility first became operational for passenger services.' ;
    rdfs:domain ind:TerminalFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ownershipModel rdf:type rdf:Property ;
    rdfs:label 'Ownership Model' ;
    rdfs:comment 'Designation of facility ownership and usage rights (airline-owned, joint-use with other carriers, or airport authority managed).' ;
    rdfs:domain ind:TerminalFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passengerCapacityPerHour rdf:type rdf:Property ;
    rdfs:label 'Passenger Capacity Per Hour' ;
    rdfs:comment 'Design capacity of the terminal facility measured in passengers (PAX) that can be processed per hour during peak operations.' ;
    rdfs:domain ind:TerminalFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:remoteGateCount rdf:type rdf:Property ;
    rdfs:label 'Remote Gate Count' ;
    rdfs:comment 'Number of remote gates requiring bus transportation for passenger boarding (no jet bridge connection).' ;
    rdfs:domain ind:TerminalFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:securityCheckpointCount rdf:type rdf:Property ;
    rdfs:label 'Security Checkpoint Count' ;
    rdfs:comment 'Number of Transportation Security Administration (TSA) or equivalent security screening checkpoints in the terminal facility.' ;
    rdfs:domain ind:TerminalFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:selfServiceKioskCount rdf:type rdf:Property ;
    rdfs:label 'Self Service Kiosk Count' ;
    rdfs:comment 'Number of self-service check-in kiosks (CUSS - Common Use Self-Service) available for passenger self-check-in.' ;
    rdfs:domain ind:TerminalFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:terminalAreaSqm rdf:type rdf:Property ;
    rdfs:label 'Terminal Area Sqm' ;
    rdfs:comment 'Total floor area of the terminal facility measured in square meters.' ;
    rdfs:domain ind:TerminalFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalGateCount rdf:type rdf:Property ;
    rdfs:label 'Total Gate Count' ;
    rdfs:comment 'Total number of aircraft gates available in this terminal facility for passenger boarding and deplaning operations.' ;
    rdfs:domain ind:TerminalFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:turnaroundInboundFlightLegId rdf:type rdf:Property ;
    rdfs:label 'Turnaround Inbound Flight Leg Id' ;
    rdfs:comment 'Reference to the arriving flight leg that initiates this turnaround event.' ;
    rdfs:domain ind:Turnaround ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FlightLeg .

ind:turnaroundOutboundFlightLegId rdf:type rdf:Property ;
    rdfs:label 'Turnaround Outbound Flight Leg Id' ;
    rdfs:comment 'Reference to the departing flight leg that concludes this turnaround event.' ;
    rdfs:domain ind:Turnaround ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FlightLeg .

ind:actualBlockInTime rdf:type rdf:Property ;
    rdfs:label 'Actual Block In Time' ;
    rdfs:comment 'Actual timestamp when the inbound aircraft arrived at the gate and parking brake was set (OOOI - On event).' ;
    rdfs:domain ind:Turnaround ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualBlockOutTime rdf:type rdf:Property ;
    rdfs:label 'Actual Block Out Time' ;
    rdfs:comment 'Actual timestamp when the outbound aircraft pushed back from the gate and began taxi (OOOI - Off event).' ;
    rdfs:domain ind:Turnaround ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualTurnaroundTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Actual Turnaround Time Minutes' ;
    rdfs:comment 'Actual duration in minutes from block-in to block-out. Calculated as the difference between actual_block_out_time and actual_block_in_time.' ;
    rdfs:domain ind:Turnaround ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allServicesCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'All Services Completed Flag' ;
    rdfs:comment 'Indicates whether all ordered ground services have been completed and signed off. True when turnaround is ready for departure.' ;
    rdfs:domain ind:Turnaround ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:baggagePiecesLoaded rdf:type rdf:Property ;
    rdfs:label 'Baggage Pieces Loaded' ;
    rdfs:comment 'Total number of baggage pieces loaded onto the outbound flight during turnaround.' ;
    rdfs:domain ind:Turnaround ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:baggagePiecesOffloaded rdf:type rdf:Property ;
    rdfs:label 'Baggage Pieces Offloaded' ;
    rdfs:comment 'Total number of baggage pieces offloaded from the inbound flight during turnaround.' ;
    rdfs:domain ind:Turnaround ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cargoWeightLoadedKg rdf:type rdf:Property ;
    rdfs:label 'Cargo Weight Loaded Kg' ;
    rdfs:comment 'Total weight in kilograms of cargo and mail loaded onto the outbound flight.' ;
    rdfs:domain ind:Turnaround ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cargoWeightOffloadedKg rdf:type rdf:Property ;
    rdfs:label 'Cargo Weight Offloaded Kg' ;
    rdfs:comment 'Total weight in kilograms of cargo and mail offloaded from the inbound flight.' ;
    rdfs:domain ind:Turnaround ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:delayMinutes rdf:type rdf:Property ;
    rdfs:label 'Delay Minutes' ;
    rdfs:comment 'Total delay in minutes attributed to turnaround operations. Calculated as actual_turnaround_time_minutes minus target_turnaround_time_minutes when positive.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deviationNotes rdf:type rdf:Property ;
    rdfs:label 'Deviation Notes' ;
    rdfs:comment 'Free-text description of any deviations from standard turnaround procedures, service failures, or operational irregularities encountered.' ;
    rdfs:domain ind:Turnaround ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelUpliftKg rdf:type rdf:Property ;
    rdfs:label 'Fuel Uplift Kg' ;
    rdfs:comment 'Quantity of fuel in kilograms added to the aircraft during this turnaround.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:groundSupportEquipmentAssigned rdf:type rdf:Property ;
    rdfs:label 'Ground Support Equipment Assigned' ;
    rdfs:comment 'Comma-separated list of GSE unit identifiers assigned to this turnaround (e.g., GPU-123, belt loader-456, tug-789).' ;
    rdfs:domain ind:Turnaround ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handlerInstructions rdf:type rdf:Property ;
    rdfs:label 'Handler Instructions' ;
    rdfs:comment 'Special instructions or notes for the ground handler regarding this specific turnaround (e.g., VIP passenger, special cargo, MEL items, security requirements).' ;
    rdfs:domain ind:Turnaround ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otpImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Otp Impact Flag' ;
    rdfs:comment 'Indicates whether this turnaround contributed to an on-time performance failure (departure delay >15 minutes). Used for OTP root-cause analysis.' ;
    rdfs:domain ind:Turnaround ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:passengerCountBoarded rdf:type rdf:Property ;
    rdfs:label 'Passenger Count Boarded' ;
    rdfs:comment 'Number of passengers who boarded the outbound flight during this turnaround.' ;
    rdfs:domain ind:Turnaround ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:passengerCountDeplaned rdf:type rdf:Property ;
    rdfs:label 'Passenger Count Deplaned' ;
    rdfs:comment 'Number of passengers who deplaned from the inbound flight during this turnaround.' ;
    rdfs:domain ind:Turnaround ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rampServiceOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Ramp Service Order Number' ;
    rdfs:comment 'Unique identifier for the ramp service order that defines all ground services to be performed during this turnaround.' ;
    rdfs:domain ind:Turnaround ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledBlockInTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Block In Time' ;
    rdfs:comment 'Planned timestamp when the inbound aircraft is scheduled to arrive at the gate (OOOI - On event).' ;
    rdfs:domain ind:Turnaround ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledBlockOutTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Block Out Time' ;
    rdfs:comment 'Planned timestamp when the outbound aircraft is scheduled to push back from the gate (OOOI - Off event).' ;
    rdfs:domain ind:Turnaround ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:servicesCompletionTime rdf:type rdf:Property ;
    rdfs:label 'Services Completion Time' ;
    rdfs:comment 'Timestamp when all ground services were completed and aircraft was declared ready for departure.' ;
    rdfs:domain ind:Turnaround ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:servicesOrdered rdf:type rdf:Property ;
    rdfs:label 'Services Ordered' ;
    rdfs:comment 'Comma-separated list of ground services ordered for this turnaround (e.g., fueling, catering, cleaning, water service, lavatory service, GPU, air start, deicing, baggage handling, cargo loading).' ;
    rdfs:domain ind:Turnaround ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetTurnaroundTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Target Turnaround Time Minutes' ;
    rdfs:comment 'Planned duration in minutes for the complete turnaround cycle from block-in to block-out, based on aircraft type and turnaround type.' ;
    rdfs:domain ind:Turnaround ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:turnaroundType rdf:type rdf:Property ;
    rdfs:label 'Turnaround Type' ;
    rdfs:comment 'Classification of turnaround based on duration and service scope. Standard (60-90 min), quick (<45 min), overnight (>8 hours), transit (international connection), maintenance (scheduled service), extended (unplanned delay).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:turnaroundTaskId rdf:type rdf:Property ;
    rdfs:label 'Turnaround Task Id' ;
    rdfs:comment 'Unique identifier for the individual ground servicing task within a turnaround event. Primary key.' ;
    rdfs:domain ind:TurnaroundTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:memberId rdf:type rdf:Property ;
    rdfs:label 'Member Id' ;
    rdfs:comment 'Reference to the ground crew or team assigned to perform this turnaround task.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Member .

ind:actualEndTime rdf:type rdf:Property ;
    rdfs:label 'Actual End Time' ;
    rdfs:comment 'Actual timestamp when the ground servicing task was completed. Used for SLA compliance measurement and operational efficiency analysis.' ;
    rdfs:domain ind:TurnaroundTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualStartTime rdf:type rdf:Property ;
    rdfs:label 'Actual Start Time' ;
    rdfs:comment 'Actual timestamp when the ground servicing task commenced. Used for performance measurement and delay analysis.' ;
    rdfs:domain ind:TurnaroundTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:completionNotes rdf:type rdf:Property ;
    rdfs:label 'Completion Notes' ;
    rdfs:comment 'Free-text notes or comments recorded by the service provider upon task completion, including any exceptions, observations, or special circumstances.' ;
    rdfs:domain ind:TurnaroundTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Amount' ;
    rdfs:comment 'Direct cost incurred for this ground servicing task, including labor, equipment, and materials. Used for turnaround cost analysis and vendor billing.' ;
    rdfs:domain ind:TurnaroundTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Cost Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the cost amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:delayReasonCode rdf:type rdf:Property ;
    rdfs:label 'Delay Reason Code' ;
    rdfs:comment 'Standardized IATA delay code indicating the reason for any task delay or late completion. Used for root cause analysis and performance improvement. [ENUM-REF-CANDIDATE: promote to reference product for full IATA delay code taxonomy]' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateStandPosition rdf:type rdf:Property ;
    rdfs:label 'Gate Stand Position' ;
    rdfs:comment 'Specific gate or stand position identifier where the aircraft is parked and this task is being performed.' ;
    rdfs:domain ind:TurnaroundTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gseDefectDescription rdf:type rdf:Property ;
    rdfs:label 'Gse Defect Description' ;
    rdfs:comment 'Textual description of any GSE defect, malfunction, or maintenance issue observed during task execution. Populated when defect flag is true.' ;
    rdfs:domain ind:TurnaroundTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gseDefectNotedFlag rdf:type rdf:Property ;
    rdfs:label 'Gse Defect Noted Flag' ;
    rdfs:comment 'Boolean indicator whether any equipment defect or malfunction was noted during this task. Triggers maintenance follow-up.' ;
    rdfs:domain ind:TurnaroundTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gseDeploymentEndTime rdf:type rdf:Property ;
    rdfs:label 'Gse Deployment End Time' ;
    rdfs:comment 'Timestamp when the GSE asset was released from this task and became available for other operations. Used for GSE utilization optimization.' ;
    rdfs:domain ind:TurnaroundTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:gseDeploymentStartTime rdf:type rdf:Property ;
    rdfs:label 'Gse Deployment Start Time' ;
    rdfs:comment 'Timestamp when the GSE asset was deployed and positioned for this task. Used for GSE utilization tracking and availability management.' ;
    rdfs:domain ind:TurnaroundTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:gseFuelConsumedLiters rdf:type rdf:Property ;
    rdfs:label 'Gse Fuel Consumed Liters' ;
    rdfs:comment 'Volume of fuel consumed by the GSE asset during this task deployment, measured in liters. Used for environmental reporting and cost allocation.' ;
    rdfs:domain ind:TurnaroundTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedEndTime rdf:type rdf:Property ;
    rdfs:label 'Planned End Time' ;
    rdfs:comment 'Scheduled timestamp when the ground servicing task is planned to be completed, based on standard service times and turnaround requirements.' ;
    rdfs:domain ind:TurnaroundTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedStartTime rdf:type rdf:Property ;
    rdfs:label 'Planned Start Time' ;
    rdfs:comment 'Scheduled timestamp when the ground servicing task is planned to begin, based on the turnaround schedule and task dependencies.' ;
    rdfs:domain ind:TurnaroundTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:qualityCheckPerformedFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Check Performed Flag' ;
    rdfs:comment 'Boolean indicator whether a quality inspection or verification check was performed for this task. Used for quality assurance and safety compliance.' ;
    rdfs:domain ind:TurnaroundTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityCheckResult rdf:type rdf:Property ;
    rdfs:label 'Quality Check Result' ;
    rdfs:comment 'Result of the quality inspection or verification check, if performed. Used for quality assurance tracking and corrective action triggering.' ;
    rdfs:domain ind:TurnaroundTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityDelivered rdf:type rdf:Property ;
    rdfs:label 'Quantity Delivered' ;
    rdfs:comment 'Numeric quantity of service delivered or resource provided during this task (e.g., liters of fuel, kilograms of cargo, number of meals, gallons of water). Unit depends on task type.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sequenceOrder rdf:type rdf:Property ;
    rdfs:label 'Sequence Order' ;
    rdfs:comment 'Numeric order indicating the planned sequence of this task within the turnaround event. Used to coordinate dependencies and parallel operations during aircraft servicing.' ;
    rdfs:domain ind:TurnaroundTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceProviderName rdf:type rdf:Property ;
    rdfs:label 'Service Provider Name' ;
    rdfs:comment 'Full name of the ground handling service provider or vendor responsible for this task.' ;
    rdfs:domain ind:TurnaroundTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Compliance Flag' ;
    rdfs:comment 'Boolean indicator whether the task was completed within the SLA target duration. Used for service provider performance measurement.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaTargetDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Sla Target Duration Minutes' ;
    rdfs:comment 'Contractual service level agreement target duration for this task type, measured in minutes. Used for performance benchmarking and vendor compliance.' ;
    rdfs:domain ind:TurnaroundTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:taskDescription rdf:type rdf:Property ;
    rdfs:label 'Task Description' ;
    rdfs:comment 'Detailed textual description of the specific ground servicing task, including any special instructions, requirements, or notes for the service provider.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskStatus rdf:type rdf:Property ;
    rdfs:label 'Task Status' ;
    rdfs:comment 'Current lifecycle status of the turnaround task. Tracks progression from pending assignment through completion or cancellation. [ENUM-REF-CANDIDATE: PENDING|ASSIGNED|IN_PROGRESS|COMPLETE|SKIPPED|CANCELLED|FAILED — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskTypeCode rdf:type rdf:Property ;
    rdfs:label 'Task Type Code' ;
    rdfs:comment 'Code representing the type of ground servicing task being performed. Examples include fueling, catering, cleaning, water service, lavatory service, de-icing, cargo loading/unloading, passenger boarding/deplaning, pushback, ground power unit (GPU), air start unit (ASU), potable water, waste removal, cabin preparation, security check, or pre-flight inspection. [ENUM-REF-CANDIDATE: FUEL|CATER|CLEAN|WATER|LAV|DEICE|CARGO_LOAD|CARGO_UNLOAD|PAX_BOARD|PAX_DEPLANE|PUSHBACK|GPU|ASU|POTABLE|WASTE|CABIN_PREP|SECURITY|INSPECTION — 18 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TurnaroundTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Unit Of Measure' ;
    rdfs:comment 'Unit of measure for the quantity delivered field. Varies by task type (e.g., liters for fuel, kilograms for cargo, units for catering). [ENUM-REF-CANDIDATE: LITERS|KILOGRAMS|GALLONS|UNITS|MEALS|PASSENGERS|BAGS — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ancillaryEmdId rdf:type rdf:Property ;
    rdfs:label 'Ancillary Emd Id' ;
    rdfs:comment 'Unique identifier for the Electronic Miscellaneous Document record. Primary key for the ancillary EMD product.' ;
    rdfs:domain ind:Ancillary ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AncillaryEmd .

ind:associatedReservationReservationETicketId rdf:type rdf:Property ;
    rdfs:label 'Associated Reservation Reservation E Ticket Id' ;
    rdfs:comment 'Foreign key linking to reservation.e_ticket. Business justification: Links EMDs to associated e-tickets per IATA EMD standards for conjunction ticket processing, settlement, and revenue accounting. Mandatory for EMD-to-ticket association in BSP/ARC reporting.' ;
    rdfs:domain ind:AncillaryEmd ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ETicket .

ind:companyCodeId rdf:type rdf:Property ;
    rdfs:label 'Company Code Id' ;
    rdfs:comment 'Foreign key linking to finance.company_code. Business justification: EMDs are financial instruments requiring legal entity attribution for statutory reporting, tax compliance, and BSP/ARC settlement. Each EMD must be issued by a specific company code for regulatory and' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CompanyCode .

ind:orgUnitId rdf:type rdf:Property ;
    rdfs:label 'Org Unit Id' ;
    rdfs:comment 'Office ID or GDS pseudo-city code (PCC) of the issuing location. Identifies the sales channel, agency, or airline office that created the EMD.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:pnrId rdf:type rdf:Property ;
    rdfs:label 'Pnr Id' ;
    rdfs:comment 'Foreign key linking to reservation.pnr. Business justification: Links EMDs to booking records for IATA BSP/ARC settlement, revenue accounting, and EMD-to-ticket association. Mandatory for EMD lifecycle management and financial reconciliation.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Pnr .

ind:reservationBookingPassengerId rdf:type rdf:Property ;
    rdfs:label 'Reservation Booking Passenger Id' ;
    rdfs:comment 'Foreign key linking to reservation.booking_passenger. Business justification: Links EMDs to booking passengers for passenger-specific EMD issuance, service entitlement, and refund processing. Essential for EMD passenger association and service delivery.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReservationBookingPassenger .

ind:salesChannelId rdf:type rdf:Property ;
    rdfs:label 'Sales Channel Id' ;
    rdfs:comment 'Foreign key linking to ancillary.sales_channel. Business justification: EMDs are issued through specific sales and distribution channels. The ancillary_emd table has gds_code (STRING) but no structured FK to sales_channel. Adding this FK normalizes the channel reference a' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SalesChannel .

ind:ticketId rdf:type rdf:Property ;
    rdfs:label 'Ticket Id' ;
    rdfs:comment 'Foreign key linking to revenue.ticket. Business justification: EMDs (Electronic Miscellaneous Documents) are issued in conjunction with tickets for ancillary services. This FK links the ancillary EMD to the base ticket for complete passenger revenue tracking and ' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Ticket .

ind:ancillaryServiceCode rdf:type rdf:Property ;
    rdfs:label 'Ancillary Service Code' ;
    rdfs:comment 'IATA RFIC (Reason for Issuance Code) or RFISC (Reason for Issuance Sub-Code) identifying the specific ancillary service. Examples: 0CC=baggage, 0B5=seat selection, 0G1=lounge access.' ;
    rdfs:domain ind:AncillaryEmd ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionAmount rdf:type rdf:Property ;
    rdfs:label 'Commission Amount' ;
    rdfs:comment 'Commission amount payable to the issuing agent or agency for selling the ancillary service. Used for agent settlement and revenue accounting.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commissionPercentage rdf:type rdf:Property ;
    rdfs:label 'Commission Percentage' ;
    rdfs:comment 'Commission rate as a percentage of the face value. Used to calculate agent compensation for ancillary sales.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:couponNumber rdf:type rdf:Property ;
    rdfs:label 'Coupon Number' ;
    rdfs:comment 'Sequential coupon number within the EMD. An EMD may have multiple coupons for multi-segment or multi-service purchases. Typically 1 for single-service EMDs.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:couponStatus rdf:type rdf:Property ;
    rdfs:label 'Coupon Status' ;
    rdfs:comment 'Current status of the individual EMD coupon. Tracks the lifecycle state of each service component within the EMD. [ENUM-REF-CANDIDATE: open|used|refunded|exchanged|void|airport_control|checked_in|flown|suspended|irregular — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emdNumber rdf:type rdf:Property ;
    rdfs:label 'Emd Number' ;
    rdfs:comment '13-digit IATA-standard EMD number uniquely identifying the document globally. Format follows IATA Resolution 722 structure with airline code prefix and sequential number.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emdStatus rdf:type rdf:Property ;
    rdfs:label 'Emd Status' ;
    rdfs:comment 'Current lifecycle status of the EMD coupon. Open indicates unused, used indicates service consumed, refunded indicates money returned, exchanged indicates replaced with new EMD, void indicates cancelled before use, expired indicates validity period lapsed.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emdType rdf:type rdf:Property ;
    rdfs:label 'Emd Type' ;
    rdfs:comment 'Type of EMD issued. EMD-S (standalone) is issued independently for ancillary services. EMD-A (associated) is linked to a base e-ticket for bundled services.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endorsementRestrictions rdf:type rdf:Property ;
    rdfs:label 'Endorsement Restrictions' ;
    rdfs:comment 'Free-text field containing endorsement and restriction information. Specifies conditions, limitations, or special handling instructions for the EMD.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeIndicator rdf:type rdf:Property ;
    rdfs:label 'Exchange Indicator' ;
    rdfs:comment 'Boolean flag indicating whether the EMD is exchangeable. True if the ancillary service can be exchanged for another service or flight, false if non-exchangeable.' ;
    rdfs:domain ind:Ancillary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:faceValueAmount rdf:type rdf:Property ;
    rdfs:label 'Face Value Amount' ;
    rdfs:comment 'Total face value amount of the EMD in the currency of issuance. Represents the gross charge for the ancillary service before any adjustments or taxes.' ;
    rdfs:domain ind:AncillaryEmd ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:formOfPayment rdf:type rdf:Property ;
    rdfs:label 'Form Of Payment' ;
    rdfs:comment 'Detailed form of payment string including masked card number or payment reference. Format follows IATA FOP standards. Contains partial payment card data.' ;
    rdfs:domain ind:Ancillary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issueDate rdf:type rdf:Property ;
    rdfs:label 'Issue Date' ;
    rdfs:comment 'Date on which the EMD was issued. Marks the creation of the document and start of validity period.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:issueTimestamp rdf:type rdf:Property ;
    rdfs:label 'Issue Timestamp' ;
    rdfs:comment 'Precise timestamp when the EMD was issued in the issuing system. Used for audit trail and transaction sequencing.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:issuingAirlineCode rdf:type rdf:Property ;
    rdfs:label 'Issuing Airline Code' ;
    rdfs:comment 'IATA 2-letter or 3-letter airline code of the carrier that issued the EMD. Identifies the airline responsible for the document and settlement.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalIssueDate rdf:type rdf:Property ;
    rdfs:label 'Original Issue Date' ;
    rdfs:comment 'Original issue date for exchanged or reissued EMDs. Tracks the first issuance date when an EMD has been modified or replaced.' ;
    rdfs:domain ind:AncillaryEmd ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentMethod rdf:type rdf:Property ;
    rdfs:label 'Payment Method' ;
    rdfs:comment 'Method of payment used to purchase the EMD. Identifies the financial instrument used for settlement. [ENUM-REF-CANDIDATE: cash|credit_card|debit_card|miles|voucher|corporate_account|bank_transfer — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundIndicator rdf:type rdf:Property ;
    rdfs:label 'Refund Indicator' ;
    rdfs:comment 'Boolean flag indicating whether the EMD is refundable. True if the ancillary service can be refunded per fare rules, false if non-refundable.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceDate rdf:type rdf:Property ;
    rdfs:label 'Service Date' ;
    rdfs:comment 'Date on which the ancillary service is scheduled to be consumed or delivered. For flight-related services, typically matches the flight departure date.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:serviceDescription rdf:type rdf:Property ;
    rdfs:label 'Service Description' ;
    rdfs:comment 'Human-readable description of the ancillary service purchased. Examples: Extra Baggage 23kg, Premium Seat 12A, Priority Boarding, Lounge Access.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceQuantity rdf:type rdf:Property ;
    rdfs:label 'Service Quantity' ;
    rdfs:comment 'Quantity of the ancillary service purchased. For example, number of baggage pieces, number of meal vouchers, or 1 for single-use services like lounge access.' ;
    rdfs:domain ind:AncillaryEmd ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:taxAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Amount' ;
    rdfs:comment 'Total tax amount included in the EMD. Sum of all applicable taxes such as VAT, GST, or service taxes on the ancillary service.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalAmount rdf:type rdf:Property ;
    rdfs:label 'Total Amount' ;
    rdfs:comment 'Total amount payable for the EMD including face value, taxes, and any fees. This is the final charge to the passenger.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tourCode rdf:type rdf:Property ;
    rdfs:label 'Tour Code' ;
    rdfs:comment 'Tour or promotional code associated with the EMD. Used for tracking special offers, packages, or corporate agreements.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validityEndDate rdf:type rdf:Property ;
    rdfs:label 'Validity End Date' ;
    rdfs:comment 'Last date on which the EMD is valid for use. After this date, the EMD expires and cannot be consumed or refunded.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validityStartDate rdf:type rdf:Property ;
    rdfs:label 'Validity Start Date' ;
    rdfs:comment 'First date on which the EMD is valid for use. Defines the beginning of the service consumption window.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ancillaryRefundId rdf:type rdf:Property ;
    rdfs:label 'Ancillary Refund Id' ;
    rdfs:comment 'Unique identifier for the ancillary refund transaction. Primary key.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AncillaryRefund .

ind:ancillaryOrderItemId rdf:type rdf:Property ;
    rdfs:label 'Ancillary Order Item Id' ;
    rdfs:comment 'Reference to the original ancillary order item being refunded. Links to the purchased ancillary service record.' ;
    rdfs:domain ind:Ancillary ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrderItem .

ind:bookingPnrId rdf:type rdf:Property ;
    rdfs:label 'Booking Pnr Id' ;
    rdfs:comment 'Internal booking identifier associated with the refunded ancillary purchase.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Pnr .

ind:flightIropEventId rdf:type rdf:Property ;
    rdfs:label 'Flight Irop Event Id' ;
    rdfs:comment 'Reference to an irregular operations event (flight cancellation, delay, diversion) that triggered the refund, if applicable.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FlightIropEvent .

ind:amount rdf:type rdf:Property ;
    rdfs:label 'Amount' ;
    rdfs:comment 'The net amount being refunded to the customer after deducting any applicable penalties or fees.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ancillaryCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Ancillary Category Code' ;
    rdfs:comment 'Code identifying the category of ancillary service being refunded (e.g., baggage, seat, lounge, meal, Wi-Fi).' ;
    rdfs:domain ind:AncillaryRefund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approval Timestamp' ;
    rdfs:comment 'Date and time when the refund was approved by the system or authorized personnel.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:completedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Completed Timestamp' ;
    rdfs:comment 'Date and time when the refund was confirmed as completed and funds were successfully returned to the customer.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:emdCouponNumber rdf:type rdf:Property ;
    rdfs:label 'Emd Coupon Number' ;
    rdfs:comment 'Coupon sequence number within the EMD being refunded. Identifies the specific service coupon.' ;
    rdfs:domain ind:AncillaryRefund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:milesCredited rdf:type rdf:Property ;
    rdfs:label 'Miles Credited' ;
    rdfs:comment 'Number of frequent flyer miles credited to the passenger account if the refund is issued as mileage credit.' ;
    rdfs:domain ind:AncillaryRefund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalPurchaseAmount rdf:type rdf:Property ;
    rdfs:label 'Original Purchase Amount' ;
    rdfs:comment 'The original gross amount paid for the ancillary service before any refund adjustments.' ;
    rdfs:domain ind:AncillaryRefund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentMethodOriginal rdf:type rdf:Property ;
    rdfs:label 'Payment Method Original' ;
    rdfs:comment 'The payment method used for the original ancillary purchase, relevant for refund routing. [ENUM-REF-CANDIDATE: credit_card|debit_card|bank_transfer|paypal|miles|voucher|cash|corporate_account — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AncillaryRefund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentReferenceOriginal rdf:type rdf:Property ;
    rdfs:label 'Payment Reference Original' ;
    rdfs:comment 'Masked or tokenized reference to the original payment transaction (e.g., last 4 digits of card, transaction ID).' ;
    rdfs:domain ind:AncillaryRefund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Processed Timestamp' ;
    rdfs:comment 'Date and time when the refund was processed and submitted to the payment gateway or settlement system.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:processingChannel rdf:type rdf:Property ;
    rdfs:label 'Processing Channel' ;
    rdfs:comment 'The channel through which the refund request was submitted and processed. [ENUM-REF-CANDIDATE: web|mobile_app|call_center|airport_counter|travel_agent|gds|chatbot — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingLocationCode rdf:type rdf:Property ;
    rdfs:label 'Processing Location Code' ;
    rdfs:comment 'Three-letter IATA airport or city code indicating where the refund was processed (e.g., call center location, airport counter).' ;
    rdfs:domain ind:AncillaryRefund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonCode rdf:type rdf:Property ;
    rdfs:label 'Reason Code' ;
    rdfs:comment 'Standardized code indicating the business reason for the refund (e.g., service not used, flight cancellation, customer request, service failure, involuntary downgrade).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonDescription rdf:type rdf:Property ;
    rdfs:label 'Reason Description' ;
    rdfs:comment 'Detailed textual explanation of the reason for the refund, providing additional context beyond the reason code.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Number' ;
    rdfs:comment 'Unique external reference number assigned to this refund transaction for customer service tracking and reconciliation.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundMethod rdf:type rdf:Property ;
    rdfs:label 'Refund Method' ;
    rdfs:comment 'The method by which the refund is being issued (e.g., back to original payment method, travel voucher, frequent flyer miles, loyalty points).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundStatus rdf:type rdf:Property ;
    rdfs:label 'Refund Status' ;
    rdfs:comment 'Current lifecycle status of the refund transaction in the processing workflow. [ENUM-REF-CANDIDATE: pending|approved|processed|completed|rejected|cancelled|reversed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundType rdf:type rdf:Property ;
    rdfs:label 'Refund Type' ;
    rdfs:comment 'Classification of the refund indicating whether it is a full refund, partial refund, penalty-adjusted refund, or fee waiver.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestTimestamp rdf:type rdf:Property ;
    rdfs:label 'Request Timestamp' ;
    rdfs:comment 'Date and time when the refund request was initiated by the customer or agent.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:revenueAccountingCode rdf:type rdf:Property ;
    rdfs:label 'Revenue Accounting Code' ;
    rdfs:comment 'General ledger or revenue accounting code used to classify the refund for financial reporting and revenue adjustment.' ;
    rdfs:domain ind:Ancillary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfiscCode rdf:type rdf:Property ;
    rdfs:label 'Rfisc Code' ;
    rdfs:comment 'Four-character IATA RFISC code identifying the specific ancillary service type for standardized reporting and distribution.' ;
    rdfs:domain ind:Ancillary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementDate rdf:type rdf:Property ;
    rdfs:label 'Settlement Date' ;
    rdfs:comment 'Date when the refund transaction was included in the BSP/ARC settlement batch for financial reconciliation.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:settlementStatus rdf:type rdf:Property ;
    rdfs:label 'Settlement Status' ;
    rdfs:comment 'Status of the refund in the BSP/ARC settlement cycle, tracking financial reconciliation with payment processors and distribution channels.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxRefundAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Refund Amount' ;
    rdfs:comment 'The portion of the refund amount representing taxes and government fees being returned to the customer.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:voucherNumber rdf:type rdf:Property ;
    rdfs:label 'Voucher Number' ;
    rdfs:comment 'Unique voucher or credit memo number issued if the refund is provided as a travel voucher rather than monetary refund.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverCode rdf:type rdf:Property ;
    rdfs:label 'Waiver Code' ;
    rdfs:comment 'Code indicating any fee waiver or penalty exemption applied to the refund (e.g., elite status waiver, operational disruption waiver).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baggageAllowanceId rdf:type rdf:Property ;
    rdfs:label 'Baggage Allowance Id' ;
    rdfs:comment 'Primary key for baggage_allowance' ;
    rdfs:domain ind:BaggageAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ancillaryCategoryId rdf:type rdf:Property ;
    rdfs:label 'Ancillary Category Id' ;
    rdfs:comment 'Foreign key linking to ancillary.category. Business justification: Baggage allowances should be classified by ancillary category (e.g., Baggage, Checked Bag, Carry-On). The baggage_allowance table has baggage_category (STRING) but no FK. Adding this FK normalizes the' ;
    rdfs:domain ind:Ancillary ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AncillaryCategory .

ind:cabinClassId rdf:type rdf:Property ;
    rdfs:label 'Cabin Class Id' ;
    rdfs:comment 'Foreign key linking to inventory.cabin_class. Business justification: Baggage allowances are defined per cabin class in fare construction rules (business 2 pieces, economy 1 piece). Fare rule application and ticketing require formal cabin class linkage. Fare constructio' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CabinClass .

ind:allowanceCode rdf:type rdf:Property ;
    rdfs:label 'Allowance Code' ;
    rdfs:comment 'Unique business identifier for the baggage allowance rule, used for reference in fare products and ancillary catalogs.' ;
    rdfs:domain ind:BaggageAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allowanceName rdf:type rdf:Property ;
    rdfs:label 'Allowance Name' ;
    rdfs:comment 'Human-readable name of the baggage allowance rule (e.g., \'Economy Standard 2PC\', \'Business Premium 3PC 32KG\').' ;
    rdfs:domain ind:BaggageAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allowanceType rdf:type rdf:Property ;
    rdfs:label 'Allowance Type' ;
    rdfs:comment 'The allowance model applied: piece_concept (number of bags), weight_concept (total weight limit), or hybrid (combination of both).' ;
    rdfs:domain ind:BaggageAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicablePtc rdf:type rdf:Property ;
    rdfs:label 'Applicable Ptc' ;
    rdfs:comment 'Passenger Type Code this allowance applies to (e.g., ADT=adult, CHD=child, INF=infant, MIL=military). Null if applies to all passenger types.' ;
    rdfs:domain ind:BaggageAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baggageAllowanceStatus rdf:type rdf:Property ;
    rdfs:label 'Baggage Allowance Status' ;
    rdfs:comment 'Current lifecycle status of the baggage allowance rule: active (in use), inactive (not in use), pending (scheduled for future), expired (past validity), suspended (temporarily disabled).' ;
    rdfs:domain ind:BaggageAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationCountryCode rdf:type rdf:Property ;
    rdfs:label 'Destination Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-2 country code for the destination of travel. Null if not country-specific.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationRegionCode rdf:type rdf:Property ;
    rdfs:label 'Destination Region Code' ;
    rdfs:comment 'IATA region or sub-region code for the destination (e.g., TC1=North America, TC2=Europe, TC3=Asia). Null if not region-specific.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dimensionLimitCm rdf:type rdf:Property ;
    rdfs:label 'Dimension Limit Cm' ;
    rdfs:comment 'Maximum dimensions allowed for each piece in centimeters, expressed as LxWxH (e.g., \'158x90x75\'). Null if no dimension restriction applies.' ;
    rdfs:domain ind:BaggageAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dimensionLimitInches rdf:type rdf:Property ;
    rdfs:label 'Dimension Limit Inches' ;
    rdfs:comment 'Maximum dimensions allowed for each piece in inches, expressed as LxWxH (e.g., \'62x35x30\'). Provided for markets using imperial units.' ;
    rdfs:domain ind:BaggageAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fareBrandCode rdf:type rdf:Property ;
    rdfs:label 'Fare Brand Code' ;
    rdfs:comment 'Fare brand or product code associated with this allowance (e.g., BASIC, STANDARD, FLEX, PREMIUM). Null if not brand-specific.' ;
    rdfs:domain ind:BaggageAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ffpTierCode rdf:type rdf:Property ;
    rdfs:label 'Ffp Tier Code' ;
    rdfs:comment 'Frequent flyer tier code that grants this baggage allowance (e.g., GOLD, PLATINUM, ELITE). Null if not tier-dependent.' ;
    rdfs:domain ind:Ancillary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interlineAgreementCode rdf:type rdf:Property ;
    rdfs:label 'Interline Agreement Code' ;
    rdfs:comment 'Code identifying the interline or codeshare agreement under which this allowance applies. Null if not interline-specific.' ;
    rdfs:domain ind:BaggageAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCombinable rdf:type rdf:Property ;
    rdfs:label 'Is Combinable' ;
    rdfs:comment 'Indicates whether this allowance can be combined with other allowances (e.g., fare allowance + FFP tier allowance). True if combinable, false if exclusive.' ;
    rdfs:domain ind:Ancillary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRefundable rdf:type rdf:Property ;
    rdfs:label 'Is Refundable' ;
    rdfs:comment 'Indicates whether the baggage allowance (if purchased as ancillary) is refundable. True if refundable, false if non-refundable.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTransferable rdf:type rdf:Property ;
    rdfs:label 'Is Transferable' ;
    rdfs:comment 'Indicates whether this baggage allowance can be transferred to another passenger or booking. True if transferable, false if non-transferable.' ;
    rdfs:domain ind:Ancillary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:linearDimensionLimitCm rdf:type rdf:Property ;
    rdfs:label 'Linear Dimension Limit Cm' ;
    rdfs:comment 'Maximum sum of length, width, and height in centimeters (L+W+H). Common standard is 158 cm for international checked baggage.' ;
    rdfs:domain ind:BaggageAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:linearDimensionLimitInches rdf:type rdf:Property ;
    rdfs:label 'Linear Dimension Limit Inches' ;
    rdfs:comment 'Maximum sum of length, width, and height in inches (L+W+H). Common standard is 62 inches for international checked baggage.' ;
    rdfs:domain ind:BaggageAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originCountryCode rdf:type rdf:Property ;
    rdfs:label 'Origin Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-2 country code for the origin of travel. Null if not country-specific.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originRegionCode rdf:type rdf:Property ;
    rdfs:label 'Origin Region Code' ;
    rdfs:comment 'IATA region or sub-region code for the origin (e.g., TC1=North America, TC2=Europe, TC3=Asia). Null if not region-specific.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pieceCount rdf:type rdf:Property ;
    rdfs:label 'Piece Count' ;
    rdfs:comment 'Number of baggage pieces allowed under this rule (applicable for piece concept allowances). Null if weight concept only.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priorityRank rdf:type rdf:Property ;
    rdfs:label 'Priority Rank' ;
    rdfs:comment 'Priority ranking used to resolve conflicts when multiple allowance rules apply to the same booking context. Lower number = higher priority.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:routeGroupCode rdf:type rdf:Property ;
    rdfs:label 'Route Group Code' ;
    rdfs:comment 'Route group or geographic zone code this allowance applies to (e.g., DOM=domestic, INTL=international, TRANSATLANTIC). Null if applies globally.' ;
    rdfs:domain ind:BaggageAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialConditions rdf:type rdf:Property ;
    rdfs:label 'Special Conditions' ;
    rdfs:comment 'Free-text field describing any special conditions, restrictions, or notes applicable to this baggage allowance (e.g., \'Applies only to direct flights\', \'Excludes codeshare partners\').' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightLimitKg rdf:type rdf:Property ;
    rdfs:label 'Weight Limit Kg' ;
    rdfs:comment 'Maximum weight allowed per piece or total weight limit in kilograms. Applicable for weight concept or per-piece weight restrictions.' ;
    rdfs:domain ind:BaggageAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightLimitLbs rdf:type rdf:Property ;
    rdfs:label 'Weight Limit Lbs' ;
    rdfs:comment 'Maximum weight allowed per piece or total weight limit in pounds. Provided for markets using imperial units.' ;
    rdfs:domain ind:BaggageAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bundleId rdf:type rdf:Property ;
    rdfs:label 'Bundle Id' ;
    rdfs:comment 'Primary key for bundle' ;
    rdfs:domain ind:Ancillary ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Bundle .

ind:campaignId rdf:type rdf:Property ;
    rdfs:label 'Campaign Id' ;
    rdfs:comment 'Foreign key linking to marketing.campaign. Business justification: Ancillary bundles (e.g., Premium Economy packages) are often launched as part of marketing campaigns with promotional pricing and targeted messaging. Real business need to track which campaign introdu' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Campaign .

ind:routeId rdf:type rdf:Property ;
    rdfs:label 'Route Id' ;
    rdfs:comment 'Foreign key linking to route.route. Business justification: Fare bundles are configured per route or route group (transatlantic vs domestic bundles differ in included services). Real business process: route-specific bundle definition for fare family merchandis' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Route .

ind:baggageAllowancePieces rdf:type rdf:Property ;
    rdfs:label 'Baggage Allowance Pieces' ;
    rdfs:comment 'Number of checked baggage pieces included in the bundle entitlement. Null if baggage is not included or uses weight-based allowance.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:baggageAllowanceWeightKg rdf:type rdf:Property ;
    rdfs:label 'Baggage Allowance Weight Kg' ;
    rdfs:comment 'Total weight allowance in kilograms for checked baggage included in the bundle. Null if baggage is not included or uses piece-based allowance.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:basePriceAmount rdf:type rdf:Property ;
    rdfs:label 'Base Price Amount' ;
    rdfs:comment 'The base price of the bundle product before any adjustments, taxes, or dynamic pricing modifiers are applied.' ;
    rdfs:domain ind:Ancillary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bookingChannelRestriction rdf:type rdf:Property ;
    rdfs:label 'Booking Channel Restriction' ;
    rdfs:comment 'Specifies any restrictions on which booking channels can sell this bundle (e.g., direct channels only, GDS excluded, mobile app exclusive). Empty if available on all channels. [ENUM-REF-CANDIDATE: all_channels|direct_only|gds_only|mobile_only|web_only|call_center_only|travel_agent_excluded — promote to reference product]' ;
    rdfs:domain ind:Ancillary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundleCode rdf:type rdf:Property ;
    rdfs:label 'Bundle Code' ;
    rdfs:comment 'Unique business identifier code for the bundle product used in reservation systems and merchandising platforms (e.g., BASIC_ECO, FLEX_PLUS, PREMIUM_BIZ).' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundleDescription rdf:type rdf:Property ;
    rdfs:label 'Bundle Description' ;
    rdfs:comment 'Detailed description of the bundle product including all included services, entitlements, restrictions, and value proposition for customer communication.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundleName rdf:type rdf:Property ;
    rdfs:label 'Bundle Name' ;
    rdfs:comment 'Marketing name of the bundle displayed to customers during booking and merchandising (e.g., Basic Economy, Flex Plus, Premium Business).' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundleStatus rdf:type rdf:Property ;
    rdfs:label 'Bundle Status' ;
    rdfs:comment 'Current lifecycle status of the bundle product indicating its availability for sale and merchandising.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundleTier rdf:type rdf:Property ;
    rdfs:label 'Bundle Tier' ;
    rdfs:comment 'Hierarchical tier level of the bundle within the airlines branded fare structure, indicating the level of service and entitlements included.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundleType rdf:type rdf:Property ;
    rdfs:label 'Bundle Type' ;
    rdfs:comment 'Classification of the bundle product by its primary business purpose and composition strategy.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationRefundableFlag rdf:type rdf:Property ;
    rdfs:label 'Cancellation Refundable Flag' ;
    rdfs:comment 'Indicates whether tickets purchased with this bundle are refundable upon cancellation (True) or non-refundable (False).' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:changeFeeWaivedFlag rdf:type rdf:Property ;
    rdfs:label 'Change Fee Waived Flag' ;
    rdfs:comment 'Indicates whether ticket change fees are waived for bookings purchased with this bundle (True) or standard change fees apply (False).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:expirationDate rdf:type rdf:Property ;
    rdfs:label 'Expiration Date' ;
    rdfs:comment 'The date on which this bundle product expires and is no longer available for sale. Null for bundles with no planned expiration.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:includedServicesCount rdf:type rdf:Property ;
    rdfs:label 'Included Services Count' ;
    rdfs:comment 'The total number of distinct ancillary services included in this bundle composition.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:loungeAccessIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Lounge Access Included Flag' ;
    rdfs:comment 'Indicates whether airport lounge access is included as an entitlement in this bundle (True) or not (False).' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maximumAdvancePurchaseDays rdf:type rdf:Property ;
    rdfs:label 'Maximum Advance Purchase Days' ;
    rdfs:comment 'The maximum number of days before departure that this bundle can be purchased. Null if no maximum advance purchase restriction exists.' ;
    rdfs:domain ind:Ancillary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mealServiceIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Meal Service Included Flag' ;
    rdfs:comment 'Indicates whether complimentary in-flight meal service is included in this bundle (True) or meals must be purchased separately (False).' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mileageAccrualPercentage rdf:type rdf:Property ;
    rdfs:label 'Mileage Accrual Percentage' ;
    rdfs:comment 'The percentage of flown miles that accrue to the passengers Frequent Flyer Program (FFP) account when traveling on this bundle (e.g., 100.00 for full accrual, 50.00 for half accrual).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumAdvancePurchaseDays rdf:type rdf:Property ;
    rdfs:label 'Minimum Advance Purchase Days' ;
    rdfs:comment 'The minimum number of days before departure that this bundle must be purchased. Null if no advance purchase requirement exists.' ;
    rdfs:domain ind:Ancillary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pricingStrategy rdf:type rdf:Property ;
    rdfs:label 'Pricing Strategy' ;
    rdfs:comment 'The pricing methodology applied to this bundle indicating whether pricing is fixed, dynamically adjusted based on demand, or subject to yield management rules.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityBoardingIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Priority Boarding Included Flag' ;
    rdfs:comment 'Indicates whether priority boarding privileges are included in this bundle entitlement (True) or not (False).' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:routeRestrictionType rdf:type rdf:Property ;
    rdfs:label 'Route Restriction Type' ;
    rdfs:comment 'Indicates whether this bundle is available on all routes or restricted to specific route types (domestic, international, regional, or specific route list).' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seatSelectionIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Seat Selection Included Flag' ;
    rdfs:comment 'Indicates whether advance seat selection is included as an entitlement in this bundle (True) or must be purchased separately (False).' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:seatSelectionType rdf:type rdf:Property ;
    rdfs:label 'Seat Selection Type' ;
    rdfs:comment 'The category of seats available for selection under this bundle entitlement (standard, preferred, extra legroom, or any seat).' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standbyPriorityLevel rdf:type rdf:Property ;
    rdfs:label 'Standby Priority Level' ;
    rdfs:comment 'The priority level assigned to passengers on this bundle when placed on standby lists for earlier or alternative flights. Lower numbers indicate higher priority.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:travelDateRestrictionEnd rdf:type rdf:Property ;
    rdfs:label 'Travel Date Restriction End' ;
    rdfs:comment 'The latest travel date for which this bundle is valid and can be applied to bookings. Null if no end date restriction exists.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:travelDateRestrictionStart rdf:type rdf:Property ;
    rdfs:label 'Travel Date Restriction Start' ;
    rdfs:comment 'The earliest travel date for which this bundle is valid and can be applied to bookings. Null if no start date restriction exists.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:upgradeEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Upgrade Eligible Flag' ;
    rdfs:comment 'Indicates whether passengers purchasing this bundle are eligible for cabin upgrades using miles, vouchers, or operational upgrades (True) or not (False).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:wifiIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Wifi Included Flag' ;
    rdfs:comment 'Indicates whether complimentary in-flight Wi-Fi connectivity is included in this bundle entitlement (True) or not (False).' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ancillaryBundleComponentId rdf:type rdf:Property ;
    rdfs:label 'Ancillary Bundle Component Id' ;
    rdfs:comment 'Unique identifier for the bundle component junction record linking a bundle to a constituent ancillary product.' ;
    rdfs:domain ind:AncillaryBundleComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productCatalogId rdf:type rdf:Property ;
    rdfs:label 'Product Catalog Id' ;
    rdfs:comment 'Reference to the specific ancillary product or service included in this bundle component.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductCatalog .

ind:ancillaryBundleComponentStatus rdf:type rdf:Property ;
    rdfs:label 'Ancillary Bundle Component Status' ;
    rdfs:comment 'Current lifecycle status of this bundle component: active (available for sale), inactive (not offered), suspended (temporarily unavailable), pending_approval (awaiting commercial approval), deprecated (being phased out), seasonal_inactive (off-season).' ;
    rdfs:domain ind:AncillaryBundleComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cabinClassRestriction rdf:type rdf:Property ;
    rdfs:label 'Cabin Class Restriction' ;
    rdfs:comment 'Cabin class restriction for this component. Defines which cabin classes this component applies to within the bundle. All indicates no restriction.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargeCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Charge Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the incremental charge amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionEligible rdf:type rdf:Property ;
    rdfs:label 'Commission Eligible' ;
    rdfs:comment 'Indicates whether this component is eligible for travel agent or distribution partner commission. True if commissionable; false if non-commissionable.' ;
    rdfs:domain ind:AncillaryBundleComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commissionRatePercent rdf:type rdf:Property ;
    rdfs:label 'Commission Rate Percent' ;
    rdfs:comment 'Commission rate percentage applicable to this component if commission_eligible is true. Null if not commissionable.' ;
    rdfs:domain ind:Ancillary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:componentSequence rdf:type rdf:Property ;
    rdfs:label 'Component Sequence' ;
    rdfs:comment 'Merchandising display order for this component within the bundle presentation, used for consistent UI rendering and fare comparison displays.' ;
    rdfs:domain ind:AncillaryBundleComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:entitlementUnit rdf:type rdf:Property ;
    rdfs:label 'Entitlement Unit' ;
    rdfs:comment 'Unit of measure for the quantity entitlement: piece (baggage items), kilogram (weight allowance), segment (per flight leg), trip (round-trip), hour (lounge time), day (rental period), access (single entry), selection (seat choice), upgrade (cabin class). [ENUM-REF-CANDIDATE: piece|kilogram|segment|trip|hour|day|access|selection|upgrade — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AncillaryBundleComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfillmentTiming rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Timing' ;
    rdfs:comment 'Defines when this component is delivered or activated in the customer journey: at_booking (immediate), pre_departure (before travel date), at_checkin (during check-in), at_gate (boarding area), onboard (during flight), post_flight (after arrival), on_demand (customer-initiated). [ENUM-REF-CANDIDATE: at_booking|pre_departure|at_checkin|at_gate|onboard|post_flight|on_demand — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AncillaryBundleComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inclusionType rdf:type rdf:Property ;
    rdfs:label 'Inclusion Type' ;
    rdfs:comment 'Defines how this ancillary product is included in the bundle: mandatory (always included), optional (customer may decline), upgradeable (customer may enhance), conditional (subject to availability or route), promotional (limited-time offer), or seasonal (specific travel periods).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incrementalChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Incremental Charge Amount' ;
    rdfs:comment 'Additional charge amount for this component if is_chargeable is true. Null or zero if component is fully included in bundle base price.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isChargeable rdf:type rdf:Property ;
    rdfs:label 'Is Chargeable' ;
    rdfs:comment 'Indicates whether this component incurs an additional charge beyond the bundle base price. True if customer must pay extra for this component; false if fully included in bundle price.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketingDescription rdf:type rdf:Property ;
    rdfs:label 'Marketing Description' ;
    rdfs:comment 'Customer-facing marketing description of this component for bundle merchandising displays, fare comparison tools, and booking flow presentation.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passengerTypeRestriction rdf:type rdf:Property ;
    rdfs:label 'Passenger Type Restriction' ;
    rdfs:comment 'Passenger type restriction for this component. Defines which passenger types are eligible for this component within the bundle. All indicates no restriction. [ENUM-REF-CANDIDATE: all|adult|child|infant|senior|student|military|corporate — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AncillaryBundleComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityEntitlement rdf:type rdf:Property ;
    rdfs:label 'Quantity Entitlement' ;
    rdfs:comment 'Number of units of this ancillary product included in the bundle entitlement (e.g., 1 for one checked bag, 2 for two lounge passes). Zero indicates unlimited or not-applicable.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:routeApplicability rdf:type rdf:Property ;
    rdfs:label 'Route Applicability' ;
    rdfs:comment 'Defines the route scope where this component is applicable: all (all routes), domestic (within country), international (cross-border), regional (within geographic region), intercontinental (long-haul), specific_routes (defined route list).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceFeeCode rdf:type rdf:Property ;
    rdfs:label 'Service Fee Code' ;
    rdfs:comment 'Internal or IATA service fee code for revenue accounting and settlement of this component within the bundle.' ;
    rdfs:domain ind:AncillaryBundleComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termsAndConditionsUrl rdf:type rdf:Property ;
    rdfs:label 'Terms And Conditions Url' ;
    rdfs:comment 'URL link to the detailed terms and conditions governing this component within the bundle, for customer disclosure and regulatory compliance.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentCategoryAncillaryCategoryId rdf:type rdf:Property ;
    rdfs:label 'Parent Category Ancillary Category Id' ;
    rdfs:comment 'Foreign key reference to a parent ancillary category, enabling hierarchical taxonomy structures (e.g., Baggage as parent, Checked Baggage and Carry-On Baggage as children).' ;
    rdfs:domain ind:AncillaryCategory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AncillaryCategory .

ind:ancillaryCategoryStatus rdf:type rdf:Property ;
    rdfs:label 'Ancillary Category Status' ;
    rdfs:comment 'Current lifecycle status of the ancillary category indicating whether it is actively used in merchandising and revenue systems.' ;
    rdfs:domain ind:AncillaryCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:atpcoServiceGroup rdf:type rdf:Property ;
    rdfs:label 'Atpco Service Group' ;
    rdfs:comment 'ATPCO Optional Services service group classification for the ancillary category, used for fare filing and distribution through GDS channels.' ;
    rdfs:domain ind:AncillaryCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryCode rdf:type rdf:Property ;
    rdfs:label 'Category Code' ;
    rdfs:comment 'Standardized alphanumeric code uniquely identifying the ancillary category, aligned with IATA PADIS and ATPCO Optional Services taxonomy (e.g., BAG for baggage, SEAT for seat selection, LOUNGE for lounge access).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryDescription rdf:type rdf:Property ;
    rdfs:label 'Category Description' ;
    rdfs:comment 'Detailed textual description of the ancillary category, including scope, typical products included, and business purpose.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryLevel rdf:type rdf:Property ;
    rdfs:label 'Category Level' ;
    rdfs:comment 'Numeric indicator of the hierarchical level of this category within the taxonomy (e.g., 1 for top-level, 2 for sub-category, 3 for detailed classification).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:categoryName rdf:type rdf:Property ;
    rdfs:label 'Category Name' ;
    rdfs:comment 'Human-readable name of the ancillary category (e.g., Baggage, Seat Selection, Priority Boarding, Lounge Access, In-Flight Meals, Wi-Fi Connectivity).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryType rdf:type rdf:Property ;
    rdfs:label 'Category Type' ;
    rdfs:comment 'High-level classification of the ancillary category distinguishing between service-based, product-based, bundled offerings, insurance, ground transport, or accommodation.' ;
    rdfs:domain ind:AncillaryCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:directChannelOnlyFlag rdf:type rdf:Property ;
    rdfs:label 'Direct Channel Only Flag' ;
    rdfs:comment 'Indicates whether this category is exclusively sold through direct airline channels (website, mobile app, call center) and not available via third-party distributors.' ;
    rdfs:domain ind:AncillaryCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:displaySequence rdf:type rdf:Property ;
    rdfs:label 'Display Sequence' ;
    rdfs:comment 'Numeric ordering for display of this category in user interfaces, merchandising platforms, and reporting hierarchies.' ;
    rdfs:domain ind:AncillaryCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:effectiveEndDate rdf:type rdf:Property ;
    rdfs:label 'Effective End Date' ;
    rdfs:comment 'Date after which this ancillary category is no longer effective and should not be used for new product assignments. Null indicates open-ended validity.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveStartDate rdf:type rdf:Property ;
    rdfs:label 'Effective Start Date' ;
    rdfs:comment 'Date from which this ancillary category becomes effective and available for use in product catalog and merchandising systems.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:emdEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Emd Eligible Flag' ;
    rdfs:comment 'Indicates whether ancillary products in this category are eligible for issuance via Electronic Miscellaneous Document (EMD) per IATA standards.' ;
    rdfs:domain ind:AncillaryCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gdsDistributionFlag rdf:type rdf:Property ;
    rdfs:label 'Gds Distribution Flag' ;
    rdfs:comment 'Indicates whether ancillary products in this category are distributed through Global Distribution Systems (GDS) such as Amadeus, Sabre, and Travelport.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iataPadisCode rdf:type rdf:Property ;
    rdfs:label 'Iata Padis Code' ;
    rdfs:comment 'IATA PADIS standard code for the ancillary category, enabling interoperability across Global Distribution Systems (GDS) and Passenger Service Systems (PSS).' ;
    rdfs:domain ind:AncillaryCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:merchandisingPriority rdf:type rdf:Property ;
    rdfs:label 'Merchandising Priority' ;
    rdfs:comment 'Numeric ranking indicating the priority of this category in merchandising and upsell workflows, with lower numbers representing higher priority.' ;
    rdfs:domain ind:Ancillary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ndcCompatibleFlag rdf:type rdf:Property ;
    rdfs:label 'Ndc Compatible Flag' ;
    rdfs:comment 'Indicates whether this ancillary category is compatible with IATA New Distribution Capability (NDC) standards for modern retailing and distribution.' ;
    rdfs:domain ind:AncillaryCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:refundableFlag rdf:type rdf:Property ;
    rdfs:label 'Refundable Flag' ;
    rdfs:comment 'Indicates whether ancillary products in this category are generally refundable per airline policy and fare rules.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryComplianceNotes rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Notes' ;
    rdfs:comment 'Free-text field capturing any regulatory compliance considerations specific to this ancillary category, including Department of Transportation (DOT), Federal Aviation Administration (FAA), European Union Aviation Safety Agency (EASA), or consumer protection requirements.' ;
    rdfs:domain ind:AncillaryCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceDeliveryPoint rdf:type rdf:Property ;
    rdfs:label 'Service Delivery Point' ;
    rdfs:comment 'Indicates the primary point in the passenger journey where the ancillary service is delivered (e.g., pre-flight for advance seat selection, in-flight for meals, airport for lounge access).' ;
    rdfs:domain ind:AncillaryCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ssrCode rdf:type rdf:Property ;
    rdfs:label 'Ssr Code' ;
    rdfs:comment 'Four-letter IATA Special Service Request (SSR) code associated with this ancillary category for communication between airlines and service providers (e.g., WCHR for wheelchair, PETC for pet in cabin).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferableFlag rdf:type rdf:Property ;
    rdfs:label 'Transferable Flag' ;
    rdfs:comment 'Indicates whether ancillary products in this category can be transferred to another passenger or booking.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unbundledFareComponentFlag rdf:type rdf:Property ;
    rdfs:label 'Unbundled Fare Component Flag' ;
    rdfs:comment 'Indicates whether this category represents a component of an unbundled fare strategy, where services traditionally included in the base fare are sold separately.' ;
    rdfs:domain ind:AncillaryCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eligibilityRuleId rdf:type rdf:Property ;
    rdfs:label 'Eligibility Rule Id' ;
    rdfs:comment 'Primary key for eligibility_rule' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:aircraftTypeList rdf:type rdf:Property ;
    rdfs:label 'Aircraft Type List' ;
    rdfs:comment 'Comma-separated list of IATA aircraft type codes (e.g., 737, 777, A320) for which this ancillary product is eligible. Empty indicates no aircraft restriction.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookingDateFrom rdf:type rdf:Property ;
    rdfs:label 'Booking Date From' ;
    rdfs:comment 'Start date of the booking window during which this eligibility rule is active. Null indicates no booking start date restriction.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bookingDateTo rdf:type rdf:Property ;
    rdfs:label 'Booking Date To' ;
    rdfs:comment 'End date of the booking window during which this eligibility rule is active. Null indicates no booking end date restriction.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cabinClassList rdf:type rdf:Property ;
    rdfs:label 'Cabin Class List' ;
    rdfs:comment 'Comma-separated list of cabin classes (First, Business, Premium Economy, Economy) eligible for this ancillary product. Empty indicates no cabin restriction.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdByUser rdf:type rdf:Property ;
    rdfs:label 'Created By User' ;
    rdfs:comment 'User identifier or system account that created this eligibility rule record.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationAirportList rdf:type rdf:Property ;
    rdfs:label 'Destination Airport List' ;
    rdfs:comment 'Comma-separated list of IATA airport codes representing eligible destination points. Empty indicates no destination restriction.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationCountryList rdf:type rdf:Property ;
    rdfs:label 'Destination Country List' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-2 country codes representing eligible destination countries. Empty indicates no destination country restriction.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusionRuleFlag rdf:type rdf:Property ;
    rdfs:label 'Exclusion Rule Flag' ;
    rdfs:comment 'Indicates whether this is an exclusion rule (true) that prevents eligibility, or an inclusion rule (false) that grants eligibility.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fareClassList rdf:type rdf:Property ;
    rdfs:label 'Fare Class List' ;
    rdfs:comment 'Comma-separated list of booking class codes (RBD - Revenue Booking Designator) to which this rule applies. Empty indicates no fare class restriction.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ffpTierList rdf:type rdf:Property ;
    rdfs:label 'Ffp Tier List' ;
    rdfs:comment 'Comma-separated list of loyalty program tier codes (e.g., Gold, Platinum, Diamond) eligible for this ancillary product. Empty indicates no tier restriction.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Last Modified By User' ;
    rdfs:comment 'User identifier or system account that most recently modified this eligibility rule record.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingCarrierList rdf:type rdf:Property ;
    rdfs:label 'Marketing Carrier List' ;
    rdfs:comment 'Comma-separated list of IATA airline codes representing marketing carriers for which this rule applies. Empty indicates all carriers.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingCarrierList rdf:type rdf:Property ;
    rdfs:label 'Operating Carrier List' ;
    rdfs:comment 'Comma-separated list of IATA airline codes representing operating carriers for which this rule applies. Empty indicates all carriers.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originAirportList rdf:type rdf:Property ;
    rdfs:label 'Origin Airport List' ;
    rdfs:comment 'Comma-separated list of IATA airport codes representing eligible origin points. Empty indicates no origin restriction.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originCountryList rdf:type rdf:Property ;
    rdfs:label 'Origin Country List' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-2 country codes representing eligible origin countries. Empty indicates no origin country restriction.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Override Allowed Flag' ;
    rdfs:comment 'Indicates whether authorized agents or systems may override this eligibility rule under exceptional circumstances.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:passengerTypeCodeList rdf:type rdf:Property ;
    rdfs:label 'Passenger Type Code List' ;
    rdfs:comment 'Comma-separated list of IATA passenger type codes (ADT, CHD, INF, MIL, SRC, etc.) eligible for this ancillary product. Empty indicates no passenger type restriction.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleCode rdf:type rdf:Property ;
    rdfs:label 'Rule Code' ;
    rdfs:comment 'Business-assigned unique code identifying this eligibility rule for operational reference and system integration.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleDescription rdf:type rdf:Property ;
    rdfs:label 'Rule Description' ;
    rdfs:comment 'Detailed business description of the eligibility rule, including rationale, business context, and any special conditions or exceptions.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleLogicExpression rdf:type rdf:Property ;
    rdfs:label 'Rule Logic Expression' ;
    rdfs:comment 'Complex logical expression or formula defining advanced eligibility conditions beyond standard attribute filters. Used for multi-condition rules requiring AND/OR/NOT logic.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleName rdf:type rdf:Property ;
    rdfs:label 'Rule Name' ;
    rdfs:comment 'Human-readable name describing the purpose and scope of this eligibility rule.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleStatus rdf:type rdf:Property ;
    rdfs:label 'Rule Status' ;
    rdfs:comment 'Current lifecycle status of the eligibility rule indicating whether it is actively enforced in sales channels.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleType rdf:type rdf:Property ;
    rdfs:label 'Rule Type' ;
    rdfs:comment 'Classification of the eligibility rule defining the primary dimension of restriction or entitlement (fare class, route, FFP tier, booking window, passenger type, or cabin).' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesChannelList rdf:type rdf:Property ;
    rdfs:label 'Sales Channel List' ;
    rdfs:comment 'Comma-separated list of sales channels (web, mobile, GDS, call_center, airport, agency) through which this ancillary product may be purchased. Empty indicates all channels.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:travelDateFrom rdf:type rdf:Property ;
    rdfs:label 'Travel Date From' ;
    rdfs:comment 'Start date of the travel period during which this eligibility rule applies. Null indicates no start date restriction.' ;
    rdfs:domain ind:Ancillary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:travelDateTo rdf:type rdf:Property ;
    rdfs:label 'Travel Date To' ;
    rdfs:comment 'End date of the travel period during which this eligibility rule applies. Null indicates no end date restriction.' ;
    rdfs:domain ind:Ancillary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:emdCouponId rdf:type rdf:Property ;
    rdfs:label 'Emd Coupon Id' ;
    rdfs:comment 'Unique identifier for the EMD coupon record. Primary key.' ;
    rdfs:domain ind:EmdCoupon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reservationETicketId rdf:type rdf:Property ;
    rdfs:label 'Reservation E Ticket Id' ;
    rdfs:comment 'Foreign key linking to reservation.e_ticket. Business justification: Associates EMD coupons with e-tickets for coupon-to-ticket linkage, service fulfillment validation, and revenue reconciliation. Required for EMD coupon lifecycle management.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ETicket .

ind:bookingClass rdf:type rdf:Property ;
    rdfs:label 'Booking Class' ;
    rdfs:comment 'Single-letter booking class (RBD - Revenue Booking Designator) of the flight segment to which this EMD coupon applies.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bspLinkNumber rdf:type rdf:Property ;
    rdfs:label 'Bsp Link Number' ;
    rdfs:comment 'BSP link reference number for reconciliation of this EMD coupon with BSP settlement reports.' ;
    rdfs:domain ind:EmdCoupon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conjunctiveTicketIndicator rdf:type rdf:Property ;
    rdfs:label 'Conjunctive Ticket Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this EMD coupon is part of a conjunctive ticket set (True) or standalone (False).' ;
    rdfs:domain ind:EmdCoupon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consumptionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Consumption Timestamp' ;
    rdfs:comment 'Timestamp when the ancillary service represented by this coupon was consumed or used by the passenger, in yyyy-MM-ddTHH:mm:ss.SSSXXX format. Null if not yet consumed.' ;
    rdfs:domain ind:EmdCoupon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:couponAmount rdf:type rdf:Property ;
    rdfs:label 'Coupon Amount' ;
    rdfs:comment 'Monetary value of the ancillary service represented by this EMD coupon, in the currency specified by coupon_currency_code.' ;
    rdfs:domain ind:EmdCoupon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:couponCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Coupon Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the coupon amount.' ;
    rdfs:domain ind:EmdCoupon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fareBasisCode rdf:type rdf:Property ;
    rdfs:label 'Fare Basis Code' ;
    rdfs:comment 'Fare basis code associated with the ticket or booking to which this EMD coupon is linked, if applicable.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdsPcc rdf:type rdf:Property ;
    rdfs:label 'Gds Pcc' ;
    rdfs:comment 'GDS Pseudo City Code of the travel agency or corporate booking office that issued this EMD coupon, if sold through a GDS.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iataAgencyNumber rdf:type rdf:Property ;
    rdfs:label 'Iata Agency Number' ;
    rdfs:comment 'Eight-digit IATA-assigned agency number of the travel agent who issued this EMD coupon.' ;
    rdfs:domain ind:EmdCoupon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingAirlineCode rdf:type rdf:Property ;
    rdfs:label 'Marketing Airline Code' ;
    rdfs:comment 'Two or three-character IATA airline code of the carrier marketing the flight segment to which this EMD coupon applies.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Modified Timestamp' ;
    rdfs:comment 'Timestamp when this EMD coupon record was last modified in the system, in yyyy-MM-ddTHH:mm:ss.SSSXXX format.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pointOfSaleCountryCode rdf:type rdf:Property ;
    rdfs:label 'Point Of Sale Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code where this EMD coupon was sold.' ;
    rdfs:domain ind:EmdCoupon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfic rdf:type rdf:Property ;
    rdfs:label 'Rfic' ;
    rdfs:comment 'Single-letter IATA Reason For Issuance Code categorizing the type of ancillary service (e.g., A=Air Transportation, C=Baggage, D=Financial Impact, E=Airport Services, F=Merchandise, G=In-flight Services, I=Individual Airline Use).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfisc rdf:type rdf:Property ;
    rdfs:label 'Rfisc' ;
    rdfs:comment 'Three-character IATA Reason For Issuance Sub-Code providing detailed classification of the ancillary service within the RFIC category (e.g., 0CC=Checked Baggage, 0B5=Seat Selection, 0G1=Lounge Access).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceTypeCode rdf:type rdf:Property ;
    rdfs:label 'Service Type Code' ;
    rdfs:comment 'Airline-specific or industry-standard code identifying the ancillary product or service type.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:voidIndicator rdf:type rdf:Property ;
    rdfs:label 'Void Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this EMD coupon has been voided (True) or remains valid (False).' ;
    rdfs:domain ind:EmdCoupon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:excessBaggageChargeId rdf:type rdf:Property ;
    rdfs:label 'Excess Baggage Charge Id' ;
    rdfs:comment 'Unique identifier for the excess baggage charge transaction record.' ;
    rdfs:domain ind:ExcessBaggageCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:flightInventoryId rdf:type rdf:Property ;
    rdfs:label 'Flight Inventory Id' ;
    rdfs:comment 'Foreign key linking to inventory.flight_inventory. Business justification: Excess baggage charges are collected at departure for specific flights. Airport operations and revenue accounting require linking charges to flight inventory for load planning and revenue reconciliati' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FlightInventory .

ind:itinerarySegmentId rdf:type rdf:Property ;
    rdfs:label 'Itinerary Segment Id' ;
    rdfs:comment 'Identifier for the specific flight segment on which the excess baggage was carried.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ItinerarySegment .

ind:baggageAllowanceKg rdf:type rdf:Property ;
    rdfs:label 'Baggage Allowance Kg' ;
    rdfs:comment 'Passenger\'s included baggage allowance in kilograms based on fare class, route, and frequent flyer status. Used to calculate excess weight.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Base Charge Amount' ;
    rdfs:comment 'Base excess baggage charge amount before taxes and fees.' ;
    rdfs:domain ind:ExcessBaggageCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chargeStatus rdf:type rdf:Property ;
    rdfs:label 'Charge Status' ;
    rdfs:comment 'Current lifecycle status of the excess baggage charge indicating whether it has been collected, is pending payment, refunded, waived by staff, or under dispute.' ;
    rdfs:domain ind:ExcessBaggageCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargeTimestamp rdf:type rdf:Property ;
    rdfs:label 'Charge Timestamp' ;
    rdfs:comment 'Date and time when the excess baggage charge was assessed and recorded in the system. Represents the principal business event time for this transaction.' ;
    rdfs:domain ind:ExcessBaggageCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:collectionPoint rdf:type rdf:Property ;
    rdfs:label 'Collection Point' ;
    rdfs:comment 'Location or channel where the excess baggage charge was assessed and collected (e.g., airport check-in counter, self-service kiosk, online pre-purchase, gate, baggage service office).' ;
    rdfs:domain ind:ExcessBaggageCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:excessPieceCount rdf:type rdf:Property ;
    rdfs:label 'Excess Piece Count' ;
    rdfs:comment 'Number of baggage pieces exceeding the passenger\'s included allowance. Null if charge is based on weight rather than piece count.' ;
    rdfs:domain ind:ExcessBaggageCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:excessWeightKg rdf:type rdf:Property ;
    rdfs:label 'Excess Weight Kg' ;
    rdfs:comment 'Total weight in kilograms of baggage exceeding the passenger\'s included allowance. Null if charge is based on piece count rather than weight.' ;
    rdfs:domain ind:ExcessBaggageCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fareClass rdf:type rdf:Property ;
    rdfs:label 'Fare Class' ;
    rdfs:comment 'Booking class or fare basis code of the passenger\'s ticket, which determines the baggage allowance and applicable excess baggage rates.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ffpTier rdf:type rdf:Property ;
    rdfs:label 'Ffp Tier' ;
    rdfs:comment 'Passenger\'s frequent flyer program tier status at time of charge, which may provide additional baggage allowance or waiver eligibility.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentReference rdf:type rdf:Property ;
    rdfs:label 'Payment Reference' ;
    rdfs:comment 'External payment transaction reference or authorization code from the payment gateway or processor. Used for reconciliation and dispute resolution.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratePerKg rdf:type rdf:Property ;
    rdfs:label 'Rate Per Kg' ;
    rdfs:comment 'Charge rate applied per kilogram of excess baggage. Used when pricing is weight-based. Null if piece-based pricing applies.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ratePerPiece rdf:type rdf:Property ;
    rdfs:label 'Rate Per Piece' ;
    rdfs:comment 'Charge rate applied per excess baggage piece. Used when pricing is piece-based. Null if weight-based pricing applies.' ;
    rdfs:domain ind:ExcessBaggageCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:refundReason rdf:type rdf:Property ;
    rdfs:label 'Refund Reason' ;
    rdfs:comment 'Explanation if the excess baggage charge was refunded after collection, including reason code or justification (e.g., measurement error, customer complaint resolution, operational error).' ;
    rdfs:domain ind:ExcessBaggageCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Total Charge Amount' ;
    rdfs:comment 'Total excess baggage charge amount including base charge and all applicable taxes and fees. Net amount collected from passenger.' ;
    rdfs:domain ind:ExcessBaggageCharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:waiverReason rdf:type rdf:Property ;
    rdfs:label 'Waiver Reason' ;
    rdfs:comment 'Free-text explanation if the excess baggage charge was waived by staff, including reason code or justification (e.g., operational disruption, customer service recovery, elite status courtesy).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inflightRetailOrderId rdf:type rdf:Property ;
    rdfs:label 'Inflight Retail Order Id' ;
    rdfs:comment 'Unique identifier for the in-flight retail order transaction. Primary key for the inflight_retail_order product.' ;
    rdfs:domain ind:InflightRetailOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:productSupplierVendorId rdf:type rdf:Property ;
    rdfs:label 'Product Supplier Vendor Id' ;
    rdfs:comment 'Foreign key linking to procurement.vendor. Business justification: Inflight retail products are sourced from suppliers tracked in procurement. Needed for inventory replenishment planning, cost of goods sold calculation, vendor performance tracking, and reconciliation' ;
    rdfs:domain ind:InflightRetailOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:cardLastFourDigits rdf:type rdf:Property ;
    rdfs:label 'Card Last Four Digits' ;
    rdfs:comment 'Last four digits of the payment card used for the transaction. Stored for customer service and dispute resolution while maintaining PCI compliance.' ;
    rdfs:domain ind:InflightRetailOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountAmount rdf:type rdf:Property ;
    rdfs:label 'Discount Amount' ;
    rdfs:comment 'Total discount applied to the order. May result from promotional offers, loyalty member benefits, or crew discretion.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fulfillmentStatus rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Status' ;
    rdfs:comment 'Current status of order delivery to the passenger. Tracks whether items were successfully delivered, unavailable, or returned.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfillmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Timestamp' ;
    rdfs:comment 'Date and time when the order was delivered to the passenger. Null if order has not yet been fulfilled.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:itemDescription rdf:type rdf:Property ;
    rdfs:label 'Item Description' ;
    rdfs:comment 'Detailed textual description of the purchased item(s). May include product name, brand, size, and variant information for customer receipt and inventory tracking.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milesEarned rdf:type rdf:Property ;
    rdfs:label 'Miles Earned' ;
    rdfs:comment 'Number of frequent flyer miles earned by the member for this purchase. Calculated based on spend amount and member tier multipliers.' ;
    rdfs:domain ind:InflightRetailOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:milesRedeemed rdf:type rdf:Property ;
    rdfs:label 'Miles Redeemed' ;
    rdfs:comment 'Number of frequent flyer miles redeemed as full or partial payment for this order. Zero if no miles were used.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:orderNumber rdf:type rdf:Property ;
    rdfs:label 'Order Number' ;
    rdfs:comment 'Human-readable order number printed on the receipt and used for customer service inquiries. Format: IFR followed by 10 digits.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderType rdf:type rdf:Property ;
    rdfs:label 'Order Type' ;
    rdfs:comment 'Classification of the retail order by product category and fulfillment method. Distinguishes between duty-free goods, meals, merchandise, and pre-ordered versus on-demand purchases.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentChannel rdf:type rdf:Property ;
    rdfs:label 'Payment Channel' ;
    rdfs:comment 'Interface or platform through which the order was placed and payment processed. Supports omnichannel retail analytics.' ;
    rdfs:domain ind:InflightRetailOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionCode rdf:type rdf:Property ;
    rdfs:label 'Promotion Code' ;
    rdfs:comment 'Promotional or discount code applied to the order. Used to track campaign effectiveness and discount attribution.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantity rdf:type rdf:Property ;
    rdfs:label 'Quantity' ;
    rdfs:comment 'Number of units of the item purchased in this order line. Supports multi-item orders and inventory depletion tracking.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:refundTimestamp rdf:type rdf:Property ;
    rdfs:label 'Refund Timestamp' ;
    rdfs:comment 'Date and time when the refund was processed. Null if no refund has been issued.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:subtotalAmount rdf:type rdf:Property ;
    rdfs:label 'Subtotal Amount' ;
    rdfs:comment 'Total amount for all items before taxes, fees, and discounts. Calculated as quantity multiplied by unit price.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transaction Timestamp' ;
    rdfs:comment 'Precise date and time when the in-flight retail transaction was initiated by the passenger. Recorded in UTC and represents the business event time.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:unitPriceAmount rdf:type rdf:Property ;
    rdfs:label 'Unit Price Amount' ;
    rdfs:comment 'Price per single unit of the item in the transaction currency. Excludes taxes and fees which are captured separately.' ;
    rdfs:domain ind:InflightRetailOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:loungeAccessId rdf:type rdf:Property ;
    rdfs:label 'Lounge Access Id' ;
    rdfs:comment 'Primary key for lounge_access' ;
    rdfs:domain ind:LoungeAccess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:loungeOperatorVendorId rdf:type rdf:Property ;
    rdfs:label 'Lounge Operator Vendor Id' ;
    rdfs:comment 'Foreign key linking to procurement.vendor. Business justification: Lounge services are typically operated by third-party vendors or partners. Critical for cost allocation (pay-per-use contracts), contract management, service quality monitoring, and invoice validation' ;
    rdfs:domain ind:LoungeAccess ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:accessDate rdf:type rdf:Property ;
    rdfs:label 'Access Date' ;
    rdfs:comment 'Date on which the passenger accessed the lounge, formatted as yyyy-MM-dd.' ;
    rdfs:domain ind:LoungeAccess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accessMethod rdf:type rdf:Property ;
    rdfs:label 'Access Method' ;
    rdfs:comment 'Method by which the passenger gained access to the lounge: purchased as ancillary, complimentary via fare class, FFP tier status, credit card partnership, day pass, upgrade, or voucher. [ENUM-REF-CANDIDATE: purchased|complimentary|day_pass|credit_card_partner|ffp_tier|fare_class|upgrade|voucher — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LoungeAccess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessStatus rdf:type rdf:Property ;
    rdfs:label 'Access Status' ;
    rdfs:comment 'Status of the lounge access transaction: granted, denied, cancelled, or no-show.' ;
    rdfs:domain ind:LoungeAccess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessTimestamp rdf:type rdf:Property ;
    rdfs:label 'Access Timestamp' ;
    rdfs:comment 'Precise date and time when the passenger entered the lounge, formatted as yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:LoungeAccess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:accessType rdf:type rdf:Property ;
    rdfs:label 'Access Type' ;
    rdfs:comment 'Indicates whether this record represents the primary passenger access or a guest accompanying the primary passenger.' ;
    rdfs:domain ind:LoungeAccess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookingChannel rdf:type rdf:Property ;
    rdfs:label 'Booking Channel' ;
    rdfs:comment 'Channel through which the lounge access was purchased or granted: web, mobile app, GDS, call center, airport, or travel agent.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargeAmount rdf:type rdf:Property ;
    rdfs:label 'Charge Amount' ;
    rdfs:comment 'Amount charged to the passenger for lounge access if purchased as an ancillary service. Null if access was complimentary.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:denialReason rdf:type rdf:Property ;
    rdfs:label 'Denial Reason' ;
    rdfs:comment 'Reason for denial if lounge access was not granted (e.g., capacity full, ineligible fare class, expired pass).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exitTimestamp rdf:type rdf:Property ;
    rdfs:label 'Exit Timestamp' ;
    rdfs:comment 'Precise date and time when the passenger exited the lounge, formatted as yyyy-MM-ddTHH:mm:ss.SSSXXX. Nullable if exit time is not tracked.' ;
    rdfs:domain ind:LoungeAccess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:guestCount rdf:type rdf:Property ;
    rdfs:label 'Guest Count' ;
    rdfs:comment 'Number of guests accompanying the primary passenger who were granted access under the same transaction.' ;
    rdfs:domain ind:LoungeAccess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:loungeCode rdf:type rdf:Property ;
    rdfs:label 'Lounge Code' ;
    rdfs:comment 'Unique code identifying the specific lounge facility accessed.' ;
    rdfs:domain ind:LoungeAccess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loungeName rdf:type rdf:Property ;
    rdfs:label 'Lounge Name' ;
    rdfs:comment 'Full name of the lounge facility accessed by the passenger.' ;
    rdfs:domain ind:LoungeAccess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerProgramCode rdf:type rdf:Property ;
    rdfs:label 'Partner Program Code' ;
    rdfs:comment 'Code identifying the partner program (e.g., credit card issuer, alliance partner) that granted lounge access eligibility.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledDepartureDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Departure Date' ;
    rdfs:comment 'Scheduled departure date of the flight associated with the lounge access, formatted as yyyy-MM-dd.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:specialServiceRequest rdf:type rdf:Property ;
    rdfs:label 'Special Service Request' ;
    rdfs:comment 'Any special service request associated with the lounge access (e.g., wheelchair assistance, dietary requirements).' ;
    rdfs:domain ind:LoungeAccess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminal rdf:type rdf:Property ;
    rdfs:label 'Terminal' ;
    rdfs:comment 'Terminal designation within the airport where the lounge is located.' ;
    rdfs:domain ind:LoungeAccess ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mealPreorderId rdf:type rdf:Property ;
    rdfs:label 'Meal Preorder Id' ;
    rdfs:comment 'Unique identifier for the meal preorder record. Primary key.' ;
    rdfs:domain ind:MealPreorder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cateringVendorId rdf:type rdf:Property ;
    rdfs:label 'Catering Vendor Id' ;
    rdfs:comment 'Foreign key linking to procurement.vendor. Business justification: Meal preorders are fulfilled by catering vendors tracked in procurement. Essential for operational coordination (order placement), quality tracking, invoice reconciliation, and vendor performance moni' ;
    rdfs:domain ind:MealPreorder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:advanceOrderHours rdf:type rdf:Property ;
    rdfs:label 'Advance Order Hours' ;
    rdfs:comment 'Number of hours in advance of departure that the meal was preordered. Used for catering planning and compliance with minimum advance order requirements.' ;
    rdfs:domain ind:MealPreorder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allergyFlag rdf:type rdf:Property ;
    rdfs:label 'Allergy Flag' ;
    rdfs:comment 'Boolean flag indicating whether the passenger has declared food allergies associated with this meal preorder.' ;
    rdfs:domain ind:MealPreorder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cancellationReason rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason' ;
    rdfs:comment 'Reason for meal preorder cancellation (e.g., passenger request, flight cancellation, booking change, catering unavailability).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cancellation Timestamp' ;
    rdfs:comment 'Date and time when the meal preorder was cancelled, if applicable. Null if not cancelled. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cateringUpliftStation rdf:type rdf:Property ;
    rdfs:label 'Catering Uplift Station' ;
    rdfs:comment 'Three-letter IATA airport code where the meal is uplifted onto the aircraft.' ;
    rdfs:domain ind:MealPreorder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Confirmation Number' ;
    rdfs:comment 'Unique confirmation number issued to the passenger upon successful meal preorder placement.' ;
    rdfs:domain ind:Ancillary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryStatus rdf:type rdf:Property ;
    rdfs:label 'Delivery Status' ;
    rdfs:comment 'Status of meal delivery on the flight (e.g., scheduled, loaded, served, not served, substituted, unavailable).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dietaryClassification rdf:type rdf:Property ;
    rdfs:label 'Dietary Classification' ;
    rdfs:comment 'Primary dietary or religious classification category for the meal (e.g., vegetarian, kosher, halal, gluten-free, diabetic). [ENUM-REF-CANDIDATE: vegetarian|vegan|kosher|halal|gluten_free|diabetic|low_sodium|low_fat|child|infant|bland|fruit|seafood|hindu|jain|other — 16 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MealPreorder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emdTypeCode rdf:type rdf:Property ;
    rdfs:label 'Emd Type Code' ;
    rdfs:comment 'Single-letter EMD type code (A for EMD-A associated with e-ticket, S for EMD-S standalone).' ;
    rdfs:domain ind:Ancillary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mealChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Meal Charge Amount' ;
    rdfs:comment 'Charge amount for the preordered meal if it is a paid ancillary service. Zero if complimentary.' ;
    rdfs:domain ind:MealPreorder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mealTypeDescription rdf:type rdf:Property ;
    rdfs:label 'Meal Type Description' ;
    rdfs:comment 'Human-readable description of the meal type corresponding to the SPML code (e.g., \'Vegetarian Meal\', \'Kosher Meal\', \'Diabetic Meal\').' ;
    rdfs:domain ind:MealPreorder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumAdvanceRequiredHours rdf:type rdf:Property ;
    rdfs:label 'Minimum Advance Required Hours' ;
    rdfs:comment 'Minimum number of hours in advance of departure required for this meal type to be preordered, as defined by catering policy.' ;
    rdfs:domain ind:MealPreorder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:modificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Modification Timestamp' ;
    rdfs:comment 'Date and time when the meal preorder was last modified. Null if never modified. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:MealPreorder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:orderChannel rdf:type rdf:Property ;
    rdfs:label 'Order Channel' ;
    rdfs:comment 'Channel through which the meal preorder was placed (e.g., web, mobile app, call center, GDS, travel agent). [ENUM-REF-CANDIDATE: web|mobile_app|call_center|airport_counter|gds|travel_agent|third_party — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MealPreorder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderTimestamp rdf:type rdf:Property ;
    rdfs:label 'Order Timestamp' ;
    rdfs:comment 'Date and time when the meal preorder was placed by the passenger or agent. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:MealPreorder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:specialInstructions rdf:type rdf:Property ;
    rdfs:label 'Special Instructions' ;
    rdfs:comment 'Free-text field for additional passenger instructions or notes related to the meal preorder (e.g., allergy information, preparation preferences).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spmlCode rdf:type rdf:Property ;
    rdfs:label 'Spml Code' ;
    rdfs:comment 'Four-letter IATA Special Meal code identifying the meal type (e.g., VGML for vegetarian, KSML for kosher, DBML for diabetic).' ;
    rdfs:domain ind:MealPreorder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ssrRecordLocator rdf:type rdf:Property ;
    rdfs:label 'Ssr Record Locator' ;
    rdfs:comment 'Reference to the associated Special Service Request (SSR) record in the PSS that documents this meal preorder.' ;
    rdfs:domain ind:MealPreorder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ancillaryOrderId rdf:type rdf:Property ;
    rdfs:label 'Ancillary Order Id' ;
    rdfs:comment 'Unique identifier for the ancillary order. Primary key for the order entity.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AncillaryOrder .

ind:ancillaryBundleId rdf:type rdf:Property ;
    rdfs:label 'Ancillary Bundle Id' ;
    rdfs:comment 'Foreign key linking to ancillary.bundle. Business justification: Orders can be for bundled ancillary products (e.g., Premium bundle including baggage + seat + lounge). The order table has ancillary_bundle_code (STRING) but no FK. Adding this FK enables proper bundl' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Bundle .

ind:fulfillmentVendorId rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Vendor Id' ;
    rdfs:comment 'Foreign key linking to procurement.vendor. Business justification: Ancillary services (lounge access, ground transport, hotel vouchers) are often fulfilled by third-party vendors. Critical for vendor performance tracking, invoice reconciliation, contract compliance, ' ;
    rdfs:domain ind:Ancillary ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:baseAmount rdf:type rdf:Property ;
    rdfs:label 'Base Amount' ;
    rdfs:comment 'Total base price of all ancillary services in the order before taxes, fees, and discounts. Represents the gross ancillary revenue component.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:departureDate rdf:type rdf:Property ;
    rdfs:label 'Departure Date' ;
    rdfs:comment 'Scheduled departure date of the flight to which the ancillary service applies. Null if the ancillary is not flight-specific.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:feeAmount rdf:type rdf:Property ;
    rdfs:label 'Fee Amount' ;
    rdfs:comment 'Total fees charged on the ancillary order, including booking fees, service charges, and payment processing fees.' ;
    rdfs:domain ind:Ancillary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fulfillmentDate rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Date' ;
    rdfs:comment 'Timestamp when the ancillary service was delivered or consumed by the passenger. Null if not yet fulfilled.' ;
    rdfs:domain ind:AncillaryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:orderDate rdf:type rdf:Property ;
    rdfs:label 'Order Date' ;
    rdfs:comment 'Timestamp when the ancillary order was placed by the passenger or agent. Represents the principal business event time for revenue recognition.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Status' ;
    rdfs:comment 'Current status of the payment transaction for this ancillary order. Tracks payment lifecycle from authorization through settlement or refund. [ENUM-REF-CANDIDATE: pending|authorized|captured|settled|failed|refunded|partially_refunded — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundEligibility rdf:type rdf:Property ;
    rdfs:label 'Refund Eligibility' ;
    rdfs:comment 'Indicates whether the ancillary order is eligible for refund based on fare rules, timing, and fulfillment status.' ;
    rdfs:domain ind:Ancillary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:orderItemId rdf:type rdf:Property ;
    rdfs:label 'Order Item Id' ;
    rdfs:comment 'Primary key for order_item' ;
    rdfs:domain ind:OrderItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fulfillmentStationId rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Station Id' ;
    rdfs:comment 'Foreign key linking to airport.station. Business justification: Order items have station-specific fulfillment points (baggage charges at check-in, lounge access at specific airports). Essential for station performance tracking, revenue attribution by location, and' ;
    rdfs:domain ind:OrderItem ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Station .

ind:bookingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Booking Timestamp' ;
    rdfs:comment 'Date and time when this ancillary service was booked or added to the order, in yyyy-MM-ddTHH:mm:ss.SSSXXX format.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fulfilmentReference rdf:type rdf:Property ;
    rdfs:label 'Fulfilment Reference' ;
    rdfs:comment 'Reference identifier used by operational systems to track delivery or fulfilment of the ancillary service (e.g., baggage tag number, seat assignment, lounge access code).' ;
    rdfs:domain ind:OrderItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Issued Timestamp' ;
    rdfs:comment 'Date and time when the EMD or service document was issued for this ancillary item, in yyyy-MM-ddTHH:mm:ss.SSSXXX format.' ;
    rdfs:domain ind:OrderItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lineNumber rdf:type rdf:Property ;
    rdfs:label 'Line Number' ;
    rdfs:comment 'Sequential ordering number of this item within the parent ancillary order. Used for display and processing order.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productCode rdf:type rdf:Property ;
    rdfs:label 'Product Code' ;
    rdfs:comment 'Business code identifying the ancillary product type. May align with RFIC (Reason for Issuance Code) and RFISC (Reason for Issuance Sub-Code) standards.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productName rdf:type rdf:Property ;
    rdfs:label 'Product Name' ;
    rdfs:comment 'Human-readable name of the ancillary service purchased, such as \'Extra Baggage 23kg\', \'Premium Seat 12A\', \'Priority Boarding\', or \'Wi-Fi Access\'.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceStatus rdf:type rdf:Property ;
    rdfs:label 'Service Status' ;
    rdfs:comment 'Current status of the ancillary service: confirmed (service guaranteed), waitlisted (pending availability), cancelled (service cancelled), refunded (payment returned), pending (awaiting confirmation), or delivered (service fulfilled).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitPrice rdf:type rdf:Property ;
    rdfs:label 'Unit Price' ;
    rdfs:comment 'Price per unit of the ancillary service before taxes and fees, in the transaction currency.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceId rdf:type rdf:Property ;
    rdfs:label 'Price Id' ;
    rdfs:comment 'Primary key for price' ;
    rdfs:domain ind:Price ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:commissionRate rdf:type rdf:Property ;
    rdfs:label 'Commission Rate' ;
    rdfs:comment 'Commission percentage paid to the sales channel or agent for selling this ancillary product at this price. Expressed as a percentage (e.g., 5.00 for 5%).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fareAmount rdf:type rdf:Property ;
    rdfs:label 'Fare Amount' ;
    rdfs:comment 'The base price amount for the ancillary product in the specified currency. Does not include taxes or fees.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marketCode rdf:type rdf:Property ;
    rdfs:label 'Market Code' ;
    rdfs:comment 'Geographic market or region code where this price applies (e.g., origin-destination pair, country, or region). Used when price is market-specific rather than route-specific.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumQuantity rdf:type rdf:Property ;
    rdfs:label 'Maximum Quantity' ;
    rdfs:comment 'Maximum number of units that can be purchased at this price. Null if no maximum limit applies.' ;
    rdfs:domain ind:Ancillary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumQuantity rdf:type rdf:Property ;
    rdfs:label 'Minimum Quantity' ;
    rdfs:comment 'Minimum number of units that must be purchased for this price to apply. Typically 1 for most ancillary products. Used for volume-based pricing.' ;
    rdfs:domain ind:Ancillary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priceCode rdf:type rdf:Property ;
    rdfs:label 'Price Code' ;
    rdfs:comment 'Business identifier for the price record, used in revenue management and offer generation systems.' ;
    rdfs:domain ind:Price ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceDescription rdf:type rdf:Property ;
    rdfs:label 'Price Description' ;
    rdfs:comment 'Detailed textual description of the price, including any special conditions, restrictions, or promotional messaging. Used for customer-facing display.' ;
    rdfs:domain ind:Price ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceStatus rdf:type rdf:Property ;
    rdfs:label 'Price Status' ;
    rdfs:comment 'Current lifecycle status of the price record: active (in use), inactive (not currently offered), pending (scheduled for future activation), expired (past expiration date), or suspended (temporarily disabled).' ;
    rdfs:domain ind:Price ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceType rdf:type rdf:Property ;
    rdfs:label 'Price Type' ;
    rdfs:comment 'Classification of the pricing strategy: flat fee (fixed amount), yield-linked (varies with fare class), dynamic (real-time demand-based), bundled (part of fare package), promotional (temporary discount), or seasonal (time-based).' ;
    rdfs:domain ind:Price ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updatedByUser rdf:type rdf:Property ;
    rdfs:label 'Updated By User' ;
    rdfs:comment 'User identifier or system account that last modified this price record. Used for audit trail and accountability.' ;
    rdfs:domain ind:Price ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carbonOffsetId rdf:type rdf:Property ;
    rdfs:label 'Carbon Offset Id' ;
    rdfs:comment 'Foreign key linking to compliance.carbon_offset. Business justification: Airlines sell carbon offsets as ancillary products to passengers at booking. Product catalog entry for \'Carbon Offset - 1 tonne CO2e\' must link to compliance carbon_offset inventory for retirement tra' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CarbonOffset .

ind:preferredVendorId rdf:type rdf:Property ;
    rdfs:label 'Preferred Vendor Id' ;
    rdfs:comment 'Foreign key linking to procurement.vendor. Business justification: Ancillary products that are vendor-delivered services (lounge access, ground transport, hotel vouchers, travel insurance) require preferred supplier linkage for procurement planning, contract negotiat' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:basePriceCurrency rdf:type rdf:Property ;
    rdfs:label 'Base Price Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the base price amount (e.g., \'USD\', \'EUR\', \'GBP\'). Defines the currency in which the product is priced in the master catalog.' ;
    rdfs:domain ind:ProductCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookingWindowEndHours rdf:type rdf:Property ;
    rdfs:label 'Booking Window End Hours' ;
    rdfs:comment 'Number of hours before scheduled departure when the ancillary product is no longer available for purchase (e.g., 24 hours before departure for baggage, 2 hours for seat selection). Null if available until departure.' ;
    rdfs:domain ind:ProductCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bookingWindowStartHours rdf:type rdf:Property ;
    rdfs:label 'Booking Window Start Hours' ;
    rdfs:comment 'Number of hours before scheduled departure when the ancillary product becomes available for purchase. Null if available immediately upon flight booking. Used for time-sensitive products like seat upgrades.' ;
    rdfs:domain ind:ProductCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cabinClassEligibility rdf:type rdf:Property ;
    rdfs:label 'Cabin Class Eligibility' ;
    rdfs:comment 'Comma-separated list of cabin classes for which this ancillary product is available (e.g., \'economy,premium_economy,business,first\'). Used to restrict or target products by travel class.' ;
    rdfs:domain ind:ProductCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelAvailability rdf:type rdf:Property ;
    rdfs:label 'Channel Availability' ;
    rdfs:comment 'Comma-separated list of sales channels where the ancillary product is available for purchase (e.g., \'web,mobile,airport,call_center,gds\'). Used to control distribution and channel-specific merchandising.' ;
    rdfs:domain ind:Ancillary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fareFamilyEligibility rdf:type rdf:Property ;
    rdfs:label 'Fare Family Eligibility' ;
    rdfs:comment 'Comma-separated list of fare families or branded fare products for which this ancillary is available or included (e.g., \'basic,standard,flex,premium\'). Used for unbundled fare strategy and fare family differentiation.' ;
    rdfs:domain ind:ProductCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iataEmdServiceType rdf:type rdf:Property ;
    rdfs:label 'Iata Emd Service Type' ;
    rdfs:comment 'IATA-standardized service type code used for EMD issuance and settlement. Maps ancillary products to industry-standard codes for interline billing and BSP/ARC settlement (e.g., \'0CC\' for baggage, \'0G1\' for lounge).' ;
    rdfs:domain ind:ProductCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iataSsimServiceCode rdf:type rdf:Property ;
    rdfs:label 'Iata Ssim Service Code' ;
    rdfs:comment 'IATA SSIM service code used for schedule and service data exchange. Identifies ancillary services in GDS and reservation systems.' ;
    rdfs:domain ind:ProductCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryControlledFlag rdf:type rdf:Property ;
    rdfs:label 'Inventory Controlled Flag' ;
    rdfs:comment 'Indicates whether the ancillary product is subject to inventory control and capacity limits (e.g., lounge seats, premium seats, onboard meal quantities). True if inventory-controlled; false if unlimited availability.' ;
    rdfs:domain ind:Ancillary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:modifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Modified By User' ;
    rdfs:comment 'User ID or system identifier of the person or process that last modified the product record. Used for audit trail and accountability.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerProductFlag rdf:type rdf:Property ;
    rdfs:label 'Partner Product Flag' ;
    rdfs:comment 'Indicates whether the ancillary product is provided by a third-party partner (e.g., car rental, hotel, travel insurance) rather than directly by the airline. True if partner product; false if airline-owned product.' ;
    rdfs:domain ind:ProductCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:passengerTypeEligibility rdf:type rdf:Property ;
    rdfs:label 'Passenger Type Eligibility' ;
    rdfs:comment 'Comma-separated list of passenger types eligible to purchase this ancillary product (e.g., \'adult,child,infant,senior,military,ffp_elite\'). Used to enforce eligibility rules and targeted merchandising.' ;
    rdfs:domain ind:ProductCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingModel rdf:type rdf:Property ;
    rdfs:label 'Pricing Model' ;
    rdfs:comment 'Pricing strategy applied to the ancillary product. Fixed pricing uses a constant price; dynamic pricing varies by demand, route, or booking class; tiered pricing offers volume discounts; bundled pricing includes multiple products; promotional pricing applies temporary discounts.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productDescription rdf:type rdf:Property ;
    rdfs:label 'Product Description' ;
    rdfs:comment 'Detailed description of the ancillary product, including features, benefits, terms, and conditions. Used for customer-facing marketing and internal reference.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productShortName rdf:type rdf:Property ;
    rdfs:label 'Product Short Name' ;
    rdfs:comment 'Abbreviated or shortened display name for the product, used in space-constrained interfaces such as mobile apps, boarding passes, and receipts.' ;
    rdfs:domain ind:ProductCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productStatus rdf:type rdf:Property ;
    rdfs:label 'Product Status' ;
    rdfs:comment 'Current lifecycle status of the ancillary product in the catalog. Active products are available for sale; inactive products are temporarily unavailable; suspended products are under review; discontinued products are permanently retired; pending_approval products await commercial approval.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Tax Category Code' ;
    rdfs:comment 'Tax classification code used to determine applicable taxes, VAT, GST, or other government charges for the ancillary product. Maps to tax calculation rules in revenue accounting systems.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelId rdf:type rdf:Property ;
    rdfs:label 'Channel Id' ;
    rdfs:comment 'Foreign key linking to marketing.marketing_channel. Business justification: Ancillary sales channels (GDS, NDC, direct web, mobile app) map to marketing channels for omnichannel campaign execution and attribution. Real business need to link distribution channels with marketin' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Channel .

ind:apiEndpointUrl rdf:type rdf:Property ;
    rdfs:label 'Api Endpoint Url' ;
    rdfs:comment 'API endpoint URL for programmatic integration with the channel. Confidential technical information.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundlingSupportedFlag rdf:type rdf:Property ;
    rdfs:label 'Bundling Supported Flag' ;
    rdfs:comment 'Indicates whether the channel supports bundled ancillary product offerings (e.g., fare families, branded fares).' ;
    rdfs:domain ind:SalesChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:channelCategory rdf:type rdf:Property ;
    rdfs:label 'Channel Category' ;
    rdfs:comment 'Categorization of the channel as direct (airline-owned), indirect (third-party), or hybrid.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelOwner rdf:type rdf:Property ;
    rdfs:label 'Channel Owner' ;
    rdfs:comment 'Entity that owns and operates the sales channel (e.g., Airline for direct channels, GDS Provider for GDS, OTA for online travel agencies). [ENUM-REF-CANDIDATE: Airline|GDS Provider|OTA|TMC|Aggregator|Airport Authority|Third Party — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SalesChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelStatus rdf:type rdf:Property ;
    rdfs:label 'Channel Status' ;
    rdfs:comment 'Current operational status of the sales channel.' ;
    rdfs:domain ind:SalesChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelType rdf:type rdf:Property ;
    rdfs:label 'Channel Type' ;
    rdfs:comment 'High-level classification of the distribution channel type.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Commission Applicable Flag' ;
    rdfs:comment 'Indicates whether commission payments apply to ancillary sales made through this channel.' ;
    rdfs:domain ind:SalesChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commissionStructureType rdf:type rdf:Property ;
    rdfs:label 'Commission Structure Type' ;
    rdfs:comment 'Type of commission structure applied to this channel (e.g., fixed percentage, tiered based on volume, product-specific rates).' ;
    rdfs:domain ind:SalesChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactEmail rdf:type rdf:Property ;
    rdfs:label 'Contact Email' ;
    rdfs:comment 'Primary email address for channel support and business inquiries. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPhone rdf:type rdf:Property ;
    rdfs:label 'Contact Phone' ;
    rdfs:comment 'Primary phone number for channel support and business inquiries. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Reference Number' ;
    rdfs:comment 'Reference number of the legal or commercial agreement governing the channel relationship. Confidential business information.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dynamicPricingEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Dynamic Pricing Enabled Flag' ;
    rdfs:comment 'Indicates whether dynamic or personalized pricing for ancillaries is enabled for this channel.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:emdIssuanceCapableFlag rdf:type rdf:Property ;
    rdfs:label 'Emd Issuance Capable Flag' ;
    rdfs:comment 'Indicates whether the channel can issue EMDs for ancillary service charges.' ;
    rdfs:domain ind:SalesChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gdsCode rdf:type rdf:Property ;
    rdfs:label 'Gds Code' ;
    rdfs:comment 'Standard GDS identifier code if the channel is a GDS (e.g., 1A for Amadeus, 1B for Sabre, 1G for Galileo, 1P for Worldspan). Null for non-GDS channels.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicScope rdf:type rdf:Property ;
    rdfs:label 'Geographic Scope' ;
    rdfs:comment 'Geographic reach and availability of the sales channel.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:integrationMethod rdf:type rdf:Property ;
    rdfs:label 'Integration Method' ;
    rdfs:comment 'Technical integration method used to connect the channel to airline systems.' ;
    rdfs:domain ind:Ancillary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:merchandisingCapability rdf:type rdf:Property ;
    rdfs:label 'Merchandising Capability' ;
    rdfs:comment 'Level of ancillary merchandising capability supported by the channel (Full = rich content, images, bundling; Limited = text-only offers; Basic = minimal ancillary support; None = no ancillary support).' ;
    rdfs:domain ind:SalesChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:multiCurrencyFlag rdf:type rdf:Property ;
    rdfs:label 'Multi Currency Flag' ;
    rdfs:comment 'Indicates whether the channel supports transactions in multiple currencies.' ;
    rdfs:domain ind:SalesChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ndcCapabilityLevel rdf:type rdf:Property ;
    rdfs:label 'Ndc Capability Level' ;
    rdfs:comment 'IATA NDC certification level achieved by the channel (Level 1 through Level 4), or None if not NDC-capable.' ;
    rdfs:domain ind:SalesChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ndcCapableFlag rdf:type rdf:Property ;
    rdfs:label 'Ndc Capable Flag' ;
    rdfs:comment 'Indicates whether the channel supports IATA NDC API standards for rich content and ancillary merchandising.' ;
    rdfs:domain ind:SalesChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paymentMethodsSupported rdf:type rdf:Property ;
    rdfs:label 'Payment Methods Supported' ;
    rdfs:comment 'Comma-separated list of payment methods accepted through this channel (e.g., Credit Card, Debit Card, PayPal, Miles, Points, Bank Transfer).' ;
    rdfs:domain ind:SalesChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformType rdf:type rdf:Property ;
    rdfs:label 'Platform Type' ;
    rdfs:comment 'Technology platform or interface type through which the channel operates. [ENUM-REF-CANDIDATE: Web|Mobile App|Kiosk|Agent Desktop|API|Voice|In-Flight System — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SalesChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:realTimeInventoryFlag rdf:type rdf:Property ;
    rdfs:label 'Real Time Inventory Flag' ;
    rdfs:comment 'Indicates whether the channel has real-time access to ancillary inventory and availability.' ;
    rdfs:domain ind:SalesChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regionCode rdf:type rdf:Property ;
    rdfs:label 'Region Code' ;
    rdfs:comment 'IATA region code or ISO region code if the channel is region-specific (e.g., EUR for Europe, NAM for North America). Null for global channels.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceLevelAgreement rdf:type rdf:Property ;
    rdfs:label 'Service Level Agreement' ;
    rdfs:comment 'Summary of service level commitments for channel availability, response time, and support (e.g., 99.9% uptime, 24/7 support).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCustomerSegment rdf:type rdf:Property ;
    rdfs:label 'Target Customer Segment' ;
    rdfs:comment 'Primary customer segment or persona targeted by this channel (e.g., Business Travelers, Leisure Travelers, Corporate Accounts, Travel Agents).' ;
    rdfs:domain ind:SalesChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seatAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Seat Assignment Id' ;
    rdfs:comment 'Primary key for seat_assignment' ;
    rdfs:domain ind:SeatAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seatMapId rdf:type rdf:Property ;
    rdfs:label 'Seat Map Id' ;
    rdfs:comment 'Foreign key linking to fleet.seat_map. Business justification: Seat assignments must reference the physical seat record from the seat map to enable operational reporting on seat characteristics (exit rows, accessibility, bulkhead) and enforce assignment rules. Cr' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SeatMap .

ind:seatProductId rdf:type rdf:Property ;
    rdfs:label 'Seat Product Id' ;
    rdfs:comment 'Foreign key linking to ancillary.seat_product. Business justification: Seat assignments reference commercial seat product definitions (e.g., Extra Legroom, Preferred, Standard). The seat_assignment table has seat_product_type (STRING) but no FK. Adding this FK normalizes' ;
    rdfs:domain ind:Ancillary ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SeatProduct .

ind:assignmentMethod rdf:type rdf:Property ;
    rdfs:label 'Assignment Method' ;
    rdfs:comment 'The method or channel through which the seat assignment was made, indicating whether it was passenger self-service, agent-assisted, or system auto-assigned. [ENUM-REF-CANDIDATE: self_select|agent_assigned|auto_assigned|kiosk|mobile_app|web|gate — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SeatAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Assignment Source System' ;
    rdfs:comment 'The source system or channel that originated the seat assignment transaction (PSS=Passenger Service System, DCS=Departure Control System, GDS=Global Distribution System). [ENUM-REF-CANDIDATE: pss|dcs|kiosk|mobile_app|web|gds|api — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SeatAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockReason rdf:type rdf:Property ;
    rdfs:label 'Block Reason' ;
    rdfs:comment 'Free-text description of the reason why the seat is blocked if is_blocked is true. Examples include crew rest, broken seat, social distancing, etc.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cabinClassCode rdf:type rdf:Property ;
    rdfs:label 'Cabin Class Code' ;
    rdfs:comment 'Single-letter IATA cabin class code indicating the service class of the assigned seat (F=First, J=Business, W=Premium Economy, Y=Economy).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancelledTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cancelled Timestamp' ;
    rdfs:comment 'The date and time when this seat assignment was cancelled or released. Null if the assignment is still active. Follows ISO 8601 format yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:changeReasonCode rdf:type rdf:Property ;
    rdfs:label 'Change Reason Code' ;
    rdfs:comment 'Code indicating the reason for a seat assignment change if the seat was reassigned after initial assignment. [ENUM-REF-CANDIDATE: passenger_request|operational|equipment_change|overbooking|upgrade|downgrade|irop|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkInSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Check In Sequence Number' ;
    rdfs:comment 'The sequence number assigned during check-in process, used for boarding pass generation and boarding order.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deckLevel rdf:type rdf:Property ;
    rdfs:label 'Deck Level' ;
    rdfs:comment 'The deck or level of the aircraft where the seat is located. Relevant for wide-body aircraft with multiple decks.' ;
    rdfs:domain ind:SeatAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupBookingIndicator rdf:type rdf:Property ;
    rdfs:label 'Group Booking Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this seat assignment is part of a group booking, which may have special handling or pricing rules.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:infantIndicator rdf:type rdf:Property ;
    rdfs:label 'Infant Indicator' ;
    rdfs:comment 'Boolean flag indicating whether an infant (lap child) is associated with this seat assignment, which may restrict certain seat types such as exit rows.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isBlocked rdf:type rdf:Property ;
    rdfs:label 'Is Blocked' ;
    rdfs:comment 'Boolean flag indicating whether the seat is blocked from assignment due to operational, safety, or commercial reasons.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isComplimentary rdf:type rdf:Property ;
    rdfs:label 'Is Complimentary' ;
    rdfs:comment 'Boolean flag indicating whether the seat assignment was provided at no charge (true) or as a paid ancillary service (false).' ;
    rdfs:domain ind:SeatAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loyaltyTierAtAssignment rdf:type rdf:Property ;
    rdfs:label 'Loyalty Tier At Assignment' ;
    rdfs:comment 'The passenger\'s loyalty program tier status at the time of seat assignment, which may influence seat selection privileges and complimentary upgrades.' ;
    rdfs:domain ind:SeatAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousSeatNumber rdf:type rdf:Property ;
    rdfs:label 'Previous Seat Number' ;
    rdfs:comment 'The seat number previously assigned to this passenger on this flight segment before a change was made. Null if this is the first assignment.' ;
    rdfs:domain ind:SeatAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seatCharacteristics rdf:type rdf:Property ;
    rdfs:label 'Seat Characteristics' ;
    rdfs:comment 'Comma-separated list of seat characteristics or attributes such as window, aisle, extra legroom, power outlet, restricted recline, etc.' ;
    rdfs:domain ind:SeatAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seatFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Seat Fee Amount' ;
    rdfs:comment 'The monetary amount charged for the seat assignment if it was a paid ancillary product. Zero or null for complimentary assignments.' ;
    rdfs:domain ind:SeatAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:seatFeeCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Seat Fee Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the seat assignment fee amount.' ;
    rdfs:domain ind:SeatAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upgradeType rdf:type rdf:Property ;
    rdfs:label 'Upgrade Type' ;
    rdfs:comment 'Indicates the type of upgrade applied if the seat assignment represents an upgrade from the originally booked cabin or seat type. Null or none if no upgrade. [ENUM-REF-CANDIDATE: paid|complimentary|operational|elite_status|voucher|bid|none — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Ancillary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seatSupplierVendorId rdf:type rdf:Property ;
    rdfs:label 'Seat Supplier Vendor Id' ;
    rdfs:comment 'Foreign key linking to procurement.vendor. Business justification: Premium seat products may involve vendor-supplied components (seat covers, cushions, entertainment systems, power outlets). Links product definition to supplier for procurement planning, warranty trac' ;
    rdfs:domain ind:SeatProduct ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:advanceSelectionWindowHours rdf:type rdf:Property ;
    rdfs:label 'Advance Selection Window Hours' ;
    rdfs:comment 'Number of hours before departure that advance seat selection opens for this product. Null if no time restriction applies.' ;
    rdfs:domain ind:SeatProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:basePriceUsd rdf:type rdf:Property ;
    rdfs:label 'Base Price Usd' ;
    rdfs:comment 'Standard base price for this seat product in USD. Actual pricing may vary by route, fare class, and dynamic pricing rules. Used as reference price for revenue attribution.' ;
    rdfs:domain ind:SeatProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bundleEligibility rdf:type rdf:Property ;
    rdfs:label 'Bundle Eligibility' ;
    rdfs:comment 'Comma-separated list of fare bundle codes that include this seat product as a complimentary benefit (e.g., \'BASIC,STANDARD,PREMIUM,BUSINESS\'). Empty if not included in any bundle.' ;
    rdfs:domain ind:SeatProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fareClassEligibility rdf:type rdf:Property ;
    rdfs:label 'Fare Class Eligibility' ;
    rdfs:comment 'Comma-separated list of fare class codes eligible to purchase or select this seat product (e.g., \'Y,B,M,H,Q,V,W\'). Empty indicates available to all fare classes.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ffpTierEligibility rdf:type rdf:Property ;
    rdfs:label 'Ffp Tier Eligibility' ;
    rdfs:comment 'Comma-separated list of FFP elite tier codes eligible for complimentary access to this seat product (e.g., \'GOLD,PLATINUM,DIAMOND\'). Empty indicates no elite benefit applies.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inSeatEntertainment rdf:type rdf:Property ;
    rdfs:label 'In Seat Entertainment' ;
    rdfs:comment 'Indicates whether this seat product includes a personal in-flight entertainment (IFE) screen. Key amenity for merchandising and customer experience differentiation.' ;
    rdfs:domain ind:SeatProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isAdvanceSelectionAllowed rdf:type rdf:Property ;
    rdfs:label 'Is Advance Selection Allowed' ;
    rdfs:comment 'Indicates whether passengers can select this seat product in advance during booking or check-in. False for seats assigned only at gate or by operational staff.' ;
    rdfs:domain ind:SeatProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isBassinetCompatible rdf:type rdf:Property ;
    rdfs:label 'Is Bassinet Compatible' ;
    rdfs:comment 'Indicates whether this seat product supports bassinet attachment for infant passengers. Typically applies to bulkhead seats in long-haul configurations.' ;
    rdfs:domain ind:SeatProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isBulkhead rdf:type rdf:Property ;
    rdfs:label 'Is Bulkhead' ;
    rdfs:comment 'Indicates whether this seat product is located at a bulkhead position (wall or divider in front). Affects legroom, storage, and bassinet availability.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isExitRow rdf:type rdf:Property ;
    rdfs:label 'Is Exit Row' ;
    rdfs:comment 'Indicates whether this seat product is located in an emergency exit row. Triggers regulatory eligibility checks and safety briefing requirements per FAA/EASA regulations.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:powerOutletType rdf:type rdf:Property ;
    rdfs:label 'Power Outlet Type' ;
    rdfs:comment 'Type of power outlet available at this seat product for passenger device charging. Key amenity for merchandising premium seat products.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingTier rdf:type rdf:Property ;
    rdfs:label 'Pricing Tier' ;
    rdfs:comment 'Revenue tier classification for this seat product. References pricing rules and fare class eligibility in revenue management systems.' ;
    rdfs:domain ind:SeatProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reclineInches rdf:type rdf:Property ;
    rdfs:label 'Recline Inches' ;
    rdfs:comment 'Maximum recline distance of the seat in inches. Null for non-reclining seats (e.g., exit row, bulkhead).' ;
    rdfs:domain ind:SeatProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:refundabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Refundability Flag' ;
    rdfs:comment 'Indicates whether the seat product purchase is refundable if the passenger cancels or changes their seat selection. Subject to fare rules and timing restrictions.' ;
    rdfs:domain ind:SeatProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:seatPitchInches rdf:type rdf:Property ;
    rdfs:label 'Seat Pitch Inches' ;
    rdfs:comment 'Distance from one point on a seat to the same point on the seat in front or behind, measured in inches. Key comfort metric for merchandising and customer communication.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:seatType rdf:type rdf:Property ;
    rdfs:label 'Seat Type' ;
    rdfs:comment 'Primary classification of the seat product defining its physical and commercial characteristics. Drives merchandising strategy and revenue attribution. [ENUM-REF-CANDIDATE: standard|preferred|extra_legroom|exit_row|bulkhead|bassinet|window|aisle|middle — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seatWidthInches rdf:type rdf:Property ;
    rdfs:label 'Seat Width Inches' ;
    rdfs:comment 'Width of the seat measured in inches. Key comfort specification for merchandising and customer communication.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transferabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Transferability Flag' ;
    rdfs:comment 'Indicates whether the seat product can be transferred to another passenger on the same Passenger Name Record (PNR) or flight. Typically false for personalized seat assignments.' ;
    rdfs:domain ind:SeatProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:wifiAccessIncluded rdf:type rdf:Property ;
    rdfs:label 'Wifi Access Included' ;
    rdfs:comment 'Indicates whether complimentary Wi-Fi access is included with this seat product. False if Wi-Fi requires separate purchase or is not available.' ;
    rdfs:domain ind:SeatProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:zoneClassification rdf:type rdf:Property ;
    rdfs:label 'Zone Classification' ;
    rdfs:comment 'Cabin zone or section identifier where this seat product is typically located (e.g., \'Forward Cabin\', \'Mid Cabin\', \'Aft Cabin\', \'Zone A\', \'Zone B\'). Used for operational boarding and merchandising segmentation.' ;
    rdfs:domain ind:SeatProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upgradeOfferId rdf:type rdf:Property ;
    rdfs:label 'Upgrade Offer Id' ;
    rdfs:comment 'Unique identifier for the upgrade offer record. Primary key.' ;
    rdfs:domain ind:Ancillary ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UpgradeOffer .

ind:sourceCabinClassId rdf:type rdf:Property ;
    rdfs:label 'Source Cabin Class Id' ;
    rdfs:comment 'Foreign key linking to inventory.cabin_class. Business justification: Upgrade offers specify source cabin class for eligibility (economy to business, business to first). Upgrade program design and offer targeting require formal cabin class linkage for source eligibility' ;
    rdfs:domain ind:UpgradeOffer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CabinClass .

ind:aircraftTypeRestriction rdf:type rdf:Property ;
    rdfs:label 'Aircraft Type Restriction' ;
    rdfs:comment 'Comma-separated list of aircraft type codes (ICAO designators) where this upgrade offer is valid. Null or empty indicates no aircraft restrictions. Used to target wide-body long-haul vs narrow-body short-haul configurations.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibleFareClasses rdf:type rdf:Property ;
    rdfs:label 'Eligible Fare Classes' ;
    rdfs:comment 'Comma-separated list of fare class codes (booking classes) that qualify for this upgrade offer. Fare classes determine revenue management eligibility and upgrade priority.' ;
    rdfs:domain ind:UpgradeOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ffpTierRequirement rdf:type rdf:Property ;
    rdfs:label 'Ffp Tier Requirement' ;
    rdfs:comment 'Minimum Frequent Flyer Program (FFP) elite tier status required for eligibility. None indicates no tier restriction; higher tiers may receive preferential upgrade offers.' ;
    rdfs:domain ind:UpgradeOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fixedPriceAmount rdf:type rdf:Property ;
    rdfs:label 'Fixed Price Amount' ;
    rdfs:comment 'The fixed monetary price for instant upgrade offers. Null for bid-based or miles-based offers. Represents the non-negotiable purchase price.' ;
    rdfs:domain ind:UpgradeOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumBidAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Bid Amount' ;
    rdfs:comment 'The maximum monetary bid amount allowed for bid-based upgrade offers. Null for non-bid offer types. Represents the ceiling price for competitive bidding.' ;
    rdfs:domain ind:UpgradeOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:milesRequired rdf:type rdf:Property ;
    rdfs:label 'Miles Required' ;
    rdfs:comment 'Number of Frequent Flyer Program (FFP) miles required to redeem this upgrade offer. Null for non-miles-based offers.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumBidAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Bid Amount' ;
    rdfs:comment 'The minimum monetary bid amount required for bid-based upgrade offers. Null for non-bid offer types. Represents the floor price for competitive bidding.' ;
    rdfs:domain ind:UpgradeOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:offerCloseHours rdf:type rdf:Property ;
    rdfs:label 'Offer Close Hours' ;
    rdfs:comment 'Number of hours before scheduled departure when this upgrade offer closes and is no longer available for purchase or bidding. Defines the closing of the offer window.' ;
    rdfs:domain ind:UpgradeOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:offerCode rdf:type rdf:Property ;
    rdfs:label 'Offer Code' ;
    rdfs:comment 'Externally-known unique code identifying this upgrade offer in merchandising and revenue management systems.' ;
    rdfs:domain ind:UpgradeOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerDescription rdf:type rdf:Property ;
    rdfs:label 'Offer Description' ;
    rdfs:comment 'Detailed description of the upgrade offer including benefits, terms, and conditions presented to passengers during the offer flow.' ;
    rdfs:domain ind:UpgradeOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerName rdf:type rdf:Property ;
    rdfs:label 'Offer Name' ;
    rdfs:comment 'Marketing name or title of the upgrade offer displayed to passengers in booking channels and merchandising platforms.' ;
    rdfs:domain ind:UpgradeOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerStatus rdf:type rdf:Property ;
    rdfs:label 'Offer Status' ;
    rdfs:comment 'Current lifecycle status of the upgrade offer. Active offers are available for purchase or bidding; inactive offers are not currently presented; expired offers have passed their validity window; suspended offers are temporarily paused; withdrawn offers have been permanently removed.' ;
    rdfs:domain ind:UpgradeOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerType rdf:type rdf:Property ;
    rdfs:label 'Offer Type' ;
    rdfs:comment 'Classification of the upgrade offer mechanism. Bid upgrade allows passengers to submit competitive bids; instant upgrade is fixed-price immediate purchase; miles upgrade uses Frequent Flyer Program (FFP) miles; operational upgrade is airline-initiated for operational reasons; points upgrade uses loyalty points; voucher upgrade redeems a voucher or certificate.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerWindowHours rdf:type rdf:Property ;
    rdfs:label 'Offer Window Hours' ;
    rdfs:comment 'Number of hours before scheduled departure that this upgrade offer becomes available to eligible passengers. Defines the opening of the offer window.' ;
    rdfs:domain ind:UpgradeOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pointsRequired rdf:type rdf:Property ;
    rdfs:label 'Points Required' ;
    rdfs:comment 'Number of loyalty points required to redeem this upgrade offer. Null for non-points-based offers. Distinct from miles for coalition or partner loyalty programs.' ;
    rdfs:domain ind:UpgradeOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:routeRestriction rdf:type rdf:Property ;
    rdfs:label 'Route Restriction' ;
    rdfs:comment 'Comma-separated list of route codes, origin-destination pairs, or geographic regions where this upgrade offer is valid. Null or empty indicates no route restrictions (global applicability).' ;
    rdfs:domain ind:UpgradeOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCabinClass rdf:type rdf:Property ;
    rdfs:label 'Target Cabin Class' ;
    rdfs:comment 'The destination cabin class to which the passenger will be upgraded if the offer is accepted and confirmed.' ;
    rdfs:domain ind:UpgradeOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upgradeTransactionId rdf:type rdf:Property ;
    rdfs:label 'Upgrade Transaction Id' ;
    rdfs:comment 'Primary key for upgrade_transaction' ;
    rdfs:domain ind:UpgradeTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:upgradeInventoryId rdf:type rdf:Property ;
    rdfs:label 'Upgrade Inventory Id' ;
    rdfs:comment 'Foreign key linking to inventory.upgrade_inventory. Business justification: Upgrade transactions consume upgrade inventory pools (elite, bid, operational). Upgrade clearance process requires tracking which inventory pool each transaction draws from for priority processing and' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UpgradeInventory .

ind:bidAcceptanceTimestamp rdf:type rdf:Property ;
    rdfs:label 'Bid Acceptance Timestamp' ;
    rdfs:comment 'Date and time when the upgrade bid was accepted and confirmed by the system. Null for non-bid or unsuccessful bid upgrades.' ;
    rdfs:domain ind:UpgradeTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:bidAmount rdf:type rdf:Property ;
    rdfs:label 'Bid Amount' ;
    rdfs:comment 'Amount bid by the passenger in an upgrade auction or bid program. Null for non-bid upgrades.' ;
    rdfs:domain ind:UpgradeTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bidSubmissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Bid Submission Timestamp' ;
    rdfs:comment 'Date and time when the passenger submitted the upgrade bid. Null for non-bid upgrades.' ;
    rdfs:domain ind:UpgradeTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:denialReasonCode rdf:type rdf:Property ;
    rdfs:label 'Denial Reason Code' ;
    rdfs:comment 'Standardized code explaining why the upgrade was denied: insufficient_inventory (no seats available), low_priority (other passengers cleared first), payment_failed (transaction declined), ineligible_fare (fare class not eligible), system_error (technical issue), expired (offer expired), cancelled_by_pax (passenger cancelled). Null if upgrade not denied. [ENUM-REF-CANDIDATE: insufficient_inventory|low_priority|payment_failed|ineligible_fare|system_error|expired|cancelled_by_pax — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationCabinClass rdf:type rdf:Property ;
    rdfs:label 'Destination Cabin Class' ;
    rdfs:comment 'The target cabin class to which the passenger is upgrading (economy, premium_economy, business, first).' ;
    rdfs:domain ind:UpgradeTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationFareClass rdf:type rdf:Property ;
    rdfs:label 'Destination Fare Class' ;
    rdfs:comment 'Single-letter fare class code assigned after the upgrade is confirmed.' ;
    rdfs:domain ind:UpgradeTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originCabinClass rdf:type rdf:Property ;
    rdfs:label 'Origin Cabin Class' ;
    rdfs:comment 'The original cabin class from which the passenger is upgrading (economy, premium_economy, business, first).' ;
    rdfs:domain ind:UpgradeTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originFareClass rdf:type rdf:Property ;
    rdfs:label 'Origin Fare Class' ;
    rdfs:comment 'Single-letter fare class code of the original booking, determining upgrade eligibility and priority.' ;
    rdfs:domain ind:UpgradeTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityScore rdf:type rdf:Property ;
    rdfs:label 'Priority Score' ;
    rdfs:comment 'Calculated priority score determining upgrade clearance order, based on fare class, elite status, bid amount, and other factors.' ;
    rdfs:domain ind:UpgradeTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:refundProcessedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Refund Processed Timestamp' ;
    rdfs:comment 'Date and time when the refund was processed and returned to the passenger. Null if no refund issued.' ;
    rdfs:domain ind:UpgradeTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:seatNumberDestination rdf:type rdf:Property ;
    rdfs:label 'Seat Number Destination' ;
    rdfs:comment 'New seat assignment after the upgrade is cleared (e.g., 2A, 8D).' ;
    rdfs:domain ind:UpgradeTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seatNumberOrigin rdf:type rdf:Property ;
    rdfs:label 'Seat Number Origin' ;
    rdfs:comment 'Original seat assignment before the upgrade (e.g., 23A, 45F).' ;
    rdfs:domain ind:UpgradeTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upgradeAmount rdf:type rdf:Property ;
    rdfs:label 'Upgrade Amount' ;
    rdfs:comment 'Monetary amount paid by the passenger for the upgrade, in the transaction currency. Zero for non-purchased upgrades (miles, operational, complimentary).' ;
    rdfs:domain ind:UpgradeTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:upgradeClearedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Upgrade Cleared Timestamp' ;
    rdfs:comment 'Date and time when the upgrade was fully processed, seat assigned, and boarding pass updated.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:upgradeConfirmedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Upgrade Confirmed Timestamp' ;
    rdfs:comment 'Date and time when the upgrade was confirmed and guaranteed to the passenger.' ;
    rdfs:domain ind:UpgradeTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:upgradeRequestTimestamp rdf:type rdf:Property ;
    rdfs:label 'Upgrade Request Timestamp' ;
    rdfs:comment 'Date and time when the upgrade transaction was initiated or requested by the passenger or system.' ;
    rdfs:domain ind:UpgradeTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:upgradeStatus rdf:type rdf:Property ;
    rdfs:label 'Upgrade Status' ;
    rdfs:comment 'Current lifecycle status of the upgrade transaction: pending (submitted awaiting processing), confirmed (upgrade guaranteed), waitlisted (on standby list), cleared (upgrade processed and seat assigned), denied (upgrade request rejected), cancelled (customer or system cancelled), expired (upgrade offer or bid expired). [ENUM-REF-CANDIDATE: pending|confirmed|waitlisted|cleared|denied|cancelled|expired — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upgradeTransactionNumber rdf:type rdf:Property ;
    rdfs:label 'Upgrade Transaction Number' ;
    rdfs:comment 'Externally-visible unique transaction number for the upgrade event, used for customer service reference and audit tracking.' ;
    rdfs:domain ind:UpgradeTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:voucherCode rdf:type rdf:Property ;
    rdfs:label 'Voucher Code' ;
    rdfs:comment 'Alphanumeric code of the upgrade voucher or certificate applied to this transaction. Null if no voucher used.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waitlistPosition rdf:type rdf:Property ;
    rdfs:label 'Waitlist Position' ;
    rdfs:comment 'Passenger\'s position on the upgrade waitlist at the time of transaction creation. Null if not waitlisted.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cargoAllotmentId rdf:type rdf:Property ;
    rdfs:label 'Cargo Allotment Id' ;
    rdfs:comment 'Unique identifier for the cargo space allotment agreement record.' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CargoAllotment .

ind:freightForwarderId rdf:type rdf:Property ;
    rdfs:label 'Freight Forwarder Id' ;
    rdfs:comment 'Foreign key linking to cargo.freight_forwarder. Business justification: Allotment has forwarder_agent_code and forwarder_agent_name as strings. Freight_forwarder is the authoritative master with iata_cargo_agent_code and legal_name. Adding freight_forwarder_id FK normaliz' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FreightForwarder .

ind:operatingCertificateId rdf:type rdf:Property ;
    rdfs:label 'Operating Certificate Id' ;
    rdfs:comment 'Foreign key linking to compliance.operating_certificate. Business justification: Cargo allotments require valid operating certificates for the routes covered. Essential for verifying route authority and traffic rights compliance when allocating capacity to freight forwarders.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OperatingCertificate .

ind:originStationId rdf:type rdf:Property ;
    rdfs:label 'Origin Station Id' ;
    rdfs:comment 'Foreign key linking to airport.station. Business justification: Allotments specify route_origin_airport_code for contract execution. Station link validates ground handler capability, customs facility, DG certification, and operational hours for allotment feasibili' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Station .

ind:allocatedVolumeCbm rdf:type rdf:Property ;
    rdfs:label 'Allocated Volume Cbm' ;
    rdfs:comment 'Pre-allocated cargo capacity in cubic meters granted to the forwarder or agent under this allotment. Null if allotment is weight-only or ULD-only.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocatedWeightKg rdf:type rdf:Property ;
    rdfs:label 'Allocated Weight Kg' ;
    rdfs:comment 'Pre-allocated cargo capacity in kilograms granted to the forwarder or agent under this allotment. Null if allotment is volume-only or ULD-only.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allotmentStatus rdf:type rdf:Property ;
    rdfs:label 'Allotment Status' ;
    rdfs:comment 'Current lifecycle status of the allotment agreement: active (in force), suspended (temporarily inactive), expired (validity period ended), cancelled (terminated early), or pending (awaiting activation).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allotmentType rdf:type rdf:Property ;
    rdfs:label 'Allotment Type' ;
    rdfs:comment 'Classification of the allotment basis: weight-based, volume-based, ULD (Unit Load Device) count-based, or hybrid combination.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoRenewalFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Flag' ;
    rdfs:comment 'Flag indicating whether the allotment agreement automatically renews upon expiration (true) or requires explicit renewal (false).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:daysOfWeekApplicable rdf:type rdf:Property ;
    rdfs:label 'Days Of Week Applicable' ;
    rdfs:comment 'Days of the week on which this allotment is valid, expressed as comma-separated day codes (e.g., \'MON,WED,FRI\') or \'ALL\' for daily applicability.' ;
    rdfs:domain ind:CargoAllotment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flightSeriesPattern rdf:type rdf:Property ;
    rdfs:label 'Flight Series Pattern' ;
    rdfs:comment 'Flight number pattern or series covered by this allotment (e.g., \'AA100-AA199\' or \'daily AA100\'). May be null if allotment applies to all flights on the route.' ;
    rdfs:domain ind:CargoAllotment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumUtilizationThresholdPct rdf:type rdf:Property ;
    rdfs:label 'Minimum Utilization Threshold Pct' ;
    rdfs:comment 'Minimum percentage of allocated capacity that the forwarder or agent must utilize to maintain the allotment in good standing. Typically ranges from 70% to 90%.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyTerms rdf:type rdf:Property ;
    rdfs:label 'Penalty Terms' ;
    rdfs:comment 'Contractual penalty terms applied if the forwarder or agent fails to meet minimum utilization thresholds or other agreement conditions.' ;
    rdfs:domain ind:CargoAllotment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateClass rdf:type rdf:Property ;
    rdfs:label 'Rate Class' ;
    rdfs:comment 'Freight rate classification applicable to shipments booked under this allotment: general cargo rates, specific commodity rates, or contract rates.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseTimeHours rdf:type rdf:Property ;
    rdfs:label 'Release Time Hours' ;
    rdfs:comment 'Number of hours before scheduled departure by which unused allotment capacity is released back to the airline for general sale.' ;
    rdfs:domain ind:CargoAllotment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:routeDestinationAirportCode rdf:type rdf:Property ;
    rdfs:label 'Route Destination Airport Code' ;
    rdfs:comment 'Three-letter IATA airport code for the destination point of the allotment route or flight series.' ;
    rdfs:domain ind:CargoAllotment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonalIndicator rdf:type rdf:Property ;
    rdfs:label 'Seasonal Indicator' ;
    rdfs:comment 'Flag indicating whether this allotment is seasonal (true) or year-round (false).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:uldCount rdf:type rdf:Property ;
    rdfs:label 'Uld Count' ;
    rdfs:comment 'Number of ULDs allocated under this agreement if allotment is ULD-based. Null if allotment is weight or volume based.' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:uldTypeCode rdf:type rdf:Property ;
    rdfs:label 'Uld Type Code' ;
    rdfs:comment 'IATA ULD type code (e.g., AKE, PMC, PAG) if the allotment is ULD-based. Null if allotment is weight or volume based.' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awbId rdf:type rdf:Property ;
    rdfs:label 'Awb Id' ;
    rdfs:comment 'Unique system identifier for the air waybill record. Primary key for the AWB entity.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Awb .

ind:handlingVendorId rdf:type rdf:Property ;
    rdfs:label 'Handling Vendor Id' ;
    rdfs:comment 'Foreign key linking to procurement.vendor. Business justification: Ground handling and cargo terminal services for AWB processing are procured from vendors. Links cargo operations to vendor performance tracking and invoice reconciliation for handling fees.' ;
    rdfs:domain ind:Awb ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:issuingAgentEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Issuing Agent Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: AWBs are issued and executed by specific cargo agents at acceptance. Regulatory requirement to track who accepted the shipment for liability and audit purposes. Standard practice in IATA cargo operati' ;
    rdfs:domain ind:Awb ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:regulatoryFilingId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Filing Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_filing. Business justification: AWBs are referenced in regulatory filings such as customs declarations, statistical reports to authorities (e.g., DOT Form 41), and trade compliance submissions. Links shipment to official filing.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryFiling .

ind:regulatoryRequirementId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Requirement Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_requirement. Business justification: AWBs must comply with IATA, customs, and dangerous goods regulations. Airlines verify regulatory compliance during acceptance and booking processes. Essential for legal shipment acceptance and audit t' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryRequirement .

ind:serviceProductId rdf:type rdf:Property ;
    rdfs:label 'Service Product Id' ;
    rdfs:comment 'Foreign key linking to cargo.service_product. Business justification: AWB has service_level (STRING) which references the cargo product catalog. Service_product table has product_code and service_level. Adding cargo_product_id FK links AWB to the authoritative product d' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceProduct .

ind:shipperId rdf:type rdf:Property ;
    rdfs:label 'Shipper Id' ;
    rdfs:comment 'Foreign key linking to cargo.shipper. Business justification: AWB currently stores shipper_name, shipper_address, shipper_account_number as denormalized strings. Shipper is the authoritative master for shipper data. Adding shipper_id FK allows JOIN to retrieve c' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Shipper .

ind:awbNumber rdf:type rdf:Property ;
    rdfs:label 'Awb Number' ;
    rdfs:comment 'The 11-digit IATA standard AWB number in format XXX-XXXXXXXX where first 3 digits are airline prefix and remaining 8 digits are serial number. This is the globally recognized identifier for the cargo shipment contract.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awbStatus rdf:type rdf:Property ;
    rdfs:label 'Awb Status' ;
    rdfs:comment 'Current lifecycle status of the AWB indicating its position in the cargo handling workflow from initial booking through final delivery. [ENUM-REF-CANDIDATE: booked|accepted|manifested|departed|in_transit|arrived|delivered|cancelled — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Awb ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awbType rdf:type rdf:Property ;
    rdfs:label 'Awb Type' ;
    rdfs:comment 'Classification of the AWB: master (MAWB issued by carrier), house (HAWB issued by freight forwarder), direct (shipper to consignee), or neutral (pre-printed blank AWB).' ;
    rdfs:domain ind:Awb ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargeableWeightKg rdf:type rdf:Property ;
    rdfs:label 'Chargeable Weight Kg' ;
    rdfs:comment 'Weight used for freight charge calculation, which is the greater of gross weight or volumetric weight (volume in cubic meters × 167 for IATA standard).' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commodityCode rdf:type rdf:Property ;
    rdfs:label 'Commodity Code' ;
    rdfs:comment 'Harmonized System (HS) code or other standardized classification code identifying the type of goods for customs and regulatory purposes.' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commodityDescription rdf:type rdf:Property ;
    rdfs:label 'Commodity Description' ;
    rdfs:comment 'Detailed description of the nature and contents of the goods being shipped, as declared by the shipper for customs and handling purposes.' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consigneeAddress rdf:type rdf:Property ;
    rdfs:label 'Consignee Address' ;
    rdfs:comment 'Complete postal address of the consignee including street, city, state/province, postal code, and country for delivery purposes.' ;
    rdfs:domain ind:Awb ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consigneeName rdf:type rdf:Property ;
    rdfs:label 'Consignee Name' ;
    rdfs:comment 'Full legal name of the party to whom the goods are being shipped and who will take delivery at destination.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dangerousGoodsIndicator rdf:type rdf:Property ;
    rdfs:label 'Dangerous Goods Indicator' ;
    rdfs:comment 'Flag indicating whether the shipment contains dangerous goods (DG) requiring special handling and documentation per IATA DGR.' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:declaredValueForCarriage rdf:type rdf:Property ;
    rdfs:label 'Declared Value For Carriage' ;
    rdfs:comment 'Value of the goods declared by the shipper for the purpose of determining carrier liability in case of loss or damage.' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:declaredValueForCustoms rdf:type rdf:Property ;
    rdfs:label 'Declared Value For Customs' ;
    rdfs:comment 'Value of the goods declared for customs purposes, used for duty and tax calculation at destination.' ;
    rdfs:domain ind:Awb ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:executedDate rdf:type rdf:Property ;
    rdfs:label 'Executed Date' ;
    rdfs:comment 'Date when the AWB contract was executed and signed by the shipper or authorized agent.' ;
    rdfs:domain ind:Awb ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:executedLocation rdf:type rdf:Property ;
    rdfs:label 'Executed Location' ;
    rdfs:comment 'City and country where the AWB was executed and signed, establishing the jurisdiction for the contract.' ;
    rdfs:domain ind:Awb ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Freight Charge Amount' ;
    rdfs:comment 'Total freight charges for the air transportation service, calculated based on chargeable weight and applicable rate.' ;
    rdfs:domain ind:Awb ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossWeightKg rdf:type rdf:Property ;
    rdfs:label 'Gross Weight Kg' ;
    rdfs:comment 'Total weight of the shipment including packaging, expressed in kilograms. This is the actual physical weight of all pieces combined.' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:natureOfGoods rdf:type rdf:Property ;
    rdfs:label 'Nature Of Goods' ;
    rdfs:comment 'High-level classification of the cargo type indicating special handling, regulatory, or operational requirements. [ENUM-REF-CANDIDATE: general|perishable|valuable|live_animals|dangerous_goods|human_remains|diplomatic|mail — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Awb ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberOfPieces rdf:type rdf:Property ;
    rdfs:label 'Number Of Pieces' ;
    rdfs:comment 'Total count of individual packages, cartons, or pieces comprising the shipment as declared on the AWB.' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:otherChargesAmount rdf:type rdf:Property ;
    rdfs:label 'Other Charges Amount' ;
    rdfs:comment 'Sum of miscellaneous charges such as fuel surcharge, security surcharge, handling fees, and other ancillary service charges.' ;
    rdfs:domain ind:Awb ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentIndicator rdf:type rdf:Property ;
    rdfs:label 'Payment Indicator' ;
    rdfs:comment 'Indicates whether freight charges are prepaid (paid by shipper at origin), collect (paid by consignee at destination), or mixed (split payment).' ;
    rdfs:domain ind:Awb ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingInstructions rdf:type rdf:Property ;
    rdfs:label 'Routing Instructions' ;
    rdfs:comment 'Specific routing path and transit points for the shipment, including intermediate airports and connecting flights.' ;
    rdfs:domain ind:Awb ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Shipment Reference Number' ;
    rdfs:comment 'Customer or agent-provided reference number for tracking and internal identification purposes.' ;
    rdfs:domain ind:Awb ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialHandlingCodes rdf:type rdf:Property ;
    rdfs:label 'Special Handling Codes' ;
    rdfs:comment 'Three-letter IATA Special Handling Codes (SHC) indicating special requirements such as PER (perishable), AVI (live animals), DGR (dangerous goods), VAL (valuable cargo). Multiple codes separated by commas.' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalChargesAmount rdf:type rdf:Property ;
    rdfs:label 'Total Charges Amount' ;
    rdfs:comment 'Grand total of all charges on the AWB including freight, valuation, and other charges.' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valuationChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Valuation Charge Amount' ;
    rdfs:comment 'Additional charge for declared value coverage exceeding the standard carrier liability limit.' ;
    rdfs:domain ind:Awb ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeCubicMeters rdf:type rdf:Property ;
    rdfs:label 'Volume Cubic Meters' ;
    rdfs:comment 'Total volumetric measurement of the shipment in cubic meters, calculated from the dimensions of all pieces.' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cargoBookingId rdf:type rdf:Property ;
    rdfs:label 'Cargo Booking Id' ;
    rdfs:comment 'Unique identifier for the cargo booking record. Primary key.' ;
    rdfs:domain ind:CargoBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:agentEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Agent Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Cargo bookings are created by specific sales or customer service agents. Essential for sales performance tracking, commission calculation, and customer relationship management. Standard CRM requiremen' ;
    rdfs:domain ind:CargoBooking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryCargoShipperId rdf:type rdf:Property ;
    rdfs:label 'Primary Cargo Shipper Id' ;
    rdfs:comment 'Reference to the party shipping the cargo. The consignor or sender of the goods.' ;
    rdfs:domain ind:CargoBooking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Shipper .

ind:acceptanceDeadlineTimestamp rdf:type rdf:Property ;
    rdfs:label 'Acceptance Deadline Timestamp' ;
    rdfs:comment 'Date and time by which the physical cargo must be delivered to the origin station for acceptance. After this time, the booking may be cancelled.' ;
    rdfs:domain ind:CargoBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:bookingStatus rdf:type rdf:Property ;
    rdfs:label 'Booking Status' ;
    rdfs:comment 'Current lifecycle status of the cargo booking. Represents the state of the commercial commitment before physical acceptance.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channel rdf:type rdf:Property ;
    rdfs:label 'Channel' ;
    rdfs:comment 'Channel through which the cargo booking was received. Indicates the interface or method used to create the reservation. [ENUM-REF-CANDIDATE: gds|direct|agent|web_portal|api|email|phone — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expiryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Expiry Timestamp' ;
    rdfs:comment 'Date and time when the booking reservation expires if not confirmed or if cargo is not accepted.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:insuranceRequested rdf:type rdf:Property ;
    rdfs:label 'Insurance Requested' ;
    rdfs:comment 'Flag indicating whether the shipper has requested cargo insurance coverage for this booking.' ;
    rdfs:domain ind:CargoBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quotedRateAmount rdf:type rdf:Property ;
    rdfs:label 'Quoted Rate Amount' ;
    rdfs:comment 'Freight rate amount quoted to the shipper for this booking. May be per kilogram or total shipment rate.' ;
    rdfs:domain ind:CargoBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Rate Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the quoted freight rate.' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateQuoteReference rdf:type rdf:Property ;
    rdfs:label 'Rate Quote Reference' ;
    rdfs:comment 'Reference number linking this booking to a previously issued freight rate quotation. Used for rate validation and pricing.' ;
    rdfs:domain ind:CargoBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedFlightDate rdf:type rdf:Property ;
    rdfs:label 'Requested Flight Date' ;
    rdfs:comment 'Date of the requested flight departure for cargo carriage.' ;
    rdfs:domain ind:CargoBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestedFlightNumber rdf:type rdf:Property ;
    rdfs:label 'Requested Flight Number' ;
    rdfs:comment 'Primary flight number requested by the shipper or agent for cargo carriage. May include multiple flights for multi-leg bookings.' ;
    rdfs:domain ind:CargoBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedVolumeCbm rdf:type rdf:Property ;
    rdfs:label 'Requested Volume Cbm' ;
    rdfs:comment 'Total volume of the cargo shipment requested for booking, measured in cubic meters.' ;
    rdfs:domain ind:CargoBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requestedWeightKg rdf:type rdf:Property ;
    rdfs:label 'Requested Weight Kg' ;
    rdfs:comment 'Total gross weight of the cargo shipment requested for booking, measured in kilograms.' ;
    rdfs:domain ind:CargoBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureControlRequired rdf:type rdf:Property ;
    rdfs:label 'Temperature Control Required' ;
    rdfs:comment 'Flag indicating whether the cargo requires temperature-controlled handling (e.g., for perishables or pharmaceuticals).' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:temperatureRangeCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Range Celsius' ;
    rdfs:comment 'Required temperature range for temperature-controlled cargo, expressed as min-max range in Celsius (e.g., 2-8).' ;
    rdfs:domain ind:CargoBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uldTypeRequested rdf:type rdf:Property ;
    rdfs:label 'Uld Type Requested' ;
    rdfs:comment 'Type of ULD (Unit Load Device) requested for the cargo, such as container or pallet type (e.g., AKE, PMC). Applicable for containerized cargo.' ;
    rdfs:domain ind:CargoBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityId rdf:type rdf:Property ;
    rdfs:label 'Capacity Id' ;
    rdfs:comment 'Primary key for capacity' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:aircraftRegistrationId rdf:type rdf:Property ;
    rdfs:label 'Aircraft Registration Id' ;
    rdfs:comment 'Reference to the aircraft registration assigned to this flight segment.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AircraftRegistration .

ind:flightNumberId rdf:type rdf:Property ;
    rdfs:label 'Flight Number Id' ;
    rdfs:comment 'Foreign key linking to route.flight_number. Business justification: Cargo capacity is allocated and controlled at flight number level (not just route). Tactical capacity management, allotment assignment, and booking acceptance decisions operate on specific flight numb' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FlightNumber .

ind:operationalApprovalId rdf:type rdf:Property ;
    rdfs:label 'Operational Approval Id' ;
    rdfs:comment 'Foreign key linking to compliance.operational_approval. Business justification: Cargo capacity on certain routes requires operational approvals (e.g., ETOPS cargo operations, special cargo authorizations). Links capacity planning to required operational approvals for compliance v' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OperationalApproval .

ind:aircraftConfiguration rdf:type rdf:Property ;
    rdfs:label 'Aircraft Configuration' ;
    rdfs:comment 'The operational configuration of the aircraft for this flight: passenger (belly cargo only), freighter (dedicated cargo aircraft), or combi (mixed passenger and main deck cargo).' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allotmentDangerousGoodsKg rdf:type rdf:Property ;
    rdfs:label 'Allotment Dangerous Goods Kg' ;
    rdfs:comment 'Weight capacity in kilograms allocated to dangerous goods (DG) cargo for this flight segment, subject to IATA DGR restrictions.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allotmentExpressKg rdf:type rdf:Property ;
    rdfs:label 'Allotment Express Kg' ;
    rdfs:comment 'Weight capacity in kilograms allocated to express cargo product type for this flight segment.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allotmentGeneralKg rdf:type rdf:Property ;
    rdfs:label 'Allotment General Kg' ;
    rdfs:comment 'Weight capacity in kilograms allocated to general cargo product type for this flight segment.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allotmentLiveAnimalsKg rdf:type rdf:Property ;
    rdfs:label 'Allotment Live Animals Kg' ;
    rdfs:comment 'Weight capacity in kilograms allocated to live animals cargo for this flight segment.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allotmentPerishableKg rdf:type rdf:Property ;
    rdfs:label 'Allotment Perishable Kg' ;
    rdfs:comment 'Weight capacity in kilograms allocated to perishable cargo product type (e.g., fresh produce, pharmaceuticals) for this flight segment.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allotmentValuableKg rdf:type rdf:Property ;
    rdfs:label 'Allotment Valuable Kg' ;
    rdfs:comment 'Weight capacity in kilograms allocated to valuable cargo (e.g., precious metals, jewelry, currency) for this flight segment.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:availableVolumeCbm rdf:type rdf:Property ;
    rdfs:label 'Available Volume Cbm' ;
    rdfs:comment 'Remaining available volume capacity in cubic meters for new bookings (total capacity minus booked volume).' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:availableWeightKg rdf:type rdf:Property ;
    rdfs:label 'Available Weight Kg' ;
    rdfs:comment 'Remaining available weight capacity in kilograms for new bookings (total capacity minus booked weight).' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bellyCargoVolumeCapacityCbm rdf:type rdf:Property ;
    rdfs:label 'Belly Cargo Volume Capacity Cbm' ;
    rdfs:comment 'Total available volume capacity in cubic meters for belly cargo compartments on this flight segment.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bellyCargoWeightCapacityKg rdf:type rdf:Property ;
    rdfs:label 'Belly Cargo Weight Capacity Kg' ;
    rdfs:comment 'Total available weight capacity in kilograms for belly cargo compartments on this flight segment.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bookedVolumeCbm rdf:type rdf:Property ;
    rdfs:label 'Booked Volume Cbm' ;
    rdfs:comment 'Total volume in cubic meters of cargo bookings confirmed for this flight segment at the time of capacity snapshot.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bookedWeightKg rdf:type rdf:Property ;
    rdfs:label 'Booked Weight Kg' ;
    rdfs:comment 'Total weight in kilograms of cargo bookings confirmed for this flight segment at the time of capacity snapshot.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bulkCargoAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Bulk Cargo Allowed Flag' ;
    rdfs:comment 'Indicates whether loose (non-containerized) bulk cargo is accepted on this flight segment (True) or only ULD cargo is permitted (False).' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capacityStatus rdf:type rdf:Property ;
    rdfs:label 'Capacity Status' ;
    rdfs:comment 'Current booking status of cargo capacity for this flight segment: open (accepting bookings), limited (restricted availability), closed (no capacity), waitlist (overbooked, accepting waitlist), embargoed (no new bookings allowed), cancelled (flight cancelled).' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlMethod rdf:type rdf:Property ;
    rdfs:label 'Control Method' ;
    rdfs:comment 'Method by which capacity allocation is managed for this flight: manual (human-controlled), automated (system-driven revenue management), or hybrid (combination of both).' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:embargoFlag rdf:type rdf:Property ;
    rdfs:label 'Embargo Flag' ;
    rdfs:comment 'Indicates whether a cargo embargo is in effect for this flight segment, preventing new bookings (True) or allowing normal operations (False).' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:embargoReason rdf:type rdf:Property ;
    rdfs:label 'Embargo Reason' ;
    rdfs:comment 'Free-text description of the reason for cargo embargo if embargo_flag is True (e.g., weight and balance restrictions, operational constraints, security concerns).' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mainDeckVolumeCapacityCbm rdf:type rdf:Property ;
    rdfs:label 'Main Deck Volume Capacity Cbm' ;
    rdfs:comment 'Total available volume capacity in cubic meters for main deck cargo on freighter or combi aircraft. Null for passenger-only configurations.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mainDeckWeightCapacityKg rdf:type rdf:Property ;
    rdfs:label 'Main Deck Weight Capacity Kg' ;
    rdfs:comment 'Total available weight capacity in kilograms for main deck cargo on freighter or combi aircraft. Null for passenger-only configurations.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overbookingFactorPercent rdf:type rdf:Property ;
    rdfs:label 'Overbooking Factor Percent' ;
    rdfs:comment 'Percentage by which capacity may be overbooked to account for expected no-shows and cancellations. Used in revenue management optimization.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:snapshotTimestamp rdf:type rdf:Property ;
    rdfs:label 'Snapshot Timestamp' ;
    rdfs:comment 'Timestamp representing the point-in-time when this capacity snapshot was captured for reporting and analytics (yyyy-MM-ddTHH:mm:ss.SSSXXX).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:totalVolumeCapacityCbm rdf:type rdf:Property ;
    rdfs:label 'Total Volume Capacity Cbm' ;
    rdfs:comment 'Total available cargo volume capacity in cubic meters across all compartments (belly plus main deck if applicable) for this flight segment.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalWeightCapacityKg rdf:type rdf:Property ;
    rdfs:label 'Total Weight Capacity Kg' ;
    rdfs:comment 'Total available cargo weight capacity in kilograms across all compartments (belly plus main deck if applicable) for this flight segment.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:uldPositionsAvailable rdf:type rdf:Property ;
    rdfs:label 'Uld Positions Available' ;
    rdfs:comment 'Number of Unit Load Device (ULD) positions available for loading on this flight segment. Applies to containerized cargo.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:uldPositionsBooked rdf:type rdf:Property ;
    rdfs:label 'Uld Positions Booked' ;
    rdfs:comment 'Number of Unit Load Device (ULD) positions already booked for this flight segment.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:volumeUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Volume Unit Of Measure' ;
    rdfs:comment 'Unit of measure for all volume capacity fields. Standardized to cubic meters (CBM) per IATA standards.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Weight Unit Of Measure' ;
    rdfs:comment 'Unit of measure for all weight capacity fields. Standardized to kilograms (KG) per IATA standards.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cargoRevenueId rdf:type rdf:Property ;
    rdfs:label 'Cargo Revenue Id' ;
    rdfs:comment 'Unique identifier for the cargo revenue accounting record. Primary key.' ;
    rdfs:domain ind:CargoRevenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cargoManifestId rdf:type rdf:Property ;
    rdfs:label 'Cargo Manifest Id' ;
    rdfs:comment 'Foreign key linking to cargo.manifest. Business justification: Cargo_revenue has flight_number and flight_date (strings) to identify which flight the revenue is associated with. Manifest is the authoritative record for flight cargo operations. Adding cargo_manife' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Manifest .

ind:accountingPeriod rdf:type rdf:Property ;
    rdfs:label 'Accounting Period' ;
    rdfs:comment 'The accounting period (YYYY-MM format) to which this revenue record is allocated for financial reporting purposes.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consigneeAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Consignee Account Number' ;
    rdfs:comment 'The account number of the consignee (receiver) to whom the cargo is being delivered.' ;
    rdfs:domain ind:CargoRevenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenter rdf:type rdf:Property ;
    rdfs:label 'Cost Center' ;
    rdfs:comment 'The cost center responsible for this cargo revenue, typically aligned with the operating station or business unit.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeRate rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate' ;
    rdfs:comment 'The exchange rate applied to convert the transaction currency to the reporting currency at the time of revenue recognition.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Freight Revenue Amount' ;
    rdfs:comment 'The base freight revenue amount earned from transporting the cargo, excluding surcharges and handling fees.' ;
    rdfs:domain ind:CargoRevenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:glAccountCode rdf:type rdf:Property ;
    rdfs:label 'Gl Account Code' ;
    rdfs:comment 'The general ledger account code to which this cargo revenue is posted in the financial accounting system.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handlingRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Handling Revenue Amount' ;
    rdfs:comment 'Revenue from cargo handling services including terminal handling charges and special handling fees.' ;
    rdfs:domain ind:CargoRevenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interlineSettlementAmount rdf:type rdf:Property ;
    rdfs:label 'Interline Settlement Amount' ;
    rdfs:comment 'The amount to be settled with partner carriers through IATA Cargo Accounts Settlement Systems (CASS) for interline shipments. Null for direct single-carrier shipments.' ;
    rdfs:domain ind:CargoRevenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:perRtk rdf:type rdf:Property ;
    rdfs:label 'Per Rtk' ;
    rdfs:comment 'Revenue per RTK, calculated as total revenue divided by RTK flown. Key yield management metric for cargo operations.' ;
    rdfs:domain ind:CargoRevenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:profitCenter rdf:type rdf:Property ;
    rdfs:label 'Profit Center' ;
    rdfs:comment 'The profit center to which this cargo revenue is attributed for management reporting and profitability analysis.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prorationFactor rdf:type rdf:Property ;
    rdfs:label 'Proration Factor' ;
    rdfs:comment 'The numeric proration factor applied to calculate this carriers share of interline revenue. Value between 0 and 1 representing the percentage allocation.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prorationMethod rdf:type rdf:Property ;
    rdfs:label 'Proration Method' ;
    rdfs:comment 'The method used to allocate revenue across multiple carriers in interline shipments. IATA_PRORATE uses standard IATA prorate factors, BILATERAL_AGREEMENT uses negotiated rates between carriers, SPECIAL_PRORATE uses custom allocation rules, DIRECT indicates single-carrier revenue with no proration.' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognitionDate rdf:type rdf:Property ;
    rdfs:label 'Recognition Date' ;
    rdfs:comment 'The date on which the cargo revenue was recognized in the accounting system, typically aligned with flight departure or completion.' ;
    rdfs:domain ind:CargoRevenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revenueStatus rdf:type rdf:Property ;
    rdfs:label 'Revenue Status' ;
    rdfs:comment 'Current status of the revenue record in the accounting lifecycle: recognized in financial statements, deferred to future period, adjusted after initial recognition, reversed due to cancellation, or disputed pending resolution.' ;
    rdfs:domain ind:CargoRevenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueType rdf:type rdf:Property ;
    rdfs:label 'Revenue Type' ;
    rdfs:comment 'Classification of revenue by operational mode: belly cargo on passenger flights, dedicated freighter operations, charter services, or ground trucking.' ;
    rdfs:domain ind:CargoRevenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rtkFlown rdf:type rdf:Property ;
    rdfs:label 'Rtk Flown' ;
    rdfs:comment 'Revenue tonne kilometers flown for this shipment segment, calculated as chargeable weight in tonnes multiplied by distance flown in kilometers. Standard cargo capacity utilization metric.' ;
    rdfs:domain ind:CargoRevenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceLevel rdf:type rdf:Property ;
    rdfs:label 'Service Level' ;
    rdfs:comment 'The service level or product type under which the cargo was transported, affecting pricing and handling requirements.' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentWeightKg rdf:type rdf:Property ;
    rdfs:label 'Shipment Weight Kg' ;
    rdfs:comment 'The chargeable weight of the cargo shipment in kilograms used for revenue calculation. May be actual weight or volumetric weight, whichever is greater.' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shipperAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Shipper Account Number' ;
    rdfs:comment 'The account number of the shipper (consignor) who tendered the cargo for transport.' ;
    rdfs:domain ind:CargoRevenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surchargeRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Surcharge Revenue Amount' ;
    rdfs:comment 'Total surcharge revenue including fuel surcharges, security surcharges, and other applicable add-on charges.' ;
    rdfs:domain ind:CargoRevenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Total Revenue Amount' ;
    rdfs:comment 'Total cargo revenue amount for this record, sum of freight, surcharge, and handling revenue components.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yieldPerKg rdf:type rdf:Property ;
    rdfs:label 'Yield Per Kg' ;
    rdfs:comment 'Revenue yield per kilogram, calculated as total revenue divided by chargeable weight. Key performance metric for cargo pricing effectiveness.' ;
    rdfs:domain ind:CargoRevenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cargoSurchargeId rdf:type rdf:Property ;
    rdfs:label 'Cargo Surcharge Id' ;
    rdfs:comment 'Unique identifier for the cargo surcharge rate record. Primary key.' ;
    rdfs:domain ind:CargoSurcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvalStatus rdf:type rdf:Property ;
    rdfs:label 'Approval Status' ;
    rdfs:comment 'Workflow approval status for the surcharge rate. Ensures proper authorization before surcharge becomes active.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedByUser rdf:type rdf:Property ;
    rdfs:label 'Approved By User' ;
    rdfs:comment 'User ID or name of the revenue management or pricing authority who approved this surcharge rate.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approved Timestamp' ;
    rdfs:comment 'Date and time when the surcharge rate was approved for use.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:calculationBasis rdf:type rdf:Property ;
    rdfs:label 'Calculation Basis' ;
    rdfs:comment 'Method used to calculate the surcharge amount (per kilogram, per shipment, per Air Waybill (AWB), percentage of base freight, flat rate per transaction, or per piece).' ;
    rdfs:domain ind:CargoSurcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Charge Amount' ;
    rdfs:comment 'Maximum surcharge amount cap. Limits the surcharge to prevent excessive charges on high-value or high-weight shipments.' ;
    rdfs:domain ind:CargoSurcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Charge Amount' ;
    rdfs:comment 'Minimum surcharge amount to be applied regardless of calculated value. Ensures a floor charge for the surcharge.' ;
    rdfs:domain ind:CargoSurcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originStationCode rdf:type rdf:Property ;
    rdfs:label 'Origin Station Code' ;
    rdfs:comment 'Three-letter IATA airport or station code where the surcharge applies at origin. Null indicates surcharge applies to all origins.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passThroughFlag rdf:type rdf:Property ;
    rdfs:label 'Pass Through Flag' ;
    rdfs:comment 'Indicates whether the surcharge is a pass-through charge collected on behalf of a third party (e.g., government, airport authority) versus airline revenue. True if pass-through, False if airline revenue.' ;
    rdfs:domain ind:CargoSurcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:publishedFlag rdf:type rdf:Property ;
    rdfs:label 'Published Flag' ;
    rdfs:comment 'Indicates whether the surcharge rate has been published to external systems (GDS, cargo portals, agent systems). True if published, False if internal only.' ;
    rdfs:domain ind:CargoSurcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:publishedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Published Timestamp' ;
    rdfs:comment 'Date and time when the surcharge rate was published to external distribution channels.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rateAmount rdf:type rdf:Property ;
    rdfs:label 'Rate Amount' ;
    rdfs:comment 'Numeric value of the surcharge rate. Interpretation depends on calculation_basis (e.g., dollar amount per kg, percentage value, flat fee amount).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryBasis rdf:type rdf:Property ;
    rdfs:label 'Regulatory Basis' ;
    rdfs:comment 'Legal or regulatory justification for the surcharge (e.g., government-mandated security fee, environmental levy, customs processing fee). Used for compliance and transparency.' ;
    rdfs:domain ind:CargoSurcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeType rdf:type rdf:Property ;
    rdfs:label 'Route Type' ;
    rdfs:comment 'Classification of route to which the surcharge applies (domestic within country, international cross-border, regional within continent, intercontinental long-haul).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surchargeCategory rdf:type rdf:Property ;
    rdfs:label 'Surcharge Category' ;
    rdfs:comment 'High-level classification of the surcharge type for grouping and reporting purposes.' ;
    rdfs:domain ind:CargoSurcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surchargeCode rdf:type rdf:Property ;
    rdfs:label 'Surcharge Code' ;
    rdfs:comment 'Standard code identifying the surcharge type (e.g., FSC for Fuel Surcharge, SSC for Security Surcharge, DGS for Dangerous Goods Surcharge, OVS for Oversize Surcharge, RAS for Remote Area Surcharge, CAF for Currency Adjustment Factor, HAN for Handling Surcharge).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surchargeName rdf:type rdf:Property ;
    rdfs:label 'Surcharge Name' ;
    rdfs:comment 'Full descriptive name of the surcharge (e.g., Fuel Surcharge, Security Surcharge, Dangerous Goods Handling Surcharge, Oversize Cargo Surcharge, Remote Area Delivery Surcharge, Currency Adjustment Factor, Peak Season Surcharge).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surchargeStatus rdf:type rdf:Property ;
    rdfs:label 'Surcharge Status' ;
    rdfs:comment 'Current lifecycle status of the surcharge rate record. Controls whether the surcharge is applied in rating and invoicing processes.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxTreatmentCode rdf:type rdf:Property ;
    rdfs:label 'Tax Treatment Code' ;
    rdfs:comment 'Code indicating how the surcharge is treated for tax purposes (e.g., taxable, exempt, zero-rated). Used for accurate tax calculation and reporting.' ;
    rdfs:domain ind:CargoSurcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightBreakMaximumKg rdf:type rdf:Property ;
    rdfs:label 'Weight Break Maximum Kg' ;
    rdfs:comment 'Maximum chargeable weight in kilograms for this surcharge rate to apply. Used for weight-tiered surcharge structures.' ;
    rdfs:domain ind:CargoSurcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightBreakMinimumKg rdf:type rdf:Property ;
    rdfs:label 'Weight Break Minimum Kg' ;
    rdfs:comment 'Minimum chargeable weight in kilograms for this surcharge rate to apply. Used for weight-tiered surcharge structures.' ;
    rdfs:domain ind:CargoSurcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:claimId rdf:type rdf:Property ;
    rdfs:label 'Claim Id' ;
    rdfs:comment 'Primary key for claim' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:claimsHandlerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Claims Handler Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Cargo claims are assigned to specific claims adjusters for investigation and settlement. Case management requirement - tracks workload, performance, and accountability. Essential for claims processing' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:claimStatus rdf:type rdf:Property ;
    rdfs:label 'Claim Status' ;
    rdfs:comment 'Current lifecycle status of the claim in the adjudication workflow. [ENUM-REF-CANDIDATE: draft|filed|under_investigation|pending_documents|liability_determined|approved|settled|rejected|closed — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimType rdf:type rdf:Property ;
    rdfs:label 'Claim Type' ;
    rdfs:comment 'Classification of the claim incident: loss (missing shipment), damage (physical harm to goods), delay (late delivery), pilferage (theft), shortage (partial loss), or contamination (quality degradation).' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimantAddress rdf:type rdf:Property ;
    rdfs:label 'Claimant Address' ;
    rdfs:comment 'Full mailing address of the claimant for official correspondence and settlement payment.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimantContactEmail rdf:type rdf:Property ;
    rdfs:label 'Claimant Contact Email' ;
    rdfs:comment 'Primary email address for claim correspondence and notifications.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimantContactPhone rdf:type rdf:Property ;
    rdfs:label 'Claimant Contact Phone' ;
    rdfs:comment 'Primary telephone number for claimant contact during claim investigation.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimantName rdf:type rdf:Property ;
    rdfs:label 'Claimant Name' ;
    rdfs:comment 'Full legal name of the party filing the claim (shipper, consignee, or their authorized representative).' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimantType rdf:type rdf:Property ;
    rdfs:label 'Claimant Type' ;
    rdfs:comment 'Classification of the claimant party role in the shipment transaction.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimedAmount rdf:type rdf:Property ;
    rdfs:label 'Claimed Amount' ;
    rdfs:comment 'Total monetary amount claimed by the claimant for loss, damage, or delay, in the claim currency.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:damageDescription rdf:type rdf:Property ;
    rdfs:label 'Damage Description' ;
    rdfs:comment 'Detailed narrative description of the loss, damage, delay, or other incident circumstances as reported by the claimant.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discoveryDate rdf:type rdf:Property ;
    rdfs:label 'Discovery Date' ;
    rdfs:comment 'Date when the loss, damage, or delay was first discovered by the claimant or carrier.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:filingDate rdf:type rdf:Property ;
    rdfs:label 'Filing Date' ;
    rdfs:comment 'Date when the claim was formally filed by the claimant. Principal business event timestamp for the claim transaction.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:incidentDate rdf:type rdf:Property ;
    rdfs:label 'Incident Date' ;
    rdfs:comment 'Date when the incident (loss, damage, delay) is believed to have occurred, if determinable.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:insuranceClaimReference rdf:type rdf:Property ;
    rdfs:label 'Insurance Claim Reference' ;
    rdfs:comment 'Reference number of the corresponding insurance claim filed by the carrier for recovery, if applicable.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceRecoveryFlag rdf:type rdf:Property ;
    rdfs:label 'Insurance Recovery Flag' ;
    rdfs:comment 'Indicates whether the carrier pursued or intends to pursue insurance recovery for this claim.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:investigationNotes rdf:type rdf:Property ;
    rdfs:label 'Investigation Notes' ;
    rdfs:comment 'Internal notes and findings from the claim investigation process.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationStatus rdf:type rdf:Property ;
    rdfs:label 'Investigation Status' ;
    rdfs:comment 'Current status of the internal investigation into the claim incident.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liabilityDetermination rdf:type rdf:Property ;
    rdfs:label 'Liability Determination' ;
    rdfs:comment 'Outcome of the liability assessment: whether the carrier is liable, not liable, partially liable, or a third party is liable.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liabilityLimitApplicable rdf:type rdf:Property ;
    rdfs:label 'Liability Limit Applicable' ;
    rdfs:comment 'Indicates whether the Montreal Convention liability limit (Special Drawing Rights per kilogram) applies to this claim.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:outcome rdf:type rdf:Property ;
    rdfs:label 'Outcome' ;
    rdfs:comment 'Final outcome of the claim adjudication process.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementAmount rdf:type rdf:Property ;
    rdfs:label 'Settlement Amount' ;
    rdfs:comment 'Final monetary amount approved for settlement payment to the claimant, in the claim currency. May differ from claimed amount based on liability determination.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shipmentPieces rdf:type rdf:Property ;
    rdfs:label 'Shipment Pieces' ;
    rdfs:comment 'Number of pieces in the shipment as declared on the AWB.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supportingDocumentsList rdf:type rdf:Property ;
    rdfs:label 'Supporting Documents List' ;
    rdfs:comment 'Comma-separated list or description of supporting documents submitted with the claim (e.g., commercial invoice, packing list, photos, survey report, delivery receipt).' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsEntryId rdf:type rdf:Property ;
    rdfs:label 'Customs Entry Id' ;
    rdfs:comment 'Unique identifier for the customs declaration record. Primary key for the customs entry entity.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:customsBrokerVendorId rdf:type rdf:Property ;
    rdfs:label 'Customs Broker Vendor Id' ;
    rdfs:comment 'Foreign key linking to procurement.vendor. Business justification: Customs brokerage services are procured from licensed vendors. Essential for broker performance tracking, clearance time SLAs, and reconciliation of customs clearance fees against vendor invoices.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:customsOfficerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Customs Officer Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Customs entries are processed by specific customs clearance officers. Regulatory requirement - must track who filed the entry for compliance audits and liability. Essential for customs broker accounta' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:portOfEntryStationId rdf:type rdf:Property ;
    rdfs:label 'Port Of Entry Station Id' ;
    rdfs:comment 'Foreign key linking to airport.station. Business justification: Customs entries specify port_of_entry_code for clearance. Station link validates customs facility availability, regulatory authority, broker assignment, operating hours, and examination capability for' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Station .

ind:certificateOfOriginNumber rdf:type rdf:Property ;
    rdfs:label 'Certificate Of Origin Number' ;
    rdfs:comment 'Reference number of the certificate of origin document supporting the declared country of origin. Required for preferential duty claims.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargesCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Charges Currency Code' ;
    rdfs:comment 'Three-letter ISO currency code for all customs charges and fees. Typically the currency of the importing or exporting country.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfDestination rdf:type rdf:Property ;
    rdfs:label 'Country Of Destination' ;
    rdfs:comment 'Three-letter ISO country code indicating the final destination country for the goods. Used for export control and trade statistics.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfExport rdf:type rdf:Property ;
    rdfs:label 'Country Of Export' ;
    rdfs:comment 'Three-letter ISO country code indicating the country from which the goods were exported. May differ from country of origin for re-exports.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfOrigin rdf:type rdf:Property ;
    rdfs:label 'Country Of Origin' ;
    rdfs:comment 'Three-letter ISO country code indicating where the goods were manufactured or produced. Determines eligibility for preferential trade agreements and origin-based duties.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsBrokerLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Customs Broker License Number' ;
    rdfs:comment 'Official license or registration number of the customs broker authorized to conduct customs business in the jurisdiction.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsDutyAmount rdf:type rdf:Property ;
    rdfs:label 'Customs Duty Amount' ;
    rdfs:comment 'Total customs duty assessed on the imported or exported goods. Calculated based on tariff classification, value, and applicable trade agreements.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:entryNumber rdf:type rdf:Property ;
    rdfs:label 'Entry Number' ;
    rdfs:comment 'Official customs entry number assigned by the customs authority. Unique identifier for tracking the declaration through customs clearance process.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryStatus rdf:type rdf:Property ;
    rdfs:label 'Entry Status' ;
    rdfs:comment 'Current status of the customs entry in the clearance workflow. Tracks progression from initial filing through final release or other disposition. [ENUM-REF-CANDIDATE: draft|filed|under_examination|released|held|seized|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryType rdf:type rdf:Property ;
    rdfs:label 'Entry Type' ;
    rdfs:comment 'Type of customs declaration indicating the nature of the cargo movement across borders. Determines applicable customs procedures and documentation requirements.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:examinationResult rdf:type rdf:Property ;
    rdfs:label 'Examination Result' ;
    rdfs:comment 'Outcome of the customs examination or inspection. Indicates whether the cargo passed inspection or if issues were identified.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:examinationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Examination Timestamp' ;
    rdfs:comment 'Date and time when customs examination or inspection was conducted. Null if no examination was performed.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:examinationType rdf:type rdf:Property ;
    rdfs:label 'Examination Type' ;
    rdfs:comment 'Type of customs examination or inspection conducted on the cargo. Ranges from documentary review to full physical inspection.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exporterName rdf:type rdf:Property ;
    rdfs:label 'Exporter Name' ;
    rdfs:comment 'Legal name of the party exporting the goods. Required for export declarations and trade compliance.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exporterTaxNumber rdf:type rdf:Property ;
    rdfs:label 'Exporter Tax Number' ;
    rdfs:comment 'Tax identification number or business registration number of the exporter. Required for export documentation and compliance.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Filing Timestamp' ;
    rdfs:comment 'Date and time when the customs declaration was officially filed with the customs authority. Critical for compliance with advance filing requirements.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:holdReason rdf:type rdf:Property ;
    rdfs:label 'Hold Reason' ;
    rdfs:comment 'Explanation for why the cargo is being held by customs. May include documentation issues, valuation disputes, or regulatory concerns.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hsCode rdf:type rdf:Property ;
    rdfs:label 'Hs Code' ;
    rdfs:comment 'International commodity classification code used to determine applicable duties, taxes, and regulatory requirements. Six to ten digit code from the Harmonized Commodity Description and Coding System.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:importerOfRecord rdf:type rdf:Property ;
    rdfs:label 'Importer Of Record' ;
    rdfs:comment 'Legal name of the party responsible for ensuring imported goods comply with local laws and for paying duties and taxes. Legally liable entity for the import.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:importerTaxNumber rdf:type rdf:Property ;
    rdfs:label 'Importer Tax Number' ;
    rdfs:comment 'Tax identification number or business registration number of the importer of record. Required for customs clearance and duty payment.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Reference Number' ;
    rdfs:comment 'Transaction reference number for the payment of customs duties and taxes. Links the customs entry to financial settlement records.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferentialTradeAgreement rdf:type rdf:Property ;
    rdfs:label 'Preferential Trade Agreement' ;
    rdfs:comment 'Name or code of the preferential trade agreement under which reduced duties are claimed. Examples include USMCA, EU-FTA, ASEAN agreements.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAuthorityCode rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority Code' ;
    rdfs:comment 'Code identifying the customs or regulatory authority responsible for processing this entry. May be port-specific or national authority code.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Release Timestamp' ;
    rdfs:comment 'Date and time when the cargo was officially released by customs for delivery or onward movement. Marks completion of customs clearance process.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:specialProgramIndicator rdf:type rdf:Property ;
    rdfs:label 'Special Program Indicator' ;
    rdfs:comment 'Code or flag indicating participation in special customs programs such as AEO (Authorized Economic Operator), C-TPAT, or bonded warehouse programs.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dangerousGoodsId rdf:type rdf:Property ;
    rdfs:label 'Dangerous Goods Id' ;
    rdfs:comment 'Primary key for dangerous_goods' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DangerousGoods .

ind:handlingEquipmentVendorId rdf:type rdf:Property ;
    rdfs:label 'Handling Equipment Vendor Id' ;
    rdfs:comment 'Foreign key linking to procurement.vendor. Business justification: Specialized DG handling equipment and certification services are procured from certified vendors. Links DG compliance to vendor qualification (EASA Part 145, FAA certification) and equipment maintenan' ;
    rdfs:domain ind:DangerousGoods ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:acceptanceCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Acceptance Certificate Number' ;
    rdfs:comment 'Reference number of the dangerous goods acceptance certificate or checklist issued upon successful acceptance inspection.' ;
    rdfs:domain ind:DangerousGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acceptanceCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Acceptance Check Status' ;
    rdfs:comment 'Result of the airline\'s dangerous goods acceptance inspection: passed (accepted for carriage), failed (rejected), pending (under review), waived (exempted).' ;
    rdfs:domain ind:DangerousGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acceptanceCheckTimestamp rdf:type rdf:Property ;
    rdfs:label 'Acceptance Check Timestamp' ;
    rdfs:comment 'Date and time when the dangerous goods acceptance check was completed by airline cargo acceptance staff.' ;
    rdfs:domain ind:DangerousGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:additionalHandlingInformation rdf:type rdf:Property ;
    rdfs:label 'Additional Handling Information' ;
    rdfs:comment 'Free-text field for supplementary handling instructions, warnings, or remarks specific to this dangerous goods shipment.' ;
    rdfs:domain ind:DangerousGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allPackedInOneFlag rdf:type rdf:Property ;
    rdfs:label 'All Packed In One Flag' ;
    rdfs:comment 'Indicates whether all dangerous goods packages covered by this declaration are contained within a single overpack or freight container.' ;
    rdfs:domain ind:DangerousGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cargoAircraftOnlyFlag rdf:type rdf:Property ;
    rdfs:label 'Cargo Aircraft Only Flag' ;
    rdfs:comment 'Indicates whether the dangerous goods are restricted to cargo aircraft only (true) or may be carried on passenger aircraft (false).' ;
    rdfs:domain ind:DangerousGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Verified Flag' ;
    rdfs:comment 'Indicates whether the dangerous goods declaration has been verified for full regulatory compliance with IATA DGR, ICAO Technical Instructions, and applicable national regulations.' ;
    rdfs:domain ind:DangerousGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dgClass rdf:type rdf:Property ;
    rdfs:label 'Dg Class' ;
    rdfs:comment 'Primary hazard class of the dangerous goods (1-9): 1=Explosives, 2=Gases, 3=Flammable Liquids, 4=Flammable Solids, 5=Oxidizing Substances, 6=Toxic and Infectious Substances, 7=Radioactive Material, 8=Corrosives, 9=Miscellaneous.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dgDivision rdf:type rdf:Property ;
    rdfs:label 'Dg Division' ;
    rdfs:comment 'Subdivision within the DG class providing further hazard classification (e.g., 2.1 for flammable gases, 6.2 for infectious substances). May be null for classes without divisions.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyContactName rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Name' ;
    rdfs:comment 'Name of the person or organization to contact in case of emergency involving the dangerous goods shipment.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossWeightPerPackageKg rdf:type rdf:Property ;
    rdfs:label 'Gross Weight Per Package Kg' ;
    rdfs:comment 'Gross weight of each package including dangerous goods and packaging material, measured in kilograms.' ;
    rdfs:domain ind:DangerousGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netQuantityPerPackage rdf:type rdf:Property ;
    rdfs:label 'Net Quantity Per Package' ;
    rdfs:comment 'Net quantity of dangerous goods per package, excluding packaging material. Unit specified in net_quantity_unit.' ;
    rdfs:domain ind:DangerousGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netQuantityUnit rdf:type rdf:Property ;
    rdfs:label 'Net Quantity Unit' ;
    rdfs:comment 'Unit of measure for net quantity: kg (kilograms), L (liters), g (grams), mL (milliliters).' ;
    rdfs:domain ind:DangerousGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberOfPackages rdf:type rdf:Property ;
    rdfs:label 'Number Of Packages' ;
    rdfs:comment 'Total count of packages containing dangerous goods within this declaration.' ;
    rdfs:domain ind:DangerousGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overpackUsedFlag rdf:type rdf:Property ;
    rdfs:label 'Overpack Used Flag' ;
    rdfs:comment 'Indicates whether an overpack (single enclosure containing one or more packages) was used for this dangerous goods shipment.' ;
    rdfs:domain ind:DangerousGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:packingGroup rdf:type rdf:Property ;
    rdfs:label 'Packing Group' ;
    rdfs:comment 'Degree of danger presented by the substance: I=Great Danger, II=Medium Danger, III=Minor Danger. Not applicable to all DG classes.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packingInstruction rdf:type rdf:Property ;
    rdfs:label 'Packing Instruction' ;
    rdfs:comment 'IATA packing instruction code specifying how the dangerous goods must be packaged for air transport (e.g., PI 965 for lithium ion batteries).' ;
    rdfs:domain ind:DangerousGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:properShippingName rdf:type rdf:Property ;
    rdfs:label 'Proper Shipping Name' ;
    rdfs:comment 'The official IATA-recognized name used to describe the dangerous goods substance or article as specified in the DGR List of Dangerous Goods.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:radioactiveCategory rdf:type rdf:Property ;
    rdfs:label 'Radioactive Category' ;
    rdfs:comment 'Category label for radioactive materials (Class 7) based on transport index and surface radiation level. Applicable only to radioactive shipments.' ;
    rdfs:domain ind:DangerousGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipperDeclarationText rdf:type rdf:Property ;
    rdfs:label 'Shipper Declaration Text' ;
    rdfs:comment 'Full text of the shipper\'s declaration certifying that the dangerous goods are properly classified, packaged, marked, labeled, and in proper condition for transport by air.' ;
    rdfs:domain ind:DangerousGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipperName rdf:type rdf:Property ;
    rdfs:label 'Shipper Name' ;
    rdfs:comment 'Name of the shipper who prepared and signed the dangerous goods declaration.' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipperSignatureDate rdf:type rdf:Property ;
    rdfs:label 'Shipper Signature Date' ;
    rdfs:comment 'Date on which the shipper signed the dangerous goods declaration, certifying compliance with IATA DGR.' ;
    rdfs:domain ind:DangerousGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:specialProvisionCodes rdf:type rdf:Property ;
    rdfs:label 'Special Provision Codes' ;
    rdfs:comment 'Comma-separated list of IATA special provision codes (e.g., A1, A2) that apply additional conditions or exemptions to the shipment.' ;
    rdfs:domain ind:DangerousGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateVariationCodes rdf:type rdf:Property ;
    rdfs:label 'State Variation Codes' ;
    rdfs:comment 'Comma-separated list of country-specific variation codes indicating deviations from IATA DGR by national civil aviation authorities.' ;
    rdfs:domain ind:DangerousGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subsidiaryRiskClass rdf:type rdf:Property ;
    rdfs:label 'Subsidiary Risk Class' ;
    rdfs:comment 'Secondary hazard class if the dangerous goods present more than one hazard. May be null if no subsidiary risk exists.' ;
    rdfs:domain ind:DangerousGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalGrossWeightKg rdf:type rdf:Property ;
    rdfs:label 'Total Gross Weight Kg' ;
    rdfs:comment 'Total gross weight of all packages containing dangerous goods in this declaration, measured in kilograms.' ;
    rdfs:domain ind:DangerousGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalNetQuantity rdf:type rdf:Property ;
    rdfs:label 'Total Net Quantity' ;
    rdfs:comment 'Total net quantity of dangerous goods across all packages in this declaration. Calculated as net_quantity_per_package multiplied by number_of_packages.' ;
    rdfs:domain ind:DangerousGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transportIndex rdf:type rdf:Property ;
    rdfs:label 'Transport Index' ;
    rdfs:comment 'Single number assigned to a package, overpack, or freight container containing radioactive material to provide control over radiation exposure. Applicable only to Class 7 DG.' ;
    rdfs:domain ind:DangerousGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unNumber rdf:type rdf:Property ;
    rdfs:label 'Un Number' ;
    rdfs:comment 'Four-digit UN identification number assigned to the dangerous substance or article. Mandatory for all DG shipments per IATA DGR.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:embargoId rdf:type rdf:Property ;
    rdfs:label 'Embargo Id' ;
    rdfs:comment 'Primary key for embargo' ;
    rdfs:domain ind:Embargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedFlightNumber rdf:type rdf:Property ;
    rdfs:label 'Affected Flight Number' ;
    rdfs:comment 'Specific flight number affected by the embargo (e.g., AA1234). Nullable if embargo applies to all flights on a route or to a station broadly.' ;
    rdfs:domain ind:Embargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedRoutePattern rdf:type rdf:Property ;
    rdfs:label 'Affected Route Pattern' ;
    rdfs:comment 'Route pattern or route group affected by the embargo (e.g., \'JFK-LHR\', \'US-EU\', \'Transatlantic\'). Nullable if embargo is station-specific or commodity-specific without route constraint.' ;
    rdfs:domain ind:Embargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Approval Required Flag' ;
    rdfs:comment 'Indicates whether override approval is required to accept cargo under this embargo. True if approval workflow must be followed; False if embargo is absolute.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dangerousGoodsClass rdf:type rdf:Property ;
    rdfs:label 'Dangerous Goods Class' ;
    rdfs:comment 'IATA Dangerous Goods Regulation (DGR) class affected by the embargo (e.g., \'Class 1 - Explosives\', \'Class 3 - Flammable Liquids\', \'Class 9 - Miscellaneous\'). Nullable if embargo does not target DG specifically.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Effective End Timestamp' ;
    rdfs:comment 'Date and time when the embargo expires and restrictions are lifted. Nullable for indefinite embargoes. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Embargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:effectiveStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Effective Start Timestamp' ;
    rdfs:comment 'Date and time when the embargo becomes effective and restrictions begin to apply. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Embargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:embargoStatus rdf:type rdf:Property ;
    rdfs:label 'Embargo Status' ;
    rdfs:comment 'Current lifecycle status of the embargo: draft (pending approval), active (in effect), suspended (temporarily paused), expired (end date reached), or cancelled (terminated before expiry).' ;
    rdfs:domain ind:Embargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:embargoType rdf:type rdf:Property ;
    rdfs:label 'Embargo Type' ;
    rdfs:comment 'Classification of the embargo defining the nature of the restriction: station closure (airport/facility closed), commodity restriction (specific goods prohibited), weight restriction (weight limits imposed), dangerous goods restriction (DG acceptance suspended), seasonal embargo (recurring seasonal restriction), or capacity embargo (capacity allocation frozen).' ;
    rdfs:domain ind:Embargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingAuthority rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority' ;
    rdfs:comment 'Name of the internal department, external regulatory body, or authority that issued the embargo (e.g., \'Cargo Operations\', \'FAA\', \'EASA\', \'Local Civil Aviation Authority\').' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationSentFlag rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Flag' ;
    rdfs:comment 'Indicates whether embargo notification has been sent to affected stations, agents, and customers. True if notification distributed; False if pending.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Notification Timestamp' ;
    rdfs:comment 'Date and time when embargo notification was distributed to stakeholders. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:overrideApprovalAuthority rdf:type rdf:Property ;
    rdfs:label 'Override Approval Authority' ;
    rdfs:comment 'Role or department authorized to approve exceptions to the embargo (e.g., \'Cargo Director\', \'Station Manager\', \'Safety Officer\'). Nullable if no override is permitted.' ;
    rdfs:domain ind:Embargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeRestrictionCbm rdf:type rdf:Property ;
    rdfs:label 'Volume Restriction Cbm' ;
    rdfs:comment 'Maximum volume in cubic meters allowed under the embargo. Nullable if embargo is not volume-based.' ;
    rdfs:domain ind:Embargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightRestrictionKg rdf:type rdf:Property ;
    rdfs:label 'Weight Restriction Kg' ;
    rdfs:comment 'Maximum weight in kilograms allowed under the embargo. Nullable if embargo is not weight-based.' ;
    rdfs:domain ind:Embargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accountManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Account Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Freight forwarders are assigned to specific cargo sales account managers for relationship management, contract negotiation, and performance monitoring. Mirrors existing shipper.account_manager_employe' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:npsSurveyId rdf:type rdf:Property ;
    rdfs:label 'Nps Survey Id' ;
    rdfs:comment 'Foreign key linking to marketing.nps_survey. Business justification: Airlines measure freight forwarder satisfaction via NPS surveys (post-shipment, quarterly relationship reviews). Linking forwarders to survey programs enables response tracking, trend analysis by acco' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NpsSurvey .

ind:accountStatus rdf:type rdf:Property ;
    rdfs:label 'Account Status' ;
    rdfs:comment 'Current operational status of the freight forwarder account with the airline: active (operational), inactive (dormant), suspended (temporarily blocked), credit_hold (financial restriction), terminated (closed).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accreditationDate rdf:type rdf:Property ;
    rdfs:label 'Accreditation Date' ;
    rdfs:comment 'Date when the freight forwarder received IATA cargo agent accreditation.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accreditationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Accreditation Expiry Date' ;
    rdfs:comment 'Date when the current IATA accreditation expires and requires renewal.' ;
    rdfs:domain ind:FreightForwarder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvedCommodityTypes rdf:type rdf:Property ;
    rdfs:label 'Approved Commodity Types' ;
    rdfs:comment 'Comma-separated list of commodity types or special cargo categories the freight forwarder is approved to handle (e.g., perishables, pharmaceuticals, live_animals, valuables, dangerous_goods). [ENUM-REF-CANDIDATE: general_cargo|perishables|pharmaceuticals|live_animals|valuables|dangerous_goods|oversized|temperature_controlled|hazmat — promote to reference product]' ;
    rdfs:domain ind:FreightForwarder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Billing Address Line1' ;
    rdfs:comment 'First line of the billing address for invoicing and financial correspondence.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Billing Address Line2' ;
    rdfs:comment 'Second line of the billing address (suite, floor, building name).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCity rdf:type rdf:Property ;
    rdfs:label 'Billing City' ;
    rdfs:comment 'City name for the billing address.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Billing Country Code' ;
    rdfs:comment 'Three-letter ISO country code for the billing address country.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingPostalCode rdf:type rdf:Property ;
    rdfs:label 'Billing Postal Code' ;
    rdfs:comment 'Postal or ZIP code for the billing address.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingStateProvince rdf:type rdf:Property ;
    rdfs:label 'Billing State Province' ;
    rdfs:comment 'State, province, or region for the billing address.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bspParticipationFlag rdf:type rdf:Property ;
    rdfs:label 'Bsp Participation Flag' ;
    rdfs:comment 'Indicates whether the freight forwarder participates in IATA BSP for passenger ticket settlement (some cargo agents also handle passenger bookings). True if participating, False otherwise.' ;
    rdfs:domain ind:FreightForwarder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:businessRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Business Registration Number' ;
    rdfs:comment 'Official business or company registration number issued by the local government authority.' ;
    rdfs:domain ind:FreightForwarder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cassNumber rdf:type rdf:Property ;
    rdfs:label 'Cass Number' ;
    rdfs:comment 'Unique identifier assigned within the IATA CASS billing and settlement system for cargo transactions.' ;
    rdfs:domain ind:FreightForwarder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cassParticipationFlag rdf:type rdf:Property ;
    rdfs:label 'Cass Participation Flag' ;
    rdfs:comment 'Indicates whether the freight forwarder participates in IATA CASS for cargo billing settlement. True if participating, False otherwise.' ;
    rdfs:domain ind:FreightForwarder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractEndDate rdf:type rdf:Property ;
    rdfs:label 'Contract End Date' ;
    rdfs:comment 'Date when the commercial agreement with this freight forwarder expires or was terminated. Null for open-ended agreements.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractStartDate rdf:type rdf:Property ;
    rdfs:label 'Contract Start Date' ;
    rdfs:comment 'Date when the commercial agreement with this freight forwarder became effective.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Amount' ;
    rdfs:comment 'Maximum credit exposure allowed for this freight forwarder in the airline\'s base currency. Used for credit risk management.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditLimitCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the credit limit amount.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dgCertificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Dg Certification Expiry Date' ;
    rdfs:comment 'Expiration date of the dangerous goods handling certification.' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dgCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Dg Certification Number' ;
    rdfs:comment 'Certification number or reference for dangerous goods handling authorization.' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dgHandlingCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Dg Handling Certified Flag' ;
    rdfs:comment 'Indicates whether the freight forwarder is certified to handle dangerous goods shipments per IATA DGR. True if certified, False otherwise.' ;
    rdfs:domain ind:FreightForwarder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:forwarderType rdf:type rdf:Property ;
    rdfs:label 'Forwarder Type' ;
    rdfs:comment 'Classification of the freight forwarder business model: direct_agent (direct cargo agent), consolidator (consolidates shipments), gsa (general sales agent), broker (intermediary), nvocc (non-vessel operating common carrier), integrated_logistics (full-service logistics provider).' ;
    rdfs:domain ind:FreightForwarder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iataAccreditationStatus rdf:type rdf:Property ;
    rdfs:label 'Iata Accreditation Status' ;
    rdfs:comment 'Current accreditation status with IATA Cargo Agency Program: accredited (full accreditation), provisional (temporary accreditation), suspended (temporarily suspended), revoked (accreditation removed), not_accredited (no IATA accreditation).' ;
    rdfs:domain ind:FreightForwarder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iataCargoAgentCode rdf:type rdf:Property ;
    rdfs:label 'Iata Cargo Agent Code' ;
    rdfs:comment 'Seven or eight-digit numeric code assigned by IATA to identify accredited cargo agents globally. Primary business identifier for cargo commercial partners.' ;
    rdfs:domain ind:FreightForwarder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalName rdf:type rdf:Property ;
    rdfs:label 'Legal Name' ;
    rdfs:comment 'Full legal registered name of the freight forwarding company or cargo agent as registered with local authorities.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermsDays rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Days' ;
    rdfs:comment 'Number of days allowed for payment after invoice date (e.g., 30 for Net 30 terms).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stationCoverage rdf:type rdf:Property ;
    rdfs:label 'Station Coverage' ;
    rdfs:comment 'Comma-separated list of three-letter IATA airport codes where the freight forwarder has operational presence or coverage.' ;
    rdfs:domain ind:FreightForwarder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxIdentificationNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Identification Number' ;
    rdfs:comment 'Tax identification number (TIN, VAT number, or equivalent) for the freight forwarder in their country of registration.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeName rdf:type rdf:Property ;
    rdfs:label 'Trade Name' ;
    rdfs:comment 'Operating or trade name used by the freight forwarder in commercial transactions, may differ from legal name.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:websiteUrl rdf:type rdf:Property ;
    rdfs:label 'Website Url' ;
    rdfs:comment 'Official website URL of the freight forwarder company.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightRateId rdf:type rdf:Property ;
    rdfs:label 'Freight Rate Id' ;
    rdfs:comment 'Unique identifier for the freight rate record. Primary key for the freight rate master data.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dangerousGoodsApplicable rdf:type rdf:Property ;
    rdfs:label 'Dangerous Goods Applicable' ;
    rdfs:comment 'Indicates whether this rate applies to dangerous goods shipments requiring special handling and documentation per IATA DGR.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:effectiveFromDate rdf:type rdf:Property ;
    rdfs:label 'Effective From Date' ;
    rdfs:comment 'Date when this freight rate becomes valid and can be applied to bookings. Part of the rate validity period.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveToDate rdf:type rdf:Property ;
    rdfs:label 'Effective To Date' ;
    rdfs:comment 'Date when this freight rate expires and can no longer be applied to new bookings. Null indicates open-ended validity.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:interlinePartnerCode rdf:type rdf:Property ;
    rdfs:label 'Interline Partner Code' ;
    rdfs:comment 'IATA two or three-letter airline code of the interline partner carrier for revenue proration. Applicable when rate_type is INTERLINE_PRORATE.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumCharge rdf:type rdf:Property ;
    rdfs:label 'Minimum Charge' ;
    rdfs:comment 'Minimum freight charge that applies regardless of weight. Ensures revenue floor for small shipments.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prorationPercentage rdf:type rdf:Property ;
    rdfs:label 'Proration Percentage' ;
    rdfs:comment 'Percentage of total freight revenue allocated to this carrier segment in interline operations. Used when proration_method is AGREED_PERCENTAGE.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateApprovalAuthority rdf:type rdf:Property ;
    rdfs:label 'Rate Approval Authority' ;
    rdfs:comment 'Name or identifier of the authority or department that approved this freight rate (e.g., Revenue Management, Pricing Committee, IATA CSC).' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCode rdf:type rdf:Property ;
    rdfs:label 'Rate Code' ;
    rdfs:comment 'Unique business identifier for the freight rate. Used in Mercator rating engine and TACT publications.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratePublicationDate rdf:type rdf:Property ;
    rdfs:label 'Rate Publication Date' ;
    rdfs:comment 'Date when this rate was officially published or filed with regulatory authorities or IATA TACT.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rateSource rdf:type rdf:Property ;
    rdfs:label 'Rate Source' ;
    rdfs:comment 'Origin of the freight rate. TACT (The Air Cargo Tariff published rate), BILATERAL_AGREEMENT (negotiated carrier-to-carrier), SPOT_RATE (one-time negotiated rate), INTERLINE (multi-carrier agreement), CONTRACT (shipper contract rate), MARKET_RATE (dynamic market-based pricing).' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateStatus rdf:type rdf:Property ;
    rdfs:label 'Rate Status' ;
    rdfs:comment 'Current lifecycle status of the freight rate. ACTIVE (in use), INACTIVE (not available), PENDING (awaiting approval), EXPIRED (past effective_to_date), SUSPENDED (temporarily disabled).' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateType rdf:type rdf:Property ;
    rdfs:label 'Rate Type' ;
    rdfs:comment 'Classification of the freight rate. GCR (General Cargo Rate) applies to standard shipments, SCR (Specific Commodity Rate) applies to designated commodities, CLASS_RATE applies to rate classes, ULD_RATE applies to unit load devices, IATA_TARIFF applies to published IATA rates, SURCHARGE applies to additional charges, INTERLINE_PRORATE applies to revenue sharing between carriers. [ENUM-REF-CANDIDATE: GCR|SCR|CLASS_RATE|ULD_RATE|IATA_TARIFF|SURCHARGE|INTERLINE_PRORATE — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingRestriction rdf:type rdf:Property ;
    rdfs:label 'Routing Restriction' ;
    rdfs:comment 'Routing constraints or requirements for this rate to apply. May specify required connection points, prohibited routings, or carrier restrictions.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementReference rdf:type rdf:Property ;
    rdfs:label 'Settlement Reference' ;
    rdfs:comment 'Reference identifier for IATA Cargo Accounts Settlement Systems (CASS) or bilateral settlement agreement. Used for interline revenue reconciliation.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surchargeCalculationBasis rdf:type rdf:Property ;
    rdfs:label 'Surcharge Calculation Basis' ;
    rdfs:comment 'Method for calculating surcharge amount. PERCENTAGE (percent of base freight), FLAT_AMOUNT (fixed charge), PER_KG (per kilogram), PER_SHIPMENT (per AWB).' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surchargeType rdf:type rdf:Property ;
    rdfs:label 'Surcharge Type' ;
    rdfs:comment 'Type of surcharge if rate_type is SURCHARGE. FSC (Fuel Surcharge), SSC (Security Surcharge), HANDLING (special handling), DG (Dangerous Goods), OVERSIZE (oversized cargo), REMOTE_AREA (remote destination), CAF (Currency Adjustment Factor), NONE (not a surcharge). [ENUM-REF-CANDIDATE: FSC|SSC|HANDLING|DG|OVERSIZE|REMOTE_AREA|CAF|NONE — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surchargeValue rdf:type rdf:Property ;
    rdfs:label 'Surcharge Value' ;
    rdfs:comment 'Numeric value for surcharge calculation. Interpretation depends on surcharge_calculation_basis (e.g., 15.5 for 15.5% or 15.5 currency units).' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightBreakLowerKg rdf:type rdf:Property ;
    rdfs:label 'Weight Break Lower Kg' ;
    rdfs:comment 'Lower weight threshold in kilograms for this rate tier. Rates typically decrease as shipment weight increases through defined break points.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightBreakUpperKg rdf:type rdf:Property ;
    rdfs:label 'Weight Break Upper Kg' ;
    rdfs:comment 'Upper weight threshold in kilograms for this rate tier. Null indicates no upper limit (open-ended tier).' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interlineCargoId rdf:type rdf:Property ;
    rdfs:label 'Interline Cargo Id' ;
    rdfs:comment 'Unique identifier for the interline cargo agreement record.' ;
    rdfs:domain ind:InterlineCargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:interlineBillingId rdf:type rdf:Property ;
    rdfs:label 'Interline Billing Id' ;
    rdfs:comment 'Foreign key linking to finance.interline_billing. Business justification: Interline cargo segments generate proration billing entries for settlement with partner airlines. Essential for IATA interline billing, CASS settlement, and partner revenue reconciliation.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InterlineBilling .

ind:segmentOriginStationId rdf:type rdf:Property ;
    rdfs:label 'Segment Origin Station Id' ;
    rdfs:comment 'Foreign key linking to airport.station. Business justification: Interline segments track segment_origin_station_code for transfer. Station link provides transfer infrastructure, ground handler, minimum connect time, and customs capability for proration and settlem' ;
    rdfs:domain ind:InterlineCargo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Station .

ind:agreementStatus rdf:type rdf:Property ;
    rdfs:label 'Agreement Status' ;
    rdfs:comment 'Current lifecycle status of the interline cargo agreement governing this shipment.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cassSettlementReference rdf:type rdf:Property ;
    rdfs:label 'Cass Settlement Reference' ;
    rdfs:comment 'Reference number linking this interline cargo record to the IATA CASS settlement transaction for inter-carrier billing.' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interlineAgreementReference rdf:type rdf:Property ;
    rdfs:label 'Interline Agreement Reference' ;
    rdfs:comment 'Unique reference number of the bilateral or multilateral interline cargo agreement governing this shipment.' ;
    rdfs:domain ind:InterlineCargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interlineAwbPrefix rdf:type rdf:Property ;
    rdfs:label 'Interline Awb Prefix' ;
    rdfs:comment 'Three-digit AWB prefix assigned to the partner airline for interline cargo documentation.' ;
    rdfs:domain ind:InterlineCargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerAirlineCode rdf:type rdf:Property ;
    rdfs:label 'Partner Airline Code' ;
    rdfs:comment 'Two or three-letter IATA airline code of the partner carrier operating the interline segment.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeSegmentSequence rdf:type rdf:Property ;
    rdfs:label 'Route Segment Sequence' ;
    rdfs:comment 'Sequential order of this segment within the multi-carrier routing (1 for first segment, 2 for second, etc.).' ;
    rdfs:domain ind:InterlineCargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:segmentChargeableWeightKg rdf:type rdf:Property ;
    rdfs:label 'Segment Chargeable Weight Kg' ;
    rdfs:comment 'Chargeable weight in kilograms used for revenue calculation on this interline segment, which may differ from actual weight based on volumetric calculations.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:segmentDestinationStationCode rdf:type rdf:Property ;
    rdfs:label 'Segment Destination Station Code' ;
    rdfs:comment 'Three-letter IATA airport code for the destination of this interline segment.' ;
    rdfs:domain ind:InterlineCargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentFlightDate rdf:type rdf:Property ;
    rdfs:label 'Segment Flight Date' ;
    rdfs:comment 'Scheduled departure date of the partner airline flight carrying this interline cargo segment.' ;
    rdfs:domain ind:InterlineCargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:segmentFlightNumber rdf:type rdf:Property ;
    rdfs:label 'Segment Flight Number' ;
    rdfs:comment 'Flight number operated by the partner airline for this interline cargo segment.' ;
    rdfs:domain ind:InterlineCargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentPieces rdf:type rdf:Property ;
    rdfs:label 'Segment Pieces' ;
    rdfs:comment 'Number of individual pieces or packages carried on this interline segment.' ;
    rdfs:domain ind:InterlineCargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:segmentRevenueShareAmount rdf:type rdf:Property ;
    rdfs:label 'Segment Revenue Share Amount' ;
    rdfs:comment 'Calculated revenue amount allocated to the partner airline for operating this interline segment, based on the proration method.' ;
    rdfs:domain ind:InterlineCargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:segmentRevenueShareCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Segment Revenue Share Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the segment revenue share amount.' ;
    rdfs:domain ind:InterlineCargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentVolumeCbm rdf:type rdf:Property ;
    rdfs:label 'Segment Volume Cbm' ;
    rdfs:comment 'Volume in cubic meters of cargo carried on this interline segment.' ;
    rdfs:domain ind:InterlineCargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:segmentWeightKg rdf:type rdf:Property ;
    rdfs:label 'Segment Weight Kg' ;
    rdfs:comment 'Actual or allocated weight in kilograms of cargo carried on this interline segment.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementCompletedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Settlement Completed Timestamp' ;
    rdfs:comment 'Timestamp when the interline revenue settlement for this cargo segment was finalized and funds transferred between carriers.' ;
    rdfs:domain ind:InterlineCargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:settlementCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Settlement Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code used for final interline settlement between carriers.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementPeriod rdf:type rdf:Property ;
    rdfs:label 'Settlement Period' ;
    rdfs:comment 'IATA CASS billing period identifier (typically YYYYMM format) during which this interline cargo settlement is processed.' ;
    rdfs:domain ind:InterlineCargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementSubmittedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Settlement Submitted Timestamp' ;
    rdfs:comment 'Timestamp when the interline revenue settlement for this cargo segment was submitted to IATA CASS for processing.' ;
    rdfs:domain ind:InterlineCargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:transferManifestReference rdf:type rdf:Property ;
    rdfs:label 'Transfer Manifest Reference' ;
    rdfs:comment 'Reference number of the cargo manifest documenting the transfer of cargo between carriers at the interline point.' ;
    rdfs:domain ind:InterlineCargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceId rdf:type rdf:Property ;
    rdfs:label 'Invoice Id' ;
    rdfs:comment 'Primary key for invoice' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:billedFreightForwarderId rdf:type rdf:Property ;
    rdfs:label 'Billed Freight Forwarder Id' ;
    rdfs:comment 'Foreign key linking to cargo.freight_forwarder. Business justification: Invoice has billing_party_id (BIGINT) and billing_party_type (STRING). When billing_party_type=\'FORWARDER\', this should FK to freight_forwarder. Adding billed_freight_forwarder_id as a labeled FK (nul' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FreightForwarder .

ind:billedShipperId rdf:type rdf:Property ;
    rdfs:label 'Billed Shipper Id' ;
    rdfs:comment 'Foreign key linking to cargo.shipper. Business justification: Invoice has billing_party_id (BIGINT) and billing_party_type (STRING). When billing_party_type=\'SHIPPER\', this should FK to shipper. Adding billed_shipper_id as a labeled FK (nullable, populated when ' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Shipper .

ind:billingProcessorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Billing Processor Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Cargo invoices are processed and approved by specific billing staff. Financial controls and audit trail requirement - must track who generated and approved the invoice for SOX compliance and dispute r' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:awbCount rdf:type rdf:Property ;
    rdfs:label 'Awb Count' ;
    rdfs:comment 'Number of distinct AWBs included in this invoice. Used for consolidated billing and reconciliation.' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:billingPartyAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Billing Party Account Number' ;
    rdfs:comment 'Customer account number or IATA CASS agent code of the billing party. Used for account reconciliation and settlement.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingPartyName rdf:type rdf:Property ;
    rdfs:label 'Billing Party Name' ;
    rdfs:comment 'Legal name of the party being billed. Captured for invoice presentation and audit trail.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingPartyType rdf:type rdf:Property ;
    rdfs:label 'Billing Party Type' ;
    rdfs:comment 'Type of party being billed: freight forwarder (consolidator), shipper (consignor), consignee (receiver), agent (GSA/handling agent), airline (interline partner), or broker.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cassPeriod rdf:type rdf:Property ;
    rdfs:label 'Cass Period' ;
    rdfs:comment 'IATA CASS billing period in YYYY-MM format (e.g., 2024-03). Used for settlement cycle reconciliation.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsClearanceFee rdf:type rdf:Property ;
    rdfs:label 'Customs Clearance Fee' ;
    rdfs:comment 'Fee for customs clearance services provided by the airline or handling agent.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dgSurcharge rdf:type rdf:Property ;
    rdfs:label 'Dg Surcharge' ;
    rdfs:comment 'Surcharge for handling dangerous goods (DG) shipments requiring special handling, documentation, and compliance with IATA DGR.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dueDate rdf:type rdf:Property ;
    rdfs:label 'Due Date' ;
    rdfs:comment 'Date by which payment is expected from the billing party. Determines overdue status.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:freightChargeCollect rdf:type rdf:Property ;
    rdfs:label 'Freight Charge Collect' ;
    rdfs:comment 'Total freight charges to be collected from the consignee at destination. Excludes prepaid charges.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightChargePrepaid rdf:type rdf:Property ;
    rdfs:label 'Freight Charge Prepaid' ;
    rdfs:comment 'Total freight charges paid by the shipper at origin. Excludes collect charges.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelSurcharge rdf:type rdf:Property ;
    rdfs:label 'Fuel Surcharge' ;
    rdfs:comment 'Fuel surcharge applied to the shipment to offset variable fuel costs. Typically calculated as a percentage of freight charges.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:handlingFee rdf:type rdf:Property ;
    rdfs:label 'Handling Fee' ;
    rdfs:comment 'Ground handling and terminal processing fees for cargo acceptance, storage, and delivery.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceDate rdf:type rdf:Property ;
    rdfs:label 'Invoice Date' ;
    rdfs:comment 'Date the invoice was issued to the billing party. Principal business event timestamp for the invoice.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:invoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Invoice Number' ;
    rdfs:comment 'Externally-known unique invoice number issued to the billing party. Business identifier for the invoice.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceStatus rdf:type rdf:Property ;
    rdfs:label 'Invoice Status' ;
    rdfs:comment 'Current lifecycle status of the invoice: draft (not yet issued), issued (finalized), sent (transmitted to billing party), partially_paid, paid (fully settled), overdue (past due date), cancelled, or disputed (under review). [ENUM-REF-CANDIDATE: draft|issued|sent|partially_paid|paid|overdue|cancelled|disputed — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceType rdf:type rdf:Property ;
    rdfs:label 'Invoice Type' ;
    rdfs:comment 'Type of invoice document: standard invoice, credit note (refund/reversal), debit note (additional charges), proforma (advance estimate), adjustment (correction), or supplementary (additional billing).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otherCharges rdf:type rdf:Property ;
    rdfs:label 'Other Charges' ;
    rdfs:comment 'Miscellaneous charges not categorized under standard surcharge types (e.g., documentation fees, special service requests).' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oversizeSurcharge rdf:type rdf:Property ;
    rdfs:label 'Oversize Surcharge' ;
    rdfs:comment 'Surcharge for oversized or non-standard cargo requiring special handling or equipment.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentTerms rdf:type rdf:Property ;
    rdfs:label 'Payment Terms' ;
    rdfs:comment 'Payment terms agreed with the billing party: net_7 (7 days), net_15, net_30, net_45, net_60, due_on_receipt, prepaid, or COD (cash on delivery). [ENUM-REF-CANDIDATE: net_7|net_15|net_30|net_45|net_60|due_on_receipt|prepaid|cod — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securitySurcharge rdf:type rdf:Property ;
    rdfs:label 'Security Surcharge' ;
    rdfs:comment 'Security surcharge for cargo screening and security compliance (TSA, EASA requirements).' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageFee rdf:type rdf:Property ;
    rdfs:label 'Storage Fee' ;
    rdfs:comment 'Warehouse storage fees for cargo held beyond free storage period.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:loadPlanId rdf:type rdf:Property ;
    rdfs:label 'Load Plan Id' ;
    rdfs:comment 'Primary key for load_plan' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LoadPlan .

ind:fuelUpliftOrderId rdf:type rdf:Property ;
    rdfs:label 'Fuel Uplift Order Id' ;
    rdfs:comment 'Foreign key linking to procurement.fuel_uplift_order. Business justification: Load plan finalization (actual zero fuel weight, CG) triggers final fuel uplift order adjustments. Critical for fuel cost allocation accuracy and weight-based fuel consumption variance reporting.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FuelUpliftOrder .

ind:loadmasterEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Loadmaster Employee Id' ;
    rdfs:comment 'Employee identifier of the loadmaster who prepared and signed off on this load plan.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualTakeoffWeightKg rdf:type rdf:Property ;
    rdfs:label 'Actual Takeoff Weight Kg' ;
    rdfs:comment 'Actual calculated takeoff weight for this flight including zero fuel weight plus fuel load. Must not exceed maximum takeoff weight.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualZeroFuelWeightKg rdf:type rdf:Property ;
    rdfs:label 'Actual Zero Fuel Weight Kg' ;
    rdfs:comment 'Actual calculated zero fuel weight for this flight including passengers, baggage, cargo, and crew. Must not exceed maximum zero fuel weight.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:aftHoldWeightKg rdf:type rdf:Property ;
    rdfs:label 'Aft Hold Weight Kg' ;
    rdfs:comment 'Weight of cargo loaded in the aft cargo hold in kilograms. Critical for center of gravity calculation.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:arrivalStation rdf:type rdf:Property ;
    rdfs:label 'Arrival Station' ;
    rdfs:comment 'Three-letter IATA airport code for the arrival station (e.g., LAX, CDG).' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bulkHoldWeightKg rdf:type rdf:Property ;
    rdfs:label 'Bulk Hold Weight Kg' ;
    rdfs:comment 'Weight of loose cargo loaded in the bulk cargo hold in kilograms. Typically used for non-containerized shipments.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cargoCenterOfGravityMacPercent rdf:type rdf:Property ;
    rdfs:label 'Cargo Center Of Gravity Mac Percent' ;
    rdfs:comment 'Cargo contribution to the aircraft center of gravity expressed as a percentage of Mean Aerodynamic Chord (MAC). Critical for flight safety and trim calculation.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cargoVolumeCubicMeters rdf:type rdf:Property ;
    rdfs:label 'Cargo Volume Cubic Meters' ;
    rdfs:comment 'Total volume of cargo loaded in cubic meters. Used for volumetric capacity utilization analysis alongside weight.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dangerousGoodsOnboardFlag rdf:type rdf:Property ;
    rdfs:label 'Dangerous Goods Onboard Flag' ;
    rdfs:comment 'Indicates whether dangerous goods (hazardous materials) are included in the cargo load. Triggers additional handling and notification requirements.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:departureStation rdf:type rdf:Property ;
    rdfs:label 'Departure Station' ;
    rdfs:comment 'Three-letter IATA airport code for the departure station (e.g., JFK, LHR). Used for station-specific cargo handling rules.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatchReleaseFlag rdf:type rdf:Property ;
    rdfs:label 'Dispatch Release Flag' ;
    rdfs:comment 'Indicates whether the flight dispatcher has released the flight for departure based on this load plan. True indicates dispatch approval granted.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:forwardHoldWeightKg rdf:type rdf:Property ;
    rdfs:label 'Forward Hold Weight Kg' ;
    rdfs:comment 'Weight of cargo loaded in the forward cargo hold in kilograms. Critical for center of gravity calculation.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:loadFactorPercent rdf:type rdf:Property ;
    rdfs:label 'Load Factor Percent' ;
    rdfs:comment 'Percentage of available cargo capacity utilized on this flight, calculated as actual cargo weight divided by available cargo capacity.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:loadPlanStatus rdf:type rdf:Property ;
    rdfs:label 'Load Plan Status' ;
    rdfs:comment 'Current lifecycle status of the load plan. Draft indicates planning in progress; final indicates approved for dispatch; closed indicates flight departed.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadSheetReference rdf:type rdf:Property ;
    rdfs:label 'Load Sheet Reference' ;
    rdfs:comment 'Reference number of the official load sheet document generated for this flight. Links to the regulatory load and trim sheet.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadmasterSignoffTimestamp rdf:type rdf:Property ;
    rdfs:label 'Loadmaster Signoff Timestamp' ;
    rdfs:comment 'Date and time when the loadmaster signed off on the load plan, certifying accuracy and compliance. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:maximumLandingWeightKg rdf:type rdf:Property ;
    rdfs:label 'Maximum Landing Weight Kg' ;
    rdfs:comment 'Maximum allowable landing weight for the destination airport based on aircraft structural limits and runway conditions.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumTakeoffWeightKg rdf:type rdf:Property ;
    rdfs:label 'Maximum Takeoff Weight Kg' ;
    rdfs:comment 'Maximum allowable takeoff weight for this flight based on aircraft performance, runway length, weather, and regulatory limits.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumZeroFuelWeightKg rdf:type rdf:Property ;
    rdfs:label 'Maximum Zero Fuel Weight Kg' ;
    rdfs:comment 'Maximum allowable weight of the aircraft without fuel for this flight, based on aircraft type and configuration. Regulatory limit for structural integrity.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedLandingWeightKg rdf:type rdf:Property ;
    rdfs:label 'Planned Landing Weight Kg' ;
    rdfs:comment 'Planned landing weight at destination calculated as takeoff weight minus planned fuel burn. Must not exceed maximum landing weight.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Flag' ;
    rdfs:comment 'Indicates whether this load plan meets all regulatory weight and balance requirements. False indicates out-of-limits condition requiring corrective action.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specialLoadFlag rdf:type rdf:Property ;
    rdfs:label 'Special Load Flag' ;
    rdfs:comment 'Indicates whether the cargo includes special loads requiring non-standard handling (e.g., live animals, human remains, valuable cargo, oversized items).' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalCargoWeightKg rdf:type rdf:Property ;
    rdfs:label 'Total Cargo Weight Kg' ;
    rdfs:comment 'Total weight of all cargo loaded on the flight in kilograms, including belly cargo and ULDs. Excludes passenger baggage.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trimAdjustmentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Trim Adjustment Required Flag' ;
    rdfs:comment 'Indicates whether trim adjustment is required due to cargo loading. True if cargo distribution requires stabilizer trim beyond normal range.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:manifestId rdf:type rdf:Property ;
    rdfs:label 'Manifest Id' ;
    rdfs:comment 'Primary key for manifest' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Manifest .

ind:dangerousGoodsIncidentId rdf:type rdf:Property ;
    rdfs:label 'Dangerous Goods Incident Id' ;
    rdfs:comment 'Foreign key linking to safety.dangerous_goods_incident. Business justification: Flight manifests must reference dangerous goods incidents for regulatory reporting (ICAO Annex 18), load planning corrections, and crew notification. Essential for tracking which flights were affected' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DangerousGoodsIncident .

ind:preparerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Preparer Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Cargo manifests are prepared by specific cargo operations staff. Regulatory requirement for customs and security - must track who compiled the manifest. Accountability for manifest accuracy and comple' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:amendedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Amended Timestamp' ;
    rdfs:comment 'Date and time when the manifest was amended post-departure to correct discrepancies or add late-loaded cargo information.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:consigneeCount rdf:type rdf:Property ;
    rdfs:label 'Consignee Count' ;
    rdfs:comment 'Total number of distinct consignees (receivers) represented across all AWBs on this manifest.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:customsClearanceTimestamp rdf:type rdf:Property ;
    rdfs:label 'Customs Clearance Timestamp' ;
    rdfs:comment 'Date and time when customs authority granted clearance for the cargo on this manifest.' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:customsDeclarationReference rdf:type rdf:Property ;
    rdfs:label 'Customs Declaration Reference' ;
    rdfs:comment 'Reference number assigned by customs authority upon submission of the manifest for clearance and regulatory compliance.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsSubmissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Customs Submission Timestamp' ;
    rdfs:comment 'Date and time when the manifest was electronically transmitted to the destination customs authority for advance cargo declaration.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:finalizedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Finalized Timestamp' ;
    rdfs:comment 'Date and time when the manifest was locked and finalized prior to flight departure, after which no further changes are permitted without amendment.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:liveAnimalsIndicator rdf:type rdf:Property ;
    rdfs:label 'Live Animals Indicator' ;
    rdfs:comment 'Flag indicating whether this manifest includes any shipments of live animals requiring special care and regulatory compliance.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mailIndicator rdf:type rdf:Property ;
    rdfs:label 'Mail Indicator' ;
    rdfs:comment 'Flag indicating whether this manifest includes postal mail shipments governed by Universal Postal Union regulations.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:manifestNumber rdf:type rdf:Property ;
    rdfs:label 'Manifest Number' ;
    rdfs:comment 'Externally-known unique manifest document number assigned by the cargo system for regulatory and operational tracking.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manifestStatus rdf:type rdf:Property ;
    rdfs:label 'Manifest Status' ;
    rdfs:comment 'Current lifecycle status of the cargo manifest. Preliminary indicates draft; final indicates locked for departure; amended indicates post-departure correction; submitted indicates transmitted to customs.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationType rdf:type rdf:Property ;
    rdfs:label 'Operation Type' ;
    rdfs:comment 'Indicates whether cargo is carried on a dedicated freighter aircraft, in the belly hold of a passenger aircraft, or on a combi (mixed passenger/cargo) configuration.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:perishablesIndicator rdf:type rdf:Property ;
    rdfs:label 'Perishables Indicator' ;
    rdfs:comment 'Flag indicating whether this manifest includes perishable cargo (e.g., fresh produce, pharmaceuticals) requiring temperature-controlled handling.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shipperCount rdf:type rdf:Property ;
    rdfs:label 'Shipper Count' ;
    rdfs:comment 'Total number of distinct shippers (consignors) represented across all AWBs on this manifest.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalChargeableWeightKg rdf:type rdf:Property ;
    rdfs:label 'Total Chargeable Weight Kg' ;
    rdfs:comment 'Total chargeable weight in kilograms used for revenue calculation, which is the greater of actual weight or volumetric weight across all AWBs.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDeclaredValueUsd rdf:type rdf:Property ;
    rdfs:label 'Total Declared Value Usd' ;
    rdfs:comment 'Total declared value for customs and insurance purposes across all AWBs on this manifest, expressed in US dollars.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPieces rdf:type rdf:Property ;
    rdfs:label 'Total Pieces' ;
    rdfs:comment 'Total count of individual cargo pieces (packages, cartons, pallets) loaded on this flight across all AWBs.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalVolumeCbm rdf:type rdf:Property ;
    rdfs:label 'Total Volume Cbm' ;
    rdfs:comment 'Total volume of all cargo loaded on this flight in cubic meters, used for capacity planning and dimensional analysis.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalWeightKg rdf:type rdf:Property ;
    rdfs:label 'Total Weight Kg' ;
    rdfs:comment 'Total actual gross weight of all cargo loaded on this flight in kilograms, used for weight and balance calculations.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transitCargoIndicator rdf:type rdf:Property ;
    rdfs:label 'Transit Cargo Indicator' ;
    rdfs:comment 'Flag indicating whether this manifest includes transit cargo that will continue on a connecting flight rather than being delivered at the destination airport.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:valuableCargoIndicator rdf:type rdf:Property ;
    rdfs:label 'Valuable Cargo Indicator' ;
    rdfs:comment 'Flag indicating whether this manifest includes high-value cargo requiring enhanced security and handling procedures.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:securityScreeningId rdf:type rdf:Property ;
    rdfs:label 'Security Screening Id' ;
    rdfs:comment 'Unique identifier for the cargo security screening record. Primary key for the security screening entity.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SecurityScreening .

ind:screenerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Screener Employee Id' ;
    rdfs:comment 'Employee identifier of the individual who performed the screening. Required for accountability and audit trail.' ;
    rdfs:domain ind:SecurityScreening ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:screeningLocationStationId rdf:type rdf:Property ;
    rdfs:label 'Screening Location Station Id' ;
    rdfs:comment 'Foreign key linking to airport.station. Business justification: Security screening tracks screening_location_code for compliance. Station link provides regulatory authority, equipment certification, screener certification requirements, and reporting obligations fo' ;
    rdfs:domain ind:SecurityScreening ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Station .

ind:screeningVendorId rdf:type rdf:Property ;
    rdfs:label 'Screening Vendor Id' ;
    rdfs:comment 'Foreign key linking to procurement.vendor. Business justification: Security screening services and equipment are procured from certified vendors (regulated agents). Links screening compliance to vendor certification tracking and service-level agreement monitoring.' ;
    rdfs:domain ind:SecurityScreening ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:shipmentId rdf:type rdf:Property ;
    rdfs:label 'Shipment Id' ;
    rdfs:comment 'Reference to the shipment record associated with this screening event.' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Shipment .

ind:acceptanceStationCode rdf:type rdf:Property ;
    rdfs:label 'Acceptance Station Code' ;
    rdfs:comment 'Three-letter IATA code of the station where the cargo was accepted after screening.' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alarmReason rdf:type rdf:Property ;
    rdfs:label 'Alarm Reason' ;
    rdfs:comment 'Detailed description of why the screening resulted in an alarm. Confidential security information used for investigation and resolution.' ;
    rdfs:domain ind:SecurityScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chainOfCustodyVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Chain Of Custody Verified Flag' ;
    rdfs:comment 'Indicates whether the secure chain of custody has been verified from screening through to loading. Critical for security compliance.' ;
    rdfs:domain ind:SecurityScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dangerousGoodsFlag rdf:type rdf:Property ;
    rdfs:label 'Dangerous Goods Flag' ;
    rdfs:comment 'Indicates whether the piece contains dangerous goods, requiring specialized screening procedures and handling.' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:equipmentCalibrationDate rdf:type rdf:Property ;
    rdfs:label 'Equipment Calibration Date' ;
    rdfs:comment 'Date when the screening equipment was last calibrated. Ensures equipment accuracy and regulatory compliance.' ;
    rdfs:domain ind:SecurityScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:knownConsignorFlag rdf:type rdf:Property ;
    rdfs:label 'Known Consignor Flag' ;
    rdfs:comment 'Indicates whether the shipper holds Known Consignor status, allowing exemption from certain screening requirements under EU ACC3 regulations.' ;
    rdfs:domain ind:SecurityScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:knownConsignorReference rdf:type rdf:Property ;
    rdfs:label 'Known Consignor Reference' ;
    rdfs:comment 'Reference number or certification identifier for the Known Consignor status, if applicable.' ;
    rdfs:domain ind:SecurityScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pieceDimensionsCm rdf:type rdf:Property ;
    rdfs:label 'Piece Dimensions Cm' ;
    rdfs:comment 'Dimensions of the piece in centimeters, typically formatted as length x width x height. Used to determine screening equipment compatibility.' ;
    rdfs:domain ind:SecurityScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pieceNumber rdf:type rdf:Property ;
    rdfs:label 'Piece Number' ;
    rdfs:comment 'Sequential piece number within the shipment being screened. Enables piece-level screening tracking for multi-piece shipments.' ;
    rdfs:domain ind:SecurityScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pieceWeightKg rdf:type rdf:Property ;
    rdfs:label 'Piece Weight Kg' ;
    rdfs:comment 'Weight of the individual piece being screened, in kilograms. Used for screening method determination and capacity planning.' ;
    rdfs:domain ind:SecurityScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatedAgentFlag rdf:type rdf:Property ;
    rdfs:label 'Regulated Agent Flag' ;
    rdfs:comment 'Indicates whether the cargo was accepted from a Regulated Agent (RA3) who has performed screening on behalf of the airline.' ;
    rdfs:domain ind:SecurityScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatedAgentReference rdf:type rdf:Property ;
    rdfs:label 'Regulated Agent Reference' ;
    rdfs:comment 'Certification or approval number of the Regulated Agent who performed the screening.' ;
    rdfs:domain ind:SecurityScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorySubmissionReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Reference' ;
    rdfs:comment 'Reference number or confirmation code from the regulatory authority submission system.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorySubmissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Timestamp' ;
    rdfs:comment 'Date and time when screening data was submitted to the regulatory authority for compliance reporting.' ;
    rdfs:domain ind:SecurityScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:resolutionAction rdf:type rdf:Property ;
    rdfs:label 'Resolution Action' ;
    rdfs:comment 'Action taken to resolve an alarm or inconclusive screening result. Documents the follow-up process for non-clear screening outcomes.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionNotes rdf:type rdf:Property ;
    rdfs:label 'Resolution Notes' ;
    rdfs:comment 'Detailed notes documenting the resolution process for screening alarms or issues. Confidential security information.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Resolution Timestamp' ;
    rdfs:comment 'Date and time when the screening alarm or issue was resolved. Tracks time-to-resolution for operational performance.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:screenerCertificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Screener Certification Expiry Date' ;
    rdfs:comment 'Expiration date of the screener\'s security certification. Must be valid at time of screening for regulatory compliance.' ;
    rdfs:domain ind:SecurityScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:screenerCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Screener Certification Number' ;
    rdfs:comment 'Certification or license number of the screener, verifying their authorization to perform cargo security screening.' ;
    rdfs:domain ind:SecurityScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screenerName rdf:type rdf:Property ;
    rdfs:label 'Screener Name' ;
    rdfs:comment 'Full name of the certified screener who performed the security inspection.' ;
    rdfs:domain ind:SecurityScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningEquipmentCode rdf:type rdf:Property ;
    rdfs:label 'Screening Equipment Code' ;
    rdfs:comment 'Unique identifier of the screening equipment used (X-ray machine, ETD device, etc.). Required for equipment calibration and maintenance audit trail.' ;
    rdfs:domain ind:SecurityScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningExemptionReason rdf:type rdf:Property ;
    rdfs:label 'Screening Exemption Reason' ;
    rdfs:comment 'Detailed justification for any screening exemption applied, including regulatory basis and authorization reference.' ;
    rdfs:domain ind:SecurityScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningMethod rdf:type rdf:Property ;
    rdfs:label 'Screening Method' ;
    rdfs:comment 'The primary method used to screen the cargo. X-ray for radiographic inspection, ETD for Explosive Trace Detection, physical inspection for manual examination, canine for sniffer dog detection, known consignor for exemption based on shipper status, regulated agent for RA3 certification, multi-method for combination approach. [ENUM-REF-CANDIDATE: x-ray|etd|physical_inspection|canine|known_consignor|regulated_agent|multi-method — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SecurityScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningResult rdf:type rdf:Property ;
    rdfs:label 'Screening Result' ;
    rdfs:comment 'Final determination of the screening process. Passed indicates no threat detected, failed indicates threat or non-compliance, inconclusive requires additional screening, exempted indicates regulatory exemption applied.' ;
    rdfs:domain ind:SecurityScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningStatus rdf:type rdf:Property ;
    rdfs:label 'Screening Status' ;
    rdfs:comment 'Current status of the security screening process for this piece. Clear indicates passed screening, alarm indicates potential threat detected, re-screen required indicates inconclusive result, exempted indicates known consignor exemption applied.' ;
    rdfs:domain ind:SecurityScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningTimestamp rdf:type rdf:Property ;
    rdfs:label 'Screening Timestamp' ;
    rdfs:comment 'Date and time when the security screening was performed. Critical for chain-of-custody and regulatory compliance documentation.' ;
    rdfs:domain ind:SecurityScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:securityStatusCode rdf:type rdf:Property ;
    rdfs:label 'Security Status Code' ;
    rdfs:comment 'Standardized security status code for cargo. SPX (Screened to Passenger Aircraft Standard), SCO (Screened Cargo), SHR (Secure Chain of Custody), NSC (Not Screened Cargo), EXM (Exempted).' ;
    rdfs:domain ind:SecurityScreening ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acceptanceCutoffHours rdf:type rdf:Property ;
    rdfs:label 'Acceptance Cutoff Hours' ;
    rdfs:comment 'Number of hours before scheduled departure by which cargo must be physically accepted at the origin station. Critical for operational planning and customer communication.' ;
    rdfs:domain ind:ServiceProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicableSurcharges rdf:type rdf:Property ;
    rdfs:label 'Applicable Surcharges' ;
    rdfs:comment 'Comma-separated list of surcharge codes that apply to this product (e.g., fuel surcharge, security surcharge, peak season surcharge). Used for rate calculation and billing.' ;
    rdfs:domain ind:ServiceProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookingLeadTimeHours rdf:type rdf:Property ;
    rdfs:label 'Booking Lead Time Hours' ;
    rdfs:comment 'Minimum advance booking time required before scheduled departure, measured in hours. Used to enforce operational cutoff times and capacity planning windows.' ;
    rdfs:domain ind:ServiceProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dangerousGoodsAccepted rdf:type rdf:Property ;
    rdfs:label 'Dangerous Goods Accepted' ;
    rdfs:comment 'Flag indicating whether this product accepts dangerous goods shipments. Determines whether DG declarations and certifications are required for bookings.' ;
    rdfs:domain ind:ServiceProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:destinationRegionRestriction rdf:type rdf:Property ;
    rdfs:label 'Destination Region Restriction' ;
    rdfs:comment 'Comma-separated list of IATA region codes or airport codes where this product is available for destination bookings. Empty indicates global availability. Used for regional product offerings.' ;
    rdfs:domain ind:ServiceProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dimensionalWeightFactor rdf:type rdf:Property ;
    rdfs:label 'Dimensional Weight Factor' ;
    rdfs:comment 'Volumetric conversion factor used to calculate chargeable weight from shipment dimensions (typically 6000 for air cargo, representing cubic centimeters per kilogram). Used when volumetric weight exceeds actual weight.' ;
    rdfs:domain ind:ServiceProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discontinuedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Discontinued Timestamp' ;
    rdfs:comment 'Timestamp when this cargo service product was discontinued and removed from active offerings. Null for active products. Used for product lifecycle analytics and historical reporting.' ;
    rdfs:domain ind:ServiceProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eligibleCommodityCodes rdf:type rdf:Property ;
    rdfs:label 'Eligible Commodity Codes' ;
    rdfs:comment 'Comma-separated list of IATA commodity codes eligible for this product. Defines which types of cargo can be booked under this service offering. Empty indicates all commodities accepted.' ;
    rdfs:domain ind:ServiceProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibleUldTypes rdf:type rdf:Property ;
    rdfs:label 'Eligible Uld Types' ;
    rdfs:comment 'Comma-separated list of ULD type codes compatible with this product (e.g., AKE, LD3, PMC). Null if product does not support ULD containerization.' ;
    rdfs:domain ind:ServiceProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freighterOnlyIndicator rdf:type rdf:Property ;
    rdfs:label 'Freighter Only Indicator' ;
    rdfs:comment 'Flag indicating whether this product is restricted to dedicated freighter aircraft and cannot be carried in passenger aircraft belly cargo. Typically true for dangerous goods and oversized cargo.' ;
    rdfs:domain ind:ServiceProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:insuranceAvailable rdf:type rdf:Property ;
    rdfs:label 'Insurance Available' ;
    rdfs:comment 'Flag indicating whether cargo insurance is available as an add-on for this product. Determines whether declared value for carriage can be specified at booking.' ;
    rdfs:domain ind:ServiceProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:liveAnimalAccepted rdf:type rdf:Property ;
    rdfs:label 'Live Animal Accepted' ;
    rdfs:comment 'Flag indicating whether this product accepts live animal shipments. Determines applicability of IATA Live Animals Regulations (LAR) and special handling requirements.' ;
    rdfs:domain ind:ServiceProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maximumPieceWeightKg rdf:type rdf:Property ;
    rdfs:label 'Maximum Piece Weight Kg' ;
    rdfs:comment 'Maximum weight per individual piece accepted under this product, measured in kilograms. Null indicates no piece weight restriction. Used for operational feasibility and equipment capacity checks.' ;
    rdfs:domain ind:ServiceProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumShipmentWeightKg rdf:type rdf:Property ;
    rdfs:label 'Maximum Shipment Weight Kg' ;
    rdfs:comment 'Maximum total weight per shipment accepted under this product, measured in kilograms. Null indicates no shipment weight restriction. Used for capacity allocation and aircraft weight and balance.' ;
    rdfs:domain ind:ServiceProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumChargeableWeightKg rdf:type rdf:Property ;
    rdfs:label 'Minimum Chargeable Weight Kg' ;
    rdfs:comment 'Minimum weight threshold in kilograms for rate calculation. Shipments below this weight are charged at this minimum. Null indicates no minimum.' ;
    rdfs:domain ind:ServiceProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originRegionRestriction rdf:type rdf:Property ;
    rdfs:label 'Origin Region Restriction' ;
    rdfs:comment 'Comma-separated list of IATA region codes or airport codes where this product is available for origin bookings. Empty indicates global availability. Used for regional product offerings.' ;
    rdfs:domain ind:ServiceProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityLoadingIndicator rdf:type rdf:Property ;
    rdfs:label 'Priority Loading Indicator' ;
    rdfs:comment 'Flag indicating whether this product receives priority loading on aircraft. True for express and premium products; affects weight and balance planning and turnaround sequencing.' ;
    rdfs:domain ind:ServiceProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:productOwner rdf:type rdf:Property ;
    rdfs:label 'Product Owner' ;
    rdfs:comment 'Business unit or department responsible for this cargo service product definition, pricing, and lifecycle management. Used for governance and accountability.' ;
    rdfs:domain ind:ServiceProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productType rdf:type rdf:Property ;
    rdfs:label 'Product Type' ;
    rdfs:comment 'Classification of the cargo service product by operational category. Determines handling requirements, equipment needs, and regulatory compliance obligations.' ;
    rdfs:domain ind:ServiceProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictedCommodityCodes rdf:type rdf:Property ;
    rdfs:label 'Restricted Commodity Codes' ;
    rdfs:comment 'Comma-separated list of IATA commodity codes explicitly excluded from this product. Used to enforce product-specific restrictions (e.g., no dangerous goods on standard service).' ;
    rdfs:domain ind:ServiceProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesChannelAvailability rdf:type rdf:Property ;
    rdfs:label 'Sales Channel Availability' ;
    rdfs:comment 'Comma-separated list of sales channels through which this product can be booked (e.g., direct, GDS, agent, web, mobile). Used for channel management and distribution strategy.' ;
    rdfs:domain ind:ServiceProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureRangeMaxCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Range Max Celsius' ;
    rdfs:comment 'Maximum temperature threshold in Celsius for temperature-controlled products. Null for non-temperature-controlled products. Used for cool chain and pharmaceutical cargo.' ;
    rdfs:domain ind:ServiceProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureRangeMinCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Range Min Celsius' ;
    rdfs:comment 'Minimum temperature threshold in Celsius for temperature-controlled products. Null for non-temperature-controlled products. Used for cool chain and pharmaceutical cargo.' ;
    rdfs:domain ind:ServiceProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trackingCapabilityLevel rdf:type rdf:Property ;
    rdfs:label 'Tracking Capability Level' ;
    rdfs:comment 'Level of shipment tracking and visibility provided for this product. Determines frequency of status updates and customer access to tracking data.' ;
    rdfs:domain ind:ServiceProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transitTimeHours rdf:type rdf:Property ;
    rdfs:label 'Transit Time Hours' ;
    rdfs:comment 'Committed maximum transit time from origin acceptance to destination delivery, measured in hours. Forms the basis of service level agreements (SLA) and On-Time Performance (OTP) measurement.' ;
    rdfs:domain ind:ServiceProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:uldCompatibleIndicator rdf:type rdf:Property ;
    rdfs:label 'Uld Compatible Indicator' ;
    rdfs:comment 'Flag indicating whether this product supports Unit Load Device (ULD) containerization. Affects capacity planning, loading procedures, and pricing.' ;
    rdfs:domain ind:ServiceProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:currentLocationStationId rdf:type rdf:Property ;
    rdfs:label 'Current Location Station Id' ;
    rdfs:comment 'Foreign key linking to airport.station. Business justification: Shipments track current_location_code for real-time tracking. Station link provides ground handler, customs capability, operational hours, and contact details essential for exception handling and deli' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Station .

ind:uldId rdf:type rdf:Property ;
    rdfs:label 'Uld Id' ;
    rdfs:comment 'FK to cargo.uld' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Uld .

ind:actualArrivalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Arrival Timestamp' ;
    rdfs:comment 'Actual date and time when the shipment physically arrived at the destination station. Recorded upon flight arrival and cargo offload.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualPieces rdf:type rdf:Property ;
    rdfs:label 'Actual Pieces' ;
    rdfs:comment 'Number of individual pieces or packages in the shipment as verified at acceptance. Used for piece-level tracking and reconciliation throughout the journey.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualWeightKg rdf:type rdf:Property ;
    rdfs:label 'Actual Weight Kg' ;
    rdfs:comment 'Gross weight of the shipment in kilograms as measured at acceptance. Used for weight and balance calculations and capacity planning.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customsClearedFlag rdf:type rdf:Property ;
    rdfs:label 'Customs Cleared Flag' ;
    rdfs:comment 'Indicates whether the shipment has successfully cleared customs at the destination. Critical for international shipments and delivery release.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedArrivalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Estimated Arrival Timestamp' ;
    rdfs:comment 'Estimated date and time when the shipment is expected to arrive at the destination station. Updated based on flight schedules and delays.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:exceptionReason rdf:type rdf:Property ;
    rdfs:label 'Exception Reason' ;
    rdfs:comment 'Free-text description of the exception condition if exception_flag is true. Provides context for operational follow-up and customer communication.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceDeclaredValue rdf:type rdf:Property ;
    rdfs:label 'Insurance Declared Value' ;
    rdfs:comment 'Declared value of the shipment for insurance purposes. Used to calculate insurance premiums and liability limits. Business-confidential financial data.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proofOfDelivery rdf:type rdf:Property ;
    rdfs:label 'Proof Of Delivery' ;
    rdfs:comment 'Name and signature of the person who received the shipment, or electronic delivery confirmation reference. Legal proof of successful delivery.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingSegments rdf:type rdf:Property ;
    rdfs:label 'Routing Segments' ;
    rdfs:comment 'Planned routing path as a sequence of station codes (e.g., JFK-FRA-DXB). Defines the intended flight segments for the shipment journey.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentStatus rdf:type rdf:Property ;
    rdfs:label 'Shipment Status' ;
    rdfs:comment 'Current lifecycle status of the physical shipment. Tracks progression from acceptance through delivery. Aligns with IATA Cargo-XML status codes. [ENUM-REF-CANDIDATE: received|built_up|loaded|in_transit|arrived|delivered|on_hold|returned — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureMaxCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Max Celsius' ;
    rdfs:comment 'Maximum allowed temperature in Celsius for temperature-controlled shipments. Null for non-temperature-sensitive cargo.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureMinCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Min Celsius' ;
    rdfs:comment 'Minimum required temperature in Celsius for temperature-controlled shipments (e.g., perishables, pharmaceuticals). Null for non-temperature-sensitive cargo.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emailSendId rdf:type rdf:Property ;
    rdfs:label 'Email Send Id' ;
    rdfs:comment 'Foreign key linking to marketing.email_send. Business justification: Email sends to shipper contacts for cargo marketing campaigns require linking for engagement tracking, bounce management, and communication preference enforcement. Enables shipper-level email performa' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EmailSend .

ind:marketResearchStudyId rdf:type rdf:Property ;
    rdfs:label 'Market Research Study Id' ;
    rdfs:comment 'Foreign key linking to marketing.market_research_study. Business justification: Shippers participate in cargo market research for service quality assessment, pricing feedback, and commodity-specific needs analysis. Linking shipper participation to studies enables targeted samplin' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MarketResearchStudy .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line1' ;
    rdfs:comment 'First line of the shipper\'s physical address including street number and street name.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line2' ;
    rdfs:comment 'Second line of the shipper\'s physical address for additional address details such as suite, floor, or building.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blacklistReason rdf:type rdf:Property ;
    rdfs:label 'Blacklist Reason' ;
    rdfs:comment 'Reason for blacklisting the shipper if status is blacklisted. Includes security violations, payment defaults, or regulatory non-compliance. Null if not blacklisted.' ;
    rdfs:domain ind:Shipper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:city rdf:type rdf:Property ;
    rdfs:label 'City' ;
    rdfs:comment 'City or municipality where the shipper is located.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commoditySpecialization rdf:type rdf:Property ;
    rdfs:label 'Commodity Specialization' ;
    rdfs:comment 'Primary commodity types or industries the shipper specializes in (e.g., pharmaceuticals, perishables, electronics, automotive, textiles). Free-text field for multiple specializations.' ;
    rdfs:domain ind:Shipper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactFax rdf:type rdf:Property ;
    rdfs:label 'Contact Fax' ;
    rdfs:comment 'Fax number for the shipper contact. May be null if fax is not used.' ;
    rdfs:domain ind:Shipper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactName rdf:type rdf:Property ;
    rdfs:label 'Contact Name' ;
    rdfs:comment 'Full name of the primary contact person at the shipper organization.' ;
    rdfs:domain ind:Shipper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditStatus rdf:type rdf:Property ;
    rdfs:label 'Credit Status' ;
    rdfs:comment 'Current credit status of the shipper for cargo services. Determines payment terms and credit limits.' ;
    rdfs:domain ind:Shipper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Customs Registration Number' ;
    rdfs:comment 'Shipper\'s registration number with the national customs authority. Required for international cargo shipments.' ;
    rdfs:domain ind:Shipper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dgShipperCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Dg Shipper Certified Flag' ;
    rdfs:comment 'Indicates whether the shipper is certified to tender dangerous goods (DG) cargo. True if certified, False otherwise.' ;
    rdfs:domain ind:Shipper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eoriNumber rdf:type rdf:Property ;
    rdfs:label 'Eori Number' ;
    rdfs:comment 'EORI number assigned by EU customs authorities for shippers operating in the European Union. Required for EU customs clearance.' ;
    rdfs:domain ind:Shipper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iataCassCode rdf:type rdf:Property ;
    rdfs:label 'Iata Cass Code' ;
    rdfs:comment 'IATA CASS code assigned to the shipper or their freight forwarder for billing and settlement purposes. Null if not enrolled in CASS.' ;
    rdfs:domain ind:Shipper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:knownShipperCertificationDate rdf:type rdf:Property ;
    rdfs:label 'Known Shipper Certification Date' ;
    rdfs:comment 'Date when the shipper was certified as a Known Shipper by the relevant aviation security authority.' ;
    rdfs:domain ind:Shipper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:knownShipperExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Known Shipper Expiry Date' ;
    rdfs:comment 'Date when the Known Shipper certification expires and requires renewal. Null if certification does not expire or is not applicable.' ;
    rdfs:domain ind:Shipper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:knownShipperStatus rdf:type rdf:Property ;
    rdfs:label 'Known Shipper Status' ;
    rdfs:comment 'IATA/ICAO security designation indicating whether the shipper has been validated and approved to tender cargo without additional security screening. Critical for aviation security compliance.' ;
    rdfs:domain ind:Shipper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastShipmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Shipment Date' ;
    rdfs:comment 'Date of the most recent cargo shipment tendered by this shipper. Used for shipper activity tracking and dormancy analysis.' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:onboardingDate rdf:type rdf:Property ;
    rdfs:label 'Onboarding Date' ;
    rdfs:comment 'Date when the shipper was first onboarded and approved to tender cargo with the airline.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:postalCode rdf:type rdf:Property ;
    rdfs:label 'Postal Code' ;
    rdfs:comment 'Postal or ZIP code for the shipper\'s address.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Preferred Currency Code' ;
    rdfs:comment 'Three-letter ISO currency code representing the shipper\'s preferred currency for invoicing and rate quotations.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipperStatus rdf:type rdf:Property ;
    rdfs:label 'Shipper Status' ;
    rdfs:comment 'Current operational status of the shipper account. Active shippers can tender cargo; inactive, suspended, or blacklisted shippers cannot.' ;
    rdfs:domain ind:Shipper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipperType rdf:type rdf:Property ;
    rdfs:label 'Shipper Type' ;
    rdfs:comment 'Classification of the shipper entity type. Distinguishes between individual shippers, corporate entities, regulated agents, freight forwarders acting as shippers, government agencies, manufacturers, and retailers. [ENUM-REF-CANDIDATE: individual|corporate|regulated_agent|freight_forwarder|government|manufacturer|retailer — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Shipper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateProvince rdf:type rdf:Property ;
    rdfs:label 'State Province' ;
    rdfs:comment 'State, province, or administrative region where the shipper is located.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalShipmentsCount rdf:type rdf:Property ;
    rdfs:label 'Total Shipments Count' ;
    rdfs:comment 'Cumulative count of all cargo shipments tendered by this shipper since onboarding. Used for shipper volume analysis.' ;
    rdfs:domain ind:Shipper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:leaseVendorId rdf:type rdf:Property ;
    rdfs:label 'Lease Vendor Id' ;
    rdfs:comment 'Foreign key linking to procurement.vendor. Business justification: ULD lease, repair, and maintenance services are procured from specialized vendors. Essential for ULD lifecycle cost tracking, vendor performance on serviceable status, and lease payment processing.' ;
    rdfs:domain ind:Uld ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:barcodeNumber rdf:type rdf:Property ;
    rdfs:label 'Barcode Number' ;
    rdfs:comment 'Barcode identifier printed on the ULD for manual or automated scanning during cargo handling operations.' ;
    rdfs:domain ind:Uld ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compatibleAircraftTypes rdf:type rdf:Property ;
    rdfs:label 'Compatible Aircraft Types' ;
    rdfs:comment 'Comma-separated list of aircraft type codes (e.g., B777, A350, B747F) that can accommodate this ULD type. Used for load planning and fleet compatibility.' ;
    rdfs:domain ind:Uld ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:damageStatus rdf:type rdf:Property ;
    rdfs:label 'Damage Status' ;
    rdfs:comment 'Current damage assessment level. None indicates no damage; minor damage allows continued use with monitoring; major damage requires repair before next use; critical damage grounds the unit immediately.' ;
    rdfs:domain ind:Uld ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionIntervalDays rdf:type rdf:Property ;
    rdfs:label 'Inspection Interval Days' ;
    rdfs:comment 'Standard number of days between required inspections for this ULD type, as defined by IATA regulations and airline maintenance programs.' ;
    rdfs:domain ind:Uld ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Last Inspection Date' ;
    rdfs:comment 'Date of the most recent scheduled inspection or maintenance check of the ULD. Required for regulatory compliance and safety.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastMovementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Movement Timestamp' ;
    rdfs:comment 'Date and time when the ULD was last scanned or moved. Used for tracking ULD utilization and identifying stale or lost units.' ;
    rdfs:domain ind:Uld ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastRepairDate rdf:type rdf:Property ;
    rdfs:label 'Last Repair Date' ;
    rdfs:comment 'Date when the most recent repair or maintenance work was completed on this ULD. Used for maintenance history tracking.' ;
    rdfs:domain ind:Uld ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:manufactureDate rdf:type rdf:Property ;
    rdfs:label 'Manufacture Date' ;
    rdfs:comment 'Date when the ULD was manufactured. Used for age tracking, depreciation, and lifecycle management.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:materialType rdf:type rdf:Property ;
    rdfs:label 'Material Type' ;
    rdfs:comment 'Primary construction material of the ULD. Aluminum is most common; composite materials are lighter; steel is used for heavy-duty applications.' ;
    rdfs:domain ind:Uld ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumGrossWeightKg rdf:type rdf:Property ;
    rdfs:label 'Maximum Gross Weight Kg' ;
    rdfs:comment 'Maximum allowable total weight (tare + cargo) for this ULD type in kilograms, as specified by IATA standards and aircraft compatibility.' ;
    rdfs:domain ind:Uld ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Maximum Volume M3' ;
    rdfs:comment 'Maximum internal volume capacity of the ULD in cubic meters. Used for cargo capacity planning and load optimization.' ;
    rdfs:domain ind:Uld ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextInspectionDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Inspection Due Date' ;
    rdfs:comment 'Date by which the next scheduled inspection must be completed. ULDs overdue for inspection should be removed from service.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ownerAirlineCode rdf:type rdf:Property ;
    rdfs:label 'Owner Airline Code' ;
    rdfs:comment 'IATA two-letter airline code of the carrier that owns this ULD asset. Part of the ULD serial number.' ;
    rdfs:domain ind:Uld ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipType rdf:type rdf:Property ;
    rdfs:label 'Ownership Type' ;
    rdfs:comment 'Indicates whether the ULD is owned by the airline, leased from a third party, or part of a shared pool arrangement.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retirementDate rdf:type rdf:Property ;
    rdfs:label 'Retirement Date' ;
    rdfs:comment 'Date when the ULD was permanently removed from service and retired from the fleet. Null for active units.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:retirementReason rdf:type rdf:Property ;
    rdfs:label 'Retirement Reason' ;
    rdfs:comment 'Explanation for why the ULD was retired (e.g., end of useful life, irreparable damage, fleet optimization, lease expiration).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfidTagNumber rdf:type rdf:Property ;
    rdfs:label 'Rfid Tag Number' ;
    rdfs:comment 'Unique identifier of the RFID tag attached to the ULD for automated tracking and scanning. Used by ULD control systems.' ;
    rdfs:domain ind:Uld ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serialNumber rdf:type rdf:Property ;
    rdfs:label 'Serial Number' ;
    rdfs:comment 'IATA-compliant ULD serial number in format: 3-letter type code + 5-digit serial + 2-letter owner code (e.g., AKE12345AA). Globally unique identifier for the physical ULD asset.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceableStatus rdf:type rdf:Property ;
    rdfs:label 'Serviceable Status' ;
    rdfs:comment 'Current operational status of the ULD. Serviceable units are available for loading; unserviceable units require repair; condemned units are retired from service; quarantined units are held for inspection; missing units are lost or unaccounted for.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tareWeightKg rdf:type rdf:Property ;
    rdfs:label 'Tare Weight Kg' ;
    rdfs:comment 'Empty weight of the ULD in kilograms. Used for weight and balance calculations and to determine net cargo weight.' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureControlledFlag rdf:type rdf:Property ;
    rdfs:label 'Temperature Controlled Flag' ;
    rdfs:comment 'Indicates whether this ULD is equipped with active or passive temperature control for perishable or pharmaceutical cargo. True if temperature-controlled, false otherwise.' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:typeCode rdf:type rdf:Property ;
    rdfs:label 'Type Code' ;
    rdfs:comment 'IATA three-letter ULD type code identifying the container or pallet type (e.g., AKE, LD3, LD7, LD11, PMC, PAG, AAA). Defines the physical dimensions and configuration.' ;
    rdfs:domain ind:Uld ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uldCategory rdf:type rdf:Property ;
    rdfs:label 'Uld Category' ;
    rdfs:comment 'High-level classification of the ULD: container (enclosed unit), pallet (flat platform), or igloo (pallet with contoured cover).' ;
    rdfs:domain ind:Uld ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uldMovementId rdf:type rdf:Property ;
    rdfs:label 'Uld Movement Id' ;
    rdfs:comment 'Unique identifier for each ULD movement event record. Primary key for the ULD movement transaction.' ;
    rdfs:domain ind:UldMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:aircraftHoldPosition rdf:type rdf:Property ;
    rdfs:label 'Aircraft Hold Position' ;
    rdfs:comment 'Specific compartment or position code within the aircraft hold where the ULD was loaded (e.g., FWD, AFT, MAIN, P1, P2). Null for non-loading events.' ;
    rdfs:domain ind:UldMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cargoWeightKg rdf:type rdf:Property ;
    rdfs:label 'Cargo Weight Kg' ;
    rdfs:comment 'Net weight of cargo contents within the ULD, calculated as gross weight minus tare weight, measured in kilograms.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:damageSeverity rdf:type rdf:Property ;
    rdfs:label 'Damage Severity' ;
    rdfs:comment 'Severity classification of ULD damage. Minor = cosmetic, moderate = functional impact but usable, major = requires repair before next use, critical = ULD unsafe for service. Null if no damage.' ;
    rdfs:domain ind:UldMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discrepancyFlag rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Flag' ;
    rdfs:comment 'Indicates whether any discrepancy, irregularity, or exception was noted during this ULD movement event. True = discrepancy exists, False = normal movement.' ;
    rdfs:domain ind:UldMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discrepancyType rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Type' ;
    rdfs:comment 'Category of discrepancy or irregularity identified during the ULD movement. Damage = physical damage to ULD, missing = ULD not found, overweight = exceeds weight limits, contamination = foreign substance present, seal_broken = security seal compromised, misdirected = sent to wrong location. Null if no discrepancy.' ;
    rdfs:domain ind:UldMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventTimestamp rdf:type rdf:Property ;
    rdfs:label 'Event Timestamp' ;
    rdfs:comment 'Date and time when the ULD movement event occurred. Recorded in UTC and follows format yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eventType rdf:type rdf:Property ;
    rdfs:label 'Event Type' ;
    rdfs:comment 'Type of ULD movement event being recorded. Buildup = cargo loaded into ULD, breakdown = cargo removed from ULD, loading = ULD loaded onto aircraft, offloading = ULD removed from aircraft, transfer = ULD moved between locations, repositioning = empty ULD moved for operational needs.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handlingAgentCode rdf:type rdf:Property ;
    rdfs:label 'Handling Agent Code' ;
    rdfs:comment 'Code identifying the ground handling agent or airline personnel responsible for executing this ULD movement event.' ;
    rdfs:domain ind:UldMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handlingAgentName rdf:type rdf:Property ;
    rdfs:label 'Handling Agent Name' ;
    rdfs:comment 'Full name of the ground handling company or airline unit that performed the ULD movement.' ;
    rdfs:domain ind:UldMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementStatus rdf:type rdf:Property ;
    rdfs:label 'Movement Status' ;
    rdfs:comment 'Current lifecycle status of this ULD movement event. Planned = scheduled but not started, in_progress = movement underway, completed = movement finished successfully, cancelled = movement aborted, delayed = movement behind schedule, exception = irregularity occurred.' ;
    rdfs:domain ind:UldMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Recorded Timestamp' ;
    rdfs:comment 'Date and time when this ULD movement record was created in the cargo management system. May differ from event_timestamp if recorded retroactively. Follows format yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:UldMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:repairRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Repair Required Flag' ;
    rdfs:comment 'Indicates whether the ULD requires maintenance or repair before it can be returned to service. True = repair needed, False = serviceable.' ;
    rdfs:domain ind:UldMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resolutionStatus rdf:type rdf:Property ;
    rdfs:label 'Resolution Status' ;
    rdfs:comment 'Status of resolution for any discrepancy or irregularity associated with this ULD movement. Open = discrepancy reported, investigating = under review, resolved = corrective action taken, closed = case finalized. Null if no discrepancy.' ;
    rdfs:domain ind:UldMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sealIntactFlag rdf:type rdf:Property ;
    rdfs:label 'Seal Intact Flag' ;
    rdfs:comment 'Indicates whether the security seal was found intact at the time of this movement event. True = seal intact, False = seal broken or missing.' ;
    rdfs:domain ind:UldMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sealNumberPrimary rdf:type rdf:Property ;
    rdfs:label 'Seal Number Primary' ;
    rdfs:comment 'Primary security seal number applied to the ULD to ensure cargo integrity and prevent tampering. Null if ULD is not sealed.' ;
    rdfs:domain ind:UldMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sealNumberSecondary rdf:type rdf:Property ;
    rdfs:label 'Seal Number Secondary' ;
    rdfs:comment 'Secondary or backup security seal number if multiple seals are applied. Null if only one seal or no seals applied.' ;
    rdfs:domain ind:UldMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adComplianceRecordId rdf:type rdf:Property ;
    rdfs:label 'Ad Compliance Record Id' ;
    rdfs:comment 'Unique identifier for the AD compliance record tracking the compliance status of a specific Airworthiness Directive for a specific aircraft.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AdComplianceRecord .

ind:adNumber rdf:type rdf:Property ;
    rdfs:label 'Ad Number' ;
    rdfs:comment 'The official regulatory AD number issued by the aviation authority (e.g., FAA AD 2023-15-08, EASA AD 2023-0142).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aircraftCyclesAtCompliance rdf:type rdf:Property ;
    rdfs:label 'Aircraft Cycles At Compliance' ;
    rdfs:comment 'Total flight cycles accumulated by the aircraft at the time compliance was achieved.' ;
    rdfs:domain ind:AdComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:aircraftHoursAtCompliance rdf:type rdf:Property ;
    rdfs:label 'Aircraft Hours At Compliance' ;
    rdfs:comment 'Total flight hours accumulated by the aircraft at the time compliance was achieved.' ;
    rdfs:domain ind:AdComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amocApprovalNumber rdf:type rdf:Property ;
    rdfs:label 'Amoc Approval Number' ;
    rdfs:comment 'The regulatory approval number for an Alternative Method of Compliance if one was used instead of the standard AD compliance method.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amocApprovedFlag rdf:type rdf:Property ;
    rdfs:label 'Amoc Approved Flag' ;
    rdfs:comment 'Indicates whether an Alternative Method of Compliance has been approved by the regulatory authority for this AD compliance.' ;
    rdfs:domain ind:AdComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:applicabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Applicability Status' ;
    rdfs:comment 'Indicates whether this AD is applicable to the specific aircraft based on model, serial number, configuration, and installed components.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifyingMechanicLicense rdf:type rdf:Property ;
    rdfs:label 'Certifying Mechanic License' ;
    rdfs:comment 'The license number of the certified aircraft mechanic or engineer who certified the AD compliance work.' ;
    rdfs:domain ind:AdComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifyingOrganization rdf:type rdf:Property ;
    rdfs:label 'Certifying Organization' ;
    rdfs:comment 'The name of the maintenance organization (MRO or internal maintenance) that performed and certified the AD compliance work.' ;
    rdfs:domain ind:AdComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceCostAmount rdf:type rdf:Property ;
    rdfs:label 'Compliance Cost Amount' ;
    rdfs:comment 'The total cost incurred to achieve compliance with this AD, including labor, parts, and overhead.' ;
    rdfs:domain ind:AdComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceCostCurrency rdf:type rdf:Property ;
    rdfs:label 'Compliance Cost Currency' ;
    rdfs:comment 'The three-letter ISO 4217 currency code for the compliance cost amount.' ;
    rdfs:domain ind:AdComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceDate rdf:type rdf:Property ;
    rdfs:label 'Compliance Date' ;
    rdfs:comment 'The date on which compliance with the AD was achieved for this aircraft.' ;
    rdfs:domain ind:AdComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceDocumentationReference rdf:type rdf:Property ;
    rdfs:label 'Compliance Documentation Reference' ;
    rdfs:comment 'Reference to the physical or digital documentation (logbook entry, maintenance record, certificate) that provides evidence of AD compliance.' ;
    rdfs:domain ind:AdComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceIntervalCycles rdf:type rdf:Property ;
    rdfs:label 'Compliance Interval Cycles' ;
    rdfs:comment 'For recurring ADs, the interval in flight cycles between required compliance actions.' ;
    rdfs:domain ind:AdComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceIntervalDays rdf:type rdf:Property ;
    rdfs:label 'Compliance Interval Days' ;
    rdfs:comment 'For recurring ADs, the calendar interval in days between required compliance actions.' ;
    rdfs:domain ind:AdComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceIntervalHours rdf:type rdf:Property ;
    rdfs:label 'Compliance Interval Hours' ;
    rdfs:comment 'For recurring ADs, the interval in flight hours between required compliance actions.' ;
    rdfs:domain ind:AdComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceMethod rdf:type rdf:Property ;
    rdfs:label 'Compliance Method' ;
    rdfs:comment 'The method used to achieve compliance with the AD (e.g., inspection, part replacement, modification, operational limitation).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionTaken rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Taken' ;
    rdfs:comment 'Description of the corrective actions taken to achieve compliance with the AD, including parts replaced, modifications performed, or operational limitations imposed.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deferralAuthorizationNumber rdf:type rdf:Property ;
    rdfs:label 'Deferral Authorization Number' ;
    rdfs:comment 'The regulatory authorization number if compliance with the AD has been deferred under approved conditions.' ;
    rdfs:domain ind:AdComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deferralExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Deferral Expiry Date' ;
    rdfs:comment 'The date by which a deferred AD must be complied with, as specified in the deferral authorization.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inspectionFindings rdf:type rdf:Property ;
    rdfs:label 'Inspection Findings' ;
    rdfs:comment 'Detailed findings from the inspection or compliance action, including any discrepancies, defects, or observations noted during the work.' ;
    rdfs:domain ind:AdComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextActionDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Action Due Date' ;
    rdfs:comment 'For recurring ADs, the date by which the next compliance action (inspection, check, etc.) is due.' ;
    rdfs:domain ind:AdComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:partsReplaced rdf:type rdf:Property ;
    rdfs:label 'Parts Replaced' ;
    rdfs:comment 'List of aircraft parts or components that were replaced as part of the AD compliance action, including part numbers and serial numbers.' ;
    rdfs:domain ind:AdComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Record Source System' ;
    rdfs:comment 'The name of the source operational system from which this AD compliance record originated (e.g., AMOS, SAP PM).' ;
    rdfs:domain ind:AdComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceBulletinReference rdf:type rdf:Property ;
    rdfs:label 'Service Bulletin Reference' ;
    rdfs:comment 'Reference to the manufacturer service bulletin that was used to comply with the AD, if applicable.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminatingActionFlag rdf:type rdf:Property ;
    rdfs:label 'Terminating Action Flag' ;
    rdfs:comment 'Indicates whether a terminating action has been performed that eliminates the need for recurring compliance with this AD.' ;
    rdfs:domain ind:AdComplianceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Work Order Number' ;
    rdfs:comment 'The maintenance work order number under which the AD compliance work was performed.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditEventId rdf:type rdf:Property ;
    rdfs:label 'Audit Event Id' ;
    rdfs:comment 'Unique identifier for the audit event. Primary key for the audit event record.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AuditEvent .

ind:auditProgramId rdf:type rdf:Property ;
    rdfs:label 'Audit Program Id' ;
    rdfs:comment 'Reference to the parent audit program under which this event was conducted.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AuditProgram .

ind:auditeeDepartmentOrgUnitId rdf:type rdf:Property ;
    rdfs:label 'Auditee Department Org Unit Id' ;
    rdfs:comment 'Foreign key linking to workforce.org_unit. Business justification: Audits target specific organizational units for compliance verification. FK enables audit coverage analysis, resource planning, finding aggregation by department, and regulatory reporting of departmen' ;
    rdfs:domain ind:AuditEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:leadAuditorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Lead Auditor Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Internal audits (SMS, quality, safety) require qualified lead auditors. FK enables verification of auditor competency, training currency, independence requirements, and audit assignment workload balan' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualEndDate rdf:type rdf:Property ;
    rdfs:label 'Actual End Date' ;
    rdfs:comment 'Actual date the audit event fieldwork concluded. For single-day audits, this equals actual start date.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualStartDate rdf:type rdf:Property ;
    rdfs:label 'Actual Start Date' ;
    rdfs:comment 'Actual date the audit event commenced. May differ from scheduled date due to operational changes or auditor availability.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:aircraftRegistration rdf:type rdf:Property ;
    rdfs:label 'Aircraft Registration' ;
    rdfs:comment 'Tail number or registration of the specific aircraft audited or inspected, if the audit was aircraft-specific (e.g., FAA ramp inspection, airworthiness review). Null if audit was not aircraft-specific.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aircraftType rdf:type rdf:Property ;
    rdfs:label 'Aircraft Type' ;
    rdfs:comment 'ICAO aircraft type designator for the aircraft audited (e.g., B738 for Boeing 737-800, A320 for Airbus A320). Null if audit was not aircraft-specific.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentRating rdf:type rdf:Property ;
    rdfs:label 'Assessment Rating' ;
    rdfs:comment 'Quantitative or qualitative rating assigned to the audit event, if applicable. May be numeric score (e.g., 85/100), letter grade (A, B, C), or maturity level (Level 1-5). Format varies by audit program and auditing body.' ;
    rdfs:domain ind:AuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditDurationDays rdf:type rdf:Property ;
    rdfs:label 'Audit Duration Days' ;
    rdfs:comment 'Total number of calendar days the audit event spanned from actual start date to actual end date, inclusive. For single-day audits, value is 1.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditLocationCode rdf:type rdf:Property ;
    rdfs:label 'Audit Location Code' ;
    rdfs:comment 'IATA (International Air Transport Association) or ICAO (International Civil Aviation Organization) airport code, or internal facility code identifying the specific location audited (e.g., JFK, EGLL, MIA-MX1 for Miami maintenance base).' ;
    rdfs:domain ind:AuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditLocationType rdf:type rdf:Property ;
    rdfs:label 'Audit Location Type' ;
    rdfs:comment 'Classification of the physical location where the audit was conducted. Station refers to airport operational locations. Hub refers to major connecting airports. Maintenance base refers to MRO (Maintenance Repair and Overhaul) facilities. Headquarters refers to corporate offices. Training center refers to crew training facilities. Cargo facility refers to freight handling locations. Remote site refers to outstations or line stations. [ENUM-REF-CANDIDATE: station|hub|maintenance_base|headquarters|training_center|cargo_facility|remote_site — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditNotes rdf:type rdf:Property ;
    rdfs:label 'Audit Notes' ;
    rdfs:comment 'Free-text field for additional notes, context, or observations about the audit event. May include special circumstances, auditor comments, or operational context relevant to the audit.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditReportIssuedDate rdf:type rdf:Property ;
    rdfs:label 'Audit Report Issued Date' ;
    rdfs:comment 'Date the formal audit report was issued or published to stakeholders. Typically follows completion of fieldwork and report review process.' ;
    rdfs:domain ind:AuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditReportReference rdf:type rdf:Property ;
    rdfs:label 'Audit Report Reference' ;
    rdfs:comment 'Document reference number or identifier for the formal audit report issued for this event. Used to link to document management system or audit report repository.' ;
    rdfs:domain ind:AuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditScope rdf:type rdf:Property ;
    rdfs:label 'Audit Scope' ;
    rdfs:comment 'Detailed description of the audit scope, including functional areas, processes, standards, or regulations covered. Examples: Flight Operations and Maintenance for IOSA, Ramp Safety and Ground Handling for FAA ramp inspection, Consumer Protection Compliance for DOT review, SMS implementation for internal audit.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditingBody rdf:type rdf:Property ;
    rdfs:label 'Auditing Body' ;
    rdfs:comment 'Name of the external organization or internal department conducting the audit. Examples: IATA (International Air Transport Association) for IOSA audits, FAA (Federal Aviation Administration) for ramp inspections, EASA (European Union Aviation Safety Agency) for standardization visits, DOT (Department of Transportation) for consumer compliance, internal Quality Assurance department, third-party certification bodies.' ;
    rdfs:domain ind:AuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditorTeamSize rdf:type rdf:Property ;
    rdfs:label 'Auditor Team Size' ;
    rdfs:comment 'Total number of auditors or inspectors on the audit team, including lead auditor, co-auditors, technical experts, and observers.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certificationStandard rdf:type rdf:Property ;
    rdfs:label 'Certification Standard' ;
    rdfs:comment 'Name and version of the certification standard, regulatory framework, or audit protocol against which the audit was conducted. Examples: IOSA Standards Manual Edition 14, ISO 9001:2015, FAA 14 CFR Part 121, EASA Part-ORO, SMS (Safety Management System) ICAO Annex 19.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceGapsIdentified rdf:type rdf:Property ;
    rdfs:label 'Compliance Gaps Identified' ;
    rdfs:comment 'Summary description of key compliance gaps, deficiencies, or areas of non-conformance identified during the audit. Provides high-level overview of systemic issues or recurring themes across findings.' ;
    rdfs:domain ind:AuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionDueDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Due Date' ;
    rdfs:comment 'Deadline by which all corrective actions resulting from audit findings must be completed and verified. Null if no corrective action required.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Required Flag' ;
    rdfs:comment 'Boolean indicator whether formal corrective action plan is required as a result of this audit event. True indicates corrective actions must be documented and tracked. False indicates no formal corrective action required (audit passed or only minor observations).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:criticalFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Critical Findings Count' ;
    rdfs:comment 'Number of critical or major findings requiring immediate corrective action. Critical findings typically indicate significant safety risk, regulatory non-compliance, or system failure.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eventNumber rdf:type rdf:Property ;
    rdfs:label 'Event Number' ;
    rdfs:comment 'Business identifier for the audit event, typically formatted as program code plus sequence number (e.g., IOSA-2024-001, FAA-RAMP-2024-045).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventStatus rdf:type rdf:Property ;
    rdfs:label 'Event Status' ;
    rdfs:comment 'Current lifecycle status of the audit event. Scheduled indicates planning phase. In progress indicates active fieldwork. Completed indicates final report issued and findings closed or tracked. Cancelled indicates event did not occur. Deferred indicates postponed to future date.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpAuditRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Follow Up Audit Required Flag' ;
    rdfs:comment 'Boolean indicator whether a follow-up audit or surveillance visit is required to verify closure of findings and effectiveness of corrective actions. True indicates mandatory follow-up. False indicates no follow-up required.' ;
    rdfs:domain ind:AuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:majorFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Major Findings Count' ;
    rdfs:comment 'Number of major findings or non-conformances that require corrective action within a defined timeframe but do not pose immediate critical risk.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minorFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Minor Findings Count' ;
    rdfs:comment 'Number of minor findings, observations, or opportunities for improvement that do not constitute non-conformances but warrant attention.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextScheduledAuditDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Audit Date' ;
    rdfs:comment 'Planned date for the next audit event in this audit program or for this scope. For recurring audits (e.g., annual internal audits, biennial IOSA audits), this represents the next cycle. Null if no follow-up audit is scheduled.' ;
    rdfs:domain ind:AuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:overallOutcome rdf:type rdf:Property ;
    rdfs:label 'Overall Outcome' ;
    rdfs:comment 'Final assessment result of the audit event. Pass or satisfactory indicates full compliance with no major findings. Fail or unsatisfactory indicates critical non-conformances requiring immediate corrective action. Conditional indicates minor findings that must be addressed within a specified timeframe. Conforming and non-conforming are used for certification audits. [ENUM-REF-CANDIDATE: pass|fail|conditional|satisfactory|unsatisfactory|conforming|non_conforming — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AuditEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAuthority rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority' ;
    rdfs:comment 'Name of the regulatory authority or national CAA (Civil Aviation Authority) with jurisdiction over this audit event. Examples: FAA (Federal Aviation Administration) for US operations, EASA (European Union Aviation Safety Agency) for EU operations, CAAC for China, DGCA for India. Null for non-regulatory audits.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Total Findings Count' ;
    rdfs:comment 'Total number of findings, observations, or non-conformances identified during the audit event, across all severity levels.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:programOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Program Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Each audit program (SMS, quality, security) requires an accountable owner per ISO 19011. FK enables verification of owner authority, succession planning, workload distribution, and accountability for ' ;
    rdfs:domain ind:AuditProgram ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:applicableJurisdictions rdf:type rdf:Property ;
    rdfs:label 'Applicable Jurisdictions' ;
    rdfs:comment 'Comma-separated list of countries, regions, or regulatory jurisdictions where this audit program applies or is recognized (e.g., USA, EU, ICAO Member States, Global).' ;
    rdfs:domain ind:AuditProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditAuthority rdf:type rdf:Property ;
    rdfs:label 'Audit Authority' ;
    rdfs:comment 'The regulatory body, certification authority, or internal department responsible for conducting or overseeing the audit program (e.g., FAA, EASA, IATA, National CAA, Internal Audit Department).' ;
    rdfs:domain ind:AuditProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditCycleFrequency rdf:type rdf:Property ;
    rdfs:label 'Audit Cycle Frequency' ;
    rdfs:comment 'The recurring frequency or cycle at which audits under this program are conducted (annual, every two years, every three years, quarterly, continuous surveillance, triggered by specific events, or ad-hoc as needed). [ENUM-REF-CANDIDATE: annual|biennial|triennial|quarterly|continuous|event_driven|ad_hoc — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AuditProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditMethodology rdf:type rdf:Property ;
    rdfs:label 'Audit Methodology' ;
    rdfs:comment 'The primary methodology or approach used to conduct audits under this program (on-site inspection, remote audit, hybrid, document review, continuous surveillance, statistical sampling, continuous monitoring). [ENUM-REF-CANDIDATE: onsite|remote|hybrid|document_review|surveillance|sampling|continuous_monitoring — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AuditProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditType rdf:type rdf:Property ;
    rdfs:label 'Audit Type' ;
    rdfs:comment 'Classification of the audit program by its primary purpose and scope (regulatory oversight, internal quality assurance, certification, compliance verification, safety management, operational performance, financial controls, environmental compliance). [ENUM-REF-CANDIDATE: regulatory|internal|certification|compliance|safety|quality|operational|financial|environmental — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Certification Required Flag' ;
    rdfs:comment 'Indicates whether successful completion of this audit program results in or is required for a formal certification, approval, or operational authorization (true) or is for compliance monitoring only (false).' ;
    rdfs:domain ind:AuditProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coverageAreas rdf:type rdf:Property ;
    rdfs:label 'Coverage Areas' ;
    rdfs:comment 'Comma-separated list or structured enumeration of specific operational domains and functional areas covered by the audit program (e.g., Flight Operations, Maintenance, Crew Training, Ground Operations, Cargo, Safety Management, Security, Environmental).' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleDurationMonths rdf:type rdf:Property ;
    rdfs:label 'Cycle Duration Months' ;
    rdfs:comment 'The duration in months of one complete audit cycle for this program (e.g., 24 months for IOSA biennial cycle, 12 months for annual internal audits).' ;
    rdfs:domain ind:AuditProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:findingClassificationScheme rdf:type rdf:Property ;
    rdfs:label 'Finding Classification Scheme' ;
    rdfs:comment 'The classification or severity scheme used to categorize audit findings under this program (e.g., Critical, Major, Minor, Observation; or Level 1, Level 2, Level 3).' ;
    rdfs:domain ind:AuditProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingStandard rdf:type rdf:Property ;
    rdfs:label 'Governing Standard' ;
    rdfs:comment 'The primary regulatory standard, framework, or regulation that defines the requirements and scope of this audit program (e.g., IOSA Standards Manual, FAA Part 121, EASA Part-ORO, ISO 9001, CORSIA SARPs).' ;
    rdfs:domain ind:AuditProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAuditCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Last Audit Completion Date' ;
    rdfs:comment 'The date on which the most recent audit under this program was completed.' ;
    rdfs:domain ind:AuditProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextAuditDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Audit Due Date' ;
    rdfs:comment 'The scheduled date by which the next audit under this program must be completed to maintain compliance or certification.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:programCode rdf:type rdf:Property ;
    rdfs:label 'Program Code' ;
    rdfs:comment 'Unique business identifier code for the audit program (e.g., IOSA-2024, FAA-ATOS-01, EASA-STD-2023).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programCostEstimate rdf:type rdf:Property ;
    rdfs:label 'Program Cost Estimate' ;
    rdfs:comment 'Estimated annual or per-cycle cost to the airline for participation in this audit program, including audit fees, preparation costs, and corrective action implementation. Business-confidential financial data.' ;
    rdfs:domain ind:AuditProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:programEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Program Effective Date' ;
    rdfs:comment 'The date on which this audit program became effective and applicable to the airline.' ;
    rdfs:domain ind:AuditProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:programExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Program Expiry Date' ;
    rdfs:comment 'The date on which this audit program expires or is scheduled for renewal, if applicable. Null for ongoing programs without expiry.' ;
    rdfs:domain ind:AuditProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:programName rdf:type rdf:Property ;
    rdfs:label 'Program Name' ;
    rdfs:comment 'Full descriptive name of the audit program (e.g., IATA Operational Safety Audit, FAA Air Transportation Oversight System, EASA Standardization Inspection).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programNotes rdf:type rdf:Property ;
    rdfs:label 'Program Notes' ;
    rdfs:comment 'Free-text field for additional notes, special conditions, historical context, or operational guidance related to this audit program.' ;
    rdfs:domain ind:AuditProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programStatus rdf:type rdf:Property ;
    rdfs:label 'Program Status' ;
    rdfs:comment 'Current lifecycle status of the audit program indicating whether it is actively in force, temporarily suspended, under review for changes, pending regulatory approval, or archived.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicDisclosureRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Public Disclosure Required Flag' ;
    rdfs:comment 'Indicates whether audit results or certification status under this program must be publicly disclosed or reported to external stakeholders (true) or remain confidential (false).' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryMandateFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Mandate Flag' ;
    rdfs:comment 'Indicates whether participation in this audit program is mandated by regulatory authority (true) or is voluntary/internal (false).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scopeDescription rdf:type rdf:Property ;
    rdfs:label 'Scope Description' ;
    rdfs:comment 'Detailed description of the operational areas, processes, systems, and functions covered by this audit program (e.g., flight operations, maintenance, ground handling, crew training, safety management systems, environmental compliance).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emissionsReportId rdf:type rdf:Property ;
    rdfs:label 'Emissions Report Id' ;
    rdfs:comment 'Foreign key linking to compliance.emissions_report. Business justification: Carbon offsets are purchased and retired to meet obligations calculated in specific emissions reports. The retirement_certificate_reference and compliance_period tie the offset to a reporting period. ' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EmissionsReport .

ind:additionalityConfirmedFlag rdf:type rdf:Property ;
    rdfs:label 'Additionality Confirmed Flag' ;
    rdfs:comment 'Boolean indicator of whether the offset project has been confirmed to meet additionality criteria (i.e., the emission reductions would not have occurred without the carbon finance incentive). True indicates additionality confirmed; False indicates not confirmed or under review.' ;
    rdfs:domain ind:CarbonOffset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:allocationNotes rdf:type rdf:Property ;
    rdfs:label 'Allocation Notes' ;
    rdfs:comment 'Free-text notes describing how the offset units have been allocated to specific flights, routes, compliance periods, or customer programs. Used for internal tracking and audit documentation.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coBenefitsDescription rdf:type rdf:Property ;
    rdfs:label 'Co Benefits Description' ;
    rdfs:comment 'Free-text description of additional environmental or social co-benefits delivered by the offset project beyond carbon emission reductions. Examples include biodiversity conservation, community employment, water quality improvement, or renewable energy access.' ;
    rdfs:domain ind:CarbonOffset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractReference rdf:type rdf:Property ;
    rdfs:label 'Contract Reference' ;
    rdfs:comment 'Reference number or identifier of the purchase contract or agreement under which the offset units were acquired. Links to procurement and legal contract management systems.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:corsiaEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Corsia Eligible Flag' ;
    rdfs:comment 'Boolean indicator of whether the offset units are eligible for use under the ICAO CORSIA scheme. True indicates CORSIA-eligible units; False indicates voluntary-only units.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:offsetStatus rdf:type rdf:Property ;
    rdfs:label 'Offset Status' ;
    rdfs:comment 'Current lifecycle status of the carbon offset units. PURCHASED indicates units acquired but not yet retired; HELD indicates units in inventory; RETIRED indicates units permanently removed from circulation; CANCELLED indicates units invalidated; EXPIRED indicates units past their eligibility window.' ;
    rdfs:domain ind:CarbonOffset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offsetUnitType rdf:type rdf:Property ;
    rdfs:label 'Offset Unit Type' ;
    rdfs:comment 'Classification of the carbon offset unit according to the certification standard. CORSIA Eligible Emission Units are approved for ICAO CORSIA compliance; voluntary standards include VCS, Gold Standard, CAR, and ACR for voluntary carbon neutrality commitments. [ENUM-REF-CANDIDATE: CORSIA_ELIGIBLE_EMISSION_UNIT|VOLUNTARY_CARBON_STANDARD|GOLD_STANDARD|CLIMATE_ACTION_RESERVE|AMERICAN_CARBON_REGISTRY|VERIFIED_CARBON_STANDARD|PLAN_VIVO|SOCIAL_CARBON — promote to reference product]' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permanenceRiskRating rdf:type rdf:Property ;
    rdfs:label 'Permanence Risk Rating' ;
    rdfs:comment 'Assessment of the risk that the emission reductions or removals may be reversed in the future (e.g., reforestation projects at risk of fire or deforestation). LOW indicates minimal reversal risk; MEDIUM indicates moderate risk with mitigation measures; HIGH indicates significant risk requiring buffer reserves.' ;
    rdfs:domain ind:CarbonOffset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectCountryCode rdf:type rdf:Property ;
    rdfs:label 'Project Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code representing the country where the carbon offset project is located. Used for geographic analysis and compliance reporting.' ;
    rdfs:domain ind:CarbonOffset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectIdentifier rdf:type rdf:Property ;
    rdfs:label 'Project Identifier' ;
    rdfs:comment 'Unique identifier assigned to the carbon offset project by the certifying body or registry. Used for project-level tracking and reporting.' ;
    rdfs:domain ind:CarbonOffset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectName rdf:type rdf:Property ;
    rdfs:label 'Project Name' ;
    rdfs:comment 'Name of the carbon offset project that generated the emission reduction or removal units. Examples include renewable energy projects, reforestation initiatives, methane capture, or energy efficiency programs.' ;
    rdfs:domain ind:CarbonOffset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:projectType rdf:type rdf:Property ;
    rdfs:label 'Project Type' ;
    rdfs:comment 'Classification of the carbon offset project by the type of emission reduction or removal activity. Categories include renewable energy generation, reforestation and afforestation, methane capture from waste or agriculture, energy efficiency improvements, and avoided deforestation (REDD+). [ENUM-REF-CANDIDATE: RENEWABLE_ENERGY|REFORESTATION|AFFORESTATION|METHANE_CAPTURE|ENERGY_EFFICIENCY|AVOIDED_DEFORESTATION|SOIL_CARBON_SEQUESTRATION|DIRECT_AIR_CAPTURE|BLUE_CARBON — promote to reference product]' ;
    rdfs:domain ind:CarbonOffset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Purchase Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the purchase transaction. Examples include USD, EUR, GBP.' ;
    rdfs:domain ind:CarbonOffset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseDate rdf:type rdf:Property ;
    rdfs:label 'Purchase Date' ;
    rdfs:comment 'The date on which the airline purchased or acquired the carbon offset units. Used for financial accounting, portfolio management, and compliance period allocation.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchasePricePerTonne rdf:type rdf:Property ;
    rdfs:label 'Purchase Price Per Tonne' ;
    rdfs:comment 'The unit price paid per tonne of CO2e offset, in the transaction currency. Used for cost analysis, budgeting, and carbon pricing strategy evaluation.' ;
    rdfs:domain ind:CarbonOffset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityTonnesCo2e rdf:type rdf:Property ;
    rdfs:label 'Quantity Tonnes Co2e' ;
    rdfs:comment 'The quantity of carbon offset units in this record, measured in metric tonnes of carbon dioxide equivalent (CO2e). Represents the total emission reductions or removals covered by this offset batch.' ;
    rdfs:domain ind:CarbonOffset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:registryIdentifier rdf:type rdf:Property ;
    rdfs:label 'Registry Identifier' ;
    rdfs:comment 'Unique identifier or serial number assigned by the carbon offset registry to this batch of offset units. Used for traceability and verification of offset authenticity.' ;
    rdfs:domain ind:CarbonOffset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registryName rdf:type rdf:Property ;
    rdfs:label 'Registry Name' ;
    rdfs:comment 'Name of the carbon offset registry where the offset units are registered and tracked. Examples include Verra Registry, Gold Standard Registry, American Carbon Registry, Climate Action Reserve, or national registries.' ;
    rdfs:domain ind:CarbonOffset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retirementCertificateReference rdf:type rdf:Property ;
    rdfs:label 'Retirement Certificate Reference' ;
    rdfs:comment 'Reference number or identifier of the official retirement certificate issued by the carbon registry. Provides proof of retirement for audit and compliance verification.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalPurchaseAmount rdf:type rdf:Property ;
    rdfs:label 'Total Purchase Amount' ;
    rdfs:comment 'The total amount paid for this batch of carbon offset units in the purchase currency. Calculated as quantity_tonnes_co2e multiplied by purchase_price_per_tonne.' ;
    rdfs:domain ind:CarbonOffset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:verificationBody rdf:type rdf:Property ;
    rdfs:label 'Verification Body' ;
    rdfs:comment 'Name of the independent third-party organization that verified the emission reductions of the offset project. Used for credibility assessment and audit trail.' ;
    rdfs:domain ind:CarbonOffset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationStandard rdf:type rdf:Property ;
    rdfs:label 'Verification Standard' ;
    rdfs:comment 'The third-party verification standard or methodology used to validate the emission reductions of the offset project. Examples include CDM (Clean Development Mechanism), VCS (Verified Carbon Standard), Gold Standard, or ISO 14064.' ;
    rdfs:domain ind:CarbonOffset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vintageYear rdf:type rdf:Property ;
    rdfs:label 'Vintage Year' ;
    rdfs:comment 'The year in which the emission reductions or removals represented by the offset units occurred. Vintage year is critical for CORSIA compliance period matching and offset eligibility determination.' ;
    rdfs:domain ind:CarbonOffset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capaId rdf:type rdf:Property ;
    rdfs:label 'Capa Id' ;
    rdfs:comment 'Unique identifier for the corrective and preventive action record. Primary key.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Capa .

ind:auditId rdf:type rdf:Property ;
    rdfs:label 'Audit Id' ;
    rdfs:comment 'Foreign key reference to the audit record that generated this CAPA, if applicable. Links to compliance audit management system.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Audit .

ind:capaAssignedOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Capa Assigned Owner Employee Id' ;
    rdfs:comment 'Employee identifier of the CAPA owner. Links to workforce management system for accountability tracking.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:capaClosureApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Capa Closure Approved By Employee Id' ;
    rdfs:comment 'Employee identifier of the approver who authorized CAPA closure. Provides audit trail for closure authority.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:capaVerifiedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Capa Verified By Employee Id' ;
    rdfs:comment 'Employee identifier of the verifier. Provides audit trail for verification accountability.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:findingId rdf:type rdf:Property ;
    rdfs:label 'Finding Id' ;
    rdfs:comment 'Foreign key reference to the specific audit finding or non-conformance record that triggered this CAPA.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Finding .

ind:regulatoryViolationId rdf:type rdf:Property ;
    rdfs:label 'Regulatory Violation Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_violation. Business justification: Many CAPAs are raised in response to regulatory violations (enforcement actions). FK links CAPA to the violation that triggered it. Nullable - not all CAPAs stem from violations (some from audit findi' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryViolation .

ind:actionDescription rdf:type rdf:Property ;
    rdfs:label 'Action Description' ;
    rdfs:comment 'Detailed description of the corrective or preventive action to be taken, including specific steps, process changes, training requirements, system modifications, or procedural updates required to address the non-conformance and prevent recurrence.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Date' ;
    rdfs:comment 'Actual date when the action was completed and submitted for verification. Null if action is still in progress.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualCostUsd rdf:type rdf:Property ;
    rdfs:label 'Actual Cost Usd' ;
    rdfs:comment 'Actual cost in USD incurred to implement the CAPA. Null if action is not yet complete or costs have not been finalized.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignedOwnerName rdf:type rdf:Property ;
    rdfs:label 'Assigned Owner Name' ;
    rdfs:comment 'Full name of the individual assigned as the owner and accountable party for completing this CAPA. This is a business reference, not direct PII of a customer.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaNumber rdf:type rdf:Property ;
    rdfs:label 'Capa Number' ;
    rdfs:comment 'Business identifier for the CAPA record, typically formatted as CAPA-NNNNNN. Used for external reference and tracking.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaStatus rdf:type rdf:Property ;
    rdfs:label 'Capa Status' ;
    rdfs:comment 'Current lifecycle status of the CAPA: open (newly created), in_progress (action being implemented), pending_verification (awaiting effectiveness check), verified (action confirmed effective), closed (completed and approved), cancelled (no longer required).' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capaType rdf:type rdf:Property ;
    rdfs:label 'Capa Type' ;
    rdfs:comment 'Classification of the action: corrective (addresses existing non-conformance), preventive (prevents potential non-conformance), systemic (addresses root cause across organization), immediate (short-term containment), interim (temporary solution), or permanent (long-term resolution).' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureApprovedByName rdf:type rdf:Property ;
    rdfs:label 'Closure Approved By Name' ;
    rdfs:comment 'Full name of the individual who approved the closure of the CAPA (typically Quality Manager, Compliance Manager, or Accountable Manager).' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureDate rdf:type rdf:Property ;
    rdfs:label 'Closure Date' ;
    rdfs:comment 'Date when the CAPA was formally closed after successful verification and approval. Null if CAPA is still open.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:costEstimateUsd rdf:type rdf:Property ;
    rdfs:label 'Cost Estimate Usd' ;
    rdfs:comment 'Estimated cost in USD to implement the corrective or preventive action, including labor, materials, training, system changes, and external consulting. Used for budgeting and cost-benefit analysis.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nonConformanceDescription rdf:type rdf:Property ;
    rdfs:label 'Non Conformance Description' ;
    rdfs:comment 'Detailed description of the non-conformance, deficiency, violation, or gap that necessitated this CAPA. Includes what was observed, what standard was violated, and the potential or actual impact.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priority rdf:type rdf:Property ;
    rdfs:label 'Priority' ;
    rdfs:comment 'Urgency level of the CAPA based on safety impact, regulatory risk, and operational criticality. Critical indicates immediate safety or regulatory threat.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recurrenceFlag rdf:type rdf:Property ;
    rdfs:label 'Recurrence Flag' ;
    rdfs:comment 'Indicates whether this CAPA addresses a recurring non-conformance (True) or a first-time occurrence (False). Used to identify systemic issues requiring deeper root cause analysis.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryReportableFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reportable Flag' ;
    rdfs:comment 'Indicates whether this CAPA must be reported to a regulatory authority (True) or is internal only (False). Drives external reporting and notification workflows.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:riskLevelAfter rdf:type rdf:Property ;
    rdfs:label 'Risk Level After' ;
    rdfs:comment 'Assessed risk level after the CAPA was implemented and verified. Demonstrates residual risk and effectiveness of risk mitigation.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskLevelBefore rdf:type rdf:Property ;
    rdfs:label 'Risk Level Before' ;
    rdfs:comment 'Assessed risk level of the non-conformance before the CAPA was implemented. Used to measure risk reduction effectiveness.' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseAnalysis rdf:type rdf:Property ;
    rdfs:label 'Root Cause Analysis' ;
    rdfs:comment 'Summary of the root cause investigation findings, identifying underlying systemic factors that led to the non-conformance. May reference techniques used (5 Whys, Fishbone, Fault Tree Analysis).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:smsIntegrationFlag rdf:type rdf:Property ;
    rdfs:label 'Sms Integration Flag' ;
    rdfs:comment 'Indicates whether this CAPA is integrated with the airline\'s Safety Management System (SMS) for safety risk tracking and hazard management (True) or is purely a quality/compliance action (False).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Source Reference Number' ;
    rdfs:comment 'External reference identifier linking this CAPA to the originating event, audit finding, violation notice, or incident report (e.g., audit report number, FAA enforcement case number, SMS occurrence ID).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceType rdf:type rdf:Property ;
    rdfs:label 'Source Type' ;
    rdfs:comment 'Origin of the CAPA: audit_finding (internal or external audit), regulatory_violation (FAA/EASA/DOT enforcement), safety_occurrence (SMS event), incident (operational disruption), customer_complaint, internal_inspection, or sms_report (Safety Management System report). [ENUM-REF-CANDIDATE: audit_finding|regulatory_violation|safety_occurrence|incident|customer_complaint|internal_inspection|sms_report — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Target Completion Date' ;
    rdfs:comment 'Planned date by which the corrective or preventive action must be fully implemented. Often driven by regulatory deadlines or audit response timelines.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verificationDate rdf:type rdf:Property ;
    rdfs:label 'Verification Date' ;
    rdfs:comment 'Date when the effectiveness of the CAPA was verified and confirmed. Null if verification has not yet occurred.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verificationMethod rdf:type rdf:Property ;
    rdfs:label 'Verification Method' ;
    rdfs:comment 'Method used to verify the effectiveness of the CAPA: document_review (procedure/record review), on_site_inspection (physical verification), process_audit (follow-up audit), data_analysis (trend analysis), testing (functional test), observation (operational observation), interview (staff interviews). [ENUM-REF-CANDIDATE: document_review|on_site_inspection|process_audit|data_analysis|testing|observation|interview — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationResult rdf:type rdf:Property ;
    rdfs:label 'Verification Result' ;
    rdfs:comment 'Outcome of the effectiveness verification: effective (action resolved the issue), partially_effective (some improvement but further action needed), ineffective (action did not resolve issue), pending (verification not yet complete).' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verifiedByName rdf:type rdf:Property ;
    rdfs:label 'Verified By Name' ;
    rdfs:comment 'Full name of the individual who performed the effectiveness verification (typically Quality Assurance, Safety, or Compliance personnel).' ;
    rdfs:domain ind:Capa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Finding Employee Id' ;
    rdfs:comment 'Reference to the employee or organizational unit assigned as the owner responsible for implementing corrective action to address the finding.' ;
    rdfs:domain ind:Finding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:findingIdentifiedByAuditorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Finding Identified By Auditor Employee Id' ;
    rdfs:comment 'Reference to the auditor or inspector who identified and documented the finding during the audit event.' ;
    rdfs:domain ind:Finding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:findingVerifiedByAuditorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Finding Verified By Auditor Employee Id' ;
    rdfs:comment 'Reference to the auditor or quality assurance personnel who verified the corrective action effectiveness and approved finding closure.' ;
    rdfs:domain ind:Finding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:previousFindingId rdf:type rdf:Property ;
    rdfs:label 'Previous Finding Id' ;
    rdfs:comment 'Reference to the previous compliance finding record if this is a recurrence. Links related findings for trend analysis and corrective action effectiveness assessment.' ;
    rdfs:domain ind:Finding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Finding .

ind:affectedArea rdf:type rdf:Property ;
    rdfs:label 'Affected Area' ;
    rdfs:comment 'The operational area, department, station, or functional unit where the finding was identified. Examples include maintenance hangar, flight operations, ground handling, crew scheduling, or specific airport station codes.' ;
    rdfs:domain ind:Finding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedProcess rdf:type rdf:Property ;
    rdfs:label 'Affected Process' ;
    rdfs:comment 'The specific business process or operational procedure affected by the finding. Examples include aircraft maintenance procedures, crew duty time tracking, baggage handling, fuel uplift procedures, or dispatch release processes.' ;
    rdfs:domain ind:Finding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:airworthinessImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Airworthiness Impact Flag' ;
    rdfs:comment 'Boolean indicator of whether the finding affects aircraft airworthiness certification or continuing airworthiness compliance. True indicates potential impact on aircraft operational approval.' ;
    rdfs:domain ind:Finding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:applicableRegulation rdf:type rdf:Property ;
    rdfs:label 'Applicable Regulation' ;
    rdfs:comment 'The specific regulatory requirement, standard, or internal policy that the finding relates to. May reference FAA regulations (14 CFR parts), EASA regulations (Part-145, Part-M), ICAO Annexes, or internal Standard Operating Procedures (SOP).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureNotes rdf:type rdf:Property ;
    rdfs:label 'Closure Notes' ;
    rdfs:comment 'Final notes and comments documenting the closure of the finding, including verification results, lessons learned, and any residual monitoring requirements.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Completion Date' ;
    rdfs:comment 'Actual date when the corrective action was completed and implemented. Null until corrective action is finished.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionDescription rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Description' ;
    rdfs:comment 'Detailed description of the corrective action plan developed to address the finding and prevent recurrence. Documents the specific steps, process changes, training, or system modifications to be implemented.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingDescription rdf:type rdf:Property ;
    rdfs:label 'Finding Description' ;
    rdfs:comment 'Detailed narrative description of the finding, including the specific non-conformance, observation, or concern identified. Documents what was observed, where it was found, and the circumstances of the discovery.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingStatus rdf:type rdf:Property ;
    rdfs:label 'Finding Status' ;
    rdfs:comment 'Current lifecycle status of the finding from identification through closure. Tracks the progression of corrective action implementation and verification. [ENUM-REF-CANDIDATE: open|under_investigation|corrective_action_assigned|corrective_action_in_progress|pending_verification|closed|reopened — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingType rdf:type rdf:Property ;
    rdfs:label 'Finding Type' ;
    rdfs:comment 'Classification of the finding severity and nature. Major non-conformance requires immediate corrective action and may affect airworthiness or operational approval. Minor non-conformance requires corrective action but does not pose immediate safety risk. Observation is a noted concern without regulatory breach. Commendation recognizes exemplary compliance.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identificationDate rdf:type rdf:Property ;
    rdfs:label 'Identification Date' ;
    rdfs:comment 'Date when the finding was first identified during the audit or inspection. Represents the business event timestamp for the discovery of the non-conformance or observation.' ;
    rdfs:domain ind:Finding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulationSection rdf:type rdf:Property ;
    rdfs:label 'Regulation Section' ;
    rdfs:comment 'Specific section, paragraph, or clause number within the applicable regulation or standard that was not met or was the subject of the finding.' ;
    rdfs:domain ind:Finding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Date' ;
    rdfs:comment 'Date when the finding was formally reported to the applicable regulatory authority. Null if regulatory notification is not required.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reference Number' ;
    rdfs:comment 'Reference number or case identifier assigned by the regulatory authority for tracking this finding. Used for correspondence and follow-up with FAA, EASA, or CAA.' ;
    rdfs:domain ind:Finding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskLevel rdf:type rdf:Property ;
    rdfs:label 'Risk Level' ;
    rdfs:comment 'Assessment of the safety or operational risk level associated with the finding. Critical findings may affect airworthiness or pose immediate safety hazards. Used to prioritize corrective action urgency.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseCategory rdf:type rdf:Property ;
    rdfs:label 'Root Cause Category' ;
    rdfs:comment 'High-level categorization of the underlying root cause of the finding. Used for trend analysis and systemic issue identification across the compliance program. [ENUM-REF-CANDIDATE: human_error|inadequate_training|procedure_not_followed|procedure_inadequate|equipment_failure|system_failure|resource_constraint|communication_breakdown|supervision_inadequate|documentation_error|other — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Impact Flag' ;
    rdfs:comment 'Boolean indicator of whether the finding has direct safety implications for flight operations, airworthiness, or passenger/crew safety. True indicates safety-related finding requiring elevated attention.' ;
    rdfs:domain ind:Finding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:consumerProtectionCaseId rdf:type rdf:Property ;
    rdfs:label 'Consumer Protection Case Id' ;
    rdfs:comment 'Unique identifier for the consumer protection compliance case. Primary key.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ConsumerProtectionCase .

ind:caseManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Case Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: DOT/EC261 consumer protection cases require assigned case managers for resolution tracking, regulatory reporting, and customer communication. FK enables workload balancing, performance tracking, and v' ;
    rdfs:domain ind:ConsumerProtectionCase ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:cateringOrderId rdf:type rdf:Property ;
    rdfs:label 'Catering Order Id' ;
    rdfs:comment 'Foreign key linking to procurement.catering_order. Business justification: Consumer protection cases (food safety incidents, allergen violations, meal quality complaints) often trace back to specific catering orders. Airlines must link cases to orders for root cause analysis' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CateringOrder .

ind:accessibilityViolationFlag rdf:type rdf:Property ;
    rdfs:label 'Accessibility Violation Flag' ;
    rdfs:comment 'Indicates whether this case involves a violation of accessibility requirements under the Air Carrier Access Act (ACAA) for passengers with disabilities.' ;
    rdfs:domain ind:ConsumerProtectionCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:accessibilityViolationType rdf:type rdf:Property ;
    rdfs:label 'Accessibility Violation Type' ;
    rdfs:comment 'Specific type of ACAA accessibility violation if applicable (e.g., wheelchair damage, service animal denial, boarding assistance failure).' ;
    rdfs:domain ind:ConsumerProtectionCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualValue rdf:type rdf:Property ;
    rdfs:label 'Actual Value' ;
    rdfs:comment 'Actual measured value of the incident metric (e.g., 195 minutes for a tarmac delay that exceeded the 180-minute threshold).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:caseNotes rdf:type rdf:Property ;
    rdfs:label 'Case Notes' ;
    rdfs:comment 'Additional notes, comments, or context related to the consumer protection case for internal tracking and audit purposes.' ;
    rdfs:domain ind:ConsumerProtectionCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseNumber rdf:type rdf:Property ;
    rdfs:label 'Case Number' ;
    rdfs:comment 'External case reference number assigned by the airline or regulatory authority for tracking and reporting purposes.' ;
    rdfs:domain ind:ConsumerProtectionCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseStatus rdf:type rdf:Property ;
    rdfs:label 'Case Status' ;
    rdfs:comment 'Current lifecycle status of the consumer protection case indicating its resolution progress.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseType rdf:type rdf:Property ;
    rdfs:label 'Case Type' ;
    rdfs:comment 'Classification of the consumer protection case type based on the nature of the regulatory incident or violation. [ENUM-REF-CANDIDATE: denied_boarding|tarmac_delay|baggage_liability|fare_advertising|accessibility_acaa|refund_delay|cancellation_compensation|downgrade_compensation — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compensationAmountTotal rdf:type rdf:Property ;
    rdfs:label 'Compensation Amount Total' ;
    rdfs:comment 'Total monetary compensation paid or owed to all affected passengers for this consumer protection case.' ;
    rdfs:domain ind:ConsumerProtectionCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compensationPerPassenger rdf:type rdf:Property ;
    rdfs:label 'Compensation Per Passenger' ;
    rdfs:comment 'Standard compensation amount paid per affected passenger as required by regulatory guidelines.' ;
    rdfs:domain ind:ConsumerProtectionCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compensationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Compensation Required Flag' ;
    rdfs:comment 'Indicates whether regulatory compensation is required to be paid to affected passengers based on the incident type and jurisdiction.' ;
    rdfs:domain ind:ConsumerProtectionCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complaintReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Complaint Receipt Date' ;
    rdfs:comment 'Date on which the passenger complaint related to this incident was received by the airline.' ;
    rdfs:domain ind:ConsumerProtectionCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dotCaseReference rdf:type rdf:Property ;
    rdfs:label 'Dot Case Reference' ;
    rdfs:comment 'Official DOT case reference number if the incident was reported to or investigated by the US Department of Transportation.' ;
    rdfs:domain ind:ConsumerProtectionCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:easaCaseReference rdf:type rdf:Property ;
    rdfs:label 'Easa Case Reference' ;
    rdfs:comment 'Official EASA or national CAA case reference number if the incident occurred under EU jurisdiction and was reported to European authorities.' ;
    rdfs:domain ind:ConsumerProtectionCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Incident Timestamp' ;
    rdfs:comment 'Precise timestamp when the consumer protection incident occurred, used for tarmac delay threshold calculations and regulatory reporting.' ;
    rdfs:domain ind:ConsumerProtectionCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:passengerComplaintReceivedFlag rdf:type rdf:Property ;
    rdfs:label 'Passenger Complaint Received Flag' ;
    rdfs:comment 'Indicates whether a formal passenger complaint was received related to this consumer protection incident.' ;
    rdfs:domain ind:ConsumerProtectionCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:passengerCountAffected rdf:type rdf:Property ;
    rdfs:label 'Passenger Count Affected' ;
    rdfs:comment 'Total number of passengers affected by the consumer protection incident, used for regulatory reporting and compensation calculations.' ;
    rdfs:domain ind:ConsumerProtectionCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryThresholdBreached rdf:type rdf:Property ;
    rdfs:label 'Regulatory Threshold Breached' ;
    rdfs:comment 'Indicates whether the incident exceeded regulatory thresholds requiring mandatory reporting or compensation (e.g., 3-hour tarmac delay for domestic flights, 4-hour for international).' ;
    rdfs:domain ind:ConsumerProtectionCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportSubmissionDate rdf:type rdf:Property ;
    rdfs:label 'Report Submission Date' ;
    rdfs:comment 'Date on which the consumer protection case was formally reported to the regulatory authority.' ;
    rdfs:domain ind:ConsumerProtectionCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportedToAuthorityFlag rdf:type rdf:Property ;
    rdfs:label 'Reported To Authority Flag' ;
    rdfs:comment 'Indicates whether this case has been formally reported to the applicable regulatory authority as required by consumer protection regulations.' ;
    rdfs:domain ind:ConsumerProtectionCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resolutionDate rdf:type rdf:Property ;
    rdfs:label 'Resolution Date' ;
    rdfs:comment 'Date on which the consumer protection case was resolved, including all compensation payments and corrective actions completed.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:resolutionDescription rdf:type rdf:Property ;
    rdfs:label 'Resolution Description' ;
    rdfs:comment 'Detailed narrative describing how the consumer protection case was resolved, including actions taken and compensation provided.' ;
    rdfs:domain ind:ConsumerProtectionCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseDescription rdf:type rdf:Property ;
    rdfs:label 'Root Cause Description' ;
    rdfs:comment 'Detailed explanation of the root cause analysis findings for the consumer protection incident.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdType rdf:type rdf:Property ;
    rdfs:label 'Threshold Type' ;
    rdfs:comment 'Specific regulatory threshold category that was breached or evaluated in this case.' ;
    rdfs:domain ind:ConsumerProtectionCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdUnit rdf:type rdf:Property ;
    rdfs:label 'Threshold Unit' ;
    rdfs:comment 'Unit of measure for the regulatory threshold value (e.g., minutes for tarmac delays, passengers for denied boarding).' ;
    rdfs:domain ind:ConsumerProtectionCase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdValue rdf:type rdf:Property ;
    rdfs:label 'Threshold Value' ;
    rdfs:comment 'Numeric value of the regulatory threshold applicable to this case (e.g., 180 minutes for domestic tarmac delay).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelContractId rdf:type rdf:Property ;
    rdfs:label 'Fuel Contract Id' ;
    rdfs:comment 'Foreign key linking to procurement.fuel_contract. Business justification: Emissions reports are calculated from fuel consumption tied to specific fuel contracts. Contract-level carbon intensity, SAF percentage, and fuel type drive CORSIA and EU ETS reporting. Real regulator' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FuelContract .

ind:compliancePeriod rdf:type rdf:Property ;
    rdfs:label 'Compliance Period' ;
    rdfs:comment 'The compliance year to which this emissions report applies, formatted as YYYY.' ;
    rdfs:domain ind:EmissionsReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emissionFactor rdf:type rdf:Property ;
    rdfs:label 'Emission Factor' ;
    rdfs:comment 'Emission factor applied in the calculation, expressed as kilograms of CO2 per kilogram of fuel burned.' ;
    rdfs:domain ind:EmissionsReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emissionsCalculationMethodology rdf:type rdf:Property ;
    rdfs:label 'Emissions Calculation Methodology' ;
    rdfs:comment 'Methodology used to calculate emissions: CORSIA CERT, ICAO Default factors, Actual Fuel Burn measurement, or Third Party Tool.' ;
    rdfs:domain ind:EmissionsReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelBurnTonnes rdf:type rdf:Property ;
    rdfs:label 'Fuel Burn Tonnes' ;
    rdfs:comment 'Total fuel consumed in metric tonnes during the reporting period and scope.' ;
    rdfs:domain ind:EmissionsReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:offsetObligationTonnes rdf:type rdf:Property ;
    rdfs:label 'Offset Obligation Tonnes' ;
    rdfs:comment 'Total carbon offset obligation in tonnes of CO2 equivalent that must be retired to achieve compliance for this reporting period.' ;
    rdfs:domain ind:EmissionsReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:offsetProjectCountry rdf:type rdf:Property ;
    rdfs:label 'Offset Project Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the country where the carbon offset project is located.' ;
    rdfs:domain ind:EmissionsReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offsetProjectName rdf:type rdf:Property ;
    rdfs:label 'Offset Project Name' ;
    rdfs:comment 'Name of the carbon offset project from which the offset units were sourced.' ;
    rdfs:domain ind:EmissionsReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offsetRegistry rdf:type rdf:Property ;
    rdfs:label 'Offset Registry' ;
    rdfs:comment 'Name of the carbon offset registry where the offset units are registered and retired (e.g., Verra, Gold Standard, CDM Registry). [ENUM-REF-CANDIDATE: Verra|Gold Standard|CDM Registry|American Carbon Registry|Climate Action Reserve|Plan Vivo|APX — promote to reference product]' ;
    rdfs:domain ind:EmissionsReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offsetVintageYear rdf:type rdf:Property ;
    rdfs:label 'Offset Vintage Year' ;
    rdfs:comment 'The vintage year of the carbon offset units, representing the year in which the emission reductions occurred.' ;
    rdfs:domain ind:EmissionsReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:offsetsRetiredTonnes rdf:type rdf:Property ;
    rdfs:label 'Offsets Retired Tonnes' ;
    rdfs:comment 'Total carbon offsets in tonnes of CO2 equivalent that have been retired against this report to meet the compliance obligation.' ;
    rdfs:domain ind:EmissionsReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reconciliationStatus rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Status' ;
    rdfs:comment 'Status of the reconciliation between offset obligation and offsets retired: pending, reconciled (fully met), shortfall (under-compliance), or surplus (over-compliance).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportNumber rdf:type rdf:Property ;
    rdfs:label 'Report Number' ;
    rdfs:comment 'Externally-known unique business identifier for the emissions report, formatted as EMR-YYYY-NNNNNN.' ;
    rdfs:domain ind:EmissionsReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportStatus rdf:type rdf:Property ;
    rdfs:label 'Report Status' ;
    rdfs:comment 'Current lifecycle status of the emissions report (draft, submitted, under_verification, verified, accepted, rejected).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportType rdf:type rdf:Property ;
    rdfs:label 'Report Type' ;
    rdfs:comment 'Type of emissions report: annual, quarterly, ad_hoc, or amendment to a prior submission.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingPeriodEnd rdf:type rdf:Property ;
    rdfs:label 'Reporting Period End' ;
    rdfs:comment 'End date of the emissions reporting period covered by this report.' ;
    rdfs:domain ind:EmissionsReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingPeriodStart rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Start' ;
    rdfs:comment 'Start date of the emissions reporting period covered by this report.' ;
    rdfs:domain ind:EmissionsReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:routeCode rdf:type rdf:Property ;
    rdfs:label 'Route Code' ;
    rdfs:comment 'IATA airport code pair representing the route or sector covered (e.g., JFK-LHR). Null for fleet-wide reports.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safPercentage rdf:type rdf:Property ;
    rdfs:label 'Saf Percentage' ;
    rdfs:comment 'Percentage of total fuel burn that was Sustainable Aviation Fuel (SAF) during the reporting period.' ;
    rdfs:domain ind:EmissionsReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scope rdf:type rdf:Property ;
    rdfs:label 'Scope' ;
    rdfs:comment 'Scope of emissions covered: fleet_wide (all operations), route_specific, sector_specific, or aircraft_specific.' ;
    rdfs:domain ind:EmissionsReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortfallTonnes rdf:type rdf:Property ;
    rdfs:label 'Shortfall Tonnes' ;
    rdfs:comment 'Amount of carbon offset shortfall in tonnes CO2e if the offset obligation has not been fully met. Null if reconciled or surplus.' ;
    rdfs:domain ind:EmissionsReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:submissionDate rdf:type rdf:Property ;
    rdfs:label 'Submission Date' ;
    rdfs:comment 'Date on which the emissions report was submitted to the regulatory authority or compliance scheme administrator.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:submissionMethod rdf:type rdf:Property ;
    rdfs:label 'Submission Method' ;
    rdfs:comment 'Method used to submit the report: online_portal, email, postal, or API integration.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surplusTonnes rdf:type rdf:Property ;
    rdfs:label 'Surplus Tonnes' ;
    rdfs:comment 'Amount of carbon offset surplus in tonnes CO2e if more offsets were retired than required. Null if reconciled or shortfall.' ;
    rdfs:domain ind:EmissionsReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCo2EmissionsTonnes rdf:type rdf:Property ;
    rdfs:label 'Total Co2 Emissions Tonnes' ;
    rdfs:comment 'Total carbon dioxide emissions in metric tonnes (CO2) for the reporting period and scope.' ;
    rdfs:domain ind:EmissionsReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:verificationStatementReference rdf:type rdf:Property ;
    rdfs:label 'Verification Statement Reference' ;
    rdfs:comment 'Reference number or document identifier of the verification statement issued by the verifier.' ;
    rdfs:domain ind:EmissionsReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationStatus rdf:type rdf:Property ;
    rdfs:label 'Verification Status' ;
    rdfs:comment 'Status of third-party verification: not_required, pending, in_progress, verified, or failed.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verifierAccreditationNumber rdf:type rdf:Property ;
    rdfs:label 'Verifier Accreditation Number' ;
    rdfs:comment 'Accreditation number of the verification body issued by the national accreditation authority.' ;
    rdfs:domain ind:EmissionsReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verifierName rdf:type rdf:Property ;
    rdfs:label 'Verifier Name' ;
    rdfs:comment 'Name of the accredited third-party verification body that verified the emissions report.' ;
    rdfs:domain ind:EmissionsReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exemptionWaiverId rdf:type rdf:Property ;
    rdfs:label 'Exemption Waiver Id' ;
    rdfs:comment 'Unique identifier for the regulatory exemption or waiver record. Primary key.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ExemptionWaiver .

ind:responsibleEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Responsible Employee Id' ;
    rdfs:comment 'Employee identifier of the individual accountable for managing this exemption or waiver and ensuring ongoing compliance with its conditions.' ;
    rdfs:domain ind:ExemptionWaiver ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:supplyContractId rdf:type rdf:Property ;
    rdfs:label 'Supply Contract Id' ;
    rdfs:comment 'Foreign key linking to procurement.supply_contract. Business justification: Exemptions/waivers may be granted based on contractual arrangements (e.g., COVID relief tied to specific vendor agreements, temporary operational waivers linked to supply contracts). Airlines track wh' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SupplyContract .

ind:aircraftTypeIcaoCode rdf:type rdf:Property ;
    rdfs:label 'Aircraft Type Icao Code' ;
    rdfs:comment 'ICAO aircraft type designator code for aircraft covered by this exemption or waiver (e.g., B738 for Boeing 737-800, A320 for Airbus A320). Null if exemption applies to all aircraft types or is not aircraft-specific.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationDate rdf:type rdf:Property ;
    rdfs:label 'Application Date' ;
    rdfs:comment 'Date when the exemption or waiver application was formally submitted to the regulatory authority.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:applicationStatus rdf:type rdf:Property ;
    rdfs:label 'Application Status' ;
    rdfs:comment 'Current lifecycle status of the exemption or waiver application (e.g., draft, submitted, under review, approved, denied, withdrawn, expired, renewed). [ENUM-REF-CANDIDATE: draft|submitted|under_review|approved|denied|withdrawn|expired|renewed — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalDate rdf:type rdf:Property ;
    rdfs:label 'Approval Date' ;
    rdfs:comment 'Date when the exemption or waiver was officially granted by the regulatory authority. Null if not yet approved.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceProgramReference rdf:type rdf:Property ;
    rdfs:label 'Compliance Program Reference' ;
    rdfs:comment 'Reference to the internal compliance program or audit program that monitors adherence to the conditions of this exemption or waiver.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionsAttached rdf:type rdf:Property ;
    rdfs:label 'Conditions Attached' ;
    rdfs:comment 'Specific conditions, limitations, or requirements imposed by the regulatory authority as part of granting the exemption or waiver. May include operational restrictions, reporting obligations, or compensating controls.' ;
    rdfs:domain ind:ExemptionWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:corsiaExemptionFlag rdf:type rdf:Property ;
    rdfs:label 'Corsia Exemption Flag' ;
    rdfs:comment 'Indicates whether this exemption or waiver relates to CORSIA emissions reporting or carbon offset requirements (True) or not (False).' ;
    rdfs:domain ind:ExemptionWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:covidReliefFlag rdf:type rdf:Property ;
    rdfs:label 'Covid Relief Flag' ;
    rdfs:comment 'Indicates whether this exemption or waiver was granted as part of COVID-19 pandemic relief measures (True) or not (False). Includes slot waivers and operational relief during the pandemic.' ;
    rdfs:domain ind:ExemptionWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:documentReferenceUrl rdf:type rdf:Property ;
    rdfs:label 'Document Reference Url' ;
    rdfs:comment 'URL or file path to the official exemption or waiver document, approval letter, or supporting documentation stored in the document management system.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:etopsDiversionTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Etops Diversion Time Minutes' ;
    rdfs:comment 'Maximum diversion time in minutes for ETOPS operations covered by this exemption or waiver (e.g., 120, 180, 207). Applicable only to ETOPS-related exemptions.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:exemptionNumber rdf:type rdf:Property ;
    rdfs:label 'Exemption Number' ;
    rdfs:comment 'Official exemption or waiver number assigned by the issuing regulatory authority (e.g., FAA exemption number, EASA deviation approval number).' ;
    rdfs:domain ind:ExemptionWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exemptionType rdf:type rdf:Property ;
    rdfs:label 'Exemption Type' ;
    rdfs:comment 'Classification of the exemption or waiver type (e.g., regulatory exemption, operational waiver, airworthiness deviation, slot waiver, special flight permit, ETOPS deviation). [ENUM-REF-CANDIDATE: regulatory_exemption|operational_waiver|airworthiness_deviation|slot_waiver|special_flight_permit|etops_deviation|temporary_relief|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ExemptionWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastRenewalDate rdf:type rdf:Property ;
    rdfs:label 'Last Renewal Date' ;
    rdfs:comment 'Date of the most recent renewal of the exemption or waiver. Null if never renewed or if this is the original grant.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextRenewalDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Renewal Due Date' ;
    rdfs:comment 'Date by which the next renewal application must be submitted to maintain continuous validity. Null if renewal is not required.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalFrequencyMonths rdf:type rdf:Property ;
    rdfs:label 'Renewal Frequency Months' ;
    rdfs:comment 'Frequency in months at which the exemption or waiver must be renewed. Null if renewal is not required or frequency is not specified.' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:renewalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Renewal Required Flag' ;
    rdfs:comment 'Indicates whether the exemption or waiver requires periodic renewal (True) or is granted indefinitely (False).' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requestingBasis rdf:type rdf:Property ;
    rdfs:label 'Requesting Basis' ;
    rdfs:comment 'Business or operational justification for requesting the exemption or waiver. Describes why relief from the regulation is necessary and how equivalent safety or compliance will be maintained.' ;
    rdfs:domain ind:ExemptionWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeScope rdf:type rdf:Property ;
    rdfs:label 'Route Scope' ;
    rdfs:comment 'Geographic or route-specific scope of the exemption or waiver (e.g., specific city pairs, regions, or route networks). Null if exemption applies to all routes.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withdrawalReason rdf:type rdf:Property ;
    rdfs:label 'Withdrawal Reason' ;
    rdfs:comment 'Reason for withdrawing the exemption or waiver application by the airline. Null if not withdrawn.' ;
    rdfs:domain ind:ExemptionWaiver ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:foreignCarrierPermitId rdf:type rdf:Property ;
    rdfs:label 'Foreign Carrier Permit Id' ;
    rdfs:comment 'Unique identifier for the foreign carrier permit record. Primary key.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ForeignCarrierPermit .

ind:permitOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Permit Owner Employee Id' ;
    rdfs:comment 'Employee ID of the individual responsible for managing this permit and ensuring compliance with its conditions.' ;
    rdfs:domain ind:ForeignCarrierPermit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:bilateralAsaReference rdf:type rdf:Property ;
    rdfs:label 'Bilateral Asa Reference' ;
    rdfs:comment 'Reference number or title of the bilateral air service agreement under which this permit is granted.' ;
    rdfs:domain ind:ForeignCarrierPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityLimitSeats rdf:type rdf:Property ;
    rdfs:label 'Capacity Limit Seats' ;
    rdfs:comment 'Maximum seat capacity per flight or per period allowed under this permit. Null if unlimited.' ;
    rdfs:domain ind:ForeignCarrierPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cargoAuthorizationFlag rdf:type rdf:Property ;
    rdfs:label 'Cargo Authorization Flag' ;
    rdfs:comment 'Indicates whether the permit authorizes cargo operations (True) or is passenger-only (False).' ;
    rdfs:domain ind:ForeignCarrierPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:codeshareAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Codeshare Allowed Flag' ;
    rdfs:comment 'Indicates whether codeshare operations are permitted under this permit (True) or restricted (False).' ;
    rdfs:domain ind:ForeignCarrierPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceAuditRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Audit Required Flag' ;
    rdfs:comment 'Indicates whether the issuing authority requires periodic compliance audits as a condition of the permit (True/False).' ;
    rdfs:domain ind:ForeignCarrierPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:frequencyLimit rdf:type rdf:Property ;
    rdfs:label 'Frequency Limit' ;
    rdfs:comment 'Maximum number of flights per week or per period allowed under this permit. Null if unlimited.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:interlineAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Interline Allowed Flag' ;
    rdfs:comment 'Indicates whether interline ticketing and baggage agreements are permitted under this permit (True) or restricted (False).' ;
    rdfs:domain ind:ForeignCarrierPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastAuditDate rdf:type rdf:Property ;
    rdfs:label 'Last Audit Date' ;
    rdfs:comment 'Date of the most recent compliance audit conducted by the issuing authority for this permit.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:passengerAuthorizationFlag rdf:type rdf:Property ;
    rdfs:label 'Passenger Authorization Flag' ;
    rdfs:comment 'Indicates whether the permit authorizes passenger operations (True) or is cargo-only (False).' ;
    rdfs:domain ind:ForeignCarrierPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:permitConditions rdf:type rdf:Property ;
    rdfs:label 'Permit Conditions' ;
    rdfs:comment 'Detailed conditions, restrictions, or special requirements attached to the permit (e.g., slot restrictions, codeshare limitations, cargo-only).' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Permit Document Url' ;
    rdfs:comment 'URL or file path to the official permit document, certificate, or authorization letter issued by the foreign authority.' ;
    rdfs:domain ind:ForeignCarrierPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitNumber rdf:type rdf:Property ;
    rdfs:label 'Permit Number' ;
    rdfs:comment 'Official permit or authorization number issued by the foreign regulatory authority. This is the externally-known business identifier for the permit.' ;
    rdfs:domain ind:ForeignCarrierPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitStatus rdf:type rdf:Property ;
    rdfs:label 'Permit Status' ;
    rdfs:comment 'Current lifecycle status of the foreign carrier permit.' ;
    rdfs:domain ind:ForeignCarrierPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permitType rdf:type rdf:Property ;
    rdfs:label 'Permit Type' ;
    rdfs:comment 'Classification of the permit or authorization type granted by the foreign jurisdiction.' ;
    rdfs:domain ind:ForeignCarrierPermit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trafficRightsType rdf:type rdf:Property ;
    rdfs:label 'Traffic Rights Type' ;
    rdfs:comment 'Type of traffic rights granted under the permit, based on the nine freedoms of the air as defined by ICAO. [ENUM-REF-CANDIDATE: first_freedom|second_freedom|third_freedom|fourth_freedom|fifth_freedom|sixth_freedom|seventh_freedom|eighth_freedom|ninth_freedom — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationRegisterId rdf:type rdf:Property ;
    rdfs:label 'Obligation Register Id' ;
    rdfs:comment 'Primary key for obligation_register' ;
    rdfs:domain ind:ObligationRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Compliance Owner Employee Id' ;
    rdfs:comment 'Foreign key reference to the employee assigned as the accountable owner for ensuring this obligation is met.' ;
    rdfs:domain ind:ObligationRegister ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:trainingCourseId rdf:type rdf:Property ;
    rdfs:label 'Training Course Id' ;
    rdfs:comment 'Foreign key reference to the training program that fulfills this obligation, if applicable.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TrainingCourse .

ind:applicableAircraftType rdf:type rdf:Property ;
    rdfs:label 'Applicable Aircraft Type' ;
    rdfs:comment 'Specific aircraft type or model to which this obligation applies (e.g., B737, A320, B787). Null if obligation applies to all aircraft or is not aircraft-specific.' ;
    rdfs:domain ind:ObligationRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableOperationType rdf:type rdf:Property ;
    rdfs:label 'Applicable Operation Type' ;
    rdfs:comment 'Type of flight operation to which this obligation applies (e.g., ETOPS (Extended-range Twin-engine Operational Performance Standards), RNAV (Area Navigation), CAT III (Category III precision approach), cargo, passenger). Null if applies to all operations.' ;
    rdfs:domain ind:ObligationRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionDate rdf:type rdf:Property ;
    rdfs:label 'Completion Date' ;
    rdfs:comment 'The actual date when the compliance obligation was fulfilled. Null if not yet completed.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceOwnerDepartment rdf:type rdf:Property ;
    rdfs:label 'Compliance Owner Department' ;
    rdfs:comment 'The department or business unit responsible for managing and fulfilling this compliance obligation (e.g., Flight Operations, Safety, Maintenance, Legal).' ;
    rdfs:domain ind:ObligationRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emissionsReportingPeriod rdf:type rdf:Property ;
    rdfs:label 'Emissions Reporting Period' ;
    rdfs:comment 'The reporting period for environmental emissions obligations (e.g., Q1 2024, FY2024). Applicable only for environmental compliance obligations.' ;
    rdfs:domain ind:ObligationRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationDate rdf:type rdf:Property ;
    rdfs:label 'Escalation Date' ;
    rdfs:comment 'The date when this obligation was escalated due to non-compliance or high risk. Null if not escalated.' ;
    rdfs:domain ind:ObligationRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:escalationFlag rdf:type rdf:Property ;
    rdfs:label 'Escalation Flag' ;
    rdfs:comment 'Boolean flag indicating whether this obligation has been escalated to senior management or regulatory authorities due to non-compliance or risk (True if escalated, False otherwise).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:evidenceLocation rdf:type rdf:Property ;
    rdfs:label 'Evidence Location' ;
    rdfs:comment 'Physical or digital location where compliance evidence is stored (e.g., document management system path, file server location, archive reference).' ;
    rdfs:domain ind:ObligationRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceReference rdf:type rdf:Property ;
    rdfs:label 'Evidence Reference' ;
    rdfs:comment 'Reference to the documentation, records, or artifacts that serve as evidence of compliance (e.g., document ID, file path, audit report number).' ;
    rdfs:domain ind:ObligationRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdiction rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction' ;
    rdfs:comment 'Three-letter ISO country code representing the jurisdiction where this obligation applies (e.g., USA, GBR, DEU).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Review Date' ;
    rdfs:comment 'The date when this obligation was last reviewed or assessed for compliance status.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Review Date' ;
    rdfs:comment 'The scheduled date for the next review or reassessment of this compliance obligation.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nonComplianceImpact rdf:type rdf:Property ;
    rdfs:label 'Non Compliance Impact' ;
    rdfs:comment 'Description of the potential consequences if this obligation is not met (e.g., fines, operational restrictions, certificate suspension, reputational damage).' ;
    rdfs:domain ind:ObligationRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationDescription rdf:type rdf:Property ;
    rdfs:label 'Obligation Description' ;
    rdfs:comment 'Detailed description of the compliance obligation, including what must be done to satisfy the regulatory requirement.' ;
    rdfs:domain ind:ObligationRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Obligation Reference Number' ;
    rdfs:comment 'Business-readable unique reference number for this compliance obligation, used for tracking and reporting purposes.' ;
    rdfs:domain ind:ObligationRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationTitle rdf:type rdf:Property ;
    rdfs:label 'Obligation Title' ;
    rdfs:comment 'Short descriptive title of the compliance obligation, summarizing the requirement being tracked.' ;
    rdfs:domain ind:ObligationRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obligationType rdf:type rdf:Property ;
    rdfs:label 'Obligation Type' ;
    rdfs:comment 'Classification of the obligation by its nature: operational compliance, regulatory reporting, certification maintenance, mandatory training, audit requirement, environmental compliance, or safety compliance. [ENUM-REF-CANDIDATE: operational|reporting|certification|training|audit|environmental|safety — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ObligationRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recurrenceFrequency rdf:type rdf:Property ;
    rdfs:label 'Recurrence Frequency' ;
    rdfs:comment 'How often this obligation must be fulfilled: one_time (single occurrence), daily, weekly, monthly, quarterly, annually, or biennial. [ENUM-REF-CANDIDATE: one_time|daily|weekly|monthly|quarterly|annually|biennial — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ObligationRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskRating rdf:type rdf:Property ;
    rdfs:label 'Risk Rating' ;
    rdfs:comment 'Risk severity rating if this obligation is not met: critical (severe operational or regulatory impact), high (significant impact), medium (moderate impact), low (minor impact).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Training Requirement Flag' ;
    rdfs:comment 'Boolean flag indicating whether this obligation involves mandatory regulatory training requirements (True if training-related, False otherwise). Examples include dangerous goods, security awareness, human trafficking, fatigue risk, SMS (Safety Management System), GDPR (General Data Protection Regulation) training.' ;
    rdfs:domain ind:ObligationRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waiverExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Waiver Expiry Date' ;
    rdfs:comment 'The date when the granted waiver or exemption expires and the obligation becomes enforceable again.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:waiverGrantedFlag rdf:type rdf:Property ;
    rdfs:label 'Waiver Granted Flag' ;
    rdfs:comment 'Boolean flag indicating whether a regulatory waiver or exemption has been granted for this obligation (True if waived, False otherwise).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waiverReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Waiver Reference Number' ;
    rdfs:comment 'Official reference number of the regulatory waiver or exemption document, if applicable.' ;
    rdfs:domain ind:ObligationRegister ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalOwnerDepartmentOrgUnitId rdf:type rdf:Property ;
    rdfs:label 'Internal Owner Department Org Unit Id' ;
    rdfs:comment 'Foreign key linking to workforce.org_unit. Business justification: Operating certificates (AOC, foreign carrier permits) are managed by specific departments. FK enables certificate renewal tracking, departmental workload visibility, and accountability for maintaining' ;
    rdfs:domain ind:OperatingCertificate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:aircraftTypesAuthorized rdf:type rdf:Property ;
    rdfs:label 'Aircraft Types Authorized' ;
    rdfs:comment 'List of aircraft types and models authorized for operation under this certificate. May reference ICAO aircraft type designators.' ;
    rdfs:domain ind:OperatingCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bilateralAgreementReference rdf:type rdf:Property ;
    rdfs:label 'Bilateral Agreement Reference' ;
    rdfs:comment 'Reference to the bilateral air service agreement under which traffic rights or foreign carrier permits are granted. Includes agreement name, date, and relevant articles.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateNumber rdf:type rdf:Property ;
    rdfs:label 'Certificate Number' ;
    rdfs:comment 'Official certificate or permit number issued by the regulatory authority. Examples include AOC number, Part 121 certificate number, foreign carrier permit number.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateStatus rdf:type rdf:Property ;
    rdfs:label 'Certificate Status' ;
    rdfs:comment 'Current lifecycle status of the operating certificate. Indicates whether the certificate is active, suspended, revoked, expired, pending renewal, or under regulatory review.' ;
    rdfs:domain ind:OperatingCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateType rdf:type rdf:Property ;
    rdfs:label 'Certificate Type' ;
    rdfs:comment 'Type of operating certificate or authorization. Distinguishes between Air Operator Certificate (AOC), foreign carrier permits, bilateral entitlements, traffic rights, and exemptions. [ENUM-REF-CANDIDATE: aoc_domestic|aoc_international|part_121_certificate|easa_aoc|foreign_carrier_permit|bilateral_entitlement|traffic_right|exemption — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceNotes rdf:type rdf:Property ;
    rdfs:label 'Compliance Notes' ;
    rdfs:comment 'Internal notes regarding compliance status, upcoming audits, regulatory correspondence, or other relevant information related to this certificate.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentRepositoryUrl rdf:type rdf:Property ;
    rdfs:label 'Document Repository Url' ;
    rdfs:comment 'URL or file path to the document management system location where the physical certificate, supporting documentation, and correspondence are stored.' ;
    rdfs:domain ind:OperatingCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exemptionDetails rdf:type rdf:Property ;
    rdfs:label 'Exemption Details' ;
    rdfs:comment 'Details of any regulatory exemptions granted as part of this certificate, including exemption number, scope, and conditions.' ;
    rdfs:domain ind:OperatingCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationalApprovals rdf:type rdf:Property ;
    rdfs:label 'Operational Approvals' ;
    rdfs:comment 'Special operational approvals granted under this certificate, such as ETOPS (Extended-range Twin-engine Operational Performance Standards), RNAV (Area Navigation), CAT III (Category III precision approach), or other advanced operational authorizations.' ;
    rdfs:domain ind:OperatingCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryContactEmail rdf:type rdf:Property ;
    rdfs:label 'Regulatory Contact Email' ;
    rdfs:comment 'Email address of the primary regulatory contact at the issuing authority for correspondence related to this certificate.' ;
    rdfs:domain ind:OperatingCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryContactName rdf:type rdf:Property ;
    rdfs:label 'Regulatory Contact Name' ;
    rdfs:comment 'Name of the primary regulatory contact or inspector assigned to this certificate at the issuing authority.' ;
    rdfs:domain ind:OperatingCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryContactPhone rdf:type rdf:Property ;
    rdfs:label 'Regulatory Contact Phone' ;
    rdfs:comment 'Phone number of the primary regulatory contact at the issuing authority.' ;
    rdfs:domain ind:OperatingCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalStatus rdf:type rdf:Property ;
    rdfs:label 'Renewal Status' ;
    rdfs:comment 'Current status of the certificate renewal process. Indicates whether renewal is not required, pending, in progress, approved, or denied.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revocationReason rdf:type rdf:Property ;
    rdfs:label 'Revocation Reason' ;
    rdfs:comment 'Reason for revocation of the operating certificate, if applicable. Includes serious safety violations, non-compliance, or voluntary surrender.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeMarketCoverage rdf:type rdf:Property ;
    rdfs:label 'Route Market Coverage' ;
    rdfs:comment 'Geographic route and market coverage authorized by this certificate or permit. May include specific city pairs, regions, or global coverage depending on certificate type.' ;
    rdfs:domain ind:OperatingCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeOfOperations rdf:type rdf:Property ;
    rdfs:label 'Scope Of Operations' ;
    rdfs:comment 'Detailed description of the operational scope authorized under this certificate, including aircraft types, route categories, passenger/cargo operations, and any operational limitations.' ;
    rdfs:domain ind:OperatingCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suspensionReason rdf:type rdf:Property ;
    rdfs:label 'Suspension Reason' ;
    rdfs:comment 'Reason for suspension of the operating certificate, if applicable. Includes regulatory findings, safety concerns, or administrative issues.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Approval Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: ETOPS, RNP, CAT III approvals require named accountable managers per regulatory requirements. FK enables verification of manager authority, succession planning for critical approvals, and regulatory a' ;
    rdfs:domain ind:OperationalApproval ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:approvalConditions rdf:type rdf:Property ;
    rdfs:label 'Approval Conditions' ;
    rdfs:comment 'Detailed text description of any conditions, limitations, or operational restrictions attached to this approval by the issuing authority (e.g., crew qualification requirements, maintenance program requirements, operational procedures).' ;
    rdfs:domain ind:OperationalApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Approval Document Url' ;
    rdfs:comment 'URL or file path to the official approval document, certificate, or letter of authorization issued by the regulatory authority.' ;
    rdfs:domain ind:OperationalApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalNumber rdf:type rdf:Property ;
    rdfs:label 'Approval Number' ;
    rdfs:comment 'Externally-known unique reference number or code assigned by the issuing authority to this operational approval (e.g., ETOPS approval number, CAT III authorization number).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalType rdf:type rdf:Property ;
    rdfs:label 'Approval Type' ;
    rdfs:comment 'Type or category of operational approval granted. [ENUM-REF-CANDIDATE: ETOPS|CAT_II|CAT_III|RVSM|RNP|RNAV|PBN|LVO|MNPS|NAT_HLA|EDTO — promote to reference product]' ;
    rdfs:domain ind:OperationalApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionHeightFeet rdf:type rdf:Property ;
    rdfs:label 'Decision Height Feet' ;
    rdfs:comment 'Minimum decision height (DH) or decision altitude (DA) in feet authorized for precision approaches under this approval (e.g., 100 feet for CAT II). Applicable to CAT II/III approvals.' ;
    rdfs:domain ind:OperationalApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maintenanceProgramReference rdf:type rdf:Property ;
    rdfs:label 'Maintenance Program Reference' ;
    rdfs:comment 'Reference to the specific maintenance program or MEL (Minimum Equipment List) provisions required to support this operational approval (e.g., ETOPS maintenance program, CAT III equipment maintenance).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumVisibilityMeters rdf:type rdf:Property ;
    rdfs:label 'Minimum Visibility Meters' ;
    rdfs:comment 'Minimum runway visual range (RVR) or visibility in meters authorized for low-visibility operations under this approval (e.g., 75m for CAT IIIb). Applicable to CAT II/III and LVO approvals.' ;
    rdfs:domain ind:OperationalApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rnpSpecification rdf:type rdf:Property ;
    rdfs:label 'Rnp Specification' ;
    rdfs:comment 'RNP specification level authorized (e.g., RNP 10, RNP 4, RNP 1, RNP 0.3, RNP AR APCH). Applicable to RNP/RNAV approvals; null for other types.' ;
    rdfs:domain ind:OperationalApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingRequirementDescription rdf:type rdf:Property ;
    rdfs:label 'Training Requirement Description' ;
    rdfs:comment 'Description of specific crew training requirements mandated for operations under this approval (e.g., ETOPS-specific training, CAT III simulator training, RNP AR approach training).' ;
    rdfs:domain ind:OperationalApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentAuthorityRegulatoryAuthorityId rdf:type rdf:Property ;
    rdfs:label 'Parent Authority Regulatory Authority Id' ;
    rdfs:comment 'Reference to a parent or umbrella regulatory authority if this authority operates under a higher-level body (e.g., a national CAA under ICAO, or a state aviation authority under a federal FAA).' ;
    rdfs:domain ind:RegulatoryAuthority ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryAuthority .

ind:auditCycleMonths rdf:type rdf:Property ;
    rdfs:label 'Audit Cycle Months' ;
    rdfs:comment 'Typical interval in months between scheduled audits or inspections conducted by this authority. Null if audits are event-driven or irregular.' ;
    rdfs:domain ind:RegulatoryAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:authorityCode rdf:type rdf:Property ;
    rdfs:label 'Authority Code' ;
    rdfs:comment 'Standardized short code or abbreviation for the regulatory authority (e.g., FAA, EASA, ICAO, DOT, TSA, CAA).' ;
    rdfs:domain ind:RegulatoryAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorityName rdf:type rdf:Property ;
    rdfs:label 'Authority Name' ;
    rdfs:comment 'Full legal name of the regulatory authority or governing body (e.g., Federal Aviation Administration, European Union Aviation Safety Agency, International Civil Aviation Organization).' ;
    rdfs:domain ind:RegulatoryAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorityStatus rdf:type rdf:Property ;
    rdfs:label 'Authority Status' ;
    rdfs:comment 'Current operational status of the regulatory authority. Active authorities are currently enforcing regulations; inactive, superseded, merged, or dissolved authorities are historical.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorityType rdf:type rdf:Property ;
    rdfs:label 'Authority Type' ;
    rdfs:comment 'Classification of the regulatory authority by its primary regulatory domain (safety, environmental, consumer protection, security, operational, financial, or industry association). [ENUM-REF-CANDIDATE: safety|environmental|consumer_protection|security|operational|financial|industry_association — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationScope rdf:type rdf:Property ;
    rdfs:label 'Certification Scope' ;
    rdfs:comment 'Description of the types of certifications, approvals, or licenses issued by this authority (e.g., Air Operator Certificate, airworthiness certificates, ETOPS approval, RNAV approval, personnel licenses).' ;
    rdfs:domain ind:RegulatoryAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dissolvedDate rdf:type rdf:Property ;
    rdfs:label 'Dissolved Date' ;
    rdfs:comment 'Date when the regulatory authority was dissolved, merged, or superseded. Null for active authorities.' ;
    rdfs:domain ind:RegulatoryAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enforcementPowers rdf:type rdf:Property ;
    rdfs:label 'Enforcement Powers' ;
    rdfs:comment 'Summary of the enforcement actions and penalties this authority can impose (e.g., fines, license suspension, operational restrictions, criminal prosecution).' ;
    rdfs:domain ind:RegulatoryAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:establishedDate rdf:type rdf:Property ;
    rdfs:label 'Established Date' ;
    rdfs:comment 'Date when the regulatory authority was officially established or incorporated.' ;
    rdfs:domain ind:RegulatoryAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:filingMethod rdf:type rdf:Property ;
    rdfs:label 'Filing Method' ;
    rdfs:comment 'Primary method accepted by the authority for submitting regulatory filings and compliance documents (electronic portal, email, postal mail, fax, API, or mixed methods).' ;
    rdfs:domain ind:RegulatoryAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingPortalUrl rdf:type rdf:Property ;
    rdfs:label 'Filing Portal Url' ;
    rdfs:comment 'URL of the online portal or system used for submitting regulatory filings, reports, and compliance documents to this authority.' ;
    rdfs:domain ind:RegulatoryAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionLevel rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Level' ;
    rdfs:comment 'Geographic scope of the authority\'s jurisdiction (international, regional, national, state/provincial, or local).' ;
    rdfs:domain ind:RegulatoryAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:language rdf:type rdf:Property ;
    rdfs:label 'Language' ;
    rdfs:comment 'ISO 639-1 or ISO 639-2 language code for the primary official language used by the authority for regulations and correspondence.' ;
    rdfs:domain ind:RegulatoryAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingAddress rdf:type rdf:Property ;
    rdfs:label 'Mailing Address' ;
    rdfs:comment 'Full postal mailing address for official correspondence and document submission to the regulatory authority.' ;
    rdfs:domain ind:RegulatoryAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactTitle rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Title' ;
    rdfs:comment 'Job title or role of the primary contact person at the regulatory authority.' ;
    rdfs:domain ind:RegulatoryAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:region rdf:type rdf:Property ;
    rdfs:label 'Region' ;
    rdfs:comment 'Geographic region or multi-country area covered by the authority (e.g., European Union, Asia-Pacific, North America, Middle East). Applicable for regional authorities.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryFramework rdf:type rdf:Property ;
    rdfs:label 'Regulatory Framework' ;
    rdfs:comment 'Primary regulatory framework, legislation, or standards administered by this authority (e.g., Federal Aviation Regulations Part 121, EASA Part-OPS, ICAO Standards and Recommended Practices, CORSIA Carbon Offsetting Scheme).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingFrequency rdf:type rdf:Property ;
    rdfs:label 'Reporting Frequency' ;
    rdfs:comment 'Typical frequency at which the airline is required to submit reports or filings to this authority (real-time, daily, weekly, monthly, quarterly, annual, event-driven, or as required). [ENUM-REF-CANDIDATE: real_time|daily|weekly|monthly|quarterly|annual|event_driven|as_required — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RegulatoryAuthority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:askPlanId rdf:type rdf:Property ;
    rdfs:label 'Ask Plan Id' ;
    rdfs:comment 'Foreign key linking to route.ask_plan. Business justification: Capacity plans (ASK forecasts) are filed with bilateral authorities for frequency/capacity entitlement compliance under restrictive ASAs. International planning teams submit capacity declarations. Ess' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AskPlan .

ind:parentFilingRegulatoryFilingId rdf:type rdf:Property ;
    rdfs:label 'Parent Filing Regulatory Filing Id' ;
    rdfs:comment 'Reference to the original filing record if this is a resubmission or amendment, establishing lineage between related filings.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryFiling .

ind:scheduleSeasonId rdf:type rdf:Property ;
    rdfs:label 'Schedule Season Id' ;
    rdfs:comment 'Foreign key linking to route.schedule_season. Business justification: IATA schedule coordination filings, slot return declarations, and capacity reports are submitted per schedule season. Regulatory affairs teams track filing deadlines by season. Essential for IATA coor' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ScheduleSeason .

ind:acceptanceDate rdf:type rdf:Property ;
    rdfs:label 'Acceptance Date' ;
    rdfs:comment 'Date on which the regulatory authority formally accepted the filing as complete and compliant, closing the submission cycle.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:acknowledgmentDate rdf:type rdf:Property ;
    rdfs:label 'Acknowledgment Date' ;
    rdfs:comment 'Date on which the regulatory authority acknowledged receipt of the filing, confirming successful submission.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:amendmentFlag rdf:type rdf:Property ;
    rdfs:label 'Amendment Flag' ;
    rdfs:comment 'Indicates whether this filing is an amendment or correction to a previously submitted filing (true) or an original submission (false).' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceQuarter rdf:type rdf:Property ;
    rdfs:label 'Compliance Quarter' ;
    rdfs:comment 'Fiscal quarter (1-4) to which this filing applies, used for quarterly regulatory reporting requirements such as DOT Form 41.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceYear rdf:type rdf:Property ;
    rdfs:label 'Compliance Year' ;
    rdfs:comment 'Calendar or fiscal year to which this filing applies for compliance tracking and historical reporting purposes.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:confidentialFlag rdf:type rdf:Property ;
    rdfs:label 'Confidential Flag' ;
    rdfs:comment 'Indicates whether the filing contains confidential business information or sensitive safety data subject to restricted disclosure under regulatory protection (true) or is public record (false).' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:departmentCode rdf:type rdf:Property ;
    rdfs:label 'Department Code' ;
    rdfs:comment 'Code identifying the internal department or business unit responsible for preparing the filing (e.g., Safety, Finance, Operations, Environmental Compliance).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentCount rdf:type rdf:Property ;
    rdfs:label 'Document Count' ;
    rdfs:comment 'Number of supporting documents, attachments, or exhibits included with the regulatory filing submission.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:documentStoragePath rdf:type rdf:Property ;
    rdfs:label 'Document Storage Path' ;
    rdfs:comment 'File system path or cloud storage URI where the complete filing package and supporting documents are archived for audit and retrieval.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingDescription rdf:type rdf:Property ;
    rdfs:label 'Filing Description' ;
    rdfs:comment 'Detailed narrative description of the filing content, scope, and context. May include summary of reported data, incident details, or compliance statement.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Filing Reference Number' ;
    rdfs:comment 'External reference number or confirmation number assigned by the regulatory authority upon submission (e.g., DOT filing confirmation number, FAA submission ID, EASA occurrence report number).' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingStatus rdf:type rdf:Property ;
    rdfs:label 'Filing Status' ;
    rdfs:comment 'Current lifecycle status of the regulatory filing in the submission and approval workflow (draft, submitted, under review by authority, accepted, rejected, resubmission required).' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingTitle rdf:type rdf:Property ;
    rdfs:label 'Filing Title' ;
    rdfs:comment 'Descriptive title or subject line of the regulatory filing, providing human-readable identification of the submission content and purpose.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingType rdf:type rdf:Property ;
    rdfs:label 'Filing Type' ;
    rdfs:comment 'Classification of the regulatory filing by form type and purpose. Identifies the specific regulatory report or submission category (e.g., DOT Form 41 financial filing, FAA accident/incident report, EASA occurrence report, CORSIA emissions report, noise abatement filing, slot coordination filing). [ENUM-REF-CANDIDATE: DOT_Form_41_Financial|FAA_Accident_Report|FAA_Incident_Report|EASA_Occurrence_Report|DOT_Consumer_Protection_Report|CORSIA_Emissions_Report|Noise_Abatement_Filing|Slot_Coordination_Filing|Airworthiness_Directive_Response|ETOPS_Approval_Filing|CAT_III_Approval_Filing|Environmental_Impact_Report|Safety_Management_System_Report|Crew_Duty_Time_Report|Dangerous_Goods_Incident_Report — promote to reference product]' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionDate rdf:type rdf:Property ;
    rdfs:label 'Rejection Date' ;
    rdfs:comment 'Date on which the regulatory authority rejected the filing due to incompleteness, errors, or non-compliance, requiring resubmission.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Reporting Period End Date' ;
    rdfs:comment 'End date of the period covered by this regulatory filing. Defines the temporal scope of data included in the submission.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Start Date' ;
    rdfs:comment 'Start date of the period covered by this regulatory filing (e.g., beginning of fiscal quarter for DOT Form 41, start of emissions reporting period for CORSIA).' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responsibleOfficerEmail rdf:type rdf:Property ;
    rdfs:label 'Responsible Officer Email' ;
    rdfs:comment 'Email address of the compliance officer responsible for this filing, used for regulatory authority correspondence and internal audit trail.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleOfficerName rdf:type rdf:Property ;
    rdfs:label 'Responsible Officer Name' ;
    rdfs:comment 'Full name of the compliance officer or authorized signatory responsible for preparing and submitting this regulatory filing.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleOfficerPhone rdf:type rdf:Property ;
    rdfs:label 'Responsible Officer Phone' ;
    rdfs:comment 'Contact phone number for the compliance officer responsible for this filing, enabling regulatory authority follow-up and internal coordination.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resubmissionDueDate rdf:type rdf:Property ;
    rdfs:label 'Resubmission Due Date' ;
    rdfs:comment 'Deadline by which a corrected filing must be resubmitted following rejection, as specified by the regulatory authority.' ;
    rdfs:domain ind:RegulatoryFiling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:submissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submission Timestamp' ;
    rdfs:comment 'Precise timestamp (date and time with timezone) when the filing was transmitted to the regulatory authority, capturing exact submission moment for audit trail and compliance verification.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:responsibleDepartmentOrgUnitId rdf:type rdf:Property ;
    rdfs:label 'Responsible Department Org Unit Id' ;
    rdfs:comment 'Foreign key linking to workforce.org_unit. Business justification: Each regulatory requirement must have an accountable department for compliance execution (e.g., Flight Ops owns FDP limits, Maintenance owns airworthiness directives). FK enables compliance workload a' ;
    rdfs:domain ind:Compliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:activeFlag rdf:type rdf:Property ;
    rdfs:label 'Active Flag' ;
    rdfs:comment 'Indicates whether this regulatory requirement is currently active and enforceable (True) or has been superseded, repealed, or is no longer applicable (False).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:aircraftTypeApplicability rdf:type rdf:Property ;
    rdfs:label 'Aircraft Type Applicability' ;
    rdfs:comment 'Specific aircraft type, family, or category to which this requirement applies (e.g., B737, A320 family, twin-engine jets, turboprop). Null if applicable to all aircraft.' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendmentNumber rdf:type rdf:Property ;
    rdfs:label 'Amendment Number' ;
    rdfs:comment 'The amendment, revision, or version number of the regulatory requirement as published by the governing authority (e.g., Amendment 121-374, Rev 5).' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicabilityScope rdf:type rdf:Property ;
    rdfs:label 'Applicability Scope' ;
    rdfs:comment 'Defines the scope of operations, aircraft types, routes, or organizational units to which this requirement applies (e.g., all Part 121 operations, widebody aircraft only, ETOPS routes, international flights, specific airport operations).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceCategory rdf:type rdf:Property ;
    rdfs:label 'Compliance Category' ;
    rdfs:comment 'High-level classification of the regulatory requirement type: airworthiness (aircraft certification, MEL), operational (flight operations, crew duty limits, ETOPS), environmental (CORSIA emissions, noise), consumer protection (DOT passenger rights, refunds), safety (SMS, incident reporting), or security (TSA, cargo screening).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceFrequency rdf:type rdf:Property ;
    rdfs:label 'Compliance Frequency' ;
    rdfs:comment 'The frequency or cadence at which compliance with this requirement must be demonstrated or reported (e.g., one-time certification, continuous monitoring, annual audit, quarterly report, event-driven such as incident reporting). [ENUM-REF-CANDIDATE: one_time|continuous|annual|quarterly|monthly|event_driven|as_required — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceSubcategory rdf:type rdf:Property ;
    rdfs:label 'Compliance Subcategory' ;
    rdfs:comment 'Detailed subcategory or domain within the compliance category (e.g., ETOPS approval, CAT III operations, RNAV certification, carbon offset reporting, tarmac delay rule, baggage liability).' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalityLevel rdf:type rdf:Property ;
    rdfs:label 'Criticality Level' ;
    rdfs:comment 'Internal risk-based classification of the importance and impact of this requirement: critical (safety-critical, AOG risk, severe penalties), high (significant operational or financial impact), medium (moderate impact), low (minor administrative requirement).' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalPolicyReference rdf:type rdf:Property ;
    rdfs:label 'Internal Policy Reference' ;
    rdfs:comment 'Reference to the airlines internal policy, procedure, or manual section that implements or addresses this regulatory requirement (e.g., Operations Manual Chapter 5.3, Safety Management System Procedure SOP-123).' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastComplianceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Compliance Review Date' ;
    rdfs:comment 'The date on which the airlines compliance with this requirement was last reviewed, audited, or assessed.' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maximumPenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Penalty Amount' ;
    rdfs:comment 'Maximum monetary penalty or fine amount (in USD or local currency) that can be assessed for a single violation of this requirement. Null if penalty is non-monetary or not specified.' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextComplianceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Compliance Review Date' ;
    rdfs:comment 'The scheduled date for the next compliance review, audit, or assessment of this requirement.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operationalApprovalType rdf:type rdf:Property ;
    rdfs:label 'Operational Approval Type' ;
    rdfs:comment 'Type of operational approval or certification this requirement pertains to (e.g., ETOPS, RNAV, RNP, CAT II/III, RVSM, PBN). Null if not approval-specific.' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyDescription rdf:type rdf:Property ;
    rdfs:label 'Penalty Description' ;
    rdfs:comment 'Description of penalties, fines, sanctions, or enforcement actions that may result from non-compliance with this requirement (e.g., civil penalty up to $25,000 per violation, certificate suspension, AOG).' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicationDate rdf:type rdf:Property ;
    rdfs:label 'Publication Date' ;
    rdfs:comment 'The date on which this requirement or its current amendment was officially published by the governing authority.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:referenceDocumentTitle rdf:type rdf:Property ;
    rdfs:label 'Reference Document Title' ;
    rdfs:comment 'Title of the primary regulatory document, regulation, or standard that contains this requirement (e.g., Federal Aviation Regulations Part 121, EASA Part-ORO, ICAO Annex 6, DOT 14 CFR Part 234).' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Reference Document Url' ;
    rdfs:comment 'Web URL or hyperlink to the official online version of the regulatory document or requirement text.' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingDeadlineDays rdf:type rdf:Property ;
    rdfs:label 'Reporting Deadline Days' ;
    rdfs:comment 'Number of days after the triggering event or period end by which the compliance report or filing must be submitted to the authority. Null if not applicable.' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reportingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Reporting Required Flag' ;
    rdfs:comment 'Indicates whether this requirement mandates formal reporting or filing to the governing authority (True) or is compliance-only without reporting (False).' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requirementCode rdf:type rdf:Property ;
    rdfs:label 'Requirement Code' ;
    rdfs:comment 'Unique business identifier code for the regulatory requirement as published by the governing authority (e.g., FAR 121.135, EASA Part-ORO.GEN.110, DOT 14 CFR 234.4).' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requirementDescription rdf:type rdf:Property ;
    rdfs:label 'Requirement Description' ;
    rdfs:comment 'Detailed description of the regulatory obligation, including what must be complied with, how, and under what conditions.' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requirementTitle rdf:type rdf:Property ;
    rdfs:label 'Requirement Title' ;
    rdfs:comment 'Official title or short name of the regulatory requirement as published by the governing authority.' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByRequirementCode rdf:type rdf:Property ;
    rdfs:label 'Superseded By Requirement Code' ;
    rdfs:comment 'The requirement code of the new or amended requirement that supersedes this one, if applicable. Null if not superseded.' ;
    rdfs:domain ind:RegulatoryRequirement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cargoEmbargoId rdf:type rdf:Property ;
    rdfs:label 'Cargo Embargo Id' ;
    rdfs:comment 'Foreign key linking to cargo.embargo. Business justification: Embargo violations (shipping restricted goods/routes) result in regulatory enforcement actions. Links violation to the specific embargo breached for penalty assessment and compliance investigation.' ;
    rdfs:domain ind:RegulatoryViolation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Embargo .

ind:appealDate rdf:type rdf:Property ;
    rdfs:label 'Appeal Date' ;
    rdfs:comment 'The date on which the airline filed the formal appeal or contest of the enforcement action. Null if no appeal was filed.' ;
    rdfs:domain ind:RegulatoryViolation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:appealFiledFlag rdf:type rdf:Property ;
    rdfs:label 'Appeal Filed Flag' ;
    rdfs:comment 'Indicates whether the airline has filed a formal appeal or contest of the enforcement action with the regulatory authority or administrative law judge.' ;
    rdfs:domain ind:RegulatoryViolation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appealStatus rdf:type rdf:Property ;
    rdfs:label 'Appeal Status' ;
    rdfs:comment 'The current status of the appeal process if an appeal was filed. Null if no appeal was filed.' ;
    rdfs:domain ind:RegulatoryViolation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arrivalAirportCode rdf:type rdf:Property ;
    rdfs:label 'Arrival Airport Code' ;
    rdfs:comment 'Three-letter IATA code of the arrival airport for the flight involved in the violation, if applicable. Null if violation is not flight-specific.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseManager rdf:type rdf:Property ;
    rdfs:label 'Case Manager' ;
    rdfs:comment 'The name of the airline compliance or legal team member assigned to manage this violation case and coordinate with the regulatory authority.' ;
    rdfs:domain ind:RegulatoryViolation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departureAirportCode rdf:type rdf:Property ;
    rdfs:label 'Departure Airport Code' ;
    rdfs:comment 'Three-letter IATA code of the departure airport for the flight involved in the violation, if applicable. Null if violation is not flight-specific.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispositionDate rdf:type rdf:Property ;
    rdfs:label 'Disposition Date' ;
    rdfs:comment 'The date on which the violation case reached its final disposition and was closed by the regulatory authority.' ;
    rdfs:domain ind:RegulatoryViolation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enforcementActionType rdf:type rdf:Property ;
    rdfs:label 'Enforcement Action Type' ;
    rdfs:comment 'The type of enforcement action taken by the regulatory authority in response to the violation (e.g., Warning Letter, Civil Penalty, Certificate Suspension, Certificate Revocation, Corrective Action Order). [ENUM-REF-CANDIDATE: warning_letter|civil_penalty|certificate_suspension|certificate_revocation|corrective_action_order|administrative_action|emergency_order — promote to reference product]' ;
    rdfs:domain ind:RegulatoryViolation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finalDisposition rdf:type rdf:Property ;
    rdfs:label 'Final Disposition' ;
    rdfs:comment 'The final outcome or resolution of the violation case after all enforcement actions, appeals, and settlements have been completed.' ;
    rdfs:domain ind:RegulatoryViolation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalCounselAssignedFlag rdf:type rdf:Property ;
    rdfs:label 'Legal Counsel Assigned Flag' ;
    rdfs:comment 'Indicates whether external or internal legal counsel has been formally assigned to represent the airline in this violation case.' ;
    rdfs:domain ind:RegulatoryViolation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationDate rdf:type rdf:Property ;
    rdfs:label 'Notification Date' ;
    rdfs:comment 'The date on which the airline was formally notified of the violation by the regulatory authority.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentDate rdf:type rdf:Property ;
    rdfs:label 'Payment Date' ;
    rdfs:comment 'The actual date on which the airline made the penalty payment to the regulatory authority.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentDueDate rdf:type rdf:Property ;
    rdfs:label 'Payment Due Date' ;
    rdfs:comment 'The date by which the civil penalty payment must be made to the regulatory authority to avoid additional enforcement action.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:penaltyAmountAssessed rdf:type rdf:Property ;
    rdfs:label 'Penalty Amount Assessed' ;
    rdfs:comment 'The monetary civil penalty amount assessed by the regulatory authority in the enforcement action. Null if no financial penalty was imposed.' ;
    rdfs:domain ind:RegulatoryViolation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:penaltyAmountPaid rdf:type rdf:Property ;
    rdfs:label 'Penalty Amount Paid' ;
    rdfs:comment 'The actual monetary amount paid by the airline to settle or satisfy the civil penalty. May differ from assessed amount due to negotiation or settlement.' ;
    rdfs:domain ind:RegulatoryViolation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:publicDisclosureDate rdf:type rdf:Property ;
    rdfs:label 'Public Disclosure Date' ;
    rdfs:comment 'The date on which the violation was publicly disclosed by the regulatory authority. Null if not publicly disclosed.' ;
    rdfs:domain ind:RegulatoryViolation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:publicDisclosureFlag rdf:type rdf:Property ;
    rdfs:label 'Public Disclosure Flag' ;
    rdfs:comment 'Indicates whether the violation and enforcement action were publicly disclosed by the regulatory authority (e.g., published in FAA enforcement database or DOT public docket).' ;
    rdfs:domain ind:RegulatoryViolation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:violationDescription rdf:type rdf:Property ;
    rdfs:label 'Violation Description' ;
    rdfs:comment 'Detailed narrative description of the violation, including the circumstances, findings, and specific non-compliance details as documented by the regulatory authority.' ;
    rdfs:domain ind:RegulatoryViolation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationNumber rdf:type rdf:Property ;
    rdfs:label 'Violation Number' ;
    rdfs:comment 'External reference number assigned by the regulatory authority to this violation case. Used for correspondence and tracking with the issuing agency.' ;
    rdfs:domain ind:RegulatoryViolation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationStatus rdf:type rdf:Property ;
    rdfs:label 'Violation Status' ;
    rdfs:comment 'Current lifecycle status of the regulatory violation case in the enforcement process.' ;
    rdfs:domain ind:RegulatoryViolation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:violationType rdf:type rdf:Property ;
    rdfs:label 'Violation Type' ;
    rdfs:comment 'High-level classification of the regulatory violation based on the nature of the infraction.' ;
    rdfs:domain ind:RegulatoryViolation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:selfAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Self Assessment Id' ;
    rdfs:comment 'Primary key for self_assessment' ;
    rdfs:domain ind:SelfAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assessmentOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Assessment Owner Employee Id' ;
    rdfs:comment 'Identifier of the employee responsible for conducting or overseeing the compliance assessment.' ;
    rdfs:domain ind:SelfAssessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assessmentCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Assessment Completion Date' ;
    rdfs:comment 'The date when the compliance assessment was finalized and all findings documented.' ;
    rdfs:domain ind:SelfAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assessmentDate rdf:type rdf:Property ;
    rdfs:label 'Assessment Date' ;
    rdfs:comment 'The date on which the compliance self-assessment was conducted or completed.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assessmentFrequency rdf:type rdf:Property ;
    rdfs:label 'Assessment Frequency' ;
    rdfs:comment 'The recurrence pattern for this type of compliance assessment (annual, semi-annual, quarterly, monthly, ad-hoc, or event-driven).' ;
    rdfs:domain ind:SelfAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentMethodology rdf:type rdf:Property ;
    rdfs:label 'Assessment Methodology' ;
    rdfs:comment 'Description of the methodology or approach used to conduct the assessment (e.g., document review, interviews, site inspections, data analysis, checklist-based evaluation).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentOwnerName rdf:type rdf:Property ;
    rdfs:label 'Assessment Owner Name' ;
    rdfs:comment 'Full name of the compliance officer or employee responsible for the assessment.' ;
    rdfs:domain ind:SelfAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Assessment Reference Number' ;
    rdfs:comment 'Business identifier for the self-assessment, typically formatted as prefix-year-sequence (e.g., COMP-2024-000123).' ;
    rdfs:domain ind:SelfAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentStartDate rdf:type rdf:Property ;
    rdfs:label 'Assessment Start Date' ;
    rdfs:comment 'The date when the compliance assessment activity commenced.' ;
    rdfs:domain ind:SelfAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assessmentStatus rdf:type rdf:Property ;
    rdfs:label 'Assessment Status' ;
    rdfs:comment 'Current lifecycle status of the compliance assessment (planned, in progress, under review, completed, cancelled, or deferred).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentTeamMembers rdf:type rdf:Property ;
    rdfs:label 'Assessment Team Members' ;
    rdfs:comment 'Comma-separated list of names or employee IDs of team members who participated in the assessment.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentType rdf:type rdf:Property ;
    rdfs:label 'Assessment Type' ;
    rdfs:comment 'Classification of the compliance assessment activity conducted (self-assessment, gap analysis, readiness review, internal audit, pre-certification review, or regulatory preparedness).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceScorePercentage rdf:type rdf:Property ;
    rdfs:label 'Compliance Score Percentage' ;
    rdfs:comment 'Quantitative compliance score expressed as a percentage (0.00 to 100.00), representing the proportion of requirements met during the assessment.' ;
    rdfs:domain ind:SelfAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:correctiveActionPlanReference rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Plan Reference' ;
    rdfs:comment 'Reference number or identifier of the corrective action plan developed in response to the assessment findings.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalGapsCount rdf:type rdf:Property ;
    rdfs:label 'Critical Gaps Count' ;
    rdfs:comment 'The number of critical or high-severity compliance gaps identified that require immediate corrective action.' ;
    rdfs:domain ind:SelfAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:evidenceDocumentationReference rdf:type rdf:Property ;
    rdfs:label 'Evidence Documentation Reference' ;
    rdfs:comment 'Reference to the location or document management system path where assessment evidence and supporting documentation are stored.' ;
    rdfs:domain ind:SelfAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingsSummary rdf:type rdf:Property ;
    rdfs:label 'Findings Summary' ;
    rdfs:comment 'Executive summary of the key findings, observations, and recommendations from the compliance assessment.' ;
    rdfs:domain ind:SelfAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gapsIdentifiedCount rdf:type rdf:Property ;
    rdfs:label 'Gaps Identified Count' ;
    rdfs:comment 'The total number of compliance gaps, deficiencies, or non-conformances identified during the assessment.' ;
    rdfs:domain ind:SelfAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:majorGapsCount rdf:type rdf:Property ;
    rdfs:label 'Major Gaps Count' ;
    rdfs:comment 'The number of major compliance gaps identified that require corrective action within a defined timeframe.' ;
    rdfs:domain ind:SelfAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minorGapsCount rdf:type rdf:Property ;
    rdfs:label 'Minor Gaps Count' ;
    rdfs:comment 'The number of minor compliance gaps or observations identified that require monitoring or improvement.' ;
    rdfs:domain ind:SelfAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextAssessmentDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Assessment Due Date' ;
    rdfs:comment 'The scheduled date for the next compliance self-assessment or follow-up review.' ;
    rdfs:domain ind:SelfAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:overallComplianceRating rdf:type rdf:Property ;
    rdfs:label 'Overall Compliance Rating' ;
    rdfs:comment 'Summary rating of the overall compliance status based on the assessment findings (compliant, substantially compliant, partially compliant, non-compliant, or not assessed).' ;
    rdfs:domain ind:SelfAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReadinessStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Readiness Status' ;
    rdfs:comment 'Assessment of the organizations readiness for regulatory inspection or audit based on the self-assessment findings (ready, substantially ready, needs improvement, or not ready).' ;
    rdfs:domain ind:SelfAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportApprovedBy rdf:type rdf:Property ;
    rdfs:label 'Report Approved By' ;
    rdfs:comment 'Name or employee ID of the senior compliance officer or executive who approved the assessment report.' ;
    rdfs:domain ind:SelfAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportIssuedDate rdf:type rdf:Property ;
    rdfs:label 'Report Issued Date' ;
    rdfs:comment 'The date when the formal assessment report was issued to stakeholders.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requirementsMet rdf:type rdf:Property ;
    rdfs:label 'Requirements Met' ;
    rdfs:comment 'The number of regulatory requirements or control points that were found to be fully compliant during the assessment.' ;
    rdfs:domain ind:SelfAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalRequirementsAssessed rdf:type rdf:Property ;
    rdfs:label 'Total Requirements Assessed' ;
    rdfs:comment 'The total number of regulatory requirements or control points evaluated during the assessment.' ;
    rdfs:domain ind:SelfAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:absenceId rdf:type rdf:Property ;
    rdfs:label 'Absence Id' ;
    rdfs:comment 'Unique identifier for the crew absence record. Primary key.' ;
    rdfs:domain ind:Absence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:absenceMemberId rdf:type rdf:Property ;
    rdfs:label 'Absence Member Id' ;
    rdfs:comment 'Identifier of the crew member who is absent. Links to the crew member master record.' ;
    rdfs:domain ind:Absence ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Member .

ind:absenceReplacementCrewMemberId rdf:type rdf:Property ;
    rdfs:label 'Absence Replacement Crew Member Id' ;
    rdfs:comment 'Identifier of the crew member assigned to replace the absent crew member. Nullable if no replacement has been assigned yet.' ;
    rdfs:domain ind:Absence ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Member .

ind:baseId rdf:type rdf:Property ;
    rdfs:label 'Base Id' ;
    rdfs:comment 'FK to crew.crew_base' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Base .

ind:medicalCertificateId rdf:type rdf:Property ;
    rdfs:label 'Medical Certificate Id' ;
    rdfs:comment 'Foreign key linking to crew.medical_certificate. Business justification: Normalize crew_absence to reference medical_certificate by FK. Currently crew_absence stores medical_certificate_reference (STRING), medical_certificate_issued_date, and medical_certificate_expiry_dat' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MedicalCertificate .

ind:previousAbsenceId rdf:type rdf:Property ;
    rdfs:label 'Previous Absence Id' ;
    rdfs:comment 'Identifier of the previous absence record if this absence is a recurrence or continuation. Nullable if this is the first occurrence.' ;
    rdfs:domain ind:Absence ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Absence .

ind:reportingStationId rdf:type rdf:Property ;
    rdfs:label 'Reporting Station Id' ;
    rdfs:comment 'Foreign key linking to airport.station. Business justification: Absences are reported and managed at crew\'s assigned station for operational impact assessment, replacement crew sourcing, and station-level crew availability tracking. Critical for daily operations c' ;
    rdfs:domain ind:Absence ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Station .

ind:absenceStatus rdf:type rdf:Property ;
    rdfs:label 'Absence Status' ;
    rdfs:comment 'Current lifecycle status of the absence record: pending approval, approved, rejected, active (ongoing), completed, or cancelled.' ;
    rdfs:domain ind:Absence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:absenceType rdf:type rdf:Property ;
    rdfs:label 'Absence Type' ;
    rdfs:comment 'Classification of the absence reason: sick leave, maternity/paternity leave, compassionate leave, suspension, administrative leave, or unplanned absence. [ENUM-REF-CANDIDATE: sick_leave|maternity_leave|paternity_leave|compassionate_leave|suspension|administrative_leave|unplanned_absence — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Absence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedDutyPeriodsCount rdf:type rdf:Property ;
    rdfs:label 'Affected Duty Periods Count' ;
    rdfs:comment 'The number of scheduled duty periods impacted by this absence, requiring roster adjustments or crew reassignments.' ;
    rdfs:domain ind:Absence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedFlightLegsCount rdf:type rdf:Property ;
    rdfs:label 'Affected Flight Legs Count' ;
    rdfs:comment 'The number of individual flight legs that the absent crew member was originally scheduled to operate, now requiring coverage.' ;
    rdfs:domain ind:Absence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clearanceAuthority rdf:type rdf:Property ;
    rdfs:label 'Clearance Authority' ;
    rdfs:comment 'The name or identifier of the medical examiner, HR officer, or other authority who issued the return-to-duty clearance.' ;
    rdfs:domain ind:Absence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectiveAgreementReference rdf:type rdf:Property ;
    rdfs:label 'Collective Agreement Reference' ;
    rdfs:comment 'Reference to the specific clause or section of the collective bargaining agreement that governs this type of absence (e.g., sick leave policy, maternity leave entitlement).' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crewPosition rdf:type rdf:Property ;
    rdfs:label 'Crew Position' ;
    rdfs:comment 'The operational position or role of the absent crew member: captain, first officer, flight engineer, purser, flight attendant, or cabin crew.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationDays rdf:type rdf:Property ;
    rdfs:label 'Duration Days' ;
    rdfs:comment 'Total number of calendar days the crew member is absent, calculated from start date to end date inclusive.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endDate rdf:type rdf:Property ;
    rdfs:label 'End Date' ;
    rdfs:comment 'The date when the crew absence period ends. Nullable for open-ended absences.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:notificationMethod rdf:type rdf:Property ;
    rdfs:label 'Notification Method' ;
    rdfs:comment 'The channel through which the absence was reported: phone, email, mobile app, in-person, crew portal, or third-party notification.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payStatus rdf:type rdf:Property ;
    rdfs:label 'Pay Status' ;
    rdfs:comment 'Indicates whether the crew member receives full pay, no pay, or partial pay during the absence period, as per company policy and collective agreement.' ;
    rdfs:domain ind:Absence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonNotes rdf:type rdf:Property ;
    rdfs:label 'Reason Notes' ;
    rdfs:comment 'Free-text notes providing additional context or details about the reason for the absence. May contain sensitive personal information.' ;
    rdfs:domain ind:Absence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replacementRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Replacement Required Flag' ;
    rdfs:comment 'Indicates whether a replacement crew member is required to cover the absent crew member\'s scheduled duties. True if replacement is needed, False otherwise.' ;
    rdfs:domain ind:Absence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:returnToDutyClearanceFlag rdf:type rdf:Property ;
    rdfs:label 'Return To Duty Clearance Flag' ;
    rdfs:comment 'Indicates whether the crew member has received medical or administrative clearance to return to duty. True if cleared, False otherwise.' ;
    rdfs:domain ind:Absence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:returnToDutyDate rdf:type rdf:Property ;
    rdfs:label 'Return To Duty Date' ;
    rdfs:comment 'The actual date when the crew member returned to active duty following the absence. Nullable if the crew member has not yet returned.' ;
    rdfs:domain ind:Absence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:startDate rdf:type rdf:Property ;
    rdfs:label 'Start Date' ;
    rdfs:comment 'The date when the crew absence period begins.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:primaryRegulatoryAuthorityId rdf:type rdf:Property ;
    rdfs:label 'Primary Regulatory Authority Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_authority. Business justification: Each crew base operates under primary regulatory authority jurisdiction determining applicable FTL rules, crew qualification requirements, and operational standards. Essential for compliance program d' ;
    rdfs:domain ind:Base ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryAuthority .

ind:baseCode rdf:type rdf:Property ;
    rdfs:label 'Base Code' ;
    rdfs:comment 'Three-letter IATA airport code representing the crew domicile base (e.g., JFK, LAX, ORD). This is the operational identifier used in crew scheduling and pairing construction.' ;
    rdfs:domain ind:Base ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseName rdf:type rdf:Property ;
    rdfs:label 'Base Name' ;
    rdfs:comment 'Full descriptive name of the crew base (e.g., \'New York JFK Base\', \'Los Angeles International Base\'). Human-readable identifier for business users.' ;
    rdfs:domain ind:Base ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseStatus rdf:type rdf:Property ;
    rdfs:label 'Base Status' ;
    rdfs:comment 'Current operational status of the crew base. Active = fully operational, Inactive = temporarily not staffed, Seasonal = operates during specific periods, Temporary = short-term base, Closed = permanently shut down.' ;
    rdfs:domain ind:Base ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseType rdf:type rdf:Property ;
    rdfs:label 'Base Type' ;
    rdfs:comment 'Classification of the crew base by operational role within the network (hub = major connecting base, spoke = destination base, regional = regional operations, international = international crew base, domestic = domestic-only operations, satellite = secondary base).' ;
    rdfs:domain ind:Base ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cabinCrewCapacity rdf:type rdf:Property ;
    rdfs:label 'Cabin Crew Capacity' ;
    rdfs:comment 'Authorized headcount for cabin crew (flight attendants) assigned to this base. Used for crew planning, reserve pool sizing, and capacity management.' ;
    rdfs:domain ind:Base ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:crewCategoriesServed rdf:type rdf:Property ;
    rdfs:label 'Crew Categories Served' ;
    rdfs:comment 'Indicates which crew categories are domiciled at this base (flight_deck_only = pilots only, cabin_crew_only = flight attendants only, both = pilots and cabin crew, all = all crew types including ground crew).' ;
    rdfs:domain ind:Base ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crewTrainingFacilityAvailable rdf:type rdf:Property ;
    rdfs:label 'Crew Training Facility Available' ;
    rdfs:comment 'Indicates whether crew training facilities (simulators, classrooms, recurrent training) are available at or near this base. Impacts crew recency management and type rating maintenance.' ;
    rdfs:domain ind:Base ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:currentCabinCrewCount rdf:type rdf:Property ;
    rdfs:label 'Current Cabin Crew Count' ;
    rdfs:comment 'Current actual number of cabin crew members assigned to this base. Used to calculate staffing gaps and utilization.' ;
    rdfs:domain ind:Base ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:currentFlightDeckCount rdf:type rdf:Property ;
    rdfs:label 'Current Flight Deck Count' ;
    rdfs:comment 'Current actual number of flight deck crew members assigned to this base. Used to calculate staffing gaps and utilization.' ;
    rdfs:domain ind:Base ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deadheadPositioningAllowed rdf:type rdf:Property ;
    rdfs:label 'Deadhead Positioning Allowed' ;
    rdfs:comment 'Indicates whether crew can be deadheaded (repositioned without revenue duty) to or from this base. Used in crew positioning decisions and irregular operations recovery.' ;
    rdfs:domain ind:Base ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:flightDeckCapacity rdf:type rdf:Property ;
    rdfs:label 'Flight Deck Capacity' ;
    rdfs:comment 'Authorized headcount for flight deck crew (pilots) assigned to this base. Used for crew planning, reserve pool sizing, and capacity management.' ;
    rdfs:domain ind:Base ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ftlRegulationApplicable rdf:type rdf:Property ;
    rdfs:label 'Ftl Regulation Applicable' ;
    rdfs:comment 'Specific flight time limitations and rest requirements regulation applicable to crew based at this location (FAR_117 = US FAR Part 117, EASA_FTL = EASA Flight Time Limitations, CAP_371 = UK CAA Flight Time Limitations, other = jurisdiction-specific regulations).' ;
    rdfs:domain ind:Base ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icaoCode rdf:type rdf:Property ;
    rdfs:label 'Icao Code' ;
    rdfs:comment 'Four-letter ICAO airport code for the crew base location (e.g., KJFK, KLAX, KORD). Used for international flight operations and regulatory reporting.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationalTimezone rdf:type rdf:Property ;
    rdfs:label 'Operational Timezone' ;
    rdfs:comment 'IANA timezone identifier for the crew base location (e.g., \'America/New_York\', \'America/Los_Angeles\'). Used for duty period calculations, rest requirement enforcement, and fatigue risk management per FAR Part 117 and EASA FTL.' ;
    rdfs:domain ind:Base ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pairingStartEndBase rdf:type rdf:Property ;
    rdfs:label 'Pairing Start End Base' ;
    rdfs:comment 'Indicates whether this base is used as a start/end point for crew pairings. True = pairings are constructed to begin and end at this base, False = crew may be positioned but pairings do not originate here.' ;
    rdfs:domain ind:Base ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:physicalAddress rdf:type rdf:Property ;
    rdfs:label 'Physical Address' ;
    rdfs:comment 'Full physical address of the crew base operations office or crew reporting location. Used for crew reporting instructions and facility management.' ;
    rdfs:domain ind:Base ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reservePoolRequired rdf:type rdf:Property ;
    rdfs:label 'Reserve Pool Required' ;
    rdfs:comment 'Indicates whether a reserve crew pool is maintained at this base for operational contingencies, irregular operations, and last-minute crew substitutions.' ;
    rdfs:domain ind:Base ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reservePoolSizeCabin rdf:type rdf:Property ;
    rdfs:label 'Reserve Pool Size Cabin' ;
    rdfs:comment 'Target number of cabin crew members to maintain in reserve status at this base. Used for reserve pool sizing and crew resource allocation.' ;
    rdfs:domain ind:Base ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reservePoolSizeFlightDeck rdf:type rdf:Property ;
    rdfs:label 'Reserve Pool Size Flight Deck' ;
    rdfs:comment 'Target number of flight deck crew members to maintain in reserve status at this base. Used for reserve pool sizing and crew resource allocation.' ;
    rdfs:domain ind:Base ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:restFacilityAvailable rdf:type rdf:Property ;
    rdfs:label 'Rest Facility Available' ;
    rdfs:comment 'Indicates whether crew rest facilities are available at this base for pre-duty rest, post-duty rest, or reserve crew standby. Critical for fatigue risk management and crew legality checks.' ;
    rdfs:domain ind:Base ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:restFacilityCapacity rdf:type rdf:Property ;
    rdfs:label 'Rest Facility Capacity' ;
    rdfs:comment 'Maximum number of crew members that can be accommodated simultaneously in the base rest facilities. Used for reserve crew planning and irregular operations (IROP) management.' ;
    rdfs:domain ind:Base ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:restFacilityType rdf:type rdf:Property ;
    rdfs:label 'Rest Facility Type' ;
    rdfs:comment 'Type of rest facility available at the base (hotel = contracted hotel rooms, crew_lounge = airport crew lounge, dedicated_facility = airline-owned rest facility, none = no rest facility).' ;
    rdfs:domain ind:Base ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationDate rdf:type rdf:Property ;
    rdfs:label 'Termination Date' ;
    rdfs:comment 'Date when this crew base was closed or deactivated. Null for active bases. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bidId rdf:type rdf:Property ;
    rdfs:label 'Bid Id' ;
    rdfs:comment 'Unique identifier for the crew bid submission. Primary key for the crew bid product.' ;
    rdfs:domain ind:Bid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:avoidRedEyeFlag rdf:type rdf:Property ;
    rdfs:label 'Avoid Red Eye Flag' ;
    rdfs:comment 'Boolean flag indicating whether the crew member prefers to avoid red-eye flights (overnight flights departing late evening and arriving early morning). True means avoid red-eyes.' ;
    rdfs:domain ind:Bid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:awardPublishTimestamp rdf:type rdf:Property ;
    rdfs:label 'Award Publish Timestamp' ;
    rdfs:comment 'Date and time when the PBS award results were published and made available to crew members. Crew can view their awarded lines after this time.' ;
    rdfs:domain ind:Bid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:awardScore rdf:type rdf:Property ;
    rdfs:label 'Award Score' ;
    rdfs:comment 'Numerical score calculated by PBS representing how well the awarded line matches the crew member\'s bid preferences. Higher scores indicate better preference satisfaction.' ;
    rdfs:domain ind:Bid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:awardedLineNumber rdf:type rdf:Property ;
    rdfs:label 'Awarded Line Number' ;
    rdfs:comment 'The line number or pairing sequence identifier awarded to the crew member by the PBS system after bid processing. Null if bid not yet awarded or if reserve status.' ;
    rdfs:domain ind:Bid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bidCategory rdf:type rdf:Property ;
    rdfs:label 'Bid Category' ;
    rdfs:comment 'Category of the bid submission indicating the crew member\'s operational status during the bid period. Line holder bids for regular pairings, reserve bids for standby duty, transition for crew changing status.' ;
    rdfs:domain ind:Bid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bidStatus rdf:type rdf:Property ;
    rdfs:label 'Bid Status' ;
    rdfs:comment 'Current lifecycle status of the bid submission. Tracks the bid from initial draft through submission, closure of bidding window, PBS award processing, and final state.' ;
    rdfs:domain ind:Bid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commuterFriendlyFlag rdf:type rdf:Property ;
    rdfs:label 'Commuter Friendly Flag' ;
    rdfs:comment 'Boolean flag indicating whether the crew member requires commuter-friendly patterns with late report times and early release times to accommodate commuting from non-base locations. True means commuter-friendly patterns preferred.' ;
    rdfs:domain ind:Bid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:linesJson rdf:type rdf:Property ;
    rdfs:label 'Lines Json' ;
    rdfs:comment 'JSON-encoded ordered preference list of pairings, days off, vacation slots, and training events. Contains the crew member\'s ranked preferences submitted to PBS for schedule optimization.' ;
    rdfs:domain ind:Bid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxDutyDaysConstraint rdf:type rdf:Property ;
    rdfs:label 'Max Duty Days Constraint' ;
    rdfs:comment 'Maximum number of duty days the crew member is willing to work in the bid period. Used by PBS to filter and rank pairing options.' ;
    rdfs:domain ind:Bid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minDaysOffConstraint rdf:type rdf:Property ;
    rdfs:label 'Min Days Off Constraint' ;
    rdfs:comment 'Minimum number of days off the crew member requests in the bid period. PBS will attempt to honor this constraint when awarding lines.' ;
    rdfs:domain ind:Bid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overrideFlag rdf:type rdf:Property ;
    rdfs:label 'Override Flag' ;
    rdfs:comment 'Boolean flag indicating whether this bid or its award was subject to manual override by crew scheduling management. True indicates an override occurred.' ;
    rdfs:domain ind:Bid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overrideReason rdf:type rdf:Property ;
    rdfs:label 'Override Reason' ;
    rdfs:comment 'Free-text explanation of why a manual override was applied to this bid or award. Populated only when override_flag is true. Documents operational or contractual justification.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pbsProcessingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pbs Processing Timestamp' ;
    rdfs:comment 'Date and time when the PBS system processed this bid and generated the award. Represents when the optimization algorithm ran and assigned lines to crew members.' ;
    rdfs:domain ind:Bid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:periodMonth rdf:type rdf:Property ;
    rdfs:label 'Period Month' ;
    rdfs:comment 'Month component of the bid period for which the crew member is submitting preferences (1-12).' ;
    rdfs:domain ind:Bid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:periodYear rdf:type rdf:Property ;
    rdfs:label 'Period Year' ;
    rdfs:comment 'Year component of the bid period for which the crew member is submitting preferences (e.g., 2024).' ;
    rdfs:domain ind:Bid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preferredDaysOff rdf:type rdf:Property ;
    rdfs:label 'Preferred Days Off' ;
    rdfs:comment 'Comma-separated list of specific dates (YYYY-MM-DD format) or day-of-week patterns the crew member prefers as days off. Used by PBS to optimize schedule satisfaction.' ;
    rdfs:domain ind:Bid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredLayoverStations rdf:type rdf:Property ;
    rdfs:label 'Preferred Layover Stations' ;
    rdfs:comment 'Comma-separated list of IATA or ICAO airport codes representing the crew member\'s preferred layover destinations. PBS uses this to prioritize pairings with these overnight stations.' ;
    rdfs:domain ind:Bid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionNumber rdf:type rdf:Property ;
    rdfs:label 'Revision Number' ;
    rdfs:comment 'Sequential revision number tracking how many times the crew member modified their bid during the open bidding window. Starts at 1 for initial submission, increments with each update.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:satisfactionPercentage rdf:type rdf:Property ;
    rdfs:label 'Satisfaction Percentage' ;
    rdfs:comment 'Percentage (0-100) representing the degree to which the awarded line satisfies the crew member\'s bid preferences. Calculated by PBS based on preference weights and constraints met.' ;
    rdfs:domain ind:Bid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:seniorityNumber rdf:type rdf:Property ;
    rdfs:label 'Seniority Number' ;
    rdfs:comment 'The crew member\'s seniority ranking number at the time of bid submission. Lower numbers indicate higher seniority. Used by PBS to prioritize bid awards in seniority order.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trainingSlotRequests rdf:type rdf:Property ;
    rdfs:label 'Training Slot Requests' ;
    rdfs:comment 'Comma-separated list of training event identifiers or date ranges for which the crew member is requesting scheduled training slots within the bid period.' ;
    rdfs:domain ind:Bid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vacationRequestDates rdf:type rdf:Property ;
    rdfs:label 'Vacation Request Dates' ;
    rdfs:comment 'Comma-separated list of date ranges (start-end pairs) for which the crew member is requesting vacation time within the bid period. Subject to seniority-based approval.' ;
    rdfs:domain ind:Bid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:windowCloseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Window Close Timestamp' ;
    rdfs:comment 'Date and time when the bidding window closed for this bid period. No further bid submissions or modifications are accepted after this time. PBS processing begins after closure.' ;
    rdfs:domain ind:Bid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:windowOpenTimestamp rdf:type rdf:Property ;
    rdfs:label 'Window Open Timestamp' ;
    rdfs:comment 'Date and time when the bidding window opened for this bid period. Crew members can begin submitting or modifying bids after this time.' ;
    rdfs:domain ind:Bid ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:certifyingStaffId rdf:type rdf:Property ;
    rdfs:label 'Certifying Staff Id' ;
    rdfs:comment 'Foreign key linking to maintenance.certifying_staff. Business justification: Dual-role personnel: pilots/engineers holding maintenance certifications perform sign-offs. Business process: tracking crew members authorized for maintenance release, Part-145 compliance, dual-role w' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CertifyingStaff .

ind:crewCostCentreId rdf:type rdf:Property ;
    rdfs:label 'Crew Cost Centre Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_centre. Business justification: Crew members are assigned to cost centres for payroll allocation, CASK calculation, and crew cost attribution in airline financial reporting. Fundamental to operational cost accounting and route profi' ;
    rdfs:domain ind:Member ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCentre .

ind:employeeFfpMemberId rdf:type rdf:Property ;
    rdfs:label 'Employee Ffp Member Id' ;
    rdfs:comment 'Foreign key linking to loyalty.ffp_member. Business justification: Airlines track crew members\' loyalty program memberships for employee travel benefits, staff travel privileges, recognition programs, and discounted/complimentary award bookings. Standard HR-loyalty i' ;
    rdfs:domain ind:Member ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FfpMember .

ind:licenseIssuingRegulatoryAuthorityId rdf:type rdf:Property ;
    rdfs:label 'License Issuing Regulatory Authority Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_authority. Business justification: Crew member licenses are issued under specific regulatory authority jurisdiction (FAA, EASA, TCCA). Essential for validating license validity, determining applicable regulations, and regulatory report' ;
    rdfs:domain ind:Member ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryAuthority .

ind:primaryAircraftTypeId rdf:type rdf:Property ;
    rdfs:label 'Primary Aircraft Type Id' ;
    rdfs:comment 'Foreign key linking to fleet.aircraft_type. Business justification: Crew scheduling and qualification tracking require knowing each crew member\'s primary aircraft type rating. Essential for daily crew assignment validation, reserve crew callout, and regulatory complia' ;
    rdfs:domain ind:Member ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AircraftType .

ind:aimsCrewCode rdf:type rdf:Property ;
    rdfs:label 'Aims Crew Code' ;
    rdfs:comment 'External crew identifier from the AIMS Crew Management System. Used for integration and reconciliation with the source system of record.' ;
    rdfs:domain ind:Member ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crewCategory rdf:type rdf:Property ;
    rdfs:label 'Crew Category' ;
    rdfs:comment 'Primary classification of crew member role: flight deck (pilots, first officers), cabin (flight attendants, pursers), ground operations, maintenance, dispatch, or other support roles.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dateOfBirth rdf:type rdf:Property ;
    rdfs:label 'Date Of Birth' ;
    rdfs:comment 'Crew member\'s date of birth, used for age-related regulatory compliance, retirement planning, and medical certification tracking.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dateOfHire rdf:type rdf:Property ;
    rdfs:label 'Date Of Hire' ;
    rdfs:comment 'The date the crew member was originally hired by the airline, used for seniority calculations and benefit eligibility.' ;
    rdfs:domain ind:Member ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:emailAddress rdf:type rdf:Property ;
    rdfs:label 'Email Address' ;
    rdfs:comment 'Primary corporate email address for crew communications, scheduling notifications, and operational updates.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employmentStatus rdf:type rdf:Property ;
    rdfs:label 'Employment Status' ;
    rdfs:comment 'Current employment classification indicating the crew member\'s contractual relationship with the airline.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:familyName rdf:type rdf:Property ;
    rdfs:label 'Family Name' ;
    rdfs:comment 'The crew member\'s legal last name or surname as it appears on official documents and travel credentials.' ;
    rdfs:domain ind:Member ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:givenName rdf:type rdf:Property ;
    rdfs:label 'Given Name' ;
    rdfs:comment 'The crew member\'s legal first name as it appears on official documents and travel credentials.' ;
    rdfs:domain ind:Member ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageProficiencyCodes rdf:type rdf:Property ;
    rdfs:label 'Language Proficiency Codes' ;
    rdfs:comment 'Comma-separated list of language codes and proficiency levels (e.g., ENG:6, SPA:4) per ICAO Language Proficiency Requirements for international operations.' ;
    rdfs:domain ind:Member ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastLineCheckDate rdf:type rdf:Property ;
    rdfs:label 'Last Line Check Date' ;
    rdfs:comment 'Date of the crew member\'s most recent line check or proficiency check conducted during actual flight operations.' ;
    rdfs:domain ind:Member ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastRecurrentTrainingDate rdf:type rdf:Property ;
    rdfs:label 'Last Recurrent Training Date' ;
    rdfs:comment 'Date of the crew member\'s most recent recurrent training completion, required annually or semi-annually per regulatory requirements.' ;
    rdfs:domain ind:Member ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:medicalCertificateClass rdf:type rdf:Property ;
    rdfs:label 'Medical Certificate Class' ;
    rdfs:comment 'Classification of the crew member\'s aviation medical certificate (Class 1 for airline transport pilots, Class 2 for commercial pilots, cabin crew medical, etc.).' ;
    rdfs:domain ind:Member ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalCertificateExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Medical Certificate Expiry Date' ;
    rdfs:comment 'Expiration date of the crew member\'s current aviation medical certificate, critical for maintaining operational legality.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:middleName rdf:type rdf:Property ;
    rdfs:label 'Middle Name' ;
    rdfs:comment 'The crew member\'s middle name or initial, if applicable.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mobilePhoneNumber rdf:type rdf:Property ;
    rdfs:label 'Mobile Phone Number' ;
    rdfs:comment 'Primary mobile contact number for crew scheduling, irregular operations (IROP) notifications, and emergency contact.' ;
    rdfs:domain ind:Member ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nationalityCode rdf:type rdf:Property ;
    rdfs:label 'Nationality Code' ;
    rdfs:comment 'Three-letter ISO country code representing the crew member\'s nationality, relevant for visa requirements and international operations.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextRecurrentTrainingDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Recurrent Training Due Date' ;
    rdfs:comment 'Date by which the crew member must complete their next recurrent training to maintain operational currency.' ;
    rdfs:domain ind:Member ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:passportExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Passport Expiry Date' ;
    rdfs:comment 'Expiration date of the crew member\'s passport, monitored to ensure compliance with six-month validity rules for international operations.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:passportNumber rdf:type rdf:Property ;
    rdfs:label 'Passport Number' ;
    rdfs:comment 'Crew member\'s passport number required for international flight operations and border crossing documentation.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityClearanceExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Security Clearance Expiry Date' ;
    rdfs:comment 'Expiration date of the crew member\'s airport security clearance or background check, required for access to secure areas.' ;
    rdfs:domain ind:Member ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:terminationReason rdf:type rdf:Property ;
    rdfs:label 'Termination Reason' ;
    rdfs:comment 'Brief description or code indicating the reason for employment termination (e.g., resignation, retirement, dismissal, medical).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalFlightHours rdf:type rdf:Property ;
    rdfs:label 'Total Flight Hours' ;
    rdfs:comment 'Cumulative total flight hours logged by the crew member across their entire career, used for experience tracking and regulatory compliance.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unionMembershipFlag rdf:type rdf:Property ;
    rdfs:label 'Union Membership Flag' ;
    rdfs:comment 'Indicates whether the crew member is a member of a labor union or collective bargaining unit.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trainingEventId rdf:type rdf:Property ;
    rdfs:label 'Training Event Id' ;
    rdfs:comment 'Unique identifier for the crew training event record. Primary key.' ;
    rdfs:domain ind:TrainingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certifyingInstructorCertifyingStaffId rdf:type rdf:Property ;
    rdfs:label 'Certifying Instructor Certifying Staff Id' ;
    rdfs:comment 'Foreign key linking to maintenance.certifying_staff. Business justification: Maintenance certifying staff deliver technical training to flight crew on aircraft systems, MEL procedures, technical limitations. Business process: instructor qualification tracking, training deliver' ;
    rdfs:domain ind:TrainingEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CertifyingStaff .

ind:correctiveActionId rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Id' ;
    rdfs:comment 'Foreign key linking to safety.corrective_action. Business justification: Training events are often corrective actions from safety findings, audit findings, or occurrence investigations. Real business process: safety-driven training requirements, competency remediation, and' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CorrectiveAction .

ind:primaryTrainingMemberId rdf:type rdf:Property ;
    rdfs:label 'Primary Training Member Id' ;
    rdfs:comment 'Identifier of the crew member who participated in this training event.' ;
    rdfs:domain ind:TrainingEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Member .

ind:purchaseOrderId rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Id' ;
    rdfs:comment 'Foreign key linking to procurement.purchase_order. Business justification: Individual training events generate purchase orders for the training service. Critical for three-way match (PO-training completion-invoice), accrual accounting, cost center allocation, training spend ' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseOrder .

ind:trainingCostCentreId rdf:type rdf:Property ;
    rdfs:label 'Training Cost Centre Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_centre. Business justification: Training events are significant cost items allocated to training cost centres for budget tracking, cost recovery, and regulatory compliance reporting. Essential for training cost management and financ' ;
    rdfs:domain ind:TrainingEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCentre .

ind:trainingStationId rdf:type rdf:Property ;
    rdfs:label 'Training Station Id' ;
    rdfs:comment 'Foreign key linking to airport.station. Business justification: Training events occur at stations with training facilities (simulators, classrooms). Required for training logistics planning, crew travel arrangements, and facility capacity management. Replaces deno' ;
    rdfs:domain ind:TrainingEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Station .

ind:trainingVendorId rdf:type rdf:Property ;
    rdfs:label 'Training Vendor Id' ;
    rdfs:comment 'Foreign key linking to procurement.vendor. Business justification: Airlines procure simulator time, type rating courses, and recurrent training from external vendors. Essential for training cost analysis, vendor performance tracking, invoice reconciliation, and regul' ;
    rdfs:domain ind:TrainingEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:approvalAuthority rdf:type rdf:Property ;
    rdfs:label 'Approval Authority' ;
    rdfs:comment 'Name or identifier of the regulatory authority or company official who approved or certified this training event.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookingReference rdf:type rdf:Property ;
    rdfs:label 'Booking Reference' ;
    rdfs:comment 'Booking or reservation reference number for the training event, used for scheduling and resource allocation.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crewPositionCode rdf:type rdf:Property ;
    rdfs:label 'Crew Position Code' ;
    rdfs:comment 'Position for which the training was conducted. CA=Captain, FO=First Officer, SO=Second Officer, PU=Pilot Under Supervision, FA=Flight Attendant, CSM=Cabin Service Manager, LSM=Lead Service Manager. [ENUM-REF-CANDIDATE: CA|FO|SO|PU|FA|CSM|LSM — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instructorName rdf:type rdf:Property ;
    rdfs:label 'Instructor Name' ;
    rdfs:comment 'Full name of the instructor or examiner who conducted the training event.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRegulatoryRequired rdf:type rdf:Property ;
    rdfs:label 'Is Regulatory Required' ;
    rdfs:comment 'Flag indicating whether this training event is mandated by regulatory authority (FAA, EASA) or is voluntary/company-initiated.' ;
    rdfs:domain ind:TrainingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Due Date' ;
    rdfs:comment 'Date by which the next recurrent training event must be completed to maintain qualification.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:passThresholdScore rdf:type rdf:Property ;
    rdfs:label 'Pass Threshold Score' ;
    rdfs:comment 'Minimum score required to pass the training event, if applicable.' ;
    rdfs:domain ind:TrainingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:simulatorDeviceCode rdf:type rdf:Property ;
    rdfs:label 'Simulator Device Code' ;
    rdfs:comment 'Identifier of the flight simulator or training device used for the training event. Null for non-simulator training.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingCategory rdf:type rdf:Property ;
    rdfs:label 'Training Category' ;
    rdfs:comment 'Category of training event. INITIAL=First-time qualification, RECURRENT=Periodic revalidation, UPGRADE=Promotion to higher position, TRANSITION=Change to different aircraft type, REQUALIFICATION=Return after lapse, REFRESHER=Skill maintenance.' ;
    rdfs:domain ind:TrainingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingCostAmount rdf:type rdf:Property ;
    rdfs:label 'Training Cost Amount' ;
    rdfs:comment 'Total cost incurred for this training event, including instructor fees, simulator time, materials, and facility charges.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingCostCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Training Cost Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the training cost amount.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingDate rdf:type rdf:Property ;
    rdfs:label 'Training Date' ;
    rdfs:comment 'Date on which the training event occurred or was completed.' ;
    rdfs:domain ind:TrainingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trainingDurationHours rdf:type rdf:Property ;
    rdfs:label 'Training Duration Hours' ;
    rdfs:comment 'Total duration of the training event in hours.' ;
    rdfs:domain ind:TrainingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Training End Timestamp' ;
    rdfs:comment 'Timestamp when the training session ended.' ;
    rdfs:domain ind:TrainingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:trainingMethod rdf:type rdf:Property ;
    rdfs:label 'Training Method' ;
    rdfs:comment 'Method by which the training was delivered. SIMULATOR=Flight simulator session, CLASSROOM=In-person classroom, CBT=Computer-Based Training, LINE=Line operational training, PRACTICAL=Hands-on practical, ONLINE=Remote online training.' ;
    rdfs:domain ind:TrainingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingResultCode rdf:type rdf:Property ;
    rdfs:label 'Training Result Code' ;
    rdfs:comment 'Outcome of the training event. PASS=Successfully completed, FAIL=Did not meet standards, INCOMPLETE=Not finished, PARTIAL=Partially completed, DEFERRED=Postponed, CANCELLED=Event cancelled.' ;
    rdfs:domain ind:TrainingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingScore rdf:type rdf:Property ;
    rdfs:label 'Training Score' ;
    rdfs:comment 'Numerical score or grade achieved in the training event, if applicable. Null for pass/fail only training.' ;
    rdfs:domain ind:TrainingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Training Start Timestamp' ;
    rdfs:comment 'Timestamp when the training session began.' ;
    rdfs:domain ind:TrainingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:trainingStatus rdf:type rdf:Property ;
    rdfs:label 'Training Status' ;
    rdfs:comment 'Current status of the training event in its lifecycle. SCHEDULED=Planned but not started, IN_PROGRESS=Currently underway, COMPLETED=Finished, CANCELLED=Event cancelled, NO_SHOW=Crew member did not attend.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingSyllabusVersion rdf:type rdf:Property ;
    rdfs:label 'Training Syllabus Version' ;
    rdfs:comment 'Version identifier of the training syllabus or curriculum used for this event.' ;
    rdfs:domain ind:TrainingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingTypeCode rdf:type rdf:Property ;
    rdfs:label 'Training Type Code' ;
    rdfs:comment 'Code representing the type of training event. PC=Proficiency Check, OPC=Operator Proficiency Check, LOE=Line Operational Evaluation, EPT=Emergency Procedures Training, CRM=Crew Resource Management, ETOPS=Extended-range Twin-engine Operational Performance Standards, DG=Dangerous Goods, SEC=Security Training, GND=Ground Training, DIFF=Differences Training, RECUR=Recurrent Training. [ENUM-REF-CANDIDATE: PC|OPC|LOE|EPT|CRM|ETOPS|DG|SEC|GND|DIFF|RECUR — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TrainingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dutyPeriodId rdf:type rdf:Property ;
    rdfs:label 'Duty Period Id' ;
    rdfs:comment 'Unique identifier for the duty period. Primary key.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DutyPeriod .

ind:dutyCostCentreId rdf:type rdf:Property ;
    rdfs:label 'Duty Cost Centre Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_centre. Business justification: Duty periods drive crew cost allocation for flight-level P&L, activity-based costing, and cost centre reporting. Supports detailed operational cost analysis and variance reporting against budget.' ;
    rdfs:domain ind:DutyPeriod ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCentre .

ind:pairingId rdf:type rdf:Property ;
    rdfs:label 'Pairing Id' ;
    rdfs:comment 'Reference to the pairing that contains this duty period. A pairing is a sequence of duty periods and rest periods assigned to a crew member.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Pairing .

ind:acclimationStatus rdf:type rdf:Property ;
    rdfs:label 'Acclimation Status' ;
    rdfs:comment 'Indicates whether the crew member is acclimated to the local time zone at duty start. Acclimated means the crew member has been in the time zone for sufficient time per FAR Part 117 definitions. Affects maximum FDP limits.' ;
    rdfs:domain ind:DutyPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualFlag rdf:type rdf:Property ;
    rdfs:label 'Actual Flag' ;
    rdfs:comment 'Indicates whether this duty period was actually operated (True) or was planned but not executed (False). Used for payroll and compliance reporting.' ;
    rdfs:domain ind:DutyPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:augmentedCrewFlag rdf:type rdf:Property ;
    rdfs:label 'Augmented Crew Flag' ;
    rdfs:comment 'Indicates whether this duty period involves augmented crew (additional crew members allowing in-flight rest). True if augmented, False otherwise. Affects maximum FDP limits.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:blockHoursMinutes rdf:type rdf:Property ;
    rdfs:label 'Block Hours Minutes' ;
    rdfs:comment 'Total block time (gate departure to gate arrival) in minutes for all flight segments within this duty period. Null for non-flight duty types.' ;
    rdfs:domain ind:DutyPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cancellationReasonCode rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason Code' ;
    rdfs:comment 'Code indicating why the duty period was cancelled if actual_flag is False (e.g., CREW_SICK, AIRCRAFT_MAINTENANCE, WEATHER, SCHEDULE_CHANGE). Null if duty was operated.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dutyEndStationCode rdf:type rdf:Property ;
    rdfs:label 'Duty End Station Code' ;
    rdfs:comment 'Three-letter IATA airport code where the duty period ends (release location).' ;
    rdfs:domain ind:DutyPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dutyPeriodNumber rdf:type rdf:Property ;
    rdfs:label 'Duty Period Number' ;
    rdfs:comment 'Sequential number of this duty period within the pairing (1, 2, 3, etc.).' ;
    rdfs:domain ind:DutyPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dutyStartStationCode rdf:type rdf:Property ;
    rdfs:label 'Duty Start Station Code' ;
    rdfs:comment 'Three-letter IATA airport code where the duty period begins (report location).' ;
    rdfs:domain ind:DutyPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dutyType rdf:type rdf:Property ;
    rdfs:label 'Duty Type' ;
    rdfs:comment 'Classification of the duty period: flight duty (operating flights), ground duty (administrative/ground tasks), deadhead (crew repositioning without revenue duty), training (simulator/classroom), standby (on-call at airport), or reserve (on-call at home/hotel).' ;
    rdfs:domain ind:DutyPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:easaFtlCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Easa Ftl Compliant Flag' ;
    rdfs:comment 'Indicates whether this duty period is compliant with EASA FTL regulations. True if compliant, False if violation detected.' ;
    rdfs:domain ind:DutyPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:far117CompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Far 117 Compliant Flag' ;
    rdfs:comment 'Indicates whether this duty period is compliant with FAA FAR Part 117 flight and duty time limitations. True if compliant, False if violation detected.' ;
    rdfs:domain ind:DutyPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fatigueRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Fatigue Risk Level' ;
    rdfs:comment 'Categorical fatigue risk level derived from the fatigue risk score: low (acceptable), moderate (monitor), high (mitigate), critical (unacceptable).' ;
    rdfs:domain ind:DutyPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fatigueRiskScore rdf:type rdf:Property ;
    rdfs:label 'Fatigue Risk Score' ;
    rdfs:comment 'Calculated fatigue risk score for this duty period based on biomathematical fatigue models (e.g., SAFTE-FAST, Boeing Alertness Model). Higher scores indicate higher fatigue risk. Scale typically 0-100.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fdpElapsedTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Fdp Elapsed Time Minutes' ;
    rdfs:comment 'Total elapsed time in minutes from FDP start to FDP end. Critical for FAR Part 117 and EASA FTL maximum FDP limit checks. Null for non-flight duty types.' ;
    rdfs:domain ind:DutyPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fdpEndTime rdf:type rdf:Property ;
    rdfs:label 'Fdp End Time' ;
    rdfs:comment 'Timestamp marking the end of the flight duty period, which ends when the aircraft finally comes to rest and the engines are shut down at the last flight segment. Null for non-flight duty types.' ;
    rdfs:domain ind:DutyPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fdpStartTime rdf:type rdf:Property ;
    rdfs:label 'Fdp Start Time' ;
    rdfs:comment 'Timestamp marking the start of the flight duty period, which begins when a crew member is required to report for duty with the intention of conducting a flight. Null for non-flight duty types.' ;
    rdfs:domain ind:DutyPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:flightSegmentsCount rdf:type rdf:Property ;
    rdfs:label 'Flight Segments Count' ;
    rdfs:comment 'Number of flight segments (takeoff and landing cycles) operated during this duty period. Used for fatigue risk assessment. Null for non-flight duty types.' ;
    rdfs:domain ind:DutyPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:legalityStatus rdf:type rdf:Property ;
    rdfs:label 'Legality Status' ;
    rdfs:comment 'Overall legality status of the duty period considering all applicable regulations (FAR Part 117, EASA FTL, company policies). Legal means all checks passed; illegal means one or more violations detected; waiver_granted means a regulatory waiver was approved; under_review means legality is being assessed.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalityViolationCodes rdf:type rdf:Property ;
    rdfs:label 'Legality Violation Codes' ;
    rdfs:comment 'Comma-separated list of violation codes if the duty period is illegal (e.g., MAX_FDP_EXCEEDED, INSUFFICIENT_REST, MAX_DUTY_EXCEEDED). Null if legal.' ;
    rdfs:domain ind:DutyPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseTime rdf:type rdf:Property ;
    rdfs:label 'Release Time' ;
    rdfs:comment 'Timestamp when the crew member is released from duty. Marks the end of the duty period.' ;
    rdfs:domain ind:DutyPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reportTime rdf:type rdf:Property ;
    rdfs:label 'Report Time' ;
    rdfs:comment 'Timestamp when the crew member is required to report for duty. Marks the start of the duty period.' ;
    rdfs:domain ind:DutyPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:restPeriodAfterMinutes rdf:type rdf:Property ;
    rdfs:label 'Rest Period After Minutes' ;
    rdfs:comment 'Duration in minutes of the rest period immediately following this duty period. Used to verify minimum rest requirements per FAR Part 117 and EASA FTL.' ;
    rdfs:domain ind:DutyPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:restPeriodBeforeMinutes rdf:type rdf:Property ;
    rdfs:label 'Rest Period Before Minutes' ;
    rdfs:comment 'Duration in minutes of the rest period immediately preceding this duty period. Used to verify minimum rest requirements per FAR Part 117 and EASA FTL.' ;
    rdfs:domain ind:DutyPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scheduledFlag rdf:type rdf:Property ;
    rdfs:label 'Scheduled Flag' ;
    rdfs:comment 'Indicates whether this duty period was part of the original published schedule (True) or was added/modified after publication (False). Used for operational performance tracking.' ;
    rdfs:domain ind:DutyPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:splitDutyFlag rdf:type rdf:Property ;
    rdfs:label 'Split Duty Flag' ;
    rdfs:comment 'Indicates whether this duty period qualifies as split duty (duty period interrupted by a rest opportunity). True if split duty, False otherwise. Affects FDP extension calculations.' ;
    rdfs:domain ind:DutyPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:splitDutyRestMinutes rdf:type rdf:Property ;
    rdfs:label 'Split Duty Rest Minutes' ;
    rdfs:comment 'Duration in minutes of the rest opportunity during a split duty period. Null if not a split duty. Used to calculate FDP extensions.' ;
    rdfs:domain ind:DutyPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:timeZoneCrossingsCount rdf:type rdf:Property ;
    rdfs:label 'Time Zone Crossings Count' ;
    rdfs:comment 'Number of time zones crossed during this duty period. Used for fatigue risk and circadian disruption assessment.' ;
    rdfs:domain ind:DutyPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:timeZoneEnd rdf:type rdf:Property ;
    rdfs:label 'Time Zone End' ;
    rdfs:comment 'IANA time zone identifier for the duty end station (e.g., Europe/London). Used for circadian rhythm and fatigue risk calculations.' ;
    rdfs:domain ind:DutyPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeZoneStart rdf:type rdf:Property ;
    rdfs:label 'Time Zone Start' ;
    rdfs:comment 'IANA time zone identifier for the duty start station (e.g., America/New_York). Used for circadian rhythm and fatigue risk calculations.' ;
    rdfs:domain ind:DutyPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalDutyElapsedTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Total Duty Elapsed Time Minutes' ;
    rdfs:comment 'Total elapsed time in minutes from report time to release time. Used for FAR Part 117 and EASA FTL compliance calculations.' ;
    rdfs:domain ind:DutyPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:flightLegAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Flight Leg Assignment Id' ;
    rdfs:comment 'Unique identifier for the flight leg assignment record. Primary key for the operational assignment of a crew member to a specific flight leg.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FlightLegAssignment .

ind:swapRequestId rdf:type rdf:Property ;
    rdfs:label 'Swap Request Id' ;
    rdfs:comment 'Identifier of the crew swap request that resulted in this assignment, if applicable. Links to crew self-service swap transactions.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SwapRequest .

ind:actualCheckinTime rdf:type rdf:Property ;
    rdfs:label 'Actual Checkin Time' ;
    rdfs:comment 'The actual time the crew member checked in for duty, as recorded by crew tracking systems or airport operations.' ;
    rdfs:domain ind:FlightLegAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assignmentCancelledTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assignment Cancelled Timestamp' ;
    rdfs:comment 'Date and time when this assignment was cancelled, if applicable.' ;
    rdfs:domain ind:FlightLegAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assignmentCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assignment Created Timestamp' ;
    rdfs:comment 'Date and time when this assignment record was first created in the crew management system.' ;
    rdfs:domain ind:FlightLegAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assignmentModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assignment Modified Timestamp' ;
    rdfs:comment 'Date and time when this assignment record was last modified.' ;
    rdfs:domain ind:FlightLegAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assignmentType rdf:type rdf:Property ;
    rdfs:label 'Assignment Type' ;
    rdfs:comment 'Discriminator indicating whether this is an operating crew assignment (crew member performs duty) or deadhead positioning (crew member travels as passenger for repositioning).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crewAcknowledgementFlag rdf:type rdf:Property ;
    rdfs:label 'Crew Acknowledgement Flag' ;
    rdfs:comment 'Indicates whether the crew member has acknowledged receipt and acceptance of this assignment via crew portal or mobile app.' ;
    rdfs:domain ind:FlightLegAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crewAcknowledgementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Crew Acknowledgement Timestamp' ;
    rdfs:comment 'Date and time when the crew member acknowledged the assignment.' ;
    rdfs:domain ind:FlightLegAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deadheadBookingClass rdf:type rdf:Property ;
    rdfs:label 'Deadhead Booking Class' ;
    rdfs:comment 'The booking class (fare class) used for deadhead crew travel. Single uppercase letter (e.g., Y, J, F). Applicable only for deadhead assignments.' ;
    rdfs:domain ind:FlightLegAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deadheadReason rdf:type rdf:Property ;
    rdfs:label 'Deadhead Reason' ;
    rdfs:comment 'The business reason for deadhead positioning. Applicable only when assignment_type is deadhead. Pairing_start/end=crew repositioning for duty sequence, IROP_recovery=irregular operations recovery, Training=training event travel.' ;
    rdfs:domain ind:FlightLegAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deadheadSeatNumber rdf:type rdf:Property ;
    rdfs:label 'Deadhead Seat Number' ;
    rdfs:comment 'The assigned seat number for deadhead crew travel (e.g., 12A, 23F). Applicable only for deadhead assignments.' ;
    rdfs:domain ind:FlightLegAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interlineCarrierCode rdf:type rdf:Property ;
    rdfs:label 'Interline Carrier Code' ;
    rdfs:comment 'The IATA two-character airline code of the operating carrier when deadhead travel is on another airline. Null if own_metal_flag is true.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalityCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Legality Check Status' ;
    rdfs:comment 'Result of automated crew legality checks against flight time limitations, duty time limitations, and rest requirements per FAR Part 117 and EASA FTL regulations.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationSentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Timestamp' ;
    rdfs:comment 'Date and time when assignment notification was sent to the crew member.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:overrideApprovedBy rdf:type rdf:Property ;
    rdfs:label 'Override Approved By' ;
    rdfs:comment 'Name or identifier of the authorized person (e.g., crew scheduler, chief pilot, operations manager) who approved the override.' ;
    rdfs:domain ind:FlightLegAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideTimestamp rdf:type rdf:Property ;
    rdfs:label 'Override Timestamp' ;
    rdfs:comment 'Date and time when the override was approved.' ;
    rdfs:domain ind:FlightLegAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ownMetalFlag rdf:type rdf:Property ;
    rdfs:label 'Own Metal Flag' ;
    rdfs:comment 'Indicates whether the deadhead travel is on the airline\'s own aircraft (true) or on another carrier via interline agreement (false). Applicable for deadhead assignments.' ;
    rdfs:domain ind:FlightLegAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualificationCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Qualification Check Status' ;
    rdfs:comment 'Result of automated qualification and legality checks for this assignment. Indicates whether crew member meets all type ratings, recency, and regulatory requirements for the assigned position and aircraft.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reliefCrewFlag rdf:type rdf:Property ;
    rdfs:label 'Relief Crew Flag' ;
    rdfs:comment 'Indicates whether this crew member is assigned as relief crew for in-flight rest rotation on long-haul flights.' ;
    rdfs:domain ind:FlightLegAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reserveCalloutTime rdf:type rdf:Property ;
    rdfs:label 'Reserve Callout Time' ;
    rdfs:comment 'The time the reserve crew member was called out for this assignment. Applicable only when assignment_source is reserve.' ;
    rdfs:domain ind:FlightLegAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledCheckinTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Checkin Time' ;
    rdfs:comment 'The planned time the crew member is required to check in for duty prior to the flight leg, per crew scheduling rules and regulatory requirements.' ;
    rdfs:domain ind:FlightLegAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledReportLocation rdf:type rdf:Property ;
    rdfs:label 'Scheduled Report Location' ;
    rdfs:comment 'The designated location where the crew member is scheduled to report for duty (e.g., crew room, gate, operations center).' ;
    rdfs:domain ind:FlightLegAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ftlLegalityCheckId rdf:type rdf:Property ;
    rdfs:label 'Ftl Legality Check Id' ;
    rdfs:comment 'Unique identifier for the FTL legality check record. Primary key.' ;
    rdfs:domain ind:FtlLegalityCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvingAuthority rdf:type rdf:Property ;
    rdfs:label 'Approving Authority' ;
    rdfs:comment 'Name or identifier of the authority who approved the check result, waiver, or mitigation (e.g., Crew Control Manager, Chief Pilot, Duty Manager). Nullable for automated pass results.' ;
    rdfs:domain ind:FtlLegalityCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentMethod rdf:type rdf:Property ;
    rdfs:label 'Assessment Method' ;
    rdfs:comment 'Method used for the fitness assessment: regulatory_rule (FAR Part 117, EASA FTL rule-based check) or biomathematical_model (SAFE, FAID, FRMS model-based fatigue risk assessment).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkNotes rdf:type rdf:Property ;
    rdfs:label 'Check Notes' ;
    rdfs:comment 'Free-text notes or comments regarding the legality check, including rationale for waivers, mitigation details, or special circumstances. Nullable if no additional context required.' ;
    rdfs:domain ind:FtlLegalityCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkTimestamp rdf:type rdf:Property ;
    rdfs:label 'Check Timestamp' ;
    rdfs:comment 'Date and time when the FTL legality or fatigue risk check was executed.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:checkTrigger rdf:type rdf:Property ;
    rdfs:label 'Check Trigger' ;
    rdfs:comment 'Event or condition that triggered the legality check: pre-assignment (during rostering), pre-departure (gate check), post-duty (compliance audit), IROP extension (irregular operations duty extension request), manual audit, or scheduled review.' ;
    rdfs:domain ind:FtlLegalityCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fatigueRiskBand rdf:type rdf:Property ;
    rdfs:label 'Fatigue Risk Band' ;
    rdfs:comment 'Categorical fatigue risk band derived from the fatigue score: low, moderate, elevated, high, or critical. Nullable for regulatory rule-based checks.' ;
    rdfs:domain ind:FtlLegalityCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fatigueScore rdf:type rdf:Property ;
    rdfs:label 'Fatigue Score' ;
    rdfs:comment 'Numeric fatigue risk score generated by the biomathematical model (e.g., SAFE effectiveness score, FAID fatigue index). Nullable for regulatory rule-based checks.' ;
    rdfs:domain ind:FtlLegalityCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fdpActualHours rdf:type rdf:Property ;
    rdfs:label 'Fdp Actual Hours' ;
    rdfs:comment 'Actual or projected FDP duration in hours for the duty period being evaluated.' ;
    rdfs:domain ind:FtlLegalityCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fdpLimitHours rdf:type rdf:Property ;
    rdfs:label 'Fdp Limit Hours' ;
    rdfs:comment 'Maximum allowable FDP duration in hours per the applicable regulation, adjusted for number of sectors, time of day, and crew augmentation.' ;
    rdfs:domain ind:FtlLegalityCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fitnessResult rdf:type rdf:Property ;
    rdfs:label 'Fitness Result' ;
    rdfs:comment 'Overall fitness-to-operate result: legal (crew is legal and fit), illegal (crew exceeds FTL limits), waiver_granted (regulatory waiver issued for non-compliance), or elevated_risk_accepted (biomathematical model shows elevated risk but accepted with mitigation).' ;
    rdfs:domain ind:FtlLegalityCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flightTime28Day rdf:type rdf:Property ;
    rdfs:label 'Flight Time 28 Day' ;
    rdfs:comment 'Cumulative flight time in hours for the crew member over the preceding 28-day rolling window at the time of check.' ;
    rdfs:domain ind:FtlLegalityCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:flightTime365Day rdf:type rdf:Property ;
    rdfs:label 'Flight Time 365 Day' ;
    rdfs:comment 'Cumulative flight time in hours for the crew member over the preceding 365-day rolling window at the time of check.' ;
    rdfs:domain ind:FtlLegalityCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mitigationApplied rdf:type rdf:Property ;
    rdfs:label 'Mitigation Applied' ;
    rdfs:comment 'Description of any mitigation measures applied to address elevated fatigue risk or legality concerns (e.g., crew augmentation, duty period reduction, additional rest, flight reassignment). Nullable if no mitigation required.' ;
    rdfs:domain ind:FtlLegalityCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Rest Compliance Status' ;
    rdfs:comment 'Status of rest period compliance: compliant (meets minimum), non_compliant (below minimum), reduced_rest_approved (approved reduced rest per regulation), or waiver_granted (regulatory waiver issued).' ;
    rdfs:domain ind:FtlLegalityCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restPeriodActualHours rdf:type rdf:Property ;
    rdfs:label 'Rest Period Actual Hours' ;
    rdfs:comment 'Actual rest period in hours provided or projected before the next duty period.' ;
    rdfs:domain ind:FtlLegalityCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:restPeriodRequiredHours rdf:type rdf:Property ;
    rdfs:label 'Rest Period Required Hours' ;
    rdfs:comment 'Minimum rest period required in hours before the next duty period per applicable regulation.' ;
    rdfs:domain ind:FtlLegalityCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:systemSource rdf:type rdf:Property ;
    rdfs:label 'System Source' ;
    rdfs:comment 'Source system or module that generated the legality check record (e.g., AIMS Crew Management System, SAFE Model Engine, FAID Quantum, Manual Entry).' ;
    rdfs:domain ind:FtlLegalityCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenceId rdf:type rdf:Property ;
    rdfs:label 'Licence Id' ;
    rdfs:comment 'Unique identifier for the crew aviation licence record. Primary key.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Licence .

ind:issuingRegulatoryAuthorityId rdf:type rdf:Property ;
    rdfs:label 'Issuing Regulatory Authority Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_authority. Business justification: Licenses issued by specific aviation regulatory authorities. Critical for license validation, determining applicable regulations, reciprocity agreements, and regulatory reporting. Replaces denormalize' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryAuthority .

ind:documentUrl rdf:type rdf:Property ;
    rdfs:label 'Document Url' ;
    rdfs:comment 'URL or file path to the scanned or electronic copy of the licence document stored in the document management system.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageProficiencyExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Language Proficiency Expiry Date' ;
    rdfs:comment 'The date on which the language proficiency endorsement expires and must be re-assessed. Null if no expiry (level 6 Expert has no expiry).' ;
    rdfs:domain ind:Licence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:languageProficiencyLevel rdf:type rdf:Property ;
    rdfs:label 'Language Proficiency Level' ;
    rdfs:comment 'ICAO language proficiency rating for aviation English (or other endorsed language). Scale 1-6, where 4 (Operational) is the minimum for international operations, 6 is Expert. Per ICAO Annex 1.' ;
    rdfs:domain ind:Licence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:licenceNumber rdf:type rdf:Property ;
    rdfs:label 'Licence Number' ;
    rdfs:comment 'The unique licence number issued by the regulatory authority. This is the official identifier on the physical or electronic licence document.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenceStatus rdf:type rdf:Property ;
    rdfs:label 'Licence Status' ;
    rdfs:comment 'Current lifecycle status of the licence: valid (active and in good standing), expired (past expiry date), suspended (temporarily invalid), revoked (permanently cancelled), pending_renewal (renewal in process), surrendered (voluntarily returned).' ;
    rdfs:domain ind:Licence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenceType rdf:type rdf:Property ;
    rdfs:label 'Licence Type' ;
    rdfs:comment 'The category of aviation licence. ATPL (Airline Transport Pilot Licence), CPL (Commercial Pilot Licence), MPL (Multi-crew Pilot Licence), cabin crew attestation, flight engineer, or flight navigator.' ;
    rdfs:domain ind:Licence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalClass rdf:type rdf:Property ;
    rdfs:label 'Medical Class' ;
    rdfs:comment 'The class of medical certificate associated with this licence. Class 1 for ATPL/CPL, Class 2 for private pilots, Class 3 for air traffic controllers, cabin crew medical for cabin crew attestation.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Medical Expiry Date' ;
    rdfs:comment 'The date on which the associated medical certificate expires. Crew cannot exercise licence privileges without a valid medical.' ;
    rdfs:domain ind:Licence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ratingsHeld rdf:type rdf:Property ;
    rdfs:label 'Ratings Held' ;
    rdfs:comment 'Comma-separated list of ratings and endorsements held on this licence (e.g., instrument rating, multi-engine, type ratings). This is a summary field; detailed type ratings are tracked in the qualification product.' ;
    rdfs:domain ind:Licence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Date' ;
    rdfs:comment 'The date on which the licence was last renewed. Null if the licence has never been renewed since original issue.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:restrictions rdf:type rdf:Property ;
    rdfs:label 'Restrictions' ;
    rdfs:comment 'Free-text description of any restrictions or limitations placed on the licence by the issuing authority (e.g., \'Valid only with corrective lenses\', \'VFR only\', \'Co-pilot only\').' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revocationDate rdf:type rdf:Property ;
    rdfs:label 'Revocation Date' ;
    rdfs:comment 'The date on which the licence was permanently revoked by the issuing authority. Null if the licence has never been revoked.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:suspensionEndDate rdf:type rdf:Property ;
    rdfs:label 'Suspension End Date' ;
    rdfs:comment 'The date on which a suspension of the licence is scheduled to end or was lifted. Null if currently suspended with no defined end date.' ;
    rdfs:domain ind:Licence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:suspensionStartDate rdf:type rdf:Property ;
    rdfs:label 'Suspension Start Date' ;
    rdfs:comment 'The date on which a suspension of the licence became effective. Null if the licence has never been suspended.' ;
    rdfs:domain ind:Licence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalFlightHoursAtIssue rdf:type rdf:Property ;
    rdfs:label 'Total Flight Hours At Issue' ;
    rdfs:comment 'The total flight hours logged by the crew member at the time the licence was issued. Captured for historical record and regulatory audit.' ;
    rdfs:domain ind:Licence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certificateClass rdf:type rdf:Property ;
    rdfs:label 'Certificate Class' ;
    rdfs:comment 'ICAO medical certificate class. Class 1 for airline transport pilots and commercial pilots, Class 2 for private pilots and cabin crew, Class 3 for air traffic controllers.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:examinationDate rdf:type rdf:Property ;
    rdfs:label 'Examination Date' ;
    rdfs:comment 'Date the crew member underwent the medical examination that resulted in this certificate issuance. May differ from issue date if additional review or approval was required.' ;
    rdfs:domain ind:MedicalCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:hearingAidRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Hearing Aid Required Flag' ;
    rdfs:comment 'Indicates whether the crew member requires a hearing aid to meet hearing standards. True if hearing aid is required, False otherwise.' ;
    rdfs:domain ind:MedicalCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuingAuthorityLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority License Number' ;
    rdfs:comment 'License or designation number of the Aviation Medical Examiner (AME) or Designated Aviation Medical Examiner (DAME) who issued the certificate. Used for regulatory verification.' ;
    rdfs:domain ind:MedicalCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority Name' ;
    rdfs:comment 'Name of the Aviation Medical Examiner (AME) or Designated Aviation Medical Examiner (DAME) who issued the certificate.' ;
    rdfs:domain ind:MedicalCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Issuing Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the country where the medical certificate was issued. Determines applicable regulatory authority (FAA, EASA, etc.).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limitations rdf:type rdf:Property ;
    rdfs:label 'Limitations' ;
    rdfs:comment 'Any operational limitations or restrictions imposed on the crew member as a condition of the medical certificate. Examples include corrective lenses required, valid only with co-pilot, daytime operations only, or specific medical monitoring requirements.' ;
    rdfs:domain ind:MedicalCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextExaminationDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Examination Due Date' ;
    rdfs:comment 'Date by which the crew member must undergo the next medical examination to maintain continuous medical certification. Used for proactive crew scheduling and compliance planning.' ;
    rdfs:domain ind:MedicalCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:specialIssuanceFlag rdf:type rdf:Property ;
    rdfs:label 'Special Issuance Flag' ;
    rdfs:comment 'Indicates whether this certificate was issued under special issuance provisions due to a medical condition that does not meet standard requirements but has been granted a waiver or authorization. True if special issuance, False for standard issuance.' ;
    rdfs:domain ind:MedicalCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:validityStatus rdf:type rdf:Property ;
    rdfs:label 'Validity Status' ;
    rdfs:comment 'Current validity status of the medical certificate. Valid indicates the certificate is active and within its validity period. Expired indicates the certificate has passed its expiry date. Suspended or Revoked indicates regulatory action. Pending indicates awaiting final approval or special issuance decision.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visionCorrectedFlag rdf:type rdf:Property ;
    rdfs:label 'Vision Corrected Flag' ;
    rdfs:comment 'Indicates whether the crew member requires corrective lenses (glasses or contact lenses) to meet vision standards. True if corrective lenses are required, False otherwise.' ;
    rdfs:domain ind:MedicalCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waivers rdf:type rdf:Property ;
    rdfs:label 'Waivers' ;
    rdfs:comment 'Any medical waivers or special issuance conditions granted by the regulatory authority. Indicates exceptions to standard medical requirements with documented justification.' ;
    rdfs:domain ind:MedicalCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cost rdf:type rdf:Property ;
    rdfs:label 'Cost' ;
    rdfs:comment 'Estimated total cost of operating this pairing, including crew pay, per diem, hotel, transportation, and deadhead costs. Used by the pairing optimizer for cost minimization.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deadheadSegments rdf:type rdf:Property ;
    rdfs:label 'Deadhead Segments' ;
    rdfs:comment 'Count of deadhead (non-revenue positioning) segments in this pairing where crew travel as passengers to reposition for operational duty.' ;
    rdfs:domain ind:Pairing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:endDatetime rdf:type rdf:Property ;
    rdfs:label 'End Datetime' ;
    rdfs:comment 'The scheduled date and time when the pairing ends (crew release time at base). Represents the end of the last duty period.' ;
    rdfs:domain ind:Pairing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:hotelCost rdf:type rdf:Property ;
    rdfs:label 'Hotel Cost' ;
    rdfs:comment 'Estimated total hotel accommodation cost for all layovers in this pairing. Used for pairing cost calculation.' ;
    rdfs:domain ind:Pairing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:internationalFlag rdf:type rdf:Property ;
    rdfs:label 'International Flag' ;
    rdfs:comment 'Indicates whether this pairing includes any international (cross-border) flight legs. True if any leg crosses international boundaries, false if all legs are domestic.' ;
    rdfs:domain ind:Pairing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxDutyPeriodHours rdf:type rdf:Property ;
    rdfs:label 'Max Duty Period Hours' ;
    rdfs:comment 'The longest single duty period (in hours) within this pairing. Used to verify compliance with FAR Part 117 and EASA FTL maximum duty limits.' ;
    rdfs:domain ind:Pairing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minRestPeriodHours rdf:type rdf:Property ;
    rdfs:label 'Min Rest Period Hours' ;
    rdfs:comment 'The shortest rest period (in hours) within this pairing. Must meet or exceed minimum rest requirements per FAR Part 117 and EASA FTL.' ;
    rdfs:domain ind:Pairing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:numberOfDutyPeriods rdf:type rdf:Property ;
    rdfs:label 'Number Of Duty Periods' ;
    rdfs:comment 'Total count of duty periods in this pairing. A duty period is a continuous block of work time from crew report to crew release, separated by rest periods.' ;
    rdfs:domain ind:Pairing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numberOfLayovers rdf:type rdf:Property ;
    rdfs:label 'Number Of Layovers' ;
    rdfs:comment 'Total count of overnight layovers (rest periods away from base) in this pairing. Each layover occurs at an overnight station.' ;
    rdfs:domain ind:Pairing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numberOfLegs rdf:type rdf:Property ;
    rdfs:label 'Number Of Legs' ;
    rdfs:comment 'Total count of flight legs (segments) included in this pairing. Each leg is a single takeoff-to-landing flight.' ;
    rdfs:domain ind:Pairing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:optimizationRunCode rdf:type rdf:Property ;
    rdfs:label 'Optimization Run Code' ;
    rdfs:comment 'Identifier of the specific optimization run that produced this pairing. Links pairing to the batch optimization process.' ;
    rdfs:domain ind:Pairing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optimizerVersion rdf:type rdf:Property ;
    rdfs:label 'Optimizer Version' ;
    rdfs:comment 'Version identifier of the crew pairing optimizer software that generated this pairing. Used for audit and reproducibility.' ;
    rdfs:domain ind:Pairing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overnightStations rdf:type rdf:Property ;
    rdfs:label 'Overnight Stations' ;
    rdfs:comment 'Comma-separated list of IATA airport codes where crew have overnight layovers during this pairing (e.g., \'JFK,LAX,ORD\'). Sequence reflects pairing order.' ;
    rdfs:domain ind:Pairing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pairingCode rdf:type rdf:Property ;
    rdfs:label 'Pairing Code' ;
    rdfs:comment 'Business identifier for the pairing, externally known code used in crew scheduling and operations. Typically alphanumeric format assigned by the pairing optimizer.' ;
    rdfs:domain ind:Pairing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pairingStatus rdf:type rdf:Property ;
    rdfs:label 'Pairing Status' ;
    rdfs:comment 'Current lifecycle status of the pairing: draft (under construction), published (available for assignment), assigned (crew assigned), in_progress (currently being flown), completed (finished), cancelled (no longer valid).' ;
    rdfs:domain ind:Pairing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pairingType rdf:type rdf:Property ;
    rdfs:label 'Pairing Type' ;
    rdfs:comment 'Classification of the pairing based on route characteristics: domestic (all legs within one country), international (crosses borders), mixed (combination), reserve (standby duty), training (instructional flights), or positioning (deadhead crew movement).' ;
    rdfs:domain ind:Pairing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:perDiemAmount rdf:type rdf:Property ;
    rdfs:label 'Per Diem Amount' ;
    rdfs:comment 'Total per diem allowance payable to crew for this pairing, covering meals and incidental expenses during layovers. Calculated per CBA rules.' ;
    rdfs:domain ind:Pairing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:premiumPayFlag rdf:type rdf:Property ;
    rdfs:label 'Premium Pay Flag' ;
    rdfs:comment 'Indicates whether this pairing qualifies for premium pay under CBA rules (e.g., due to red-eye flights, long duty periods, or undesirable layovers). True if premium pay applies.' ;
    rdfs:domain ind:Pairing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:redEyeFlag rdf:type rdf:Property ;
    rdfs:label 'Red Eye Flag' ;
    rdfs:comment 'Indicates whether this pairing includes any red-eye (overnight) flights that operate during typical sleep hours (typically 10 PM to 6 AM). True if any leg is a red-eye flight.' ;
    rdfs:domain ind:Pairing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:startDatetime rdf:type rdf:Property ;
    rdfs:label 'Start Datetime' ;
    rdfs:comment 'The scheduled date and time when the pairing begins (crew report time at base). Represents the start of the first duty period.' ;
    rdfs:domain ind:Pairing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:timeAwayFromBaseHours rdf:type rdf:Property ;
    rdfs:label 'Time Away From Base Hours' ;
    rdfs:comment 'Total elapsed time from pairing start to pairing end, representing how long crew are away from their base. Includes duty time, rest time, and layover time. Key quality-of-life metric.' ;
    rdfs:domain ind:Pairing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalBlockHours rdf:type rdf:Property ;
    rdfs:label 'Total Block Hours' ;
    rdfs:comment 'Total flight time (block hours) accumulated across all legs in this pairing, measured from gate departure (off-blocks) to gate arrival (on-blocks). Used for crew pay and legality checks.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCreditHours rdf:type rdf:Property ;
    rdfs:label 'Total Credit Hours' ;
    rdfs:comment 'Total pay credit hours for this pairing, calculated per collective bargaining agreement rules. May differ from block hours due to minimum guarantees, premiums, and duty rigs.' ;
    rdfs:domain ind:Pairing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDutyHours rdf:type rdf:Property ;
    rdfs:label 'Total Duty Hours' ;
    rdfs:comment 'Total duty time across all duty periods in this pairing, from crew report to crew release. Includes flight time, ground time, and pre/post-flight duties. Subject to FAR Part 117 and EASA FTL limits.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalRestHours rdf:type rdf:Property ;
    rdfs:label 'Total Rest Hours' ;
    rdfs:comment 'Total rest time provided across all rest periods in this pairing. Must meet minimum rest requirements per FAR Part 117 and EASA FTL.' ;
    rdfs:domain ind:Pairing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualificationId rdf:type rdf:Property ;
    rdfs:label 'Qualification Id' ;
    rdfs:comment 'Unique identifier for the crew qualification record. Primary key.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:governingRegulatoryAuthorityId rdf:type rdf:Property ;
    rdfs:label 'Governing Regulatory Authority Id' ;
    rdfs:comment 'Foreign key linking to compliance.regulatory_authority. Business justification: Each qualification (type rating, endorsement) is governed by specific regulatory authority standards. Critical for determining qualification validity periods, recency requirements, and checking compli' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryAuthority .

ind:typeRatingId rdf:type rdf:Property ;
    rdfs:label 'Type Rating Id' ;
    rdfs:comment 'Foreign key linking to workforce.type_rating. Business justification: Crew scheduling eligibility verification requires linking operational qualification records (crew domain) to HR compliance records of type ratings (workforce domain). When qualification_category indic' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TypeRating .

ind:checkType rdf:type rdf:Property ;
    rdfs:label 'Check Type' ;
    rdfs:comment 'Type of check or evaluation that resulted in this qualification: initial (first-time qualification), recurrent (periodic revalidation), upgrade (promotion to higher position), requalification (after lapse), line_check (operational line check). Null if not check-based.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endorsementCodes rdf:type rdf:Property ;
    rdfs:label 'Endorsement Codes' ;
    rdfs:comment 'Comma-separated list of additional endorsements or restrictions on this qualification (e.g., ETOPS, CAT III, RNP AR, VFR only). Aligns with ICAO and FAA endorsement standards.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flightHours rdf:type rdf:Property ;
    rdfs:label 'Flight Hours' ;
    rdfs:comment 'Total flight hours logged under this qualification. Used for tracking experience and recency requirements.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isPicQualified rdf:type rdf:Property ;
    rdfs:label 'Is Pic Qualified' ;
    rdfs:comment 'Indicates whether this qualification authorizes the crew member to act as Pilot in Command (PIC). True if PIC-qualified, False otherwise.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSicQualified rdf:type rdf:Property ;
    rdfs:label 'Is Sic Qualified' ;
    rdfs:comment 'Indicates whether this qualification authorizes the crew member to act as Second in Command (SIC). True if SIC-qualified, False otherwise.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:landingsCount rdf:type rdf:Property ;
    rdfs:label 'Landings Count' ;
    rdfs:comment 'Total number of landings performed under this qualification. Critical for recency requirements (e.g., 3 takeoffs and landings in 90 days).' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastCheckDate rdf:type rdf:Property ;
    rdfs:label 'Last Check Date' ;
    rdfs:comment 'Date of the most recent proficiency check, simulator check, or line check for this qualification. Used to track recency and currency.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastFlightDate rdf:type rdf:Property ;
    rdfs:label 'Last Flight Date' ;
    rdfs:comment 'Date of the most recent flight operated under this qualification. Used to determine recency and currency status.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextCheckDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Check Due Date' ;
    rdfs:comment 'Date by which the next proficiency check or recurrent training must be completed to maintain qualification currency.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:positionCode rdf:type rdf:Property ;
    rdfs:label 'Position Code' ;
    rdfs:comment 'Crew position this qualification authorizes: CA (Captain), FO (First Officer), SO (Second Officer), CP (Co-Pilot), FA (Flight Attendant), PS (Purser), LS (Lead Steward). Null for non-position qualifications.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationCategory rdf:type rdf:Property ;
    rdfs:label 'Qualification Category' ;
    rdfs:comment 'High-level category of the qualification: type_rating (aircraft type), position_authorization (Captain, FO, Purser), endorsement (ICAO/FAA licence endorsement), recurrent_training (annual recurrency), special_qualification (ETOPS, CAT III), medical_certificate (Class 1/2 medical).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationCode rdf:type rdf:Property ;
    rdfs:label 'Qualification Code' ;
    rdfs:comment 'Standardized code representing the qualification type (e.g., B737, A320, B777, PURSER, FA). Aligns with ICAO and FAA type rating nomenclature.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationName rdf:type rdf:Property ;
    rdfs:label 'Qualification Name' ;
    rdfs:comment 'Full descriptive name of the qualification (e.g., Boeing 737-800 Type Rating, Airbus A320 Family Type Rating, Purser Qualification).' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationStatus rdf:type rdf:Property ;
    rdfs:label 'Qualification Status' ;
    rdfs:comment 'Current lifecycle status of the qualification: current (valid and active), expired (past expiry date), suspended (temporarily invalid), revoked (permanently invalid), pending (awaiting approval), in_training (training in progress).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recencyStatus rdf:type rdf:Property ;
    rdfs:label 'Recency Status' ;
    rdfs:comment 'Indicates whether the crew member meets recency requirements for this qualification: current (meets all recency rules), expiring_soon (within alert window), expired (recency lapsed), not_applicable (no recency requirement).' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:simulatorHours rdf:type rdf:Property ;
    rdfs:label 'Simulator Hours' ;
    rdfs:comment 'Total simulator training hours logged for this qualification. Used for tracking training investment and proficiency.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingOrganization rdf:type rdf:Property ;
    rdfs:label 'Training Organization' ;
    rdfs:comment 'Name of the training organization or flight school that provided the initial qualification training (e.g., CAE, FlightSafety International, internal airline training center).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recencyRecordId rdf:type rdf:Property ;
    rdfs:label 'Recency Record Id' ;
    rdfs:comment 'Unique identifier for the crew recency record. Primary key.' ;
    rdfs:domain ind:RecencyRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:currencyStatus rdf:type rdf:Property ;
    rdfs:label 'Currency Status' ;
    rdfs:comment 'The current currency status of the crew member for this recency type and aircraft type. Current=within recency period, Expired=beyond recency period, Expiring Soon=within warning threshold, Not Applicable=recency not required for this position/type combination.' ;
    rdfs:domain ind:RecencyRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gracePeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Grace Period End Date' ;
    rdfs:comment 'The end date of any regulatory or company grace period during which the crew member may still operate under supervision or restricted conditions after recency expiry.' ;
    rdfs:domain ind:RecencyRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:instrumentConditionsFlag rdf:type rdf:Property ;
    rdfs:label 'Instrument Conditions Flag' ;
    rdfs:comment 'Indicates whether this recency requirement applies to operations under Instrument Flight Rules (IFR) or in instrument meteorological conditions (IMC).' ;
    rdfs:domain ind:RecencyRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastQualifyingEventDate rdf:type rdf:Property ;
    rdfs:label 'Last Qualifying Event Date' ;
    rdfs:comment 'The date of the last qualifying event that satisfied this recency requirement (e.g., last takeoff, last landing, last line check, last emergency drill).' ;
    rdfs:domain ind:RecencyRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastQualifyingEventFlightNumber rdf:type rdf:Property ;
    rdfs:label 'Last Qualifying Event Flight Number' ;
    rdfs:comment 'The flight number or training session identifier associated with the last qualifying event.' ;
    rdfs:domain ind:RecencyRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastVerificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Verification Timestamp' ;
    rdfs:comment 'The timestamp when this recency record was last verified or updated by crew scheduling or training records systems.' ;
    rdfs:domain ind:RecencyRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lineCheckRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Line Check Required Flag' ;
    rdfs:comment 'Indicates whether a line check (supervised flight with a check airman) is required to restore currency after expiry of this recency requirement.' ;
    rdfs:domain ind:RecencyRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nightOperationsFlag rdf:type rdf:Property ;
    rdfs:label 'Night Operations Flag' ;
    rdfs:comment 'Indicates whether this recency requirement specifically applies to night operations (one hour after sunset to one hour before sunrise).' ;
    rdfs:domain ind:RecencyRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:passengerCarryingFlag rdf:type rdf:Property ;
    rdfs:label 'Passenger Carrying Flag' ;
    rdfs:comment 'Indicates whether this recency requirement applies specifically to passenger-carrying operations (as opposed to cargo-only or ferry flights).' ;
    rdfs:domain ind:RecencyRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualifyingEventCount rdf:type rdf:Property ;
    rdfs:label 'Qualifying Event Count' ;
    rdfs:comment 'The number of qualifying events completed within the recency period (e.g., three takeoffs and landings in the preceding 90 days).' ;
    rdfs:domain ind:RecencyRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recencyExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Recency Expiry Date' ;
    rdfs:comment 'The date on which this recency requirement expires if no further qualifying events occur. Calculated as last_qualifying_event_date plus recency_period_days.' ;
    rdfs:domain ind:RecencyRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recencyPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Recency Period Days' ;
    rdfs:comment 'The regulatory or company-defined period (in days) within which qualifying events must occur to maintain currency (e.g., 90 days for takeoff/landing recency).' ;
    rdfs:domain ind:RecencyRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recencyRequirementReference rdf:type rdf:Property ;
    rdfs:label 'Recency Requirement Reference' ;
    rdfs:comment 'The specific regulatory or company policy reference that defines this recency requirement (e.g., FAR 61.57(a), EASA FTL.3.225, Company Operations Manual Section 8.4.2).' ;
    rdfs:domain ind:RecencyRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recencyType rdf:type rdf:Property ;
    rdfs:label 'Recency Type' ;
    rdfs:comment 'The type of recency requirement being tracked. Includes takeoff, landing, instrument approach, ETOPS (Extended-range Twin-engine Operational Performance Standards), low-visibility operations, and emergency procedures drill.' ;
    rdfs:domain ind:RecencyRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:simulatorQualifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Simulator Qualified Flag' ;
    rdfs:comment 'Indicates whether this recency requirement can be satisfied using a qualified flight simulator or flight training device instead of actual aircraft operations.' ;
    rdfs:domain ind:RecencyRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:warningThresholdDays rdf:type rdf:Property ;
    rdfs:label 'Warning Threshold Days' ;
    rdfs:comment 'The number of days before recency expiry when the system should issue a warning to crew scheduling and the crew member (e.g., 14 days before expiry).' ;
    rdfs:domain ind:RecencyRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rosterId rdf:type rdf:Property ;
    rdfs:label 'Roster Id' ;
    rdfs:comment 'Unique identifier for the crew roster record. Primary key.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Roster .

ind:bidPeriodMonth rdf:type rdf:Property ;
    rdfs:label 'Bid Period Month' ;
    rdfs:comment 'The month component of the bid period for which this roster is published (1-12).' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bidPeriodYear rdf:type rdf:Property ;
    rdfs:label 'Bid Period Year' ;
    rdfs:comment 'The year component of the bid period for which this roster is published (e.g., 2024).' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:daysOffCount rdf:type rdf:Property ;
    rdfs:label 'Days Off Count' ;
    rdfs:comment 'Total number of days off (rest days, leave days) scheduled in this roster period. Used for union compliance and crew rest verification.' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deadheadSegmentsCount rdf:type rdf:Property ;
    rdfs:label 'Deadhead Segments Count' ;
    rdfs:comment 'Number of deadhead positioning segments (crew repositioning flights without duty) included in this roster.' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:leaveDaysCount rdf:type rdf:Property ;
    rdfs:label 'Leave Days Count' ;
    rdfs:comment 'Number of approved leave days (vacation, sick leave, personal leave) included in this roster period.' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:legalityCheckTimestamp rdf:type rdf:Property ;
    rdfs:label 'Legality Check Timestamp' ;
    rdfs:comment 'Timestamp when the most recent legality check was performed on this roster.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pbsAwardReference rdf:type rdf:Property ;
    rdfs:label 'Pbs Award Reference' ;
    rdfs:comment 'Reference identifier to the PBS award or bid result that generated this roster, if applicable. Empty if roster was manually constructed or assigned outside PBS.' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reserveDaysCount rdf:type rdf:Property ;
    rdfs:label 'Reserve Days Count' ;
    rdfs:comment 'Total number of days the crew member is assigned to reserve or standby duty in this roster period.' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rosterSource rdf:type rdf:Property ;
    rdfs:label 'Roster Source' ;
    rdfs:comment 'The method or system by which this roster was generated. PBS indicates Preferential Bidding System; manual indicates crew scheduler assignment; optimization indicates automated optimizer; crew_request indicates crew-initiated swap or change.' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rosterStatus rdf:type rdf:Property ;
    rdfs:label 'Roster Status' ;
    rdfs:comment 'Current lifecycle status of the roster. Draft indicates preliminary assignment; published indicates official release; revised indicates changes after publication; frozen indicates locked for payroll; cancelled indicates roster voided.' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCreditedBlockHours rdf:type rdf:Property ;
    rdfs:label 'Total Credited Block Hours' ;
    rdfs:comment 'Total block hours (gate-to-gate flight time) credited to the crew member for this roster period. Used for pay calculation and regulatory compliance.' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDutyDays rdf:type rdf:Property ;
    rdfs:label 'Total Duty Days' ;
    rdfs:comment 'Total number of days in the roster period on which the crew member has assigned duty (flight, training, standby, or other duty).' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalFlightDutyPeriods rdf:type rdf:Property ;
    rdfs:label 'Total Flight Duty Periods' ;
    rdfs:comment 'Total number of flight duty periods (FDPs) assigned in this roster. An FDP is a continuous duty period that includes one or more flight segments.' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trainingEventsCount rdf:type rdf:Property ;
    rdfs:label 'Training Events Count' ;
    rdfs:comment 'Number of training events (simulator sessions, recurrent training, line checks) scheduled in this roster period.' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unionComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Union Compliance Flag' ;
    rdfs:comment 'Boolean flag indicating whether this roster complies with all applicable Collective Bargaining Agreement (CBA) rules. True indicates compliance; false indicates violations.' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:version rdf:type rdf:Property ;
    rdfs:label 'Version' ;
    rdfs:comment 'Version number of the roster for the given bid period. Increments with each revision or republication.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rosterActivityId rdf:type rdf:Property ;
    rdfs:label 'Roster Activity Id' ;
    rdfs:comment 'Unique identifier for the roster activity line item. Primary key.' ;
    rdfs:domain ind:RosterActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryRosterMemberId rdf:type rdf:Property ;
    rdfs:label 'Primary Roster Member Id' ;
    rdfs:comment 'Reference to the crew member assigned to this roster activity.' ;
    rdfs:domain ind:RosterActivity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Member .

ind:tertiaryRosterSwapReceivingCrewMemberId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Roster Swap Receiving Crew Member Id' ;
    rdfs:comment 'Reference to the crew member who accepted or was assigned to take over this activity in a swap. Null if no swap occurred.' ;
    rdfs:domain ind:RosterActivity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Member .

ind:triggeredFlightLegId rdf:type rdf:Property ;
    rdfs:label 'Triggered Flight Leg Id' ;
    rdfs:comment 'Reference to the flight leg that the standby crew member was assigned to upon activation. Null if not activated or for non-standby activities.' ;
    rdfs:domain ind:RosterActivity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FlightLeg .

ind:activityStatus rdf:type rdf:Property ;
    rdfs:label 'Activity Status' ;
    rdfs:comment 'Current lifecycle status of the roster activity.' ;
    rdfs:domain ind:RosterActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activityType rdf:type rdf:Property ;
    rdfs:label 'Activity Type' ;
    rdfs:comment 'Type of roster activity assigned to the crew member. [ENUM-REF-CANDIDATE: pairing|training|standby|day_off|deadhead|leave|ground_duty|medical|administrative|union|vacation|sick_leave|personal_leave|jury_duty|bereavement|simulator|classroom|line_check|proficiency_check|recurrent_training|initial_training|transition_training|upgrade_training|airport_standby|home_standby|hot_standby|cold_standby|office_duty|meeting|project_work — promote to reference product]' ;
    rdfs:domain ind:RosterActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualEndDatetime rdf:type rdf:Property ;
    rdfs:label 'Actual End Datetime' ;
    rdfs:comment 'Actual end date and time when the crew member completed the activity in UTC. Null if activity has not completed or was cancelled.' ;
    rdfs:domain ind:RosterActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualStartDatetime rdf:type rdf:Property ;
    rdfs:label 'Actual Start Datetime' ;
    rdfs:comment 'Actual start date and time when the crew member commenced the activity in UTC. Null if activity has not started or was cancelled.' ;
    rdfs:domain ind:RosterActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:blockHours rdf:type rdf:Property ;
    rdfs:label 'Block Hours' ;
    rdfs:comment 'Total block hours (gate departure to gate arrival time) for pairing activities. Null for non-flight activities.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:createdDatetime rdf:type rdf:Property ;
    rdfs:label 'Created Datetime' ;
    rdfs:comment 'Date and time when this roster activity record was first created in the system.' ;
    rdfs:domain ind:RosterActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:creditHours rdf:type rdf:Property ;
    rdfs:label 'Credit Hours' ;
    rdfs:comment 'Number of credit hours assigned to this activity for crew pay and scheduling purposes. Calculated based on block hours, duty hours, or contractual rules depending on activity type.' ;
    rdfs:domain ind:RosterActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deadheadFlag rdf:type rdf:Property ;
    rdfs:label 'Deadhead Flag' ;
    rdfs:comment 'Indicates whether this activity involves deadhead crew repositioning (crew traveling as passengers to position for a duty assignment). True for deadhead activities; false otherwise.' ;
    rdfs:domain ind:RosterActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dutyHours rdf:type rdf:Property ;
    rdfs:label 'Duty Hours' ;
    rdfs:comment 'Total duty hours for this activity, calculated from check-in to release time for pairings, or scheduled duration for other duty activities. Used for FAR Part 117 and EASA FTL compliance.' ;
    rdfs:domain ind:RosterActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:iropRelatedFlag rdf:type rdf:Property ;
    rdfs:label 'Irop Related Flag' ;
    rdfs:comment 'Indicates whether this roster activity was created or modified as a result of irregular operations (flight delays, cancellations, crew recovery). True if IROP-related; false for normal scheduled activities.' ;
    rdfs:domain ind:RosterActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastModifiedDatetime rdf:type rdf:Property ;
    rdfs:label 'Last Modified Datetime' ;
    rdfs:comment 'Date and time when this roster activity record was last modified. Used for audit trail and roster change tracking.' ;
    rdfs:domain ind:RosterActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:leaveType rdf:type rdf:Property ;
    rdfs:label 'Leave Type' ;
    rdfs:comment 'Type of leave if activity_type is leave. Vacation is planned time off; sick is illness-related absence; personal is discretionary leave; medical is extended medical leave; bereavement is compassionate leave; jury_duty is civic duty. Null for non-leave activities.' ;
    rdfs:domain ind:RosterActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalityViolationCode rdf:type rdf:Property ;
    rdfs:label 'Legality Violation Code' ;
    rdfs:comment 'Code identifying the specific regulation or rule violated if legality_check_status is illegal or warning. Examples: FDP_EXCEEDED (flight duty period limit), REST_INSUFFICIENT (minimum rest not met), RECENCY_EXPIRED (currency requirement lapsed). Null if legal or not checked.' ;
    rdfs:domain ind:RosterActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rosterPublishDatetime rdf:type rdf:Property ;
    rdfs:label 'Roster Publish Datetime' ;
    rdfs:comment 'Date and time when the roster containing this activity was published to the crew member. Used to track roster stability and last-minute changes.' ;
    rdfs:domain ind:RosterActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledEndDatetime rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Datetime' ;
    rdfs:comment 'Scheduled end date and time of the roster activity in UTC. Represents the conclusion of the duty period, training session, standby window, or leave period.' ;
    rdfs:domain ind:RosterActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledStartDatetime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Datetime' ;
    rdfs:comment 'Scheduled start date and time of the roster activity in UTC. Represents the beginning of the duty period, training session, standby window, or leave period.' ;
    rdfs:domain ind:RosterActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:standbyActivationDatetime rdf:type rdf:Property ;
    rdfs:label 'Standby Activation Datetime' ;
    rdfs:comment 'Date and time when the standby crew member was activated and assigned to a flight. Null if not activated or for non-standby activities.' ;
    rdfs:domain ind:RosterActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:standbyActivationStatus rdf:type rdf:Property ;
    rdfs:label 'Standby Activation Status' ;
    rdfs:comment 'Indicates whether the standby crew member was activated for a flight assignment. Not_activated means crew remained on standby; activated means crew was called out; released means standby period ended without activation. Null for non-standby activities.' ;
    rdfs:domain ind:RosterActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standbyContactEndTime rdf:type rdf:Property ;
    rdfs:label 'Standby Contact End Time' ;
    rdfs:comment 'End of the contact window during which crew on standby must be reachable. Null for non-standby activities.' ;
    rdfs:domain ind:RosterActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:standbyContactStartTime rdf:type rdf:Property ;
    rdfs:label 'Standby Contact Start Time' ;
    rdfs:comment 'Start of the contact window during which crew on standby must be reachable. Null for non-standby activities.' ;
    rdfs:domain ind:RosterActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:standbyType rdf:type rdf:Property ;
    rdfs:label 'Standby Type' ;
    rdfs:comment 'Type of standby duty if activity_type is standby. Airport standby requires crew to be at the airport; home standby allows crew to remain at home; hot standby requires immediate availability; cold standby allows longer call-out time. Null for non-standby activities.' ;
    rdfs:domain ind:RosterActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stationCode rdf:type rdf:Property ;
    rdfs:label 'Station Code' ;
    rdfs:comment 'Three-letter IATA airport code representing the station where the activity takes place or originates. For pairings, this is the check-in station. For standby, this is the standby location. For training, this is the training facility location.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:swapApprovalDatetime rdf:type rdf:Property ;
    rdfs:label 'Swap Approval Datetime' ;
    rdfs:comment 'Date and time when the swap was approved. Null if swap not approved or no swap occurred.' ;
    rdfs:domain ind:RosterActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:swapApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Swap Approval Status' ;
    rdfs:comment 'Approval status of the swap request. Pending indicates awaiting management approval; approved means swap is confirmed; rejected means swap was denied; cancelled means swap request was withdrawn. Null if no swap was requested.' ;
    rdfs:domain ind:RosterActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:swapRequestedFlag rdf:type rdf:Property ;
    rdfs:label 'Swap Requested Flag' ;
    rdfs:comment 'Indicates whether this activity has been requested for swap by the assigned crew member. True if swap request is pending or approved; false otherwise.' ;
    rdfs:domain ind:RosterActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trainingType rdf:type rdf:Property ;
    rdfs:label 'Training Type' ;
    rdfs:comment 'Type of training if activity_type is training. Simulator is flight simulator session; classroom is ground school; line_check is operational proficiency check; recurrent is periodic requalification; initial is new-hire or type-rating training. Null for non-training activities. [ENUM-REF-CANDIDATE: simulator|classroom|line_check|recurrent|initial|transition|upgrade|proficiency_check|emergency_procedures|differences_training|cbt|elearning — promote to reference product]' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expenseEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Expense Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: AP invoices for employee expenses (training, relocation, travel advances) require employee linkage for expense management, reimbursement tracking, and payroll integration. Role prefix distinguishes fr' ;
    rdfs:domain ind:AccountsPayable ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:goodsReceiptId rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Id' ;
    rdfs:comment 'Foreign key linking to procurement.goods_receipt. Business justification: Three-way match (PO-GR-Invoice) requires AP to reference specific goods receipt for invoice verification, payment release authorization, and procurement compliance. Mandatory for accounts payable proc' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GoodsReceipt .

ind:repairOrderId rdf:type rdf:Property ;
    rdfs:label 'Repair Order Id' ;
    rdfs:comment 'Foreign key linking to procurement.repair_order. Business justification: MRO repair invoices must reference the originating repair order for cost validation, warranty claim processing, maintenance cost tracking, and airworthiness compliance. Essential for MRO financial con' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RepairOrder .

ind:bspArcSettlementRef rdf:type rdf:Property ;
    rdfs:label 'Bsp Arc Settlement Ref' ;
    rdfs:comment 'The IATA Billing and Settlement Plan (BSP) or Airlines Reporting Corporation (ARC) settlement reference number for invoices settled through interline or agency billing cycles. Applicable for GDS provider fees, interline billing, and travel agency commission settlements.' ;
    rdfs:domain ind:AccountsPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Clearing Document Number' ;
    rdfs:comment 'The SAP accounting document number of the payment document that cleared (settled) this open invoice item. Populated upon successful payment execution. Corresponds to SAP field AUGBL (Clearing Document). Null for unpaid invoices.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountDueDate rdf:type rdf:Property ;
    rdfs:label 'Discount Due Date' ;
    rdfs:comment 'The deadline by which early payment must be made to qualify for the cash discount offered under the vendor\'s payment terms (e.g., 2/10 net 30). Supports cash flow optimization and working capital management.' ;
    rdfs:domain ind:AccountsPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fiscalPeriod rdf:type rdf:Property ;
    rdfs:label 'Fiscal Period' ;
    rdfs:comment 'The fiscal posting period (1–16, including special periods) within the fiscal year in which this invoice is recorded. Supports monthly accrual management and period-end close processes in SAP FI.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fiscalYear rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year' ;
    rdfs:comment 'The fiscal year in which this vendor invoice is posted in SAP FI. Used for period-end closing, financial reporting, and year-over-year cost analysis. Corresponds to SAP field GJAHR.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fuelUpliftVolumeLiters rdf:type rdf:Property ;
    rdfs:label 'Fuel Uplift Volume Liters' ;
    rdfs:comment 'For fuel vendor invoices, the volume of jet fuel (Jet-A or Jet-A1) uplifted in liters as recorded on the fuel receipt. Supports fuel cost per liter analysis, CASK fuel component reporting, and CORSIA carbon emissions accounting. Null for non-fuel invoices.' ;
    rdfs:domain ind:AccountsPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:goodsReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Date' ;
    rdfs:comment 'The date on which goods or services were confirmed as received, forming the third leg of the three-way match (PO → Goods Receipt → Invoice). Critical for MRO parts, fuel uplift, and catering deliveries. Corresponds to SAP MIGO goods receipt posting date.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:grossAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Amount' ;
    rdfs:comment 'The total gross amount of the vendor invoice before deduction of taxes, withholding tax, or discounts, expressed in the invoice currency. Represents the full obligation as stated on the vendor\'s invoice document.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ifrs16LeaseFlag rdf:type rdf:Property ;
    rdfs:label 'Ifrs16 Lease Flag' ;
    rdfs:comment 'Indicates whether this invoice relates to a lease obligation subject to IFRS 16 Leases accounting treatment (e.g., aircraft dry lease, wet lease, ACMI lease payments, airport gate lease). When true, the payment is classified as a lease liability repayment rather than an operating expense.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:invoiceCurrency rdf:type rdf:Property ;
    rdfs:label 'Invoice Currency' ;
    rdfs:comment 'The ISO 4217 three-letter currency code in which the vendor invoice is denominated (e.g., USD, EUR, GBP). May differ from the company code local currency, requiring foreign exchange translation for GL posting. Corresponds to SAP field WAERS.' ;
    rdfs:domain ind:AccountsPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Local Currency Amount' ;
    rdfs:comment 'The net payable amount translated into the company code\'s local (functional) currency using the exchange rate at posting date. Used for GL posting, financial reporting, and CASK calculation in the airline\'s reporting currency.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netAmount rdf:type rdf:Property ;
    rdfs:label 'Net Amount' ;
    rdfs:comment 'The net amount payable to the vendor after deducting withholding tax and any applicable cash discounts from the gross invoice amount. Represents the actual cash outflow obligation. Calculated as gross_amount minus withholding_tax_amount minus discount_amount.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentBlockReason rdf:type rdf:Property ;
    rdfs:label 'Payment Block Reason' ;
    rdfs:comment 'Reason code explaining why a payment block has been applied to this invoice, preventing it from being included in the next payment run. Corresponds to SAP field ZLSPR (Payment Block Key). Null when no block is active.' ;
    rdfs:domain ind:AccountsPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermsCode rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Code' ;
    rdfs:comment 'The SAP payment terms key (e.g., NT30, NT60, 2/10N30) defining the agreed payment schedule, discount percentages, and due date calculation rules for this vendor. Corresponds to SAP field ZTERM.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingDate rdf:type rdf:Property ;
    rdfs:label 'Posting Date' ;
    rdfs:comment 'The date on which the vendor invoice is posted to the SAP general ledger, determining the accounting period for recognition. May differ from invoice date due to processing delays. Corresponds to SAP field BUDAT.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sapDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Document Number' ;
    rdfs:comment 'The internal SAP FI accounting document number (BELNR) assigned upon posting of the vendor invoice in the general ledger. Uniquely identifies the FI document within a company code and fiscal year.' ;
    rdfs:domain ind:AccountsPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCode rdf:type rdf:Property ;
    rdfs:label 'Tax Code' ;
    rdfs:comment 'The SAP tax code identifying the applicable tax rate and tax type (input VAT, zero-rated, exempt) for this invoice line. Drives automated tax calculation and input tax recovery reporting. Corresponds to SAP field MWSKZ.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:threeWayMatchStatus rdf:type rdf:Property ;
    rdfs:label 'Three Way Match Status' ;
    rdfs:comment 'Result of the automated three-way match validation comparing the purchase order, goods receipt, and vendor invoice for quantity and price alignment. \'matched\' = all three documents agree; \'price_variance\' = invoice price differs from PO; \'quantity_variance\' = invoice quantity differs from GR; \'pending_gr\' = goods receipt not yet confirmed; \'failed\' = match failed requiring manual review.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorCategory rdf:type rdf:Property ;
    rdfs:label 'Vendor Category' ;
    rdfs:comment 'Classification of the vendor type supplying goods or services to the airline. Drives cost allocation to CASK components and supports spend analytics by supplier category. [ENUM-REF-CANDIDATE: mro_supplier|fuel_vendor|airport_authority|gds_provider|catering|ground_handling|bsp_arc — promote to reference product]' ;
    rdfs:domain ind:AccountsPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withholdingTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Amount' ;
    rdfs:comment 'The amount of withholding tax (WHT) to be deducted from the vendor payment and remitted to the tax authority on behalf of the vendor. Applicable for cross-border supplier payments subject to bilateral tax treaties. Corresponds to SAP Extended Withholding Tax (WITH_ITEM).' ;
    rdfs:domain ind:AccountsPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:staffTravelEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Staff Travel Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Staff travel tickets (ID90, ZED fares) sold to employees create AR entries requiring employee linkage for payroll deduction processing, travel entitlement tracking, and revenue recognition per airline' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:ageingBucket rdf:type rdf:Property ;
    rdfs:label 'Ageing Bucket' ;
    rdfs:comment 'Ageing classification of the open receivable based on days past due date: CURRENT (not yet due), 1_30_DAYS, 31_60_DAYS, 61_90_DAYS, 91_120_DAYS, OVER_120_DAYS. Drives credit risk assessment and bad debt provisioning under IFRS 9 expected credit loss model.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arStatus rdf:type rdf:Property ;
    rdfs:label 'Ar Status' ;
    rdfs:comment 'Current lifecycle status of the receivable: OPEN (unpaid), PARTIALLY_PAID (partial payment received), CLEARED (fully paid and matched), DISPUTED (customer dispute raised), WRITTEN_OFF (bad debt write-off applied), IN_DUNNING (active dunning process initiated).' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankValueDate rdf:type rdf:Property ;
    rdfs:label 'Bank Value Date' ;
    rdfs:comment 'Value date on which funds were credited to the airline\'s bank account for this receivable. Distinct from posting date; used for treasury cash flow forecasting and bank reconciliation.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bspArcBillingPeriod rdf:type rdf:Property ;
    rdfs:label 'Bsp Arc Billing Period' ;
    rdfs:comment 'IATA BSP or ARC billing period identifier (e.g., 2024-W03 for weekly cycle) to which this agency receivable belongs. Supports settlement reconciliation and dispute management with travel agencies.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingDate rdf:type rdf:Property ;
    rdfs:label 'Clearing Date' ;
    rdfs:comment 'Date on which the receivable was fully cleared (matched against incoming payment or credit memo) in SAP. Null for open items. Used for Days Sales Outstanding (DSO) calculation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:creditControlArea rdf:type rdf:Property ;
    rdfs:label 'Credit Control Area' ;
    rdfs:comment 'SAP credit control area (KKBER) under which the customer\'s credit limit is managed. Groups customers for credit exposure monitoring across company codes.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimit rdf:type rdf:Property ;
    rdfs:label 'Credit Limit' ;
    rdfs:comment 'Approved credit limit assigned to the customer in the credit control area, expressed in the credit control area currency. Used for credit exposure monitoring and order block decisions.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Customer Account Number' ;
    rdfs:comment 'SAP debtor account number (KUNNR) identifying the customer — travel agency, corporate account, interline carrier, or cargo shipper — against whom the receivable is raised.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerName rdf:type rdf:Property ;
    rdfs:label 'Customer Name' ;
    rdfs:comment 'Legal name of the debtor customer as maintained in SAP customer master. Covers travel agencies, corporate accounts, interline carriers, and cargo clients.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daysOverdue rdf:type rdf:Property ;
    rdfs:label 'Days Overdue' ;
    rdfs:comment 'Number of calendar days the receivable is past its due date as of the last refresh date. Negative values indicate days until due. Used for DSO reporting and credit risk monitoring.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:disputeReasonCode rdf:type rdf:Property ;
    rdfs:label 'Dispute Reason Code' ;
    rdfs:comment 'Standardized code identifying the reason for a customer dispute on this receivable (e.g., pricing discrepancy, duplicate billing, service not rendered, ADM — Agency Debit Memo dispute). Null when no dispute exists. [ENUM-REF-CANDIDATE: PRICE_DISCREPANCY|DUPLICATE_BILLING|SERVICE_NOT_RENDERED|ADM_DISPUTE|CREDIT_NOT_APPLIED|INTERLINE_PRORATE_DIFF — promote to reference product]' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentCurrency rdf:type rdf:Property ;
    rdfs:label 'Document Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the AR document amounts are denominated (e.g., USD, EUR, GBP). Supports multi-currency airline operations and foreign exchange reporting.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentNumber rdf:type rdf:Property ;
    rdfs:label 'Document Number' ;
    rdfs:comment 'SAP FI-AR accounting document number uniquely identifying the receivable posting within the company code. Corresponds to BELNR field in SAP BSID/BSAD tables.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentType rdf:type rdf:Property ;
    rdfs:label 'Document Type' ;
    rdfs:comment 'SAP document type code classifying the nature of the AR posting: DR (customer invoice), DG (credit memo), DA (customer document), RV (billing document transfer), AB (accounting document). Drives posting logic and account determination.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dunningLevel rdf:type rdf:Property ;
    rdfs:label 'Dunning Level' ;
    rdfs:comment 'Current dunning level (1–4) assigned to this receivable in SAP dunning program, indicating the escalation stage of the collection notice. Level 0 means no dunning initiated.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:glAccount rdf:type rdf:Property ;
    rdfs:label 'Gl Account' ;
    rdfs:comment 'SAP general ledger account number to which the receivable is posted (e.g., trade receivables, interline receivables, cargo receivables). Drives financial statement classification.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastDunningDate rdf:type rdf:Property ;
    rdfs:label 'Last Dunning Date' ;
    rdfs:comment 'Date on which the most recent dunning notice was issued to the customer for this receivable. Used to track collection activity and enforce dunning intervals.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:localCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Local Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter code for the company code local (functional) currency to which document amounts are translated for statutory reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openAmount rdf:type rdf:Property ;
    rdfs:label 'Open Amount' ;
    rdfs:comment 'Remaining unpaid balance on the receivable at the current point in time, calculated as gross amount minus payments received and credit memos applied. Core field for working capital management and ageing analysis.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receivableType rdf:type rdf:Property ;
    rdfs:label 'Receivable Type' ;
    rdfs:comment 'Classification of the receivable by originating business channel: BSP_AGENCY (IATA Billing and Settlement Plan agency), ARC_AGENCY (Airlines Reporting Corporation agency), CORPORATE (direct corporate account billing), INTERLINE (interline carrier settlement), CARGO_AWB (Air Waybill cargo collection), ANCILLARY (ancillary service charges such as excess baggage, upgrades).' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceDocument rdf:type rdf:Property ;
    rdfs:label 'Reference Document' ;
    rdfs:comment 'External reference number associated with the receivable, such as the BSP billing period reference, ARC settlement report number, Air Waybill (AWB) number for cargo, or PNR for passenger billings. Enables cross-system reconciliation.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:writeOffAmount rdf:type rdf:Property ;
    rdfs:label 'Write Off Amount' ;
    rdfs:comment 'Amount written off as bad debt for this receivable, in document currency. Populated when ar_status is WRITTEN_OFF. Supports bad debt expense reporting and IFRS 9 expected credit loss provisioning.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetPlanId rdf:type rdf:Property ;
    rdfs:label 'Budget Plan Id' ;
    rdfs:comment 'Unique surrogate identifier for the budget plan record in the finance data product. Primary key for the budget_plan entity.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BudgetPlan .

ind:approverEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Approver Employee Id' ;
    rdfs:comment 'Reference to the senior manager, CFO, or board member who approved this budget plan. Supports segregation of duties and audit trail requirements.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryBudgetEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Budget Employee Id' ;
    rdfs:comment 'Reference to the employee or manager responsible for owning and managing this budget plan. Supports accountability tracking and approval workflow routing in SAP BPC.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:procurementCategoryId rdf:type rdf:Property ;
    rdfs:label 'Procurement Category Id' ;
    rdfs:comment 'Foreign key linking to procurement.procurement_category. Business justification: Budget planning allocates spend targets by procurement category for category management, variance reporting, and strategic sourcing alignment. Core to procurement financial planning and category strat' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcurementCategory .

ind:profitCentreId rdf:type rdf:Property ;
    rdfs:label 'Profit Centre Id' ;
    rdfs:comment 'Reference to the SAP CO-PA profit centre associated with this budget plan. Supports profitability analysis by route, fleet type, or business unit.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCentre .

ind:askBudget rdf:type rdf:Property ;
    rdfs:label 'Ask Budget' ;
    rdfs:comment 'Budgeted Available Seat Kilometers (ASK) for the planning period, representing planned capacity output. ASK is the industry-standard capacity metric (seats × kilometers flown). Used as the denominator for CASK and RASK budget calculations.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetCategory rdf:type rdf:Property ;
    rdfs:label 'Budget Category' ;
    rdfs:comment 'High-level financial category of the budget plan. OPEX = Operating Expenditure; CAPEX = Capital Expenditure; REVENUE = Revenue budget; MIXED = combined OPEX and CAPEX plan. Aligns with SAP CO-PA cost element categories.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capexBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Capex Budget Amount' ;
    rdfs:comment 'Budgeted amount allocated to capital expenditure (CAPEX) within this plan, including aircraft acquisitions, fleet modifications, and infrastructure investments. Supports IFRS 16 lease liability planning.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:caskBudget rdf:type rdf:Property ;
    rdfs:label 'Cask Budget' ;
    rdfs:comment 'Budgeted Cost per Available Seat Kilometer (CASK), calculated as total OPEX budget divided by ASK budget. Expressed in currency units per ASK. Primary airline unit cost efficiency metric used in board-level financial planning and investor reporting.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consolidationLevel rdf:type rdf:Property ;
    rdfs:label 'Consolidation Level' ;
    rdfs:comment 'The organisational level at which this budget plan is consolidated. \'entity\' = legal entity; \'division\' = business division (e.g., cargo, MRO); \'group\' = airline group; \'segment\' = IFRS 8 reportable segment. Supports financial consolidation and group reporting.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controllingAreaCode rdf:type rdf:Property ;
    rdfs:label 'Controlling Area Code' ;
    rdfs:comment 'The SAP CO controlling area code under which this budget plan is managed. The controlling area defines the organisational unit for internal cost accounting and profitability analysis in SAP CO-PA.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveFrom rdf:type rdf:Property ;
    rdfs:label 'Effective From' ;
    rdfs:comment 'The start date from which this budget plan is effective and binding for financial control purposes. Aligns with the fiscal period start in SAP FI.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveUntil rdf:type rdf:Property ;
    rdfs:label 'Effective Until' ;
    rdfs:comment 'The end date through which this budget plan remains effective. Null for open-ended multi-year plans. Aligns with fiscal period end in SAP FI.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:forecastCycle rdf:type rdf:Property ;
    rdfs:label 'Forecast Cycle' ;
    rdfs:comment 'The frequency at which this rolling forecast budget plan is updated and resubmitted. Applicable only when is_rolling_forecast is True. Supports planning cadence governance.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelCostBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Fuel Cost Budget Amount' ;
    rdfs:comment 'Budgeted amount specifically allocated to jet fuel procurement and uplift costs. Fuel is typically the largest single OPEX line for airlines. Supports fuel cost accounting and hedging strategy alignment.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interlineSettlementBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Interline Settlement Budget Amount' ;
    rdfs:comment 'Budgeted net interline billing settlement amount payable or receivable through IATA BSP/ARC for interline ticketing agreements with partner carriers. Supports interline prorate and billing reconciliation planning.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isRollingForecast rdf:type rdf:Property ;
    rdfs:label 'Is Rolling Forecast' ;
    rdfs:comment 'Indicates whether this budget plan is part of a rolling forecast cycle (True) or a fixed annual budget (False). Rolling forecasts are updated periodically (monthly/quarterly) to reflect current business conditions.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leaseLiabilityBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Lease Liability Budget Amount' ;
    rdfs:comment 'Budgeted amount for aircraft and facility lease liabilities recognised under IFRS 16. Covers both operating lease right-of-use asset depreciation and interest on lease liabilities for dry lease and ACMI arrangements.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:loadFactorBudgetPct rdf:type rdf:Property ;
    rdfs:label 'Load Factor Budget Pct' ;
    rdfs:comment 'Budgeted passenger load factor expressed as a percentage (e.g., 82.50 = 82.5%). Load factor is the percentage of available seats filled by revenue passengers. Used in revenue budget planning and yield management alignment.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lockedDate rdf:type rdf:Property ;
    rdfs:label 'Locked Date' ;
    rdfs:comment 'The date on which the budget plan was locked to prevent further modifications, marking the start of the execution period. Locked budgets serve as the baseline for variance reporting.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:opexBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Opex Budget Amount' ;
    rdfs:comment 'Budgeted amount allocated to operating expenditure (OPEX) within this plan, including fuel, crew, maintenance, airport charges, and overhead. Key input for CASK (Cost per Available Seat Kilometer) reporting.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planName rdf:type rdf:Property ;
    rdfs:label 'Plan Name' ;
    rdfs:comment 'Human-readable descriptive name of the budget plan (e.g., \'FY2025 Annual Operating Budget\', \'Q3 2025 Rolling Forecast\'). Used for display and reporting purposes.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planNumber rdf:type rdf:Property ;
    rdfs:label 'Plan Number' ;
    rdfs:comment 'Externally-known alphanumeric identifier for the budget plan, aligned with SAP BPC plan version numbering (e.g., BP-2025-001). Used for cross-system reference and audit trails.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planStatus rdf:type rdf:Property ;
    rdfs:label 'Plan Status' ;
    rdfs:comment 'Current lifecycle state of the budget plan within the approval workflow. \'draft\' = in preparation; \'submitted\' = awaiting review; \'under_review\' = being evaluated; \'approved\' = board/CFO approved; \'rejected\' = returned for revision; \'locked\' = frozen for execution; \'archived\' = superseded. [ENUM-REF-CANDIDATE: draft|submitted|under_review|approved|rejected|locked|archived — promote to reference product]' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planType rdf:type rdf:Property ;
    rdfs:label 'Plan Type' ;
    rdfs:comment 'Classification of the budget plan by planning methodology. \'annual\' = full-year fixed budget; \'rolling_forecast\' = continuously updated forecast; \'supplemental\' = mid-year adjustment; \'capital\' = CAPEX-specific plan; \'zero_based\' = zero-based budgeting cycle.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planVersion rdf:type rdf:Property ;
    rdfs:label 'Plan Version' ;
    rdfs:comment 'Version identifier of the budget plan, supporting iterative planning cycles (e.g., \'v1.0\', \'v2.3\', \'RF-Q2\'). Enables tracking of revisions and rolling forecast iterations within SAP BPC.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningHorizonYears rdf:type rdf:Property ;
    rdfs:label 'Planning Horizon Years' ;
    rdfs:comment 'Number of years covered by this budget plan (e.g., 1 for annual, 3 or 5 for multi-year strategic plans). Supports long-range financial planning and IFRS 16 lease liability projections.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:raskBudget rdf:type rdf:Property ;
    rdfs:label 'Rask Budget' ;
    rdfs:comment 'Budgeted Revenue per Available Seat Kilometer (RASK), calculated as total revenue budget divided by ASK budget. Expressed in currency units per ASK. Key airline revenue productivity metric for strategic planning and investor reporting.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Revenue Budget Amount' ;
    rdfs:comment 'Budgeted revenue target for the planning period, covering passenger revenue, cargo revenue, ancillary services, and loyalty program income. Supports RASK (Revenue per Available Seat Kilometer) planning.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Total Budget Amount' ;
    rdfs:comment 'The gross total budgeted amount for this plan in the plan currency, covering all line items. Represents the top-line financial commitment approved for the planning period. Used for board-level financial reporting.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Variance Threshold Amount' ;
    rdfs:comment 'The maximum allowable absolute monetary deviation between budgeted and actual amounts before a variance alert is triggered. Complements the percentage threshold for large-value budget lines where a fixed amount cap is more appropriate.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceThresholdPct rdf:type rdf:Property ;
    rdfs:label 'Variance Threshold Pct' ;
    rdfs:comment 'The maximum allowable percentage deviation between budgeted and actual amounts before a variance alert is triggered for management review. Expressed as a percentage (e.g., 5.00 = 5%). Supports financial control and exception reporting.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:airlineAccountingCode rdf:type rdf:Property ;
    rdfs:label 'Airline Accounting Code' ;
    rdfs:comment 'Three-digit IATA numeric airline accounting code (also known as the airline prefix) used in e-ticket stock numbering, interline billing, and BSP/ARC settlement transactions. Uniquely identifies the airline in financial settlement systems.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arcParticipantFlag rdf:type rdf:Property ;
    rdfs:label 'Arc Participant Flag' ;
    rdfs:comment 'Indicates whether this legal entity participates in the Airlines Reporting Corporation (ARC) settlement system for US domestic ticket sales. Relevant for North American entities and drives ARC settlement accounts receivable processing.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bspParticipantFlag rdf:type rdf:Property ;
    rdfs:label 'Bsp Participant Flag' ;
    rdfs:comment 'Indicates whether this legal entity is a registered participant in the IATA Billing and Settlement Plan (BSP) for settlement of ticket sales through travel agents. Drives interline billing and accounts receivable settlement workflows.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:chartOfAccounts rdf:type rdf:Property ;
    rdfs:label 'Chart Of Accounts' ;
    rdfs:comment 'Four-character SAP code identifying the chart of accounts assigned to this company code. Defines the general ledger account structure, account numbering, and account descriptions applicable to all financial postings. Corresponds to SAP KTOPL field.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyCodeCode rdf:type rdf:Property ;
    rdfs:label 'Company Code Code' ;
    rdfs:comment 'Four-character alphanumeric SAP FI company code uniquely identifying the legal entity within the SAP S/4HANA system. Matches the SAP Bukrs field. Used as the primary business key across all FI/CO postings, journal entries, and financial statements.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyCodeStatus rdf:type rdf:Property ;
    rdfs:label 'Company Code Status' ;
    rdfs:comment 'Current lifecycle status of the company code within SAP FI. Controls whether new financial postings can be made against this entity. \'inactive\' blocks new postings; \'in_liquidation\' triggers specific closing procedures under IFRS.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationGroup rdf:type rdf:Property ;
    rdfs:label 'Consolidation Group' ;
    rdfs:comment 'Identifier of the financial consolidation group to which this company code belongs within the group reporting hierarchy. Used for intercompany elimination, minority interest calculations, and preparation of consolidated financial statements under IFRS 10.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationUnit rdf:type rdf:Property ;
    rdfs:label 'Consolidation Unit' ;
    rdfs:comment 'SAP Group Reporting consolidation unit identifier mapped to this company code. Represents the lowest-level reporting unit in the consolidation hierarchy for multi-entity financial roll-up and statutory consolidation.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controllingArea rdf:type rdf:Property ;
    rdfs:label 'Controlling Area' ;
    rdfs:comment 'Four-character SAP CO controlling area code assigned to this company code. Defines the scope of cost accounting, profit center accounting, and internal order management. Enables CASK (Cost per Available Seat Kilometer) and RASK reporting by aligning cost objects to revenue data.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:corsiaParticipantFlag rdf:type rdf:Property ;
    rdfs:label 'Corsia Participant Flag' ;
    rdfs:comment 'Indicates whether this legal entity is subject to CORSIA (Carbon Offsetting and Reduction Scheme for International Aviation) obligations. Drives carbon offset liability accounting and regulatory reporting to ICAO.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:countryOfIncorporation rdf:type rdf:Property ;
    rdfs:label 'Country Of Incorporation' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code of the jurisdiction in which the legal entity is incorporated. Drives statutory reporting requirements, applicable tax law, and national civil aviation authority oversight.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entityType rdf:type rdf:Property ;
    rdfs:label 'Entity Type' ;
    rdfs:comment 'Classification of the legal entity by its corporate structure. Determines consolidation treatment, intercompany elimination rules, and applicable accounting standards. [ENUM-REF-CANDIDATE: airline|subsidiary|holding|joint_venture|special_purpose_vehicle|branch — promote to reference product if additional types are required]' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalYearVariant rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year Variant' ;
    rdfs:comment 'Two-character SAP code defining the fiscal year structure for this company code, including the number of posting periods, special periods, and whether the fiscal year aligns with the calendar year. Corresponds to SAP PERIV field. Critical for period-end close and CASK reporting cycles.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Group Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code of the parent group\'s reporting currency used for financial consolidation. Transactions in local currency are translated to group currency for consolidated financial statements.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iataAirlineCode rdf:type rdf:Property ;
    rdfs:label 'Iata Airline Code' ;
    rdfs:comment 'Two-character IATA airline designator code assigned to this legal entity. Used in BSP (Billing and Settlement Plan) settlements, interline billing, ticket issuance, and ARC (Airlines Reporting Corporation) reporting. Links financial entity to operational airline identity.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icaoAirlineCode rdf:type rdf:Property ;
    rdfs:label 'Icao Airline Code' ;
    rdfs:comment 'Three-letter ICAO airline designator code for this legal entity. Used in flight plan filings, ATC communications, NOTAM references, and regulatory correspondence with national civil aviation authorities.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ifrs16LesseeFlag rdf:type rdf:Property ;
    rdfs:label 'Ifrs16 Lessee Flag' ;
    rdfs:comment 'Indicates whether this company code is subject to IFRS 16 Leases accounting, requiring recognition of right-of-use assets and lease liabilities on the balance sheet. Applicable to entities with aircraft dry leases, wet leases, or ACMI arrangements.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ifrsReportingStandard rdf:type rdf:Property ;
    rdfs:label 'Ifrs Reporting Standard' ;
    rdfs:comment 'Accounting standard under which this legal entity prepares its statutory financial statements. Determines recognition, measurement, and disclosure requirements including IFRS 16 lease liability treatment and CORSIA carbon offset accounting.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incorporationDate rdf:type rdf:Property ;
    rdfs:label 'Incorporation Date' ;
    rdfs:comment 'Date on which the legal entity was formally incorporated or registered with the relevant national company registry. Used for entity lifecycle tracking and statutory reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:intercompanyEliminationFlag rdf:type rdf:Property ;
    rdfs:label 'Intercompany Elimination Flag' ;
    rdfs:comment 'Indicates whether intercompany transactions posted against this company code are subject to elimination during group financial consolidation. True for entities within the consolidation perimeter; false for associates or joint ventures accounted for under equity method.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operatingCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Operating Certificate Number' ;
    rdfs:comment 'Air Operator Certificate (AOC) number issued by the national civil aviation authority authorising this legal entity to conduct commercial air transport operations. Links the financial entity to its operational regulatory authorisation.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipPercentage rdf:type rdf:Property ;
    rdfs:label 'Ownership Percentage' ;
    rdfs:comment 'Percentage of equity ownership held by the immediate parent entity in this legal entity. Determines consolidation method: full consolidation (>50%), equity method (20-50%), or cost method (<20%) under IFRS 10/IAS 28.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postingPeriodVariant rdf:type rdf:Property ;
    rdfs:label 'Posting Period Variant' ;
    rdfs:comment 'Four-character SAP code controlling which fiscal periods are open or closed for posting in this company code. Governs period-end close procedures and prevents backdated postings outside approved windows. Corresponds to SAP BDATV field.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredAddress rdf:type rdf:Property ;
    rdfs:label 'Registered Address' ;
    rdfs:comment 'Full registered office address of the legal entity as recorded with the national company registry. Used for statutory correspondence, regulatory filings, and legal notices.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredAddressCountry rdf:type rdf:Property ;
    rdfs:label 'Registered Address Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the registered office address of the legal entity. May differ from country of incorporation for branch entities. Required for statutory filings and regulatory correspondence.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortName rdf:type rdf:Property ;
    rdfs:label 'Short Name' ;
    rdfs:comment 'Abbreviated trading or operating name of the legal entity used in internal reports, SAP correspondence, and financial dashboards. Corresponds to SAP BUTXT field.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxJurisdictionCode rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction Code' ;
    rdfs:comment 'Tax jurisdiction code identifying the applicable tax authority and tax calculation procedure for this company code. Used for VAT/GST determination, withholding tax, and Passenger Facility Charge (PFC) reporting to DOT.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vatRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Vat Registration Number' ;
    rdfs:comment 'Official VAT or GST registration number issued by the national tax authority for this legal entity. Required for VAT invoicing, reclaim submissions, and cross-border tax compliance. Sensitive business identifier.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activityTypeCode rdf:type rdf:Property ;
    rdfs:label 'Activity Type Code' ;
    rdfs:comment 'Primary SAP CO activity type associated with this cost centre, defining the unit of output for internal activity allocation (e.g., \'FLT-HRS\' = flight hours, \'BLK-HRS\' = block hours, \'MRO-MHR\' = maintenance man-hours, \'GND-TRN\' = ground turns). Used to calculate internal activity rates for cost allocation between centres.' ;
    rdfs:domain ind:CostCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Budget Amount' ;
    rdfs:comment 'Total approved annual budget allocated to this cost centre for the current fiscal year, in the controlling area currency. Represents the authorised spending limit for departmental P&L management. Used in budget vs. actual variance reporting and financial planning.' ;
    rdfs:domain ind:CostCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetVersion rdf:type rdf:Property ;
    rdfs:label 'Budget Version' ;
    rdfs:comment 'SAP CO planning version identifier for the budget associated with this cost centre (e.g., \'000\' = actuals, \'001\' = original budget, \'002\' = revised forecast, \'PLAN\' = annual plan). Enables comparison of actuals vs. budget vs. forecast in variance reporting.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessAreaCode rdf:type rdf:Property ;
    rdfs:label 'Business Area Code' ;
    rdfs:comment 'SAP FI business area assigned to this cost centre, representing a distinct area of operations for internal balance sheet and P&L reporting (e.g., \'PASS\' = Passenger, \'CARG\' = Cargo, \'MRO\' = Maintenance). Enables segment reporting per IFRS 8 without full profit centre accounting.' ;
    rdfs:domain ind:CostCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caskAllocationKey rdf:type rdf:Property ;
    rdfs:label 'Cask Allocation Key' ;
    rdfs:comment 'Allocation driver used to apportion this cost centre\'s costs to Available Seat Kilometers (ASK) for CASK reporting. \'ask\' = direct ASK-based allocation; \'block_hours\' = by block hours flown; \'departures\' = by number of departures; \'pax\' = by passenger count; \'revenue\' = by revenue share; \'equal\' = equal split; \'manual\' = manually defined percentages. Critical for unit cost benchmarking. [ENUM-REF-CANDIDATE: ask|block_hours|departures|pax|revenue|equal|manual — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CostCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:centreType rdf:type rdf:Property ;
    rdfs:label 'Centre Type' ;
    rdfs:comment 'Classification of the responsibility centre by financial accountability type. \'cost\' centres track expenditure only (e.g., maintenance base); \'profit\' centres track both revenue and cost for P&L reporting (e.g., route group, cargo division); \'investment\' centres include capital employed; \'revenue\' centres track revenue attribution (e.g., lounge, ancillary). Drives CASK/RASK allocation methodology.' ;
    rdfs:domain ind:CostCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:corsiaEmissionsFlag rdf:type rdf:Property ;
    rdfs:label 'Corsia Emissions Flag' ;
    rdfs:comment 'Indicates whether this cost centre is subject to CORSIA (Carbon Offsetting and Reduction Scheme for International Aviation) emissions monitoring and offset cost accounting. True for international route operations cost centres. Drives inclusion in ICAO CORSIA compliance reporting and carbon offset cost allocation.' ;
    rdfs:domain ind:CostCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costCentreCode rdf:type rdf:Property ;
    rdfs:label 'Cost Centre Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the cost centre within the SAP CO controlling area. Used in journal entries, budget allocations, and management reporting (e.g., \'FLT-OPS-001\', \'MRO-BASE-LHR\', \'CARGO-HUB-JFK\'). Aligns with SAP CO cost centre number.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCentreDescription rdf:type rdf:Property ;
    rdfs:label 'Cost Centre Description' ;
    rdfs:comment 'Long-form narrative description of the cost centre\'s business purpose, scope of operations, and cost accountability. Provides context for financial analysts and auditors beyond the short name (e.g., \'Responsible for all direct operating costs of widebody long-haul fleet on North Atlantic routes including fuel uplift, crew costs, and ATC charges\').' ;
    rdfs:domain ind:CostCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCentreName rdf:type rdf:Property ;
    rdfs:label 'Cost Centre Name' ;
    rdfs:comment 'Full descriptive name of the cost centre as maintained in SAP CO master data (e.g., \'Flight Operations — North Atlantic Hub\', \'Cabin Crew Training — Base London\', \'MRO Line Maintenance — Frankfurt\'). Used in financial reports and management dashboards.' ;
    rdfs:domain ind:CostCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCentreStatus rdf:type rdf:Property ;
    rdfs:label 'Cost Centre Status' ;
    rdfs:comment 'Current lifecycle status of the cost centre in SAP CO. \'active\' = open for postings; \'inactive\' = temporarily suspended; \'locked\' = blocked for new postings (period-end); \'pending_activation\' = created but not yet released; \'closed\' = permanently deactivated with no further postings permitted.' ;
    rdfs:domain ind:CostCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelCostFlag rdf:type rdf:Property ;
    rdfs:label 'Fuel Cost Flag' ;
    rdfs:comment 'Indicates whether this cost centre is designated for fuel cost accounting and uplift tracking. True for flight operations and route cost centres where jet fuel (Jet-A/A1) costs are directly attributed. Enables fuel cost per ASK (fuel CASK) component reporting and hedging P&L attribution.' ;
    rdfs:domain ind:CostCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:functionalAreaCode rdf:type rdf:Property ;
    rdfs:label 'Functional Area Code' ;
    rdfs:comment 'SAP FI/CO functional area classifying the cost centre by business function for cost-of-sales accounting and segment reporting (e.g., \'PROD\' = Production/Operations, \'SELL\' = Sales, \'ADMN\' = Administration, \'R&D\' = Research). Required for IFRS income statement by function of expense.' ;
    rdfs:domain ind:CostCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccountGroup rdf:type rdf:Property ;
    rdfs:label 'Gl Account Group' ;
    rdfs:comment 'SAP FI general ledger account group associated with primary cost postings for this cost centre. Defines the range of GL accounts permissible for postings, ensuring cost classification consistency (e.g., \'OPEX\' for operating expenses, \'FUEL\' for fuel costs, \'LABOR\' for crew and staff costs).' ;
    rdfs:domain ind:CostCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyArea rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Area' ;
    rdfs:comment 'Node identifier within the standard cost centre hierarchy (SAP CO standard hierarchy) to which this centre is assigned. Enables roll-up reporting by business segment, division, or region (e.g., \'FLIGHT-OPS\', \'MRO-EMEA\', \'CARGO-APAC\'). Used for group-level CASK reporting and segment P&L consolidation.' ;
    rdfs:domain ind:CostCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyLevel rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Level' ;
    rdfs:comment 'Numeric depth of this cost centre within the standard hierarchy tree (1 = top-level division, 2 = sub-division, 3 = department, 4 = operational unit, etc.). Used to control report aggregation and drill-down navigation in management accounting dashboards.' ;
    rdfs:domain ind:CostCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hubAirportCode rdf:type rdf:Property ;
    rdfs:label 'Hub Airport Code' ;
    rdfs:comment 'IATA three-letter airport code of the hub or base airport associated with this cost centre, where applicable (e.g., \'LHR\' for London Heathrow hub operations, \'JFK\' for New York hub, \'FRA\' for Frankfurt MRO base). Enables geographic cost attribution and hub-level CASK analysis. Null for non-location-specific centres.' ;
    rdfs:domain ind:CostCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iataCostCategory rdf:type rdf:Property ;
    rdfs:label 'Iata Cost Category' ;
    rdfs:comment 'IATA standard cost category classification for airline management accounting and industry benchmarking (e.g., \'Flight Operations\', \'Maintenance\', \'Passenger Services\', \'Sales and Distribution\', \'General and Administration\'). Enables CASK component benchmarking against IATA industry data. [ENUM-REF-CANDIDATE: Flight Operations|Maintenance|Passenger Services|Sales and Distribution|General and Administration|Cargo|Ground Operations — promote to reference product]' ;
    rdfs:domain ind:CostCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interlineSettlementFlag rdf:type rdf:Property ;
    rdfs:label 'Interline Settlement Flag' ;
    rdfs:comment 'Indicates whether this cost centre participates in interline billing settlement processes (IATA BSP/ARC). True for cost centres associated with interline revenue sharing, prorate agreements, and bilateral settlement with partner carriers. Drives inclusion in interline financial reconciliation workflows.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:internalActivityRate rdf:type rdf:Property ;
    rdfs:label 'Internal Activity Rate' ;
    rdfs:comment 'Planned cost rate per unit of activity output for this cost centre (in controlling area currency). Used for internal cost allocation between cost centres (e.g., cost per block hour charged from Flight Operations to Route cost centres). Recalculated each planning cycle. Classified confidential as it reflects internal transfer pricing.' ;
    rdfs:domain ind:CostCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastChangedBy rdf:type rdf:Property ;
    rdfs:label 'Last Changed By' ;
    rdfs:comment 'SAP user ID of the person who last modified this cost centre master record. Supports audit trail requirements for financial master data governance and SOX compliance controls over cost centre maintenance.' ;
    rdfs:domain ind:CostCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastChangedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Changed Timestamp' ;
    rdfs:comment 'Timestamp of the most recent modification to this cost centre master record in SAP CO. Used for change tracking, incremental data extraction (delta loads), and audit compliance. Corresponds to SAP CDHDR change document header timestamp.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:profitCentreCode rdf:type rdf:Property ;
    rdfs:label 'Profit Centre Code' ;
    rdfs:comment 'SAP CO profit centre to which this cost centre is assigned for internal P&L reporting. Enables revenue attribution and profitability analysis at route, hub, or business segment level. Supports RASK/CASK analysis by profit centre.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:raskAttributionFlag rdf:type rdf:Property ;
    rdfs:label 'Rask Attribution Flag' ;
    rdfs:comment 'Indicates whether this cost centre participates in Revenue per Available Seat Kilometer (RASK) attribution for route profitability analysis. True for profit centres and revenue-generating units (e.g., route groups, lounges, ancillary services); False for pure cost centres (e.g., corporate functions, back-office).' ;
    rdfs:domain ind:CostCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:validFrom rdf:type rdf:Property ;
    rdfs:label 'Valid From' ;
    rdfs:comment 'Date from which this cost centre is valid and open for financial postings in SAP CO. Supports time-dependent master data management — cost centre attributes may change over time with new validity periods. Aligns with fiscal year planning cycles.' ;
    rdfs:domain ind:CostCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validTo rdf:type rdf:Property ;
    rdfs:label 'Valid To' ;
    rdfs:comment 'Date until which this cost centre is valid for financial postings. Null or 31-Dec-9999 indicates an open-ended validity. Used to manage cost centre lifecycle, seasonal operations (e.g., charter season cost centres), and organisational restructuring.' ;
    rdfs:domain ind:CostCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:custodianEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Custodian Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Assets assigned to employees (laptops, uniforms, tools, crew equipment) require custodian tracking for asset accountability, loss prevention, and disposal authorization per airline asset management po' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accumulatedDepreciation rdf:type rdf:Property ;
    rdfs:label 'Accumulated Depreciation' ;
    rdfs:comment 'Total depreciation charged against the asset from acquisition date to the current reporting period. Corresponds to SAP ANLC.KNAFA (cumulative ordinary depreciation). Used to compute net book value and for balance sheet reporting.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acquisitionCost rdf:type rdf:Property ;
    rdfs:label 'Acquisition Cost' ;
    rdfs:comment 'Original acquisition cost (historical cost) of the asset in the document currency at the time of purchase. For aircraft, includes purchase price, import duties, and directly attributable costs to bring the asset to its intended use. Corresponds to SAP ANLC.KANSW.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assetClassCode rdf:type rdf:Property ;
    rdfs:label 'Asset Class Code' ;
    rdfs:comment 'SAP asset class (ANLKL) categorising the asset for depreciation rules, GL account determination, and reporting. Examples: 1000=Aircraft, 1100=Aircraft Engines, 1200=Simulators, 2000=Ground Support Equipment, 3000=IT Infrastructure, 4000=Leasehold Improvements, 5000=Right-of-Use Assets (IFRS 16). [ENUM-REF-CANDIDATE: 1000|1100|1200|2000|3000|4000|5000|6000 — promote to reference product]' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetClassName rdf:type rdf:Property ;
    rdfs:label 'Asset Class Name' ;
    rdfs:comment 'Human-readable name of the SAP asset class (e.g., \'Aircraft\', \'Aircraft Engines\', \'Flight Simulators\', \'Ground Support Equipment\'). Denormalised for reporting convenience.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetDescription rdf:type rdf:Property ;
    rdfs:label 'Asset Description' ;
    rdfs:comment 'Primary human-readable description of the fixed asset (e.g., \'Boeing 737-800 MSN 45123\', \'Full Flight Simulator B737\', \'Ground Power Unit GPU-400\'). Corresponds to SAP ANLA.TXT50 field.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetLocationCode rdf:type rdf:Property ;
    rdfs:label 'Asset Location Code' ;
    rdfs:comment 'IATA airport or facility code indicating the primary physical location of the asset (e.g., \'LHR\' for Heathrow maintenance base, \'JFK\' for ground support equipment). Corresponds to SAP ANLA.STORT. Supports insurance valuation and physical asset verification.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetNumber rdf:type rdf:Property ;
    rdfs:label 'Asset Number' ;
    rdfs:comment 'SAP FI-AA main asset number uniquely identifying the asset within the company code. Corresponds to the ANLN1 field in SAP Asset Master (ANLZ/ANLB tables). Used for CAPEX tracking and asset register reconciliation.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetStatus rdf:type rdf:Property ;
    rdfs:label 'Asset Status' ;
    rdfs:comment 'Current lifecycle status of the fixed asset. \'active\' = in service and depreciating; \'under_construction\' = Asset Under Construction (AUC) not yet capitalised; \'disposed\' = sold, scrapped, or written off; \'transferred\' = transferred to another company code or cost centre; \'impaired\' = impairment loss recognised per IAS 36; \'deactivated\' = temporarily taken out of service.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetSubnumber rdf:type rdf:Property ;
    rdfs:label 'Asset Subnumber' ;
    rdfs:comment 'SAP FI-AA sub-number (ANLN2) used to track component-level assets under a main asset number, such as individual aircraft engines under a parent airframe asset. Supports component accounting per IAS 16.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetType rdf:type rdf:Property ;
    rdfs:label 'Asset Type' ;
    rdfs:comment 'Categorises the asset by ownership or lease arrangement. \'owned\' = outright purchase; \'finance_lease\' = IFRS 16 right-of-use finance lease; \'operating_lease_rou\' = IFRS 16 right-of-use operating lease; \'dry_lease\' = aircraft leased without crew; \'wet_lease\' = aircraft leased with crew; \'acmi\' = Aircraft Crew Maintenance Insurance lease. Drives IFRS 16 vs IAS 16 accounting treatment.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capitalisationDate rdf:type rdf:Property ;
    rdfs:label 'Capitalisation Date' ;
    rdfs:comment 'Date on which the asset was formally capitalised and transferred from Asset Under Construction (AUC) to a productive asset class. May differ from acquisition_date for self-constructed assets or aircraft deliveries with pre-delivery payments.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:depreciationArea rdf:type rdf:Property ;
    rdfs:label 'Depreciation Area' ;
    rdfs:comment 'SAP FI-AA depreciation area code (AFABE) identifying the valuation basis (e.g., 01=Book Depreciation IFRS, 10=Tax Depreciation, 20=Group Reporting). Multiple depreciation areas allow parallel valuation for IFRS, local GAAP, and tax purposes.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depreciationMethodCode rdf:type rdf:Property ;
    rdfs:label 'Depreciation Method Code' ;
    rdfs:comment 'Code identifying the depreciation method applied to the asset. SL=Straight-Line; DB=Declining Balance; UOP=Units of Production (e.g., flight cycles or block hours for engines); SOYD=Sum of Years Digits; NONE=Non-depreciable (e.g., land). Corresponds to SAP ANLB.AFASL.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalDate rdf:type rdf:Property ;
    rdfs:label 'Disposal Date' ;
    rdfs:comment 'Date on which the asset was disposed of, sold, scrapped, or retired from service. Triggers cessation of depreciation and recognition of disposal gain or loss. Corresponds to SAP ANLA.DEAKT.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disposalProceeds rdf:type rdf:Property ;
    rdfs:label 'Disposal Proceeds' ;
    rdfs:comment 'Net proceeds received on disposal or sale of the asset. Used to calculate the gain or loss on disposal (disposal proceeds minus net book value at disposal date). Relevant for aircraft sales, part-out transactions, and GSE disposals.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impairmentLoss rdf:type rdf:Property ;
    rdfs:label 'Impairment Loss' ;
    rdfs:comment 'Cumulative impairment loss recognised on the asset where the carrying amount exceeds the recoverable amount. Applicable for aircraft fleets affected by route network changes, AOG events, or market value declines. Corresponds to SAP ANLC extraordinary depreciation.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceValue rdf:type rdf:Property ;
    rdfs:label 'Insurance Value' ;
    rdfs:comment 'Agreed hull insurance value of the asset as declared to the insurer, typically the agreed value or replacement cost for aircraft. Used for insurance premium calculation and claims settlement. May differ from net book value for older aircraft.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isIfrs16RouAsset rdf:type rdf:Property ;
    rdfs:label 'Is Ifrs16 Rou Asset' ;
    rdfs:comment 'Indicates whether this asset is a right-of-use (ROU) asset recognised under IFRS 16 Leases. True for aircraft, engines, and equipment under finance or operating leases. Drives separate balance sheet presentation and disclosure requirements.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leaseCommencementDate rdf:type rdf:Property ;
    rdfs:label 'Lease Commencement Date' ;
    rdfs:comment 'Date on which the lease term commences and the right-of-use (ROU) asset is recognised on the balance sheet under IFRS 16. Determines the start of ROU asset amortisation and lease liability unwinding.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leaseEndDate rdf:type rdf:Property ;
    rdfs:label 'Lease End Date' ;
    rdfs:comment 'Contractual end date of the lease term for right-of-use assets. Used to determine the remaining lease term for IFRS 16 ROU asset amortisation and lease liability discounting. Includes any reasonably certain renewal option periods.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:netBookValue rdf:type rdf:Property ;
    rdfs:label 'Net Book Value' ;
    rdfs:comment 'Current net book value of the asset calculated as acquisition cost minus accumulated depreciation and any impairment losses. Corresponds to SAP ANLC carrying amount. Key metric for CAPEX tracking, insurance valuation, and balance sheet reporting.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:purchaseOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Number' ;
    rdfs:comment 'SAP purchase order number (EBELN) associated with the asset acquisition. Links the fixed asset to the procurement process for CAPEX budget control and three-way matching (PO, goods receipt, invoice).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationNumber rdf:type rdf:Property ;
    rdfs:label 'Registration Number' ;
    rdfs:comment 'Official civil aviation authority registration number (tail number) assigned to the aircraft asset (e.g., G-BOAC, N12345). Applicable to aircraft and rotorcraft assets. Used for cross-referencing with flight operations, MRO, and insurance records.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualValue rdf:type rdf:Property ;
    rdfs:label 'Residual Value' ;
    rdfs:comment 'Estimated residual (salvage) value of the asset at the end of its useful life. For aircraft, this is typically the estimated scrap or resale value. Depreciation is calculated on the depreciable amount (acquisition cost minus residual value). Corresponds to SAP ANLB.SCHRW.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revaluationAmount rdf:type rdf:Property ;
    rdfs:label 'Revaluation Amount' ;
    rdfs:comment 'Cumulative revaluation surplus or deficit recognised where the airline applies the revaluation model for aircraft or property assets. Recorded in Other Comprehensive Income (OCI) under IAS 16 revaluation model. Corresponds to SAP ANLC.KZINS.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usefulLifePeriods rdf:type rdf:Property ;
    rdfs:label 'Useful Life Periods' ;
    rdfs:comment 'Remaining useful life expressed in fiscal periods (months) within the current fiscal year. Complements useful_life_years for mid-year acquisitions and partial-period depreciation calculations. Corresponds to SAP ANLB.NDPER.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vendorNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Number' ;
    rdfs:comment 'SAP vendor account number (LIFNR) of the supplier or lessor from whom the asset was acquired or leased. Used for accounts payable reconciliation and CAPEX purchase order matching.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wbsElement rdf:type rdf:Property ;
    rdfs:label 'Wbs Element' ;
    rdfs:comment 'SAP Project System WBS element (POSID) linked to the asset for CAPEX project tracking. Used during the Asset Under Construction (AUC) phase to accumulate project costs before capitalisation. Common for aircraft delivery projects and MRO facility upgrades.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelCostTransactionId rdf:type rdf:Property ;
    rdfs:label 'Fuel Cost Transaction Id' ;
    rdfs:comment 'Unique surrogate identifier for each fuel cost transaction record in the finance domain silver layer. Primary key for this data product.' ;
    rdfs:domain ind:FuelCostTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fuelUpliftId rdf:type rdf:Property ;
    rdfs:label 'Fuel Uplift Id' ;
    rdfs:comment 'Reference to the physical fuel uplift event recorded in flight operations (Jeppesen / NetLine/Ops). Links the financial accounting entry back to the operational fuel uplift record for CASK reconciliation.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FuelUplift .

ind:hedgeContractId rdf:type rdf:Property ;
    rdfs:label 'Hedge Contract Id' ;
    rdfs:comment 'Foreign key linking to finance.hedge_contract. Business justification: Each fuel cost transaction can be linked to ONE hedge contract for fuel price hedging. The fuel_cost_transaction table has hedging_contract_reference (STRING) which should be replaced with a FK to the' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:HedgeContract .

ind:carbonEmissionKg rdf:type rdf:Property ;
    rdfs:label 'Carbon Emission Kg' ;
    rdfs:comment 'Estimated CO2-equivalent carbon emissions in kilograms attributable to this fuel uplift, calculated using ICAO/CORSIA emission factors applied to the fuel quantity and SAF blend. Required for CORSIA offsetting obligations and ESG regulatory reporting.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeReference rdf:type rdf:Property ;
    rdfs:label 'Dispute Reference' ;
    rdfs:comment 'Reference number of any active or resolved supplier dispute raised against this fuel cost transaction (e.g., quantity discrepancy, pricing error). Populated when transaction_status = \'disputed\'. Used for accounts payable dispute management.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelDensity rdf:type rdf:Property ;
    rdfs:label 'Fuel Density' ;
    rdfs:comment 'Measured fuel density in kilograms per litre at the time of uplift, as recorded on the fuel delivery receipt. Used to reconcile volumetric (litres) and mass (kg) quantities and to validate fuel quality compliance.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelSupplierName rdf:type rdf:Property ;
    rdfs:label 'Fuel Supplier Name' ;
    rdfs:comment 'Name of the fuel supplier (oil major or independent) who provided the fuel (e.g., Shell Aviation, BP Aviation, ExxonMobil Aviation, World Fuel Services). Used for supplier spend analysis and contract compliance monitoring.' ;
    rdfs:domain ind:FuelCostTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Functional Currency Amount' ;
    rdfs:comment 'Net fuel cost translated into the airline\'s functional (reporting) currency using the exchange rate at the posting date. Required for consolidated P&L reporting and CASK calculation in a single currency.' ;
    rdfs:domain ind:FuelCostTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fxRate rdf:type rdf:Property ;
    rdfs:label 'Fx Rate' ;
    rdfs:comment 'Exchange rate applied to convert the transaction currency amount to the functional currency at the posting date. Sourced from SAP S/4HANA treasury exchange rate tables. Required for IFRS IAS 21 compliance.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossCostAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Cost Amount' ;
    rdfs:comment 'Total gross cost of the fuel uplift before any discounts, surcharges, or tax adjustments, in the transaction currency. Calculated as quantity × unit price. Base figure for CASK fuel component reporting.' ;
    rdfs:domain ind:FuelCostTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hedgeGainLossAmount rdf:type rdf:Property ;
    rdfs:label 'Hedge Gain Loss Amount' ;
    rdfs:comment 'Monetary gain or loss on the fuel hedge for this uplift, calculated as (hedged_unit_price - actual unit_price) × quantity. Positive = hedge gain (actual price exceeded hedged price); negative = hedge loss. Posted to the hedge reserve in OCI under IFRS 9.' ;
    rdfs:domain ind:FuelCostTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hedgedUnitPrice rdf:type rdf:Property ;
    rdfs:label 'Hedged Unit Price' ;
    rdfs:comment 'The locked-in fuel price per litre from the hedging contract applicable to this uplift. Compared against the actual unit_price to calculate hedge gain/loss and measure hedge effectiveness per IFRS 9.' ;
    rdfs:domain ind:FuelCostTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:intoPlaneAgentName rdf:type rdf:Property ;
    rdfs:label 'Into Plane Agent Name' ;
    rdfs:comment 'Name of the into-plane fuelling agent responsible for the physical delivery of fuel to the aircraft at the airport (may differ from the fuel supplier). Into-plane agents are contracted separately and charge a service fee included in the surcharge amount.' ;
    rdfs:domain ind:FuelCostTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netCostAmount rdf:type rdf:Property ;
    rdfs:label 'Net Cost Amount' ;
    rdfs:comment 'Net total cost of the fuel uplift after applying discounts and adjustments but inclusive of taxes and surcharges, in the transaction currency. This is the amount posted to the General Ledger and used for CASK fuel component reporting.' ;
    rdfs:domain ind:FuelCostTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Posting Timestamp' ;
    rdfs:comment 'Date and time when the fuel cost was posted to the General Ledger in SAP S/4HANA FI. Used for period-end close, accrual management, and financial reporting cut-off.' ;
    rdfs:domain ind:FuelCostTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:quantityKg rdf:type rdf:Property ;
    rdfs:label 'Quantity Kg' ;
    rdfs:comment 'Mass of fuel uplifted expressed in kilograms. The operationally authoritative unit for flight planning and weight-and-balance. Used for CASK fuel component calculation (cost per ASK) and fuel hedge effectiveness measurement.' ;
    rdfs:domain ind:FuelCostTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityLitres rdf:type rdf:Property ;
    rdfs:label 'Quantity Litres' ;
    rdfs:comment 'Volume of fuel uplifted expressed in litres. Standard volumetric unit used for into-plane agent invoicing and fuel supplier billing. Used alongside quantity_kg for density reconciliation.' ;
    rdfs:domain ind:FuelCostTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safBlendPercentage rdf:type rdf:Property ;
    rdfs:label 'Saf Blend Percentage' ;
    rdfs:comment 'Percentage of Sustainable Aviation Fuel (SAF) in the total fuel uplift volume (0.00–100.00). Required for CORSIA carbon offsetting calculations, SAF mandate compliance reporting, and ESG/sustainability disclosures.' ;
    rdfs:domain ind:FuelCostTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supplierInvoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Supplier Invoice Number' ;
    rdfs:comment 'Invoice number issued by the fuel supplier or into-plane agent for this uplift. Used for three-way matching (PO / goods receipt / invoice) in SAP S/4HANA MM/FI and for dispute resolution.' ;
    rdfs:domain ind:FuelCostTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxAndSurchargeAmount rdf:type rdf:Property ;
    rdfs:label 'Tax And Surcharge Amount' ;
    rdfs:comment 'Total taxes, levies, and into-plane service surcharges applied to the fuel uplift in the transaction currency. Includes Passenger Facility Charges (PFC) where applicable, fuel throughput fees, and local fuel taxes.' ;
    rdfs:domain ind:FuelCostTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionCurrency rdf:type rdf:Property ;
    rdfs:label 'Transaction Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the fuel cost transaction is denominated (e.g., USD, EUR, GBP). May differ from the company code currency requiring FX translation for consolidated reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionNumber rdf:type rdf:Property ;
    rdfs:label 'Transaction Number' ;
    rdfs:comment 'Externally-known business document number assigned by SAP S/4HANA FI at the time of financial posting (e.g., FI document number or material document number). Used for audit trail and cross-system reconciliation.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionStatus rdf:type rdf:Property ;
    rdfs:label 'Transaction Status' ;
    rdfs:comment 'Current lifecycle state of the fuel cost transaction in the financial system. \'posted\' = FI document posted to GL; \'reversed\' = reversal document created; \'pending\' = awaiting invoice matching; \'disputed\' = under supplier dispute; \'cancelled\' = voided prior to posting.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitPriceCurrency rdf:type rdf:Property ;
    rdfs:label 'Unit Price Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the unit price is denominated (e.g., USD, EUR, GBP). Fuel is typically priced in USD at international stations; local currency may apply at domestic stations.' ;
    rdfs:domain ind:FuelCostTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upliftSourceType rdf:type rdf:Property ;
    rdfs:label 'Uplift Source Type' ;
    rdfs:comment 'Method by which fuel was delivered to the aircraft: \'hydrant\' = airport hydrant system; \'bowser\' = mobile fuel tanker truck; \'pipeline\' = direct pipeline connection; \'barge\' = waterborne fuel barge (seaplane/amphibious operations). Affects into-plane service fee rates.' ;
    rdfs:domain ind:FuelCostTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upliftTimestamp rdf:type rdf:Property ;
    rdfs:label 'Uplift Timestamp' ;
    rdfs:comment 'Date and time (UTC) when the physical fuel uplift occurred at the airport. This is the principal real-world business event time, distinct from the financial posting timestamp. Critical for matching operational fuel records to financial entries.' ;
    rdfs:domain ind:FuelCostTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:accountingPrinciple rdf:type rdf:Property ;
    rdfs:label 'Accounting Principle' ;
    rdfs:comment 'The accounting standard under which this posting is recorded. Supports dual-reporting requirements for airlines operating across multiple jurisdictions. IFRS16 specifically tracks right-of-use asset and lease liability postings for aircraft operating leases.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amountCompanyCurrency rdf:type rdf:Property ;
    rdfs:label 'Amount Company Currency' ;
    rdfs:comment 'The posting amount converted to the company code\'s local currency (BSEG-DMBTR). Used for statutory financial reporting, local GAAP compliance, and period-end balance sheet preparation.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amountGroupCurrency rdf:type rdf:Property ;
    rdfs:label 'Amount Group Currency' ;
    rdfs:comment 'The posting amount translated to the group reporting currency (BSEG-KURSF-based calculation, stored as parallel ledger amount). Supports consolidated financial statements and group-level CASK/RASK reporting across all airline entities.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amountTransactionCurrency rdf:type rdf:Property ;
    rdfs:label 'Amount Transaction Currency' ;
    rdfs:comment 'The gross posting amount in the original transaction currency (BSEG-WRBTR). Represents the raw financial value before currency conversion. Used for interline billing settlements, BSP reconciliation, and multi-currency financial reporting.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:companyCurrency rdf:type rdf:Property ;
    rdfs:label 'Company Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code of the company code\'s local (functional) currency (T001-WAERS). The currency in which statutory accounts are prepared for the legal entity.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costElement rdf:type rdf:Property ;
    rdfs:label 'Cost Element' ;
    rdfs:comment 'SAP CO cost element corresponding to the GL account for cost and revenue postings (BSEG-KOSTL-linked KSTAR). Bridges FI and CO modules, enabling detailed cost analysis for fuel uplift, crew costs, MRO expenses, and lease payments.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:debitCreditIndicator rdf:type rdf:Property ;
    rdfs:label 'Debit Credit Indicator' ;
    rdfs:comment 'SAP indicator specifying whether the line item is a debit (S = Soll) or credit (H = Haben) posting (BSEG-SHKZG). Fundamental to double-entry bookkeeping and ensures the document balances to zero.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentDate rdf:type rdf:Property ;
    rdfs:label 'Document Date' ;
    rdfs:comment 'The date of the original source document (invoice, receipt, contract) that triggered the accounting entry (BKPF-BLDAT). May differ from posting_date for accruals, prepayments, or late-received invoices.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:functionalArea rdf:type rdf:Property ;
    rdfs:label 'Functional Area' ;
    rdfs:comment 'SAP functional area classifying the business function of the posting for cost-of-sales accounting (BSEG-FKBER). Enables income statement presentation by function (e.g., Flight Operations, Sales & Distribution, Administration) per IFRS IAS 1.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccountName rdf:type rdf:Property ;
    rdfs:label 'Gl Account Name' ;
    rdfs:comment 'Human-readable description of the GL account (SKA1-TXT50). Denormalised from the chart of accounts for reporting convenience and audit trail completeness. Examples: \'Jet Fuel Expense\', \'Aircraft Lease Liability (IFRS 16)\', \'Interline Receivable\'.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headerText rdf:type rdf:Property ;
    rdfs:label 'Header Text' ;
    rdfs:comment 'Free-text description at the accounting document header level (BKPF-BKTXT). Provides overall context for the journal entry, shared across all line items of the same document. Used for audit trail and period-end close documentation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intercompanyIndicator rdf:type rdf:Property ;
    rdfs:label 'Intercompany Indicator' ;
    rdfs:comment 'Flag indicating whether this posting is an intercompany transaction between two legal entities within the airline group (BKPF-BVTYP populated). True = intercompany posting requiring elimination in group consolidation. Critical for IFRS 10 consolidation.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:internalOrder rdf:type rdf:Property ;
    rdfs:label 'Internal Order' ;
    rdfs:comment 'SAP CO internal order number used to collect costs for specific projects, campaigns, or temporary cost objects (BSEG-AUFNR). Used in aviation for aircraft modification projects, route launch campaigns, and MRO work orders.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ledgerCode rdf:type rdf:Property ;
    rdfs:label 'Ledger Code' ;
    rdfs:comment 'SAP parallel ledger identifier (BKPF-RLDNR) supporting dual IFRS and local GAAP reporting. Common values: \'0L\' = leading ledger (IFRS), \'N1\' = local GAAP ledger. Enables simultaneous reporting under multiple accounting standards required for multinational airline operations.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineItemNumber rdf:type rdf:Property ;
    rdfs:label 'Line Item Number' ;
    rdfs:comment 'Sequential line item number within the accounting document (BSEG-BUZEI in SAP). Identifies the specific debit or credit posting line within the journal entry. Combined with document_number and company_code forms the natural key of a GL line item.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:postingStatus rdf:type rdf:Property ;
    rdfs:label 'Posting Status' ;
    rdfs:comment 'Current lifecycle status of the accounting document. \'posted\' = active GL entry; \'reversed\' = entry has been reversed by a reversal document; \'parked\' = document saved but not yet posted; \'held\' = incomplete document; \'cleared\' = open item has been cleared against a payment or offsetting entry.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingText rdf:type rdf:Property ;
    rdfs:label 'Posting Text' ;
    rdfs:comment 'Free-text description of the individual line item posting (BSEG-SGTXT). Provides narrative context for the accounting entry, e.g., \'Jet fuel uplift JFK-LHR 15-Jan\', \'IFRS 16 lease liability accrual Q1\', \'Interline settlement IATA BSP Jan\'.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingUser rdf:type rdf:Property ;
    rdfs:label 'Posting User' ;
    rdfs:comment 'SAP user ID of the person or system process that created the accounting document (BKPF-USNAM). Essential for SOX audit trail, segregation of duties controls, and financial fraud detection. May be a batch job ID for automated postings.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCentre rdf:type rdf:Property ;
    rdfs:label 'Profit Centre' ;
    rdfs:comment 'SAP Controlling profit centre representing a business unit responsible for its own profitability (BSEG-PRCTR / CEPC-PRCTR). Used for route-level, hub-level, or business-segment P&L reporting. Supports RASK and yield analysis by profit centre.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Document Number' ;
    rdfs:comment 'External reference number from the source document (BKPF-XBLNR), such as a vendor invoice number, AWB (Air Waybill) number, PNR, interline billing statement number, or BSP settlement reference. Enables traceability from the GL back to the originating business transaction.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reversal Document Number' ;
    rdfs:comment 'The document number of the corresponding reversal or reversed document (BKPF-STBLG). Populated when reversal_indicator is true, enabling bidirectional traceability between original and reversal entries for audit and compliance purposes.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalIndicator rdf:type rdf:Property ;
    rdfs:label 'Reversal Indicator' ;
    rdfs:comment 'Flag indicating whether this document is a reversal of a previously posted document (BKPF-STBLG is populated). True = this is a reversal document. Supports audit trail integrity and period-end close accuracy.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tradingPartnerCompanyCode rdf:type rdf:Property ;
    rdfs:label 'Trading Partner Company Code' ;
    rdfs:comment 'Company code of the intercompany trading partner for intercompany postings (BSEG-VBUND). Populated when intercompany_indicator is true. Used for automated intercompany elimination during group financial consolidation.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collateralCurrency rdf:type rdf:Property ;
    rdfs:label 'Collateral Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which collateral is posted. Null if no collateral posted.' ;
    rdfs:domain ind:HedgeContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collateralPostedAmount rdf:type rdf:Property ;
    rdfs:label 'Collateral Posted Amount' ;
    rdfs:comment 'Amount of cash or securities posted as collateral to the counterparty under Credit Support Annex (CSA) terms. Null if no collateral arrangement exists.' ;
    rdfs:domain ind:HedgeContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Number' ;
    rdfs:comment 'Externally-known unique business identifier for the hedge contract, used in treasury operations and external reporting.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractStatus rdf:type rdf:Property ;
    rdfs:label 'Contract Status' ;
    rdfs:comment 'Current lifecycle status of the hedge contract, indicating whether it is in force, expired, or terminated early.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterpartyIdentifier rdf:type rdf:Property ;
    rdfs:label 'Counterparty Identifier' ;
    rdfs:comment 'Unique identifier for the counterparty, typically LEI (Legal Entity Identifier) or internal counterparty code.' ;
    rdfs:domain ind:HedgeContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterpartyName rdf:type rdf:Property ;
    rdfs:label 'Counterparty Name' ;
    rdfs:comment 'Legal name of the financial institution or counterparty with whom the hedge contract is executed.' ;
    rdfs:domain ind:HedgeContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cumulativeGainLoss rdf:type rdf:Property ;
    rdfs:label 'Cumulative Gain Loss' ;
    rdfs:comment 'Cumulative realized and unrealized gain or loss on the hedge contract since inception, used for hedge accounting reserve calculations.' ;
    rdfs:domain ind:HedgeContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currencyPair rdf:type rdf:Property ;
    rdfs:label 'Currency Pair' ;
    rdfs:comment 'ISO 4217 currency pair for foreign exchange hedges (e.g., USD/EUR, GBP/USD). Null for non-FX hedges.' ;
    rdfs:domain ind:HedgeContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentationCompleteFlag rdf:type rdf:Property ;
    rdfs:label 'Documentation Complete Flag' ;
    rdfs:comment 'Indicates whether all required IFRS 9 hedge accounting documentation (hedge designation memo, effectiveness testing methodology) has been completed and approved.' ;
    rdfs:domain ind:HedgeContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:effectivenessTestDate rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Test Date' ;
    rdfs:comment 'Date on which the most recent hedge effectiveness test was performed.' ;
    rdfs:domain ind:HedgeContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fairValueAmount rdf:type rdf:Property ;
    rdfs:label 'Fair Value Amount' ;
    rdfs:comment 'Current fair value (mark-to-market) of the hedge instrument as of the last valuation date, used for balance sheet reporting.' ;
    rdfs:domain ind:HedgeContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fairValueCurrency rdf:type rdf:Property ;
    rdfs:label 'Fair Value Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the fair value is denominated.' ;
    rdfs:domain ind:HedgeContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fairValueDate rdf:type rdf:Property ;
    rdfs:label 'Fair Value Date' ;
    rdfs:comment 'Date as of which the fair value was calculated, typically month-end or quarter-end for financial reporting.' ;
    rdfs:domain ind:HedgeContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:hedgeDesignation rdf:type rdf:Property ;
    rdfs:label 'Hedge Designation' ;
    rdfs:comment 'Formal hedge accounting designation under IFRS 9, determining how gains and losses are recognized in financial statements.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hedgeEffectivenessTestResult rdf:type rdf:Property ;
    rdfs:label 'Hedge Effectiveness Test Result' ;
    rdfs:comment 'Result of the most recent prospective or retrospective hedge effectiveness test under IFRS 9, determining continued eligibility for hedge accounting.' ;
    rdfs:domain ind:HedgeContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hedgeRatio rdf:type rdf:Property ;
    rdfs:label 'Hedge Ratio' ;
    rdfs:comment 'Ratio of the hedging instrument quantity to the hedged item quantity, used in hedge effectiveness calculations (e.g., 1.0000 for perfect hedge).' ;
    rdfs:domain ind:HedgeContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hedgedItemDescription rdf:type rdf:Property ;
    rdfs:label 'Hedged Item Description' ;
    rdfs:comment 'Textual description of the specific forecasted transaction or recognized asset/liability being hedged (e.g., Q3 2024 jet fuel purchases for transatlantic routes).' ;
    rdfs:domain ind:HedgeContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instrumentType rdf:type rdf:Property ;
    rdfs:label 'Instrument Type' ;
    rdfs:comment 'Type of financial derivative instrument used for hedging. Determines the contractual structure and settlement mechanism.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isdaMasterAgreementFlag rdf:type rdf:Property ;
    rdfs:label 'Isda Master Agreement Flag' ;
    rdfs:comment 'Indicates whether this hedge contract is governed by an ISDA Master Agreement with the counterparty.' ;
    rdfs:domain ind:HedgeContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maturityDate rdf:type rdf:Property ;
    rdfs:label 'Maturity Date' ;
    rdfs:comment 'Date on which the hedge contract expires or settles, marking the end of the hedging relationship.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:notionalAmount rdf:type rdf:Property ;
    rdfs:label 'Notional Amount' ;
    rdfs:comment 'Principal amount or volume of the underlying exposure being hedged (e.g., barrels of fuel, currency units, interest principal).' ;
    rdfs:domain ind:HedgeContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:notionalUnit rdf:type rdf:Property ;
    rdfs:label 'Notional Unit' ;
    rdfs:comment 'Unit of measure for the notional amount (barrels for fuel, currency code for FX, basis points for interest rate). [ENUM-REF-CANDIDATE: barrels|gallons|metric_tons|usd|eur|gbp|basis_points — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:HedgeContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:premiumCurrency rdf:type rdf:Property ;
    rdfs:label 'Premium Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the premium was paid.' ;
    rdfs:domain ind:HedgeContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:premiumPaid rdf:type rdf:Property ;
    rdfs:label 'Premium Paid' ;
    rdfs:comment 'Upfront premium paid to acquire the hedge instrument (primarily for options and collars). Zero for forwards and swaps with no upfront cost.' ;
    rdfs:domain ind:HedgeContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:strikePrice rdf:type rdf:Property ;
    rdfs:label 'Strike Price' ;
    rdfs:comment 'Agreed price or rate at which the hedge instrument can be exercised (for options) or settled (for forwards/swaps). Null for instruments without a fixed strike.' ;
    rdfs:domain ind:HedgeContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tradeDate rdf:type rdf:Property ;
    rdfs:label 'Trade Date' ;
    rdfs:comment 'Date on which the hedge contract was executed and agreed between the airline and counterparty.' ;
    rdfs:domain ind:HedgeContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:underlyingCommodityCode rdf:type rdf:Property ;
    rdfs:label 'Underlying Commodity Code' ;
    rdfs:comment 'Standardized code for the specific commodity being hedged (e.g., JET for jet fuel, BRENT for Brent crude). Null for non-commodity hedges.' ;
    rdfs:domain ind:HedgeContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:underlyingType rdf:type rdf:Property ;
    rdfs:label 'Underlying Type' ;
    rdfs:comment 'Category of the underlying asset or rate being hedged (fuel commodity, currency pair, interest rate benchmark, or carbon allowance).' ;
    rdfs:domain ind:HedgeContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Billing Document Number' ;
    rdfs:comment 'Unique externally-known billing document number or reference assigned to this interline billing transaction. Used for reconciliation and audit trail.' ;
    rdfs:domain ind:InterlineBilling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Billing Period End Date' ;
    rdfs:comment 'End date of the billing period covered by this interline billing record. Defines the close of the settlement window.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Billing Period Start Date' ;
    rdfs:comment 'Start date of the billing period covered by this interline billing record. Defines the beginning of the settlement window.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingStatus rdf:type rdf:Property ;
    rdfs:label 'Billing Status' ;
    rdfs:comment 'Current lifecycle status of the interline billing record. Tracks the billing through submission, acceptance, dispute resolution, and final settlement stages.' ;
    rdfs:domain ind:InterlineBilling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingType rdf:type rdf:Property ;
    rdfs:label 'Billing Type' ;
    rdfs:comment 'Type of interline billing transaction. Categorizes the nature of the settlement: passenger ticketing, cargo waybill, ancillary services, or billing adjustment.' ;
    rdfs:domain ind:InterlineBilling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationAirportIataCode rdf:type rdf:Property ;
    rdfs:label 'Destination Airport Iata Code' ;
    rdfs:comment 'Three-letter IATA airport code for the destination of the interline segment. Identifies the arrival point for billing allocation.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossBillingAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Billing Amount' ;
    rdfs:comment 'Total gross amount billed before any adjustments, fees, or commissions. Base amount for the interline transaction.' ;
    rdfs:domain ind:InterlineBilling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netSettlementAmount rdf:type rdf:Property ;
    rdfs:label 'Net Settlement Amount' ;
    rdfs:comment 'Final net amount to be settled between airlines after all adjustments, commissions, and taxes. This is the actual payable or receivable amount.' ;
    rdfs:domain ind:InterlineBilling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originAirportIataCode rdf:type rdf:Property ;
    rdfs:label 'Origin Airport Iata Code' ;
    rdfs:comment 'Three-letter IATA airport code for the origin of the interline segment. Identifies the departure point for billing allocation.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Original Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code of the original transaction before currency conversion for settlement. Used for reconciliation and audit purposes.' ;
    rdfs:domain ind:InterlineBilling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerAirlineIataCode rdf:type rdf:Property ;
    rdfs:label 'Partner Airline Iata Code' ;
    rdfs:comment 'Two-character IATA airline designator code of the partner carrier involved in the interline agreement. Identifies the counterparty airline for billing settlement.' ;
    rdfs:domain ind:InterlineBilling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prorationAmount rdf:type rdf:Property ;
    rdfs:label 'Proration Amount' ;
    rdfs:comment 'Revenue or cost amount allocated to the partner airline based on interline proration rules. Represents the partner\'s share of the total ticket or waybill value.' ;
    rdfs:domain ind:InterlineBilling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementDueDate rdf:type rdf:Property ;
    rdfs:label 'Settlement Due Date' ;
    rdfs:comment 'Date by which the interline settlement payment is due. Defines the payment deadline per IATA settlement cycle rules.' ;
    rdfs:domain ind:InterlineBilling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transactionType rdf:type rdf:Property ;
    rdfs:label 'Transaction Type' ;
    rdfs:comment 'Specific transaction type within the billing record. Indicates whether this is a debit memo (amount owed to partner), credit memo (amount owed by partner), proration allocation, or final settlement.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:journalEntryId rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Id' ;
    rdfs:comment 'Unique surrogate identifier for each journal entry record in the general ledger. Primary key for the journal_entry data product in the finance domain silver layer.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryJournalCustomerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Journal Customer Employee Id' ;
    rdfs:comment 'Reference to the customer master record for accounts receivable postings (e.g., interline billing receivables, corporate travel account receivables, cargo customer invoices). Populated for document types involving customer transactions.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accountType rdf:type rdf:Property ;
    rdfs:label 'Account Type' ;
    rdfs:comment 'SAP FI account type indicating the subledger category for this posting: A=Asset, D=Customer (Debtor/Accounts Receivable), K=Vendor (Creditor/Accounts Payable), M=Material, S=General Ledger. Determines which subledger is updated.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amountDocumentCurrency rdf:type rdf:Property ;
    rdfs:label 'Amount Document Currency' ;
    rdfs:comment 'The transaction amount in the original document currency (transaction currency). May differ from amount_local_currency when the source document is in a foreign currency, such as interline billing settlements in USD or EUR.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amountLocalCurrency rdf:type rdf:Property ;
    rdfs:label 'Amount Local Currency' ;
    rdfs:comment 'The gross transaction amount in the company code\'s local (functional) currency. This is the primary monetary value for statutory reporting and forms part of the MONETARY_TRIPLET for this transaction.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:businessArea rdf:type rdf:Property ;
    rdfs:label 'Business Area' ;
    rdfs:comment 'SAP FI business area code representing an organizational unit for which an internal balance sheet and P&L can be produced (e.g., passenger operations, cargo, MRO, loyalty). Supports segment reporting under IFRS 8.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Document Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code of the original document currency (e.g., USD, EUR, GBP). Critical for interline billing, BSP settlements, and multi-currency treasury operations.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Entry Timestamp' ;
    rdfs:comment 'The precise date and time when this journal entry record was created in the SAP S/4HANA system. Serves as the RECORD_AUDIT_CREATED timestamp for audit trail and data lineage purposes.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:internalOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Internal Order Number' ;
    rdfs:comment 'SAP CO internal order number used to collect costs for specific projects or events (e.g., aircraft heavy maintenance C-check, airport terminal renovation, fleet acquisition project). Enables project-level cost tracking.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineItemText rdf:type rdf:Property ;
    rdfs:label 'Line Item Text' ;
    rdfs:comment 'Free-text description at the individual line item level providing specific context for this debit or credit posting (e.g., \'Jet-A fuel uplift LHR 15-Oct\', \'ACMI wet lease payment\', \'Crew hotel deadhead expense\').' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingKey rdf:type rdf:Property ;
    rdfs:label 'Posting Key' ;
    rdfs:comment 'SAP FI two-digit posting key controlling the account type, debit/credit indicator, and field selection for this line item (e.g., 40=GL Debit, 50=GL Credit, 31=Vendor Credit, 01=Customer Debit). Determines the accounting treatment applied.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterCode rdf:type rdf:Property ;
    rdfs:label 'Profit Center Code' ;
    rdfs:comment 'SAP CO profit center identifying the business segment (e.g., route, hub, cabin class, cargo) responsible for this posting. Supports profitability analysis by route, fleet type, and business unit.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Contract Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Lease contracts (aircraft, facilities, equipment) managed by specific employees require relationship manager tracking for accountability, renewal negotiations, and contract administration per airline ' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assetCategory rdf:type rdf:Property ;
    rdfs:label 'Asset Category' ;
    rdfs:comment 'High-level asset class of the underlying leased asset. Used for IFRS 16 disclosure note groupings (right-of-use asset classes) and fleet planning integration.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetRegistration rdf:type rdf:Property ;
    rdfs:label 'Asset Registration' ;
    rdfs:comment 'ICAO/national civil aviation authority tail number or asset registration identifier for the leased aircraft or engine (e.g., N-number, G-prefix). Null for property leases and spare part pool agreements. Links to fleet planning and MRO systems.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commencementDate rdf:type rdf:Property ;
    rdfs:label 'Commencement Date' ;
    rdfs:comment 'Date on which the lessor makes the underlying asset available for use by the lessee. This is the IFRS 16 commencement date from which the right-of-use (ROU) asset and lease liability are initially recognised on the balance sheet.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractCurrency rdf:type rdf:Property ;
    rdfs:label 'Contract Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which lease payments are denominated (e.g., USD for US Dollar, EUR for Euro). Aircraft leases are predominantly USD-denominated. Drives FX translation to functional currency for IFRS reporting.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountRatePct rdf:type rdf:Property ;
    rdfs:label 'Discount Rate Pct' ;
    rdfs:comment 'Annual discount rate used to calculate the present value of future lease payments. Represents the rate implicit in the lease if readily determinable; otherwise the lessee\'s incremental borrowing rate (IBR) as determined by the treasury function. Stored as a decimal fraction (e.g., 0.045000 = 4.5%).' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:functionalCurrency rdf:type rdf:Property ;
    rdfs:label 'Functional Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code of the reporting entity\'s functional currency. Used for translating the lease liability and ROU asset from contract currency to functional currency per IAS 21.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glLeaseLiabilityAccount rdf:type rdf:Property ;
    rdfs:label 'Gl Lease Liability Account' ;
    rdfs:comment 'SAP S/4HANA GL account code for the lease liability balance sheet line. Supports automated posting of opening balance, interest accrual, and principal repayment journal entries.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glRouAssetAccount rdf:type rdf:Property ;
    rdfs:label 'Gl Rou Asset Account' ;
    rdfs:comment 'SAP S/4HANA GL account code for the right-of-use asset balance sheet line. Used for automated journal entry generation for initial recognition, depreciation, and derecognition of the ROU asset.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingLaw rdf:type rdf:Property ;
    rdfs:label 'Governing Law' ;
    rdfs:comment 'Legal jurisdiction whose laws govern the lease contract (e.g., \'English Law\', \'New York Law\', \'Irish Law\'). Relevant for dispute resolution, enforcement, and cross-border lease structuring common in aviation.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ifrs16ExemptionType rdf:type rdf:Property ;
    rdfs:label 'Ifrs16 Exemption Type' ;
    rdfs:comment 'Indicates whether the lease qualifies for a recognition exemption under IFRS 16. \'short_term\' = lease term of 12 months or less at commencement; \'low_value\' = underlying asset value below the entity\'s low-value threshold (typically USD 5,000); \'none\' = full IFRS 16 recognition required.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModificationDate rdf:type rdf:Property ;
    rdfs:label 'Last Modification Date' ;
    rdfs:comment 'Date of the most recent lease modification event (e.g., extension of lease term, change in lease payments, change in scope). Triggers remeasurement of the lease liability at the revised discount rate.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leaseLiabilityOpening rdf:type rdf:Property ;
    rdfs:label 'Lease Liability Opening' ;
    rdfs:comment 'Present value of the lease payments not yet made at the commencement date, discounted at the incremental borrowing rate (IBR) or the rate implicit in the lease. This is the initial recognition amount of the lease liability on the balance sheet.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leaseTermMonths rdf:type rdf:Property ;
    rdfs:label 'Lease Term Months' ;
    rdfs:comment 'Total lease term in whole months as determined under IFRS 16, including the non-cancellable period plus any optional renewal periods that the lessee is reasonably certain to exercise, and excluding optional termination periods the lessee is reasonably certain to exercise.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:leaseType rdf:type rdf:Property ;
    rdfs:label 'Lease Type' ;
    rdfs:comment 'Classification of the lease by asset category and operational arrangement. Dry lease = aircraft without crew; wet lease / ACMI (Aircraft Crew Maintenance Insurance) = aircraft with crew, maintenance, and insurance; engine_lease = standalone engine; spare_part_pool = access agreement for pooled spare parts; property_lease = airport lounges, hangars, office space. Determines IFRS 16 scope and disclosure grouping.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lessorCountryCode rdf:type rdf:Property ;
    rdfs:label 'Lessor Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the lessor\'s registered jurisdiction. Relevant for withholding tax treatment, OECD transfer pricing, and cross-border lease disclosure.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceReserveFlag rdf:type rdf:Property ;
    rdfs:label 'Maintenance Reserve Flag' ;
    rdfs:comment 'Indicates whether the lease contract includes maintenance reserve payments (common in aircraft dry leases). Maintenance reserves are typically excluded from IFRS 16 lease liability measurement and treated as variable lease payments or prepaid maintenance.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:modificationCount rdf:type rdf:Property ;
    rdfs:label 'Modification Count' ;
    rdfs:comment 'Running count of the number of lease modifications processed against this contract since commencement. Each modification triggers remeasurement of the lease liability and ROU asset per IFRS 16 paragraphs 44–46. Supports audit trail and modification history tracking.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paymentFrequency rdf:type rdf:Property ;
    rdfs:label 'Payment Frequency' ;
    rdfs:comment 'Frequency at which fixed lease payments are contractually due. Determines the period length used in the amortisation schedule and GL journal entry generation cadence.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentInAdvanceFlag rdf:type rdf:Property ;
    rdfs:label 'Payment In Advance Flag' ;
    rdfs:comment 'Indicates whether lease payments are due at the beginning (True) or end (False) of each payment period. Affects the timing of interest expense accrual and principal repayment in the IFRS 16 amortisation schedule.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:periodicLeasePayment rdf:type rdf:Property ;
    rdfs:label 'Periodic Lease Payment' ;
    rdfs:comment 'Fixed lease payment amount due per payment period (monthly, quarterly, or annually as defined by payment_frequency). Excludes variable lease payments not dependent on an index or rate. Used as the primary input to the amortisation schedule.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:purchaseOptionFlag rdf:type rdf:Property ;
    rdfs:label 'Purchase Option Flag' ;
    rdfs:comment 'Indicates whether the lease contract includes an option for the lessee to purchase the underlying asset. If the lessee is reasonably certain to exercise the purchase option, the option price is included in the lease liability measurement.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:purchaseOptionPrice rdf:type rdf:Property ;
    rdfs:label 'Purchase Option Price' ;
    rdfs:comment 'Contractual price at which the lessee may purchase the underlying asset if the purchase option is exercised. Included in the lease liability present value calculation when the lessee is reasonably certain to exercise. Null when purchase_option_flag is False.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewalOptionFlag rdf:type rdf:Property ;
    rdfs:label 'Renewal Option Flag' ;
    rdfs:comment 'Indicates whether the lease contract contains one or more renewal options exercisable by the lessee. When True, renewal_option_reasonably_certain_flag must be assessed for IFRS 16 lease term determination.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalOptionReasonablyCertain rdf:type rdf:Property ;
    rdfs:label 'Renewal Option Reasonably Certain' ;
    rdfs:comment 'Management\'s assessment of whether the lessee is reasonably certain to exercise the renewal option. When True, the optional renewal period is included in the IFRS 16 lease term and the lease liability is remeasured accordingly.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:residualValueGuarantee rdf:type rdf:Property ;
    rdfs:label 'Residual Value Guarantee' ;
    rdfs:comment 'Amount of any residual value guarantee provided by the lessee to the lessor, representing the lessee\'s exposure to the residual value of the leased asset at lease end. Included in the IFRS 16 lease liability measurement as a lease payment.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rouAssetValue rdf:type rdf:Property ;
    rdfs:label 'Rou Asset Value' ;
    rdfs:comment 'Initial carrying amount of the right-of-use (ROU) asset recognised on the balance sheet at the lease commencement date, comprising the initial lease liability measurement plus any initial direct costs, prepaid lease payments, and estimated dismantling costs, less any lease incentives received. Expressed in the contract currency.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:securityDepositAmount rdf:type rdf:Property ;
    rdfs:label 'Security Deposit Amount' ;
    rdfs:comment 'Cash security deposit paid to the lessor at lease commencement, refundable at lease expiry subject to asset return conditions. Classified as a financial asset (receivable) on the lessee\'s balance sheet, separate from the lease liability.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:terminationOptionFlag rdf:type rdf:Property ;
    rdfs:label 'Termination Option Flag' ;
    rdfs:comment 'Indicates whether the lease contract contains a termination option exercisable by the lessee before the contractual expiry date. Affects IFRS 16 lease term and liability measurement.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:terminationOptionReasonablyCertain rdf:type rdf:Property ;
    rdfs:label 'Termination Option Reasonably Certain' ;
    rdfs:comment 'Management\'s assessment of whether the lessee is reasonably certain to exercise the termination option. When True, the lease term is shortened to the termination date and the liability is remeasured.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:variablePaymentTerms rdf:type rdf:Property ;
    rdfs:label 'Variable Payment Terms' ;
    rdfs:comment 'Free-text description of any variable lease payment clauses, including index-linked escalation (e.g., CPI, LIBOR/SOFR), utilisation-based payments (e.g., per flight hour for ACMI), or maintenance reserve adjustments. Required for IFRS 16 disclosure notes.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaseLiabilityScheduleId rdf:type rdf:Property ;
    rdfs:label 'Lease Liability Schedule Id' ;
    rdfs:comment 'Unique surrogate identifier for each lease liability amortisation schedule record in the IFRS 16 ledger. Primary key for this table.' ;
    rdfs:domain ind:LeaseLiabilitySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:closingBalance rdf:type rdf:Property ;
    rdfs:label 'Closing Balance' ;
    rdfs:comment 'Carrying amount of the lease liability at the end of the period (opening balance + interest expense − principal repayment). Becomes the next period\'s opening balance. Key IFRS 16 balance sheet figure.' ;
    rdfs:domain ind:LeaseLiabilitySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discountRate rdf:type rdf:Property ;
    rdfs:label 'Discount Rate' ;
    rdfs:comment 'The interest rate used to discount future lease payments to present value, typically the lessee\'s incremental borrowing rate (IBR) or the implicit rate in the lease if determinable. Expressed as an annual decimal (e.g., 0.045 = 4.5%).' ;
    rdfs:domain ind:LeaseLiabilitySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:extensionOptionFlag rdf:type rdf:Property ;
    rdfs:label 'Extension Option Flag' ;
    rdfs:comment 'Indicates whether the lease term used in the liability calculation includes one or more extension option periods that management has assessed as reasonably certain to be exercised.' ;
    rdfs:domain ind:LeaseLiabilitySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:functionalCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Functional Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 code for the airline\'s functional currency used for consolidated financial reporting. Enables FX translation of foreign-currency lease liabilities for IFRS disclosure.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initialRecognitionAmount rdf:type rdf:Property ;
    rdfs:label 'Initial Recognition Amount' ;
    rdfs:comment 'Present value of future lease payments at the commencement date, representing the lease liability recognised on the balance sheet at inception. Equals the initial ROU asset cost (before initial direct costs and lease incentives).' ;
    rdfs:domain ind:LeaseLiabilitySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interestExpense rdf:type rdf:Property ;
    rdfs:label 'Interest Expense' ;
    rdfs:comment 'Finance charge accrued during the period calculated by applying the incremental borrowing rate (or implicit rate) to the opening lease liability balance. Posted to the P&L interest expense account.' ;
    rdfs:domain ind:LeaseLiabilitySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:journalEntryDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Document Number' ;
    rdfs:comment 'SAP S/4HANA FI accounting document number assigned when the IFRS 16 journal entry is posted. Provides a direct audit trail from the amortisation schedule row to the posted ledger document.' ;
    rdfs:domain ind:LeaseLiabilitySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:journalEntryPostedFlag rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Posted Flag' ;
    rdfs:comment 'Indicates whether the automated IFRS 16 journal entries (interest accrual and principal repayment) for this period have been successfully posted to the SAP S/4HANA general ledger. Supports period-close control and reconciliation.' ;
    rdfs:domain ind:LeaseLiabilitySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leasePayment rdf:type rdf:Property ;
    rdfs:label 'Lease Payment' ;
    rdfs:comment 'Total cash payment made to the lessor during the period, comprising both the principal repayment and the interest component. Corresponds to the cash outflow in the statement of cash flows.' ;
    rdfs:domain ind:LeaseLiabilitySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leaseStatus rdf:type rdf:Property ;
    rdfs:label 'Lease Status' ;
    rdfs:comment 'Current lifecycle state of the lease contract as of the period. Drives whether amortisation rows continue to be generated and whether remeasurement events have occurred.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lessorName rdf:type rdf:Property ;
    rdfs:label 'Lessor Name' ;
    rdfs:comment 'Legal name of the lessor (aircraft leasing company, property owner, or equipment provider) from whom the asset is leased. Common aviation lessors include AerCap, Air Lease Corporation, SMBC Aviation Capital.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lowValueAssetFlag rdf:type rdf:Property ;
    rdfs:label 'Low Value Asset Flag' ;
    rdfs:comment 'Indicates whether the lease qualifies for the IFRS 16 low-value asset exemption (underlying asset value when new is approximately USD 5,000 or below). When true, payments are expensed and no liability is recognised.' ;
    rdfs:domain ind:LeaseLiabilitySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:openingBalance rdf:type rdf:Property ;
    rdfs:label 'Opening Balance' ;
    rdfs:comment 'Carrying amount of the lease liability at the beginning of the period before any payments or interest accrual. Equals the prior period\'s closing balance. Core IFRS 16 disclosure figure.' ;
    rdfs:domain ind:LeaseLiabilitySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:periodEndDate rdf:type rdf:Property ;
    rdfs:label 'Period End Date' ;
    rdfs:comment 'Last calendar date of the amortisation period covered by this schedule row. Typically the last day of the accounting month or quarter.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodSequence rdf:type rdf:Property ;
    rdfs:label 'Period Sequence' ;
    rdfs:comment 'Sequential integer identifying the ordinal position of this amortisation period within the full lease term (e.g., 1 = first period, 24 = twenty-fourth period). Enables ordered traversal of the schedule.' ;
    rdfs:domain ind:LeaseLiabilitySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:periodStartDate rdf:type rdf:Property ;
    rdfs:label 'Period Start Date' ;
    rdfs:comment 'First calendar date of the amortisation period covered by this schedule row. Aligns with the accounting period open date in the general ledger.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:principalRepayment rdf:type rdf:Property ;
    rdfs:label 'Principal Repayment' ;
    rdfs:comment 'Portion of the lease payment that reduces the lease liability principal (lease payment minus interest expense). Classified as a financing cash outflow under IAS 7.' ;
    rdfs:domain ind:LeaseLiabilitySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remeasurementAmount rdf:type rdf:Property ;
    rdfs:label 'Remeasurement Amount' ;
    rdfs:comment 'Adjustment to the lease liability arising from a remeasurement event (e.g., lease modification, change in extension option assessment, change in index/rate). Positive values increase the liability; negative values decrease it.' ;
    rdfs:domain ind:LeaseLiabilitySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remeasurementDate rdf:type rdf:Property ;
    rdfs:label 'Remeasurement Date' ;
    rdfs:comment 'Date on which the lease liability was remeasured due to a triggering event such as a lease modification, reassessment of extension option, or change in variable lease payments linked to an index. Null if no remeasurement occurred in this period.' ;
    rdfs:domain ind:LeaseLiabilitySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remeasurementReason rdf:type rdf:Property ;
    rdfs:label 'Remeasurement Reason' ;
    rdfs:comment 'Reason code explaining why the lease liability was remeasured in this period. Required for IFRS 16 disclosure notes and auditor reconciliation. Null if no remeasurement occurred.' ;
    rdfs:domain ind:LeaseLiabilitySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortTermLeaseFlag rdf:type rdf:Property ;
    rdfs:label 'Short Term Lease Flag' ;
    rdfs:comment 'Indicates whether the lease qualifies for the IFRS 16 short-term lease exemption (lease term of 12 months or less at commencement). When true, payments are expensed on a straight-line basis and no liability is recognised.' ;
    rdfs:domain ind:LeaseLiabilitySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:variableLeasePayment rdf:type rdf:Property ;
    rdfs:label 'Variable Lease Payment' ;
    rdfs:comment 'Lease payments that depend on an index or rate (e.g., CPI-linked rent escalations) included in the lease liability measurement. Excludes purely variable payments not based on an index or rate, which are expensed as incurred.' ;
    rdfs:domain ind:LeaseLiabilitySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxTransactionId rdf:type rdf:Property ;
    rdfs:label 'Tax Transaction Id' ;
    rdfs:comment 'Unique surrogate identifier for each tax posting record in the finance domain. Primary key for the tax_transaction data product.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TaxTransaction .

ind:profileId rdf:type rdf:Property ;
    rdfs:label 'Profile Id' ;
    rdfs:comment 'Reference to the customer or passenger party associated with this tax transaction, applicable for output VAT/GST on ancillary services, passenger facility charges, and airport taxes.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Profile .

ind:taxEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tax Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Tax transactions related to employee benefits, payroll taxes, expatriate tax equalization require employee linkage for compliance reporting, tax certificate generation, and employee tax statement prep' ;
    rdfs:domain ind:TaxTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:filingReference rdf:type rdf:Property ;
    rdfs:label 'Filing Reference' ;
    rdfs:comment 'The reference number assigned by the tax authority or internal tax filing system when this tax transaction is included in a periodic tax return or remittance filing (e.g., VAT return reference, PFC quarterly report number, WHT certificate number).' ;
    rdfs:domain ind:TaxTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRecoverable rdf:type rdf:Property ;
    rdfs:label 'Is Recoverable' ;
    rdfs:comment 'Indicates whether this input tax amount is recoverable (reclaimable) from the tax authority as a credit against output tax liability. True for recoverable input VAT/GST; False for irrecoverable taxes such as non-deductible VAT on entertainment or blocked input tax.' ;
    rdfs:domain ind:TaxTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:localCurrencyTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Local Currency Tax Amount' ;
    rdfs:comment 'The tax amount translated into the company code\'s local (functional) currency using the exchange rate at posting date. Required for statutory financial reporting and local tax authority filings.' ;
    rdfs:domain ind:TaxTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reversalReasonCode rdf:type rdf:Property ;
    rdfs:label 'Reversal Reason Code' ;
    rdfs:comment 'SAP FI reversal reason code explaining why this tax posting was reversed (e.g., data entry error, duplicate posting, credit note issued). Null for non-reversed transactions.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Source Document Reference' ;
    rdfs:comment 'The reference number of the originating source document (e.g., vendor invoice number, AWB number for cargo customs, PNR for passenger-related taxes, BSP billing reference). Enables traceability from tax posting back to the originating business transaction.' ;
    rdfs:domain ind:TaxTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceDocumentType rdf:type rdf:Property ;
    rdfs:label 'Source Document Type' ;
    rdfs:comment 'Type of the originating business document that generated this tax posting. INVOICE=vendor or customer invoice; CREDIT_NOTE=credit memo; PAYMENT=payment document; JOURNAL=manual journal entry; CUSTOMS_DECL=customs declaration for cargo; PFC_REPORT=Passenger Facility Charge quarterly report; WHT_CERT=withholding tax certificate. [ENUM-REF-CANDIDATE: INVOICE|CREDIT_NOTE|PAYMENT|JOURNAL|CUSTOMS_DECL|PFC_REPORT|WHT_CERT — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TaxTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Tax Authority Name' ;
    rdfs:comment 'Name of the government or regulatory body to which this tax is remitted (e.g., \'IRS\', \'HMRC\', \'Bundeszentralamt für Steuern\', \'FAA - PFC\'). Required for tax filing and regulatory reporting.' ;
    rdfs:domain ind:TaxTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxDirection rdf:type rdf:Property ;
    rdfs:label 'Tax Direction' ;
    rdfs:comment 'Indicates whether this is an input tax (recoverable tax paid on purchases/vendor invoices) or output tax (tax collected from customers on sales of ancillary services and tickets). Drives VAT/GST net settlement calculation.' ;
    rdfs:domain ind:TaxTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxJurisdictionName rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction Name' ;
    rdfs:comment 'Human-readable name of the tax jurisdiction (e.g., \'United States Federal\', \'Germany VAT\', \'New York State\', \'London Heathrow Airport\'). Supports tax reporting and audit documentation.' ;
    rdfs:domain ind:TaxTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxPeriod rdf:type rdf:Property ;
    rdfs:label 'Tax Period' ;
    rdfs:comment 'The fiscal tax reporting period in YYYY-MM format to which this tax transaction belongs. Used for VAT/GST return filing, withholding tax remittance, and corporate income tax provision reporting.' ;
    rdfs:domain ind:TaxTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxRate rdf:type rdf:Property ;
    rdfs:label 'Tax Rate' ;
    rdfs:comment 'The applicable tax rate as a percentage (e.g., 20.0000 for 20% VAT, 7.5000 for 7.5% WHT). Sourced from the tax code configuration in SAP FI-TX and validated against jurisdiction-specific statutory rates.' ;
    rdfs:domain ind:TaxTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxReturnPeriod rdf:type rdf:Property ;
    rdfs:label 'Tax Return Period' ;
    rdfs:comment 'The period identifier for the tax return in which this transaction is reported to the tax authority. May be monthly (YYYY-MM) or quarterly (YYYY-Q1 through YYYY-Q4) depending on jurisdiction requirements.' ;
    rdfs:domain ind:TaxTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxType rdf:type rdf:Property ;
    rdfs:label 'Tax Type' ;
    rdfs:comment 'Classification of the tax category applicable to this transaction. VAT=Value Added Tax, GST=Goods and Services Tax, WHT=Withholding Tax, PFC=Passenger Facility Charge, AIRPORT_TAX=Airport-levied tax, CORP_INCOME_TAX=Corporate Income Tax provision, EXCISE=Fuel/aviation excise duty, CUSTOMS=Import/export customs duty on cargo. [ENUM-REF-CANDIDATE: VAT|GST|WHT|PFC|AIRPORT_TAX|CORP_INCOME_TAX|EXCISE|CUSTOMS — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxableBaseAmount rdf:type rdf:Property ;
    rdfs:label 'Taxable Base Amount' ;
    rdfs:comment 'The gross monetary amount on which the tax is calculated, expressed in the transaction currency. For VAT/GST this is the net invoice value; for PFC it is the per-passenger charge base; for WHT it is the gross vendor payment.' ;
    rdfs:domain ind:TaxTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:treasuryPositionId rdf:type rdf:Property ;
    rdfs:label 'Treasury Position Id' ;
    rdfs:comment 'Unique surrogate identifier for each treasury cash and liquidity position record in the silver layer lakehouse. Primary key for this data product.' ;
    rdfs:domain ind:TreasuryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cashPoolId rdf:type rdf:Property ;
    rdfs:label 'Cash Pool Id' ;
    rdfs:comment 'Identifier of the notional or physical cash pool to which this bank account belongs. Supports zero-balance sweeping, notional pooling, and group-level liquidity optimisation across legal entities.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CashPool .

ind:treasuryOfficerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Treasury Officer Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Treasury positions managed by specific treasury officers require accountability tracking for cash management, investment decisions, and regulatory compliance (SOX, internal controls) per airline treas' ;
    rdfs:domain ind:TreasuryPosition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:balanceAmount rdf:type rdf:Property ;
    rdfs:label 'Balance Amount' ;
    rdfs:comment 'The gross cash or investment balance in the transaction currency for this position record. Positive values represent assets/inflows; negative values represent liabilities/outflows or overdraft positions. Core monetary field for daily cash management.' ;
    rdfs:domain ind:TreasuryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:balanceAmountUsd rdf:type rdf:Property ;
    rdfs:label 'Balance Amount Usd' ;
    rdfs:comment 'The balance amount translated to US Dollars (USD) using the applicable FX rate on the position date. Used for consolidated group-level cash reporting, CASK analysis, and DOT financial reporting in USD.' ;
    rdfs:domain ind:TreasuryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:balanceType rdf:type rdf:Property ;
    rdfs:label 'Balance Type' ;
    rdfs:comment 'Classifies the nature of the balance recorded: \'actual\' (confirmed bank balance), \'forecast\' (projected inflow/outflow), \'committed\' (contractually obligated but not yet settled), \'projected\' (model-driven estimate), \'opening\' (start-of-day balance), \'closing\' (end-of-day balance). Supports daily cash management and IROP contingency liquidity planning.' ;
    rdfs:domain ind:TreasuryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankAccountIban rdf:type rdf:Property ;
    rdfs:label 'Bank Account Iban' ;
    rdfs:comment 'The International Bank Account Number (IBAN) for the bank account associated with this position, where applicable (primarily European and SEPA-zone accounts). Classified as confidential financial data.' ;
    rdfs:domain ind:TreasuryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankAccountName rdf:type rdf:Property ;
    rdfs:label 'Bank Account Name' ;
    rdfs:comment 'The descriptive name of the bank account as registered with the counterparty bank (e.g., \'Airlines Operating Account USD - JPMorgan NYC\'). Used for human-readable identification in cash management dashboards.' ;
    rdfs:domain ind:TreasuryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Bank Account Number' ;
    rdfs:comment 'The bank account number associated with this treasury position. Classified as confidential financial data. Used for bank account reconciliation and cash pooling identification.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankStatementReference rdf:type rdf:Property ;
    rdfs:label 'Bank Statement Reference' ;
    rdfs:comment 'The bank-assigned statement or transaction reference number from the SWIFT MT940 or ISO 20022 camt.053 bank statement. Used for bank account reconciliation matching in SAP S/4HANA FI-BL.' ;
    rdfs:domain ind:TreasuryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bspSettlementPeriod rdf:type rdf:Property ;
    rdfs:label 'Bsp Settlement Period' ;
    rdfs:comment 'The IATA BSP or ARC settlement period (YYYY-MM format) to which this interline or agency settlement cash flow belongs. Populated only when interline_settlement_flag is True. Used for BSP reconciliation and interline billing dispute resolution.' ;
    rdfs:domain ind:TreasuryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterpartyBankCode rdf:type rdf:Property ;
    rdfs:label 'Counterparty Bank Code' ;
    rdfs:comment 'The BIC (Bank Identifier Code) / SWIFT code of the counterparty bank holding this position. Used for FX exposure reporting, counterparty credit risk monitoring, and debt covenant compliance.' ;
    rdfs:domain ind:TreasuryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:counterpartyBankName rdf:type rdf:Property ;
    rdfs:label 'Counterparty Bank Name' ;
    rdfs:comment 'Full legal name of the counterparty bank or financial institution holding this treasury position (e.g., \'JPMorgan Chase Bank N.A.\'). Used in FX exposure and counterparty risk reports.' ;
    rdfs:domain ind:TreasuryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:covenantBreachFlag rdf:type rdf:Property ;
    rdfs:label 'Covenant Breach Flag' ;
    rdfs:comment 'Indicates whether the current balance_amount is below the covenant_threshold_amount, triggering a potential debt covenant breach. True = covenant breach condition; False = compliant. Drives automated treasury alerts.' ;
    rdfs:domain ind:TreasuryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:covenantThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Covenant Threshold Amount' ;
    rdfs:comment 'The minimum cash or liquidity balance required under debt covenant agreements with lenders, in the transaction currency. Used for debt covenant monitoring and breach early-warning reporting. Null if no covenant applies to this account.' ;
    rdfs:domain ind:TreasuryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:facilityLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Facility Limit Amount' ;
    rdfs:comment 'The total approved credit limit of the bank facility (revolving credit line, overdraft facility) in the transaction currency. Used for bank facility utilisation monitoring and debt covenant compliance reporting.' ;
    rdfs:domain ind:TreasuryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:facilityUtilisedAmount rdf:type rdf:Property ;
    rdfs:label 'Facility Utilised Amount' ;
    rdfs:comment 'The amount currently drawn down against the bank facility limit on the position date. The difference between facility_limit_amount and this field represents available headroom. Used for IROP contingency liquidity planning.' ;
    rdfs:domain ind:TreasuryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fxRateType rdf:type rdf:Property ;
    rdfs:label 'Fx Rate Type' ;
    rdfs:comment 'Identifies the type of FX rate used for translation: \'spot\' (real-time market rate), \'average\' (period average rate), \'closing\' (period-end rate), \'budget\' (planning rate), \'hedge\' (contractual hedge rate). Determines the accounting treatment under IAS 21.' ;
    rdfs:domain ind:TreasuryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interestRate rdf:type rdf:Property ;
    rdfs:label 'Interest Rate' ;
    rdfs:comment 'The annual interest rate (as a decimal, e.g., 0.045 = 4.5%) applicable to this treasury position for time deposits, money market funds, or revolving credit facilities. Used for interest income/expense accrual and yield analysis.' ;
    rdfs:domain ind:TreasuryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:iropReserveFlag rdf:type rdf:Property ;
    rdfs:label 'Irop Reserve Flag' ;
    rdfs:comment 'Indicates whether this treasury position is designated as an IROP (Irregular Operations) contingency liquidity reserve. True = reserved for IROP events (e.g., mass rebooking, hotel accommodation, compensation payouts); False = general operating liquidity.' ;
    rdfs:domain ind:TreasuryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:liquidityCategory rdf:type rdf:Property ;
    rdfs:label 'Liquidity Category' ;
    rdfs:comment 'Classifies the type of liquid asset or instrument: \'cash_and_equivalents\' (demand deposits), \'money_market_fund\', \'commercial_paper\', \'time_deposit\', \'bank_facility\' (revolving credit facility drawdown), \'restricted_cash\' (escrowed or pledged funds). Aligns with IAS 7 cash and cash equivalents classification.' ;
    rdfs:domain ind:TreasuryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionDate rdf:type rdf:Property ;
    rdfs:label 'Position Date' ;
    rdfs:comment 'The business date for which this cash or liquidity position is recorded. Used as the primary time dimension for daily cash management, bank reconciliation, and FX exposure reporting.' ;
    rdfs:domain ind:TreasuryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:positionReference rdf:type rdf:Property ;
    rdfs:label 'Position Reference' ;
    rdfs:comment 'Externally-known business identifier for the treasury position record, sourced from SAP S/4HANA FI-TR or the bank\'s statement reference. Used for reconciliation and audit trail across systems.' ;
    rdfs:domain ind:TreasuryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionStatus rdf:type rdf:Property ;
    rdfs:label 'Position Status' ;
    rdfs:comment 'Current lifecycle state of the treasury position record: \'open\' (pending confirmation), \'confirmed\' (bank-confirmed balance), \'reconciled\' (matched to bank statement), \'disputed\' (discrepancy under investigation), \'closed\' (period-end finalised), \'cancelled\' (voided entry).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valueDate rdf:type rdf:Property ;
    rdfs:label 'Value Date' ;
    rdfs:comment 'The date on which the funds are actually available or settled in the bank account, which may differ from the position date due to clearing cycles or float. Critical for accurate liquidity planning.' ;
    rdfs:domain ind:TreasuryPosition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:baseStationId rdf:type rdf:Property ;
    rdfs:label 'Base Station Id' ;
    rdfs:comment 'Foreign key linking to airport.station. Business justification: Aircraft home base assignment drives crew rostering, maintenance scheduling, and fleet deployment planning. Essential for operational planning and cost allocation. Replaces denormalized base_station_c' ;
    rdfs:domain ind:Aircraft ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Station .

ind:lessorId rdf:type rdf:Property ;
    rdfs:label 'Lessor Id' ;
    rdfs:comment 'Foreign key linking to fleet.lessor. Business justification: aircraft has denormalized lessor_name (STRING) attribute. For leased aircraft, the lessor is a critical operational reference. The lessor product exists in fleet domain as the authoritative master. Th' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lessor .

ind:primaryMaintenanceEngineerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Maintenance Engineer Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Airlines assign dedicated maintenance engineers to each aircraft for regulatory accountability, airworthiness oversight, and maintenance program compliance tracking. Required for CAMO audit trail and ' ;
    rdfs:domain ind:Aircraft ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:airworthinessCategory rdf:type rdf:Property ;
    rdfs:label 'Airworthiness Category' ;
    rdfs:comment 'The category of airworthiness certificate issued. Standard = normal commercial operations; Restricted = limited operations; Limited = special purpose; Experimental = testing; Provisional = pre-certification.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apuManufacturer rdf:type rdf:Property ;
    rdfs:label 'Apu Manufacturer' ;
    rdfs:comment 'The manufacturer of the Auxiliary Power Unit installed on the aircraft (e.g., Honeywell, Pratt & Whitney, Hamilton Sundstrand).' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apuModel rdf:type rdf:Property ;
    rdfs:label 'Apu Model' ;
    rdfs:comment 'The specific model designation of the Auxiliary Power Unit installed on the aircraft.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cabinConfigurationCode rdf:type rdf:Property ;
    rdfs:label 'Cabin Configuration Code' ;
    rdfs:comment 'Internal code identifying the specific cabin layout and seat map configuration installed on this aircraft (e.g., 2-class, 3-class, high-density). Links to detailed seat map reference data.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:catIiiIlsApproved rdf:type rdf:Property ;
    rdfs:label 'Cat Iii Ils Approved' ;
    rdfs:comment 'Indicates whether the aircraft is equipped and certified for CAT III ILS precision approaches in very low visibility conditions (decision height below 100 feet or no decision height).' ;
    rdfs:domain ind:Aircraft ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificateOfAirworthinessNumber rdf:type rdf:Property ;
    rdfs:label 'Certificate Of Airworthiness Number' ;
    rdfs:comment 'The unique certificate number issued by the civil aviation authority certifying that the aircraft meets all safety and airworthiness standards for flight operations.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateOfRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Certificate Of Registration Number' ;
    rdfs:comment 'The unique certificate number issued by the civil aviation authority proving legal registration of the aircraft.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfRegistration rdf:type rdf:Property ;
    rdfs:label 'Country Of Registration' ;
    rdfs:comment 'The three-letter ISO country code of the nation where the aircraft is registered (e.g., USA, GBR, DEU). Determines regulatory jurisdiction.' ;
    rdfs:domain ind:Aircraft ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryDate rdf:type rdf:Property ;
    rdfs:label 'Delivery Date' ;
    rdfs:comment 'The date the aircraft was delivered from the manufacturer to the original customer or the date it entered the current operator\'s fleet.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:etopsCertified rdf:type rdf:Property ;
    rdfs:label 'Etops Certified' ;
    rdfs:comment 'Indicates whether the aircraft holds ETOPS certification allowing extended-range operations over water or remote areas beyond single-engine diversion time limits.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:etopsMinutesRating rdf:type rdf:Property ;
    rdfs:label 'Etops Minutes Rating' ;
    rdfs:comment 'The maximum diversion time in minutes that the aircraft is certified to fly from the nearest suitable airport under ETOPS rules (e.g., 120, 180, 207, 330 minutes). Null if not ETOPS certified.' ;
    rdfs:domain ind:Aircraft ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:melApplicable rdf:type rdf:Property ;
    rdfs:label 'Mel Applicable' ;
    rdfs:comment 'Indicates whether a Minimum Equipment List is applicable to this aircraft, allowing dispatch with certain non-critical equipment inoperative under controlled conditions.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:msn rdf:type rdf:Property ;
    rdfs:label 'Msn' ;
    rdfs:comment 'The unique serial number assigned by the aircraft manufacturer at the time of production. Permanent identifier that never changes regardless of ownership or registration.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noiseChapter rdf:type rdf:Property ;
    rdfs:label 'Noise Chapter' ;
    rdfs:comment 'The ICAO noise certification standard chapter that the aircraft meets. Chapter 4 is the most stringent current standard. Determines airport access and noise restrictions.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipCategory rdf:type rdf:Property ;
    rdfs:label 'Ownership Category' ;
    rdfs:comment 'The legal and financial ownership structure of the aircraft. Owned = airline owns outright; Finance_lease = capital lease with purchase option; Operating_lease = rental without ownership transfer; Dry_lease = aircraft only; Wet_lease_in = aircraft with crew from lessor; ACMI = Aircraft Crew Maintenance Insurance lease.' ;
    rdfs:domain ind:Aircraft ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredOperator rdf:type rdf:Property ;
    rdfs:label 'Registered Operator' ;
    rdfs:comment 'The airline or operator name registered with the civil aviation authority as the entity authorized to operate this aircraft.' ;
    rdfs:domain ind:Aircraft ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredOwner rdf:type rdf:Property ;
    rdfs:label 'Registered Owner' ;
    rdfs:comment 'The legal entity name appearing on the certificate of registration as the registered owner of the aircraft. May differ from operator for leased aircraft.' ;
    rdfs:domain ind:Aircraft ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationAuthority rdf:type rdf:Property ;
    rdfs:label 'Registration Authority' ;
    rdfs:comment 'The name of the civil aviation authority that issued the certificate of registration (e.g., FAA, EASA, CAAC, Transport Canada).' ;
    rdfs:domain ind:Aircraft ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationDate rdf:type rdf:Property ;
    rdfs:label 'Registration Date' ;
    rdfs:comment 'The date the current certificate of registration was issued by the civil aviation authority.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:registrationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Registration Expiry Date' ;
    rdfs:comment 'The expiration date of the current certificate of registration. Aircraft must be re-registered before this date to maintain legal operating authority.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rvsmApproved rdf:type rdf:Property ;
    rdfs:label 'Rvsm Approved' ;
    rdfs:comment 'Indicates whether the aircraft is approved for RVSM operations allowing flight in airspace between FL290 and FL410 with 1,000-foot vertical separation.' ;
    rdfs:domain ind:Aircraft ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:seatingCapacityBusiness rdf:type rdf:Property ;
    rdfs:label 'Seating Capacity Business' ;
    rdfs:comment 'The number of seats in the business class cabin. Zero if aircraft does not have business class configuration.' ;
    rdfs:domain ind:Aircraft ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seatingCapacityEconomy rdf:type rdf:Property ;
    rdfs:label 'Seating Capacity Economy' ;
    rdfs:comment 'The number of seats in the economy class cabin.' ;
    rdfs:domain ind:Aircraft ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seatingCapacityFirst rdf:type rdf:Property ;
    rdfs:label 'Seating Capacity First' ;
    rdfs:comment 'The number of seats in the first class cabin. Zero if aircraft does not have first class configuration.' ;
    rdfs:domain ind:Aircraft ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seatingCapacityPremiumEconomy rdf:type rdf:Property ;
    rdfs:label 'Seating Capacity Premium Economy' ;
    rdfs:comment 'The number of seats in the premium economy cabin. Zero if aircraft does not have premium economy configuration.' ;
    rdfs:domain ind:Aircraft ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seatingCapacityTotal rdf:type rdf:Property ;
    rdfs:label 'Seating Capacity Total' ;
    rdfs:comment 'The total number of passenger seats installed on the aircraft across all cabin classes. Used for load factor and capacity planning calculations.' ;
    rdfs:domain ind:Aircraft ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tailNumber rdf:type rdf:Property ;
    rdfs:label 'Tail Number' ;
    rdfs:comment 'The official registration mark painted on the aircraft tail, serving as the globally unique identifier for the physical aircraft asset. Also known as registration mark or tail sign.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCycles rdf:type rdf:Property ;
    rdfs:label 'Total Cycles' ;
    rdfs:comment 'Cumulative total number of flight cycles (takeoff and landing pairs) accumulated by the aircraft since delivery. Key metric for fatigue life and maintenance interval tracking.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:aircraftDeliveryId rdf:type rdf:Property ;
    rdfs:label 'Aircraft Delivery Id' ;
    rdfs:comment 'Unique identifier for the aircraft delivery event. Primary key for the aircraft delivery transaction.' ;
    rdfs:domain ind:AircraftDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:acceptanceTeamLeadEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Acceptance Team Lead Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Aircraft delivery acceptance requires named technical lead with sign-off authority for manufacturer handover, certificate of acceptance issuance, and warranty claim accountability. Replaces denormaliz' ;
    rdfs:domain ind:AircraftDelivery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:deliveryStationId rdf:type rdf:Property ;
    rdfs:label 'Delivery Station Id' ;
    rdfs:comment 'Foreign key linking to airport.station. Business justification: New aircraft acceptance logistics, delivery team deployment, and acceptance flight planning require station linkage. Fleet planning and delivery coordination depend on accurate station tracking. Repla' ;
    rdfs:domain ind:AircraftDelivery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Station .

ind:fleetOrderId rdf:type rdf:Property ;
    rdfs:label 'Fleet Order Id' ;
    rdfs:comment 'Foreign key linking to fleet.fleet_order. Business justification: Aircraft delivery fulfills a fleet order. fleet_order tracks purchase orders and lease commitments; aircraft_delivery records the actual delivery event. Linking delivery to order establishes traceabil' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FleetOrder .

ind:acceptanceCertificateReference rdf:type rdf:Property ;
    rdfs:label 'Acceptance Certificate Reference' ;
    rdfs:comment 'Reference number of the formal acceptance certificate document signed by the airline and manufacturer/lessor confirming aircraft delivery and acceptance.' ;
    rdfs:domain ind:AircraftDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:airframeCyclesAtDelivery rdf:type rdf:Property ;
    rdfs:label 'Airframe Cycles At Delivery' ;
    rdfs:comment 'Total accumulated flight cycles (takeoff and landing cycles) on the airframe at the time of delivery. Zero for new aircraft, non-zero for used aircraft.' ;
    rdfs:domain ind:AircraftDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:airframeHoursAtDelivery rdf:type rdf:Property ;
    rdfs:label 'Airframe Hours At Delivery' ;
    rdfs:comment 'Total accumulated flight hours (block hours) on the airframe at the time of delivery. Zero for new aircraft, non-zero for used aircraft.' ;
    rdfs:domain ind:AircraftDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:apuSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Apu Serial Number' ;
    rdfs:comment 'Manufacturer serial number of the Auxiliary Power Unit (APU) installed on the aircraft at delivery. APU provides electrical power and pneumatic air on the ground and in-flight backup.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryCondition rdf:type rdf:Property ;
    rdfs:label 'Delivery Condition' ;
    rdfs:comment 'Condition classification of the aircraft at delivery: new from manufacturer, used from lessor, refurbished after major overhaul, or pre-owned from another operator.' ;
    rdfs:domain ind:AircraftDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryFlightNumber rdf:type rdf:Property ;
    rdfs:label 'Delivery Flight Number' ;
    rdfs:comment 'Flight number assigned to the ferry flight that delivered the aircraft from the manufacturer or lessor facility to the airline\'s base. May be a non-revenue positioning flight.' ;
    rdfs:domain ind:AircraftDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryNotes rdf:type rdf:Property ;
    rdfs:label 'Delivery Notes' ;
    rdfs:comment 'Free-text notes capturing additional details about the delivery event, including any special conditions, snags identified during acceptance inspection, or deviations from standard delivery procedures.' ;
    rdfs:domain ind:AircraftDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryNumber rdf:type rdf:Property ;
    rdfs:label 'Delivery Number' ;
    rdfs:comment 'Externally-known unique business identifier for this aircraft delivery transaction, typically assigned by the manufacturer or lessor.' ;
    rdfs:domain ind:AircraftDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engine1SerialNumber rdf:type rdf:Property ;
    rdfs:label 'Engine 1 Serial Number' ;
    rdfs:comment 'Manufacturer serial number of the engine installed in position 1 (typically left engine on twin-engine aircraft) at delivery.' ;
    rdfs:domain ind:AircraftDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engine2SerialNumber rdf:type rdf:Property ;
    rdfs:label 'Engine 2 Serial Number' ;
    rdfs:comment 'Manufacturer serial number of the engine installed in position 2 (typically right engine on twin-engine aircraft) at delivery.' ;
    rdfs:domain ind:AircraftDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engine3SerialNumber rdf:type rdf:Property ;
    rdfs:label 'Engine 3 Serial Number' ;
    rdfs:comment 'Manufacturer serial number of the engine installed in position 3 (for tri-jet or quad-jet aircraft) at delivery. Null for twin-engine aircraft.' ;
    rdfs:domain ind:AircraftDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engine4SerialNumber rdf:type rdf:Property ;
    rdfs:label 'Engine 4 Serial Number' ;
    rdfs:comment 'Manufacturer serial number of the engine installed in position 4 (for quad-jet aircraft) at delivery. Null for twin-engine and tri-jet aircraft.' ;
    rdfs:domain ind:AircraftDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:etopsCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Etops Certified Flag' ;
    rdfs:comment 'Indicates whether the aircraft is certified for ETOPS operations at delivery, allowing extended-range twin-engine flights over routes distant from diversion airports.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:etopsRatingMinutes rdf:type rdf:Property ;
    rdfs:label 'Etops Rating Minutes' ;
    rdfs:comment 'ETOPS rating in minutes (e.g., 120, 180, 207, 330) indicating the maximum diversion time the aircraft is certified for. Null if not ETOPS certified.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:melApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Mel Applicable Flag' ;
    rdfs:comment 'Indicates whether a Minimum Equipment List (MEL) is applicable to this aircraft, allowing dispatch with certain non-critical equipment inoperative under specified conditions.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:technicalAcceptanceOutcome rdf:type rdf:Property ;
    rdfs:label 'Technical Acceptance Outcome' ;
    rdfs:comment 'Outcome of the technical acceptance inspection performed by the airline\'s engineering team: accepted (no issues), accepted with conditions (minor snags to be resolved), rejected (major defects), or deferred (inspection postponed).' ;
    rdfs:domain ind:AircraftDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalSeatCapacity rdf:type rdf:Property ;
    rdfs:label 'Total Seat Capacity' ;
    rdfs:comment 'Total number of passenger seats installed in the aircraft at delivery, across all cabin classes.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:aircraftDocumentId rdf:type rdf:Property ;
    rdfs:label 'Aircraft Document Id' ;
    rdfs:comment 'Unique identifier for the aircraft document record. Primary key for the aircraft document registry.' ;
    rdfs:domain ind:AircraftDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:documentCustodianEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Document Custodian Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Regulatory documents (CofA, CofR, noise certificates) require named custodian for compliance audit trail, renewal tracking, and authority submission. Required for IOSA audit and regulatory inspection ' ;
    rdfs:domain ind:AircraftDocument ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:applicableOperations rdf:type rdf:Property ;
    rdfs:label 'Applicable Operations' ;
    rdfs:comment 'Description of the flight operations or routes for which this document is required or applicable (e.g., ETOPS routes, RVSM airspace, international operations).' ;
    rdfs:domain ind:AircraftDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditTrailReference rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Reference' ;
    rdfs:comment 'Reference identifier linking this document record to the audit log or compliance tracking system. Enables full traceability of document lifecycle events.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentFormat rdf:type rdf:Property ;
    rdfs:label 'Document Format' ;
    rdfs:comment 'Physical or digital format in which the document is stored. Supports document retrieval and archival strategy.' ;
    rdfs:domain ind:AircraftDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentStatus rdf:type rdf:Property ;
    rdfs:label 'Document Status' ;
    rdfs:comment 'Current lifecycle state of the document. Determines whether the aircraft is compliant for operation under this document requirement.' ;
    rdfs:domain ind:AircraftDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentStorageReference rdf:type rdf:Property ;
    rdfs:label 'Document Storage Reference' ;
    rdfs:comment 'URI, file path, or document management system identifier pointing to the digital or physical storage location of the document. Enables rapid retrieval during audits or inspections.' ;
    rdfs:domain ind:AircraftDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalReminderDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Reminder Date' ;
    rdfs:comment 'Internal trigger date for initiating the document renewal process. Typically set 30-90 days before expiry to ensure timely renewal and avoid operational disruption.' ;
    rdfs:domain ind:AircraftDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verifiedBy rdf:type rdf:Property ;
    rdfs:label 'Verified By' ;
    rdfs:comment 'Name or identifier of the individual or team who performed the last verification of the document. Supports audit trail and accountability.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aircraftLeaseId rdf:type rdf:Property ;
    rdfs:label 'Aircraft Lease Id' ;
    rdfs:comment 'Unique identifier for the aircraft lease agreement record. Primary key for the aircraft lease entity.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AircraftLease .

ind:lesseeEntityId rdf:type rdf:Property ;
    rdfs:label 'Lessee Entity Id' ;
    rdfs:comment 'Reference to the lessee entity (airline operating unit or subsidiary) receiving the aircraft. Links to internal organizational hierarchy.' ;
    rdfs:domain ind:AircraftLease ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:actualDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Actual Delivery Date' ;
    rdfs:comment 'Actual date when the aircraft was physically delivered to the lessee and accepted into operational service. May differ from lease start date.' ;
    rdfs:domain ind:AircraftLease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualReturnDate rdf:type rdf:Property ;
    rdfs:label 'Actual Return Date' ;
    rdfs:comment 'Actual date when the aircraft was returned to the lessor and removed from lessee operational control. Populated upon lease termination.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:aircraftTypeCode rdf:type rdf:Property ;
    rdfs:label 'Aircraft Type Code' ;
    rdfs:comment 'IATA or ICAO aircraft type designator code identifying the aircraft model (e.g., B738 for Boeing 737-800, A320 for Airbus A320).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:earlyTerminationClauseFlag rdf:type rdf:Property ;
    rdfs:label 'Early Termination Clause Flag' ;
    rdfs:comment 'Indicates whether the lease agreement includes provisions allowing early termination by either party under specified conditions.' ;
    rdfs:domain ind:AircraftLease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:earlyTerminationPenaltyUsd rdf:type rdf:Property ;
    rdfs:label 'Early Termination Penalty Usd' ;
    rdfs:comment 'Financial penalty amount in US dollars payable if the lease is terminated before the scheduled end date. Nullable if no penalty applies.' ;
    rdfs:domain ind:AircraftLease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:extensionOptionAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Extension Option Available Flag' ;
    rdfs:comment 'Indicates whether the lease agreement includes an option for the lessee to extend the lease term beyond the original end date.' ;
    rdfs:domain ind:AircraftLease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:extensionOptionDurationMonths rdf:type rdf:Property ;
    rdfs:label 'Extension Option Duration Months' ;
    rdfs:comment 'Duration in months for which the lease can be extended if the extension option is exercised. Nullable if no extension option exists.' ;
    rdfs:domain ind:AircraftLease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:governingLawJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Governing Law Jurisdiction' ;
    rdfs:comment 'Legal jurisdiction and governing law specified in the lease agreement for dispute resolution and contract interpretation (e.g., New York, England and Wales, Singapore).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceResponsibility rdf:type rdf:Property ;
    rdfs:label 'Insurance Responsibility' ;
    rdfs:comment 'Party responsible for maintaining aircraft hull and liability insurance coverage during the lease term. Critical for ACMI vs dry lease distinction.' ;
    rdfs:domain ind:AircraftLease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaseAgreementNumber rdf:type rdf:Property ;
    rdfs:label 'Lease Agreement Number' ;
    rdfs:comment 'Externally-known unique identifier for the lease agreement as referenced in legal contracts and financial systems. Business identifier for the lease.' ;
    rdfs:domain ind:AircraftLease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaseCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Lease Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the lease agreement. While amounts are stored in USD, this captures the original contract currency for reference.' ;
    rdfs:domain ind:AircraftLease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaseExecutionDate rdf:type rdf:Property ;
    rdfs:label 'Lease Execution Date' ;
    rdfs:comment 'Date when the lease agreement was formally signed and executed by both lessor and lessee parties. Legal effective date of the contract.' ;
    rdfs:domain ind:AircraftLease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leaseStartDate rdf:type rdf:Property ;
    rdfs:label 'Lease Start Date' ;
    rdfs:comment 'Effective date when the lease agreement becomes binding and the aircraft is delivered to the lessee. Marks the beginning of rental obligations.' ;
    rdfs:domain ind:AircraftLease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maintenanceReserveRatePerCycle rdf:type rdf:Property ;
    rdfs:label 'Maintenance Reserve Rate Per Cycle' ;
    rdfs:comment 'Maintenance reserve contribution rate in US dollars per flight cycle (takeoff and landing). Applied to landing gear and other cycle-sensitive components.' ;
    rdfs:domain ind:AircraftLease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maintenanceReserveRatePerFh rdf:type rdf:Property ;
    rdfs:label 'Maintenance Reserve Rate Per Fh' ;
    rdfs:comment 'Maintenance reserve contribution rate in US dollars per flight hour. Accumulated reserves fund major maintenance events and are reconciled at lease end.' ;
    rdfs:domain ind:AircraftLease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maintenanceResponsibility rdf:type rdf:Property ;
    rdfs:label 'Maintenance Responsibility' ;
    rdfs:comment 'Party responsible for performing and funding aircraft maintenance during the lease term. Defines operational obligations under the lease type.' ;
    rdfs:domain ind:AircraftLease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monthlyRentalRateUsd rdf:type rdf:Property ;
    rdfs:label 'Monthly Rental Rate Usd' ;
    rdfs:comment 'Fixed monthly lease payment amount in US dollars payable to the lessor. Base rental rate excluding maintenance reserves and other variable charges.' ;
    rdfs:domain ind:AircraftLease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:redeliveryLocationCode rdf:type rdf:Property ;
    rdfs:label 'Redelivery Location Code' ;
    rdfs:comment 'IATA three-letter airport code specifying the contractual location where the aircraft must be returned to the lessor at lease end.' ;
    rdfs:domain ind:AircraftLease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnConditionMaxCycles rdf:type rdf:Property ;
    rdfs:label 'Return Condition Max Cycles' ;
    rdfs:comment 'Maximum total flight cycles allowed on the aircraft at lease return. Contractual limit for takeoff/landing cycles at redelivery.' ;
    rdfs:domain ind:AircraftLease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:returnConditionMaxFlightHours rdf:type rdf:Property ;
    rdfs:label 'Return Condition Max Flight Hours' ;
    rdfs:comment 'Maximum total flight hours allowed on the aircraft at lease return. Contractual limit defining acceptable utilization at redelivery.' ;
    rdfs:domain ind:AircraftLease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:securityDepositAmountUsd rdf:type rdf:Property ;
    rdfs:label 'Security Deposit Amount Usd' ;
    rdfs:comment 'Refundable security deposit amount in US dollars held by the lessor as collateral against lease obligations and aircraft return conditions.' ;
    rdfs:domain ind:AircraftLease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:aircraftRedeliveryId rdf:type rdf:Property ;
    rdfs:label 'Aircraft Redelivery Id' ;
    rdfs:comment 'Unique identifier for the aircraft redelivery transaction. Primary key for the aircraft redelivery record.' ;
    rdfs:domain ind:AircraftRedelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:redeliveryCoordinatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Redelivery Coordinator Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Redelivery process requires named coordinator for lessor handback inspection scheduling, technical records package preparation, maintenance reserve settlement, and redelivery certificate issuance. Rep' ;
    rdfs:domain ind:AircraftRedelivery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:redeliveryStationId rdf:type rdf:Property ;
    rdfs:label 'Redelivery Station Id' ;
    rdfs:comment 'Foreign key linking to airport.station. Business justification: Lease return logistics, ground handler coordination, and redelivery inspection scheduling require station linkage. Contract compliance verification and lessor coordination depend on accurate station t' ;
    rdfs:domain ind:AircraftRedelivery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Station .

ind:redeliveryWorkOrderId rdf:type rdf:Property ;
    rdfs:label 'Redelivery Work Order Id' ;
    rdfs:comment 'Foreign key linking to maintenance.work_order. Business justification: Redelivery inspections identify maintenance discrepancies that must be rectified before lessor acceptance. Redelivery coordinators track specific work orders completing outstanding items for lease ret' ;
    rdfs:domain ind:AircraftRedelivery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkOrder .

ind:airframeCyclesAtRedelivery rdf:type rdf:Property ;
    rdfs:label 'Airframe Cycles At Redelivery' ;
    rdfs:comment 'Total accumulated flight cycles (takeoff and landing pairs) recorded on the aircraft at the time of redelivery. Used for maintenance reserve calculations.' ;
    rdfs:domain ind:AircraftRedelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:airframeHoursAtRedelivery rdf:type rdf:Property ;
    rdfs:label 'Airframe Hours At Redelivery' ;
    rdfs:comment 'Total accumulated airframe flight hours recorded on the aircraft at the time of redelivery. Critical for lease return condition assessment.' ;
    rdfs:domain ind:AircraftRedelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:apuCyclesAtRedelivery rdf:type rdf:Property ;
    rdfs:label 'Apu Cycles At Redelivery' ;
    rdfs:comment 'Total accumulated start cycles on the Auxiliary Power Unit at the time of redelivery.' ;
    rdfs:domain ind:AircraftRedelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:apuHoursAtRedelivery rdf:type rdf:Property ;
    rdfs:label 'Apu Hours At Redelivery' ;
    rdfs:comment 'Total accumulated operating hours on the Auxiliary Power Unit at the time of redelivery.' ;
    rdfs:domain ind:AircraftRedelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeDescription rdf:type rdf:Property ;
    rdfs:label 'Dispute Description' ;
    rdfs:comment 'Detailed description of any disputes raised during or after the redelivery process, including the nature of disagreement and items under contention.' ;
    rdfs:domain ind:AircraftRedelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeRaisedFlag rdf:type rdf:Property ;
    rdfs:label 'Dispute Raised Flag' ;
    rdfs:comment 'Boolean indicator of whether any disputes were raised by either party (lessee or lessor) regarding the redelivery condition, financial settlement, or compliance with lease return terms.' ;
    rdfs:domain ind:AircraftRedelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:engine1CyclesAtRedelivery rdf:type rdf:Property ;
    rdfs:label 'Engine 1 Cycles At Redelivery' ;
    rdfs:comment 'Total accumulated cycles on engine position 1 at the time of redelivery.' ;
    rdfs:domain ind:AircraftRedelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:engine1HoursAtRedelivery rdf:type rdf:Property ;
    rdfs:label 'Engine 1 Hours At Redelivery' ;
    rdfs:comment 'Total accumulated flight hours on engine position 1 at the time of redelivery.' ;
    rdfs:domain ind:AircraftRedelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:engine2CyclesAtRedelivery rdf:type rdf:Property ;
    rdfs:label 'Engine 2 Cycles At Redelivery' ;
    rdfs:comment 'Total accumulated cycles on engine position 2 at the time of redelivery.' ;
    rdfs:domain ind:AircraftRedelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:engine2HoursAtRedelivery rdf:type rdf:Property ;
    rdfs:label 'Engine 2 Hours At Redelivery' ;
    rdfs:comment 'Total accumulated flight hours on engine position 2 at the time of redelivery.' ;
    rdfs:domain ind:AircraftRedelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:finalSettlementAmountUsd rdf:type rdf:Property ;
    rdfs:label 'Final Settlement Amount Usd' ;
    rdfs:comment 'The total net settlement amount in US Dollars for the redelivery transaction, including maintenance reserves, security deposit adjustments, outstanding rent, and any penalty or credit adjustments. Positive values indicate amounts due to lessee; negative values indicate amounts due to lessor.' ;
    rdfs:domain ind:AircraftRedelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceCoverageEndDate rdf:type rdf:Property ;
    rdfs:label 'Insurance Coverage End Date' ;
    rdfs:comment 'The date on which the lessee\'s insurance coverage for the aircraft terminated following redelivery. Critical for liability transfer documentation.' ;
    rdfs:domain ind:AircraftRedelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lessorRepresentativeName rdf:type rdf:Property ;
    rdfs:label 'Lessor Representative Name' ;
    rdfs:comment 'The name of the lessor\'s representative who conducted the redelivery inspection and acceptance process.' ;
    rdfs:domain ind:AircraftRedelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceReserveSettlementAmountUsd rdf:type rdf:Property ;
    rdfs:label 'Maintenance Reserve Settlement Amount Usd' ;
    rdfs:comment 'The final settlement amount in US Dollars for maintenance reserves held by the lessor. This represents the net payment due to or from the lessee based on actual maintenance performed versus reserves paid during the lease term.' ;
    rdfs:domain ind:AircraftRedelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outstandingMaintenanceDescription rdf:type rdf:Property ;
    rdfs:label 'Outstanding Maintenance Description' ;
    rdfs:comment 'Detailed description of any outstanding maintenance items, defects, or deferred maintenance actions at redelivery. Used for dispute resolution and settlement negotiations.' ;
    rdfs:domain ind:AircraftRedelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outstandingMaintenanceItemsCount rdf:type rdf:Property ;
    rdfs:label 'Outstanding Maintenance Items Count' ;
    rdfs:comment 'The number of outstanding maintenance items, defects, or deferred maintenance actions recorded at the time of redelivery that may require rectification or financial settlement.' ;
    rdfs:domain ind:AircraftRedelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:redeliveryAcceptanceStatus rdf:type rdf:Property ;
    rdfs:label 'Redelivery Acceptance Status' ;
    rdfs:comment 'The lessor\'s formal acceptance status of the aircraft redelivery. Indicates whether the lessor has accepted the aircraft back without dispute.' ;
    rdfs:domain ind:AircraftRedelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redeliveryCertificateIssuedFlag rdf:type rdf:Property ;
    rdfs:label 'Redelivery Certificate Issued Flag' ;
    rdfs:comment 'Boolean indicator of whether a formal redelivery certificate was issued by the lessor acknowledging receipt and acceptance of the aircraft.' ;
    rdfs:domain ind:AircraftRedelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:redeliveryCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Redelivery Certificate Number' ;
    rdfs:comment 'The unique reference number of the formal redelivery certificate issued by the lessor upon acceptance of the aircraft.' ;
    rdfs:domain ind:AircraftRedelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redeliveryConditionStatus rdf:type rdf:Property ;
    rdfs:label 'Redelivery Condition Status' ;
    rdfs:comment 'The outcome of the redelivery condition assessment performed by the lessor\'s technical team. Indicates whether the aircraft met the return conditions specified in the lease agreement.' ;
    rdfs:domain ind:AircraftRedelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Redelivery Date' ;
    rdfs:comment 'The date on which the aircraft was physically redelivered to the lessor and operational control was transferred.' ;
    rdfs:domain ind:AircraftRedelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:redeliveryInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Redelivery Inspection Date' ;
    rdfs:comment 'The date on which the formal redelivery inspection was conducted by the lessor\'s technical representatives to assess aircraft condition against lease return requirements.' ;
    rdfs:domain ind:AircraftRedelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:redeliveryType rdf:type rdf:Property ;
    rdfs:label 'Redelivery Type' ;
    rdfs:comment 'The reason or circumstance under which the aircraft redelivery occurred. Distinguishes between normal lease expiry, early termination, purchase option exercise, or default scenarios.' ;
    rdfs:domain ind:AircraftRedelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityDepositReturnAmountUsd rdf:type rdf:Property ;
    rdfs:label 'Security Deposit Return Amount Usd' ;
    rdfs:comment 'The amount of the security deposit in US Dollars being returned to the lessee upon successful redelivery, after deducting any applicable charges or damages.' ;
    rdfs:domain ind:AircraftRedelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:technicalRecordsTransferDate rdf:type rdf:Property ;
    rdfs:label 'Technical Records Transfer Date' ;
    rdfs:comment 'The date on which all aircraft technical records, maintenance logs, and documentation were formally transferred from the lessee to the lessor as part of the redelivery process.' ;
    rdfs:domain ind:AircraftRedelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:registrationCoordinatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Registration Coordinator Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Aircraft registration requires named coordinator for national CAA liaison, certificate renewal application, export certificate processing, and registration mark reservation. Critical for airworthiness' ;
    rdfs:domain ind:AircraftRegistration ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:aircraftCategory rdf:type rdf:Property ;
    rdfs:label 'Aircraft Category' ;
    rdfs:comment 'The regulatory category classification of the aircraft. Transport category includes commercial passenger and cargo aircraft. General aviation includes smaller aircraft for personal or business use.' ;
    rdfs:domain ind:AircraftRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:airworthinessExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Airworthiness Expiry Date' ;
    rdfs:comment 'The date on which the current certificate of airworthiness expires. Nullable for certificates that remain valid subject to continuing airworthiness requirements.' ;
    rdfs:domain ind:AircraftRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:airworthinessIssueDate rdf:type rdf:Property ;
    rdfs:label 'Airworthiness Issue Date' ;
    rdfs:comment 'The date on which the current certificate of airworthiness was issued by the national civil aviation authority.' ;
    rdfs:domain ind:AircraftRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exportCertificateDate rdf:type rdf:Property ;
    rdfs:label 'Export Certificate Date' ;
    rdfs:comment 'The date on which the export certificate of airworthiness was issued by the exporting country civil aviation authority.' ;
    rdfs:domain ind:AircraftRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exportCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Export Certificate Number' ;
    rdfs:comment 'The certificate number issued by the exporting country civil aviation authority when the aircraft was transferred from another jurisdiction. Required for international aircraft transfers.' ;
    rdfs:domain ind:AircraftRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nationalCaaName rdf:type rdf:Property ;
    rdfs:label 'National Caa Name' ;
    rdfs:comment 'The name of the national civil aviation authority that issued the registration. Examples: Federal Aviation Administration (FAA), European Union Aviation Safety Agency (EASA), Civil Aviation Authority (CAA).' ;
    rdfs:domain ind:AircraftRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noiseCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Noise Certificate Number' ;
    rdfs:comment 'The unique certificate number issued by the national civil aviation authority certifying that the aircraft meets noise emission standards per ICAO Annex 16. Required for commercial operations at most airports.' ;
    rdfs:domain ind:AircraftRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noiseChapterCompliance rdf:type rdf:Property ;
    rdfs:label 'Noise Chapter Compliance' ;
    rdfs:comment 'The ICAO Annex 16 noise certification chapter that the aircraft complies with. Chapter 4 is the most stringent current standard. Chapter 2 aircraft are banned from most airports.' ;
    rdfs:domain ind:AircraftRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousRegisteringCountryCode rdf:type rdf:Property ;
    rdfs:label 'Previous Registering Country Code' ;
    rdfs:comment 'The ICAO country code of the previous country of registration, if the aircraft was transferred from another jurisdiction.' ;
    rdfs:domain ind:AircraftRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousRegistrationMark rdf:type rdf:Property ;
    rdfs:label 'Previous Registration Mark' ;
    rdfs:comment 'The previous registration mark (tail number) assigned to this aircraft before the current registration, if applicable. Used to track aircraft that have been re-registered or transferred between jurisdictions.' ;
    rdfs:domain ind:AircraftRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredOperatorName rdf:type rdf:Property ;
    rdfs:label 'Registered Operator Name' ;
    rdfs:comment 'The legal name of the airline or entity authorized to operate the aircraft as recorded on the certificate of registration. This is the entity responsible for operational control.' ;
    rdfs:domain ind:AircraftRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredOwnerName rdf:type rdf:Property ;
    rdfs:label 'Registered Owner Name' ;
    rdfs:comment 'The legal name of the entity or individual that holds legal ownership of the aircraft as recorded on the certificate of registration. This may differ from the operator.' ;
    rdfs:domain ind:AircraftRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeringCountryCode rdf:type rdf:Property ;
    rdfs:label 'Registering Country Code' ;
    rdfs:comment 'The ICAO two or three-letter country code prefix indicating the country of registration. Examples: N (USA), G (UK), D (Germany), C (Canada).' ;
    rdfs:domain ind:AircraftRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationMark rdf:type rdf:Property ;
    rdfs:label 'Registration Mark' ;
    rdfs:comment 'The official registration mark (tail number) assigned by the national civil aviation authority. This is the unique identifier painted on the aircraft fuselage and tail. Also known as aircraft registration number or tail number.' ;
    rdfs:domain ind:AircraftRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationRemarks rdf:type rdf:Property ;
    rdfs:label 'Registration Remarks' ;
    rdfs:comment 'Free-text field for additional notes, comments, or special conditions related to the aircraft registration. May include restrictions, special authorizations, or historical notes.' ;
    rdfs:domain ind:AircraftRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationStatus rdf:type rdf:Property ;
    rdfs:label 'Registration Status' ;
    rdfs:comment 'The current lifecycle status of the aircraft registration. Current indicates active registration, expired indicates registration has lapsed, cancelled indicates registration has been terminated, suspended indicates temporary suspension, transferred indicates registration has been moved to another jurisdiction.' ;
    rdfs:domain ind:AircraftRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationStatusDate rdf:type rdf:Property ;
    rdfs:label 'Registration Status Date' ;
    rdfs:comment 'The date on which the current registration status became effective. Used to track when a registration was cancelled, suspended, or transferred.' ;
    rdfs:domain ind:AircraftRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:aircraftFamily rdf:type rdf:Property ;
    rdfs:label 'Aircraft Family' ;
    rdfs:comment 'High-level aircraft family grouping (e.g., B737, A320, B777, A350, E190) used for fleet planning and commonality analysis.' ;
    rdfs:domain ind:AircraftType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aircraftTypeStatus rdf:type rdf:Property ;
    rdfs:label 'Aircraft Type Status' ;
    rdfs:comment 'Current lifecycle status of the aircraft type in the airline\'s context: active (currently operated), retired (formerly operated), planned (future fleet addition), reference (not operated, maintained for codeshare/interline/industry reference).' ;
    rdfs:domain ind:AircraftType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aircraftVariant rdf:type rdf:Property ;
    rdfs:label 'Aircraft Variant' ;
    rdfs:comment 'Specific aircraft variant within the family including generation and configuration details (e.g., B737-800, A320neo, B777-300ER, A350-900, E190-E2).' ;
    rdfs:domain ind:AircraftType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cargoVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Cargo Volume M3' ;
    rdfs:comment 'Total cargo hold volume in cubic meters. Used for cargo revenue planning and ULD capacity analysis.' ;
    rdfs:domain ind:AircraftType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emissionsStandard rdf:type rdf:Property ;
    rdfs:label 'Emissions Standard' ;
    rdfs:comment 'ICAO engine emissions standard (e.g., CAEP/6, CAEP/8, CAEP/10) indicating compliance level for NOx, CO, HC, and smoke. Used for CORSIA reporting and environmental compliance.' ;
    rdfs:domain ind:AircraftType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engineCount rdf:type rdf:Property ;
    rdfs:label 'Engine Count' ;
    rdfs:comment 'Number of engines installed on the aircraft type (typically 2, 3, or 4 for commercial jets; 2 for turboprops).' ;
    rdfs:domain ind:AircraftType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:engineModel rdf:type rdf:Property ;
    rdfs:label 'Engine Model' ;
    rdfs:comment 'Specific engine model and manufacturer (e.g., CFM56-7B, PW1100G-JM, GE90-115B, Trent XWB) used for maintenance planning and fuel efficiency analysis.' ;
    rdfs:domain ind:AircraftType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engineType rdf:type rdf:Property ;
    rdfs:label 'Engine Type' ;
    rdfs:comment 'Propulsion system type installed on the aircraft (turbofan for modern jets, turboprop for regional aircraft, turbojet for older jets, piston for small aircraft).' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:etopsBaselineMinutes rdf:type rdf:Property ;
    rdfs:label 'Etops Baseline Minutes' ;
    rdfs:comment 'Baseline ETOPS certification in minutes (e.g., 120, 180, 330, 370) indicating how far the aircraft can fly from the nearest suitable airport with one engine inoperative. Null for non-ETOPS or multi-engine (3+) aircraft.' ;
    rdfs:domain ind:AircraftType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fleetEntryDate rdf:type rdf:Property ;
    rdfs:label 'Fleet Entry Date' ;
    rdfs:comment 'Date when this aircraft type first entered the airline\'s operating fleet. Null if not yet in fleet or planned only.' ;
    rdfs:domain ind:AircraftType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fleetExitDate rdf:type rdf:Property ;
    rdfs:label 'Fleet Exit Date' ;
    rdfs:comment 'Date when this aircraft type was retired from the airline\'s operating fleet. Null if still active or never operated.' ;
    rdfs:domain ind:AircraftType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fuelCapacityLiters rdf:type rdf:Property ;
    rdfs:label 'Fuel Capacity Liters' ;
    rdfs:comment 'Total usable fuel capacity in liters. Critical for range calculation, fuel uplift planning, and operational cost analysis.' ;
    rdfs:domain ind:AircraftType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuselageLengthM rdf:type rdf:Property ;
    rdfs:label 'Fuselage Length M' ;
    rdfs:comment 'Overall length of the aircraft fuselage in meters. Impacts gate compatibility and ground handling requirements.' ;
    rdfs:domain ind:AircraftType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuselageWidthCategory rdf:type rdf:Property ;
    rdfs:label 'Fuselage Width Category' ;
    rdfs:comment 'Classification of aircraft by fuselage width: narrowbody (single-aisle, e.g., A320, B737), widebody (twin-aisle, e.g., A350, B777), regional (smaller single-aisle, e.g., E190, CRJ).' ;
    rdfs:domain ind:AircraftType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iataTypeCode rdf:type rdf:Property ;
    rdfs:label 'Iata Type Code' ;
    rdfs:comment 'Three-character IATA aircraft type code used in reservation systems, schedules, and commercial documentation (e.g., 738 for Boeing 737-800, 32Q for Airbus A321neo).' ;
    rdfs:domain ind:AircraftType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icaoTypeCode rdf:type rdf:Property ;
    rdfs:label 'Icao Type Code' ;
    rdfs:comment 'Four-character ICAO aircraft type designator used globally for flight planning, ATC communication, and operational documentation (e.g., B738 for Boeing 737-800, A20N for Airbus A320neo).' ;
    rdfs:domain ind:AircraftType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inFleetFlag rdf:type rdf:Property ;
    rdfs:label 'In Fleet Flag' ;
    rdfs:comment 'Indicates whether this aircraft type is currently operated in the airline\'s fleet (true) or is a reference type for codeshare, interline, or future planning (false).' ;
    rdfs:domain ind:AircraftType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxPassengerCapacity rdf:type rdf:Property ;
    rdfs:label 'Max Passenger Capacity' ;
    rdfs:comment 'Maximum number of passenger seats that can be installed per the aircraft type certificate, regardless of airline-specific configuration. Used for regulatory compliance and emergency planning.' ;
    rdfs:domain ind:AircraftType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxRangeNm rdf:type rdf:Property ;
    rdfs:label 'Max Range Nm' ;
    rdfs:comment 'Maximum certified range in nautical miles with maximum fuel and reduced payload. Defines the aircraft\'s absolute capability for ultra-long-haul operations.' ;
    rdfs:domain ind:AircraftType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxStructuralPayloadKg rdf:type rdf:Property ;
    rdfs:label 'Max Structural Payload Kg' ;
    rdfs:comment 'Maximum weight of passengers, cargo, and baggage that can be carried, limited by structural design. Critical for load planning and revenue optimization.' ;
    rdfs:domain ind:AircraftType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mlwKg rdf:type rdf:Property ;
    rdfs:label 'Mlw Kg' ;
    rdfs:comment 'Maximum certified weight at which the aircraft is permitted to land. Determines whether fuel jettison is required in emergency return scenarios.' ;
    rdfs:domain ind:AircraftType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mtowKg rdf:type rdf:Property ;
    rdfs:label 'Mtow Kg' ;
    rdfs:comment 'Maximum certified weight at which the aircraft is permitted to take off. Determines runway length requirements, fuel capacity, and payload trade-offs.' ;
    rdfs:domain ind:AircraftType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mzfwKg rdf:type rdf:Property ;
    rdfs:label 'Mzfw Kg' ;
    rdfs:comment 'Maximum permitted weight of the aircraft and its contents (excluding usable fuel). Limits payload when fuel load is high. Critical for load planning.' ;
    rdfs:domain ind:AircraftType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:typicalBlockFuelPerHourKg rdf:type rdf:Property ;
    rdfs:label 'Typical Block Fuel Per Hour Kg' ;
    rdfs:comment 'Average fuel burn per block hour in kilograms under typical operating conditions. Used for CASK calculation, route profitability analysis, and fuel budgeting.' ;
    rdfs:domain ind:AircraftType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:typicalCruiseSpeedMach rdf:type rdf:Property ;
    rdfs:label 'Typical Cruise Speed Mach' ;
    rdfs:comment 'Typical cruise speed expressed as Mach number (e.g., 0.78, 0.82, 0.85). Used for flight planning, schedule optimization, and block time calculation.' ;
    rdfs:domain ind:AircraftType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:typicalRangeNm rdf:type rdf:Property ;
    rdfs:label 'Typical Range Nm' ;
    rdfs:comment 'Typical operational range in nautical miles with standard passenger load and reserves. Used for route network planning and aircraft assignment.' ;
    rdfs:domain ind:AircraftType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wakeTurbulenceCategory rdf:type rdf:Property ;
    rdfs:label 'Wake Turbulence Category' ;
    rdfs:comment 'ICAO wake turbulence category based on maximum takeoff weight: L (Light, <7000kg), M (Medium, 7000-136000kg), H (Heavy, >136000kg), J (Super, A380 only). Critical for ATC separation standards.' ;
    rdfs:domain ind:AircraftType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wingspanM rdf:type rdf:Property ;
    rdfs:label 'Wingspan M' ;
    rdfs:comment 'Aircraft wingspan in meters. Determines gate compatibility, taxiway clearance requirements, and ICAO aerodrome reference code.' ;
    rdfs:domain ind:AircraftType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:aircraftUtilizationId rdf:type rdf:Property ;
    rdfs:label 'Aircraft Utilization Id' ;
    rdfs:comment 'Unique identifier for each daily aircraft utilization record. Primary key for the aircraft utilization ledger.' ;
    rdfs:domain ind:AircraftUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operatingStationId rdf:type rdf:Property ;
    rdfs:label 'Operating Station Id' ;
    rdfs:comment 'Foreign key linking to airport.station. Business justification: Daily utilization records require station context for station-level performance reporting, cost center allocation, and operational efficiency analysis. Critical for hub vs spoke utilization comparison' ;
    rdfs:domain ind:AircraftUtilization ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Station .

ind:apuHours rdf:type rdf:Property ;
    rdfs:label 'Apu Hours' ;
    rdfs:comment 'Total APU operating hours on this date. APU provides ground power and air conditioning when main engines are off. Tracked for APU maintenance intervals.' ;
    rdfs:domain ind:AircraftUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageDailyUtilizationHours rdf:type rdf:Property ;
    rdfs:label 'Average Daily Utilization Hours' ;
    rdfs:comment 'Rolling 30-day average daily block hours for this aircraft, calculated as of this utilization date. Used for fleet planning and lease utilization benchmarking.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataQualityFlag rdf:type rdf:Property ;
    rdfs:label 'Data Quality Flag' ;
    rdfs:comment 'Indicates the quality and completeness of this utilization record. Verified indicates data has been validated against multiple sources, estimated indicates calculated or interpolated values, incomplete indicates missing data elements, reconciled indicates discrepancies have been resolved.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSource rdf:type rdf:Property ;
    rdfs:label 'Data Source' ;
    rdfs:comment 'The source system from which this utilization data was captured. ACARS (Aircraft Communications Addressing and Reporting System) provides automated flight data, FMS (Flight Management System) provides flight planning data, AMOS (Aircraft Maintenance and Engineering System) provides maintenance records, manual indicates operator-entered data.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:etopsSectors rdf:type rdf:Property ;
    rdfs:label 'Etops Sectors' ;
    rdfs:comment 'Number of ETOPS-certified flight sectors operated on this date. ETOPS allows twin-engine aircraft to fly routes more than 60 minutes from the nearest suitable airport.' ;
    rdfs:domain ind:AircraftUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:flightCycles rdf:type rdf:Property ;
    rdfs:label 'Flight Cycles' ;
    rdfs:comment 'Total number of flight cycles (pressurization cycles) completed on this date. One cycle equals one takeoff and landing. Critical for fatigue-sensitive component maintenance.' ;
    rdfs:domain ind:AircraftUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fuelBurnKg rdf:type rdf:Property ;
    rdfs:label 'Fuel Burn Kg' ;
    rdfs:comment 'Total fuel consumed (in kilograms) on this date across all flights. Used for CASK calculation and environmental reporting.' ;
    rdfs:domain ind:AircraftUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:groundTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Ground Time Minutes' ;
    rdfs:comment 'Total ground time (turnaround time) between flights on this date, summed across all sectors. Used for ground operations efficiency analysis.' ;
    rdfs:domain ind:AircraftUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:landings rdf:type rdf:Property ;
    rdfs:label 'Landings' ;
    rdfs:comment 'Total number of landings performed on this date. Used for landing gear and brake maintenance tracking.' ;
    rdfs:domain ind:AircraftUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:melItemsOpen rdf:type rdf:Property ;
    rdfs:label 'Mel Items Open' ;
    rdfs:comment 'Number of open MEL items (deferred defects) at the end of this utilization date. MEL allows aircraft to operate with certain non-critical systems inoperative under specific conditions.' ;
    rdfs:domain ind:AircraftUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nightFlightHours rdf:type rdf:Property ;
    rdfs:label 'Night Flight Hours' ;
    rdfs:comment 'Total flight hours operated during night hours (as defined by local aviation authority) on this date. Used for crew scheduling and fatigue management compliance.' ;
    rdfs:domain ind:AircraftUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nonRevenueBlockHours rdf:type rdf:Property ;
    rdfs:label 'Non Revenue Block Hours' ;
    rdfs:comment 'Block hours flown on non-revenue flights including ferry, positioning, maintenance test flights, and crew training.' ;
    rdfs:domain ind:AircraftUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pirepCount rdf:type rdf:Property ;
    rdfs:label 'Pirep Count' ;
    rdfs:comment 'Number of pilot-reported maintenance discrepancies logged on this date. Used for aircraft reliability trending and predictive maintenance.' ;
    rdfs:domain ind:AircraftUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revenueBlockHours rdf:type rdf:Property ;
    rdfs:label 'Revenue Block Hours' ;
    rdfs:comment 'Block hours flown on revenue-generating flights (passenger or cargo). Excludes ferry, positioning, and maintenance flights.' ;
    rdfs:domain ind:AircraftUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sectorsFlown rdf:type rdf:Property ;
    rdfs:label 'Sectors Flown' ;
    rdfs:comment 'Total number of flight sectors (legs) operated on this date. Equivalent to number of departures.' ;
    rdfs:domain ind:AircraftUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:technicalDelayMinutes rdf:type rdf:Property ;
    rdfs:label 'Technical Delay Minutes' ;
    rdfs:comment 'Delay minutes caused by technical or maintenance issues on this date. Subset of total delay minutes, used for aircraft reliability and maintenance effectiveness analysis.' ;
    rdfs:domain ind:AircraftUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalAirframeHoursTsn rdf:type rdf:Property ;
    rdfs:label 'Total Airframe Hours Tsn' ;
    rdfs:comment 'Cumulative total airframe hours since the aircraft was manufactured, as of the end of this utilization date. Running total used for major maintenance checks and lease return conditions.' ;
    rdfs:domain ind:AircraftUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCyclesCsn rdf:type rdf:Property ;
    rdfs:label 'Total Cycles Csn' ;
    rdfs:comment 'Cumulative total flight cycles since the aircraft was manufactured, as of the end of this utilization date. Running total used for fatigue-sensitive component tracking.' ;
    rdfs:domain ind:AircraftUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:utilizationDate rdf:type rdf:Property ;
    rdfs:label 'Utilization Date' ;
    rdfs:comment 'The calendar date (UTC) for which this utilization record applies. Each aircraft has one record per operational day.' ;
    rdfs:domain ind:AircraftUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:apuRecordId rdf:type rdf:Property ;
    rdfs:label 'Apu Record Id' ;
    rdfs:comment 'Unique identifier for the APU record. Primary key for the APU asset registry.' ;
    rdfs:domain ind:ApuRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lessorVendorId rdf:type rdf:Property ;
    rdfs:label 'Lessor Vendor Id' ;
    rdfs:comment 'Foreign key linking to procurement.vendor. Business justification: APUs can be leased separately from aircraft. Links APU lease to vendor for payment processing, lease return coordination, maintenance reserve tracking, and vendor performance evaluation.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:locationStationId rdf:type rdf:Property ;
    rdfs:label 'Location Station Id' ;
    rdfs:comment 'Foreign key linking to airport.station. Business justification: APU inventory management and maintenance logistics require station tracking when units are removed. Spare APU positioning and rotable pool management depend on accurate location tracking. Replaces den' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Station .

ind:airworthinessDirectiveStatus rdf:type rdf:Property ;
    rdfs:label 'Airworthiness Directive Status' ;
    rdfs:comment 'Current compliance status with applicable Airworthiness Directives (ADs) issued by regulatory authorities. Critical for determining if APU is legally airworthy.' ;
    rdfs:domain ind:ApuRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apuRecordStatus rdf:type rdf:Property ;
    rdfs:label 'Apu Record Status' ;
    rdfs:comment 'Current operational status of the APU asset. Installed = on aircraft; Spare = available in inventory; Shop = undergoing maintenance/repair; Retired = end of service life; Scrapped = disposed; AOG = Aircraft on Ground (critical failure).' ;
    rdfs:domain ind:ApuRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cyclesSinceOverhaul rdf:type rdf:Property ;
    rdfs:label 'Cycles Since Overhaul' ;
    rdfs:comment 'Number of start/stop cycles accumulated since the last major overhaul (CSLO). Reset to zero after each overhaul event.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastOverhaulDate rdf:type rdf:Property ;
    rdfs:label 'Last Overhaul Date' ;
    rdfs:comment 'Date when the APU last underwent a major overhaul. Used to calculate time/cycles since overhaul and plan next overhaul.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maintenanceProgram rdf:type rdf:Property ;
    rdfs:label 'Maintenance Program' ;
    rdfs:comment 'Code identifying the approved maintenance program under which this APU is maintained (e.g., MSG-3, manufacturer program). Defines inspection intervals and maintenance tasks.' ;
    rdfs:domain ind:ApuRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturer rdf:type rdf:Property ;
    rdfs:label 'Manufacturer' ;
    rdfs:comment 'Name of the company that manufactured the APU unit (e.g., Honeywell, Pratt & Whitney Canada).' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:melCategory rdf:type rdf:Property ;
    rdfs:label 'Mel Category' ;
    rdfs:comment 'MEL category for APU dispatch. Category A = repair before next flight; B = repair within 3 days; C = repair within 10 days; D = repair within 120 days. Determines dispatch authority when APU is inoperative.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextOverhaulDueCycles rdf:type rdf:Property ;
    rdfs:label 'Next Overhaul Due Cycles' ;
    rdfs:comment 'Total APU cycles at which the next overhaul is due. Calculated based on manufacturer recommendations and regulatory requirements.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextOverhaulDueHours rdf:type rdf:Property ;
    rdfs:label 'Next Overhaul Due Hours' ;
    rdfs:comment 'Total APU hours at which the next overhaul is due. Calculated based on manufacturer recommendations and regulatory requirements.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partNumber rdf:type rdf:Property ;
    rdfs:label 'Part Number' ;
    rdfs:comment 'Manufacturer part number for the APU model. Used for parts ordering, technical documentation reference, and configuration management.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:removalDate rdf:type rdf:Property ;
    rdfs:label 'Removal Date' ;
    rdfs:comment 'Date when the APU was removed from an aircraft. Null if currently installed or never installed.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:thrustRatingPounds rdf:type rdf:Property ;
    rdfs:label 'Thrust Rating Pounds' ;
    rdfs:comment 'Maximum thrust output of the APU measured in pounds. Defines the power generation and bleed air capacity of the unit.' ;
    rdfs:domain ind:ApuRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:timeSinceOverhaul rdf:type rdf:Property ;
    rdfs:label 'Time Since Overhaul' ;
    rdfs:comment 'Operating hours accumulated since the last major overhaul (TSLO). Reset to zero after each overhaul event.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalHours rdf:type rdf:Property ;
    rdfs:label 'Total Hours' ;
    rdfs:comment 'Total operating hours accumulated by the APU since it was new (TSN - Time Since New). Critical for maintenance planning and life-limited part tracking.' ;
    rdfs:domain ind:ApuRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warrantyExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Warranty Expiration Date' ;
    rdfs:comment 'Date when the manufacturer warranty for the APU expires. Null if no warranty or warranty has expired.' ;
    rdfs:domain ind:ApuRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cabinConfigurationId rdf:type rdf:Property ;
    rdfs:label 'Cabin Configuration Id' ;
    rdfs:comment 'Unique identifier for the cabin configuration record. Primary key.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CabinConfiguration .

ind:businessClassSeatCount rdf:type rdf:Property ;
    rdfs:label 'Business Class Seat Count' ;
    rdfs:comment 'Number of seats in the Business Class cabin. Zero if Business Class is not offered in this configuration.' ;
    rdfs:domain ind:CabinConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:businessClassSeatPitchInches rdf:type rdf:Property ;
    rdfs:label 'Business Class Seat Pitch Inches' ;
    rdfs:comment 'Average seat pitch in Business Class, measured in inches. Null if Business Class is not offered.' ;
    rdfs:domain ind:CabinConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:businessClassSeatWidthInches rdf:type rdf:Property ;
    rdfs:label 'Business Class Seat Width Inches' ;
    rdfs:comment 'Average seat width in Business Class, measured in inches. Null if Business Class is not offered.' ;
    rdfs:domain ind:CabinConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cabinClassCount rdf:type rdf:Property ;
    rdfs:label 'Cabin Class Count' ;
    rdfs:comment 'Number of distinct cabin classes in this configuration (e.g., 1 for all-economy, 2 for business and economy, 3 for first/business/economy).' ;
    rdfs:domain ind:CabinConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:configurationCode rdf:type rdf:Property ;
    rdfs:label 'Configuration Code' ;
    rdfs:comment 'Unique business identifier for the cabin configuration version (e.g., B738-CFG-A, A320-Y180). Used for operational reference and inventory management.' ;
    rdfs:domain ind:CabinConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configurationName rdf:type rdf:Property ;
    rdfs:label 'Configuration Name' ;
    rdfs:comment 'Human-readable name or description of the cabin configuration (e.g., \'High-Density Economy\', \'Premium Three-Class\').' ;
    rdfs:domain ind:CabinConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configurationStatus rdf:type rdf:Property ;
    rdfs:label 'Configuration Status' ;
    rdfs:comment 'Current lifecycle status of the cabin configuration. Active configurations are in operational use; planned configurations are approved but not yet installed; retired configurations are no longer in service.' ;
    rdfs:domain ind:CabinConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doorCount rdf:type rdf:Property ;
    rdfs:label 'Door Count' ;
    rdfs:comment 'Total number of passenger entry/exit doors in this cabin configuration. Critical for emergency evacuation certification.' ;
    rdfs:domain ind:CabinConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:economySeatCount rdf:type rdf:Property ;
    rdfs:label 'Economy Seat Count' ;
    rdfs:comment 'Number of seats in the Economy (standard coach) cabin.' ;
    rdfs:domain ind:CabinConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:economySeatPitchInches rdf:type rdf:Property ;
    rdfs:label 'Economy Seat Pitch Inches' ;
    rdfs:comment 'Average seat pitch in Economy class, measured in inches.' ;
    rdfs:domain ind:CabinConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:economySeatWidthInches rdf:type rdf:Property ;
    rdfs:label 'Economy Seat Width Inches' ;
    rdfs:comment 'Average seat width in Economy class, measured in inches.' ;
    rdfs:domain ind:CabinConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:firstClassSeatCount rdf:type rdf:Property ;
    rdfs:label 'First Class Seat Count' ;
    rdfs:comment 'Number of seats in the First Class cabin. Zero if First Class is not offered in this configuration.' ;
    rdfs:domain ind:CabinConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:firstClassSeatPitchInches rdf:type rdf:Property ;
    rdfs:label 'First Class Seat Pitch Inches' ;
    rdfs:comment 'Average seat pitch (distance from one seat to the same point on the seat in front) in First Class, measured in inches. Null if First Class is not offered.' ;
    rdfs:domain ind:CabinConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:firstClassSeatWidthInches rdf:type rdf:Property ;
    rdfs:label 'First Class Seat Width Inches' ;
    rdfs:comment 'Average seat width in First Class, measured in inches. Null if First Class is not offered.' ;
    rdfs:domain ind:CabinConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:galleyCount rdf:type rdf:Property ;
    rdfs:label 'Galley Count' ;
    rdfs:comment 'Total number of galleys (food and beverage preparation areas) installed in this cabin configuration.' ;
    rdfs:domain ind:CabinConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ifeSystemType rdf:type rdf:Property ;
    rdfs:label 'Ife System Type' ;
    rdfs:comment 'Type or model of the In-Flight Entertainment system installed (e.g., \'Panasonic eX3\', \'Thales AVANT\', \'Streaming-only\'). Null if no IFE is installed.' ;
    rdfs:domain ind:CabinConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lavatoryCount rdf:type rdf:Property ;
    rdfs:label 'Lavatory Count' ;
    rdfs:comment 'Total number of lavatories (restrooms) installed in this cabin configuration.' ;
    rdfs:domain ind:CabinConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lieFlatSeatAvailable rdf:type rdf:Property ;
    rdfs:label 'Lie Flat Seat Available' ;
    rdfs:comment 'Indicates whether this configuration includes lie-flat seats (typically in First or Business Class). True if any cabin class offers lie-flat capability.' ;
    rdfs:domain ind:CabinConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overwingExitCount rdf:type rdf:Property ;
    rdfs:label 'Overwing Exit Count' ;
    rdfs:comment 'Number of overwing emergency exits in this cabin configuration. Used for evacuation planning and seating restrictions.' ;
    rdfs:domain ind:CabinConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:powerOutletAvailability rdf:type rdf:Property ;
    rdfs:label 'Power Outlet Availability' ;
    rdfs:comment 'Indicates the availability of power outlets (AC or USB) for passenger devices. Values: none (no power outlets), selected_seats (available in premium cabins or select rows), all_seats (available at every seat).' ;
    rdfs:domain ind:CabinConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:premiumEconomySeatCount rdf:type rdf:Property ;
    rdfs:label 'Premium Economy Seat Count' ;
    rdfs:comment 'Number of seats in the Premium Economy cabin. Zero if Premium Economy is not offered in this configuration.' ;
    rdfs:domain ind:CabinConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:premiumEconomySeatPitchInches rdf:type rdf:Property ;
    rdfs:label 'Premium Economy Seat Pitch Inches' ;
    rdfs:comment 'Average seat pitch in Premium Economy, measured in inches. Null if Premium Economy is not offered.' ;
    rdfs:domain ind:CabinConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:premiumEconomySeatWidthInches rdf:type rdf:Property ;
    rdfs:label 'Premium Economy Seat Width Inches' ;
    rdfs:comment 'Average seat width in Premium Economy, measured in inches. Null if Premium Economy is not offered.' ;
    rdfs:domain ind:CabinConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:seatMapReference rdf:type rdf:Property ;
    rdfs:label 'Seat Map Reference' ;
    rdfs:comment 'Reference identifier or URL to the detailed seat map diagram for this configuration. Used by reservation systems and passenger-facing applications.' ;
    rdfs:domain ind:CabinConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalSeatCount rdf:type rdf:Property ;
    rdfs:label 'Total Seat Count' ;
    rdfs:comment 'Total number of passenger seats installed in this cabin configuration across all classes. Critical for revenue management and Available Seat Kilometer (ASK) calculations.' ;
    rdfs:domain ind:CabinConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wifiAvailable rdf:type rdf:Property ;
    rdfs:label 'Wifi Available' ;
    rdfs:comment 'Indicates whether in-flight Wi-Fi connectivity is available in this cabin configuration.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:wifiProvider rdf:type rdf:Property ;
    rdfs:label 'Wifi Provider' ;
    rdfs:comment 'Name of the Wi-Fi service provider (e.g., \'Gogo\', \'Viasat\', \'Panasonic Avionics\'). Null if Wi-Fi is not available.' ;
    rdfs:domain ind:CabinConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engineId rdf:type rdf:Property ;
    rdfs:label 'Engine Id' ;
    rdfs:comment 'Unique identifier for the aircraft engine asset. Primary key for the engine master record.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Engine .

ind:currentStationId rdf:type rdf:Property ;
    rdfs:label 'Current Station Id' ;
    rdfs:comment 'Foreign key linking to airport.station. Business justification: Off-wing engine inventory management and shop visit logistics require station tracking. Spare engine positioning, MRO coordination, and rotable pool management depend on knowing current engine locatio' ;
    rdfs:domain ind:Engine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Station .

ind:responsibleEngineerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Responsible Engineer Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Engine maintenance tracking requires assigned powerplant engineer for shop visit planning, LLP monitoring, performance trend analysis, and MRO provider coordination. Essential for engine reliability p' ;
    rdfs:domain ind:Engine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:cslsvCycles rdf:type rdf:Property ;
    rdfs:label 'Cslsv Cycles' ;
    rdfs:comment 'Flight cycles accumulated since the engine\'s last major shop visit or overhaul. Resets to zero after each shop visit. Used alongside TSLSV for shop visit planning.' ;
    rdfs:domain ind:Engine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:csnCycles rdf:type rdf:Property ;
    rdfs:label 'Csn Cycles' ;
    rdfs:comment 'Total number of flight cycles (takeoff and landing pairs) accumulated by this engine since manufacture. One cycle equals one takeoff-landing sequence. Used for fatigue life tracking.' ;
    rdfs:domain ind:Engine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:currentBookValue rdf:type rdf:Property ;
    rdfs:label 'Current Book Value' ;
    rdfs:comment 'Current depreciated book value of this engine on the airline\'s balance sheet. Updated based on depreciation schedule and any impairment charges. Null if not tracked.' ;
    rdfs:domain ind:Engine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:engineStatus rdf:type rdf:Property ;
    rdfs:label 'Engine Status' ;
    rdfs:comment 'Current operational status of the engine. Installed (on-wing), spare (serviceable spare pool), QEC (Quick Engine Change kit), shop (undergoing MRO), beyond-repair (uneconomical to repair), retired (end of service life), or AOG (Aircraft on Ground - engine causing aircraft grounding). [ENUM-REF-CANDIDATE: installed|spare|QEC|shop|beyond-repair|retired|AOG — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Engine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esn rdf:type rdf:Property ;
    rdfs:label 'Esn' ;
    rdfs:comment 'Manufacturer-assigned unique serial number for this engine. The globally unique identifier used for tracking, MRO, and lease return. Also known as ESN in aviation industry.' ;
    rdfs:domain ind:Engine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:etopsEligible rdf:type rdf:Property ;
    rdfs:label 'Etops Eligible' ;
    rdfs:comment 'Indicates whether this engine meets ETOPS certification requirements for extended over-water or remote area operations. True if engine is ETOPS-certified and current on all ETOPS maintenance requirements.' ;
    rdfs:domain ind:Engine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastShopVisitDate rdf:type rdf:Property ;
    rdfs:label 'Last Shop Visit Date' ;
    rdfs:comment 'Date when this engine completed its most recent major shop visit or overhaul. Used to calculate TSLSV and CSLSV intervals.' ;
    rdfs:domain ind:Engine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastShopVisitType rdf:type rdf:Property ;
    rdfs:label 'Last Shop Visit Type' ;
    rdfs:comment 'Type of maintenance work performed during the last shop visit. Performance restoration (PR), life-limited parts replacement, hot section inspection (HSI), or full overhaul. Determines next shop visit scope.' ;
    rdfs:domain ind:Engine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaseExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Lease Expiry Date' ;
    rdfs:comment 'Date when the current engine lease agreement expires. Critical for return condition planning and lease extension negotiations. Null if engine is owned.' ;
    rdfs:domain ind:Engine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leaseReturnCondition rdf:type rdf:Property ;
    rdfs:label 'Lease Return Condition' ;
    rdfs:comment 'Contractual maintenance condition requirements that must be met when returning this leased engine to the lessor. Typically specifies minimum remaining hours/cycles on LLPs and maintenance status. Null if owned.' ;
    rdfs:domain ind:Engine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:llpLowestRemainingCycles rdf:type rdf:Property ;
    rdfs:label 'Llp Lowest Remaining Cycles' ;
    rdfs:comment 'Remaining cycles until mandatory retirement of the most limiting life-limited part in this engine. Critical for shop visit planning and residual value assessment.' ;
    rdfs:domain ind:Engine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:llpSummary rdf:type rdf:Property ;
    rdfs:label 'Llp Summary' ;
    rdfs:comment 'Summary of remaining cycles for critical life-limited parts (LLP) in this engine. LLPs are components with mandatory retirement life limits due to fatigue considerations. Format typically includes part numbers and remaining cycles.' ;
    rdfs:domain ind:Engine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:melItemCount rdf:type rdf:Property ;
    rdfs:label 'Mel Item Count' ;
    rdfs:comment 'Number of active MEL items currently logged against this engine. Zero indicates no MEL items. Higher counts may indicate declining engine health or deferred maintenance.' ;
    rdfs:domain ind:Engine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:model rdf:type rdf:Property ;
    rdfs:label 'Model' ;
    rdfs:comment 'Specific engine model and variant designation (e.g., CFM56-7B27, LEAP-1A26, Trent 1000, PW4000). Defines thrust rating, fuel efficiency, and maintenance program applicability.' ;
    rdfs:domain ind:Engine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mroProvider rdf:type rdf:Property ;
    rdfs:label 'Mro Provider' ;
    rdfs:comment 'Name of the MRO facility or provider currently responsible for this engine\'s maintenance, or the facility where the engine is currently undergoing shop work. May be OEM, third-party MRO, or airline in-house facility.' ;
    rdfs:domain ind:Engine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextShopVisitDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Shop Visit Due Date' ;
    rdfs:comment 'Planned or forecast date when this engine is scheduled for its next major shop visit or overhaul. Based on maintenance program intervals and current utilization rates.' ;
    rdfs:domain ind:Engine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:position rdf:type rdf:Property ;
    rdfs:label 'Position' ;
    rdfs:comment 'Current position of the engine. For installed engines: 1, 2, 3, or 4 (left to right facing forward). For uninstalled: spare (serviceable spare pool), shop (undergoing MRO), or QEC (Quick Engine Change kit assembly). [ENUM-REF-CANDIDATE: 1|2|3|4|spare|shop|QEC — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Engine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:powerByHourContract rdf:type rdf:Property ;
    rdfs:label 'Power By Hour Contract' ;
    rdfs:comment 'Indicates whether this engine is covered under a power-by-hour (PBH) or similar pay-per-use maintenance contract with the OEM or MRO provider. True if under PBH contract.' ;
    rdfs:domain ind:Engine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:thrustRatingKn rdf:type rdf:Property ;
    rdfs:label 'Thrust Rating Kn' ;
    rdfs:comment 'Maximum certified thrust output of this engine variant measured in kilonewtons (kN). International standard unit for thrust measurement.' ;
    rdfs:domain ind:Engine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:thrustRatingLbf rdf:type rdf:Property ;
    rdfs:label 'Thrust Rating Lbf' ;
    rdfs:comment 'Maximum certified thrust output of this engine variant measured in pounds-force (lbf). Determines aircraft performance capabilities and operational limitations.' ;
    rdfs:domain ind:Engine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tslsvHours rdf:type rdf:Property ;
    rdfs:label 'Tslsv Hours' ;
    rdfs:comment 'Flight hours accumulated since the engine\'s last major shop visit or overhaul. Resets to zero after each shop visit. Used to plan next shop visit interval.' ;
    rdfs:domain ind:Engine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tsnHours rdf:type rdf:Property ;
    rdfs:label 'Tsn Hours' ;
    rdfs:comment 'Total flight hours accumulated by this engine since it was manufactured (Time Since New). Critical metric for life-limited parts tracking and residual value calculation.' ;
    rdfs:domain ind:Engine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warrantyExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Warranty Expiry Date' ;
    rdfs:comment 'Date when the manufacturer\'s warranty coverage for this engine expires. After this date, all maintenance costs are borne by the airline or covered under separate maintenance agreements.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:etopsAuthorizationId rdf:type rdf:Property ;
    rdfs:label 'Etops Authorization Id' ;
    rdfs:comment 'Unique identifier for the ETOPS authorization record. Primary key.' ;
    rdfs:domain ind:EtopsAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:authorizingStationId rdf:type rdf:Property ;
    rdfs:label 'Authorizing Station Id' ;
    rdfs:comment 'Foreign key linking to airport.station. Business justification: ETOPS authorizations often tied to specific maintenance stations with certified capabilities. Regulatory compliance audits and diversion planning require tracking which station holds ETOPS maintenance' ;
    rdfs:domain ind:EtopsAuthorization ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Station .

ind:complianceManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Compliance Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: ETOPS authorizations require named compliance manager for regulatory authority liaison, revalidation application submission, and MEL compliance verification. Essential for extended diversion time oper' ;
    rdfs:domain ind:EtopsAuthorization ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:applicableRoutePairs rdf:type rdf:Property ;
    rdfs:label 'Applicable Route Pairs' ;
    rdfs:comment 'Description of the specific route pairs, city pairs, or geographic areas (e.g., North Atlantic, Pacific) for which this ETOPS authorization is valid. May be a free-text description or reference to an attached route schedule.' ;
    rdfs:domain ind:EtopsAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apuEtopsComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Apu Etops Compliance Flag' ;
    rdfs:comment 'Indicates whether the APU on this aircraft meets ETOPS reliability and operational standards. True if APU is ETOPS-compliant and available for in-flight use; false otherwise.' ;
    rdfs:domain ind:EtopsAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:authorizationStatus rdf:type rdf:Property ;
    rdfs:label 'Authorization Status' ;
    rdfs:comment 'Current lifecycle status of the ETOPS authorization. Active authorizations are valid for dispatch; suspended, expired, or revoked authorizations prohibit ETOPS operations.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cargoFireSuppressionEtopsFlag rdf:type rdf:Property ;
    rdfs:label 'Cargo Fire Suppression Etops Flag' ;
    rdfs:comment 'Indicates whether the cargo compartment fire suppression system meets ETOPS requirements for extended diversion times. True if compliant; false otherwise.' ;
    rdfs:domain ind:EtopsAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:communicationSystemEtopsFlag rdf:type rdf:Property ;
    rdfs:label 'Communication System Etops Flag' ;
    rdfs:comment 'Indicates whether the aircraft communication systems (HF, SATCOM, ACARS) meet ETOPS requirements for extended overwater operations. True if compliant; false otherwise.' ;
    rdfs:domain ind:EtopsAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:diversionTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Diversion Time Minutes' ;
    rdfs:comment 'The maximum approved diversion time in minutes that the aircraft is authorized to operate from the nearest suitable alternate airport. Common values include 120, 138, 180, 207, or 240 minutes.' ;
    rdfs:domain ind:EtopsAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:electricalSystemEtopsFlag rdf:type rdf:Property ;
    rdfs:label 'Electrical System Etops Flag' ;
    rdfs:comment 'Indicates whether the aircraft electrical power generation and distribution systems meet ETOPS redundancy standards. True if compliant; false otherwise.' ;
    rdfs:domain ind:EtopsAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:engineTypeDesignator rdf:type rdf:Property ;
    rdfs:label 'Engine Type Designator' ;
    rdfs:comment 'ICAO or manufacturer engine type designator for the engines installed on this aircraft under this ETOPS authorization (e.g., CFM56-7B, GE90-115B). ETOPS authorization is engine-type specific.' ;
    rdfs:domain ind:EtopsAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelSystemEtopsFlag rdf:type rdf:Property ;
    rdfs:label 'Fuel System Etops Flag' ;
    rdfs:comment 'Indicates whether the aircraft fuel system (including pumps, crossfeed, and monitoring) meets ETOPS reliability and redundancy standards. True if compliant; false otherwise.' ;
    rdfs:domain ind:EtopsAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hydraulicSystemEtopsFlag rdf:type rdf:Property ;
    rdfs:label 'Hydraulic System Etops Flag' ;
    rdfs:comment 'Indicates whether the aircraft hydraulic systems meet ETOPS redundancy and reliability requirements. True if compliant; false otherwise.' ;
    rdfs:domain ind:EtopsAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastComplianceVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Last Compliance Verification Date' ;
    rdfs:comment 'The date of the most recent compliance verification or audit confirming that the aircraft and operator continue to meet ETOPS standards. Used to track ongoing compliance.' ;
    rdfs:domain ind:EtopsAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:melReference rdf:type rdf:Property ;
    rdfs:label 'Mel Reference' ;
    rdfs:comment 'Reference to the specific MEL section or revision that governs ETOPS dispatch requirements for this aircraft. Identifies which equipment must be operational for ETOPS flight.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:navigationSystemEtopsFlag rdf:type rdf:Property ;
    rdfs:label 'Navigation System Etops Flag' ;
    rdfs:comment 'Indicates whether the aircraft navigation systems (FMS, GPS, INS) meet ETOPS accuracy and redundancy requirements. True if compliant; false otherwise.' ;
    rdfs:domain ind:EtopsAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operatorEtopsExperienceLevel rdf:type rdf:Property ;
    rdfs:label 'Operator Etops Experience Level' ;
    rdfs:comment 'The operator\'s ETOPS experience classification at the time of this authorization. Initial operators may have more restrictive conditions; advanced operators may have fewer limitations.' ;
    rdfs:domain ind:EtopsAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeLimitedSystemExtensionMinutes rdf:type rdf:Property ;
    rdfs:label 'Time Limited System Extension Minutes' ;
    rdfs:comment 'For certain ETOPS authorizations, the approved extension time (in minutes) for time-limited systems (e.g., cargo fire suppression discharge time). Nullable if not applicable.' ;
    rdfs:domain ind:EtopsAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fleetPlanId rdf:type rdf:Property ;
    rdfs:label 'Fleet Plan Id' ;
    rdfs:comment 'Reference to the strategic fleet planning scenario that this order supports. Links order to long-term fleet growth, replacement, or renewal strategy.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FleetPlan .

ind:procurementManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Procurement Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Fleet orders require assigned procurement manager for OEM contract negotiation, pricing approval authority, delivery schedule coordination, and purchase order authorization. Essential for procurement ' ;
    rdfs:domain ind:FleetOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:cancellationDate rdf:type rdf:Property ;
    rdfs:label 'Cancellation Date' ;
    rdfs:comment 'Date when the order was officially cancelled or terminated. Null for active orders.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cancellationPenaltyUsd rdf:type rdf:Property ;
    rdfs:label 'Cancellation Penalty Usd' ;
    rdfs:comment 'Financial penalty amount in US Dollars if the order is cancelled before delivery. Defined in contract terms.' ;
    rdfs:domain ind:FleetOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conversionDate rdf:type rdf:Property ;
    rdfs:label 'Conversion Date' ;
    rdfs:comment 'Date when an option or letter of intent was converted to a firm order. Null if order was firm from inception or has not been converted.' ;
    rdfs:domain ind:FleetOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:counterpartyType rdf:type rdf:Property ;
    rdfs:label 'Counterparty Type' ;
    rdfs:comment 'Classification of the counterparty. OEM = Original Equipment Manufacturer (Boeing, Airbus), Lessor = Aircraft leasing company, Broker = Intermediary facilitating the transaction.' ;
    rdfs:domain ind:FleetOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryWindowEndDate rdf:type rdf:Property ;
    rdfs:label 'Delivery Window End Date' ;
    rdfs:comment 'Latest contractual delivery date for aircraft in this order. Defines the end of the delivery period.' ;
    rdfs:domain ind:FleetOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deliveryWindowStartDate rdf:type rdf:Property ;
    rdfs:label 'Delivery Window Start Date' ;
    rdfs:comment 'Earliest contractual delivery date for aircraft in this order. Defines the beginning of the delivery period.' ;
    rdfs:domain ind:FleetOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:depositAmountUsd rdf:type rdf:Property ;
    rdfs:label 'Deposit Amount Usd' ;
    rdfs:comment 'Initial deposit or down payment amount paid to secure the order, in US Dollars. Typically a percentage of total order value.' ;
    rdfs:domain ind:FleetOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financingStructure rdf:type rdf:Property ;
    rdfs:label 'Financing Structure' ;
    rdfs:comment 'Method of financing the aircraft acquisition. Cash = direct purchase, Debt Financing = loan-backed purchase, Sale-Leaseback = sell and lease back, Operating Lease = rental, Finance Lease = lease-to-own, Hybrid = combination of methods.' ;
    rdfs:domain ind:FleetOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:listPricePerUnitUsd rdf:type rdf:Property ;
    rdfs:label 'List Price Per Unit Usd' ;
    rdfs:comment 'Manufacturer\'s published list price per aircraft in US Dollars. This is the catalog price before any negotiated discounts.' ;
    rdfs:domain ind:FleetOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:negotiatedPricePerUnitUsd rdf:type rdf:Property ;
    rdfs:label 'Negotiated Price Per Unit Usd' ;
    rdfs:comment 'Actual negotiated price per aircraft in US Dollars after discounts and concessions. Highly confidential commercial terms. Null if not disclosed or still under negotiation.' ;
    rdfs:domain ind:FleetOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:optionExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Option Expiry Date' ;
    rdfs:comment 'Date by which option rights must be exercised or they expire. Applicable only for orders with option quantities. Null for firm orders.' ;
    rdfs:domain ind:FleetOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:purpose rdf:type rdf:Property ;
    rdfs:label 'Purpose' ;
    rdfs:comment 'Strategic business purpose for the aircraft order. Fleet Growth = net addition to fleet size, Fleet Replacement = replacing retiring aircraft, Fleet Renewal = modernizing existing capacity, Capacity Expansion = increasing seat capacity, Route Expansion = supporting new route network.' ;
    rdfs:domain ind:FleetOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityCancelled rdf:type rdf:Property ;
    rdfs:label 'Quantity Cancelled' ;
    rdfs:comment 'Number of aircraft from this order that have been cancelled or terminated before delivery.' ;
    rdfs:domain ind:FleetOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantityFirm rdf:type rdf:Property ;
    rdfs:label 'Quantity Firm' ;
    rdfs:comment 'Number of aircraft under firm binding commitment. These are contractually committed deliveries.' ;
    rdfs:domain ind:FleetOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantityLoi rdf:type rdf:Property ;
    rdfs:label 'Quantity Loi' ;
    rdfs:comment 'Number of aircraft covered by letter of intent. Non-binding preliminary agreement expressing purchase interest.' ;
    rdfs:domain ind:FleetOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantityOption rdf:type rdf:Property ;
    rdfs:label 'Quantity Option' ;
    rdfs:comment 'Number of aircraft under option rights. Airline has the right but not obligation to purchase at predetermined terms.' ;
    rdfs:domain ind:FleetOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalOrderValueUsd rdf:type rdf:Property ;
    rdfs:label 'Total Order Value Usd' ;
    rdfs:comment 'Total financial value of the entire order in US Dollars. Calculated as quantity times negotiated price (or list price if negotiated not available). Represents total capital commitment.' ;
    rdfs:domain ind:FleetOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Planner Employee Id' ;
    rdfs:comment 'FK to workforce.employee' ;
    rdfs:domain ind:FleetPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:environmentalComplianceTarget rdf:type rdf:Property ;
    rdfs:label 'Environmental Compliance Target' ;
    rdfs:comment 'Environmental performance or compliance target for this aircraft type during the planning period (e.g., CORSIA offset requirements, carbon intensity reduction target, SAF blending percentage).' ;
    rdfs:domain ind:FleetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkDeploymentStrategy rdf:type rdf:Property ;
    rdfs:label 'Network Deployment Strategy' ;
    rdfs:comment 'Strategic deployment approach for this aircraft type (e.g., long-haul international, regional feeder, domestic trunk, point-to-point). Describes the intended network role.' ;
    rdfs:domain ind:FleetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedActiveAircraftCount rdf:type rdf:Property ;
    rdfs:label 'Planned Active Aircraft Count' ;
    rdfs:comment 'Number of aircraft of this type planned to be in active service during the planning period. Represents the core fleet size target for operational planning.' ;
    rdfs:domain ind:FleetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedAsk rdf:type rdf:Property ;
    rdfs:label 'Planned Ask' ;
    rdfs:comment 'Planned Available Seat Kilometers for this aircraft type during the planning period. Represents total capacity supply (seats multiplied by kilometers flown). Fundamental capacity planning metric.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedCapitalExpenditure rdf:type rdf:Property ;
    rdfs:label 'Planned Capital Expenditure' ;
    rdfs:comment 'Total planned capital expenditure for aircraft acquisitions, modifications, or major investments for this aircraft type during the planning period. Supports financial planning and budgeting.' ;
    rdfs:domain ind:FleetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedCaskTarget rdf:type rdf:Property ;
    rdfs:label 'Planned Cask Target' ;
    rdfs:comment 'Target Cost per Available Seat Kilometer for this aircraft type during the planning period. Key unit cost metric for financial planning and fleet efficiency benchmarking.' ;
    rdfs:domain ind:FleetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedDeliveryCount rdf:type rdf:Property ;
    rdfs:label 'Planned Delivery Count' ;
    rdfs:comment 'Number of new aircraft of this type planned to be delivered and inducted into the fleet during the planning period. Supports capital planning and fleet growth analysis.' ;
    rdfs:domain ind:FleetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedDryLeaseInCount rdf:type rdf:Property ;
    rdfs:label 'Planned Dry Lease In Count' ;
    rdfs:comment 'Number of aircraft of this type planned to be dry-leased in (leased without crew) during the planning period. Supports fleet expansion without capital expenditure.' ;
    rdfs:domain ind:FleetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedDryLeaseOutCount rdf:type rdf:Property ;
    rdfs:label 'Planned Dry Lease Out Count' ;
    rdfs:comment 'Number of aircraft of this type planned to be dry-leased out during the planning period. Supports asset monetization strategies.' ;
    rdfs:domain ind:FleetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedOperatingExpense rdf:type rdf:Property ;
    rdfs:label 'Planned Operating Expense' ;
    rdfs:comment 'Total planned operating expenses (fuel, crew, maintenance, insurance, etc.) for this aircraft type during the planning period. Supports cost planning and profitability analysis.' ;
    rdfs:domain ind:FleetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedRaskTarget rdf:type rdf:Property ;
    rdfs:label 'Planned Rask Target' ;
    rdfs:comment 'Target Revenue per Available Seat Kilometer for this aircraft type during the planning period. Key unit revenue metric for revenue management and pricing strategy.' ;
    rdfs:domain ind:FleetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedRetirementCount rdf:type rdf:Property ;
    rdfs:label 'Planned Retirement Count' ;
    rdfs:comment 'Number of aircraft of this type planned to be retired or removed from active service during the planning period. Supports fleet renewal and disposal planning.' ;
    rdfs:domain ind:FleetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedRpk rdf:type rdf:Property ;
    rdfs:label 'Planned Rpk' ;
    rdfs:comment 'Planned Revenue Passenger Kilometers for this aircraft type during the planning period. Represents expected passenger traffic (paying passengers multiplied by kilometers flown).' ;
    rdfs:domain ind:FleetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedTotalBlockHours rdf:type rdf:Property ;
    rdfs:label 'Planned Total Block Hours' ;
    rdfs:comment 'Total planned block hours (gate-to-gate flight time) for all aircraft of this type during the planning period. Supports maintenance planning and crew scheduling.' ;
    rdfs:domain ind:FleetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedTotalCycles rdf:type rdf:Property ;
    rdfs:label 'Planned Total Cycles' ;
    rdfs:comment 'Total planned flight cycles (takeoff and landing pairs) for all aircraft of this type during the planning period. Critical for maintenance interval planning.' ;
    rdfs:domain ind:FleetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedWetLeaseInCount rdf:type rdf:Property ;
    rdfs:label 'Planned Wet Lease In Count' ;
    rdfs:comment 'Number of aircraft of this type planned to be wet-leased in (leased with crew, maintenance, and insurance) during the planning period. Supports flexible capacity planning.' ;
    rdfs:domain ind:FleetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedWetLeaseOutCount rdf:type rdf:Property ;
    rdfs:label 'Planned Wet Lease Out Count' ;
    rdfs:comment 'Number of aircraft of this type planned to be wet-leased out to other carriers during the planning period. Supports asset optimization and revenue diversification.' ;
    rdfs:domain ind:FleetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedYieldTarget rdf:type rdf:Property ;
    rdfs:label 'Planned Yield Target' ;
    rdfs:comment 'Target yield (revenue per Revenue Passenger Kilometer) for this aircraft type during the planning period. Measures pricing effectiveness and revenue quality.' ;
    rdfs:domain ind:FleetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planningAssumptions rdf:type rdf:Property ;
    rdfs:label 'Planning Assumptions' ;
    rdfs:comment 'Key assumptions underlying this fleet plan (e.g., fuel price forecast, demand growth rate, competitive environment, regulatory changes). Provides context for scenario analysis and plan interpretation.' ;
    rdfs:domain ind:FleetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Planning Period End Date' ;
    rdfs:comment 'End date of the planning period covered by this fleet plan record. Defines the conclusion of the time horizon for this plan.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planningPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Planning Period Start Date' ;
    rdfs:comment 'Start date of the planning period covered by this fleet plan record. Defines the beginning of the time horizon for this plan.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planningQuarter rdf:type rdf:Property ;
    rdfs:label 'Planning Quarter' ;
    rdfs:comment 'Calendar quarter (1-4) for which this fleet plan applies. Enables quarterly fleet planning granularity.' ;
    rdfs:domain ind:FleetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:planningYear rdf:type rdf:Property ;
    rdfs:label 'Planning Year' ;
    rdfs:comment 'Calendar year for which this fleet plan applies. Supports year-over-year fleet planning analysis.' ;
    rdfs:domain ind:FleetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:riskAssessmentNotes rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Notes' ;
    rdfs:comment 'Risk factors and mitigation strategies associated with this fleet plan (e.g., delivery delays, market volatility, regulatory uncertainty). Supports risk management and contingency planning.' ;
    rdfs:domain ind:FleetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scenarioName rdf:type rdf:Property ;
    rdfs:label 'Scenario Name' ;
    rdfs:comment 'Name of the planning scenario (e.g., base case, optimistic, pessimistic, high fuel cost, low demand). Identifies the strategic assumptions underlying this fleet plan version.' ;
    rdfs:domain ind:FleetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetLoadFactorPercent rdf:type rdf:Property ;
    rdfs:label 'Target Load Factor Percent' ;
    rdfs:comment 'Target average load factor (percentage of seats filled) for this aircraft type during the planning period. Critical revenue management planning metric.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetUtilizationBlockHoursPerDay rdf:type rdf:Property ;
    rdfs:label 'Target Utilization Block Hours Per Day' ;
    rdfs:comment 'Target average daily block hours (gate-to-gate flight time) per aircraft for this type during the planning period. Key metric for fleet productivity planning.' ;
    rdfs:domain ind:FleetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:columnLetter rdf:type rdf:Property ;
    rdfs:label 'Column Letter' ;
    rdfs:comment 'The alphabetic column identifier for the seat position within the row (A through K). Typically A and K are window seats in wide-body aircraft.' ;
    rdfs:domain ind:SeatMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deck rdf:type rdf:Property ;
    rdfs:label 'Deck' ;
    rdfs:comment 'The deck or level of the aircraft where the seat is located. Relevant for wide-body aircraft with multiple passenger decks.' ;
    rdfs:domain ind:SeatMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:galleyProximity rdf:type rdf:Property ;
    rdfs:label 'Galley Proximity' ;
    rdfs:comment 'Indicates the proximity of the seat to galley (kitchen) facilities. Proximity to galleys can impact passenger experience due to noise and crew activity.' ;
    rdfs:domain ind:SeatMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hasIfe rdf:type rdf:Property ;
    rdfs:label 'Has Ife' ;
    rdfs:comment 'Flag indicating whether the seat is equipped with an in-flight entertainment system. IFE availability is a key amenity for passenger satisfaction and ancillary revenue.' ;
    rdfs:domain ind:SeatMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ifeScreenSizeInches rdf:type rdf:Property ;
    rdfs:label 'Ife Screen Size Inches' ;
    rdfs:comment 'The diagonal screen size in inches of the in-flight entertainment display at this seat. Used for product differentiation and passenger communication.' ;
    rdfs:domain ind:SeatMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isAccessible rdf:type rdf:Property ;
    rdfs:label 'Is Accessible' ;
    rdfs:comment 'Flag indicating whether the seat is designated as accessible for passengers with disabilities or reduced mobility. Accessible seats meet regulatory requirements for space and proximity to facilities.' ;
    rdfs:domain ind:SeatMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isBassinetCapable rdf:type rdf:Property ;
    rdfs:label 'Is Bassinet Capable' ;
    rdfs:comment 'Flag indicating whether the seat position can accommodate an infant bassinet attachment. Typically available at bulkhead seats with sufficient wall space.' ;
    rdfs:domain ind:SeatMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCrewRest rdf:type rdf:Property ;
    rdfs:label 'Is Crew Rest' ;
    rdfs:comment 'Flag indicating whether the seat is designated for crew rest on long-haul flights. Crew rest seats are blocked from passenger assignment and reserved for flight crew during rest periods.' ;
    rdfs:domain ind:SeatMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLastRow rdf:type rdf:Property ;
    rdfs:label 'Is Last Row' ;
    rdfs:comment 'Flag indicating whether the seat is in the last row of the cabin or section. Last row seats often have limited or no recline and proximity to lavatories.' ;
    rdfs:domain ind:SeatMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOverwing rdf:type rdf:Property ;
    rdfs:label 'Is Overwing' ;
    rdfs:comment 'Flag indicating whether the seat is located over the aircraft wing, which may restrict window views. Used for passenger communication and seat selection preferences.' ;
    rdfs:domain ind:SeatMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPreferredSeat rdf:type rdf:Property ;
    rdfs:label 'Is Preferred Seat' ;
    rdfs:comment 'Flag indicating whether the seat is designated as a preferred or premium seat eligible for ancillary seat selection fees. Preferred seats typically offer enhanced comfort or location.' ;
    rdfs:domain ind:SeatMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lavatoryProximity rdf:type rdf:Property ;
    rdfs:label 'Lavatory Proximity' ;
    rdfs:comment 'Indicates the proximity of the seat to lavatory facilities. Proximity to lavatories can be a positive (convenience) or negative (noise, traffic) factor for seat selection.' ;
    rdfs:domain ind:SeatMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reclineAngleDegrees rdf:type rdf:Property ;
    rdfs:label 'Recline Angle Degrees' ;
    rdfs:comment 'The maximum recline angle of the seat in degrees from vertical. Used to communicate seat comfort specifications and differentiate premium products.' ;
    rdfs:domain ind:SeatMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reclineType rdf:type rdf:Property ;
    rdfs:label 'Recline Type' ;
    rdfs:comment 'The recline capability of the seat, ranging from no recline to full lie-flat configurations. Critical for premium cabin differentiation and passenger comfort.' ;
    rdfs:domain ind:SeatMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rowNumber rdf:type rdf:Property ;
    rdfs:label 'Row Number' ;
    rdfs:comment 'The numeric row identifier within the aircraft cabin. Used for seat assignment logic and cabin zone management.' ;
    rdfs:domain ind:SeatMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seatDesignator rdf:type rdf:Property ;
    rdfs:label 'Seat Designator' ;
    rdfs:comment 'The unique seat identifier within the aircraft, combining row number and column letter (e.g., 12A, 34F). This is the seat label passengers see on their boarding pass.' ;
    rdfs:domain ind:SeatMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seatFeeTier rdf:type rdf:Property ;
    rdfs:label 'Seat Fee Tier' ;
    rdfs:comment 'The pricing tier for ancillary seat selection fees. Used by revenue management systems to price seat assignments and optimize ancillary revenue.' ;
    rdfs:domain ind:SeatMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seatMapStatus rdf:type rdf:Property ;
    rdfs:label 'Seat Map Status' ;
    rdfs:comment 'The current lifecycle status of the seat map record. Indicates whether the seat configuration is currently in use, pending activation, or retired.' ;
    rdfs:domain ind:SeatMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageRestriction rdf:type rdf:Property ;
    rdfs:label 'Storage Restriction' ;
    rdfs:comment 'Indicates any restrictions on carry-on baggage storage at this seat location. Some seats (e.g., bulkhead, exit row) have limited under-seat or overhead storage.' ;
    rdfs:domain ind:SeatMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acarsMessageId rdf:type rdf:Property ;
    rdfs:label 'Acars Message Id' ;
    rdfs:comment 'Unique identifier for the ACARS message record. Primary key.' ;
    rdfs:domain ind:AcarsMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:oooiEventId rdf:type rdf:Property ;
    rdfs:label 'Oooi Event Id' ;
    rdfs:comment 'Foreign key linking to flight.oooi_event. Business justification: ACARS messages with oooi_event_type populated are specifically OOOI event reports (Out-Off-On-In gate/runway timestamps). When an ACARS message IS an OOOI event report, it should FK to the oooi_event ' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OooiEvent .

ind:acknowledgementRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Required Flag' ;
    rdfs:comment 'Indicates whether the message requires an acknowledgement response from the receiving party.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:acknowledgementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Timestamp' ;
    rdfs:comment 'UTC timestamp when the acknowledgement was received for this message. Null if no acknowledgement required or not yet received.' ;
    rdfs:domain ind:AcarsMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:altitudeFeet rdf:type rdf:Property ;
    rdfs:label 'Altitude Feet' ;
    rdfs:comment 'Aircraft altitude in feet above mean sea level at the time of message transmission. Populated for position report and engine data messages.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:blockNumber rdf:type rdf:Property ;
    rdfs:label 'Block Number' ;
    rdfs:comment 'Block identifier used in ACARS protocol for message segmentation and reassembly when messages exceed single transmission size.' ;
    rdfs:domain ind:AcarsMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataLinkServiceProvider rdf:type rdf:Property ;
    rdfs:label 'Data Link Service Provider' ;
    rdfs:comment 'Communication service provider or medium used for ACARS message transmission (SITA network, ARINC network, satellite communication, VHF radio, or HF radio).' ;
    rdfs:domain ind:AcarsMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:errorCode rdf:type rdf:Property ;
    rdfs:label 'Error Code' ;
    rdfs:comment 'Error code indicating transmission or processing failure, if applicable. Null for successful messages.' ;
    rdfs:domain ind:AcarsMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flightPhase rdf:type rdf:Property ;
    rdfs:label 'Flight Phase' ;
    rdfs:comment 'Phase of flight during which the ACARS message was transmitted, derived from OOOI events and flight profile data. [ENUM-REF-CANDIDATE: pre_departure|taxi_out|takeoff|climb|cruise|descent|approach|landing|taxi_in|post_arrival — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groundSpeedKnots rdf:type rdf:Property ;
    rdfs:label 'Ground Speed Knots' ;
    rdfs:comment 'Aircraft ground speed in knots at the time of message transmission. Populated for position report messages.' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:messageContent rdf:type rdf:Property ;
    rdfs:label 'Message Content' ;
    rdfs:comment 'Full text payload of the ACARS message containing the transmitted data, parameters, or free-text communication.' ;
    rdfs:domain ind:AcarsMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:messageDirection rdf:type rdf:Property ;
    rdfs:label 'Message Direction' ;
    rdfs:comment 'Direction of message transmission: uplink (ground to aircraft) or downlink (aircraft to ground).' ;
    rdfs:domain ind:AcarsMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:messageLabel rdf:type rdf:Property ;
    rdfs:label 'Message Label' ;
    rdfs:comment 'Two-character ARINC 618 message label code that identifies the message category and routing (e.g., H1 for OOOI, 44 for free text, B6 for position report).' ;
    rdfs:domain ind:AcarsMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:messageSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Message Sequence Number' ;
    rdfs:comment 'Sequential number assigned to the message within the flight leg or transmission session for ordering and duplicate detection.' ;
    rdfs:domain ind:AcarsMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:messageSizeBytes rdf:type rdf:Property ;
    rdfs:label 'Message Size Bytes' ;
    rdfs:comment 'Size of the ACARS message payload in bytes.' ;
    rdfs:domain ind:AcarsMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:oooiEventType rdf:type rdf:Property ;
    rdfs:label 'Oooi Event Type' ;
    rdfs:comment 'Specific OOOI gate event captured in this message: OUT (pushback from gate), OFF (wheels up/takeoff), ON (wheels down/landing), IN (arrival at gate). Populated only for OOOI message types.' ;
    rdfs:domain ind:AcarsMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionLatitude rdf:type rdf:Property ;
    rdfs:label 'Position Latitude' ;
    rdfs:comment 'Latitude coordinate of the aircraft position at the time of message transmission, in decimal degrees. Populated for position report messages.' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:positionLongitude rdf:type rdf:Property ;
    rdfs:label 'Position Longitude' ;
    rdfs:comment 'Longitude coordinate of the aircraft position at the time of message transmission, in decimal degrees. Populated for position report messages.' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receiptTimestamp rdf:type rdf:Property ;
    rdfs:label 'Receipt Timestamp' ;
    rdfs:comment 'UTC timestamp when the ACARS message was received by the ground station or aircraft system.' ;
    rdfs:domain ind:AcarsMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:retryCount rdf:type rdf:Property ;
    rdfs:label 'Retry Count' ;
    rdfs:comment 'Number of transmission retry attempts for this message due to delivery failures or acknowledgement timeouts.' ;
    rdfs:domain ind:AcarsMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transmissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transmission Timestamp' ;
    rdfs:comment 'UTC timestamp when the ACARS message was transmitted from the aircraft or ground station.' ;
    rdfs:domain ind:AcarsMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:delayRecordId rdf:type rdf:Property ;
    rdfs:label 'Delay Record Id' ;
    rdfs:comment 'Unique identifier for the delay record. Primary key.' ;
    rdfs:domain ind:DelayRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryDelayVerifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Delay Verified By User Employee Id' ;
    rdfs:comment 'User identifier of the supervisor or quality assurance staff member who verified and approved this delay record. Used for data quality control and compliance auditing.' ;
    rdfs:domain ind:DelayRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:responsibleStationId rdf:type rdf:Property ;
    rdfs:label 'Responsible Station Id' ;
    rdfs:comment 'Foreign key linking to airport.station. Business justification: Delay accountability requires linking to responsible station entity for performance tracking, cost allocation of controllable delays, station manager accountability, and regulatory DOT reporting by st' ;
    rdfs:domain ind:DelayRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Station .

ind:affectedPassengerCount rdf:type rdf:Property ;
    rdfs:label 'Affected Passenger Count' ;
    rdfs:comment 'Number of passengers (Pax) affected by this delay event. Used for customer impact assessment and compensation calculations.' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:compensationIssuedFlag rdf:type rdf:Property ;
    rdfs:label 'Compensation Issued Flag' ;
    rdfs:comment 'Boolean flag indicating whether passenger compensation (monetary or vouchers) was issued as a result of this delay under EU261, DOT, or airline policy. True if compensation issued, False if not.' ;
    rdfs:domain ind:DelayRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Data Source System' ;
    rdfs:comment 'Identifier of the source system from which this delay record originated (e.g., Lufthansa Systems NetLine/Ops, Jeppesen Flight Planning, manual entry by operations staff, ACARS messaging, or other systems).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:delayCategory rdf:type rdf:Property ;
    rdfs:label 'Delay Category' ;
    rdfs:comment 'High-level classification of the delay cause: airline operational issues, ATC (Air Traffic Control) restrictions, airport facility problems, weather conditions, passenger-related issues, reactionary delays from late inbound aircraft, security events, or other causes. [ENUM-REF-CANDIDATE: airline_operational|air_traffic_control|airport_facilities|weather|passenger_related|reactionary|security|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DelayRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:delayCostEstimateUsd rdf:type rdf:Property ;
    rdfs:label 'Delay Cost Estimate Usd' ;
    rdfs:comment 'Estimated financial cost of the delay in US dollars, including crew overtime, passenger compensation, fuel burn, missed connections, and operational disruption. Used for cost-benefit analysis and delay reduction initiatives.' ;
    rdfs:domain ind:DelayRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:delayDescription rdf:type rdf:Property ;
    rdfs:label 'Delay Description' ;
    rdfs:comment 'Free-text narrative description providing detailed context and explanation of the delay event, root cause, and any corrective actions taken.' ;
    rdfs:domain ind:DelayRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:delayEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Delay End Timestamp' ;
    rdfs:comment 'Timestamp marking the resolution or end of the delay event in UTC. Nullable if delay is ongoing or not yet resolved.' ;
    rdfs:domain ind:DelayRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:delayNotificationSentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Delay Notification Sent Timestamp' ;
    rdfs:comment 'Timestamp when delay notification was sent to passengers via SMS, email, or mobile app. Used to measure compliance with customer communication standards.' ;
    rdfs:domain ind:DelayRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:delaySequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Delay Sequence Number' ;
    rdfs:comment 'Sequential ordering of multiple delay events for the same flight leg. Allows tracking of multiple delay causes on a single flight.' ;
    rdfs:domain ind:DelayRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:delayStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Delay Start Timestamp' ;
    rdfs:comment 'Timestamp marking the beginning of the delay event in UTC. Used to calculate delay duration and analyze delay patterns by time of day.' ;
    rdfs:domain ind:DelayRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:delayStatus rdf:type rdf:Property ;
    rdfs:label 'Delay Status' ;
    rdfs:comment 'Current lifecycle status of the delay record: open (delay ongoing), resolved (delay ended), under investigation (root cause analysis in progress), closed (finalized and archived), or disputed (under review or challenge).' ;
    rdfs:domain ind:DelayRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:delayVerificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Delay Verification Timestamp' ;
    rdfs:comment 'Timestamp when the delay record was verified and approved by a supervisor. Nullable if verification is pending.' ;
    rdfs:domain ind:DelayRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isControllableDelay rdf:type rdf:Property ;
    rdfs:label 'Is Controllable Delay' ;
    rdfs:comment 'Boolean flag indicating whether the delay was within the airline\'s control (e.g., maintenance, crew scheduling) versus external factors (e.g., weather, ATC). Used for internal performance accountability and root cause analysis.' ;
    rdfs:domain ind:DelayRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReactionaryDelay rdf:type rdf:Property ;
    rdfs:label 'Is Reactionary Delay' ;
    rdfs:comment 'Boolean flag indicating whether this delay was reactionary (caused by a late inbound aircraft from a previous flight leg). True if reactionary, False if not.' ;
    rdfs:domain ind:DelayRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReportableToDot rdf:type rdf:Property ;
    rdfs:label 'Is Reportable To Dot' ;
    rdfs:comment 'Boolean flag indicating whether this delay must be reported to the US Department of Transportation under 14 CFR Part 234 (applies to delays of 15 minutes or more for covered carriers). True if reportable, False if not.' ;
    rdfs:domain ind:DelayRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:missedConnectionCount rdf:type rdf:Property ;
    rdfs:label 'Missed Connection Count' ;
    rdfs:comment 'Number of passengers who missed their connecting flights as a result of this delay. Used for IROP (Irregular Operations) management and customer service planning.' ;
    rdfs:domain ind:DelayRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryDelayCode rdf:type rdf:Property ;
    rdfs:label 'Primary Delay Code' ;
    rdfs:comment 'Two-digit IATA delay code representing the primary cause of the delay per AHM 730 standard (e.g., 11=Aircraft defects, 31=Flight deck crew, 81=Weather).' ;
    rdfs:domain ind:DelayRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordLastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Last Updated Timestamp' ;
    rdfs:comment 'Timestamp when this delay record was last modified. Used for audit trail and change tracking.' ;
    rdfs:domain ind:DelayRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:responsibleDepartmentCode rdf:type rdf:Property ;
    rdfs:label 'Responsible Department Code' ;
    rdfs:comment 'Internal department code identifying the organizational unit responsible for or associated with the delay (e.g., MX=Maintenance, OPS=Operations, CREW=Crew Scheduling, GND=Ground Handling).' ;
    rdfs:domain ind:DelayRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondaryDelayCode rdf:type rdf:Property ;
    rdfs:label 'Secondary Delay Code' ;
    rdfs:comment 'Two-digit IATA delay code representing a secondary contributing cause of the delay per AHM 730 standard. Nullable if only one cause exists.' ;
    rdfs:domain ind:DelayRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatchReleaseId rdf:type rdf:Property ;
    rdfs:label 'Dispatch Release Id' ;
    rdfs:comment 'Unique identifier for the dispatch release document. Primary key for the dispatch release entity.' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DispatchRelease .

ind:flightPlanId rdf:type rdf:Property ;
    rdfs:label 'Flight Plan Id' ;
    rdfs:comment 'Foreign key linking to flight.flight_plan. Business justification: Dispatch release is based on and references a specific flight plan version. The dispatcher reviews the flight plan and issues the release authorizing departure. This is a core operational relationship' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FlightPlan .

ind:supersededByReleaseDispatchReleaseId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Release Dispatch Release Id' ;
    rdfs:comment 'Reference to the dispatch release that superseded this one, if applicable. Used to track release amendment history.' ;
    rdfs:domain ind:DispatchRelease ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DispatchRelease .

ind:additionalFuelKg rdf:type rdf:Property ;
    rdfs:label 'Additional Fuel Kg' ;
    rdfs:comment 'Extra fuel added at captain or dispatcher discretion beyond regulatory minimums for operational flexibility, measured in kilograms.' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alternateAirport1Icao rdf:type rdf:Property ;
    rdfs:label 'Alternate Airport 1 Icao' ;
    rdfs:comment 'Four-letter ICAO code of the primary alternate airport designated in case destination is unavailable.' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alternateAirport2Icao rdf:type rdf:Property ;
    rdfs:label 'Alternate Airport 2 Icao' ;
    rdfs:comment 'Four-letter ICAO code of the secondary alternate airport if required by operational conditions or regulations.' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alternateFuelKg rdf:type rdf:Property ;
    rdfs:label 'Alternate Fuel Kg' ;
    rdfs:comment 'Fuel required to fly from destination to the designated alternate airport, measured in kilograms.' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:captainName rdf:type rdf:Property ;
    rdfs:label 'Captain Name' ;
    rdfs:comment 'Full name of the pilot-in-command who accepted this dispatch release.' ;
    rdfs:domain ind:DispatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:captainSignoffTimestamp rdf:type rdf:Property ;
    rdfs:label 'Captain Signoff Timestamp' ;
    rdfs:comment 'Date and time when the captain electronically accepted and co-signed the dispatch release, indicating agreement with flight plan and operational conditions.' ;
    rdfs:domain ind:DispatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:contingencyFuelKg rdf:type rdf:Property ;
    rdfs:label 'Contingency Fuel Kg' ;
    rdfs:comment 'Additional fuel to account for unforeseen factors such as weather deviations or ATC (Air Traffic Control) routing changes, typically 5% of trip fuel or 5 minutes holding, measured in kilograms.' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departureAirportIcao rdf:type rdf:Property ;
    rdfs:label 'Departure Airport Icao' ;
    rdfs:comment 'Four-letter ICAO code of the departure airport for this flight leg.' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departureMetar rdf:type rdf:Property ;
    rdfs:label 'Departure Metar' ;
    rdfs:comment 'Current METAR weather observation for the departure airport at time of dispatch release issuance.' ;
    rdfs:domain ind:DispatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationAirportIcao rdf:type rdf:Property ;
    rdfs:label 'Destination Airport Icao' ;
    rdfs:comment 'Four-letter ICAO code of the destination airport for this flight leg.' ;
    rdfs:domain ind:DispatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationMetar rdf:type rdf:Property ;
    rdfs:label 'Destination Metar' ;
    rdfs:comment 'Current METAR weather observation for the destination airport at time of dispatch release issuance.' ;
    rdfs:domain ind:DispatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationTaf rdf:type rdf:Property ;
    rdfs:label 'Destination Taf' ;
    rdfs:comment 'Terminal Aerodrome Forecast for the destination airport covering the estimated time of arrival window.' ;
    rdfs:domain ind:DispatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatcherLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Dispatcher License Number' ;
    rdfs:comment 'FAA or EASA license number of the dispatcher who authorized this release. Required for regulatory compliance.' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatcherName rdf:type rdf:Property ;
    rdfs:label 'Dispatcher Name' ;
    rdfs:comment 'Full name of the certified flight dispatcher who issued this dispatch release.' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatcherSignoffTimestamp rdf:type rdf:Property ;
    rdfs:label 'Dispatcher Signoff Timestamp' ;
    rdfs:comment 'Date and time when the dispatcher electronically signed and approved the dispatch release.' ;
    rdfs:domain ind:DispatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:estimatedBlockTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Estimated Block Time Minutes' ;
    rdfs:comment 'Estimated total block time from gate departure (out) to gate arrival (in), measured in minutes.' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedFlightTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Estimated Flight Time Minutes' ;
    rdfs:comment 'Estimated total flight time from takeoff to landing, measured in minutes.' ;
    rdfs:domain ind:DispatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:etopsAuthorizationFlag rdf:type rdf:Property ;
    rdfs:label 'Etops Authorization Flag' ;
    rdfs:comment 'Indicates whether this flight is authorized for ETOPS operations (extended-range twin-engine flight over water or remote areas).' ;
    rdfs:domain ind:DispatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:etopsEntryPoint rdf:type rdf:Property ;
    rdfs:label 'Etops Entry Point' ;
    rdfs:comment 'Geographic waypoint or coordinate where the flight enters ETOPS airspace, if applicable.' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:etopsExitPoint rdf:type rdf:Property ;
    rdfs:label 'Etops Exit Point' ;
    rdfs:comment 'Geographic waypoint or coordinate where the flight exits ETOPS airspace, if applicable.' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finalReserveFuelKg rdf:type rdf:Property ;
    rdfs:label 'Final Reserve Fuel Kg' ;
    rdfs:comment 'Minimum fuel that must remain on board upon landing at the alternate airport, typically 30 minutes holding at 1500 feet above alternate, measured in kilograms.' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatOnboardFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Onboard Flag' ;
    rdfs:comment 'Indicates whether dangerous goods or hazardous materials are being carried on this flight, requiring special handling and documentation.' ;
    rdfs:domain ind:DispatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:landingWeightKg rdf:type rdf:Property ;
    rdfs:label 'Landing Weight Kg' ;
    rdfs:comment 'Planned aircraft landing weight at destination, measured in kilograms.' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:melItemsAcceptedCount rdf:type rdf:Property ;
    rdfs:label 'Mel Items Accepted Count' ;
    rdfs:comment 'Number of MEL (Minimum Equipment List) deferred maintenance items accepted and documented in this dispatch release, allowing flight with specific inoperative equipment.' ;
    rdfs:domain ind:DispatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:melItemsSummary rdf:type rdf:Property ;
    rdfs:label 'Mel Items Summary' ;
    rdfs:comment 'Textual summary of all MEL items accepted for this flight, including item numbers, descriptions, and operational limitations.' ;
    rdfs:domain ind:DispatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumFuelKg rdf:type rdf:Property ;
    rdfs:label 'Minimum Fuel Kg' ;
    rdfs:comment 'Regulatory minimum fuel quantity required for this flight considering all fuel policy components, measured in kilograms.' ;
    rdfs:domain ind:DispatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:notamBriefingPackage rdf:type rdf:Property ;
    rdfs:label 'Notam Briefing Package' ;
    rdfs:comment 'Comprehensive text package of all relevant NOTAMs (Notices to Air Missions) for departure, en-route, destination, and alternate airports with operational significance flags.' ;
    rdfs:domain ind:DispatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passengerCount rdf:type rdf:Property ;
    rdfs:label 'Passenger Count' ;
    rdfs:comment 'Total number of passengers planned to be carried on this flight at time of dispatch release.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedCruiseAltitudeFt rdf:type rdf:Property ;
    rdfs:label 'Planned Cruise Altitude Ft' ;
    rdfs:comment 'Planned cruising altitude for this flight leg, measured in feet above mean sea level.' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedCruiseSpeedKts rdf:type rdf:Property ;
    rdfs:label 'Planned Cruise Speed Kts' ;
    rdfs:comment 'Planned true airspeed during cruise phase, measured in knots.' ;
    rdfs:domain ind:DispatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedFuelUpliftKg rdf:type rdf:Property ;
    rdfs:label 'Planned Fuel Uplift Kg' ;
    rdfs:comment 'Total quantity of fuel planned to be loaded onto the aircraft for this flight, measured in kilograms.' ;
    rdfs:domain ind:DispatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:releaseIssuedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Release Issued Timestamp' ;
    rdfs:comment 'Date and time when the dispatch release was officially issued and authorized for flight departure. Principal business event timestamp for this regulatory document.' ;
    rdfs:domain ind:DispatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:releaseNumber rdf:type rdf:Property ;
    rdfs:label 'Release Number' ;
    rdfs:comment 'Official externally-known dispatch release document number assigned by flight operations control. Unique business identifier for regulatory traceability.' ;
    rdfs:domain ind:DispatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseStatus rdf:type rdf:Property ;
    rdfs:label 'Release Status' ;
    rdfs:comment 'Current lifecycle status of the dispatch release document in the authorization workflow.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseVersionNumber rdf:type rdf:Property ;
    rdfs:label 'Release Version Number' ;
    rdfs:comment 'Version number of this dispatch release if it has been amended or superseded after initial issuance.' ;
    rdfs:domain ind:DispatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:routeDescription rdf:type rdf:Property ;
    rdfs:label 'Route Description' ;
    rdfs:comment 'Detailed flight route including airways, waypoints, and navigation fixes from departure to destination.' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialHandlingNotes rdf:type rdf:Property ;
    rdfs:label 'Special Handling Notes' ;
    rdfs:comment 'Free-text field for any special operational considerations, restrictions, or handling instructions for this flight.' ;
    rdfs:domain ind:DispatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:takeoffWeightKg rdf:type rdf:Property ;
    rdfs:label 'Takeoff Weight Kg' ;
    rdfs:comment 'Planned aircraft takeoff weight including fuel, payload, and operating empty weight, measured in kilograms.' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tripFuelKg rdf:type rdf:Property ;
    rdfs:label 'Trip Fuel Kg' ;
    rdfs:comment 'Fuel required to fly from departure to destination under planned conditions, measured in kilograms.' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weatherBriefingPackage rdf:type rdf:Property ;
    rdfs:label 'Weather Briefing Package' ;
    rdfs:comment 'Comprehensive weather briefing including METARs (Meteorological Aerodrome Reports), TAFs (Terminal Aerodrome Forecasts), SIGMETs (Significant Meteorological Information), PIREPs (Pilot Reports), and winds-aloft data for all relevant stations.' ;
    rdfs:domain ind:DispatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zeroFuelWeightKg rdf:type rdf:Property ;
    rdfs:label 'Zero Fuel Weight Kg' ;
    rdfs:comment 'Aircraft weight excluding all usable fuel, including operating empty weight and payload, measured in kilograms.' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diversionId rdf:type rdf:Property ;
    rdfs:label 'Diversion Id' ;
    rdfs:comment 'Unique identifier for the flight diversion event. Primary key.' ;
    rdfs:domain ind:Diversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:decisionAuthorityEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Decision Authority Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Diversion decisions require named authority for regulatory accountability (FAA/EASA reporting). Operations Control Center duty managers or dispatchers make diversion calls; tracking the specific emplo' ;
    rdfs:domain ind:Diversion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualGateArrivalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Gate Arrival Timestamp' ;
    rdfs:comment 'Date and time when the aircraft arrived at the gate at the diversion airport. Completes the In event of OOOI tracking. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Diversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualLandingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Landing Timestamp' ;
    rdfs:comment 'Date and time when the aircraft touched down at the diversion airport. Part of OOOI (Out-Off-On-In) event tracking. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Diversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:airportIcaoCode rdf:type rdf:Property ;
    rdfs:label 'Airport Icao Code' ;
    rdfs:comment 'Four-letter ICAO airport code of the diversion airport. Provides international standard identifier for flight planning and ATC coordination.' ;
    rdfs:domain ind:Diversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:atcCoordinationReference rdf:type rdf:Property ;
    rdfs:label 'Atc Coordination Reference' ;
    rdfs:comment 'Reference number or identifier provided by Air Traffic Control (ATC) for the diversion coordination. Used for operational tracking and incident investigation.' ;
    rdfs:domain ind:Diversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compensationEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Compensation Eligibility Flag' ;
    rdfs:comment 'Indicates whether passengers are eligible for monetary compensation under applicable passenger rights regulations due to the diversion. True if eligible; False otherwise.' ;
    rdfs:domain ind:Diversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:continuationDepartureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Continuation Departure Timestamp' ;
    rdfs:comment 'Date and time when the continuation flight departed from the diversion airport toward the original destination. Null if no continuation occurred. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Diversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:continuationFlightNumber rdf:type rdf:Property ;
    rdfs:label 'Continuation Flight Number' ;
    rdfs:comment 'Flight number assigned to the continuation flight if the aircraft or passengers continued to the original destination after the diversion. Null if flight was cancelled or returned to origin.' ;
    rdfs:domain ind:Diversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costImpactCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Cost Impact Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the estimated cost impact amount.' ;
    rdfs:domain ind:Diversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crewDutyTimeImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Crew Duty Time Impact Flag' ;
    rdfs:comment 'Indicates whether the diversion caused crew duty time or flight time limitations to be exceeded or approached, requiring crew replacement or schedule adjustments. True if impacted; False otherwise.' ;
    rdfs:domain ind:Diversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:decisionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Decision Timestamp' ;
    rdfs:comment 'Date and time when the decision to divert was made by the pilot-in-command or operational control. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dispatchReleaseUpdatedFlag rdf:type rdf:Property ;
    rdfs:label 'Dispatch Release Updated Flag' ;
    rdfs:comment 'Indicates whether a new or amended dispatch release was issued for the continuation flight from the diversion airport. True if updated; False otherwise.' ;
    rdfs:domain ind:Diversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dispositionAction rdf:type rdf:Property ;
    rdfs:label 'Disposition Action' ;
    rdfs:comment 'Subsequent operational action taken after landing at the diversion airport. Continued_to_destination indicates flight resumed to original destination; returned_to_origin indicates flight returned to departure airport; cancelled indicates flight was terminated; aircraft_swap indicates passengers transferred to another aircraft; overnight_recovery indicates passengers accommodated overnight.' ;
    rdfs:domain ind:Diversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diversionNumber rdf:type rdf:Property ;
    rdfs:label 'Diversion Number' ;
    rdfs:comment 'Business identifier for the diversion event, used for operational tracking and reporting. Format: DIV followed by numeric sequence.' ;
    rdfs:domain ind:Diversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diversionStatus rdf:type rdf:Property ;
    rdfs:label 'Diversion Status' ;
    rdfs:comment 'Current lifecycle status of the diversion event. Tracks progression from initial declaration through resolution.' ;
    rdfs:domain ind:Diversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelUpliftAtDiversionKg rdf:type rdf:Property ;
    rdfs:label 'Fuel Uplift At Diversion Kg' ;
    rdfs:comment 'Amount of fuel uplifted at the diversion airport in kilograms. Required if the aircraft continued to the original destination or another airport after the diversion.' ;
    rdfs:domain ind:Diversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:groundTimeDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Ground Time Duration Minutes' ;
    rdfs:comment 'Total time in minutes that the aircraft spent on the ground at the diversion airport, from gate arrival to departure (if continuation occurred) or final shutdown.' ;
    rdfs:domain ind:Diversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hotelAccommodationProvidedFlag rdf:type rdf:Property ;
    rdfs:label 'Hotel Accommodation Provided Flag' ;
    rdfs:comment 'Indicates whether hotel accommodation was provided to passengers due to the diversion. True if accommodation was arranged; False otherwise.' ;
    rdfs:domain ind:Diversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mealVoucherProvidedFlag rdf:type rdf:Property ;
    rdfs:label 'Meal Voucher Provided Flag' ;
    rdfs:comment 'Indicates whether meal vouchers or meals were provided to passengers due to the diversion. True if meals were provided; False otherwise.' ;
    rdfs:domain ind:Diversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notamReference rdf:type rdf:Property ;
    rdfs:label 'Notam Reference' ;
    rdfs:comment 'Reference to any relevant NOTAM (Notice to Air Missions) that contributed to or was issued in relation to the diversion event.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passengerCareActionTaken rdf:type rdf:Property ;
    rdfs:label 'Passenger Care Action Taken' ;
    rdfs:comment 'Description of passenger care actions provided at the diversion airport, including meals, accommodation, rebooking, ground transportation, and communication. Documents compliance with passenger rights regulations.' ;
    rdfs:domain ind:Diversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passengerCountDiverted rdf:type rdf:Property ;
    rdfs:label 'Passenger Count Diverted' ;
    rdfs:comment 'Total number of passengers (Pax) on board the aircraft at the time of diversion. Used for passenger care planning and regulatory reporting.' ;
    rdfs:domain ind:Diversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedDestinationAirportCode rdf:type rdf:Property ;
    rdfs:label 'Planned Destination Airport Code' ;
    rdfs:comment 'Three-letter IATA airport code of the original planned destination airport before diversion was declared.' ;
    rdfs:domain ind:Diversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Required Flag' ;
    rdfs:comment 'Indicates whether the diversion event requires formal reporting to aviation regulatory authorities (FAA, EASA, national CAA). True if reporting is required; False otherwise.' ;
    rdfs:domain ind:Diversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryReportSubmittedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Submitted Timestamp' ;
    rdfs:comment 'Date and time when the required regulatory report was submitted to the aviation authority. Null if no report was required or not yet submitted. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Diversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:safetyReportReference rdf:type rdf:Property ;
    rdfs:label 'Safety Report Reference' ;
    rdfs:comment 'Reference number of any safety report filed in the airline\'s Safety Management System (SMS) related to the diversion event. Used for safety trend analysis and continuous improvement.' ;
    rdfs:domain ind:Diversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationId rdf:type rdf:Property ;
    rdfs:label 'Cancellation Id' ;
    rdfs:comment 'Unique identifier for the flight cancellation record. Primary key.' ;
    rdfs:domain ind:Cancellation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:authorityEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Authority Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Flight cancellations require named decision authority for financial accountability (revenue impact tracking), regulatory reporting (DOT on-time performance), and union grievance defense. Current cance' ;
    rdfs:domain ind:Cancellation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:advanceNoticeHours rdf:type rdf:Property ;
    rdfs:label 'Advance Notice Hours' ;
    rdfs:comment 'Number of hours between cancellation decision and scheduled departure time. Critical for determining passenger compensation eligibility under EU261 (14-day, 7-day thresholds).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationType rdf:type rdf:Property ;
    rdfs:label 'Cancellation Type' ;
    rdfs:comment 'Whether the cancellation was proactive (planned in advance to minimize disruption) or reactive (last-minute response to an operational event).' ;
    rdfs:domain ind:Cancellation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compensationAmountPerPassenger rdf:type rdf:Property ;
    rdfs:label 'Compensation Amount Per Passenger' ;
    rdfs:comment 'Standard compensation amount per passenger under applicable regulations (e.g., EUR 250/400/600 under EU261 based on distance and delay).' ;
    rdfs:domain ind:Cancellation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compensationEligibilityStatus rdf:type rdf:Property ;
    rdfs:label 'Compensation Eligibility Status' ;
    rdfs:comment 'Status of passenger compensation eligibility determination under applicable regulations (EU261, DOT, local regulations).' ;
    rdfs:domain ind:Cancellation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crewLegalityIssue rdf:type rdf:Property ;
    rdfs:label 'Crew Legality Issue' ;
    rdfs:comment 'Type of crew legality or availability issue that caused the cancellation (DUTY_TIME=exceeded duty limits, REST=insufficient rest, QUALIFICATION=crew not qualified, AVAILABILITY=crew unavailable, POSITIONING=crew positioning failure).' ;
    rdfs:domain ind:Cancellation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveTimestamp rdf:type rdf:Property ;
    rdfs:label 'Effective Timestamp' ;
    rdfs:comment 'Date and time when the cancellation became effective in operational systems and passenger notifications were triggered.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:estimatedRevenueImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Revenue Impact Amount' ;
    rdfs:comment 'Estimated revenue loss from the cancelled flight including ticket revenue, ancillary revenue, and potential future booking impact.' ;
    rdfs:domain ind:Cancellation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:firstNotificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'First Notification Timestamp' ;
    rdfs:comment 'Date and time when the first passenger notification was sent regarding the cancellation.' ;
    rdfs:domain ind:Cancellation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isControllable rdf:type rdf:Property ;
    rdfs:label 'Is Controllable' ;
    rdfs:comment 'Indicates whether the cancellation was within the airline\'s control (maintenance, crew, operational decisions) versus uncontrollable (weather, ATC, security, force majeure). Used for passenger compensation eligibility under EU261 and DOT regulations.' ;
    rdfs:domain ind:Cancellation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDotReportable rdf:type rdf:Property ;
    rdfs:label 'Is Dot Reportable' ;
    rdfs:comment 'Indicates whether this cancellation must be reported to the US Department of Transportation under 14 CFR Part 234 (applies to US domestic flights and international flights to/from US by US carriers).' ;
    rdfs:domain ind:Cancellation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maintenanceDefectCode rdf:type rdf:Property ;
    rdfs:label 'Maintenance Defect Code' ;
    rdfs:comment 'ATA chapter or MEL (Minimum Equipment List) code for the maintenance defect that caused the cancellation, if maintenance-related.' ;
    rdfs:domain ind:Cancellation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkOptimizationFlag rdf:type rdf:Property ;
    rdfs:label 'Network Optimization Flag' ;
    rdfs:comment 'Indicates whether the cancellation was a strategic network optimization decision (e.g., consolidating low-load flights, repositioning aircraft) rather than an operational failure.' ;
    rdfs:domain ind:Cancellation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:occRemarks rdf:type rdf:Property ;
    rdfs:label 'Occ Remarks' ;
    rdfs:comment 'Free-text operational remarks and notes from the Operations Control Center regarding the cancellation decision and handling.' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passengerCareCostAmount rdf:type rdf:Property ;
    rdfs:label 'Passenger Care Cost Amount' ;
    rdfs:comment 'Total cost incurred for passenger care obligations including meals, accommodation, transportation, and compensation payments under EU261 or DOT regulations.' ;
    rdfs:domain ind:Cancellation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rebookedPassengerCount rdf:type rdf:Property ;
    rdfs:label 'Rebooked Passenger Count' ;
    rdfs:comment 'Number of affected passengers who were successfully rebooked on alternative flights.' ;
    rdfs:domain ind:Cancellation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:refundedPassengerCount rdf:type rdf:Property ;
    rdfs:label 'Refunded Passenger Count' ;
    rdfs:comment 'Number of affected passengers who requested and received full refunds instead of rebooking.' ;
    rdfs:domain ind:Cancellation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryReportSubmittedFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Submitted Flag' ;
    rdfs:comment 'Indicates whether the required regulatory report (DOT, EASA, local CAA) has been submitted for this cancellation.' ;
    rdfs:domain ind:Cancellation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryReportTimestamp rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Timestamp' ;
    rdfs:comment 'Date and time when the regulatory report for this cancellation was submitted to the governing authority.' ;
    rdfs:domain ind:Cancellation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:substituteDepartureTime rdf:type rdf:Property ;
    rdfs:label 'Substitute Departure Time' ;
    rdfs:comment 'Scheduled departure time of the substitute flight, if one was operated to replace the cancelled service.' ;
    rdfs:domain ind:Cancellation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:substituteFlightNumber rdf:type rdf:Property ;
    rdfs:label 'Substitute Flight Number' ;
    rdfs:comment 'Flight number of the substitute or replacement flight operated to cover the cancelled service, if applicable.' ;
    rdfs:domain ind:Cancellation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weatherConditionCode rdf:type rdf:Property ;
    rdfs:label 'Weather Condition Code' ;
    rdfs:comment 'METAR/TAF weather phenomenon code if weather was a contributing factor to the cancellation (e.g., TS for thunderstorm, FG for fog, SN for snow).' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedStationId rdf:type rdf:Property ;
    rdfs:label 'Affected Station Id' ;
    rdfs:comment 'Foreign key linking to airport.station. Business justification: IROP events impact specific stations; linking enables station-level impact analysis, resource allocation during irregular operations, recovery plan coordination with station managers, and financial im' ;
    rdfs:domain ind:FlightIropEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Station .

ind:eventCoordinatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Event Coordinator Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: IROP events (irregular operations) have designated coordinators managing recovery. Current event_coordinator_name is denormalized. Airlines track coordinator accountability for performance reviews, re' ;
    rdfs:domain ind:FlightIropEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualPassengersAffected rdf:type rdf:Property ;
    rdfs:label 'Actual Passengers Affected' ;
    rdfs:comment 'Actual total number of passengers impacted by the irregular operations event across all affected flights. Calculated after event resolution.' ;
    rdfs:domain ind:FlightIropEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualTotalDelayMinutes rdf:type rdf:Property ;
    rdfs:label 'Actual Total Delay Minutes' ;
    rdfs:comment 'Actual cumulative delay minutes across all affected flights resulting from this irregular operations event. Calculated after event resolution.' ;
    rdfs:domain ind:FlightIropEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:additionalAffectedStations rdf:type rdf:Property ;
    rdfs:label 'Additional Affected Stations' ;
    rdfs:comment 'Comma-separated list of additional IATA airport codes for stations impacted by the irregular operations event beyond the primary affected station.' ;
    rdfs:domain ind:FlightIropEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:atcCoordinationNotes rdf:type rdf:Property ;
    rdfs:label 'Atc Coordination Notes' ;
    rdfs:comment 'Notes documenting coordination activities and communications with Air Traffic Control during the irregular operations event.' ;
    rdfs:domain ind:FlightIropEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdmSessionReference rdf:type rdf:Property ;
    rdfs:label 'Cdm Session Reference' ;
    rdfs:comment 'Reference identifier linking to the Collaborative Decision Making session coordinating the operational response to this irregular operations event.' ;
    rdfs:domain ind:FlightIropEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedFinancialImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Financial Impact Amount' ;
    rdfs:comment 'Estimated total financial impact of the irregular operations event including operational costs, passenger compensation, and revenue loss. Expressed in airline base currency.' ;
    rdfs:domain ind:FlightIropEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedPassengersAffected rdf:type rdf:Property ;
    rdfs:label 'Estimated Passengers Affected' ;
    rdfs:comment 'Estimated total number of passengers impacted by the irregular operations event across all affected flights. Used for customer service resource planning.' ;
    rdfs:domain ind:FlightIropEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedTotalDelayMinutes rdf:type rdf:Property ;
    rdfs:label 'Estimated Total Delay Minutes' ;
    rdfs:comment 'Estimated cumulative delay minutes across all affected flights resulting from this irregular operations event. Used for impact assessment and reporting.' ;
    rdfs:domain ind:FlightIropEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eventCode rdf:type rdf:Property ;
    rdfs:label 'Event Code' ;
    rdfs:comment 'Standardized code identifying the type of irregular operations event. Used for operational reporting and analysis.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventDescription rdf:type rdf:Property ;
    rdfs:label 'Event Description' ;
    rdfs:comment 'Detailed narrative description of the irregular operations event including circumstances, operational impact, and contributing factors.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Event End Timestamp' ;
    rdfs:comment 'Date and time when the irregular operations event was resolved and normal operations resumed. Nullable for ongoing events.' ;
    rdfs:domain ind:FlightIropEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eventStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Event Start Timestamp' ;
    rdfs:comment 'Date and time when the irregular operations event was first detected or began affecting operations. Critical for timeline analysis and delay attribution.' ;
    rdfs:domain ind:FlightIropEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:flightsCancelledCount rdf:type rdf:Property ;
    rdfs:label 'Flights Cancelled Count' ;
    rdfs:comment 'Total number of flights cancelled as a direct result of this irregular operations event. Key metric for operational impact assessment.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:flightsDelayedCount rdf:type rdf:Property ;
    rdfs:label 'Flights Delayed Count' ;
    rdfs:comment 'Total number of flights delayed as a direct result of this irregular operations event. Key metric for operational impact assessment.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:flightsDivertedCount rdf:type rdf:Property ;
    rdfs:label 'Flights Diverted Count' ;
    rdfs:comment 'Total number of flights diverted to alternate airports as a direct result of this irregular operations event.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recoveryPlanDescription rdf:type rdf:Property ;
    rdfs:label 'Recovery Plan Description' ;
    rdfs:comment 'Detailed description of the operational recovery plan including actions, resource allocation, and timeline for restoring normal operations.' ;
    rdfs:domain ind:FlightIropEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recoveryPlanStatus rdf:type rdf:Property ;
    rdfs:label 'Recovery Plan Status' ;
    rdfs:comment 'Current state of the operational recovery plan developed to address the irregular operations event and restore normal operations.' ;
    rdfs:domain ind:FlightIropEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleDepartment rdf:type rdf:Property ;
    rdfs:label 'Responsible Department' ;
    rdfs:comment 'Name of the operational department or division responsible for managing the response to this irregular operations event.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weatherConditionSummary rdf:type rdf:Property ;
    rdfs:label 'Weather Condition Summary' ;
    rdfs:comment 'Summary of weather conditions contributing to or associated with the irregular operations event. Applicable for weather-related IROP events.' ;
    rdfs:domain ind:FlightIropEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:airborneTimeHours rdf:type rdf:Property ;
    rdfs:label 'Airborne Time Hours' ;
    rdfs:comment 'Total time the aircraft was airborne, from wheels-off (Off) to wheels-on (On), measured in hours.' ;
    rdfs:domain ind:FlightLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:arrivalTerminal rdf:type rdf:Property ;
    rdfs:label 'Arrival Terminal' ;
    rdfs:comment 'The terminal identifier at the destination airport where the flight arrived.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departureTerminal rdf:type rdf:Property ;
    rdfs:label 'Departure Terminal' ;
    rdfs:comment 'The terminal identifier at the origin airport from which the flight departed.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatchReleaseNumber rdf:type rdf:Property ;
    rdfs:label 'Dispatch Release Number' ;
    rdfs:comment 'Unique identifier for the dispatch release document authorizing this flight leg to operate, issued by flight dispatch.' ;
    rdfs:domain ind:FlightLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diversionAirportCode rdf:type rdf:Property ;
    rdfs:label 'Diversion Airport Code' ;
    rdfs:comment 'Three-letter IATA airport code for the alternate airport if the flight was diverted from its original destination.' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedArrivalTime rdf:type rdf:Property ;
    rdfs:label 'Estimated Arrival Time' ;
    rdfs:comment 'The current estimated arrival time, updated based on operational conditions. ETA is the best current estimate of when the flight will arrive.' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:estimatedDepartureTime rdf:type rdf:Property ;
    rdfs:label 'Estimated Departure Time' ;
    rdfs:comment 'The current estimated departure time, updated based on operational conditions. ETD is the best current estimate of when the flight will depart.' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:flightStatus rdf:type rdf:Property ;
    rdfs:label 'Flight Status' ;
    rdfs:comment 'Current operational status of the flight leg in its lifecycle. Tracks progression from scheduled through boarding, departure, airborne, landing, arrival, or exceptional states like cancelled or diverted. [ENUM-REF-CANDIDATE: scheduled|boarding|departed|airborne|landed|arrived|cancelled|diverted — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FlightLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flightStatusTimestamp rdf:type rdf:Property ;
    rdfs:label 'Flight Status Timestamp' ;
    rdfs:comment 'The timestamp when the current flight status was last updated, in UTC.' ;
    rdfs:domain ind:FlightLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:inTime rdf:type rdf:Property ;
    rdfs:label 'In Time' ;
    rdfs:comment 'The time the aircraft arrived at the gate and parking brake was set. Fourth event in OOOI (Out-Off-On-In) sequence.' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isCodeshare rdf:type rdf:Property ;
    rdfs:label 'Is Codeshare' ;
    rdfs:comment 'Indicates whether this flight leg is operated as a codeshare with one or more partner airlines.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:offTime rdf:type rdf:Property ;
    rdfs:label 'Off Time' ;
    rdfs:comment 'The time the aircraft wheels left the ground at takeoff. Second event in OOOI (Out-Off-On-In) sequence.' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:onTime rdf:type rdf:Property ;
    rdfs:label 'On Time' ;
    rdfs:comment 'The time the aircraft wheels touched down on the runway at landing. Third event in OOOI (Out-Off-On-In) sequence.' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:operatingDate rdf:type rdf:Property ;
    rdfs:label 'Operating Date' ;
    rdfs:comment 'The date on which this flight leg is operated or planned to be operated, in local departure timezone.' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:outTime rdf:type rdf:Property ;
    rdfs:label 'Out Time' ;
    rdfs:comment 'The time the aircraft pushed back from the gate or began taxi for departure. First event in OOOI (Out-Off-On-In) sequence.' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:publicStatusMessage rdf:type rdf:Property ;
    rdfs:label 'Public Status Message' ;
    rdfs:comment 'Customer-facing status message displayed on airport FIDS, mobile apps, and passenger notifications describing the current flight status.' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusSource rdf:type rdf:Property ;
    rdfs:label 'Status Source' ;
    rdfs:comment 'The source system or feed that provided the current flight status update (ACARS, ATC feed, airport FIDS, manual OCC update, GDS, NetLine/Ops).' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flightPerformanceId rdf:type rdf:Property ;
    rdfs:label 'Flight Performance Id' ;
    rdfs:comment 'Unique identifier for the flight performance record. Primary key.' ;
    rdfs:domain ind:FlightPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operationalFlightPlanId rdf:type rdf:Property ;
    rdfs:label 'Operational Flight Plan Id' ;
    rdfs:comment 'Foreign key linking to flight.operational_flight_plan. Business justification: Flight_performance captures post-flight data from FDR/FMS/ACARS. It should reference the specific OFP (operational flight plan loaded into FMS) that was executed. This is more specific than the filed ' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OperationalFlightPlan .

ind:actualBlockTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Actual Block Time Minutes' ;
    rdfs:comment 'The actual block time in minutes from Out to In (OOOI) as recorded during flight operations.' ;
    rdfs:domain ind:FlightPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualFuelBurnKg rdf:type rdf:Property ;
    rdfs:label 'Actual Fuel Burn Kg' ;
    rdfs:comment 'The actual fuel consumed during the flight in kilograms, captured from FDR/FMS/ACARS data.' ;
    rdfs:domain ind:FlightPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:anomalyDescription rdf:type rdf:Property ;
    rdfs:label 'Anomaly Description' ;
    rdfs:comment 'Textual description of any performance anomalies flagged during this flight, including threshold violations and engineering notes.' ;
    rdfs:domain ind:FlightPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:anomalyFlag rdf:type rdf:Property ;
    rdfs:label 'Anomaly Flag' ;
    rdfs:comment 'Boolean flag indicating whether any performance anomalies were detected during this flight (e.g., excessive fuel burn, engine parameter deviations).' ;
    rdfs:domain ind:FlightPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:atcDelayMinutes rdf:type rdf:Property ;
    rdfs:label 'Atc Delay Minutes' ;
    rdfs:comment 'Total delay in minutes attributed to ATC restrictions, holding patterns, or routing changes during this flight.' ;
    rdfs:domain ind:FlightPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:averageCruiseSpeedMach rdf:type rdf:Property ;
    rdfs:label 'Average Cruise Speed Mach' ;
    rdfs:comment 'The average cruise speed expressed as a Mach number during the cruise phase of flight.' ;
    rdfs:domain ind:FlightPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageGroundSpeedKnots rdf:type rdf:Property ;
    rdfs:label 'Average Ground Speed Knots' ;
    rdfs:comment 'The average ground speed in knots during the flight, accounting for wind effects.' ;
    rdfs:domain ind:FlightPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:blockTimeVarianceMinutes rdf:type rdf:Property ;
    rdfs:label 'Block Time Variance Minutes' ;
    rdfs:comment 'The difference between planned and actual block time in minutes. Positive indicates longer than planned, negative indicates shorter.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:co2EmissionsKg rdf:type rdf:Property ;
    rdfs:label 'Co2 Emissions Kg' ;
    rdfs:comment 'Calculated CO2 emissions in kilograms for this flight based on actual fuel burn and fuel type emission factors.' ;
    rdfs:domain ind:FlightPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cruiseAltitudeFeet rdf:type rdf:Property ;
    rdfs:label 'Cruise Altitude Feet' ;
    rdfs:comment 'The actual cruise altitude achieved during flight in feet above mean sea level, captured from FMS data.' ;
    rdfs:domain ind:FlightPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataQualityScore rdf:type rdf:Property ;
    rdfs:label 'Data Quality Score' ;
    rdfs:comment 'A quality score from 0.00 to 1.00 indicating the completeness and reliability of the performance data captured for this flight.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:engine1AvgEgtCelsius rdf:type rdf:Property ;
    rdfs:label 'Engine 1 Avg Egt Celsius' ;
    rdfs:comment 'Average Exhaust Gas Temperature for engine 1 during cruise phase in degrees Celsius, captured from FDR.' ;
    rdfs:domain ind:FlightPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:engine1AvgFuelFlowKgPerHour rdf:type rdf:Property ;
    rdfs:label 'Engine 1 Avg Fuel Flow Kg Per Hour' ;
    rdfs:comment 'Average fuel flow rate for engine 1 in kilograms per hour during cruise phase.' ;
    rdfs:domain ind:FlightPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:engine1AvgN1Percent rdf:type rdf:Property ;
    rdfs:label 'Engine 1 Avg N1 Percent' ;
    rdfs:comment 'Average N1 (low-pressure spool speed) for engine 1 during cruise phase as a percentage of maximum RPM.' ;
    rdfs:domain ind:FlightPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:engine2AvgEgtCelsius rdf:type rdf:Property ;
    rdfs:label 'Engine 2 Avg Egt Celsius' ;
    rdfs:comment 'Average Exhaust Gas Temperature for engine 2 during cruise phase in degrees Celsius, captured from FDR.' ;
    rdfs:domain ind:FlightPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:engine2AvgFuelFlowKgPerHour rdf:type rdf:Property ;
    rdfs:label 'Engine 2 Avg Fuel Flow Kg Per Hour' ;
    rdfs:comment 'Average fuel flow rate for engine 2 in kilograms per hour during cruise phase.' ;
    rdfs:domain ind:FlightPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:engine2AvgN1Percent rdf:type rdf:Property ;
    rdfs:label 'Engine 2 Avg N1 Percent' ;
    rdfs:comment 'Average N1 (low-pressure spool speed) for engine 2 during cruise phase as a percentage of maximum RPM.' ;
    rdfs:domain ind:FlightPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:flightPhaseCoverage rdf:type rdf:Property ;
    rdfs:label 'Flight Phase Coverage' ;
    rdfs:comment 'Comma-separated list of flight phases for which performance data was successfully captured (e.g., TAXI_OUT, TAKEOFF, CLIMB, CRUISE, DESCENT, LANDING, TAXI_IN).' ;
    rdfs:domain ind:FlightPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelEfficiencyIndex rdf:type rdf:Property ;
    rdfs:label 'Fuel Efficiency Index' ;
    rdfs:comment 'Normalized fuel efficiency metric comparing actual fuel burn to planned fuel burn. Values near 1.0 indicate on-plan performance.' ;
    rdfs:domain ind:FlightPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelVarianceKg rdf:type rdf:Property ;
    rdfs:label 'Fuel Variance Kg' ;
    rdfs:comment 'The difference between planned and actual fuel burn in kilograms. Positive indicates over-burn, negative indicates under-burn.' ;
    rdfs:domain ind:FlightPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceCategory rdf:type rdf:Property ;
    rdfs:label 'Performance Category' ;
    rdfs:comment 'Overall performance classification for this flight based on fuel efficiency, block time adherence, and engine performance metrics.' ;
    rdfs:domain ind:FlightPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedBlockTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Planned Block Time Minutes' ;
    rdfs:comment 'The scheduled block time in minutes from gate departure to gate arrival as planned during scheduling.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedCruiseAltitudeFeet rdf:type rdf:Property ;
    rdfs:label 'Planned Cruise Altitude Feet' ;
    rdfs:comment 'The planned cruise altitude in feet as filed in the flight plan.' ;
    rdfs:domain ind:FlightPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedFuelKg rdf:type rdf:Property ;
    rdfs:label 'Planned Fuel Kg' ;
    rdfs:comment 'The planned fuel load in kilograms as calculated during flight planning and dispatch release.' ;
    rdfs:domain ind:FlightPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weatherImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Weather Impact Flag' ;
    rdfs:comment 'Boolean flag indicating whether significant weather conditions (turbulence, icing, convective activity) impacted flight performance.' ;
    rdfs:domain ind:FlightPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:windComponentKnots rdf:type rdf:Property ;
    rdfs:label 'Wind Component Knots' ;
    rdfs:comment 'The average wind component in knots experienced during cruise. Positive values indicate tailwind, negative values indicate headwind.' ;
    rdfs:domain ind:FlightPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:arrivalAirportIcao rdf:type rdf:Property ;
    rdfs:label 'Arrival Airport Icao' ;
    rdfs:comment 'Four-letter ICAO code of the destination airport.' ;
    rdfs:domain ind:FlightPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costIndex rdf:type rdf:Property ;
    rdfs:label 'Cost Index' ;
    rdfs:comment 'Cost index value used for flight planning optimization, balancing time cost versus fuel cost. Higher values favor speed; lower values favor fuel efficiency.' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cruiseAltitudeFt rdf:type rdf:Property ;
    rdfs:label 'Cruise Altitude Ft' ;
    rdfs:comment 'Planned cruise altitude in feet above mean sea level (MSL) for the primary cruise segment.' ;
    rdfs:domain ind:FlightPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cruiseSpeedKts rdf:type rdf:Property ;
    rdfs:label 'Cruise Speed Kts' ;
    rdfs:comment 'Planned cruise speed in knots (true airspeed or indicated airspeed as per flight planning convention).' ;
    rdfs:domain ind:FlightPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:etopsQualifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Etops Qualified Flag' ;
    rdfs:comment 'Indicates whether this flight plan is qualified for ETOPS operations (extended-range twin-engine flights over water or remote areas).' ;
    rdfs:domain ind:FlightPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:filedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Filed Timestamp' ;
    rdfs:comment 'Date and time when this flight plan version was filed with Air Traffic Control (ATC) or ICAO Flight Plan Processing System.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:operationalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Operational Timestamp' ;
    rdfs:comment 'Date and time when this flight plan version was accepted by the crew and loaded into the Flight Management System (FMS) as the operational flight plan (OFP).' ;
    rdfs:domain ind:FlightPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedBlockHours rdf:type rdf:Property ;
    rdfs:label 'Planned Block Hours' ;
    rdfs:comment 'Estimated total block time in hours from gate departure (Out) to gate arrival (In), including taxi, flight, and approach time.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedFlightTimeHours rdf:type rdf:Property ;
    rdfs:label 'Planned Flight Time Hours' ;
    rdfs:comment 'Estimated airborne time in hours from wheels-off to wheels-on.' ;
    rdfs:domain ind:FlightPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedTaxiInMinutes rdf:type rdf:Property ;
    rdfs:label 'Planned Taxi In Minutes' ;
    rdfs:comment 'Estimated taxi time in minutes from landing to gate arrival.' ;
    rdfs:domain ind:FlightPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedTaxiOutMinutes rdf:type rdf:Property ;
    rdfs:label 'Planned Taxi Out Minutes' ;
    rdfs:comment 'Estimated taxi time in minutes from gate departure to takeoff.' ;
    rdfs:domain ind:FlightPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:routeOfFlight rdf:type rdf:Property ;
    rdfs:label 'Route Of Flight' ;
    rdfs:comment 'Full textual representation of the planned route including RNAV waypoints, airways, Standard Instrument Departures (SIDs), and Standard Terminal Arrival Routes (STARs).' ;
    rdfs:domain ind:FlightPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stepClimbSchedule rdf:type rdf:Property ;
    rdfs:label 'Step Climb Schedule' ;
    rdfs:comment 'Planned altitude step-climb profile showing waypoints and altitudes where the aircraft will request higher cruise levels to optimize fuel efficiency as weight decreases.' ;
    rdfs:domain ind:FlightPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalFuelRequiredKg rdf:type rdf:Property ;
    rdfs:label 'Total Fuel Required Kg' ;
    rdfs:comment 'Total fuel required in kilograms: sum of trip fuel, contingency fuel, alternate fuel, final reserve fuel, taxi fuel, and any additional fuel.' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionNumber rdf:type rdf:Property ;
    rdfs:label 'Version Number' ;
    rdfs:comment 'Sequential version number of this flight plan. Increments with each amendment or update to the plan for the same flight.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:windDataSource rdf:type rdf:Property ;
    rdfs:label 'Wind Data Source' ;
    rdfs:comment 'Source of wind and temperature forecast data used in flight planning (e.g., NOAA GFS, ECMWF, proprietary meteorological service).' ;
    rdfs:domain ind:FlightPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusId rdf:type rdf:Property ;
    rdfs:label 'Status Id' ;
    rdfs:comment 'Unique identifier for the flight status record. Primary key.' ;
    rdfs:domain ind:Status ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:atcSlotTime rdf:type rdf:Property ;
    rdfs:label 'Atc Slot Time' ;
    rdfs:comment 'Allocated takeoff or landing slot time assigned by ATC. Critical for slot-controlled airports and ATFM (Air Traffic Flow Management) compliance.' ;
    rdfs:domain ind:Status ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:boardingStartTime rdf:type rdf:Property ;
    rdfs:label 'Boarding Start Time' ;
    rdfs:comment 'Actual time when passenger boarding commenced at the departure gate. Used for operational metrics and passenger communication.' ;
    rdfs:domain ind:Status ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:boardingStatus rdf:type rdf:Property ;
    rdfs:label 'Boarding Status' ;
    rdfs:comment 'Current boarding process status. Indicates the stage of passenger boarding operations at the departure gate.' ;
    rdfs:domain ind:Status ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fidsPublishedFlag rdf:type rdf:Property ;
    rdfs:label 'Fids Published Flag' ;
    rdfs:comment 'Indicates whether this status has been published to airport FIDS displays. Used for display synchronization and audit purposes.' ;
    rdfs:domain ind:Status ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gateClosureTime rdf:type rdf:Property ;
    rdfs:label 'Gate Closure Time' ;
    rdfs:comment 'Actual time when the departure gate was closed and no further passengers were accepted for boarding. Critical for on-time departure metrics.' ;
    rdfs:domain ind:Status ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:gdsDistributionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Gds Distribution Timestamp' ;
    rdfs:comment 'Timestamp when this status was distributed to GDS systems (Amadeus, Sabre, Travelport). Used for external partner data synchronization tracking.' ;
    rdfs:domain ind:Status ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isIrop rdf:type rdf:Property ;
    rdfs:label 'Is Irop' ;
    rdfs:comment 'Indicates whether this flight is currently under irregular operations status requiring special handling, rebooking, or recovery procedures.' ;
    rdfs:domain ind:Status ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:statusCode rdf:type rdf:Property ;
    rdfs:label 'Status Code' ;
    rdfs:comment 'Current operational state of the flight leg. Represents the lifecycle stage from scheduled through completion or cancellation. [ENUM-REF-CANDIDATE: scheduled|boarding|departed|airborne|landed|arrived|cancelled|diverted|delayed|returned — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Status ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusTimestamp rdf:type rdf:Property ;
    rdfs:label 'Status Timestamp' ;
    rdfs:comment 'Date and time when this status was recorded or became effective. Represents the business event time for this status change.' ;
    rdfs:domain ind:Status ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fuelingVendorId rdf:type rdf:Property ;
    rdfs:label 'Fueling Vendor Id' ;
    rdfs:comment 'Foreign key linking to procurement.vendor. Business justification: Fuel uplifts are performed by contracted into-plane agents (vendors). Airlines track vendor performance, invoicing, and SLA compliance per uplift. Current fueling_company_code is denormalized; proper ' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:fuelBatchNumber rdf:type rdf:Property ;
    rdfs:label 'Fuel Batch Number' ;
    rdfs:comment 'Batch or lot number of the fuel supplied, used for quality traceability.' ;
    rdfs:domain ind:FuelUplift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelPriceCurrency rdf:type rdf:Property ;
    rdfs:label 'Fuel Price Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the fuel price.' ;
    rdfs:domain ind:FuelUplift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelPricePerUnit rdf:type rdf:Property ;
    rdfs:label 'Fuel Price Per Unit' ;
    rdfs:comment 'Price per unit (per kilogram or per litre) of fuel charged by the supplier.' ;
    rdfs:domain ind:FuelUplift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelQualityCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Fuel Quality Certificate Number' ;
    rdfs:comment 'Certificate number issued by the fuel supplier confirming fuel quality and compliance with aviation standards.' ;
    rdfs:domain ind:FuelUplift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelQuantityKg rdf:type rdf:Property ;
    rdfs:label 'Fuel Quantity Kg' ;
    rdfs:comment 'Quantity of fuel uplifted measured in kilograms.' ;
    rdfs:domain ind:FuelUplift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelQuantityLbs rdf:type rdf:Property ;
    rdfs:label 'Fuel Quantity Lbs' ;
    rdfs:comment 'Quantity of fuel uplifted measured in pounds.' ;
    rdfs:domain ind:FuelUplift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelQuantityLitres rdf:type rdf:Property ;
    rdfs:label 'Fuel Quantity Litres' ;
    rdfs:comment 'Quantity of fuel uplifted measured in litres.' ;
    rdfs:domain ind:FuelUplift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelSurchargeAmount rdf:type rdf:Property ;
    rdfs:label 'Fuel Surcharge Amount' ;
    rdfs:comment 'Additional surcharge or fee applied to the fuel uplift transaction.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelTemperatureCelsius rdf:type rdf:Property ;
    rdfs:label 'Fuel Temperature Celsius' ;
    rdfs:comment 'Temperature of the fuel at the time of uplift, measured in degrees Celsius, used for density correction.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelTicketNumber rdf:type rdf:Property ;
    rdfs:label 'Fuel Ticket Number' ;
    rdfs:comment 'Unique ticket or document number issued by the fueling company for this uplift transaction.' ;
    rdfs:domain ind:FuelUplift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelUpliftStatus rdf:type rdf:Property ;
    rdfs:label 'Fuel Uplift Status' ;
    rdfs:comment 'Current status of the fuel uplift transaction (e.g., completed, partial, cancelled, disputed).' ;
    rdfs:domain ind:FuelUplift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelingDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Fueling Duration Minutes' ;
    rdfs:comment 'Duration of the fueling operation in minutes.' ;
    rdfs:domain ind:FuelUplift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fuelingStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Fueling Start Timestamp' ;
    rdfs:comment 'Date and time when the fuel uplift operation began.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fuelingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Fueling Timestamp' ;
    rdfs:comment 'Date and time when the fuel uplift operation was completed, in ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX).' ;
    rdfs:domain ind:FuelUplift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:intoPlaneAgent rdf:type rdf:Property ;
    rdfs:label 'Into Plane Agent' ;
    rdfs:comment 'Name or identifier of the into-plane agent or ground handler responsible for the physical fueling operation.' ;
    rdfs:domain ind:FuelUplift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postFuelingQuantityKg rdf:type rdf:Property ;
    rdfs:label 'Post Fueling Quantity Kg' ;
    rdfs:comment 'Total quantity of fuel on board the aircraft after the uplift, measured in kilograms.' ;
    rdfs:domain ind:FuelUplift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preFuelingQuantityKg rdf:type rdf:Property ;
    rdfs:label 'Pre Fueling Quantity Kg' ;
    rdfs:comment 'Quantity of fuel already on board the aircraft before the uplift, measured in kilograms.' ;
    rdfs:domain ind:FuelUplift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalFuelCost rdf:type rdf:Property ;
    rdfs:label 'Total Fuel Cost' ;
    rdfs:comment 'Total cost of the fuel uplift transaction in the specified currency.' ;
    rdfs:domain ind:FuelUplift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acarsMessageLabel rdf:type rdf:Property ;
    rdfs:label 'Acars Message Label' ;
    rdfs:comment 'The ACARS message label identifier associated with this OOOI event transmission (e.g., H1 for OUT, 10 for OFF, 11 for ON, 12 for IN). Null if data source is not ACARS.' ;
    rdfs:domain ind:OooiEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acarsMessageNumber rdf:type rdf:Property ;
    rdfs:label 'Acars Message Number' ;
    rdfs:comment 'The unique ACARS message sequence number for this OOOI event transmission. Used for message tracking and reconciliation. Null if data source is not ACARS.' ;
    rdfs:domain ind:OooiEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctionReason rdf:type rdf:Property ;
    rdfs:label 'Correction Reason' ;
    rdfs:comment 'Free-text description explaining why this OOOI event timestamp was corrected. Null if is_corrected is False. Used for audit trail and data quality improvement.' ;
    rdfs:domain ind:OooiEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventTimestampLocal rdf:type rdf:Property ;
    rdfs:label 'Event Timestamp Local' ;
    rdfs:comment 'The OOOI event timestamp converted to the local time zone of the airport where the event occurred. Used for operational reporting and crew scheduling.' ;
    rdfs:domain ind:OooiEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:gateStand rdf:type rdf:Property ;
    rdfs:label 'Gate Stand' ;
    rdfs:comment 'The gate or stand identifier where the OUT (pushback) or IN (arrival) event occurred. Null for OFF and ON events. Used for ground operations coordination.' ;
    rdfs:domain ind:OooiEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCorrected rdf:type rdf:Property ;
    rdfs:label 'Is Corrected' ;
    rdfs:comment 'Boolean flag indicating whether this OOOI event timestamp was manually corrected after initial capture due to data quality issues or system errors. True if corrected, False if original.' ;
    rdfs:domain ind:OooiEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isEstimated rdf:type rdf:Property ;
    rdfs:label 'Is Estimated' ;
    rdfs:comment 'Boolean flag indicating whether this OOOI event timestamp was estimated or interpolated rather than directly captured from aircraft or ground systems. True if estimated, False if actual.' ;
    rdfs:domain ind:OooiEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:originalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Original Timestamp' ;
    rdfs:comment 'The original OOOI event timestamp before any corrections were applied. Null if is_corrected is False. Preserved for audit trail and data lineage.' ;
    rdfs:domain ind:OooiEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:otpEligible rdf:type rdf:Property ;
    rdfs:label 'Otp Eligible' ;
    rdfs:comment 'Boolean flag indicating whether this OOOI event is eligible for inclusion in OTP calculations per IATA or DOT standards. False if flight was cancelled, diverted, or otherwise excluded from OTP metrics.' ;
    rdfs:domain ind:OooiEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Received Timestamp' ;
    rdfs:comment 'The timestamp when the OOOI event data was received and recorded by the ground-based flight operations system. Used for data latency analysis and system performance monitoring.' ;
    rdfs:domain ind:OooiEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reportingStatus rdf:type rdf:Property ;
    rdfs:label 'Reporting Status' ;
    rdfs:comment 'Indicates whether this OOOI event has been included in regulatory reporting submissions to DOT, IATA, or other authorities: REPORTED (included in submission), UNREPORTED (not yet submitted), EXCLUDED (intentionally omitted per reporting rules), AMENDED (corrected in a subsequent filing).' ;
    rdfs:domain ind:OooiEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runwayIdentifier rdf:type rdf:Property ;
    rdfs:label 'Runway Identifier' ;
    rdfs:comment 'The runway designation used for the OFF (takeoff) or ON (landing) event. Format follows ICAO runway naming conventions (e.g., 27L, 09R). Null for OUT and IN events.' ;
    rdfs:domain ind:OooiEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Timestamp' ;
    rdfs:comment 'The originally scheduled timestamp for this OOOI event type (scheduled departure for OUT, scheduled takeoff for OFF, scheduled landing for ON, scheduled arrival for IN). Used to calculate delay and OTP metrics.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:operationalStandardId rdf:type rdf:Property ;
    rdfs:label 'Operational Standard Id' ;
    rdfs:comment 'Foreign key linking to route.operational_standard. Business justification: OFP generation requires direct reference to route-specific turnaround standards for accurate crew duty time calculations, minimum ground time validation, and fuel planning. Dispatchers validate planne' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OperationalStandard .

ind:primaryOperationalEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Operational Employee Id' ;
    rdfs:comment 'Reference to the flight dispatcher who prepared and released this operational flight plan.' ;
    rdfs:domain ind:OperationalFlightPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:alternateAirport1Code rdf:type rdf:Property ;
    rdfs:label 'Alternate Airport 1 Code' ;
    rdfs:comment 'IATA or ICAO code of the primary alternate airport designated in the operational flight plan.' ;
    rdfs:domain ind:OperationalFlightPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alternateAirport2Code rdf:type rdf:Property ;
    rdfs:label 'Alternate Airport 2 Code' ;
    rdfs:comment 'IATA or ICAO code of the secondary alternate airport designated in the operational flight plan.' ;
    rdfs:domain ind:OperationalFlightPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crewAcceptedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Crew Accepted Timestamp' ;
    rdfs:comment 'Timestamp when the flight crew formally accepted the operational flight plan. Represents the final crew-accepted version distinct from the initial computerized flight plan filed with ATC.' ;
    rdfs:domain ind:OperationalFlightPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:estimatedTimeEnrouteMinutes rdf:type rdf:Property ;
    rdfs:label 'Estimated Time Enroute Minutes' ;
    rdfs:comment 'Estimated time enroute from takeoff to landing at destination in minutes.' ;
    rdfs:domain ind:OperationalFlightPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:etopsAlternateCode rdf:type rdf:Property ;
    rdfs:label 'Etops Alternate Code' ;
    rdfs:comment 'IATA or ICAO code of the ETOPS alternate airport for extended-range twin-engine operations.' ;
    rdfs:domain ind:OperationalFlightPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:etopsApprovalIndicator rdf:type rdf:Property ;
    rdfs:label 'Etops Approval Indicator' ;
    rdfs:comment 'Indicates whether this flight operates under ETOPS approval for extended-range twin-engine operations.' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:etopsRuleTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Etops Rule Time Minutes' ;
    rdfs:comment 'ETOPS rule time in minutes (e.g., 120, 180, 207) indicating maximum diversion time to an alternate airport.' ;
    rdfs:domain ind:OperationalFlightPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:flightPlanningSystemCode rdf:type rdf:Property ;
    rdfs:label 'Flight Planning System Code' ;
    rdfs:comment 'Code identifying the flight planning system that generated this operational flight plan (e.g., Jeppesen, Lido, NavBlue).' ;
    rdfs:domain ind:OperationalFlightPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumEquipmentListItems rdf:type rdf:Property ;
    rdfs:label 'Minimum Equipment List Items' ;
    rdfs:comment 'List of MEL items or deferred maintenance items affecting this flight. Comma-separated MEL reference numbers.' ;
    rdfs:domain ind:OperationalFlightPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notamSummary rdf:type rdf:Property ;
    rdfs:label 'Notam Summary' ;
    rdfs:comment 'Summary of relevant NOTAMs affecting the route, departure, destination, and alternate airports.' ;
    rdfs:domain ind:OperationalFlightPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ofpVersionNumber rdf:type rdf:Property ;
    rdfs:label 'Ofp Version Number' ;
    rdfs:comment 'Version number of the operational flight plan. Increments when the plan is revised after initial dispatch.' ;
    rdfs:domain ind:OperationalFlightPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:planGeneratedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Plan Generated Timestamp' ;
    rdfs:comment 'Timestamp when the operational flight plan was generated by the flight planning system.' ;
    rdfs:domain ind:OperationalFlightPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedCruiseSpeedMach rdf:type rdf:Property ;
    rdfs:label 'Planned Cruise Speed Mach' ;
    rdfs:comment 'Planned cruise speed expressed as Mach number.' ;
    rdfs:domain ind:OperationalFlightPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedTakeoffWeightKg rdf:type rdf:Property ;
    rdfs:label 'Planned Takeoff Weight Kg' ;
    rdfs:comment 'Planned takeoff weight of the aircraft in kilograms including fuel, payload, and crew.' ;
    rdfs:domain ind:OperationalFlightPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stepClimbProfile rdf:type rdf:Property ;
    rdfs:label 'Step Climb Profile' ;
    rdfs:comment 'Planned step-climb altitude profile showing waypoints and altitudes for fuel-efficient cruise climbs.' ;
    rdfs:domain ind:OperationalFlightPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxiFuelKg rdf:type rdf:Property ;
    rdfs:label 'Taxi Fuel Kg' ;
    rdfs:comment 'Fuel expected to be consumed during taxi operations before takeoff in kilograms.' ;
    rdfs:domain ind:OperationalFlightPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weatherDeviationIndicator rdf:type rdf:Property ;
    rdfs:label 'Weather Deviation Indicator' ;
    rdfs:comment 'Indicates whether the operational flight plan includes route deviations due to weather conditions.' ;
    rdfs:domain ind:OperationalFlightPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:aircraftConfigurationCode rdf:type rdf:Property ;
    rdfs:label 'Aircraft Configuration Code' ;
    rdfs:comment 'Code identifying the specific cabin configuration and seat layout for the scheduled aircraft (e.g., 3-class, 2-class, all-economy). Links to detailed seat maps and cabin class definitions.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Block Time Minutes' ;
    rdfs:comment 'Planned block time in minutes from gate departure (Out) to gate arrival (In). This is the scheduled elapsed time for the flight leg.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:codeshareIndicator rdf:type rdf:Property ;
    rdfs:label 'Codeshare Indicator' ;
    rdfs:comment 'Flag indicating whether this scheduled flight is part of a codeshare agreement where multiple airlines market the same flight operation. True if codeshare, false if single-carrier operation.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dayOfWeekPattern rdf:type rdf:Property ;
    rdfs:label 'Day Of Week Pattern' ;
    rdfs:comment 'Seven-character string indicating which days of the week the flight operates (1=operates, 0=does not operate). Position 1=Monday through position 7=Sunday (e.g., 1111100 = Monday-Friday only).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveUntilDate rdf:type rdf:Property ;
    rdfs:label 'Effective Until Date' ;
    rdfs:comment 'The last date this scheduled flight is valid and may operate. End of the schedule validity period. Nullable for open-ended schedules.' ;
    rdfs:domain ind:ScheduledFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:flightDistanceKm rdf:type rdf:Property ;
    rdfs:label 'Flight Distance Km' ;
    rdfs:comment 'Great circle distance between departure and arrival airports in kilometers. Used for RPK and ASK calculations.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mealServiceCode rdf:type rdf:Property ;
    rdfs:label 'Meal Service Code' ;
    rdfs:comment 'Single-character IATA code indicating the type of meal service provided: B=Breakfast, L=Lunch, D=Dinner, S=Snack, M=Meal (unspecified), N=No meal service.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumConnectingTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Minimum Connecting Time Minutes' ;
    rdfs:comment 'Minimum time in minutes required for passengers to make a legal connection from this flight to another flight at the arrival airport. Varies by airport, terminal, and connection type (domestic-domestic, domestic-international, international-international).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:publishedDate rdf:type rdf:Property ;
    rdfs:label 'Published Date' ;
    rdfs:comment 'Date when this scheduled flight was first published to Global Distribution Systems (GDS) and made available for booking. Critical for revenue management and distribution.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Status' ;
    rdfs:comment 'Status of regulatory approval from civil aviation authorities for this scheduled flight route and slot allocation: approved (fully authorized), pending (awaiting approval), conditional (approved with restrictions), or denied (not authorized).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeNetworkType rdf:type rdf:Property ;
    rdfs:label 'Route Network Type' ;
    rdfs:comment 'Classification of the scheduled flight within the airlines route network strategy: hub_spoke (connecting through a hub), point_to_point (direct city-pair), regional_feeder (short-haul feed to hub), long_haul_international (intercontinental), or domestic_trunk (major domestic route).' ;
    rdfs:domain ind:ScheduledFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleStatus rdf:type rdf:Property ;
    rdfs:label 'Schedule Status' ;
    rdfs:comment 'Current lifecycle status of the scheduled flight: active (currently operating), suspended (temporarily not operating), cancelled (permanently removed), seasonal_inactive (out of season), or pending_approval (awaiting regulatory approval).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleVersionNumber rdf:type rdf:Property ;
    rdfs:label 'Schedule Version Number' ;
    rdfs:comment 'Version number of this schedule record. Incremented each time the scheduled flight details are modified (time changes, equipment changes, etc.). Supports schedule change tracking and audit.' ;
    rdfs:domain ind:ScheduledFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trafficRestrictionCode rdf:type rdf:Property ;
    rdfs:label 'Traffic Restriction Code' ;
    rdfs:comment 'IATA traffic restriction code indicating any limitations on passenger or cargo carriage (e.g., C=Cargo only, G=Technical stop no traffic rights, F=Passenger service only). Empty if no restrictions.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wetLeaseIndicator rdf:type rdf:Property ;
    rdfs:label 'Wet Lease Indicator' ;
    rdfs:comment 'Flag indicating whether this scheduled flight is operated under a wet lease agreement (aircraft leased with crew, maintenance, and insurance from another carrier). True if wet lease operation.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:weightBalanceId rdf:type rdf:Property ;
    rdfs:label 'Weight Balance Id' ;
    rdfs:comment 'Unique identifier for the weight and balance loadsheet record. Primary key.' ;
    rdfs:domain ind:WeightBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:captainAcceptanceSignature rdf:type rdf:Property ;
    rdfs:label 'Captain Acceptance Signature' ;
    rdfs:comment 'Digital or physical signature of the pilot in command accepting the weight and balance loadsheet and authorizing departure.' ;
    rdfs:domain ind:WeightBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:captainAcceptanceTimestamp rdf:type rdf:Property ;
    rdfs:label 'Captain Acceptance Timestamp' ;
    rdfs:comment 'Date and time when the pilot in command accepted and signed the weight and balance loadsheet.' ;
    rdfs:domain ind:WeightBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cgAftLimitPercentMac rdf:type rdf:Property ;
    rdfs:label 'Cg Aft Limit Percent Mac' ;
    rdfs:comment 'Aft limit of the certified CG envelope for this weight and configuration. CG must not be behind this limit.' ;
    rdfs:domain ind:WeightBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cgForwardLimitPercentMac rdf:type rdf:Property ;
    rdfs:label 'Cg Forward Limit Percent Mac' ;
    rdfs:comment 'Forward limit of the certified CG envelope for this weight and configuration. CG must not be ahead of this limit.' ;
    rdfs:domain ind:WeightBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cgLandingPercentMac rdf:type rdf:Property ;
    rdfs:label 'Cg Landing Percent Mac' ;
    rdfs:comment 'Estimated longitudinal centre of gravity position at landing expressed as percentage of mean aerodynamic chord. Must remain within certified CG envelope.' ;
    rdfs:domain ind:WeightBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cgTakeoffPercentMac rdf:type rdf:Property ;
    rdfs:label 'Cg Takeoff Percent Mac' ;
    rdfs:comment 'Longitudinal centre of gravity position at takeoff expressed as percentage of mean aerodynamic chord. Must be within certified CG envelope.' ;
    rdfs:domain ind:WeightBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dryOperatingWeightKg rdf:type rdf:Property ;
    rdfs:label 'Dry Operating Weight Kg' ;
    rdfs:comment 'The weight of the aircraft including crew, crew baggage, catering, and all operational equipment but excluding fuel, passengers, cargo, and baggage. Also known as basic operating weight.' ;
    rdfs:domain ind:WeightBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holdAftWeightKg rdf:type rdf:Property ;
    rdfs:label 'Hold Aft Weight Kg' ;
    rdfs:comment 'Total weight loaded in the aft cargo hold compartment.' ;
    rdfs:domain ind:WeightBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holdBulkWeightKg rdf:type rdf:Property ;
    rdfs:label 'Hold Bulk Weight Kg' ;
    rdfs:comment 'Total weight loaded in the bulk cargo hold compartment, typically used for loose baggage and small cargo items.' ;
    rdfs:domain ind:WeightBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holdForwardWeightKg rdf:type rdf:Property ;
    rdfs:label 'Hold Forward Weight Kg' ;
    rdfs:comment 'Total weight loaded in the forward cargo hold compartment.' ;
    rdfs:domain ind:WeightBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:loadDistributionCompliant rdf:type rdf:Property ;
    rdfs:label 'Load Distribution Compliant' ;
    rdfs:comment 'Flag indicating whether the load distribution meets all structural and CG envelope requirements for safe flight.' ;
    rdfs:domain ind:WeightBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loadmasterLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Loadmaster License Number' ;
    rdfs:comment 'Professional license or certification number of the loadmaster who prepared the loadsheet.' ;
    rdfs:domain ind:WeightBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadmasterName rdf:type rdf:Property ;
    rdfs:label 'Loadmaster Name' ;
    rdfs:comment 'Name of the loadmaster or load control agent who prepared the weight and balance loadsheet.' ;
    rdfs:domain ind:WeightBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadsheetNumber rdf:type rdf:Property ;
    rdfs:label 'Loadsheet Number' ;
    rdfs:comment 'Unique externally-known identifier for the weight and balance loadsheet document, typically assigned by the load control system or dispatcher.' ;
    rdfs:domain ind:WeightBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadsheetStatus rdf:type rdf:Property ;
    rdfs:label 'Loadsheet Status' ;
    rdfs:comment 'Current lifecycle status of the weight and balance loadsheet. Final status indicates dispatcher sign-off and regulatory compliance approval.' ;
    rdfs:domain ind:WeightBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadsheetVersion rdf:type rdf:Property ;
    rdfs:label 'Loadsheet Version' ;
    rdfs:comment 'Version number of the loadsheet. Incremented when corrections or updates are made prior to departure.' ;
    rdfs:domain ind:WeightBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mailWeightKg rdf:type rdf:Property ;
    rdfs:label 'Mail Weight Kg' ;
    rdfs:comment 'Weight of mail cargo loaded in cargo holds.' ;
    rdfs:domain ind:WeightBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxLandingWeightKg rdf:type rdf:Property ;
    rdfs:label 'Max Landing Weight Kg' ;
    rdfs:comment 'Maximum permissible landing weight for this aircraft as specified in the aircraft flight manual. Structural limit.' ;
    rdfs:domain ind:WeightBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxTakeoffWeightKg rdf:type rdf:Property ;
    rdfs:label 'Max Takeoff Weight Kg' ;
    rdfs:comment 'Maximum permissible takeoff weight for this aircraft under current conditions (runway length, temperature, altitude, obstacles). May be limited below certified MTOW.' ;
    rdfs:domain ind:WeightBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxZeroFuelWeightKg rdf:type rdf:Property ;
    rdfs:label 'Max Zero Fuel Weight Kg' ;
    rdfs:comment 'Maximum permissible zero fuel weight for this aircraft as specified in the aircraft flight manual. Structural limit.' ;
    rdfs:domain ind:WeightBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:passengerCountBusiness rdf:type rdf:Property ;
    rdfs:label 'Passenger Count Business' ;
    rdfs:comment 'Number of passengers seated in business class cabin.' ;
    rdfs:domain ind:WeightBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:passengerCountEconomy rdf:type rdf:Property ;
    rdfs:label 'Passenger Count Economy' ;
    rdfs:comment 'Number of passengers seated in economy cabin.' ;
    rdfs:domain ind:WeightBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:passengerCountFirst rdf:type rdf:Property ;
    rdfs:label 'Passenger Count First' ;
    rdfs:comment 'Number of passengers seated in first class cabin.' ;
    rdfs:domain ind:WeightBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:passengerCountPremiumEconomy rdf:type rdf:Property ;
    rdfs:label 'Passenger Count Premium Economy' ;
    rdfs:comment 'Number of passengers seated in premium economy cabin.' ;
    rdfs:domain ind:WeightBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:passengerCountTotal rdf:type rdf:Property ;
    rdfs:label 'Passenger Count Total' ;
    rdfs:comment 'Total number of passengers on board across all cabin classes (first, business, premium economy, economy).' ;
    rdfs:domain ind:WeightBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:passengerWeightKg rdf:type rdf:Property ;
    rdfs:label 'Passenger Weight Kg' ;
    rdfs:comment 'Total weight of all passengers calculated using standard or actual passenger weights per regulatory requirements.' ;
    rdfs:domain ind:WeightBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preparedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Prepared Timestamp' ;
    rdfs:comment 'Date and time when the weight and balance loadsheet was initially prepared by the loadmaster or dispatcher.' ;
    rdfs:domain ind:WeightBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:specialLoadIndicator rdf:type rdf:Property ;
    rdfs:label 'Special Load Indicator' ;
    rdfs:comment 'Flag indicating whether the flight carries special loads requiring additional handling or documentation (dangerous goods, live animals, human remains, etc.).' ;
    rdfs:domain ind:WeightBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:takeoffFuelKg rdf:type rdf:Property ;
    rdfs:label 'Takeoff Fuel Kg' ;
    rdfs:comment 'Total usable fuel on board at takeoff, including trip fuel, contingency, alternate, final reserve, and additional fuel.' ;
    rdfs:domain ind:WeightBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPayloadKg rdf:type rdf:Property ;
    rdfs:label 'Total Payload Kg' ;
    rdfs:comment 'Total revenue payload weight including passengers, baggage, cargo, and mail.' ;
    rdfs:domain ind:WeightBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trimSetting rdf:type rdf:Property ;
    rdfs:label 'Trim Setting' ;
    rdfs:comment 'Calculated horizontal stabilizer trim setting required for takeoff based on CG position and weight. Entered into flight management system or set manually.' ;
    rdfs:domain ind:WeightBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:underfloorCargoUldCount rdf:type rdf:Property ;
    rdfs:label 'Underfloor Cargo Uld Count' ;
    rdfs:comment 'Number of unit load devices (containers and pallets) loaded in underfloor cargo holds.' ;
    rdfs:domain ind:WeightBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:availabilitySnapshotId rdf:type rdf:Property ;
    rdfs:label 'Availability Snapshot Id' ;
    rdfs:comment 'Unique surrogate identifier for each point-in-time availability snapshot record captured for a flight inventory record.' ;
    rdfs:domain ind:AvailabilitySnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fareClassBucketId rdf:type rdf:Property ;
    rdfs:label 'Fare Class Bucket Id' ;
    rdfs:comment 'Foreign key linking to inventory.fare_class_bucket. Business justification: availability_snapshot captures availability state for a specific fare class bucket (RBD). fare_class_bucket is the master entity for RBD buckets. This FK links snapshot records to the bucket master. b' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FareClassBucket .

ind:advancePurchaseDays rdf:type rdf:Property ;
    rdfs:label 'Advance Purchase Days' ;
    rdfs:comment 'The minimum number of days before departure that a booking must be made to qualify for this fare class bucket at snapshot time. A fare restriction parameter that governs bucket eligibility.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:authorizedCapacity rdf:type rdf:Property ;
    rdfs:label 'Authorized Capacity' ;
    rdfs:comment 'The total number of seats authorized for sale in this cabin at snapshot time, incorporating the overbooking factor applied to physical cabin capacity. Represents the effective sellable ceiling for the cabin.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:availabilityCode rdf:type rdf:Property ;
    rdfs:label 'Availability Code' ;
    rdfs:comment 'The availability indicator code broadcast to GDS channels at snapshot time (e.g., A = available, L = limited, C = closed, R = request). Follows IATA/GDS standard availability display codes used in Amadeus, Sabre, and Travelport.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bucketStatus rdf:type rdf:Property ;
    rdfs:label 'Bucket Status' ;
    rdfs:comment 'The availability status of this fare class bucket as broadcast to GDS and direct channels at snapshot time. Open = seats available for sale; Closed = bucket closed by RM; Waitlist = no seats but waitlist accepted; Request_only = availability subject to manual approval.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelRestrictionFlag rdf:type rdf:Property ;
    rdfs:label 'Channel Restriction Flag' ;
    rdfs:comment 'Indicates whether this fare class bucket has channel-specific distribution restrictions applied at snapshot time (e.g., web-only, GDS-excluded, direct-only). True = one or more channel restrictions are active.' ;
    rdfs:domain ind:AvailabilitySnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:codeshareSeatsAllocated rdf:type rdf:Property ;
    rdfs:label 'Codeshare Seats Allocated' ;
    rdfs:comment 'The number of seats in this fare class bucket allocated to codeshare partner airlines at snapshot time. Represents inventory blocked for partner distribution and reduces the seats available to the operating carrier\'s own channels.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:daysBeforeDeparture rdf:type rdf:Property ;
    rdfs:label 'Days Before Departure' ;
    rdfs:comment 'The number of days between the snapshot timestamp and the scheduled departure date at the time of capture. A critical dimension for revenue management booking curve analysis and demand forecasting model training.' ;
    rdfs:domain ind:AvailabilitySnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gdsBroadcastTimestamp rdf:type rdf:Property ;
    rdfs:label 'Gds Broadcast Timestamp' ;
    rdfs:comment 'The UTC timestamp at which this availability state was broadcast to Global Distribution Systems (Amadeus, Sabre, Travelport). Used for GDS audit trails and latency analysis between snapshot capture and distribution. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:AvailabilitySnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:groupSeatsBlocked rdf:type rdf:Property ;
    rdfs:label 'Group Seats Blocked' ;
    rdfs:comment 'The number of seats in this cabin blocked for confirmed or tentative group bookings at snapshot time. Group blocks reduce the net availability for individual (PNR-level) bookings.' ;
    rdfs:domain ind:AvailabilitySnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isActiveSnapshot rdf:type rdf:Property ;
    rdfs:label 'Is Active Snapshot' ;
    rdfs:comment 'Indicates whether this record represents the most current (latest) availability snapshot for the given flight inventory record and fare class bucket combination. True = this is the current state; False = superseded by a later snapshot. Supports efficient current-state queries without full history scans.' ;
    rdfs:domain ind:AvailabilitySnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loadFactor rdf:type rdf:Property ;
    rdfs:label 'Load Factor' ;
    rdfs:comment 'The cabin-level load factor at snapshot time, expressed as a ratio of seats sold to physical cabin capacity (e.g., 0.8500 = 85%). A key revenue management KPI used to assess fill rate and trigger yield optimization actions. Calculated as seats_sold / physical_capacity.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumStayRequired rdf:type rdf:Property ;
    rdfs:label 'Minimum Stay Required' ;
    rdfs:comment 'Indicates whether a minimum stay condition (e.g., Saturday night stay) is required for bookings in this fare class bucket at snapshot time. True = minimum stay restriction is active on this bucket.' ;
    rdfs:domain ind:AvailabilitySnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overbookingFactor rdf:type rdf:Property ;
    rdfs:label 'Overbooking Factor' ;
    rdfs:comment 'The overbooking multiplier applied to this cabin at snapshot time, expressed as a ratio (e.g., 1.0500 = 5% overbooking above physical capacity). Set by revenue management to account for expected no-shows and cancellations.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:physicalCapacity rdf:type rdf:Property ;
    rdfs:label 'Physical Capacity' ;
    rdfs:comment 'The actual number of physical seats installed in this cabin on the aircraft assigned to this flight at snapshot time. Reflects the aircraft configuration at the time of capture, which may differ from the scheduled configuration.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rmBidPrice rdf:type rdf:Property ;
    rdfs:label 'Rm Bid Price' ;
    rdfs:comment 'The revenue management bid price (opportunity cost threshold) for this cabin at snapshot time, expressed in the operating currency. A booking is accepted only if its revenue exceeds the bid price. Core RM optimization output from Sabre AirVision.' ;
    rdfs:domain ind:AvailabilitySnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rmForecastDemand rdf:type rdf:Property ;
    rdfs:label 'Rm Forecast Demand' ;
    rdfs:comment 'The revenue management system\'s demand forecast (unconstrained) for this fare class bucket at the time of the snapshot, expressed as number of expected bookings. Sourced from Sabre AirVision RM forecasting module. Used for model training and forecast accuracy measurement.' ;
    rdfs:domain ind:AvailabilitySnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seatsAuthorized rdf:type rdf:Property ;
    rdfs:label 'Seats Authorized' ;
    rdfs:comment 'The maximum number of seats authorized by revenue management for sale in this fare class bucket (the bucket cap set by the RM system). Distinct from physical capacity; reflects yield optimization controls from Sabre AirVision.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seatsAvailable rdf:type rdf:Property ;
    rdfs:label 'Seats Available' ;
    rdfs:comment 'The number of seats available for sale in this fare class bucket at the moment of the snapshot. A value of zero indicates the bucket is closed. This is the primary sellable inventory count broadcast to GDS and direct channels.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seatsHeld rdf:type rdf:Property ;
    rdfs:label 'Seats Held' ;
    rdfs:comment 'Number of seats in this bucket currently held under option or waitlist status (not yet confirmed) at snapshot time. Represents tentative demand that may convert to confirmed bookings.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seatsSold rdf:type rdf:Property ;
    rdfs:label 'Seats Sold' ;
    rdfs:comment 'The cumulative number of confirmed bookings (paid and held) in this fare class bucket at the time of the snapshot. Includes codeshare and interline bookings allocated to this bucket.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:snapshotSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Snapshot Sequence Number' ;
    rdfs:comment 'An ordinal sequence number for snapshots taken for the same flight inventory record and fare class bucket, ordered by snapshot_timestamp ascending. Enables reconstruction of the full availability history and booking curve for a given flight-bucket combination.' ;
    rdfs:domain ind:AvailabilitySnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceSystemCode rdf:type rdf:Property ;
    rdfs:label 'Source System Code' ;
    rdfs:comment 'Identifies the operational system that generated or triggered this availability snapshot. ALTEA = Amadeus Altéa Inventory (primary PSS); SABRE_AV = Sabre AirVision RM override; NETLINE = Lufthansa Systems NetLine/Ops operational change; MANUAL = manually entered override.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggerReason rdf:type rdf:Property ;
    rdfs:label 'Trigger Reason' ;
    rdfs:comment 'The business event or condition that caused this snapshot to be taken. Distinguishes between routine scheduled captures, threshold-driven captures (booking or cancellation crossing a bucket boundary), manual revenue management overrides, reaccommodation events (IROPs), and overbooking adjustments. [ENUM-REF-CANDIDATE: scheduled|booking_threshold|cancellation_threshold|manual_override|reaccommodation|overbooking_adjustment — promote to reference product]' ;
    rdfs:domain ind:AvailabilitySnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upgradeSeatsUsed rdf:type rdf:Property ;
    rdfs:label 'Upgrade Seats Used' ;
    rdfs:comment 'The number of seats in this cabin occupied by passengers who have been upgraded from a lower cabin class (operational, complimentary, or mileage-based upgrades) at snapshot time. Affects net revenue yield for the cabin.' ;
    rdfs:domain ind:AvailabilitySnapshot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:waitlistCount rdf:type rdf:Property ;
    rdfs:label 'Waitlist Count' ;
    rdfs:comment 'The number of passengers currently on the waitlist for this fare class bucket at snapshot time. A non-zero value when bucket_status is \'waitlist\' or \'closed\', indicating latent demand that may be cleared if cancellations occur.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bucketAdjustmentId rdf:type rdf:Property ;
    rdfs:label 'Bucket Adjustment Id' ;
    rdfs:comment 'Unique surrogate identifier for each inventory bucket adjustment audit record in the silver layer lakehouse. Primary key for this transactional audit entity.' ;
    rdfs:domain ind:BucketAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rmForecastId rdf:type rdf:Property ;
    rdfs:label 'Rm Forecast Id' ;
    rdfs:comment 'Reference to the revenue management demand forecast record in Sabre AirVision that triggered or informed this automated inventory adjustment. Links the audit record to the RM optimization decision for post-departure forecast accuracy analysis.' ;
    rdfs:domain ind:BucketAdjustment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Forecast .

ind:adjustmentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Adjustment Reference Number' ;
    rdfs:comment 'Externally-known alphanumeric reference number assigned to this inventory adjustment event, used for cross-system traceability between Altéa Inventory, Sabre AirVision Revenue Management, and GDS channels.' ;
    rdfs:domain ind:BucketAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentScope rdf:type rdf:Property ;
    rdfs:label 'Adjustment Scope' ;
    rdfs:comment 'Defines the granularity level at which this inventory adjustment was applied: \'flight\' (entire flight stop-sale or reopen), \'cabin\' (all buckets within a cabin class), or \'bucket\' (a specific fare class booking designator). Determines which of the cabin_code and booking_class_code fields are applicable.' ;
    rdfs:domain ind:BucketAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentStatus rdf:type rdf:Property ;
    rdfs:label 'Adjustment Status' ;
    rdfs:comment 'Current lifecycle state of this adjustment record. \'applied\' indicates the change is live in inventory; \'reversed\' indicates a subsequent correction nullified this action; \'superseded\' indicates a later adjustment replaced this one.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentType rdf:type rdf:Property ;
    rdfs:label 'Adjustment Type' ;
    rdfs:comment 'Categorical discriminator identifying the nature of the inventory control action applied. Drives downstream revenue analysis and audit classification. [ENUM-REF-CANDIDATE: bucket_limit_change|status_change|cabin_closure|flight_stop_sale|flight_reopen|codeshare_reallocation — promote to reference product]' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:afterAuthorizationLevel rdf:type rdf:Property ;
    rdfs:label 'After Authorization Level' ;
    rdfs:comment 'The bucket authorization level (seat limit / cap) set by this adjustment. Represents the maximum number of seats authorized for sale in this booking class after the change is applied. Delta from before_authorization_level quantifies the inventory impact.' ;
    rdfs:domain ind:BucketAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:afterBucketStatus rdf:type rdf:Property ;
    rdfs:label 'After Bucket Status' ;
    rdfs:comment 'The availability status of the fare class bucket set by this adjustment. Captures whether the bucket is now open for sale, closed, on waitlist, or request-only after the change is applied.' ;
    rdfs:domain ind:BucketAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beforeAuthorizationLevel rdf:type rdf:Property ;
    rdfs:label 'Before Authorization Level' ;
    rdfs:comment 'The bucket authorization level (seat limit / cap) in effect immediately before this adjustment was applied. Represents the maximum number of seats authorized for sale in this booking class prior to the change. Used for before/after delta analysis in revenue management.' ;
    rdfs:domain ind:BucketAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:beforeBucketStatus rdf:type rdf:Property ;
    rdfs:label 'Before Bucket Status' ;
    rdfs:comment 'The availability status of the fare class bucket immediately before this adjustment. Captures whether the bucket was open for sale, closed, on waitlist, or request-only prior to the change.' ;
    rdfs:domain ind:BucketAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookingClassCode rdf:type rdf:Property ;
    rdfs:label 'Booking Class Code' ;
    rdfs:comment 'Single-letter IATA Reservation Booking Designator (RBD) identifying the fare class bucket affected by this adjustment (e.g., Y, B, M, Q, V, G). Null for flight-level or cabin-level adjustments that span all buckets.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelRestriction rdf:type rdf:Property ;
    rdfs:label 'Channel Restriction' ;
    rdfs:comment 'Specifies whether this inventory adjustment applies to all distribution channels or is restricted to a specific channel subset: GDS (Global Distribution System), direct (airline.com and mobile), or NDC (New Distribution Capability) channels only. \'none\' indicates no channel restriction is applied.' ;
    rdfs:domain ind:BucketAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codesharePartnerCode rdf:type rdf:Property ;
    rdfs:label 'Codeshare Partner Code' ;
    rdfs:comment 'Two-character IATA airline designator of the codeshare marketing partner whose inventory allocation is affected by this adjustment. Populated only when is_codeshare_affected is True. Used to reconcile codeshare inventory reallocation events with partner settlement.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daysToDeparture rdf:type rdf:Property ;
    rdfs:label 'Days To Departure' ;
    rdfs:comment 'Number of days between the effective_timestamp of this adjustment and the scheduled flight departure date. Critical revenue management context metric used to analyze booking curve behavior and evaluate the appropriateness of inventory control decisions at each booking horizon.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:initiatingSystem rdf:type rdf:Property ;
    rdfs:label 'Initiating System' ;
    rdfs:comment 'Identifies the operational system or channel that triggered this inventory adjustment. Distinguishes automated revenue management actions (Sabre AirVision) from inventory system actions (Altéa Inventory), operations control actions (NetLine/Ops for IROPs), and manual analyst overrides.' ;
    rdfs:domain ind:BucketAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iropEventReference rdf:type rdf:Property ;
    rdfs:label 'Irop Event Reference' ;
    rdfs:comment 'Reference identifier linking this inventory adjustment to a specific Irregular Operations (IROP) event such as a cancellation, diversion, or significant delay that necessitated inventory reprotection or stop-sale actions. Null for non-IROP-driven adjustments.' ;
    rdfs:domain ind:BucketAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAutomated rdf:type rdf:Property ;
    rdfs:label 'Is Automated' ;
    rdfs:comment 'Indicates whether this inventory adjustment was triggered automatically by a revenue management system rule or algorithm (True) versus initiated manually by a revenue management analyst (False). Enables segregation of automated vs. manual control decisions in audit and performance analysis.' ;
    rdfs:domain ind:BucketAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCodeshareAffected rdf:type rdf:Property ;
    rdfs:label 'Is Codeshare Affected' ;
    rdfs:comment 'Indicates whether this inventory adjustment affects codeshare inventory allocations (True) in addition to or instead of the operating carrier\'s own inventory. When True, the codeshare_partner_code field identifies the affected marketing carrier.' ;
    rdfs:domain ind:BucketAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loadFactorAtAdjustment rdf:type rdf:Property ;
    rdfs:label 'Load Factor At Adjustment' ;
    rdfs:comment 'The cabin or flight load factor (percentage of seats filled) at the time this adjustment was triggered. Expressed as a decimal percentage (e.g., 0.85 = 85%). Key context metric for revenue management yield optimization analysis and threshold-triggered automation.' ;
    rdfs:domain ind:BucketAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overbookingFactorAfter rdf:type rdf:Property ;
    rdfs:label 'Overbooking Factor After' ;
    rdfs:comment 'The overbooking authorization factor (as a percentage above physical capacity) set by this adjustment for this cabin/bucket. Compared against overbooking_factor_before to quantify the overbooking control change applied.' ;
    rdfs:domain ind:BucketAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overbookingFactorBefore rdf:type rdf:Property ;
    rdfs:label 'Overbooking Factor Before' ;
    rdfs:comment 'The overbooking authorization factor (as a percentage above physical capacity) in effect for this cabin/bucket immediately before this adjustment. For example, 1.10 represents 110% of physical seat capacity authorized. Used to audit overbooking control decisions.' ;
    rdfs:domain ind:BucketAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reversalReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Reversal Reference Number' ;
    rdfs:comment 'The adjustment_reference_number of the subsequent adjustment record that reversed or superseded this action. Populated only when adjustment_status is \'reversed\' or \'superseded\'. Enables full audit chain reconstruction for compliance and revenue analysis.' ;
    rdfs:domain ind:BucketAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seatsAvailableAfter rdf:type rdf:Property ;
    rdfs:label 'Seats Available After' ;
    rdfs:comment 'The count of seats available for sale in this fare class bucket immediately after this adjustment was applied. Compared against seats_available_before to measure the net availability impact on GDS and direct channel inventory.' ;
    rdfs:domain ind:BucketAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seatsAvailableBefore rdf:type rdf:Property ;
    rdfs:label 'Seats Available Before' ;
    rdfs:comment 'The count of seats available for sale in this fare class bucket immediately before this adjustment was applied. Snapshot of the real-time availability figure consumed by GDS channels prior to the change.' ;
    rdfs:domain ind:BucketAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceSystemTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Source System Transaction Reference' ;
    rdfs:comment 'The native transaction or message identifier assigned by the originating operational system (Altéa Inventory, Sabre AirVision, or NetLine/Ops) for this adjustment event. Enables traceability back to the system-of-record for reconciliation and dispute resolution.' ;
    rdfs:domain ind:BucketAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cabinConfigurationPartMasterId rdf:type rdf:Property ;
    rdfs:label 'Cabin Configuration Part Master Id' ;
    rdfs:comment 'Foreign key linking to procurement.part_master. Business justification: Cabin configurations require specific parts (seats, IFE units, galley equipment). Procurement must know which parts are compatible with each cabin class for refurbishment projects, spare parts plannin' ;
    rdfs:domain ind:CabinClass ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PartMaster .

ind:applicableFlightRange rdf:type rdf:Property ;
    rdfs:label 'Applicable Flight Range' ;
    rdfs:comment 'Flight range category for which this cabin class configuration is applicable: \'short_haul\' (under 3 hours), \'medium_haul\' (3–6 hours), \'long_haul\' (6–12 hours), \'ultra_long_haul\' (over 12 hours), or \'all\'. Drives route-specific product deployment and inventory segmentation.' ;
    rdfs:domain ind:CabinClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baggagePiecesAllowed rdf:type rdf:Property ;
    rdfs:label 'Baggage Pieces Allowed' ;
    rdfs:comment 'Number of checked baggage pieces included in the standard allowance for this cabin class under the piece concept. Applicable for routes governed by IATA piece concept (primarily transatlantic and transpacific). Complements baggage_allowance_kg for weight-concept routes.' ;
    rdfs:domain ind:CabinClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cabinClassStatus rdf:type rdf:Property ;
    rdfs:label 'Cabin Class Status' ;
    rdfs:comment 'Current lifecycle status of the cabin class record. \'active\' indicates the cabin is currently offered and sellable; \'inactive\' indicates temporarily suspended; \'retired\' indicates permanently discontinued; \'pending\' indicates configured but not yet activated for sale.' ;
    rdfs:domain ind:CabinClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cabinCode rdf:type rdf:Property ;
    rdfs:label 'Cabin Code' ;
    rdfs:comment 'Airline-internal alphanumeric code uniquely identifying the cabin class within the carrier\'s Passenger Service System (PSS). Used in Amadeus Altéa Inventory for cabin-level availability and inventory management. May differ from the IATA designator when the airline operates sub-cabin variants.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cabinName rdf:type rdf:Property ;
    rdfs:label 'Cabin Name' ;
    rdfs:comment 'Commercial marketing name of the cabin class as presented to passengers and travel agents (e.g., \'First Class\', \'Business Class\', \'Premium Economy\', \'Economy\'). Used in passenger-facing communications, booking flows, and GDS displays.' ;
    rdfs:domain ind:CabinClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cabinType rdf:type rdf:Property ;
    rdfs:label 'Cabin Type' ;
    rdfs:comment 'Standardized classification of the cabin into one of the four IATA-recognized commercial cabin tiers: first, business, premium_economy, or economy. Drives revenue management segmentation, yield optimization in Sabre AirVision, and inventory bucket hierarchy.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carryOnAllowanceKg rdf:type rdf:Property ;
    rdfs:label 'Carry On Allowance Kg' ;
    rdfs:comment 'Maximum weight in kilograms permitted for carry-on baggage in the cabin for this cabin class. Used in ground handling operations, security screening coordination with TSA/EASA, and passenger service standards.' ;
    rdfs:domain ind:CabinClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:codeshareSellable rdf:type rdf:Property ;
    rdfs:label 'Codeshare Sellable' ;
    rdfs:comment 'Indicates whether this cabin class can be sold on codeshare flights operated by partner airlines. When true, inventory allocations for this cabin are made available to codeshare partners through interline agreements. Drives GDS availability display for codeshare itineraries.' ;
    rdfs:domain ind:CabinClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discontinuationDate rdf:type rdf:Property ;
    rdfs:label 'Discontinuation Date' ;
    rdfs:comment 'Date on which this cabin class definition is retired and no longer available for new bookings. Null for currently active cabin classes. Supports historical inventory analysis and regulatory record retention requirements.' ;
    rdfs:domain ind:CabinClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fareBasisPrefix rdf:type rdf:Property ;
    rdfs:label 'Fare Basis Prefix' ;
    rdfs:comment 'Standard alphabetic prefix used in fare basis codes for this cabin class (e.g., \'Y\' for Economy, \'C\' for Business, \'F\' for First). Aligns fare construction with IATA fare basis code conventions and drives revenue management fare class bucket assignment in Sabre AirVision.' ;
    rdfs:domain ind:CabinClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ffpAccrualMultiplier rdf:type rdf:Property ;
    rdfs:label 'Ffp Accrual Multiplier' ;
    rdfs:comment 'Multiplier applied to base miles flown to calculate Frequent Flyer Program (FFP) miles or points accrued for travel in this cabin class. For example, a value of 2.0 means passengers earn double miles. Feeds Oracle Loyalty Cloud FFP accrual engine.' ;
    rdfs:domain ind:CabinClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gdsDisplayCode rdf:type rdf:Property ;
    rdfs:label 'Gds Display Code' ;
    rdfs:comment 'Code used to represent this cabin class in Global Distribution System (GDS) availability displays (e.g., Amadeus, Sabre, Travelport). May differ from the internal cabin_code for legacy GDS compatibility. Ensures correct cabin identification in travel agent booking workflows.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iataCabinDesignator rdf:type rdf:Property ;
    rdfs:label 'Iata Cabin Designator' ;
    rdfs:comment 'Single-letter IATA standard cabin designator code identifying the commercial cabin class (e.g., F = First, C = Business, W = Premium Economy, Y = Economy). Used as the industry-standard booking class grouping code across Global Distribution Systems (GDS) and interline agreements.' ;
    rdfs:domain ind:CabinClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ifeType rdf:type rdf:Property ;
    rdfs:label 'Ife Type' ;
    rdfs:comment 'Type of In-Flight Entertainment (IFE) system available in this cabin class: \'seatback_screen\' = personal seatback display, \'overhead_screen\' = shared overhead monitors, \'personal_device\' = bring-your-own-device streaming, \'none\' = no IFE. Used in product definition and passenger experience standards.' ;
    rdfs:domain ind:CabinClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isLieFlat rdf:type rdf:Property ;
    rdfs:label 'Is Lie Flat' ;
    rdfs:comment 'Indicates whether the seats in this cabin class convert to a fully flat sleeping surface (180-degree recline). True for premium long-haul First and Business class products. Critical for product differentiation, revenue management premium pricing, and GDS display.' ;
    rdfs:domain ind:CabinClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loungeAccessEntitlement rdf:type rdf:Property ;
    rdfs:label 'Lounge Access Entitlement' ;
    rdfs:comment 'Level of airport lounge access included with this cabin class: \'none\' = no lounge access, \'home_carrier\' = access to the airline\'s own lounges only, \'partner\' = access to partner airline lounges, \'all_alliance\' = full alliance lounge network access. Drives ground handling instructions and passenger service delivery.' ;
    rdfs:domain ind:CabinClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxOverbookingPct rdf:type rdf:Property ;
    rdfs:label 'Max Overbooking Pct' ;
    rdfs:comment 'Maximum percentage above physical seat capacity that bookings may be accepted for this cabin class under the airline\'s overbooking policy. For example, 10.00 means up to 110% of seats may be sold. Null when overbooking_allowed is false. Governed by DOT regulations.' ;
    rdfs:domain ind:CabinClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mealServiceType rdf:type rdf:Property ;
    rdfs:label 'Meal Service Type' ;
    rdfs:comment 'Standard meal service type provided in this cabin class: \'full_meal\' = multi-course meal service, \'light_meal\' = single-course meal, \'snack\' = snack and beverage only, \'buy_on_board\' = no complimentary meal, \'none\' = no food service. Drives catering uplift planning and galley configuration.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overbookingAllowed rdf:type rdf:Property ;
    rdfs:label 'Overbooking Allowed' ;
    rdfs:comment 'Indicates whether overbooking is permitted for this cabin class. When true, the inventory system may accept bookings beyond physical seat capacity based on no-show forecasting models. Governed by DOT overbooking regulations and airline revenue management policy.' ;
    rdfs:domain ind:CabinClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorityBoarding rdf:type rdf:Property ;
    rdfs:label 'Priority Boarding' ;
    rdfs:comment 'Indicates whether passengers in this cabin class receive priority boarding privileges ahead of general boarding groups. Drives boarding sequence configuration in SITA Airport Management Platform and ground handling SOPs.' ;
    rdfs:domain ind:CabinClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorityCheckIn rdf:type rdf:Property ;
    rdfs:label 'Priority Check In' ;
    rdfs:comment 'Indicates whether passengers in this cabin class are entitled to dedicated priority check-in counters or lanes. Drives airport operations configuration in SITA Airport Management Platform and ground handling service level agreements.' ;
    rdfs:domain ind:CabinClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revenueClassHierarchy rdf:type rdf:Property ;
    rdfs:label 'Revenue Class Hierarchy' ;
    rdfs:comment 'Numeric rank defining the commercial hierarchy of this cabin class relative to others (1 = highest/First, 4 = lowest/Economy). Used by Sabre AirVision Revenue Management for yield optimization, upgrade logic, and inventory nesting rules. Lower number = higher revenue class.' ;
    rdfs:domain ind:CabinClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seatConfigurationCode rdf:type rdf:Property ;
    rdfs:label 'Seat Configuration Code' ;
    rdfs:comment 'Standard seat layout configuration code for this cabin class expressed as a row-abreast pattern (e.g., \'2-2-2\' for Business, \'3-3-3\' for Economy). Reflects the physical seat arrangement across the aircraft cross-section. Sourced from aircraft type configuration in AMOS.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seatReclineInches rdf:type rdf:Property ;
    rdfs:label 'Seat Recline Inches' ;
    rdfs:comment 'Maximum recline distance in inches for seats in this cabin class. Distinguishes flat-bed (Business/First) from recliner (Premium Economy) and standard recline (Economy) product tiers. Used in product definition and passenger experience standards.' ;
    rdfs:domain ind:CabinClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceLevelDescription rdf:type rdf:Property ;
    rdfs:label 'Service Level Description' ;
    rdfs:comment 'Narrative description of the service standards, amenities, and passenger experience associated with this cabin class. Includes details such as meal service type, lounge access entitlement, priority boarding, and onboard entertainment offerings. Used for product definition and customer communication.' ;
    rdfs:domain ind:CabinClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upgradeEligible rdf:type rdf:Property ;
    rdfs:label 'Upgrade Eligible' ;
    rdfs:comment 'Indicates whether passengers booked in this cabin class are eligible to receive complimentary or paid upgrades to a higher cabin class. Drives upgrade logic in Amadeus Altéa Inventory and Oracle Loyalty Cloud FFP upgrade award processing.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:upgradeTargetCabinCode rdf:type rdf:Property ;
    rdfs:label 'Upgrade Target Cabin Code' ;
    rdfs:comment 'Cabin code of the next higher cabin class to which passengers in this cabin may be upgraded. Null for the highest cabin class (First). Used in automated upgrade processing and FFP award redemption workflows.' ;
    rdfs:domain ind:CabinClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codeshareAllocationId rdf:type rdf:Property ;
    rdfs:label 'Codeshare Allocation Id' ;
    rdfs:comment 'Unique surrogate identifier for the codeshare or interline inventory allocation record within the Amadeus Altéa Inventory system. Primary key for this entity.' ;
    rdfs:domain ind:CodeshareAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bilateralAsaId rdf:type rdf:Property ;
    rdfs:label 'Bilateral Asa Id' ;
    rdfs:comment 'Reference to the governing bilateral codeshare or interline agreement between the operating carrier and the marketing carrier that authorises this allocation.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BilateralAsa .

ind:operatingCarrierId rdf:type rdf:Property ;
    rdfs:label 'Operating Carrier Id' ;
    rdfs:comment 'Reference to the airline that physically operates the flight on which this inventory allocation is granted. The operating carrier owns the aircraft and crew.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:operatingCarrierOrgUnitId rdf:type rdf:Property ;
    rdfs:label 'Operating Carrier Org Unit Id' ;
    rdfs:comment 'Foreign key linking to workforce.org_unit. Business justification: Operating carriers in codeshare agreements are airline organizational units (divisions/subsidiaries). Essential for codeshare revenue allocation, bilateral agreement compliance tracking, and operation' ;
    rdfs:domain ind:CodeshareAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:operatingCarrierVendorId rdf:type rdf:Property ;
    rdfs:label 'Operating Carrier Vendor Id' ;
    rdfs:comment 'Foreign key linking to procurement.vendor. Business justification: Operating carrier in codeshare is a vendor for settlement purposes. Prorate agreements, revenue sharing, and interline billing require vendor master linkage. Finance uses this for accounts payable/rec' ;
    rdfs:domain ind:CodeshareAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:allocationStatus rdf:type rdf:Property ;
    rdfs:label 'Allocation Status' ;
    rdfs:comment 'Current lifecycle state of the codeshare allocation record within Altéa Inventory. \'active\' means the allocation is live and available for booking; \'suspended\' means temporarily halted; \'cancelled\' means permanently withdrawn; \'pending\' means awaiting activation; \'expired\' means the flight date has passed.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationType rdf:type rdf:Property ;
    rdfs:label 'Allocation Type' ;
    rdfs:comment 'Defines the inventory control mechanism governing this codeshare allocation. \'block_space\' means a fixed seat block is ring-fenced for the marketing carrier regardless of overall availability; \'free_flow\' means the marketing carrier draws from the operating carrier\'s shared availability pool without a hard block; \'hybrid\' combines a guaranteed minimum block with free-flow access above it.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alteaAllocationReference rdf:type rdf:Property ;
    rdfs:label 'Altea Allocation Reference' ;
    rdfs:comment 'Native allocation reference identifier assigned by the Amadeus Altéa Inventory system for this codeshare block. Used for reconciliation and traceability back to the operational PSS source record.' ;
    rdfs:domain ind:CodeshareAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedSeatCount rdf:type rdf:Property ;
    rdfs:label 'Authorized Seat Count' ;
    rdfs:comment 'Maximum number of seats the marketing carrier is authorised to sell on this flight-date and cabin under this allocation. For block-space agreements this is the contracted block size; for free-flow it represents the cap agreed in the bilateral.' ;
    rdfs:domain ind:CodeshareAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:availabilitySnapshotTimestamp rdf:type rdf:Property ;
    rdfs:label 'Availability Snapshot Timestamp' ;
    rdfs:comment 'Timestamp of the most recent real-time availability snapshot captured from Altéa Inventory for this allocation. Used by GDS and direct channels to serve current seat availability to booking agents.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:daysOfOperation rdf:type rdf:Property ;
    rdfs:label 'Days Of Operation' ;
    rdfs:comment 'IATA-standard days-of-week string indicating on which days of the week this allocation applies within the effective date range (e.g., \'1234567\' = daily, \'135\' = Mon/Wed/Fri). Encoded as ISO weekday numbers 1=Monday through 7=Sunday.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationIataCode rdf:type rdf:Property ;
    rdfs:label 'Destination Iata Code' ;
    rdfs:comment 'Three-letter IATA airport code for the arrival airport of the operating flight segment covered by this allocation (e.g., CDG, SIN, ORD).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fareClassBucket rdf:type rdf:Property ;
    rdfs:label 'Fare Class Bucket' ;
    rdfs:comment 'IATA booking class (RBD — Reservation Booking Designator) within the cabin to which this allocation is mapped in Altéa Inventory (e.g., Y, B, M, Q, V). Determines the yield tier at which the marketing carrier\'s seats are ring-fenced.' ;
    rdfs:domain ind:CodeshareAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdsAvailabilityIndicator rdf:type rdf:Property ;
    rdfs:label 'Gds Availability Indicator' ;
    rdfs:comment 'Flag indicating whether the marketing carrier\'s availability under this allocation is published and visible in Global Distribution Systems (GDS) such as Amadeus, Sabre, and Travelport. When False, the allocation is restricted to direct or NDC channels only.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastSeatDate rdf:type rdf:Property ;
    rdfs:label 'Last Seat Date' ;
    rdfs:comment 'Latest date on which the marketing carrier may sell the last available seat under this allocation before the booking window closes. May differ from the flight date due to advance purchase restrictions in the bilateral.' ;
    rdfs:domain ind:CodeshareAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:marketingFlightNumber rdf:type rdf:Property ;
    rdfs:label 'Marketing Flight Number' ;
    rdfs:comment 'IATA-format flight designator under which the marketing carrier sells the codeshare seats (e.g., BA5678). This is the flight number visible to passengers booking through the marketing carrier.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumSeatThreshold rdf:type rdf:Property ;
    rdfs:label 'Maximum Seat Threshold' ;
    rdfs:comment 'Hard upper limit on the number of seats the marketing carrier may sell on this flight-date and cabin, enforced by Altéa Inventory to prevent over-allocation beyond the bilateral agreement cap.' ;
    rdfs:domain ind:CodeshareAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumSeatThreshold rdf:type rdf:Property ;
    rdfs:label 'Minimum Seat Threshold' ;
    rdfs:comment 'Minimum number of seats guaranteed to the marketing carrier that the operating carrier must hold available regardless of overall flight demand. Relevant for block-space and hybrid allocation types. Null for pure free-flow allocations.' ;
    rdfs:domain ind:CodeshareAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operatingFlightNumber rdf:type rdf:Property ;
    rdfs:label 'Operating Flight Number' ;
    rdfs:comment 'IATA-format flight designator of the operating carrier (e.g., AA1234). Identifies the physical flight on which the codeshare seats are allocated.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originIataCode rdf:type rdf:Property ;
    rdfs:label 'Origin Iata Code' ;
    rdfs:comment 'Three-letter IATA airport code for the departure airport of the operating flight segment covered by this allocation (e.g., LHR, JFK, DXB).' ;
    rdfs:domain ind:CodeshareAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prorateAgreementCode rdf:type rdf:Property ;
    rdfs:label 'Prorate Agreement Code' ;
    rdfs:comment 'Code referencing the revenue proration agreement between the operating and marketing carriers that governs how ticket revenue is split for seats sold under this codeshare allocation. Aligns with IATA BSP prorate rules.' ;
    rdfs:domain ind:CodeshareAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseDate rdf:type rdf:Property ;
    rdfs:label 'Release Date' ;
    rdfs:comment 'Date on which any unsold seats in a block-space allocation are automatically released back to the operating carrier\'s general inventory pool for unrestricted sale. Null for free-flow allocations where no block is held.' ;
    rdfs:domain ind:CodeshareAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:releaseDaysPrior rdf:type rdf:Property ;
    rdfs:label 'Release Days Prior' ;
    rdfs:comment 'Number of days before scheduled departure at which unsold block-space seats are automatically released to the operating carrier\'s open inventory. Derived from the bilateral agreement terms and used to compute release_date.' ;
    rdfs:domain ind:CodeshareAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revenueSharePercentage rdf:type rdf:Property ;
    rdfs:label 'Revenue Share Percentage' ;
    rdfs:comment 'Percentage of ticket revenue attributable to the operating carrier for seats sold by the marketing carrier under this allocation, as stipulated in the bilateral prorate agreement. Commercially sensitive.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inventoryLegId rdf:type rdf:Property ;
    rdfs:label 'Inventory Leg Id' ;
    rdfs:comment 'Reference to the flight inventory leg record to which this fare class bucket belongs. Links the bucket to a specific flight-date-leg combination managed in Altéa Inventory.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InventoryLeg .

ind:promotionalFareId rdf:type rdf:Property ;
    rdfs:label 'Promotional Fare Id' ;
    rdfs:comment 'Foreign key linking to marketing.promotional_fare. Business justification: Promotional fares must be mapped to specific RBD buckets for inventory control. Revenue management systems authorize promotional inventory at the bucket level. Critical for integrating marketing promo' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PromotionalFare .

ind:authorizedUnits rdf:type rdf:Property ;
    rdfs:label 'Authorized Units' ;
    rdfs:comment 'Authorized capacity (AU) — the maximum number of seats the revenue management system has authorized for sale in this booking class bucket for the flight leg. Set by Sabre AirVision yield optimization and loaded into Altéa Inventory. Core inventory control parameter.' ;
    rdfs:domain ind:FareClassBucket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bookingLimit rdf:type rdf:Property ;
    rdfs:label 'Booking Limit' ;
    rdfs:comment 'Booking limit (BL) — the maximum cumulative number of bookings permitted across this bucket and all lower-yield buckets nested beneath it. Enforced in real time by Altéa Inventory to prevent overselling beyond the authorized level.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bucketRank rdf:type rdf:Property ;
    rdfs:label 'Bucket Rank' ;
    rdfs:comment 'Ordinal position of this RBD bucket within its cabin hierarchy, from highest-yield (rank 1) to lowest-yield. Used by Sabre AirVision and Altéa Inventory to determine availability cascade — a lower-ranked (higher-yield) bucket must be open before a higher-ranked (lower-yield) bucket can sell.' ;
    rdfs:domain ind:FareClassBucket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:changeFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Change Fee Amount' ;
    rdfs:comment 'Monetary penalty charged to the passenger for a voluntary itinerary change on a ticket issued under this booking class, expressed in the filing currency. A value of 0.00 indicates no change fee. Commercially sensitive pricing parameter.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:changeFeeCurrency rdf:type rdf:Property ;
    rdfs:label 'Change Fee Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the change fee amount is denominated (e.g., USD, EUR, GBP). Required for multi-currency fare filing and BSP/ARC settlement.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentBookings rdf:type rdf:Property ;
    rdfs:label 'Current Bookings' ;
    rdfs:comment 'Number of confirmed bookings currently held against this fare class bucket. Updated in near-real-time from Altéa Inventory as PNRs are created, modified, or cancelled. Used to compute remaining availability.' ;
    rdfs:domain ind:FareClassBucket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fareFamilyCode rdf:type rdf:Property ;
    rdfs:label 'Fare Family Code' ;
    rdfs:comment 'Branded fare family or product bundle code associated with this booking class (e.g., BASIC, STANDARD, FLEX, BUSINESS_PLUS). Aligns the RBD bucket with the airline\'s branded fare product hierarchy for ancillary bundling and NDC offer construction.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupBlockSeats rdf:type rdf:Property ;
    rdfs:label 'Group Block Seats' ;
    rdfs:comment 'Number of seats within this bucket reserved as a group block allocation. A value of 0 indicates no group block. Group blocks are managed separately from individual seat availability and are subject to group contract terms.' ;
    rdfs:domain ind:FareClassBucket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isChangeable rdf:type rdf:Property ;
    rdfs:label 'Is Changeable' ;
    rdfs:comment 'Indicates whether the itinerary booked under this fare class may be voluntarily changed (True) or is a fixed non-changeable ticket (False). Relevant for IROP handling, voluntary rebooking, and ancillary change-fee revenue.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastRmUpdateTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Rm Update Timestamp' ;
    rdfs:comment 'Timestamp of the most recent authorized unit or booking limit update pushed from Sabre AirVision to Altéa Inventory. Enables audit of RM optimization cycle frequency and latency monitoring between the two systems.' ;
    rdfs:domain ind:FareClassBucket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:loadFactorPct rdf:type rdf:Property ;
    rdfs:label 'Load Factor Pct' ;
    rdfs:comment 'Current load factor for this fare class bucket expressed as a percentage (current_bookings / authorized_units × 100). Stored as a snapshot field for real-time RM monitoring and GDS availability optimization. Aligns with IATA load factor (percentage of seats filled) definition.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxStayDays rdf:type rdf:Property ;
    rdfs:label 'Max Stay Days' ;
    rdfs:comment 'Maximum number of days the passenger may remain at the destination before return travel must commence for fares in this booking class. A null value indicates no maximum stay restriction. Standard fare restriction filed with ATPCO.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minStayDays rdf:type rdf:Property ;
    rdfs:label 'Min Stay Days' ;
    rdfs:comment 'Minimum number of days the passenger must remain at the destination before return travel is permitted for fares in this booking class. A value of 0 indicates no minimum stay restriction. Standard fare restriction filed with ATPCO.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:protectionLevel rdf:type rdf:Property ;
    rdfs:label 'Protection Level' ;
    rdfs:comment 'Number of seats protected (reserved) for higher-yield demand in this bucket, as computed by the EMSR (Expected Marginal Seat Revenue) optimization in Sabre AirVision. Prevents lower-yield bookings from displacing higher-yield passengers. Core RM optimization output.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rbdCode rdf:type rdf:Property ;
    rdfs:label 'Rbd Code' ;
    rdfs:comment 'Single uppercase IATA letter identifying the booking class (e.g., Y, B, M, Q, V, H, K, L, S, N, O, G). The RBD is the atomic unit of inventory control in Altéa Inventory and the direct input to Sabre AirVision yield optimization. Governed by IATA Resolution 728.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sellUpTargetRbd rdf:type rdf:Property ;
    rdfs:label 'Sell Up Target Rbd' ;
    rdfs:comment 'The preferred higher-yield RBD code to which Sabre AirVision should attempt to sell up when this bucket is closed or constrained. Commercially sensitive RM strategy parameter used in availability cascade logic.' ;
    rdfs:domain ind:FareClassBucket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yieldClass rdf:type rdf:Property ;
    rdfs:label 'Yield Class' ;
    rdfs:comment 'Revenue management yield classification assigned to this bucket by Sabre AirVision, grouping RBDs into broad yield tiers for reporting and optimization. Commercially sensitive as it reveals pricing strategy segmentation.' ;
    rdfs:domain ind:FareClassBucket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fleetAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Fleet Assignment Id' ;
    rdfs:comment 'Foreign key linking to route.route_fleet_assignment. Business justification: Fleet assignment determines aircraft type, seat configuration, and cabin class capacity that inventory must control. Revenue management bucket authorization, overbooking limits, and codeshare allocati' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FleetAssignment .

ind:seasonalScheduleId rdf:type rdf:Property ;
    rdfs:label 'Seasonal Schedule Id' ;
    rdfs:comment 'Foreign key linking to route.seasonal_schedule. Business justification: Flight inventory operationalizes a specific seasonal schedule template. Linking inventory to seasonal_schedule enables variance analysis (planned vs actual capacity), schedule change impact assessment' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SeasonalSchedule .

ind:alteaInventoryKey rdf:type rdf:Property ;
    rdfs:label 'Altea Inventory Key' ;
    rdfs:comment 'Native primary key or reference identifier assigned by the Amadeus Altéa Inventory system to this flight inventory record. Used for system-of-record traceability and reconciliation between the lakehouse Silver layer and the operational PSS.' ;
    rdfs:domain ind:FlightInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookingCurveDay rdf:type rdf:Property ;
    rdfs:label 'Booking Curve Day' ;
    rdfs:comment 'Number of days prior to departure at which this inventory snapshot was captured, representing the position on the booking curve (e.g., 90, 60, 30, 14, 7, 1). Used by Sabre AirVision Revenue Management for demand forecasting and fare class optimization.' ;
    rdfs:domain ind:FlightInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:businessClassCapacity rdf:type rdf:Property ;
    rdfs:label 'Business Class Capacity' ;
    rdfs:comment 'Total number of seats allocated to the Business Class cabin on this flight-date. Reflects the aircraft configuration and any cabin reconfiguration applied for this specific flight.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:channelRestrictionCode rdf:type rdf:Property ;
    rdfs:label 'Channel Restriction Code' ;
    rdfs:comment 'Code indicating any channel-specific sales restrictions applied to this flight inventory (e.g., \'DIRECT_ONLY\' for web/app exclusive fares, \'GDS_BLOCKED\' for GDS channel closure, \'NDC_ONLY\' for IATA NDC channel exclusivity). Controls distribution channel access to inventory.' ;
    rdfs:domain ind:FlightInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:economyCapacity rdf:type rdf:Property ;
    rdfs:label 'Economy Capacity' ;
    rdfs:comment 'Total number of seats allocated to the Economy Class cabin on this flight-date. Typically the largest cabin and primary driver of load factor and revenue management decisions.' ;
    rdfs:domain ind:FlightInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:equipmentChangeIndicator rdf:type rdf:Property ;
    rdfs:label 'Equipment Change Indicator' ;
    rdfs:comment 'Flag indicating whether the aircraft type assigned to this flight-date has been changed from the originally scheduled equipment. Equipment changes may alter cabin configuration, total capacity, and fare class bucket allocations requiring inventory rebalancing.' ;
    rdfs:domain ind:FlightInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fareClassBucketConfig rdf:type rdf:Property ;
    rdfs:label 'Fare Class Bucket Config' ;
    rdfs:comment 'Serialized representation of the active fare class bucket (booking class) configuration for this flight-date, listing each IATA booking class code and its authorized seat allocation (e.g., \'Y:20,B:15,M:10,Q:5\'). Managed by Sabre AirVision Revenue Management and consumed by Amadeus Altéa for availability control.' ;
    rdfs:domain ind:FlightInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstClassCapacity rdf:type rdf:Property ;
    rdfs:label 'First Class Capacity' ;
    rdfs:comment 'Total number of seats allocated to the First Class cabin on this flight-date. Reflects the aircraft configuration and any cabin reconfiguration applied for this specific flight.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gdsAvailabilityCode rdf:type rdf:Property ;
    rdfs:label 'Gds Availability Code' ;
    rdfs:comment 'Single-letter availability status code broadcast to Global Distribution Systems (GDS) representing the highest open booking class on this flight-date (e.g., \'Y\' for full availability, \'L\' for restricted availability). Conforms to IATA availability message standards.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupSeatsHeld rdf:type rdf:Property ;
    rdfs:label 'Group Seats Held' ;
    rdfs:comment 'Number of seats currently held under group booking reservations (typically 10+ passengers under a single PNR group) on this flight-date. Group holds reduce available inventory for individual bookings and are subject to group ticketing deadlines.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:interlineSeatsAllocated rdf:type rdf:Property ;
    rdfs:label 'Interline Seats Allocated' ;
    rdfs:comment 'Number of seats allocated for interline ticketing partner bookings on this flight-date under IATA interline agreements. Distinct from codeshare allocations and tracked for ARC/BSP proration and revenue accounting.' ;
    rdfs:domain ind:FlightInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inventoryControlMode rdf:type rdf:Property ;
    rdfs:label 'Inventory Control Mode' ;
    rdfs:comment 'Indicates whether inventory management for this flight-date is operating under MANUAL (revenue analyst override), AUTOMATED (Sabre AirVision algorithmic control), or HYBRID (automated with manual overrides) mode. Affects how fare class bucket changes are applied.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryStatus rdf:type rdf:Property ;
    rdfs:label 'Inventory Status' ;
    rdfs:comment 'Current operational status of the flight inventory record in Amadeus Altéa. OPEN indicates seats are available for sale; CLOSED indicates no further sales permitted; WAITLIST indicates demand exceeds supply and waitlist is active; SUSPENDED indicates temporary hold on sales; CANCELLED indicates the flight has been cancelled and inventory is frozen.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastSeatAvailabilityDate rdf:type rdf:Property ;
    rdfs:label 'Last Seat Availability Date' ;
    rdfs:comment 'Date on which the last available seat on this flight-date was sold or the inventory was closed. Used for post-departure revenue analysis and booking curve benchmarking.' ;
    rdfs:domain ind:FlightInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operationalSeatsHeld rdf:type rdf:Property ;
    rdfs:label 'Operational Seats Held' ;
    rdfs:comment 'Number of seats withheld from sale for operational purposes including deadhead crew positioning, airline staff travel, and aircraft ferry requirements. These seats are excluded from the sellable inventory pool.' ;
    rdfs:domain ind:FlightInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overbookingLimit rdf:type rdf:Property ;
    rdfs:label 'Overbooking Limit' ;
    rdfs:comment 'Absolute maximum number of bookings permitted on this flight-date including the overbooking allowance. Computed from authorized_capacity multiplied by overbooking_factor and used as the hard ceiling in the Amadeus Altéa booking engine.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:premiumEconomyCapacity rdf:type rdf:Property ;
    rdfs:label 'Premium Economy Capacity' ;
    rdfs:comment 'Total number of seats allocated to the Premium Economy cabin on this flight-date. Nullable for aircraft configurations that do not include a Premium Economy cabin.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revenueManagementClass rdf:type rdf:Property ;
    rdfs:label 'Revenue Management Class' ;
    rdfs:comment 'Revenue management classification assigned by Sabre AirVision to this flight-date based on demand forecast, booking curve position, and competitive pricing environment. Drives automated fare class bucket opening and closing decisions for yield optimization.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleChangeIndicator rdf:type rdf:Property ;
    rdfs:label 'Schedule Change Indicator' ;
    rdfs:comment 'Flag indicating whether this flight-date has undergone a schedule change (time, equipment, or routing modification) since the original inventory record was created. Schedule changes may trigger IROP (Irregular Operations) rebooking workflows and inventory reallocation.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalCapacity rdf:type rdf:Property ;
    rdfs:label 'Total Capacity' ;
    rdfs:comment 'Total number of physical seats available on the aircraft for this flight-date combination across all cabins. Derived from the aircraft configuration assigned to the flight and represents the maximum sellable inventory ceiling.' ;
    rdfs:domain ind:FlightInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:groupBlockId rdf:type rdf:Property ;
    rdfs:label 'Group Block Id' ;
    rdfs:comment 'Unique surrogate identifier for the group block record in the inventory system. Primary key for this entity.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GroupBlock .

ind:createdByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Created By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Group sales agents create and manage group blocks. Essential for sales commission calculation, performance metrics, accountability, and customer relationship management. Replaces agent_code with prope' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:fareClassId rdf:type rdf:Property ;
    rdfs:label 'Fare Class Id' ;
    rdfs:comment 'Reference to the fare class bucket (booking class) under which the group block seats are held. Determines the yield and revenue management bucket impacted by this block.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FareClass .

ind:blockStatus rdf:type rdf:Property ;
    rdfs:label 'Block Status' ;
    rdfs:comment 'Current lifecycle status of the group block. \'tentative\' = seats held pending confirmation; \'confirmed\' = group has committed; \'ticketed\' = tickets issued; \'cancelled\' = block released back to inventory; \'expired\' = option date passed without confirmation; \'waitlisted\' = requested but not yet allocated. [ENUM-REF-CANDIDATE: tentative|confirmed|ticketed|cancelled|expired|waitlisted — promote to reference product]' ;
    rdfs:domain ind:GroupBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depositAmount rdf:type rdf:Property ;
    rdfs:label 'Deposit Amount' ;
    rdfs:comment 'The monetary deposit amount required or received for this group block, expressed in fare_currency_code. Null if deposit_required is False.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:depositPaid rdf:type rdf:Property ;
    rdfs:label 'Deposit Paid' ;
    rdfs:comment 'Indicates whether the required deposit has been received from the group organizer. True = deposit received; False = deposit outstanding. Drives follow-up and cancellation workflows.' ;
    rdfs:domain ind:GroupBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:depositPaidDate rdf:type rdf:Property ;
    rdfs:label 'Deposit Paid Date' ;
    rdfs:comment 'The date on which the deposit payment was received from the group organizer. Null if deposit has not been paid.' ;
    rdfs:domain ind:GroupBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:depositRequired rdf:type rdf:Property ;
    rdfs:label 'Deposit Required' ;
    rdfs:comment 'Indicates whether a deposit payment is required from the group organizer to hold or confirm this group block. True = deposit required; False = no deposit required.' ;
    rdfs:domain ind:GroupBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fareCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Fare Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the group_fare_amount is denominated (e.g., \'USD\', \'EUR\', \'GBP\').' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finalPaymentDueDate rdf:type rdf:Property ;
    rdfs:label 'Final Payment Due Date' ;
    rdfs:comment 'The date by which the full fare payment for all ticketed seats in the group block must be settled. Distinct from the deposit due date and ticketing deadline.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:freeSeatRatio rdf:type rdf:Property ;
    rdfs:label 'Free Seat Ratio' ;
    rdfs:comment 'The ratio of complimentary (free) seats granted to the group organizer relative to the total seats purchased, expressed as a decimal (e.g., 0.1000 = 1 free seat per 10 paid). Drives revenue accounting and yield calculations.' ;
    rdfs:domain ind:GroupBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freeSeatsAllocated rdf:type rdf:Property ;
    rdfs:label 'Free Seats Allocated' ;
    rdfs:comment 'The actual number of complimentary (free) seats allocated to the group organizer based on the free_seat_ratio and confirmed group size. Impacts revenue accounting and load factor reporting.' ;
    rdfs:domain ind:GroupBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:groupFareAmount rdf:type rdf:Property ;
    rdfs:label 'Group Fare Amount' ;
    rdfs:comment 'Negotiated per-seat fare amount agreed for this group block, expressed in the currency specified by fare_currency_code. Represents the contracted price per passenger for revenue accounting and settlement.' ;
    rdfs:domain ind:GroupBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:groupFareBasis rdf:type rdf:Property ;
    rdfs:label 'Group Fare Basis' ;
    rdfs:comment 'The fare basis code applicable to the group block, defining the fare rules, restrictions, and pricing conditions under which the group seats are sold (e.g., \'GEXCAP\', \'YGROUP\'). Aligns with IATA fare construction rules.' ;
    rdfs:domain ind:GroupBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupName rdf:type rdf:Property ;
    rdfs:label 'Group Name' ;
    rdfs:comment 'The commercial or organizational name of the group for whom the seat block is reserved (e.g., \'Smith Wedding Party\', \'ACME Corp Sales Conference\'). Used for identification and communication with the group organizer.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupType rdf:type rdf:Property ;
    rdfs:label 'Group Type' ;
    rdfs:comment 'Classification of the group by purpose or segment. Used for revenue management analysis, pricing strategy, and reporting. [ENUM-REF-CANDIDATE: leisure|corporate|incentive|military|religious|sports|charter — promote to reference product]' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumGroupSize rdf:type rdf:Property ;
    rdfs:label 'Minimum Group Size' ;
    rdfs:comment 'The minimum number of passengers required to qualify for group fare pricing on this block, as defined by the applicable fare rules. Typically 10 passengers per IATA group fare conventions.' ;
    rdfs:domain ind:GroupBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:namesDueDate rdf:type rdf:Property ;
    rdfs:label 'Names Due Date' ;
    rdfs:comment 'The date by which the group organizer must submit individual passenger names (Pax names) for all seats in the confirmed block. Required for check-in, security compliance, and advance passenger information (API) submission.' ;
    rdfs:domain ind:GroupBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:optionDate rdf:type rdf:Property ;
    rdfs:label 'Option Date' ;
    rdfs:comment 'The deadline date by which the group organizer must confirm the number of seats and provide passenger names. If not confirmed by this date, the block may be automatically released back to inventory. Critical for inventory management and revenue optimization.' ;
    rdfs:domain ind:GroupBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:overbookingEligible rdf:type rdf:Property ;
    rdfs:label 'Overbooking Eligible' ;
    rdfs:comment 'Indicates whether this group block is subject to overbooking controls. True = the block counts against overbooking limits; False = the block is protected from overbooking displacement (e.g., guaranteed allocation). Feeds revenue management overbooking models.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reference rdf:type rdf:Property ;
    rdfs:label 'Reference' ;
    rdfs:comment 'Externally-known alphanumeric reference code assigned to this group block by the Passenger Service System (PSS) or reservations team. Used by travel agents and group coordinators to identify and manage the block.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seatsBlocked rdf:type rdf:Property ;
    rdfs:label 'Seats Blocked' ;
    rdfs:comment 'Current number of seats held (blocked) in inventory for this group. Reduces available seat count for individual sale. May differ from seats_requested if the airline partially approved the block.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seatsConfirmed rdf:type rdf:Property ;
    rdfs:label 'Seats Confirmed' ;
    rdfs:comment 'Number of seats within the block that have been formally confirmed by the group organizer. May be less than seats_blocked during the tentative phase. Drives revenue recognition and ticketing obligations.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seatsReleased rdf:type rdf:Property ;
    rdfs:label 'Seats Released' ;
    rdfs:comment 'Number of seats that have been released back to general inventory from this group block, either due to partial cancellation, reduction, or expiry of the option. Supports inventory reconciliation.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seatsRequested rdf:type rdf:Property ;
    rdfs:label 'Seats Requested' ;
    rdfs:comment 'Total number of seats originally requested by the group organizer at the time of the initial group block request. Baseline for tracking changes to the block size.' ;
    rdfs:domain ind:GroupBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seatsTicketed rdf:type rdf:Property ;
    rdfs:label 'Seats Ticketed' ;
    rdfs:comment 'Number of seats within the confirmed block for which electronic tickets (e-tickets) have been issued. Used to track ticketing progress against the ticketing deadline.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ticketingDeadline rdf:type rdf:Property ;
    rdfs:label 'Ticketing Deadline' ;
    rdfs:comment 'The final date by which all confirmed seats in the group block must be ticketed (e-tickets issued). Failure to ticket by this date may result in automatic cancellation of unticketed seats and release to general inventory.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availabilitySnapshotDatetime rdf:type rdf:Property ;
    rdfs:label 'Availability Snapshot Datetime' ;
    rdfs:comment 'UTC timestamp of the most recent real-time availability snapshot for this leg as published to GDS and direct booking channels. Supports audit of availability state at a point in time and feeds through-availability calculations.' ;
    rdfs:domain ind:InventoryLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:bookedCount rdf:type rdf:Property ;
    rdfs:label 'Booked Count' ;
    rdfs:comment 'Current total number of confirmed bookings (Pax) held against this leg across all fare classes and cabins. Updated in real time by the Amadeus Altéa PSS as reservations are created, modified, or cancelled.' ;
    rdfs:domain ind:InventoryLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:codeshareBlockedCount rdf:type rdf:Property ;
    rdfs:label 'Codeshare Blocked Count' ;
    rdfs:comment 'Number of seats allocated to codeshare partner airlines on this operating leg. Represents inventory carved out for marketing carrier partners under codeshare agreements, reducing net availability for the operating carrier.' ;
    rdfs:domain ind:InventoryLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:departureSlotTime rdf:type rdf:Property ;
    rdfs:label 'Departure Slot Time' ;
    rdfs:comment 'Allocated airport departure slot time (UTC) assigned by the slot coordinator for this leg at the origin airport. May differ from scheduled departure time. Null for airports without slot coordination (non-Level 2/3 airports).' ;
    rdfs:domain ind:InventoryLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:groupBlockedCount rdf:type rdf:Property ;
    rdfs:label 'Group Blocked Count' ;
    rdfs:comment 'Number of seats currently blocked and held for group bookings on this leg. Reduces the net availability exposed to individual GDS and direct channel requests.' ;
    rdfs:domain ind:InventoryLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inventoryCloseDatetime rdf:type rdf:Property ;
    rdfs:label 'Inventory Close Datetime' ;
    rdfs:comment 'Date and time (UTC) when inventory for this leg was closed to new bookings. Typically triggered at departure or by revenue management closure rules. Null if inventory is still open.' ;
    rdfs:domain ind:InventoryLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:inventoryOpenDatetime rdf:type rdf:Property ;
    rdfs:label 'Inventory Open Datetime' ;
    rdfs:comment 'Date and time (UTC) when inventory for this leg was first opened for sale across GDS and direct channels. Marks the start of the revenue management availability window.' ;
    rdfs:domain ind:InventoryLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:iropIndicator rdf:type rdf:Property ;
    rdfs:label 'Irop Indicator' ;
    rdfs:comment 'Flag indicating whether this leg is currently subject to an Irregular Operations (IROP) event such as a delay, cancellation, diversion, or equipment swap. True = IROP condition active. Triggers passenger re-accommodation workflows in Amadeus Altéa.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legStatus rdf:type rdf:Property ;
    rdfs:label 'Leg Status' ;
    rdfs:comment 'Current operational and inventory lifecycle status of this leg. \'active\' — open for sale; \'cancelled\' — flight cancelled, inventory closed; \'diverted\' — flight diverted to alternate airport; \'suspended\' — temporarily removed from sale; \'closed\' — inventory closed post-departure.' ;
    rdfs:domain ind:InventoryLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingDayOfWeek rdf:type rdf:Property ;
    rdfs:label 'Operating Day Of Week' ;
    rdfs:comment 'IATA day-of-week code on which this leg operates, where 1=Monday through 7=Sunday per IATA SSIM convention. Used for schedule frequency analysis and inventory pattern matching. [ENUM-REF-CANDIDATE: 1|2|3|4|5|6|7 — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:InventoryLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schedulePeriodCode rdf:type rdf:Property ;
    rdfs:label 'Schedule Period Code' ;
    rdfs:comment 'IATA seasonal schedule period code under which this leg is published (e.g., \'W24\' for Winter 2024, \'S25\' for Summer 2025). Aligns with IATA SSIM scheduling seasons for slot coordination and network planning.' ;
    rdfs:domain ind:InventoryLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledArrivalDatetime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Arrival Datetime' ;
    rdfs:comment 'Scheduled gate arrival date and time for this leg in UTC (ISO 8601 format). Represents the planned OOOI \'In\' time used for connection logic, MCT calculations, and inventory closure triggers.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledBlockHours rdf:type rdf:Property ;
    rdfs:label 'Scheduled Block Hours' ;
    rdfs:comment 'Planned block time for this leg in decimal hours, measured from scheduled gate departure (Out) to scheduled gate arrival (In). Block hours are the primary unit for aircraft utilization, crew duty time, and cost accounting (CASK calculations).' ;
    rdfs:domain ind:InventoryLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduledDepartureDatetime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Departure Datetime' ;
    rdfs:comment 'Scheduled gate departure date and time for this leg in UTC (ISO 8601 format). Represents the planned OOOI \'Out\' time used for inventory availability windows, GDS display, and OTP measurement.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledFlightDistanceKm rdf:type rdf:Property ;
    rdfs:label 'Scheduled Flight Distance Km' ;
    rdfs:comment 'Great-circle distance of this leg in kilometres between origin and destination airports. Used in RPK (Revenue Passenger Kilometre) and ASK (Available Seat Kilometre) calculations, yield analysis, and CORSIA carbon emissions reporting.' ;
    rdfs:domain ind:InventoryLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:throughAvailabilityIndicator rdf:type rdf:Property ;
    rdfs:label 'Through Availability Indicator' ;
    rdfs:comment 'Flag indicating whether this leg participates in through-availability calculations, allowing connecting itinerary availability to be computed across multiple legs without individual leg-level availability checks. True = through-availability enabled.' ;
    rdfs:domain ind:InventoryLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waitlistedCount rdf:type rdf:Property ;
    rdfs:label 'Waitlisted Count' ;
    rdfs:comment 'Number of passengers currently on the waitlist for this leg, pending availability opening due to cancellations or capacity adjustments. Managed within Amadeus Altéa Inventory waitlist queues.' ;
    rdfs:domain ind:InventoryLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:segmentId rdf:type rdf:Property ;
    rdfs:label 'Segment Id' ;
    rdfs:comment 'Unique surrogate identifier for the commercial Origin-Destination (O&D) inventory segment record in the Amadeus Altéa Inventory system. Primary key for this entity.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:availabilityControlMethod rdf:type rdf:Property ;
    rdfs:label 'Availability Control Method' ;
    rdfs:comment 'Method used to control seat availability for this segment: \'leg_based\' = availability derived from individual leg bucket counts; \'od_based\' = availability controlled at the O&D segment level using virtual nesting; \'hybrid\' = combination of leg and O&D controls.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availabilitySnapshotTime rdf:type rdf:Property ;
    rdfs:label 'Availability Snapshot Time' ;
    rdfs:comment 'Timestamp (UTC) at which the current availability figures (seats_sold, seats_available, load_factor) were last refreshed from the Amadeus Altéa Inventory system. Critical for GDS cache synchronization and real-time availability accuracy.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:codeshareSeatAllocation rdf:type rdf:Property ;
    rdfs:label 'Codeshare Seat Allocation' ;
    rdfs:comment 'Number of seats allocated to the marketing carrier under a block-space codeshare agreement for this segment. Applicable only when codeshare_type = \'block_space\'. Null for free-flow or non-codeshare segments.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:codeshareType rdf:type rdf:Property ;
    rdfs:label 'Codeshare Type' ;
    rdfs:comment 'Type of codeshare arrangement governing inventory allocation for this segment: \'free_flow\' = marketing carrier draws from operating carrier\'s open inventory; \'block_space\' = a fixed seat block is allocated to the marketing carrier; \'none\' = not a codeshare segment.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interlineEligible rdf:type rdf:Property ;
    rdfs:label 'Interline Eligible' ;
    rdfs:comment 'Indicates whether this inventory segment is eligible for interline ticketing agreements, allowing passengers to book connecting itineraries across multiple carriers on a single ticket. Governed by bilateral interline agreements and IATA BSP/ARC settlement rules.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketedFlightNumber rdf:type rdf:Property ;
    rdfs:label 'Marketed Flight Number' ;
    rdfs:comment 'The IATA-format flight number as sold to passengers and published in GDS channels (e.g., AA1234). For codeshare segments, this is the marketing carrier\'s flight number, which may differ from the operating carrier\'s flight number.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minConnectingTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Min Connecting Time Minutes' ;
    rdfs:comment 'Minimum Connecting Time (MCT) in minutes required at the connecting airport for this segment to be valid in a connecting itinerary. Enforced during availability display and booking to prevent infeasible connections. Sourced from IATA SSIM MCT tables.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nestingLevel rdf:type rdf:Property ;
    rdfs:label 'Nesting Level' ;
    rdfs:comment 'Hierarchical nesting level of this booking class within the cabin\'s availability nesting structure (e.g., 1=highest yield class, 10=lowest yield class). Governs through-availability rules: higher-level classes inherit availability from lower-level buckets per revenue management nesting policy.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overbookingRate rdf:type rdf:Property ;
    rdfs:label 'Overbooking Rate' ;
    rdfs:comment 'Overbooking authorization expressed as a percentage above physical cabin capacity (e.g., 5.00 = 5% overbooking). Used by revenue management to calibrate no-show risk models and optimize load factor.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:saleCloseDate rdf:type rdf:Property ;
    rdfs:label 'Sale Close Date' ;
    rdfs:comment 'Date after which this inventory segment is no longer available for new bookings. Typically set to the departure date or earlier based on advance purchase restrictions and revenue management close-out rules.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:saleOpenDate rdf:type rdf:Property ;
    rdfs:label 'Sale Open Date' ;
    rdfs:comment 'Date from which this inventory segment is open for sale in GDS and direct booking channels. Defines the advance purchase window start for revenue management and distribution control.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:segmentStatus rdf:type rdf:Property ;
    rdfs:label 'Segment Status' ;
    rdfs:comment 'Current availability status of this inventory segment as published to GDS and direct booking channels. \'open\' = seats available for sale; \'closed\' = no availability; \'waitlisted\' = demand exceeds supply, waitlist active; \'cancelled\' = flight/segment cancelled; \'suspended\' = temporarily removed from sale.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentType rdf:type rdf:Property ;
    rdfs:label 'Segment Type' ;
    rdfs:comment 'Classification of the commercial segment by its operational and commercial structure: \'direct\' = single leg O&D; \'connecting\' = multi-leg through-availability segment; \'codeshare\' = marketed by partner airline; \'interline\' = cross-carrier ticketing agreement; \'virtual\' = constructed availability for display purposes.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:throughAvailabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Through Availability Flag' ;
    rdfs:comment 'Indicates whether this segment participates in through-availability nesting, meaning its availability is derived from the aggregated availability of underlying leg buckets rather than being independently controlled. True = through-availability applies.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iropReprotectionId rdf:type rdf:Property ;
    rdfs:label 'Irop Reprotection Id' ;
    rdfs:comment 'Unique surrogate identifier for each IROP reprotection action record in the inventory system. Primary key for this transactional entity.' ;
    rdfs:domain ind:IropReprotection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:authorizedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Authorized By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Operations Control Center staff authorize IROP passenger reprotections and inventory ring-fencing. Required for operational accountability, regulatory compliance audit trails (EU261, DOT), and cost ce' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryIropScheduledFlightId rdf:type rdf:Property ;
    rdfs:label 'Primary Irop Scheduled Flight Id' ;
    rdfs:comment 'Reference to the original flight segment that was disrupted (cancelled, diverted, or significantly delayed), causing the need for passenger reprotection. Directly impacts inventory on the disrupted flight.' ;
    rdfs:domain ind:IropReprotection ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ScheduledFlight .

ind:authorizedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Authorized Timestamp' ;
    rdfs:comment 'Date and time (UTC) when the Operations Control Center (OCC) formally authorized this reprotection action. Represents the principal business event time for this transaction.' ;
    rdfs:domain ind:IropReprotection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:disruptedFlightDate rdf:type rdf:Property ;
    rdfs:label 'Disrupted Flight Date' ;
    rdfs:comment 'Scheduled departure date (local airport time) of the disrupted flight. Used for day-of-operations reporting and IROP timeline analysis.' ;
    rdfs:domain ind:IropReprotection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disruptedFlightNumber rdf:type rdf:Property ;
    rdfs:label 'Disrupted Flight Number' ;
    rdfs:comment 'IATA flight number of the disrupted flight (e.g., AA1234). Denormalized for operational reporting and IROP dashboards without requiring a join to the flight segment table.' ;
    rdfs:domain ind:IropReprotection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downgradeCompensationApplicable rdf:type rdf:Property ;
    rdfs:label 'Downgrade Compensation Applicable' ;
    rdfs:comment 'Indicates whether passengers in this reprotection block are entitled to downgrade compensation (e.g., fare difference refund or EMD issuance) because they are being accommodated in a lower cabin class than originally booked.' ;
    rdfs:domain ind:IropReprotection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gdsAvailabilityUpdated rdf:type rdf:Property ;
    rdfs:label 'Gds Availability Updated' ;
    rdfs:comment 'Indicates whether the real-time availability snapshot on the recovery flight has been updated and broadcast to GDS channels (e.g., Amadeus, Sabre, Travelport) to reflect the ring-fenced seats. Critical for preventing oversell on the recovery flight.' ;
    rdfs:domain ind:IropReprotection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interlineReprotectionIndicator rdf:type rdf:Property ;
    rdfs:label 'Interline Reprotection Indicator' ;
    rdfs:comment 'Indicates whether this reprotection action involves rebooking passengers onto a flight operated by a different carrier under an interline agreement. Triggers BSP/ARC settlement and interline billing processes.' ;
    rdfs:domain ind:IropReprotection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inventoryImpactAcknowledged rdf:type rdf:Property ;
    rdfs:label 'Inventory Impact Acknowledged' ;
    rdfs:comment 'Indicates whether the Revenue Management system has acknowledged and processed the inventory reduction on the recovery flight caused by this reprotection action. Ensures yield optimization models reflect the ring-fenced seats.' ;
    rdfs:domain ind:IropReprotection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iropCauseType rdf:type rdf:Property ;
    rdfs:label 'Irop Cause Type' ;
    rdfs:comment 'Classification of the root cause of the IROP event that triggered reprotection. Drives downstream analytics on disruption patterns and recovery cost attribution. [ENUM-REF-CANDIDATE: CANCELLATION|DIVERSION|SIGNIFICANT_DELAY|EQUIPMENT_SWAP|ATC_GROUND_STOP|WEATHER|CREW_SHORTAGE|SECURITY|MEDICAL|MECHANICAL — promote to reference product]' ;
    rdfs:domain ind:IropReprotection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:occAuthorizationReference rdf:type rdf:Property ;
    rdfs:label 'Occ Authorization Reference' ;
    rdfs:comment 'Reference to the Operations Control Center authorization record that approved this reprotection action. Ensures accountability and traceability of inventory ring-fencing decisions.' ;
    rdfs:domain ind:IropReprotection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overbookingOverrideApplied rdf:type rdf:Property ;
    rdfs:label 'Overbooking Override Applied' ;
    rdfs:comment 'Indicates whether the OCC applied an overbooking override to accommodate reprotected passengers beyond the recovery flight\'s standard authorized overbooking limit. Requires elevated authorization and triggers denied boarding risk monitoring.' ;
    rdfs:domain ind:IropReprotection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:paxDisplacedCount rdf:type rdf:Property ;
    rdfs:label 'Pax Displaced Count' ;
    rdfs:comment 'Total number of passengers displaced by the IROP event who are eligible for reprotection under this action. May exceed seats_ring_fenced if partial reprotection is applied.' ;
    rdfs:domain ind:IropReprotection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pnrCount rdf:type rdf:Property ;
    rdfs:label 'Pnr Count' ;
    rdfs:comment 'Number of distinct Passenger Name Records (PNRs) included in this reprotection action. Used to track the scope of the reprotection and reconcile against seats_ring_fenced.' ;
    rdfs:domain ind:IropReprotection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:priorityClass rdf:type rdf:Property ;
    rdfs:label 'Priority Class' ;
    rdfs:comment 'Priority tier assigned to this reprotection block, determining the order in which displaced passengers are accommodated on the recovery flight. ELITE: frequent flyer elite members; CONNECTING: passengers with onward connections at risk; MEDICAL: passengers with medical needs or SSR codes; UNACCOMPANIED_MINOR: UM passengers; STANDARD: general passengers.' ;
    rdfs:domain ind:IropReprotection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recoveryFlightDate rdf:type rdf:Property ;
    rdfs:label 'Recovery Flight Date' ;
    rdfs:comment 'Scheduled departure date (local airport time) of the recovery flight. Used to determine inventory impact window and reprotection timeline.' ;
    rdfs:domain ind:IropReprotection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recoveryFlightNumber rdf:type rdf:Property ;
    rdfs:label 'Recovery Flight Number' ;
    rdfs:comment 'IATA flight number of the recovery (reprotection) flight on which seats are ring-fenced (e.g., AA1456). Denormalized for operational dashboards and GDS availability messaging.' ;
    rdfs:domain ind:IropReprotection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reprotectionNotes rdf:type rdf:Property ;
    rdfs:label 'Reprotection Notes' ;
    rdfs:comment 'Free-text operational notes entered by the OCC agent describing special circumstances, exceptions, or instructions related to this reprotection action (e.g., VIP handling, diplomatic passengers, group reprotection conditions).' ;
    rdfs:domain ind:IropReprotection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reprotectionReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Reprotection Reference Number' ;
    rdfs:comment 'Externally-known alphanumeric reference number assigned by the Passenger Service System (PSS) to uniquely identify this reprotection action across operational systems and GDS channels. Used for cross-system traceability.' ;
    rdfs:domain ind:IropReprotection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reprotectionStatus rdf:type rdf:Property ;
    rdfs:label 'Reprotection Status' ;
    rdfs:comment 'Current lifecycle state of the reprotection action. PENDING: awaiting OCC authorization; ACTIVE: seats ring-fenced and available for displaced passengers; CONFIRMED: passengers booked onto recovery flight; RELEASED: unused seats returned to general inventory; EXPIRED: reprotection window passed without use; CANCELLED: reprotection voided.' ;
    rdfs:domain ind:IropReprotection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reprotectionType rdf:type rdf:Property ;
    rdfs:label 'Reprotection Type' ;
    rdfs:comment 'Classification of the reprotection strategy applied. SAME_DAY: recovery on same calendar day; NEXT_DAY: recovery on following day; MULTI_LEG: recovery requires multiple connecting flights; INTERLINE: recovery on partner carrier; UPGRADE: passenger accommodated in higher cabin; DOWNGRADE: passenger accommodated in lower cabin with compensation.' ;
    rdfs:domain ind:IropReprotection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reprotectionWindowCloseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reprotection Window Close Timestamp' ;
    rdfs:comment 'Date and time (UTC) when the reprotection inventory block expires. After this time, unused ring-fenced seats are released back to general inventory. Nullable if the window is open-ended until flight departure.' ;
    rdfs:domain ind:IropReprotection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reprotectionWindowOpenTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reprotection Window Open Timestamp' ;
    rdfs:comment 'Date and time (UTC) when the reprotection inventory block was activated and seats became available for displaced passenger booking. Marks the start of the reprotection window.' ;
    rdfs:domain ind:IropReprotection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:seatsRingFenced rdf:type rdf:Property ;
    rdfs:label 'Seats Ring Fenced' ;
    rdfs:comment 'Number of seats on the recovery flight that have been ring-fenced (blocked from general sale) for displaced passengers under this reprotection action. Directly reduces available inventory on the recovery flight.' ;
    rdfs:domain ind:IropReprotection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seatsUtilized rdf:type rdf:Property ;
    rdfs:label 'Seats Utilized' ;
    rdfs:comment 'Number of ring-fenced seats that were actually used by displaced passengers. Compared against seats_ring_fenced to measure reprotection efficiency and inventory recovery.' ;
    rdfs:domain ind:IropReprotection ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ssrCodes rdf:type rdf:Property ;
    rdfs:label 'Ssr Codes' ;
    rdfs:comment 'Comma-separated list of IATA four-letter Special Service Request (SSR) codes applicable to passengers in this reprotection block (e.g., WCHR, UMNR, MEDA). Ensures special handling requirements are preserved during reprotection.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overbookingControlId rdf:type rdf:Property ;
    rdfs:label 'Overbooking Control Id' ;
    rdfs:comment 'Unique surrogate identifier for the overbooking control record. Primary key for this entity.' ;
    rdfs:domain ind:OverbookingControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:authorizedOverbookingPct rdf:type rdf:Property ;
    rdfs:label 'Authorized Overbooking Pct' ;
    rdfs:comment 'The approved percentage above physical cabin seat capacity that the revenue management system is authorized to sell. For example, a value of 10.00 means up to 10% more seats than physically available may be booked. Derived from historical no-show rates and spoilage risk models in Sabre AirVision Revenue Management.' ;
    rdfs:domain ind:OverbookingControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:avgFareValueUsd rdf:type rdf:Property ;
    rdfs:label 'Avg Fare Value Usd' ;
    rdfs:comment 'The average fare value in USD for bookings in this cabin on this flight, used as an input to the overbooking revenue optimization model. Enables the model to weigh the revenue benefit of additional bookings against the cost of denied boarding compensation.' ;
    rdfs:domain ind:OverbookingControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cancellationRateInput rdf:type rdf:Property ;
    rdfs:label 'Cancellation Rate Input' ;
    rdfs:comment 'Historical cancellation rate (expressed as a decimal proportion) for this route, cabin, and season used as an actuarial input alongside the no-show rate in the overbooking model. Distinct from no-show rate as it captures pre-departure cancellations.' ;
    rdfs:domain ind:OverbookingControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:codeshareInventoryFlag rdf:type rdf:Property ;
    rdfs:label 'Codeshare Inventory Flag' ;
    rdfs:comment 'Indicates whether this overbooking control applies to a codeshare inventory allocation rather than the operating carrier\'s own inventory. Codeshare overbooking controls may differ from mainline controls due to interline agreements and partner airline seat block commitments.' ;
    rdfs:domain ind:OverbookingControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:controlStatus rdf:type rdf:Property ;
    rdfs:label 'Control Status' ;
    rdfs:comment 'Current lifecycle status of this overbooking control record. Active indicates the parameters are live and being applied by Altéa Inventory booking limit calculations. Suspended means overbooking is temporarily halted for this cabin. Overridden indicates a manual revenue management analyst override is in effect.' ;
    rdfs:domain ind:OverbookingControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentBookingCount rdf:type rdf:Property ;
    rdfs:label 'Current Booking Count' ;
    rdfs:comment 'The real-time count of confirmed bookings (PNRs) held against this cabin at the time of the last availability snapshot. Used to compute remaining availability and monitor oversale exposure.' ;
    rdfs:domain ind:OverbookingControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deniedBoardingRiskThreshold rdf:type rdf:Property ;
    rdfs:label 'Denied Boarding Risk Threshold' ;
    rdfs:comment 'The maximum acceptable probability (expressed as a decimal, e.g., 0.0200 = 2%) that at least one passenger will be involuntarily denied boarding due to oversale. Balances revenue optimization against regulatory denied boarding compensation exposure under DOT 14 CFR Part 250 and IATA Resolution 830d.' ;
    rdfs:domain ind:OverbookingControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:goShowRateInput rdf:type rdf:Property ;
    rdfs:label 'Go Show Rate Input' ;
    rdfs:comment 'Historical rate of passengers who arrive at the gate without a prior reservation (go-shows) for this route and cabin, expressed as a decimal proportion. Used in the overbooking model to account for demand that materialises at departure.' ;
    rdfs:domain ind:OverbookingControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:groupBookingSeatsReserved rdf:type rdf:Property ;
    rdfs:label 'Group Booking Seats Reserved' ;
    rdfs:comment 'Number of seats within the cabin that are reserved for confirmed group bookings and excluded from the overbooking calculation. Group bookings typically have lower no-show rates and are treated separately in the overbooking model.' ;
    rdfs:domain ind:OverbookingControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:historicalNoShowRate rdf:type rdf:Property ;
    rdfs:label 'Historical No Show Rate' ;
    rdfs:comment 'The input no-show rate (expressed as a decimal proportion, e.g., 0.0850 = 8.50%) derived from historical passenger behaviour for this route, cabin, and season. Used as the primary actuarial input to the overbooking authorization model in Sabre AirVision.' ;
    rdfs:domain ind:OverbookingControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:idbCompensationExposureUsd rdf:type rdf:Property ;
    rdfs:label 'Idb Compensation Exposure Usd' ;
    rdfs:comment 'Estimated maximum financial exposure in USD for involuntary denied boarding (IDB) compensation if all oversold seats result in IDB events. Calculated based on max_oversale_seats and applicable DOT/IATA compensation rates. Used in revenue management risk assessment.' ;
    rdfs:domain ind:OverbookingControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastReviewedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Reviewed Timestamp' ;
    rdfs:comment 'The date and time when a revenue management analyst last reviewed and confirmed or adjusted this overbooking control record. Supports governance workflows requiring periodic review of overbooking authorizations.' ;
    rdfs:domain ind:OverbookingControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:loadFactorForecast rdf:type rdf:Property ;
    rdfs:label 'Load Factor Forecast' ;
    rdfs:comment 'The forecasted load factor (proportion of physical seats expected to be occupied at departure, expressed as a decimal e.g., 0.9200 = 92%) for this cabin on this flight. Input from Sabre AirVision demand forecasting, used to calibrate the overbooking level.' ;
    rdfs:domain ind:OverbookingControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxOversaleSeats rdf:type rdf:Property ;
    rdfs:label 'Max Oversale Seats' ;
    rdfs:comment 'The absolute maximum number of seats above physical cabin capacity that may be sold, regardless of the authorized overbooking percentage. Acts as a hard cap to limit denied boarding exposure. Set by revenue management analysts in Altéa Inventory.' ;
    rdfs:domain ind:OverbookingControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overbookingModelVersion rdf:type rdf:Property ;
    rdfs:label 'Overbooking Model Version' ;
    rdfs:comment 'Version identifier of the statistical overbooking model used to compute the authorized overbooking percentage for this record. Enables reproducibility, model governance, and comparison of model performance across versions in Sabre AirVision.' ;
    rdfs:domain ind:OverbookingControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:physicalSeatCapacity rdf:type rdf:Property ;
    rdfs:label 'Physical Seat Capacity' ;
    rdfs:comment 'The actual number of physical seats available in the cabin for this flight departure, as configured in the aircraft fleet assignment. This is the baseline against which the overbooking percentage is applied.' ;
    rdfs:domain ind:OverbookingControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryMarketCode rdf:type rdf:Property ;
    rdfs:label 'Regulatory Market Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code or regulatory jurisdiction code (e.g., USA, EU) identifying the regulatory regime governing denied boarding compensation obligations for this flight. Determines applicable DOT, EASA EC 261/2004, or national civil aviation authority rules.' ;
    rdfs:domain ind:OverbookingControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rmSystemOverrideFlag rdf:type rdf:Property ;
    rdfs:label 'Rm System Override Flag' ;
    rdfs:comment 'Indicates whether a revenue management analyst has manually overridden the system-calculated overbooking parameters. When True, the authorized_overbooking_pct and max_oversale_seats reflect analyst-entered values rather than the automated Sabre AirVision model output.' ;
    rdfs:domain ind:OverbookingControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:spoilageRiskThreshold rdf:type rdf:Property ;
    rdfs:label 'Spoilage Risk Threshold' ;
    rdfs:comment 'The maximum acceptable probability (expressed as a decimal, e.g., 0.0500 = 5%) that the flight departs with empty seats due to under-booking. Revenue management uses this threshold to calibrate the overbooking level against the risk of seat spoilage versus denied boarding.' ;
    rdfs:domain ind:OverbookingControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:upgradeBufferSeats rdf:type rdf:Property ;
    rdfs:label 'Upgrade Buffer Seats' ;
    rdfs:comment 'Number of seats held back from the overbooking pool to accommodate anticipated operational upgrades (e.g., elite frequent flyer upgrades, compensation upgrades). Reduces the effective booking limit to preserve upgrade capacity.' ;
    rdfs:domain ind:OverbookingControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:voluntaryDeniedBoardingTarget rdf:type rdf:Property ;
    rdfs:label 'Voluntary Denied Boarding Target' ;
    rdfs:comment 'The target number of passengers expected to accept voluntary denied boarding (VDB) compensation offers at the gate in the event of an oversale. Used in the overbooking model to offset the involuntary denied boarding risk.' ;
    rdfs:domain ind:OverbookingControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seasonInventoryPlanId rdf:type rdf:Property ;
    rdfs:label 'Season Inventory Plan Id' ;
    rdfs:comment 'Unique surrogate identifier for the seasonal inventory plan record. Primary key for this entity in the Silver Layer lakehouse.' ;
    rdfs:domain ind:SeasonInventoryPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedBy rdf:type rdf:Property ;
    rdfs:label 'Approved By' ;
    rdfs:comment 'Name or employee identifier of the Revenue Management or Inventory Control authority who formally approved this seasonal inventory plan for activation. Supports audit trail and governance requirements.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedDate rdf:type rdf:Property ;
    rdfs:label 'Approved Date' ;
    rdfs:comment 'The date on which this seasonal inventory plan was formally approved by the authorized Revenue Management or Inventory Control authority. Represents the BUSINESS_EVENT_TIMESTAMP for the approval milestone.' ;
    rdfs:domain ind:SeasonInventoryPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:codeshareAllocationSeats rdf:type rdf:Property ;
    rdfs:label 'Codeshare Allocation Seats' ;
    rdfs:comment 'Number of seats within the total authorized capacity allocated to codeshare marketing partners for sale under their own flight numbers. Null or zero if codeshare_indicator is False.' ;
    rdfs:domain ind:SeasonInventoryPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:economyClassCapacity rdf:type rdf:Property ;
    rdfs:label 'Economy Class Capacity' ;
    rdfs:comment 'Number of seats planned in the Economy Class cabin for this seasonal inventory plan. Typically the largest cabin and primary driver of load factor and yield management decisions.' ;
    rdfs:domain ind:SeasonInventoryPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:iataSeasonCode rdf:type rdf:Property ;
    rdfs:label 'Iata Season Code' ;
    rdfs:comment 'IATA-standard season designator indicating the schedule period this plan covers. Format: S=Summer, W=Winter followed by 2-digit year (e.g., \'S24\' for Summer 2024, \'W24\' for Winter 2024). Aligns with IATA SSIM season definitions.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initialBucketAuthorization rdf:type rdf:Property ;
    rdfs:label 'Initial Bucket Authorization' ;
    rdfs:comment 'Serialized representation of the initial booking class (fare bucket) authorization levels at season open, as configured in Amadeus Altéa Inventory (e.g., \'Y:180,B:120,M:90,Q:60,V:30\'). Defines the starting inventory allocation across RBD (Reservation Booking Designator) buckets before dynamic RM optimization. Confidential as it encodes pricing strategy. [ENUM-REF-CANDIDATE: promote bucket detail to a child product season_inventory_bucket_plan — promote to reference product]' ;
    rdfs:domain ind:SeasonInventoryPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadFactorTarget rdf:type rdf:Property ;
    rdfs:label 'Load Factor Target' ;
    rdfs:comment 'The target load factor (percentage of seats filled) set by Revenue Management for this flight during the season, expressed as a percentage (e.g., 85.00 = 85%). Used as the baseline KPI against which actual load factor performance is measured. Confidential as it reflects commercial strategy.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planCode rdf:type rdf:Property ;
    rdfs:label 'Plan Code' ;
    rdfs:comment 'Externally-known alphanumeric business identifier for this seasonal inventory plan, used in Amadeus Altéa Inventory and cross-system references (e.g., \'SIP-W24-LHR-JFK-Y\'). Serves as the BUSINESS_IDENTIFIER for this master resource.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueManagementSystemCode rdf:type rdf:Property ;
    rdfs:label 'Revenue Management System Code' ;
    rdfs:comment 'The identifier assigned to this inventory plan within the Sabre AirVision Revenue Management system. Used for cross-system traceability between the inventory plan in Altéa and the corresponding RM optimization model in Sabre AirVision.' ;
    rdfs:domain ind:SeasonInventoryPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonEndDate rdf:type rdf:Property ;
    rdfs:label 'Season End Date' ;
    rdfs:comment 'The last date of the IATA schedule season for which this inventory plan is effective. Corresponds to the IATA SSIM-defined season end date. Serves as EFFECTIVE_UNTIL.' ;
    rdfs:domain ind:SeasonInventoryPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:seasonStartDate rdf:type rdf:Property ;
    rdfs:label 'Season Start Date' ;
    rdfs:comment 'The first date of the IATA schedule season for which this inventory plan is effective. Corresponds to the IATA SSIM-defined season start date (typically last Sunday of March for Summer, last Sunday of October for Winter). Serves as EFFECTIVE_FROM.' ;
    rdfs:domain ind:SeasonInventoryPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalPlannedCapacity rdf:type rdf:Property ;
    rdfs:label 'Total Planned Capacity' ;
    rdfs:comment 'Total number of sellable seats planned for this flight for the season, across all cabins. Represents the principal quantitative capacity fact (MEASUREMENT_OR_VALUE) for this inventory plan. Derived from aircraft configuration but stored here as the authoritative planned figure.' ;
    rdfs:domain ind:SeasonInventoryPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:yieldTarget rdf:type rdf:Property ;
    rdfs:label 'Yield Target' ;
    rdfs:comment 'The target yield (revenue per Revenue Passenger Kilometer — RPK) set by Revenue Management for this flight for the season, expressed in the operating currency per RPK. Used as the baseline revenue efficiency target. Confidential as it encodes pricing strategy.' ;
    rdfs:domain ind:SeasonInventoryPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:seatAvailabilityId rdf:type rdf:Property ;
    rdfs:label 'Seat Availability Id' ;
    rdfs:comment 'Unique surrogate identifier for each seat availability snapshot record in the inventory system. Primary key for this data product.' ;
    rdfs:domain ind:SeatAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:availabilityVersion rdf:type rdf:Property ;
    rdfs:label 'Availability Version' ;
    rdfs:comment 'Monotonically increasing version counter for this flight-date-fare-class availability record. Enables ordering of multiple snapshots for the same key and supports optimistic concurrency control in the Silver layer.' ;
    rdfs:domain ind:SeatAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bookingClassAvailabilityMap rdf:type rdf:Property ;
    rdfs:label 'Booking Class Availability Map' ;
    rdfs:comment 'Availability status string (AVS) representing the full cabin availability across all booking classes at the time of snapshot, as broadcast in GDS availability responses (e.g., \'Y9B9M9Q4V0\'). Enables reconstruction of the complete availability display seen by travel agents.' ;
    rdfs:domain ind:SeatAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:broadcastTimestamp rdf:type rdf:Property ;
    rdfs:label 'Broadcast Timestamp' ;
    rdfs:comment 'Date and time when this availability update was broadcast to GDS and distribution channels. Distinct from snapshot_timestamp (capture time) and last_updated_timestamp (system update time). Used for GDS broadcast latency measurement and SLA verification.' ;
    rdfs:domain ind:SeatAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:codeshareAllotment rdf:type rdf:Property ;
    rdfs:label 'Codeshare Allotment' ;
    rdfs:comment 'Number of seats allocated to the codeshare marketing partner within this fare class bucket. Null when codeshare_indicator is false. Used to track partner inventory consumption against agreed allotment caps.' ;
    rdfs:domain ind:SeatAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:distributionChannel rdf:type rdf:Property ;
    rdfs:label 'Distribution Channel' ;
    rdfs:comment 'Channel context for which this availability snapshot was generated or broadcast. GDS = Global Distribution System (Amadeus, Sabre, Travelport); NDC = IATA New Distribution Capability; Direct = airline.com or mobile app; API = B2B direct connect; Interline = partner carrier ticketing; Codeshare = shared flight operation partner.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastDemand rdf:type rdf:Property ;
    rdfs:label 'Forecast Demand' ;
    rdfs:comment 'Revenue management system\'s demand forecast for this fare class bucket at the time of the snapshot, expressed as expected number of bookings. Captured alongside actual availability for model accuracy tracking and yield optimization.' ;
    rdfs:domain ind:SeatAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gdsProviderCode rdf:type rdf:Property ;
    rdfs:label 'Gds Provider Code' ;
    rdfs:comment 'IATA-assigned GDS provider code identifying the specific GDS to which this availability was broadcast: 1A = Amadeus, 1S = Sabre, 1G = Galileo (Travelport), 1P = Worldspan (Travelport). Null when distribution_channel is not GDS.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCurrentSnapshot rdf:type rdf:Property ;
    rdfs:label 'Is Current Snapshot' ;
    rdfs:comment 'Flag indicating whether this record represents the most recent (current) availability snapshot for the flight-date-fare-class combination. Enables efficient point-in-time queries without full history scan. Set to false when superseded by a newer snapshot.' ;
    rdfs:domain ind:SeatAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isInterlineEligible rdf:type rdf:Property ;
    rdfs:label 'Is Interline Eligible' ;
    rdfs:comment 'Flag indicating whether this fare class bucket is open for interline ticketing by partner carriers under bilateral interline agreements. Governs availability visibility in interline booking flows.' ;
    rdfs:domain ind:SeatAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rmDecisionCode rdf:type rdf:Property ;
    rdfs:label 'Rm Decision Code' ;
    rdfs:comment 'Code identifying the revenue management optimization decision or rule that triggered the current availability status or booking limit for this fare class bucket (e.g., FCST_CLOSE, MANUAL_OVERRIDE, AUTO_OPEN). Supports RM model audit and performance attribution.' ;
    rdfs:domain ind:SeatAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:snapshotTrigger rdf:type rdf:Property ;
    rdfs:label 'Snapshot Trigger' ;
    rdfs:comment 'Business event or system action that caused this availability snapshot to be generated and broadcast. Enables audit of why availability changed at a given point in time. [ENUM-REF-CANDIDATE: Booking|Cancellation|Schedule Change|RM Override|GDS Poll|NDC Request|Overbooking Adjustment|Batch Interval — promote to reference product]' ;
    rdfs:domain ind:SeatAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoUpgradeEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Upgrade Enabled' ;
    rdfs:comment 'Indicates whether the system is configured to automatically process and clear eligible upgrade requests for this flight-cabin pool without manual agent intervention.' ;
    rdfs:domain ind:UpgradeInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bidUpgradeMaxPrice rdf:type rdf:Property ;
    rdfs:label 'Bid Upgrade Max Price' ;
    rdfs:comment 'Maximum monetary bid amount cap for a paid bid-upgrade auction seat in this cabin on this flight. Prevents outlier bids and anchors the auction ceiling for revenue management.' ;
    rdfs:domain ind:UpgradeInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bidUpgradeMinPrice rdf:type rdf:Property ;
    rdfs:label 'Bid Upgrade Min Price' ;
    rdfs:comment 'Minimum monetary bid amount accepted for a paid bid-upgrade auction seat in this cabin on this flight. Expressed in the operating currency. Feeds ancillary revenue management.' ;
    rdfs:domain ind:UpgradeInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bidUpgradeSeats rdf:type rdf:Property ;
    rdfs:label 'Bid Upgrade Seats' ;
    rdfs:comment 'Number of seats allocated to the paid bid-upgrade auction channel (e.g., Plusgrade or equivalent ancillary upgrade product). Feeds the ancillary services domain for revenue capture.' ;
    rdfs:domain ind:UpgradeInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clearanceCutoffHours rdf:type rdf:Property ;
    rdfs:label 'Clearance Cutoff Hours' ;
    rdfs:comment 'Number of hours before scheduled departure at which upgrade clearance processing closes. After this threshold, no further upgrades are processed and remaining pool seats revert to general inventory.' ;
    rdfs:domain ind:UpgradeInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clearanceWindowHours rdf:type rdf:Property ;
    rdfs:label 'Clearance Window Hours' ;
    rdfs:comment 'Number of hours before scheduled departure at which the upgrade clearance processing window opens. Defines when the system begins auto-clearing eligible waitlisted upgrade requests.' ;
    rdfs:domain ind:UpgradeInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:codeshareUpgradeSeats rdf:type rdf:Property ;
    rdfs:label 'Codeshare Upgrade Seats' ;
    rdfs:comment 'Number of upgrade seats within the pool allocated to codeshare partner airline passengers. Governs interline and codeshare upgrade entitlements per bilateral agreements.' ;
    rdfs:domain ind:UpgradeInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:confirmedUpgrades rdf:type rdf:Property ;
    rdfs:label 'Confirmed Upgrades' ;
    rdfs:comment 'Current count of upgrade seats that have been confirmed and assigned to passengers across all upgrade types. Used to compute remaining availability in real time.' ;
    rdfs:domain ind:UpgradeInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eliteUpgradeProcessingOrder rdf:type rdf:Property ;
    rdfs:label 'Elite Upgrade Processing Order' ;
    rdfs:comment 'Primary sort criterion used when sequencing elite FFP upgrade candidates from the waitlist. TIER_FIRST=highest loyalty tier processed first; FARE_FIRST=highest paid fare class first; CHECKIN_FIRST=earliest check-in time first; MILES_FIRST=highest accrued miles balance first.' ;
    rdfs:domain ind:UpgradeInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eliteUpgradeSeats rdf:type rdf:Property ;
    rdfs:label 'Elite Upgrade Seats' ;
    rdfs:comment 'Number of seats within the upgrade pool reserved exclusively for complimentary upgrades to elite-tier Frequent Flyer Program (FFP) members. Interfaces with Oracle Loyalty Cloud for tier eligibility.' ;
    rdfs:domain ind:UpgradeInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inventorySnapshotTimestamp rdf:type rdf:Property ;
    rdfs:label 'Inventory Snapshot Timestamp' ;
    rdfs:comment 'Timestamp of the most recent real-time availability snapshot for this upgrade inventory pool, as published to GDS and direct booking channels. Aligns with Amadeus Altéa real-time availability feeds.' ;
    rdfs:domain ind:UpgradeInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastClearanceRunTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Clearance Run Timestamp' ;
    rdfs:comment 'Timestamp of the most recent automated upgrade clearance processing run for this flight-cabin pool. Used for operational monitoring and audit of clearance execution.' ;
    rdfs:domain ind:UpgradeInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:loadFactorAtSnapshot rdf:type rdf:Property ;
    rdfs:label 'Load Factor At Snapshot' ;
    rdfs:comment 'Cabin load factor (percentage of seats filled) in the target upgrade cabin at the time of the most recent inventory snapshot. Expressed as a percentage (0.00–100.00). Used by revenue management to calibrate upgrade pool sizing.' ;
    rdfs:domain ind:UpgradeInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minEliteTierRequired rdf:type rdf:Property ;
    rdfs:label 'Min Elite Tier Required' ;
    rdfs:comment 'Minimum Frequent Flyer Program (FFP) elite tier level a member must hold to be eligible for a complimentary upgrade from this pool. Tiers below this threshold are excluded from elite upgrade processing.' ;
    rdfs:domain ind:UpgradeInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationalUpgradeSeats rdf:type rdf:Property ;
    rdfs:label 'Operational Upgrade Seats' ;
    rdfs:comment 'Number of seats held for operational upgrades issued by the airline at check-in or gate (e.g., IROP recovery, oversell resolution, VIP handling). Managed by ground operations and airport staff.' ;
    rdfs:domain ind:UpgradeInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overbookingBufferSeats rdf:type rdf:Property ;
    rdfs:label 'Overbooking Buffer Seats' ;
    rdfs:comment 'Number of additional upgrade seats held as an overbooking buffer above physical cabin capacity to account for expected no-shows and cancellations. Managed by revenue management yield optimization.' ;
    rdfs:domain ind:UpgradeInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overrideReasonCode rdf:type rdf:Property ;
    rdfs:label 'Override Reason Code' ;
    rdfs:comment 'Standardized reason code explaining why a revenue management override was applied to this upgrade inventory pool. Applicable only when revenue_management_override is TRUE. IROP=Irregular Operations; VIP=VIP passenger handling; COMMERCIAL=commercial agreement; CAPACITY_CHANGE=aircraft swap or gauge change.' ;
    rdfs:domain ind:UpgradeInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poolClosedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pool Closed Timestamp' ;
    rdfs:comment 'Timestamp at which the upgrade inventory pool was closed, either by reaching the clearance cutoff or by manual revenue management action. Null if pool is still open.' ;
    rdfs:domain ind:UpgradeInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:poolOpenTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pool Open Timestamp' ;
    rdfs:comment 'Timestamp at which the upgrade inventory pool was opened and made available for upgrade request intake. Marks the start of the upgrade acceptance window.' ;
    rdfs:domain ind:UpgradeInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:priorityRuleCode rdf:type rdf:Property ;
    rdfs:label 'Priority Rule Code' ;
    rdfs:comment 'Code referencing the upgrade priority rule set applied to this inventory pool. Governs the sequencing logic for elite FFP tier, fare class paid, check-in time, and other tiebreaker criteria.' ;
    rdfs:domain ind:UpgradeInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueManagementOverride rdf:type rdf:Property ;
    rdfs:label 'Revenue Management Override' ;
    rdfs:comment 'Indicates whether a revenue management analyst has manually overridden the system-calculated upgrade seat allocation for this flight-cabin pool, superseding automated yield optimization rules.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceCabinClassCode rdf:type rdf:Property ;
    rdfs:label 'Source Cabin Class Code' ;
    rdfs:comment 'IATA cabin class code of the originating cabin from which passengers are being upgraded. Defines the upgrade direction (e.g., Y→C means Economy to Business). Complements cabin_class_code which is the target cabin.' ;
    rdfs:domain ind:UpgradeInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalUpgradeSeats rdf:type rdf:Property ;
    rdfs:label 'Total Upgrade Seats' ;
    rdfs:comment 'Total number of seats in the target cabin designated as available for upgrade processing across all upgrade types (elite FFP, bid, operational). This is the gross pool before allocation by upgrade type.' ;
    rdfs:domain ind:UpgradeInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:waitlistedUpgrades rdf:type rdf:Property ;
    rdfs:label 'Waitlisted Upgrades' ;
    rdfs:comment 'Number of upgrade requests currently on the waitlist for this flight-cabin pool, pending seat availability or clearance processing.' ;
    rdfs:domain ind:UpgradeInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:waitlistEntryId rdf:type rdf:Property ;
    rdfs:label 'Waitlist Entry Id' ;
    rdfs:comment 'Unique surrogate identifier for each waitlist entry record in the Altéa Inventory waitlist processing engine. Primary key for this data product.' ;
    rdfs:domain ind:WaitlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:campaignResponseId rdf:type rdf:Property ;
    rdfs:label 'Campaign Response Id' ;
    rdfs:comment 'Foreign key linking to marketing.campaign_response. Business justification: Passengers may waitlist after responding to a campaign offer when inventory is sold out. Airlines track campaign-driven demand including waitlisted requests for demand forecasting. Essential for measu' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CampaignResponse .

ind:alteaWaitlistSequence rdf:type rdf:Property ;
    rdfs:label 'Altea Waitlist Sequence' ;
    rdfs:comment 'Native waitlist sequence number assigned by the Amadeus Altéa Inventory waitlist processing engine. Serves as the business identifier for this waitlist entry within the Altéa system, used for reconciliation between the lakehouse Silver layer and the source PSS.' ;
    rdfs:domain ind:WaitlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelCode rdf:type rdf:Property ;
    rdfs:label 'Channel Code' ;
    rdfs:comment 'Distribution channel through which the waitlist entry was created. GDS: Global Distribution System (e.g., Amadeus, Sabre, Travelport); NDC: IATA New Distribution Capability channel; DIRECT_WEB: airline direct website; MOBILE: airline mobile application; AIRPORT: airport check-in or gate agent; CALL_CENTER: reservations call center; INTERLINE: interline partner booking. [ENUM-REF-CANDIDATE: GDS|NDC|DIRECT_WEB|MOBILE|AIRPORT|CALL_CENTER|INTERLINE — promote to reference product]' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearanceBookingClass rdf:type rdf:Property ;
    rdfs:label 'Clearance Booking Class' ;
    rdfs:comment 'The actual booking class in which the waitlist entry was cleared and confirmed, which may differ from the originally requested booking class if the revenue management system cleared the passenger into a higher-availability bucket. Null until clearance occurs.' ;
    rdfs:domain ind:WaitlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearanceMethod rdf:type rdf:Property ;
    rdfs:label 'Clearance Method' ;
    rdfs:comment 'Method by which the waitlist entry was cleared. AUTOMATIC: Altéa Inventory engine cleared automatically when bucket availability opened; MANUAL: airport or reservations agent manually cleared the entry; UPGRADE_PROCESSING: cleared as part of an upgrade processing run; IROP_REACCOMMODATION: cleared during Irregular Operations (IROP) reaccommodation workflow.' ;
    rdfs:domain ind:WaitlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearanceTimestamp rdf:type rdf:Property ;
    rdfs:label 'Clearance Timestamp' ;
    rdfs:comment 'Date and time (UTC) when the waitlist entry was successfully cleared and the seat confirmed. Null if the entry has not yet been cleared. Used to measure waitlist clearance latency and revenue recovery timing. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:WaitlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ffpMemberNumber rdf:type rdf:Property ;
    rdfs:label 'Ffp Member Number' ;
    rdfs:comment 'Frequent Flyer Program (FFP) membership number of the waitlisted passenger. Used to apply loyalty-based priority rules and to credit miles upon clearance and travel. Classified as confidential PII as it is a unique personal identifier.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdsQueueNumber rdf:type rdf:Property ;
    rdfs:label 'Gds Queue Number' ;
    rdfs:comment 'Queue number assigned by the Global Distribution System (GDS) for this waitlist entry, used to route clearance notifications back to the originating travel agent or booking system. Null for direct-channel bookings.' ;
    rdfs:domain ind:WaitlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationSent rdf:type rdf:Property ;
    rdfs:label 'Notification Sent' ;
    rdfs:comment 'Indicates whether a clearance or status-change notification has been dispatched to the passenger or booking agent following a waitlist status transition. True: notification sent; False: notification pending or not applicable. Supports DOT consumer notification compliance.' ;
    rdfs:domain ind:WaitlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:seatCountRequested rdf:type rdf:Property ;
    rdfs:label 'Seat Count Requested' ;
    rdfs:comment 'Number of seats requested on the waitlist for this entry. For individual bookings this is typically 1; for group bookings this may be greater than 1. Determines the inventory units required for clearance.' ;
    rdfs:domain ind:WaitlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:upgradeFromCabinCode rdf:type rdf:Property ;
    rdfs:label 'Upgrade From Cabin Code' ;
    rdfs:comment 'For upgrade-request waitlist entries, the cabin code of the originally booked cabin from which the passenger is requesting an upgrade (e.g., Y for Economy). Null for sold-out or group overflow waitlist reasons. Used by upgrade processing logic in Altéa Inventory.' ;
    rdfs:domain ind:WaitlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waitlistReason rdf:type rdf:Property ;
    rdfs:label 'Waitlist Reason' ;
    rdfs:comment 'Business reason why the passenger or booking was placed on the waitlist rather than confirmed. SOLD_OUT: requested fare class bucket was closed; UPGRADE_REQUEST: passenger requested cabin upgrade pending availability; GROUP_OVERFLOW: group booking exceeded available allotment; OVERBOOKING_CONTROL: revenue management overbooking limit reached; CODESHARE_ALLOTMENT: codeshare partner inventory allocation exhausted.' ;
    rdfs:domain ind:WaitlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waitlistStatus rdf:type rdf:Property ;
    rdfs:label 'Waitlist Status' ;
    rdfs:comment 'Current lifecycle status of the waitlist entry as managed by the Altéa Inventory waitlist processing engine. OPEN: actively queued awaiting availability; CLEARED: bucket opened and seat confirmed; CANCELLED: passenger or agent cancelled the waitlist request; EXPIRED: flight departed or deadline passed without clearance; REJECTED: system or revenue management rule prevented clearance.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awardBookingId rdf:type rdf:Property ;
    rdfs:label 'Award Booking Id' ;
    rdfs:comment 'Unique identifier for the award flight booking. Primary key for the award booking record.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AwardBooking .

ind:awardInventoryId rdf:type rdf:Property ;
    rdfs:label 'Award Inventory Id' ;
    rdfs:comment 'Foreign key linking to loyalty.award_inventory. Business justification: award_booking consumes award seat inventory from award_inventory. The award_inventory_bucket attribute (STRING) indicates which inventory bucket was used. Adding award_inventory_id FK links the bookin' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AwardInventory .

ind:mileageRedemptionId rdf:type rdf:Property ;
    rdfs:label 'Mileage Redemption Id' ;
    rdfs:comment 'Identifier linking to the mileage redemption transaction that debited the miles for this award booking.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MileageRedemption .

ind:partnerProgramId rdf:type rdf:Property ;
    rdfs:label 'Partner Program Id' ;
    rdfs:comment 'Foreign key linking to loyalty.partner_program. Business justification: award_booking has is_partner_award flag, operating_carrier_code, and marketing_carrier_code attributes. When is_partner_award is true, the booking is made through a partner airline agreement. Adding p' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PartnerProgram .

ind:awardPnr rdf:type rdf:Property ;
    rdfs:label 'Award Pnr' ;
    rdfs:comment 'Six-character alphanumeric Passenger Name Record locator for the award booking. Unique identifier used across reservation systems for this award travel.' ;
    rdfs:domain ind:AwardBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awardType rdf:type rdf:Property ;
    rdfs:label 'Award Type' ;
    rdfs:comment 'Classification of the award booking type. Saver awards require fewer miles but have limited availability; standard awards have higher mileage cost but greater availability; upgrade awards convert paid tickets to higher cabin; companion awards allow a second passenger at reduced miles; mixed cabin combines different service classes; partner awards are on codeshare or alliance airlines.' ;
    rdfs:domain ind:AwardBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:copayAmount rdf:type rdf:Property ;
    rdfs:label 'Copay Amount' ;
    rdfs:comment 'Monetary amount paid by the member in addition to miles for this award booking. Covers taxes, fees, and carrier-imposed surcharges not covered by miles.' ;
    rdfs:domain ind:AwardBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:copayCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Copay Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the co-pay amount. Indicates the currency in which taxes and fees were charged.' ;
    rdfs:domain ind:AwardBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPartnerAward rdf:type rdf:Property ;
    rdfs:label 'Is Partner Award' ;
    rdfs:comment 'Boolean flag indicating whether this award booking involves travel on a partner airline (alliance member or codeshare partner) rather than the marketing carrier\'s own metal.' ;
    rdfs:domain ind:AwardBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRoundTrip rdf:type rdf:Property ;
    rdfs:label 'Is Round Trip' ;
    rdfs:comment 'Boolean flag indicating whether this is a round-trip award booking (true) or one-way (false). Round-trip awards include both outbound and return travel.' ;
    rdfs:domain ind:AwardBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:numberOfPassengers rdf:type rdf:Property ;
    rdfs:label 'Number Of Passengers' ;
    rdfs:comment 'Total count of passengers included in this award booking. Represents how many travelers are covered by this single award PNR.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numberOfSegments rdf:type rdf:Property ;
    rdfs:label 'Number Of Segments' ;
    rdfs:comment 'Total count of flight segments (individual flight legs) included in this award booking itinerary. Multi-segment awards involve connections.' ;
    rdfs:domain ind:AwardBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:refundFeeMiles rdf:type rdf:Property ;
    rdfs:label 'Refund Fee Miles' ;
    rdfs:comment 'Number of FFP miles charged as a cancellation or change fee when refunding the award booking. Represents the penalty for award cancellation.' ;
    rdfs:domain ind:AwardBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:refundMilesAmount rdf:type rdf:Property ;
    rdfs:label 'Refund Miles Amount' ;
    rdfs:comment 'Number of FFP miles returned to the member account upon cancellation or refund of the award booking. May be less than original redemption if cancellation fees apply.' ;
    rdfs:domain ind:AwardBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:returnDate rdf:type rdf:Property ;
    rdfs:label 'Return Date' ;
    rdfs:comment 'Scheduled date of return for the inbound award flight. Null for one-way award bookings. Represents the return travel date for round-trip awards.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ticketingStatus rdf:type rdf:Property ;
    rdfs:label 'Ticketing Status' ;
    rdfs:comment 'Current status of e-ticket issuance for the award booking. Not ticketed means reservation exists but no ticket issued; ticketed means e-ticket generated; voided indicates ticket cancelled before travel; refunded means ticket cancelled with miles returned; exchanged means ticket modified for different travel.' ;
    rdfs:domain ind:AwardBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ticketingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ticketing Timestamp' ;
    rdfs:comment 'Date and time when the award e-ticket was issued. Null if booking has not been ticketed. Represents when the reservation was converted to a confirmed ticket.' ;
    rdfs:domain ind:AwardBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:totalMilesRedeemed rdf:type rdf:Property ;
    rdfs:label 'Total Miles Redeemed' ;
    rdfs:comment 'Total number of FFP miles debited from the member account for this award booking. Represents the mileage cost across all passengers and segments.' ;
    rdfs:domain ind:AwardBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocationEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Allocation Effective Date' ;
    rdfs:comment 'The date from which this award seat allocation becomes effective and available for member booking.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allocationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Allocation Expiry Date' ;
    rdfs:comment 'The date after which this award seat allocation expires and is no longer available for booking. Null for open-ended allocations.' ;
    rdfs:domain ind:AwardInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allocationSource rdf:type rdf:Property ;
    rdfs:label 'Allocation Source' ;
    rdfs:comment 'The source or method by which award seats were allocated to this inventory bucket. Revenue management indicates standard RM allocation; partner agreement indicates contractual allocation; promotional indicates campaign-driven allocation; dynamic indicates real-time algorithmic allocation.' ;
    rdfs:domain ind:AwardInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awardBucketCode rdf:type rdf:Property ;
    rdfs:label 'Award Bucket Code' ;
    rdfs:comment 'The award inventory bucket code indicating the redemption tier (e.g., saver, standard, premium). Determines mileage cost and availability rules.' ;
    rdfs:domain ind:AwardInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awardBucketType rdf:type rdf:Property ;
    rdfs:label 'Award Bucket Type' ;
    rdfs:comment 'The award redemption tier type. Saver awards require fewer miles but have limited availability; standard and premium awards offer greater availability at higher mileage cost.' ;
    rdfs:domain ind:AwardInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blackoutDateFlag rdf:type rdf:Property ;
    rdfs:label 'Blackout Date Flag' ;
    rdfs:comment 'Indicates whether this travel date is designated as a blackout date for award redemptions. True means no award seats are available regardless of inventory.' ;
    rdfs:domain ind:AwardInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bookingWindowCloseDays rdf:type rdf:Property ;
    rdfs:label 'Booking Window Close Days' ;
    rdfs:comment 'The minimum number of days before departure that award bookings close. Typically 1-14 days depending on route and cabin.' ;
    rdfs:domain ind:AwardInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bookingWindowOpenDays rdf:type rdf:Property ;
    rdfs:label 'Booking Window Open Days' ;
    rdfs:comment 'The number of days in advance that award seats become available for booking. Standard is 330-365 days for most airlines.' ;
    rdfs:domain ind:AwardInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cancellationFeeWaivedFlag rdf:type rdf:Property ;
    rdfs:label 'Cancellation Fee Waived Flag' ;
    rdfs:comment 'Indicates whether the standard award cancellation fee is waived for bookings in this inventory bucket. Often applies to elite members or promotional awards.' ;
    rdfs:domain ind:AwardInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coPayAmount rdf:type rdf:Property ;
    rdfs:label 'Co Pay Amount' ;
    rdfs:comment 'The mandatory cash co-payment amount required in addition to miles for award redemption. Zero if no co-pay is required.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coPayCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Co Pay Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the co-payment amount. Null if no co-pay is required.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eliteOnlyFlag rdf:type rdf:Property ;
    rdfs:label 'Elite Only Flag' ;
    rdfs:comment 'Indicates whether award seat availability is restricted to elite tier members only. Used for premium cabin inventory management.' ;
    rdfs:domain ind:AwardInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minimumTierRequired rdf:type rdf:Property ;
    rdfs:label 'Minimum Tier Required' ;
    rdfs:comment 'The minimum FFP tier status code required to access this award inventory bucket. Null if available to all members.' ;
    rdfs:domain ind:AwardInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerAwardAvailabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Partner Award Availability Flag' ;
    rdfs:comment 'Indicates whether these award seats are available for redemption by partner FFP members under reciprocal agreements.' ;
    rdfs:domain ind:AwardInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:seatsRedeemed rdf:type rdf:Property ;
    rdfs:label 'Seats Redeemed' ;
    rdfs:comment 'The cumulative number of award seats that have been successfully redeemed and ticketed for this flight, cabin, and bucket.' ;
    rdfs:domain ind:AwardInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seatsWaitlisted rdf:type rdf:Property ;
    rdfs:label 'Seats Waitlisted' ;
    rdfs:comment 'The number of members currently on the waitlist for award seats on this flight and cabin when availability is zero.' ;
    rdfs:domain ind:AwardInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalAwardSeatsAllocated rdf:type rdf:Property ;
    rdfs:label 'Total Award Seats Allocated' ;
    rdfs:comment 'The total number of seats allocated to the FFP award inventory pool for this flight, cabin, and bucket combination. Set by revenue management.' ;
    rdfs:domain ind:AwardInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:coalitionProgramId rdf:type rdf:Property ;
    rdfs:label 'Coalition Program Id' ;
    rdfs:comment 'Unique identifier for the coalition loyalty program. Primary key.' ;
    rdfs:domain ind:CoalitionProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:apiAuthenticationMethod rdf:type rdf:Property ;
    rdfs:label 'Api Authentication Method' ;
    rdfs:comment 'Authentication protocol used to secure API communications between the airline and coalition operator systems.' ;
    rdfs:domain ind:CoalitionProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:burnRulesSummary rdf:type rdf:Property ;
    rdfs:label 'Burn Rules Summary' ;
    rdfs:comment 'High-level description of how members redeem coalition currency for airline rewards (e.g., \'Redeem points for award flights at standard rates\').' ;
    rdfs:domain ind:CoalitionProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:burnSettlementRate rdf:type rdf:Property ;
    rdfs:label 'Burn Settlement Rate' ;
    rdfs:comment 'Financial rate (in settlement currency) that the airline charges the coalition operator per unit of coalition currency redeemed for airline rewards.' ;
    rdfs:domain ind:CoalitionProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coalitionOperatorCountryCode rdf:type rdf:Property ;
    rdfs:label 'Coalition Operator Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the coalition operator\'s headquarters.' ;
    rdfs:domain ind:CoalitionProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coalitionOperatorName rdf:type rdf:Property ;
    rdfs:label 'Coalition Operator Name' ;
    rdfs:comment 'Legal name of the organization that operates and governs the coalition program (e.g., \'Star Alliance Services GmbH\').' ;
    rdfs:domain ind:CoalitionProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPersonName rdf:type rdf:Property ;
    rdfs:label 'Contact Person Name' ;
    rdfs:comment 'Name of the primary contact person at the coalition operator for operational and commercial matters.' ;
    rdfs:domain ind:CoalitionProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionRateToAirlineMiles rdf:type rdf:Property ;
    rdfs:label 'Conversion Rate To Airline Miles' ;
    rdfs:comment 'Exchange rate for converting coalition program currency to the airline\'s native FFP miles (e.g., 1.0000 means 1:1, 0.5000 means 2 coalition points = 1 airline mile).' ;
    rdfs:domain ind:CoalitionProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataSharingAgreementReference rdf:type rdf:Property ;
    rdfs:label 'Data Sharing Agreement Reference' ;
    rdfs:comment 'Reference number or identifier of the legal data sharing agreement governing member data exchange between the airline and coalition operator.' ;
    rdfs:domain ind:CoalitionProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:earnRulesSummary rdf:type rdf:Property ;
    rdfs:label 'Earn Rules Summary' ;
    rdfs:comment 'High-level description of how members earn coalition currency through airline activity (e.g., \'Earn 1 point per dollar spent on eligible flights\').' ;
    rdfs:domain ind:CoalitionProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:earnSettlementRate rdf:type rdf:Property ;
    rdfs:label 'Earn Settlement Rate' ;
    rdfs:comment 'Financial rate (in settlement currency) that the coalition operator pays the airline per unit of coalition currency earned by members through airline activity.' ;
    rdfs:domain ind:CoalitionProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gdprCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Gdpr Compliant Flag' ;
    rdfs:comment 'Indicates whether the coalition program\'s data handling practices are compliant with GDPR requirements for EU member data.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:governanceModel rdf:type rdf:Property ;
    rdfs:label 'Governance Model' ;
    rdfs:comment 'Organizational governance structure of the coalition program defining decision-making authority and member airline roles.' ;
    rdfs:domain ind:CoalitionProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingVisibilityLevel rdf:type rdf:Property ;
    rdfs:label 'Marketing Visibility Level' ;
    rdfs:comment 'Level of prominence given to the coalition program in the airline\'s customer-facing marketing materials and FFP communications.' ;
    rdfs:domain ind:CoalitionProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:memberEnrollmentUrl rdf:type rdf:Property ;
    rdfs:label 'Member Enrollment Url' ;
    rdfs:comment 'Web URL where airline FFP members can enroll in or link their accounts to the coalition program.' ;
    rdfs:domain ind:CoalitionProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:memberLinkageMechanism rdf:type rdf:Property ;
    rdfs:label 'Member Linkage Mechanism' ;
    rdfs:comment 'Technical method used to link airline FFP members to their coalition program accounts.' ;
    rdfs:domain ind:CoalitionProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumCommitmentAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Commitment Amount' ;
    rdfs:comment 'Minimum financial commitment (in settlement currency) the airline must meet annually to maintain participation in the coalition program.' ;
    rdfs:domain ind:CoalitionProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:noticePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Notice Period Days' ;
    rdfs:comment 'Number of days advance notice required by either party to terminate participation in the coalition program.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:programCurrencyName rdf:type rdf:Property ;
    rdfs:label 'Program Currency Name' ;
    rdfs:comment 'Name of the loyalty currency used within the coalition program (e.g., \'Alliance Miles\', \'Coalition Points\').' ;
    rdfs:domain ind:CoalitionProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programType rdf:type rdf:Property ;
    rdfs:label 'Program Type' ;
    rdfs:comment 'Classification of the coalition program by industry vertical or partnership model.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementFrequency rdf:type rdf:Property ;
    rdfs:label 'Settlement Frequency' ;
    rdfs:comment 'Frequency at which financial settlements occur between the airline and the coalition operator for earned and redeemed currency.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audienceSegmentId rdf:type rdf:Property ;
    rdfs:label 'Audience Segment Id' ;
    rdfs:comment 'Foreign key linking to marketing.audience_segment. Business justification: FFP members are segmented for targeted marketing campaigns. This FK links the member to their primary audience segment for campaign targeting and personalization.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AudienceSegment .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line 1' ;
    rdfs:comment 'First line of the member\'s mailing address (street number and name).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line 2' ;
    rdfs:comment 'Second line of the member\'s mailing address (apartment, suite, unit number).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentMilesBalance rdf:type rdf:Property ;
    rdfs:label 'Current Miles Balance' ;
    rdfs:comment 'Current available miles or points balance that can be redeemed for awards, upgrades, or partner benefits. Reflects accruals minus redemptions and expirations.' ;
    rdfs:domain ind:FfpMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emailConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Email Consent Flag' ;
    rdfs:comment 'Indicates whether the member has consented to receive email communications. True=consent given, False=opt-out.' ;
    rdfs:domain ind:FfpMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:enrollmentChannel rdf:type rdf:Property ;
    rdfs:label 'Enrollment Channel' ;
    rdfs:comment 'Channel through which the member enrolled in the FFP. Used for channel attribution and marketing analysis.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment Date' ;
    rdfs:comment 'Date when the member first enrolled in the FFP. Used for tenure-based benefits and anniversary promotions.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ffpNumber rdf:type rdf:Property ;
    rdfs:label 'Ffp Number' ;
    rdfs:comment 'Externally-known unique FFP membership number issued to the member. This is the business identifier used across all customer touchpoints, partner airlines, and GDS systems.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gender rdf:type rdf:Property ;
    rdfs:label 'Gender' ;
    rdfs:comment 'Member\'s gender. M=Male, F=Female, X=Non-binary/Other, U=Undisclosed/Prefer not to say.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:homeAirportCode rdf:type rdf:Property ;
    rdfs:label 'Home Airport Code' ;
    rdfs:comment 'Three-letter IATA airport code representing the member\'s primary departure airport. Used for targeted route promotions and service personalization.' ;
    rdfs:domain ind:FfpMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastActivityDate rdf:type rdf:Property ;
    rdfs:label 'Last Activity Date' ;
    rdfs:comment 'Date of the member\'s most recent FFP activity (flight, redemption, or partner transaction). Used for dormancy detection and reactivation campaigns.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lifetimeMilesBalance rdf:type rdf:Property ;
    rdfs:label 'Lifetime Miles Balance' ;
    rdfs:comment 'Total cumulative miles or points earned by the member since enrollment, never decremented by redemptions. Used for lifetime status qualification.' ;
    rdfs:domain ind:FfpMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lifetimeStatusFlag rdf:type rdf:Property ;
    rdfs:label 'Lifetime Status Flag' ;
    rdfs:comment 'Indicates whether the member has achieved lifetime elite status, which is never revoked regardless of annual activity. True=lifetime status achieved, False=standard annual qualification.' ;
    rdfs:domain ind:FfpMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketingConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Marketing Consent Flag' ;
    rdfs:comment 'Indicates whether the member has consented to receive marketing communications and promotional offers. True=consent given, False=opt-out.' ;
    rdfs:domain ind:FfpMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mealPreference rdf:type rdf:Property ;
    rdfs:label 'Meal Preference' ;
    rdfs:comment 'Member\'s dietary preference or special meal request code (e.g., VGML=vegetarian, KSML=kosher, DBML=diabetic). Free-text or SSR code.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:memberFirstName rdf:type rdf:Property ;
    rdfs:label 'Member First Name' ;
    rdfs:comment 'First name (given name) of the FFP member as registered in the loyalty program.' ;
    rdfs:domain ind:FfpMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:memberLastName rdf:type rdf:Property ;
    rdfs:label 'Member Last Name' ;
    rdfs:comment 'Last name (family name) of the FFP member as registered in the loyalty program.' ;
    rdfs:domain ind:FfpMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:memberMiddleName rdf:type rdf:Property ;
    rdfs:label 'Member Middle Name' ;
    rdfs:comment 'Middle name or initial of the FFP member, if provided.' ;
    rdfs:domain ind:FfpMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:membershipStatus rdf:type rdf:Property ;
    rdfs:label 'Membership Status' ;
    rdfs:comment 'Current lifecycle status of the FFP membership. Active=member in good standing, Inactive=no recent activity, Suspended=temporarily restricted, Closed=permanently terminated, Pending=enrollment not yet complete.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phoneNumber rdf:type rdf:Property ;
    rdfs:label 'Phone Number' ;
    rdfs:comment 'Primary contact phone number for the FFP member, including country code.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredCabinClass rdf:type rdf:Property ;
    rdfs:label 'Preferred Cabin Class' ;
    rdfs:comment 'Member\'s preferred cabin class for travel. Used for upgrade targeting and personalized offers.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredLanguage rdf:type rdf:Property ;
    rdfs:label 'Preferred Language' ;
    rdfs:comment 'Two-letter ISO 639-1 language code for member communication preferences.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredSeatType rdf:type rdf:Property ;
    rdfs:label 'Preferred Seat Type' ;
    rdfs:comment 'Member\'s preferred seat location on the aircraft.' ;
    rdfs:domain ind:FfpMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:smsConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Sms Consent Flag' ;
    rdfs:comment 'Indicates whether the member has consented to receive SMS/text message communications. True=consent given, False=opt-out.' ;
    rdfs:domain ind:FfpMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tierExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Tier Expiration Date' ;
    rdfs:comment 'Date when the current tier status expires and will be re-evaluated based on qualifying activity.' ;
    rdfs:domain ind:FfpMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tierLevel rdf:type rdf:Property ;
    rdfs:label 'Tier Level' ;
    rdfs:comment 'Current elite tier status of the member within the FFP hierarchy. Determines benefits, upgrade priority, lounge access, and bonus mileage accrual rates.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierQualificationDate rdf:type rdf:Property ;
    rdfs:label 'Tier Qualification Date' ;
    rdfs:comment 'Date when the member achieved their current tier level.' ;
    rdfs:domain ind:FfpMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tierQualifyingMiles rdf:type rdf:Property ;
    rdfs:label 'Tier Qualifying Miles' ;
    rdfs:comment 'Miles earned in the current qualification period that count toward tier status. Typically excludes bonus miles and partner accruals.' ;
    rdfs:domain ind:FfpMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tierQualifyingSegments rdf:type rdf:Property ;
    rdfs:label 'Tier Qualifying Segments' ;
    rdfs:comment 'Number of flight segments flown in the current qualification period that count toward tier status.' ;
    rdfs:domain ind:FfpMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lifetimeStatusId rdf:type rdf:Property ;
    rdfs:label 'Lifetime Status Id' ;
    rdfs:comment 'Unique identifier for the lifetime status record. Primary key.' ;
    rdfs:domain ind:LifetimeStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tierStatusId rdf:type rdf:Property ;
    rdfs:label 'Tier Status Id' ;
    rdfs:comment 'Foreign key linking to loyalty.tier_status. Business justification: lifetime_status has lifetime_status_level and lifetime_status_code attributes indicating the permanent tier level granted. tier_status is the master definition table for tier levels. Adding tier_statu' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TierStatus .

ind:benefitsOverrideFlag rdf:type rdf:Property ;
    rdfs:label 'Benefits Override Flag' ;
    rdfs:comment 'Indicates whether this lifetime status includes custom or enhanced benefits beyond the standard tier benefits (true if custom benefits apply).' ;
    rdfs:domain ind:LifetimeStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bonusMileMultiplierLifetime rdf:type rdf:Property ;
    rdfs:label 'Bonus Mile Multiplier Lifetime' ;
    rdfs:comment 'The permanent bonus mile earning multiplier applied to all future flights for this lifetime status holder (e.g., 1.50 for 50% bonus).' ;
    rdfs:domain ind:LifetimeStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:externalReferenceCode rdf:type rdf:Property ;
    rdfs:label 'External Reference Code' ;
    rdfs:comment 'External system identifier or reference number for this lifetime status record in the source system.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:extraBaggageAllowanceKg rdf:type rdf:Property ;
    rdfs:label 'Extra Baggage Allowance Kg' ;
    rdfs:comment 'Additional baggage allowance in kilograms granted permanently to the lifetime status holder.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:grantDate rdf:type rdf:Property ;
    rdfs:label 'Grant Date' ;
    rdfs:comment 'The date on which the lifetime status was officially granted to the member.' ;
    rdfs:domain ind:LifetimeStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lifetimeMilesEarned rdf:type rdf:Property ;
    rdfs:label 'Lifetime Miles Earned' ;
    rdfs:comment 'Cumulative total of all miles earned by the member across their entire FFP membership history at the time of lifetime status grant.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lifetimeSegmentsFlown rdf:type rdf:Property ;
    rdfs:label 'Lifetime Segments Flown' ;
    rdfs:comment 'Cumulative total of flight segments flown by the member across their entire FFP membership history at the time of lifetime status grant.' ;
    rdfs:domain ind:LifetimeStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lifetimeSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Lifetime Spend Amount' ;
    rdfs:comment 'Cumulative total spend (revenue contribution) by the member across their entire FFP membership history at the time of lifetime status grant.' ;
    rdfs:domain ind:LifetimeStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lifetimeSpendCurrency rdf:type rdf:Property ;
    rdfs:label 'Lifetime Spend Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the lifetime spend amount.' ;
    rdfs:domain ind:LifetimeStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lifetimeStatusCode rdf:type rdf:Property ;
    rdfs:label 'Lifetime Status Code' ;
    rdfs:comment 'Short code representing the lifetime status level for system processing and display.' ;
    rdfs:domain ind:LifetimeStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lifetimeStatusLevel rdf:type rdf:Property ;
    rdfs:label 'Lifetime Status Level' ;
    rdfs:comment 'The permanent tier level achieved by the member (e.g., Lifetime Gold, Lifetime Platinum). This status is non-expiring and represents lifetime achievement.' ;
    rdfs:domain ind:LifetimeStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lifetimeStatusStatus rdf:type rdf:Property ;
    rdfs:label 'Lifetime Status Status' ;
    rdfs:comment 'Current state of the lifetime status. Typically active, but may be suspended or revoked in exceptional circumstances (e.g., program abuse, fraud).' ;
    rdfs:domain ind:LifetimeStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loungeAccessLifetimeFlag rdf:type rdf:Property ;
    rdfs:label 'Lounge Access Lifetime Flag' ;
    rdfs:comment 'Indicates whether the member has permanent lounge access as part of their lifetime status benefits.' ;
    rdfs:domain ind:LifetimeStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:partnerTierEquivalentCode rdf:type rdf:Property ;
    rdfs:label 'Partner Tier Equivalent Code' ;
    rdfs:comment 'The equivalent tier code recognized by partner airlines and alliance programs for this lifetime status (e.g., oneworld Emerald, Star Alliance Gold).' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityBoardingLifetimeFlag rdf:type rdf:Property ;
    rdfs:label 'Priority Boarding Lifetime Flag' ;
    rdfs:comment 'Indicates whether the member has permanent priority boarding privileges as part of their lifetime status benefits.' ;
    rdfs:domain ind:LifetimeStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualificationBasis rdf:type rdf:Property ;
    rdfs:label 'Qualification Basis' ;
    rdfs:comment 'The primary criterion or method by which the member qualified for lifetime status (e.g., lifetime miles threshold, lifetime segments, special recognition).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognitionType rdf:type rdf:Property ;
    rdfs:label 'Recognition Type' ;
    rdfs:comment 'The type of recognition or award associated with this lifetime status (e.g., Million Miler, Two Million Miler, Lifetime Achievement Award).' ;
    rdfs:domain ind:LifetimeStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialBenefitsDescription rdf:type rdf:Property ;
    rdfs:label 'Special Benefits Description' ;
    rdfs:comment 'Free-text description of any special or custom benefits granted to this lifetime status holder beyond standard tier benefits.' ;
    rdfs:domain ind:LifetimeStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdMilesRequired rdf:type rdf:Property ;
    rdfs:label 'Threshold Miles Required' ;
    rdfs:comment 'The lifetime miles threshold that was required to achieve this lifetime status level at the time of grant.' ;
    rdfs:domain ind:LifetimeStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:thresholdSegmentsRequired rdf:type rdf:Property ;
    rdfs:label 'Threshold Segments Required' ;
    rdfs:comment 'The lifetime segments threshold that was required to achieve this lifetime status level at the time of grant.' ;
    rdfs:domain ind:LifetimeStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:thresholdSpendRequired rdf:type rdf:Property ;
    rdfs:label 'Threshold Spend Required' ;
    rdfs:comment 'The lifetime spend threshold that was required to achieve this lifetime status level at the time of grant.' ;
    rdfs:domain ind:LifetimeStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:upgradeEligibilityLifetimeFlag rdf:type rdf:Property ;
    rdfs:label 'Upgrade Eligibility Lifetime Flag' ;
    rdfs:comment 'Indicates whether the member has permanent complimentary upgrade eligibility as part of their lifetime status benefits.' ;
    rdfs:domain ind:LifetimeStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waitlistPriorityRank rdf:type rdf:Property ;
    rdfs:label 'Waitlist Priority Rank' ;
    rdfs:comment 'The priority ranking assigned to this lifetime status holder for upgrade and standby waitlists (lower number = higher priority).' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:loyaltyPromotionId rdf:type rdf:Property ;
    rdfs:label 'Loyalty Promotion Id' ;
    rdfs:comment 'Unique identifier for the FFP (Frequent Flyer Program) promotional campaign. Primary key. Inferred role: MASTER_RESOURCE (promotional campaign as a managed marketing resource).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LoyaltyPromotion .

ind:parentCampaignId rdf:type rdf:Property ;
    rdfs:label 'Parent Campaign Id' ;
    rdfs:comment 'Foreign key linking to marketing.campaign. Business justification: Loyalty promotions are often tactical components of broader marketing campaigns (e.g., summer travel campaign includes bonus miles promotion). Parent campaign link enables budget consolidation, strate' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Campaign .

ind:actualCost rdf:type rdf:Property ;
    rdfs:label 'Actual Cost' ;
    rdfs:comment 'Actual total financial cost incurred by the promotion after completion, calculated from bonus miles awarded and their valuation. Used for ROI (Return on Investment) analysis. Business-sensitive financial data.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bonusMilesFormula rdf:type rdf:Property ;
    rdfs:label 'Bonus Miles Formula' ;
    rdfs:comment 'Business rule or formula defining how bonus miles are calculated (e.g., \'2x base miles\', \'flat 5000 miles\', \'base_miles * 1.5 + 1000\'). Free-text expression used by accrual engine. Measurement/value category for the promotion.' ;
    rdfs:domain ind:LoyaltyPromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communicationChannel rdf:type rdf:Property ;
    rdfs:label 'Communication Channel' ;
    rdfs:comment 'Primary channel(s) used to communicate the promotion to members (email, SMS, push notification, in-app message, website banner, or all). Used for campaign execution and member engagement.' ;
    rdfs:domain ind:LoyaltyPromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibleMemberTiers rdf:type rdf:Property ;
    rdfs:label 'Eligible Member Tiers' ;
    rdfs:comment 'Comma-separated list of FFP (Frequent Flyer Program) member tier codes eligible to participate (e.g., \'SILVER,GOLD,PLATINUM\' or \'ALL\'). Empty or \'ALL\' indicates no tier restriction.' ;
    rdfs:domain ind:LoyaltyPromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligiblePartners rdf:type rdf:Property ;
    rdfs:label 'Eligible Partners' ;
    rdfs:comment 'Comma-separated list of partner airline IATA codes or coalition partner identifiers eligible for bonus earn (e.g., \'AA,BA,QF\' for airline partners or \'HOTEL_CHAIN_X\' for non-air partners). Empty or \'ALL\' indicates no partner restriction.' ;
    rdfs:domain ind:LoyaltyPromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Cost' ;
    rdfs:comment 'Estimated total financial cost or liability of the promotion in the airline\'s reporting currency (e.g., USD). Used for budgeting and financial planning. Business-sensitive financial data.' ;
    rdfs:domain ind:LoyaltyPromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:externalPromotionCode rdf:type rdf:Property ;
    rdfs:label 'External Promotion Code' ;
    rdfs:comment 'Unique identifier for the promotion in the source operational system (e.g., Oracle Loyalty Cloud promotion ID). Used for cross-system reconciliation and data lineage.' ;
    rdfs:domain ind:LoyaltyPromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedBy rdf:type rdf:Property ;
    rdfs:label 'Last Modified By' ;
    rdfs:comment 'User ID or name of the staff who last updated the promotion record. Used for audit trail and change tracking.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumBonusCap rdf:type rdf:Property ;
    rdfs:label 'Maximum Bonus Cap' ;
    rdfs:comment 'Maximum total bonus miles a member can earn under this promotion. Null indicates no cap. Used to control promotion liability and prevent abuse.' ;
    rdfs:domain ind:LoyaltyPromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:optInCount rdf:type rdf:Property ;
    rdfs:label 'Opt In Count' ;
    rdfs:comment 'Total number of members who have opted into this promotion. Updated in real-time or batch. Used for campaign performance measurement.' ;
    rdfs:domain ind:LoyaltyPromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:optInRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Opt In Required Flag' ;
    rdfs:comment 'Indicates whether members must explicitly opt-in or register for the promotion (true) or if it is automatically applied to eligible members (false). Used for campaign engagement tracking.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:promotionDescription rdf:type rdf:Property ;
    rdfs:label 'Promotion Description' ;
    rdfs:comment 'Detailed marketing description of the promotion, including terms, conditions, and member benefits. Used for customer communication and internal reference.' ;
    rdfs:domain ind:LoyaltyPromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionName rdf:type rdf:Property ;
    rdfs:label 'Promotion Name' ;
    rdfs:comment 'Human-readable marketing name of the promotion (e.g., \'Summer Double Miles\', \'Elite Status Challenge\'). Identity label for the promotion.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionStatus rdf:type rdf:Property ;
    rdfs:label 'Promotion Status' ;
    rdfs:comment 'Current lifecycle state of the promotion: draft (being designed), scheduled (approved, not yet started), active (currently running), paused (temporarily suspended), completed (ended successfully), cancelled (terminated before completion). Lifecycle status for the promotion.' ;
    rdfs:domain ind:LoyaltyPromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionType rdf:type rdf:Property ;
    rdfs:label 'Promotion Type' ;
    rdfs:comment 'Classification of the promotional campaign mechanism: double_miles (2x earn rate), triple_miles (3x earn rate), tier_challenge (accelerated tier qualification), status_match (match competitor status), bonus_on_route (extra miles on specific routes), partner_bonus (bonus on partner airline or coalition earn), upgrade_bonus (complimentary or discounted upgrades). Classification category for the promotion. [ENUM-REF-CANDIDATE: double_miles|triple_miles|tier_challenge|status_match|bonus_on_route|partner_bonus|upgrade_bonus — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionCount rdf:type rdf:Property ;
    rdfs:label 'Redemption Count' ;
    rdfs:comment 'Total number of transactions or bookings where this promotion was successfully applied and bonus miles were awarded. Used for ROI (Return on Investment) analysis and campaign effectiveness.' ;
    rdfs:domain ind:LoyaltyPromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetSegment rdf:type rdf:Property ;
    rdfs:label 'Target Segment' ;
    rdfs:comment 'Marketing segment or customer cohort targeted by this promotion (e.g., \'Inactive Members\', \'High-Value Flyers\', \'New Enrollees\', \'Corporate Travelers\'). Used for campaign targeting and performance analysis.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdBy rdf:type rdf:Property ;
    rdfs:label 'Created By' ;
    rdfs:comment 'User ID or name of the marketing or loyalty operations staff who created the promotion record. Used for audit trail and accountability.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:memberBenefitId rdf:type rdf:Property ;
    rdfs:label 'Member Benefit Id' ;
    rdfs:comment 'Unique identifier for the member benefit entitlement record. Primary key.' ;
    rdfs:domain ind:MemberBenefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:activationTrigger rdf:type rdf:Property ;
    rdfs:label 'Activation Trigger' ;
    rdfs:comment 'Event or condition that triggered the activation of this benefit entitlement (e.g., tier qualification, manual grant by admin, promotional campaign, lifetime status achievement, status challenge match).' ;
    rdfs:domain ind:MemberBenefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoRenewFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Renew Flag' ;
    rdfs:comment 'Indicates whether the benefit automatically renews upon tier re-qualification or expiration (True) or requires manual re-issuance (False).' ;
    rdfs:domain ind:MemberBenefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:benefitCode rdf:type rdf:Property ;
    rdfs:label 'Benefit Code' ;
    rdfs:comment 'Unique alphanumeric code identifying the benefit type (e.g., LOUNGE_ACCESS, PRIORITY_CHECKIN, EXTRA_BAG).' ;
    rdfs:domain ind:MemberBenefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benefitDescription rdf:type rdf:Property ;
    rdfs:label 'Benefit Description' ;
    rdfs:comment 'Detailed description of the benefit entitlement, including terms, conditions, and usage instructions.' ;
    rdfs:domain ind:MemberBenefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benefitName rdf:type rdf:Property ;
    rdfs:label 'Benefit Name' ;
    rdfs:comment 'Human-readable name of the benefit (e.g., Priority Lounge Access, Extra Baggage Allowance).' ;
    rdfs:domain ind:MemberBenefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benefitQuantity rdf:type rdf:Property ;
    rdfs:label 'Benefit Quantity' ;
    rdfs:comment 'Numeric quantity or limit of the benefit entitlement (e.g., 2 lounge passes, 20kg extra baggage). Null indicates unlimited.' ;
    rdfs:domain ind:MemberBenefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:benefitStatus rdf:type rdf:Property ;
    rdfs:label 'Benefit Status' ;
    rdfs:comment 'Current lifecycle status of the benefit entitlement: active (usable), suspended (temporarily unavailable), expired (validity period ended), revoked (administratively removed), or pending activation.' ;
    rdfs:domain ind:MemberBenefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benefitTerms rdf:type rdf:Property ;
    rdfs:label 'Benefit Terms' ;
    rdfs:comment 'Full text of terms and conditions governing the use of this benefit, including restrictions, blackout dates, and eligibility criteria.' ;
    rdfs:domain ind:MemberBenefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benefitType rdf:type rdf:Property ;
    rdfs:label 'Benefit Type' ;
    rdfs:comment 'Category of benefit entitlement: lounge access, priority check-in, priority boarding, extra baggage allowance, seat upgrade priority, companion ticket, bonus mile multiplier, or dedicated phone support. [ENUM-REF-CANDIDATE: lounge_access|priority_checkin|priority_boarding|extra_baggage|seat_upgrade|companion_ticket|bonus_miles|dedicated_support — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MemberBenefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benefitUnit rdf:type rdf:Property ;
    rdfs:label 'Benefit Unit' ;
    rdfs:comment 'Unit of measurement for the benefit quantity (e.g., passes, kg for baggage, segments, upgrade certificates, multiplier for bonus miles). [ENUM-REF-CANDIDATE: passes|kg|segments|upgrades|multiplier|tickets|hours — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MemberBenefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benefitValidityEndDate rdf:type rdf:Property ;
    rdfs:label 'Benefit Validity End Date' ;
    rdfs:comment 'Date on which the benefit entitlement expires. Null indicates no expiration.' ;
    rdfs:domain ind:MemberBenefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:benefitValidityStartDate rdf:type rdf:Property ;
    rdfs:label 'Benefit Validity Start Date' ;
    rdfs:comment 'Date from which the benefit entitlement becomes active and usable by the member.' ;
    rdfs:domain ind:MemberBenefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:blackoutDates rdf:type rdf:Property ;
    rdfs:label 'Blackout Dates' ;
    rdfs:comment 'Comma-separated list of date ranges or specific dates when the benefit cannot be used (e.g., peak holiday periods). Null if no blackout dates apply.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCurrency rdf:type rdf:Property ;
    rdfs:label 'Cost Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the cost_to_airline amount.' ;
    rdfs:domain ind:MemberBenefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costToAirline rdf:type rdf:Property ;
    rdfs:label 'Cost To Airline' ;
    rdfs:comment 'Estimated cost to the airline for providing this benefit entitlement, used for financial planning and benefit valuation analysis.' ;
    rdfs:domain ind:MemberBenefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryChannel rdf:type rdf:Property ;
    rdfs:label 'Delivery Channel' ;
    rdfs:comment 'Channel through which the benefit is delivered or redeemed (e.g., airport counter, online portal, mobile app, call center, partner location, automatic application).' ;
    rdfs:domain ind:MemberBenefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicRestriction rdf:type rdf:Property ;
    rdfs:label 'Geographic Restriction' ;
    rdfs:comment 'Geographic scope or restriction for benefit usage (e.g., domestic only, international only, specific regions or airport codes). Null if no restriction.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastUsageDate rdf:type rdf:Property ;
    rdfs:label 'Last Usage Date' ;
    rdfs:comment 'Date when the benefit was most recently used or redeemed by the member.' ;
    rdfs:domain ind:MemberBenefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remainingBalance rdf:type rdf:Property ;
    rdfs:label 'Remaining Balance' ;
    rdfs:comment 'Remaining quantity of the benefit available for use (benefit_quantity minus usage_count). Null if unlimited.' ;
    rdfs:domain ind:MemberBenefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tierApplicability rdf:type rdf:Property ;
    rdfs:label 'Tier Applicability' ;
    rdfs:comment 'Comma-separated list of tier codes to which this benefit applies (e.g., GOLD,PLATINUM,DIAMOND).' ;
    rdfs:domain ind:MemberBenefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageCount rdf:type rdf:Property ;
    rdfs:label 'Usage Count' ;
    rdfs:comment 'Number of times this benefit has been used or redeemed by the member during the current validity period.' ;
    rdfs:domain ind:MemberBenefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:usageHistorySummary rdf:type rdf:Property ;
    rdfs:label 'Usage History Summary' ;
    rdfs:comment 'Summary text of benefit usage history, including dates, locations, and transaction references for audit and member inquiry purposes.' ;
    rdfs:domain ind:MemberBenefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mileageAccrualId rdf:type rdf:Property ;
    rdfs:label 'Mileage Accrual Id' ;
    rdfs:comment 'Unique identifier for each mileage accrual transaction in the FFP (Frequent Flyer Program) ledger. Primary key for the mileage accrual record.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MileageAccrual .

ind:fareFamilyId rdf:type rdf:Property ;
    rdfs:label 'Fare Family Id' ;
    rdfs:comment 'Foreign key linking to revenue.fare_family. Business justification: Branded fares have differentiated mileage earn rates (e.g., Basic Economy earns 50%, Premium earns 150%). Accrual calculation requires fare family reference. New attribute for earn rate determination.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FareFamily .

ind:flightRevenuePerformanceId rdf:type rdf:Property ;
    rdfs:label 'Flight Revenue Performance Id' ;
    rdfs:comment 'Foreign key linking to revenue.flight_revenue_performance. Business justification: Aggregate mileage accruals by flight enable revenue-loyalty performance analysis (miles issued vs. revenue generated). Supports yield management and loyalty program cost analysis. New attribute for an' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FlightRevenuePerformance .

ind:ticketCouponId rdf:type rdf:Property ;
    rdfs:label 'Ticket Coupon Id' ;
    rdfs:comment 'Foreign key linking to revenue.ticket_coupon. Business justification: Accruals must reference specific flown coupon for audit trail, dispute resolution, and revenue reconciliation. Core operational link. Replaces denormalized ticket_number with proper FK to ticket_coupo' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TicketCoupon .

ind:accrualDate rdf:type rdf:Property ;
    rdfs:label 'Accrual Date' ;
    rdfs:comment 'Business date when the mileage-earning activity occurred (e.g., flight departure date, partner transaction date, purchase date). This is the real-world event date, distinct from posting date.' ;
    rdfs:domain ind:MileageAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accrualSourceType rdf:type rdf:Property ;
    rdfs:label 'Accrual Source Type' ;
    rdfs:comment 'Category of the mileage earning activity. Distinguishes between flight-based earnings, partner transactions, direct purchases, and manual adjustments. [ENUM-REF-CANDIDATE: flight|partner_airline|credit_card|hotel|car_rental|retail|purchase|adjustment|reinstatement — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MileageAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accrualStatus rdf:type rdf:Property ;
    rdfs:label 'Accrual Status' ;
    rdfs:comment 'Current lifecycle status of the mileage accrual transaction. Pending indicates awaiting validation or posting; posted indicates credited to member account; reversed indicates clawed back due to refund or fraud; expired indicates miles lapsed before use; cancelled indicates transaction voided.' ;
    rdfs:domain ind:MileageAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentNotes rdf:type rdf:Property ;
    rdfs:label 'Adjustment Notes' ;
    rdfs:comment 'Free-text explanation for manual adjustments. Captures customer service agent notes, retro-claim justification, or fraud investigation details. Null for standard accruals.' ;
    rdfs:domain ind:MileageAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalReference rdf:type rdf:Property ;
    rdfs:label 'Approval Reference' ;
    rdfs:comment 'Case number, ticket number, or workflow reference for manual adjustments requiring supervisory approval. Null for standard accruals.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseMiles rdf:type rdf:Property ;
    rdfs:label 'Base Miles' ;
    rdfs:comment 'Core mileage amount earned before any bonuses or multipliers. For flights, typically calculated from actual flown distance or fare class earning rate. For partners, based on transaction value or partner agreement.' ;
    rdfs:domain ind:MileageAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eliteBonusMiles rdf:type rdf:Property ;
    rdfs:label 'Elite Bonus Miles' ;
    rdfs:comment 'Additional miles earned due to member\'s elite tier status (e.g., Gold, Platinum, Diamond). Calculated as a percentage multiplier of base miles based on tier level.' ;
    rdfs:domain ind:MileageAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eliteBonusMultiplier rdf:type rdf:Property ;
    rdfs:label 'Elite Bonus Multiplier' ;
    rdfs:comment 'Percentage multiplier applied to base miles for elite tier members (e.g., 1.25 for 25% bonus, 1.50 for 50% bonus). Zero or 1.00 for non-elite members.' ;
    rdfs:domain ind:MileageAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:milesExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Miles Expiry Date' ;
    rdfs:comment 'Date when the miles earned in this transaction will expire if not used. Null for programs with no expiration policy or lifetime miles.' ;
    rdfs:domain ind:MileageAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:partnerTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Partner Transaction Reference' ;
    rdfs:comment 'External transaction identifier provided by the partner organization for partner-based accruals (e.g., hotel confirmation number, car rental agreement number, credit card transaction ID). Null for own-airline flights and non-partner accruals.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionalBonusMiles rdf:type rdf:Property ;
    rdfs:label 'Promotional Bonus Miles' ;
    rdfs:comment 'Additional miles earned through limited-time promotions, campaigns, or special offers (e.g., double miles promotion, new route bonus, seasonal campaign). Zero if no promotion applies.' ;
    rdfs:domain ind:MileageAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reversalDate rdf:type rdf:Property ;
    rdfs:label 'Reversal Date' ;
    rdfs:comment 'Date when the miles were reversed or clawed back from the member account. Null unless accrual_status is reversed.' ;
    rdfs:domain ind:MileageAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reversalReason rdf:type rdf:Property ;
    rdfs:label 'Reversal Reason' ;
    rdfs:comment 'Explanation for why miles were reversed after initial posting (e.g., ticket refund, fraudulent activity detected, duplicate posting, partner transaction cancelled). Null unless accrual_status is reversed.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalMilesCredited rdf:type rdf:Property ;
    rdfs:label 'Total Miles Credited' ;
    rdfs:comment 'Sum of base miles, elite bonus miles, and promotional bonus miles. This is the net amount credited to the member\'s account for this transaction.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionAmount rdf:type rdf:Property ;
    rdfs:label 'Transaction Amount' ;
    rdfs:comment 'Monetary value of the partner transaction in the transaction currency for spend-based accruals (e.g., credit card purchase amount, hotel bill total). Null for distance-based flight accruals.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Transaction Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for partner transactions where miles are earned based on spend amount (e.g., credit card purchases, hotel stays). Null for distance-based flight accruals.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awardBookingReference rdf:type rdf:Property ;
    rdfs:label 'Award Booking Reference' ;
    rdfs:comment 'Passenger Name Record (PNR) or booking reference for award flight redemptions. Null for non-flight redemptions.' ;
    rdfs:domain ind:MileageRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milesDiscountApplied rdf:type rdf:Property ;
    rdfs:label 'Miles Discount Applied' ;
    rdfs:comment 'Number of miles discounted due to promotional campaign or elite status benefit. Zero if no discount applied.' ;
    rdfs:domain ind:MileageRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:processingFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Processing Fee Amount' ;
    rdfs:comment 'Fee charged by the airline or partner for processing the redemption transaction (e.g., award booking fee, transfer fee).' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processingFeeCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Processing Fee Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the processing fee.' ;
    rdfs:domain ind:MileageRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionChannel rdf:type rdf:Property ;
    rdfs:label 'Redemption Channel' ;
    rdfs:comment 'Channel through which the member initiated the redemption: airline website, mobile app, call center, airport counter, partner portal, or self-service kiosk.' ;
    rdfs:domain ind:MileageRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionNotes rdf:type rdf:Property ;
    rdfs:label 'Redemption Notes' ;
    rdfs:comment 'Free-text notes or comments about the redemption transaction, captured by agent or system for audit and customer service purposes.' ;
    rdfs:domain ind:MileageRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionStatus rdf:type rdf:Property ;
    rdfs:label 'Redemption Status' ;
    rdfs:comment 'Current lifecycle status of the redemption transaction: requested (pending), confirmed (approved), ticketed (award ticket issued), cancelled (member cancelled), refunded (miles returned), or expired (award not used).' ;
    rdfs:domain ind:MileageRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Redemption Timestamp' ;
    rdfs:comment 'Date and time when the redemption transaction was initiated by the member or agent.' ;
    rdfs:domain ind:MileageRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:redemptionTransactionNumber rdf:type rdf:Property ;
    rdfs:label 'Redemption Transaction Number' ;
    rdfs:comment 'Externally-visible unique transaction number for the redemption event, used for customer service and reconciliation.' ;
    rdfs:domain ind:MileageRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionType rdf:type rdf:Property ;
    rdfs:label 'Redemption Type' ;
    rdfs:comment 'Category of redemption: award flight booking, cabin upgrade, partner airline/hotel reward, merchandise purchase, charity donation, peer-to-peer miles transfer, miles purchase with cash co-pay, or co-pay booking combining miles and cash. [ENUM-REF-CANDIDATE: award_flight|upgrade|partner_reward|merchandise|charity_donation|miles_transfer|purchase_miles|co_pay_booking — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MileageRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundMiles rdf:type rdf:Property ;
    rdfs:label 'Refund Miles' ;
    rdfs:comment 'Number of miles returned to the member account upon cancellation or refund of the redemption. Zero if no refund occurred.' ;
    rdfs:domain ind:MileageRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transferFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Transfer Fee Amount' ;
    rdfs:comment 'Fee charged for transferring miles to another member. Null for non-transfer redemptions.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transferFeeCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Transfer Fee Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the transfer fee.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferRecipientFfpNumber rdf:type rdf:Property ;
    rdfs:label 'Transfer Recipient Ffp Number' ;
    rdfs:comment 'FFP membership number of the recipient member for peer-to-peer miles transfers or family pooling. Null for non-transfer redemptions.' ;
    rdfs:domain ind:MileageRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferType rdf:type rdf:Property ;
    rdfs:label 'Transfer Type' ;
    rdfs:comment 'Type of miles transfer: gift (peer-to-peer gifting), family_pool (pooling within family account), purchase (buying miles for another member), or none (not a transfer redemption).' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milesAdjustmentId rdf:type rdf:Property ;
    rdfs:label 'Miles Adjustment Id' ;
    rdfs:comment 'Unique identifier for the miles adjustment transaction. Primary key for the miles adjustment record.' ;
    rdfs:domain ind:MilesAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalAdjustmentMilesAdjustmentId rdf:type rdf:Property ;
    rdfs:label 'Original Adjustment Miles Adjustment Id' ;
    rdfs:comment 'Reference to the original miles adjustment record that is being reversed by this transaction.' ;
    rdfs:domain ind:MilesAdjustment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MilesAdjustment .

ind:adjustmentChannel rdf:type rdf:Property ;
    rdfs:label 'Adjustment Channel' ;
    rdfs:comment 'Channel or interface through which the adjustment request was initiated or processed. [ENUM-REF-CANDIDATE: call_center|web_portal|mobile_app|email_request|social_media|airport_counter|system_batch — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MilesAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Adjustment Timestamp' ;
    rdfs:comment 'Date and time when the miles adjustment was processed and applied to the member balance.' ;
    rdfs:domain ind:MilesAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:adjustmentTransactionNumber rdf:type rdf:Property ;
    rdfs:label 'Adjustment Transaction Number' ;
    rdfs:comment 'Externally-visible unique transaction number for the miles adjustment, used for customer service reference and audit trail.' ;
    rdfs:domain ind:MilesAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalLevel rdf:type rdf:Property ;
    rdfs:label 'Approval Level' ;
    rdfs:comment 'Organizational level of authority that approved the adjustment, indicating the escalation tier required based on adjustment amount or type.' ;
    rdfs:domain ind:MilesAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Flag' ;
    rdfs:comment 'Indicates whether this adjustment was flagged for compliance review due to unusual amount, pattern, or regulatory concern.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:financialImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Amount' ;
    rdfs:comment 'Estimated monetary value or liability impact of the miles adjustment, calculated based on the airline internal valuation of miles.' ;
    rdfs:domain ind:MilesAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financialImpactCurrency rdf:type rdf:Property ;
    rdfs:label 'Financial Impact Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the financial impact amount.' ;
    rdfs:domain ind:MilesAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudReviewFlag rdf:type rdf:Property ;
    rdfs:label 'Fraud Review Flag' ;
    rdfs:comment 'Indicates whether this adjustment was flagged for fraud investigation due to suspicious activity or pattern detection.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:memberNotificationFlag rdf:type rdf:Property ;
    rdfs:label 'Member Notification Flag' ;
    rdfs:comment 'Indicates whether the FFP member was notified of this miles adjustment via email, SMS, or account alert.' ;
    rdfs:domain ind:MilesAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:milesAmount rdf:type rdf:Property ;
    rdfs:label 'Miles Amount' ;
    rdfs:comment 'Quantity of miles being adjusted. Positive values represent credits to the member account; negative values represent debits or reversals.' ;
    rdfs:domain ind:MilesAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:processingPriority rdf:type rdf:Property ;
    rdfs:label 'Processing Priority' ;
    rdfs:comment 'Priority level assigned to the adjustment request, often influenced by member tier status or issue severity.' ;
    rdfs:domain ind:MilesAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalFlag rdf:type rdf:Property ;
    rdfs:label 'Reversal Flag' ;
    rdfs:comment 'Indicates whether this adjustment is a reversal of a previous adjustment transaction.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Source Transaction Reference' ;
    rdfs:comment 'Reference to the original transaction that is being corrected or adjusted, such as a flight booking reference, partner transaction ID, or redemption number.' ;
    rdfs:domain ind:MilesAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceTransactionType rdf:type rdf:Property ;
    rdfs:label 'Source Transaction Type' ;
    rdfs:comment 'Type of original transaction that triggered the need for this adjustment, providing context for the correction.' ;
    rdfs:domain ind:MilesAdjustment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milesBalanceId rdf:type rdf:Property ;
    rdfs:label 'Miles Balance Id' ;
    rdfs:comment 'Unique identifier for the miles balance ledger record. Primary key for the miles balance entity.' ;
    rdfs:domain ind:MilesBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountInceptionDate rdf:type rdf:Property ;
    rdfs:label 'Account Inception Date' ;
    rdfs:comment 'Date when the member first enrolled in the FFP and the miles balance account was created. Used for member tenure analysis and lifetime value calculation.' ;
    rdfs:domain ind:MilesBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:balanceAsOfTimestamp rdf:type rdf:Property ;
    rdfs:label 'Balance As Of Timestamp' ;
    rdfs:comment 'Timestamp indicating when this balance snapshot was calculated. Critical for point-in-time balance queries and historical balance reconstruction.' ;
    rdfs:domain ind:MilesBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:balanceCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Balance Calculation Method' ;
    rdfs:comment 'Method used to calculate this balance snapshot. Real-time balances are updated transactionally; batch balances are calculated in nightly runs; reconciled balances include manual adjustments.' ;
    rdfs:domain ind:MilesBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:balanceLastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Balance Last Updated Timestamp' ;
    rdfs:comment 'Timestamp when this balance record was last modified by any transaction or adjustment. Used for data freshness validation and audit trail.' ;
    rdfs:domain ind:MilesBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:balanceStatus rdf:type rdf:Property ;
    rdfs:label 'Balance Status' ;
    rdfs:comment 'Current lifecycle status of the miles balance account. Active accounts allow accrual and redemption; suspended accounts are temporarily restricted; frozen accounts are under investigation; closed accounts are terminated.' ;
    rdfs:domain ind:MilesBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:balanceVersionNumber rdf:type rdf:Property ;
    rdfs:label 'Balance Version Number' ;
    rdfs:comment 'Version number of this balance record, incremented with each update. Used for optimistic locking and concurrency control in real-time balance updates.' ;
    rdfs:domain ind:MilesBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bonusMilesBalance rdf:type rdf:Property ;
    rdfs:label 'Bonus Miles Balance' ;
    rdfs:comment 'Subset of total miles balance earned through promotional campaigns, partner bonuses, or special offers. Tracked separately for marketing attribution analysis.' ;
    rdfs:domain ind:MilesBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eliteBonusMilesYtd rdf:type rdf:Property ;
    rdfs:label 'Elite Bonus Miles Ytd' ;
    rdfs:comment 'Additional miles earned year-to-date as elite tier status bonuses (e.g., 25%, 50%, 100% bonus on base miles). Separate from base miles for tier benefit tracking.' ;
    rdfs:domain ind:MilesBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isLifetimeStatusQualified rdf:type rdf:Property ;
    rdfs:label 'Is Lifetime Status Qualified' ;
    rdfs:comment 'Boolean flag indicating whether the member has achieved lifetime elite status qualification based on lifetime miles earned or lifetime qualifying criteria. True if qualified, False otherwise.' ;
    rdfs:domain ind:MilesBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastAccrualDate rdf:type rdf:Property ;
    rdfs:label 'Last Accrual Date' ;
    rdfs:comment 'Date of the most recent miles accrual transaction posted to this account. Used for account activity monitoring and dormancy detection.' ;
    rdfs:domain ind:MilesBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastRedemptionDate rdf:type rdf:Property ;
    rdfs:label 'Last Redemption Date' ;
    rdfs:comment 'Date of the most recent miles redemption transaction posted to this account. Used for member engagement analysis and redemption pattern tracking.' ;
    rdfs:domain ind:MilesBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastTransactionDate rdf:type rdf:Property ;
    rdfs:label 'Last Transaction Date' ;
    rdfs:comment 'Date of the most recent transaction (accrual or redemption) posted to this account. Used for account activity monitoring and expiration policy enforcement.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lifetimeMilesRedeemed rdf:type rdf:Property ;
    rdfs:label 'Lifetime Miles Redeemed' ;
    rdfs:comment 'Cumulative total of all miles redeemed by the member since program enrollment. Used for member engagement analytics and redemption behavior analysis.' ;
    rdfs:domain ind:MilesBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:memberNumber rdf:type rdf:Property ;
    rdfs:label 'Member Number' ;
    rdfs:comment 'The externally-known FFP membership number assigned to the member. Used for member identification across all touchpoints.' ;
    rdfs:domain ind:MilesBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milesExpiring180Days rdf:type rdf:Property ;
    rdfs:label 'Miles Expiring 180 Days' ;
    rdfs:comment 'Total miles scheduled to expire within the next 180 days based on program expiration policy. Used for proactive member engagement and redemption encouragement.' ;
    rdfs:domain ind:MilesBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:milesExpiring90Days rdf:type rdf:Property ;
    rdfs:label 'Miles Expiring 90 Days' ;
    rdfs:comment 'Total miles scheduled to expire within the next 90 days based on program expiration policy. Used for member communication and retention campaigns.' ;
    rdfs:domain ind:MilesBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Next Expiration Date' ;
    rdfs:comment 'Date when the next batch of miles is scheduled to expire based on program expiration policy. Used for member notification and retention campaigns.' ;
    rdfs:domain ind:MilesBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:onHoldMiles rdf:type rdf:Property ;
    rdfs:label 'On Hold Miles' ;
    rdfs:comment 'Miles temporarily held and unavailable for redemption due to fraud investigation, dispute resolution, or account review. Released once issue is resolved.' ;
    rdfs:domain ind:MilesBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:partnerMilesBalance rdf:type rdf:Property ;
    rdfs:label 'Partner Miles Balance' ;
    rdfs:comment 'Subset of total miles balance earned through partner airline flights, hotel stays, car rentals, credit card spend, or coalition program activities. Tracked for partner settlement.' ;
    rdfs:domain ind:MilesBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pendingMiles rdf:type rdf:Property ;
    rdfs:label 'Pending Miles' ;
    rdfs:comment 'Miles that have been earned but not yet posted to the redeemable balance. Typically includes miles from recent flights or partner transactions awaiting verification.' ;
    rdfs:domain ind:MilesBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualificationYearEndDate rdf:type rdf:Property ;
    rdfs:label 'Qualification Year End Date' ;
    rdfs:comment 'End date of the current qualification year for elite tier status. QM, QS, and QSP counters reset after this date.' ;
    rdfs:domain ind:MilesBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualificationYearStartDate rdf:type rdf:Property ;
    rdfs:label 'Qualification Year Start Date' ;
    rdfs:comment 'Start date of the current qualification year for elite tier status. Typically calendar year or membership anniversary date depending on program rules.' ;
    rdfs:domain ind:MilesBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualifyingMilesYtd rdf:type rdf:Property ;
    rdfs:label 'Qualifying Miles Ytd' ;
    rdfs:comment 'Total qualifying miles earned year-to-date that count toward elite tier status qualification. QM are typically based on distance flown and fare class, excluding bonus miles.' ;
    rdfs:domain ind:MilesBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualifyingSegmentsYtd rdf:type rdf:Property ;
    rdfs:label 'Qualifying Segments Ytd' ;
    rdfs:comment 'Total number of qualifying flight segments flown year-to-date that count toward elite tier status qualification. Each eligible flight leg counts as one segment.' ;
    rdfs:domain ind:MilesBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualifyingSpendCurrency rdf:type rdf:Property ;
    rdfs:label 'Qualifying Spend Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the qualifying spend amount. Typically the program base currency (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualifyingSpendYtd rdf:type rdf:Property ;
    rdfs:label 'Qualifying Spend Ytd' ;
    rdfs:comment 'Total qualifying spend amount year-to-date that counts toward elite tier status qualification. Typically based on ticket price paid, excluding taxes and fees.' ;
    rdfs:domain ind:MilesBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:redeemableMiles rdf:type rdf:Property ;
    rdfs:label 'Redeemable Miles' ;
    rdfs:comment 'Subset of total miles balance that is currently available for redemption. Excludes miles that are pending, on hold, or not yet eligible for use.' ;
    rdfs:domain ind:MilesBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalMilesBalance rdf:type rdf:Property ;
    rdfs:label 'Total Miles Balance' ;
    rdfs:comment 'Total accumulated miles currently available in the member account, including all earned miles minus all redeemed miles. This is the authoritative running balance.' ;
    rdfs:domain ind:MilesBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:milesPurchaseId rdf:type rdf:Property ;
    rdfs:label 'Miles Purchase Id' ;
    rdfs:comment 'Unique identifier for the miles purchase transaction. Primary key.' ;
    rdfs:domain ind:MilesPurchase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bonusMilesQuantity rdf:type rdf:Property ;
    rdfs:label 'Bonus Miles Quantity' ;
    rdfs:comment 'Number of promotional bonus miles awarded with this purchase, if applicable.' ;
    rdfs:domain ind:MilesPurchase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deviceType rdf:type rdf:Property ;
    rdfs:label 'Device Type' ;
    rdfs:comment 'Type of device used to initiate the purchase.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalTransactionCode rdf:type rdf:Property ;
    rdfs:label 'External Transaction Code' ;
    rdfs:comment 'Transaction identifier from the external payment gateway or partner system.' ;
    rdfs:domain ind:MilesPurchase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Fraud Check Status' ;
    rdfs:comment 'Result of fraud detection screening for this transaction.' ;
    rdfs:domain ind:MilesPurchase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudScore rdf:type rdf:Property ;
    rdfs:label 'Fraud Score' ;
    rdfs:comment 'Numerical fraud risk score assigned by the fraud detection system.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ipAddress rdf:type rdf:Property ;
    rdfs:label 'Ip Address' ;
    rdfs:comment 'IP address from which the purchase was initiated, used for fraud detection and security.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milesExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Miles Expiration Date' ;
    rdfs:comment 'Date when the purchased miles will expire if not redeemed.' ;
    rdfs:domain ind:MilesPurchase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:milesQuantity rdf:type rdf:Property ;
    rdfs:label 'Miles Quantity' ;
    rdfs:comment 'Number of base miles purchased by the member in this transaction.' ;
    rdfs:domain ind:MilesPurchase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paymentAuthorizationCode rdf:type rdf:Property ;
    rdfs:label 'Payment Authorization Code' ;
    rdfs:comment 'Authorization code returned by the payment processor confirming the transaction.' ;
    rdfs:domain ind:MilesPurchase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricePerMile rdf:type rdf:Property ;
    rdfs:label 'Price Per Mile' ;
    rdfs:comment 'Unit price charged per mile in the purchase currency.' ;
    rdfs:domain ind:MilesPurchase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:purchaseChannel rdf:type rdf:Property ;
    rdfs:label 'Purchase Channel' ;
    rdfs:comment 'Channel through which the member initiated the miles purchase (e.g., web, mobile app, call center).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseStatus rdf:type rdf:Property ;
    rdfs:label 'Purchase Status' ;
    rdfs:comment 'Current lifecycle status of the miles purchase transaction.' ;
    rdfs:domain ind:MilesPurchase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purchaseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Purchase Timestamp' ;
    rdfs:comment 'Date and time when the member initiated the miles purchase transaction.' ;
    rdfs:domain ind:MilesPurchase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:refundFlag rdf:type rdf:Property ;
    rdfs:label 'Refund Flag' ;
    rdfs:comment 'Indicates whether this purchase has been refunded.' ;
    rdfs:domain ind:MilesPurchase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalAmountCharged rdf:type rdf:Property ;
    rdfs:label 'Total Amount Charged' ;
    rdfs:comment 'Total amount charged to the customer, including base amount, taxes, and fees.' ;
    rdfs:domain ind:MilesPurchase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:milesTransferId rdf:type rdf:Property ;
    rdfs:label 'Miles Transfer Id' ;
    rdfs:comment 'Unique identifier for the peer-to-peer miles transfer transaction. Primary key.' ;
    rdfs:domain ind:MilesTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryMilesSenderFfpMemberId rdf:type rdf:Property ;
    rdfs:label 'Primary Miles Sender Ffp Member Id' ;
    rdfs:comment 'FFP member identifier of the member sending/gifting miles. References the member initiating the transfer.' ;
    rdfs:domain ind:MilesTransfer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FfpMember .

ind:bonusMilesAwarded rdf:type rdf:Property ;
    rdfs:label 'Bonus Miles Awarded' ;
    rdfs:comment 'Additional bonus miles awarded to sender or recipient as part of a transfer promotion. Zero if no bonus awarded.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:feeDiscountApplied rdf:type rdf:Property ;
    rdfs:label 'Fee Discount Applied' ;
    rdfs:comment 'Monetary discount amount applied to the standard transfer fee due to promotion, tier status, or relationship type. Zero if no discount applied.' ;
    rdfs:domain ind:MilesTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fraudRiskScore rdf:type rdf:Property ;
    rdfs:label 'Fraud Risk Score' ;
    rdfs:comment 'Automated fraud detection risk score assigned to this transfer at time of initiation (0.00 = no risk, 100.00 = high risk). Used to flag suspicious transfers for review.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:milesTransferred rdf:type rdf:Property ;
    rdfs:label 'Miles Transferred' ;
    rdfs:comment 'Quantity of loyalty miles transferred from sender to recipient in this transaction. Must be positive integer value.' ;
    rdfs:domain ind:MilesTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recipientAnnualReceiptConsumed rdf:type rdf:Property ;
    rdfs:label 'Recipient Annual Receipt Consumed' ;
    rdfs:comment 'Cumulative miles the recipient has received in the current calendar year after this transaction completes. Used to enforce annual receipt limits.' ;
    rdfs:domain ind:MilesTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recipientAnnualReceiptLimit rdf:type rdf:Property ;
    rdfs:label 'Recipient Annual Receipt Limit' ;
    rdfs:comment 'Maximum miles the recipient is allowed to receive per calendar year according to FFP program rules. Captured at time of transfer for audit purposes.' ;
    rdfs:domain ind:MilesTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:relationshipType rdf:type rdf:Property ;
    rdfs:label 'Relationship Type' ;
    rdfs:comment 'Declared relationship between sender and recipient. Some FFP programs offer preferential transfer terms for family members. Self-declared by sender at time of transfer. [ENUM-REF-CANDIDATE: family|friend|spouse|partner|child|parent|sibling|unrelated — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Relationship Verified Flag' ;
    rdfs:comment 'Indicates whether the declared relationship between sender and recipient has been verified by the airline (e.g., through documentation submission). True if verified, False if unverified or not required.' ;
    rdfs:domain ind:MilesTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reversalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reversal Timestamp' ;
    rdfs:comment 'Date and time when the transfer was reversed and miles returned to sender. Null if not reversed.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:senderAnnualTransferConsumed rdf:type rdf:Property ;
    rdfs:label 'Sender Annual Transfer Consumed' ;
    rdfs:comment 'Cumulative miles the sender has transferred in the current calendar year after this transaction completes. Used to enforce annual transfer limits.' ;
    rdfs:domain ind:MilesTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:senderAnnualTransferLimit rdf:type rdf:Property ;
    rdfs:label 'Sender Annual Transfer Limit' ;
    rdfs:comment 'Maximum miles the sender is allowed to transfer per calendar year according to FFP program rules and sender tier status. Captured at time of transfer for audit purposes.' ;
    rdfs:domain ind:MilesTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transferChannel rdf:type rdf:Property ;
    rdfs:label 'Transfer Channel' ;
    rdfs:comment 'Digital or physical channel through which the transfer was initiated: web (airline website), mobile_app, call_center (agent-assisted), partner_portal (coalition partner interface), kiosk (airport self-service).' ;
    rdfs:domain ind:MilesTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferNotes rdf:type rdf:Property ;
    rdfs:label 'Transfer Notes' ;
    rdfs:comment 'Free-text notes or comments about the transfer, entered by sender (e.g., gift message) or operations agent (e.g., special handling instructions). Null if no notes.' ;
    rdfs:domain ind:MilesTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferStatus rdf:type rdf:Property ;
    rdfs:label 'Transfer Status' ;
    rdfs:comment 'Current lifecycle status of the miles transfer: pending (awaiting approval), approved (authorized but not yet posted), completed (miles successfully transferred), rejected (transfer denied), cancelled (sender cancelled before completion), reversed (transfer reversed after completion due to fraud or error).' ;
    rdfs:domain ind:MilesTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transfer Timestamp' ;
    rdfs:comment 'Date and time when the miles transfer was initiated by the sender. Represents the business event time of the transfer request.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:transferTransactionNumber rdf:type rdf:Property ;
    rdfs:label 'Transfer Transaction Number' ;
    rdfs:comment 'Externally visible unique transaction reference number for the miles transfer, used for customer service inquiries and audit trails.' ;
    rdfs:domain ind:MilesTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accrualDelayDays rdf:type rdf:Property ;
    rdfs:label 'Accrual Delay Days' ;
    rdfs:comment 'Number of days after a qualifying partner transaction before earned miles are posted to the member account. Allows for transaction validation and fraud prevention.' ;
    rdfs:domain ind:PartnerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:autoEnrollmentFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Enrollment Flag' ;
    rdfs:comment 'Indicates whether Airlines FFP members are automatically enrolled in the partner loyalty program for seamless earn/burn. True if auto-enrollment is enabled.' ;
    rdfs:domain ind:PartnerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bonusMileEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Bonus Mile Eligibility Flag' ;
    rdfs:comment 'Indicates whether transactions with this partner are eligible for promotional bonus mile campaigns and tier multipliers. True if eligible.' ;
    rdfs:domain ind:PartnerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:burnRate rdf:type rdf:Property ;
    rdfs:label 'Burn Rate' ;
    rdfs:comment 'Redemption rate for using FFP miles with this partner, expressed as miles required per reward unit (e.g., miles per free night, miles per rental day, miles per dollar value).' ;
    rdfs:domain ind:PartnerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:burnUnit rdf:type rdf:Property ;
    rdfs:label 'Burn Unit' ;
    rdfs:comment 'Unit of measure for the burn rate calculation (e.g., per hotel night redeemed, per car rental day, per dollar value of merchandise). [ENUM-REF-CANDIDATE: night|day|dollar|euro|pound|item|service — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PartnerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:earnRate rdf:type rdf:Property ;
    rdfs:label 'Earn Rate' ;
    rdfs:comment 'Base mileage accrual rate for member transactions with this partner, expressed as miles earned per unit (dollar, euro, night, rental day, etc.). Subject to tier multipliers and promotions.' ;
    rdfs:domain ind:PartnerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:earnUnit rdf:type rdf:Property ;
    rdfs:label 'Earn Unit' ;
    rdfs:comment 'Unit of measure for the earn rate calculation (e.g., per dollar spent, per hotel night, per car rental day). [ENUM-REF-CANDIDATE: dollar|euro|pound|night|day|transaction|point — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PartnerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumEarnPerTransaction rdf:type rdf:Property ;
    rdfs:label 'Maximum Earn Per Transaction' ;
    rdfs:comment 'Maximum number of miles that can be earned in a single transaction with this partner. Null if no cap applies. Prevents abuse and controls liability.' ;
    rdfs:domain ind:PartnerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumTransactionAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Transaction Amount' ;
    rdfs:comment 'Minimum transaction value (in settlement currency) required for a partner transaction to qualify for mileage accrual. Null if no minimum applies.' ;
    rdfs:domain ind:PartnerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partnerContactEmail rdf:type rdf:Property ;
    rdfs:label 'Partner Contact Email' ;
    rdfs:comment 'Primary email address for the partner business contact. Used for operational communications, settlement queries, and program updates.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerContactName rdf:type rdf:Property ;
    rdfs:label 'Partner Contact Name' ;
    rdfs:comment 'Full name of the primary business contact at the partner organization responsible for FFP program coordination and issue resolution.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerContactPhone rdf:type rdf:Property ;
    rdfs:label 'Partner Contact Phone' ;
    rdfs:comment 'Primary telephone number for the partner business contact, including country code and extension where applicable.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerCountryCode rdf:type rdf:Property ;
    rdfs:label 'Partner Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code for the partners primary country of operation or headquarters location.' ;
    rdfs:domain ind:PartnerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerIataCode rdf:type rdf:Property ;
    rdfs:label 'Partner Iata Code' ;
    rdfs:comment 'Two-character IATA airline designator code for airline codeshare partners. Null for non-airline partners.' ;
    rdfs:domain ind:PartnerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerIcaoCode rdf:type rdf:Property ;
    rdfs:label 'Partner Icao Code' ;
    rdfs:comment 'Three-character ICAO airline designator code for airline codeshare partners. Null for non-airline partners.' ;
    rdfs:domain ind:PartnerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerName rdf:type rdf:Property ;
    rdfs:label 'Partner Name' ;
    rdfs:comment 'Legal or trading name of the FFP earn/burn partner organization (e.g., Marriott Hotels, Hertz Car Rental, Chase Bank).' ;
    rdfs:domain ind:PartnerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerTaxNumber rdf:type rdf:Property ;
    rdfs:label 'Partner Tax Number' ;
    rdfs:comment 'Tax identification number or business registration number for the partner organization. Used for financial settlement and regulatory compliance.' ;
    rdfs:domain ind:PartnerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerType rdf:type rdf:Property ;
    rdfs:label 'Partner Type' ;
    rdfs:comment 'Classification of the partner organization by business category. Determines applicable earn/burn rules and integration requirements. [ENUM-REF-CANDIDATE: airline_codeshare|hotel|car_rental|credit_card|retail|telecom|dining|travel_services — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerWebsiteUrl rdf:type rdf:Property ;
    rdfs:label 'Partner Website Url' ;
    rdfs:comment 'Primary website URL for the partner organization. Used for member communications and marketing materials promoting partner earn/burn opportunities.' ;
    rdfs:domain ind:PartnerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionBlackoutFlag rdf:type rdf:Property ;
    rdfs:label 'Redemption Blackout Flag' ;
    rdfs:comment 'Indicates whether this partner imposes blackout dates or capacity restrictions on award redemptions. True if blackouts apply.' ;
    rdfs:domain ind:PartnerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tierRecognitionFlag rdf:type rdf:Property ;
    rdfs:label 'Tier Recognition Flag' ;
    rdfs:comment 'Indicates whether the partner honors Airlines FFP elite tier status with reciprocal benefits (e.g., priority service, upgrades, bonus earn). True if tier benefits apply.' ;
    rdfs:domain ind:PartnerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:partnerSettlementId rdf:type rdf:Property ;
    rdfs:label 'Partner Settlement Id' ;
    rdfs:comment 'Unique identifier for the partner settlement transaction record. Primary key for the partner settlement entity.' ;
    rdfs:domain ind:PartnerSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adjustmentAmount rdf:type rdf:Property ;
    rdfs:label 'Adjustment Amount' ;
    rdfs:comment 'Any manual adjustments applied to the settlement, including corrections, credits, or penalties agreed between the airline and partner.' ;
    rdfs:domain ind:PartnerSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Invoice Reference Number' ;
    rdfs:comment 'Reference number of the invoice generated for this settlement. Links the settlement to the accounts receivable or payable invoice in the finance system.' ;
    rdfs:domain ind:PartnerSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milesRedeemedAmount rdf:type rdf:Property ;
    rdfs:label 'Miles Redeemed Amount' ;
    rdfs:comment 'Total monetary value of miles redeemed via the partner during the settlement period, calculated using the agreed burn rate.' ;
    rdfs:domain ind:PartnerSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:milesRedeemedViaPartner rdf:type rdf:Property ;
    rdfs:label 'Miles Redeemed Via Partner' ;
    rdfs:comment 'Total number of FFP miles redeemed through the partner during the settlement period. Represents burn transactions where members used miles for partner services.' ;
    rdfs:domain ind:PartnerSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:milesSoldAmount rdf:type rdf:Property ;
    rdfs:label 'Miles Sold Amount' ;
    rdfs:comment 'Total monetary value of miles sold to the partner during the settlement period, calculated using the agreed earn rate.' ;
    rdfs:domain ind:PartnerSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:milesSoldToPartner rdf:type rdf:Property ;
    rdfs:label 'Miles Sold To Partner' ;
    rdfs:comment 'Total number of FFP miles sold to the partner during the settlement period. Represents earn transactions where the partner purchased miles for their customers.' ;
    rdfs:domain ind:PartnerSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:netMilesPosition rdf:type rdf:Property ;
    rdfs:label 'Net Miles Position' ;
    rdfs:comment 'Net miles position for the settlement period, calculated as miles sold minus miles redeemed. Positive indicates partner owes airline; negative indicates airline owes partner.' ;
    rdfs:domain ind:PartnerSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:partnerStatementReference rdf:type rdf:Property ;
    rdfs:label 'Partner Statement Reference' ;
    rdfs:comment 'Reference number from the partners settlement statement or report, used for cross-referencing during reconciliation.' ;
    rdfs:domain ind:PartnerSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Payment Received Date' ;
    rdfs:comment 'Actual date when payment was received from the partner or paid to the partner. Null if payment has not yet been completed.' ;
    rdfs:domain ind:PartnerSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:settlementNotes rdf:type rdf:Property ;
    rdfs:label 'Settlement Notes' ;
    rdfs:comment 'Free-text notes regarding the settlement, including special circumstances, dispute details, or communication with the partner.' ;
    rdfs:domain ind:PartnerSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Settlement Period End Date' ;
    rdfs:comment 'The last date of the period covered by this settlement transaction. Defines the end of the accrual and redemption window being reconciled.' ;
    rdfs:domain ind:PartnerSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:settlementPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Settlement Period Start Date' ;
    rdfs:comment 'The first date of the period covered by this settlement transaction. Defines the beginning of the accrual and redemption window being reconciled.' ;
    rdfs:domain ind:PartnerSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:settlementReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Settlement Reference Number' ;
    rdfs:comment 'Externally-known unique business identifier for this settlement transaction, used for partner communication and reconciliation.' ;
    rdfs:domain ind:PartnerSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionCountRedeemed rdf:type rdf:Property ;
    rdfs:label 'Transaction Count Redeemed' ;
    rdfs:comment 'Number of individual burn transactions included in the miles redeemed via partner total. Used for reconciliation and audit purposes.' ;
    rdfs:domain ind:PartnerSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transactionCountSold rdf:type rdf:Property ;
    rdfs:label 'Transaction Count Sold' ;
    rdfs:comment 'Number of individual earn transactions included in the miles sold to partner total. Used for reconciliation and audit purposes.' ;
    rdfs:domain ind:PartnerSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:varianceAmount rdf:type rdf:Property ;
    rdfs:label 'Variance Amount' ;
    rdfs:comment 'Monetary variance identified during reconciliation between airline and partner records. Null if no variance exists.' ;
    rdfs:domain ind:PartnerSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceReason rdf:type rdf:Property ;
    rdfs:label 'Variance Reason' ;
    rdfs:comment 'Explanation of any variance identified during reconciliation, including root cause and resolution plan.' ;
    rdfs:domain ind:PartnerSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerTransactionId rdf:type rdf:Property ;
    rdfs:label 'Partner Transaction Id' ;
    rdfs:comment 'Unique identifier for the partner transaction record. Primary key.' ;
    rdfs:domain ind:PartnerTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalTransactionPartnerTransactionId rdf:type rdf:Property ;
    rdfs:label 'Original Transaction Partner Transaction Id' ;
    rdfs:comment 'Reference to the original partner transaction ID if this record is a reversal or adjustment of a prior transaction.' ;
    rdfs:domain ind:PartnerTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PartnerTransaction .

ind:baseMilesAwarded rdf:type rdf:Property ;
    rdfs:label 'Base Miles Awarded' ;
    rdfs:comment 'Number of base FFP miles earned or redeemed through this partner transaction, calculated per the partner agreement earn/burn rate.' ;
    rdfs:domain ind:PartnerTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:disputeFlag rdf:type rdf:Property ;
    rdfs:label 'Dispute Flag' ;
    rdfs:comment 'Indicates whether this partner transaction is under dispute by the member or partner (true if disputed, false otherwise).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disputeReason rdf:type rdf:Property ;
    rdfs:label 'Dispute Reason' ;
    rdfs:comment 'Description of the reason for dispute if the transaction is flagged for dispute (e.g., miles not posted, incorrect amount, transaction not recognized).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Date' ;
    rdfs:comment 'Date when the dispute was resolved, if applicable.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:earnRateMultiplier rdf:type rdf:Property ;
    rdfs:label 'Earn Rate Multiplier' ;
    rdfs:comment 'Multiplier applied to calculate miles earned per unit of partner transaction amount, as defined in the partner agreement (e.g., 1.5 miles per dollar spent).' ;
    rdfs:domain ind:PartnerTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:memberTierAtTransaction rdf:type rdf:Property ;
    rdfs:label 'Member Tier At Transaction' ;
    rdfs:comment 'FFP tier status of the member at the time of the partner transaction (e.g., Silver, Gold, Platinum), which may affect bonus miles calculation.' ;
    rdfs:domain ind:PartnerTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerCategory rdf:type rdf:Property ;
    rdfs:label 'Partner Category' ;
    rdfs:comment 'Category of partner business type (hotel, car rental, credit card issuer, retail merchant, dining, travel services).' ;
    rdfs:domain ind:PartnerTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerLocationCity rdf:type rdf:Property ;
    rdfs:label 'Partner Location City' ;
    rdfs:comment 'City where the partner transaction occurred.' ;
    rdfs:domain ind:PartnerTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerLocationCode rdf:type rdf:Property ;
    rdfs:label 'Partner Location Code' ;
    rdfs:comment 'Code identifying the specific partner location where the transaction occurred (e.g., hotel property code, car rental branch code, retail store identifier).' ;
    rdfs:domain ind:PartnerTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerLocationCountryCode rdf:type rdf:Property ;
    rdfs:label 'Partner Location Country Code' ;
    rdfs:comment 'Three-letter ISO country code where the partner transaction occurred.' ;
    rdfs:domain ind:PartnerTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerLocationName rdf:type rdf:Property ;
    rdfs:label 'Partner Location Name' ;
    rdfs:comment 'Descriptive name of the partner location where the transaction occurred (e.g., Marriott Times Square, Hertz LAX Airport).' ;
    rdfs:domain ind:PartnerTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationDate rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Date' ;
    rdfs:comment 'Date when this transaction was reconciled with the partner for settlement purposes.' ;
    rdfs:domain ind:PartnerTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceSystemTransactionCode rdf:type rdf:Property ;
    rdfs:label 'Source System Transaction Code' ;
    rdfs:comment 'Unique transaction identifier in the source system or partner platform, used for traceability and audit.' ;
    rdfs:domain ind:PartnerTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalMiles rdf:type rdf:Property ;
    rdfs:label 'Total Miles' ;
    rdfs:comment 'Total miles awarded or redeemed in this transaction (sum of base miles and bonus miles).' ;
    rdfs:domain ind:PartnerTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transactionDate rdf:type rdf:Property ;
    rdfs:label 'Transaction Date' ;
    rdfs:comment 'Date when the partner transaction occurred (e.g., hotel checkout date, car rental return date, credit card purchase date).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:loyaltyPromotionEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Loyalty Promotion Enrollment Id' ;
    rdfs:comment 'Unique identifier for the promotion enrollment record. Primary key.' ;
    rdfs:domain ind:LoyaltyPromotionEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceCampaignId rdf:type rdf:Property ;
    rdfs:label 'Source Campaign Id' ;
    rdfs:comment 'Foreign key linking to marketing.campaign. Business justification: Members enroll in loyalty promotions via marketing campaign touchpoints (email, web, app). Linking enables funnel analysis from campaign exposure to enrollment, measures campaign effectiveness in driv' ;
    rdfs:domain ind:LoyaltyPromotionEnrollment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Campaign .

ind:autoEnrolledFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Enrolled Flag' ;
    rdfs:comment 'Indicates whether the member was automatically enrolled based on tier status or other eligibility criteria, versus explicit opt-in.' ;
    rdfs:domain ind:LoyaltyPromotionEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bonusMilesEarned rdf:type rdf:Property ;
    rdfs:label 'Bonus Miles Earned' ;
    rdfs:comment 'Total bonus miles or points awarded to the member upon successful completion of the promotion.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bonusPostingDate rdf:type rdf:Property ;
    rdfs:label 'Bonus Posting Date' ;
    rdfs:comment 'Date when bonus miles or rewards were posted to the member\'s FFP account.' ;
    rdfs:domain ind:LoyaltyPromotionEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bonusPostingStatus rdf:type rdf:Property ;
    rdfs:label 'Bonus Posting Status' ;
    rdfs:comment 'Status of the bonus miles posting transaction to the member\'s account.' ;
    rdfs:domain ind:LoyaltyPromotionEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentNumber rdf:type rdf:Property ;
    rdfs:label 'Enrollment Number' ;
    rdfs:comment 'Business-facing unique enrollment reference number for tracking and customer service inquiries.' ;
    rdfs:domain ind:LoyaltyPromotionEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentSourceCampaign rdf:type rdf:Property ;
    rdfs:label 'Enrollment Source Campaign' ;
    rdfs:comment 'Marketing campaign code or identifier that drove the enrollment, used for campaign effectiveness tracking.' ;
    rdfs:domain ind:LoyaltyPromotionEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentStatus rdf:type rdf:Property ;
    rdfs:label 'Enrollment Status' ;
    rdfs:comment 'Current lifecycle status of the promotion enrollment. Tracks progression from initial enrollment through completion or termination. [ENUM-REF-CANDIDATE: enrolled|in_progress|qualified|completed|expired|cancelled|disqualified — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Enrollment Timestamp' ;
    rdfs:comment 'Precise date and time when the member enrolled in the promotion, including timezone information.' ;
    rdfs:domain ind:LoyaltyPromotionEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:optInConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Opt In Consent Flag' ;
    rdfs:comment 'Indicates whether the member provided explicit consent to participate in the promotion and receive related communications.' ;
    rdfs:domain ind:LoyaltyPromotionEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:partnerCode rdf:type rdf:Property ;
    rdfs:label 'Partner Code' ;
    rdfs:comment 'IATA or internal code of the partner organization for co-branded promotions.' ;
    rdfs:domain ind:LoyaltyPromotionEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerPromotionFlag rdf:type rdf:Property ;
    rdfs:label 'Partner Promotion Flag' ;
    rdfs:comment 'Indicates whether this is a co-branded promotion with a partner airline, hotel, or coalition program.' ;
    rdfs:domain ind:LoyaltyPromotionEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:promotionEndDate rdf:type rdf:Property ;
    rdfs:label 'Promotion End Date' ;
    rdfs:comment 'Date when the promotion period ends and qualification window closes.' ;
    rdfs:domain ind:LoyaltyPromotionEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:promotionStartDate rdf:type rdf:Property ;
    rdfs:label 'Promotion Start Date' ;
    rdfs:comment 'Date when the promotion period begins for this enrollment, may differ from enrollment date for future-dated promotions.' ;
    rdfs:domain ind:LoyaltyPromotionEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualificationCriteriaType rdf:type rdf:Property ;
    rdfs:label 'Qualification Criteria Type' ;
    rdfs:comment 'Type of qualification criteria the member must meet to complete the promotion (e.g., number of flights, miles earned, spend threshold).' ;
    rdfs:domain ind:LoyaltyPromotionEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationCurrentValue rdf:type rdf:Property ;
    rdfs:label 'Qualification Current Value' ;
    rdfs:comment 'Current progress value toward the qualification target, updated as qualifying activities are completed.' ;
    rdfs:domain ind:LoyaltyPromotionEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualificationDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Qualification Deadline Date' ;
    rdfs:comment 'Final date by which the member must complete qualification criteria to earn promotion rewards.' ;
    rdfs:domain ind:LoyaltyPromotionEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualificationPercentage rdf:type rdf:Property ;
    rdfs:label 'Qualification Percentage' ;
    rdfs:comment 'Percentage of qualification criteria completed, calculated as (current_value / target_value) * 100.' ;
    rdfs:domain ind:LoyaltyPromotionEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualificationTargetValue rdf:type rdf:Property ;
    rdfs:label 'Qualification Target Value' ;
    rdfs:comment 'Target value the member must achieve to qualify for promotion completion (e.g., 5 flights, 10000 miles, 500 USD spend).' ;
    rdfs:domain ind:LoyaltyPromotionEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualificationUnit rdf:type rdf:Property ;
    rdfs:label 'Qualification Unit' ;
    rdfs:comment 'Unit of measure for qualification progress (e.g., flights, miles, currency units). [ENUM-REF-CANDIDATE: flights|segments|miles|kilometers|currency|points|nights|transactions — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:LoyaltyPromotionEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualifiedDate rdf:type rdf:Property ;
    rdfs:label 'Qualified Date' ;
    rdfs:comment 'Date when the member met all qualification criteria and became eligible for promotion rewards.' ;
    rdfs:domain ind:LoyaltyPromotionEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualifyingActivitiesCount rdf:type rdf:Property ;
    rdfs:label 'Qualifying Activities Count' ;
    rdfs:comment 'Number of qualifying activities (flights, transactions, partner activities) completed toward promotion requirements.' ;
    rdfs:domain ind:LoyaltyPromotionEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:termsVersion rdf:type rdf:Property ;
    rdfs:label 'Terms Version' ;
    rdfs:comment 'Version identifier of the promotion terms and conditions that the member agreed to at enrollment.' ;
    rdfs:domain ind:LoyaltyPromotionEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierBonusMultiplier rdf:type rdf:Property ;
    rdfs:label 'Tier Bonus Multiplier' ;
    rdfs:comment 'Additional multiplier applied to promotion rewards based on the member\'s elite tier status at time of qualification.' ;
    rdfs:domain ind:LoyaltyPromotionEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:statusMatchId rdf:type rdf:Property ;
    rdfs:label 'Status Match Id' ;
    rdfs:comment 'Unique identifier for the status match or tier challenge request. Primary key.' ;
    rdfs:domain ind:StatusMatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requestedTierStatusId rdf:type rdf:Property ;
    rdfs:label 'Requested Tier Status Id' ;
    rdfs:comment 'Foreign key linking to loyalty.tier_status. Business justification: status_match has requested_tier_code and requested_tier_name attributes indicating which tier level the member is requesting to match. tier_status is the master definition table for tier levels. Addin' ;
    rdfs:domain ind:StatusMatch ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TierStatus .

ind:approvalNotes rdf:type rdf:Property ;
    rdfs:label 'Approval Notes' ;
    rdfs:comment 'Internal notes recorded by the reviewer regarding the approval or denial decision, including any special conditions or considerations.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:challengeDurationMonths rdf:type rdf:Property ;
    rdfs:label 'Challenge Duration Months' ;
    rdfs:comment 'Duration of the tier challenge period in months (typically 3, 6, or 12 months). Null for instant match requests.' ;
    rdfs:domain ind:StatusMatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:challengeEndDate rdf:type rdf:Property ;
    rdfs:label 'Challenge End Date' ;
    rdfs:comment 'End date of the tier challenge period by which the member must complete qualifying activity. Null for instant match requests.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:challengeStartDate rdf:type rdf:Property ;
    rdfs:label 'Challenge Start Date' ;
    rdfs:comment 'Start date of the tier challenge period during which the member must meet qualifying activity requirements. Null for instant match requests.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:competingAirlineCode rdf:type rdf:Property ;
    rdfs:label 'Competing Airline Code' ;
    rdfs:comment 'Two-letter IATA airline code of the competing carrier where the member holds elite status.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competingAirlineName rdf:type rdf:Property ;
    rdfs:label 'Competing Airline Name' ;
    rdfs:comment 'Full name of the competing airline where the member holds elite status.' ;
    rdfs:domain ind:StatusMatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competingTierHeld rdf:type rdf:Property ;
    rdfs:label 'Competing Tier Held' ;
    rdfs:comment 'Name or code of the elite tier status the member currently holds with the competing airline (e.g., Gold, Platinum, Diamond).' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competingTierLevel rdf:type rdf:Property ;
    rdfs:label 'Competing Tier Level' ;
    rdfs:comment 'Numeric level of the competing tier for comparison purposes, where higher numbers indicate higher status (e.g., 1=Silver, 2=Gold, 3=Platinum).' ;
    rdfs:domain ind:StatusMatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:matchOutcome rdf:type rdf:Property ;
    rdfs:label 'Match Outcome' ;
    rdfs:comment 'Final outcome of the status match request: matched (instant tier granted), challenged (challenge period active), denied (request rejected), expired (challenge period ended without completion), withdrawn (member cancelled), completed_success (challenge met), completed_failure (challenge not met). [ENUM-REF-CANDIDATE: matched|challenged|denied|expired|withdrawn|completed_success|completed_failure — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchedTierCode rdf:type rdf:Property ;
    rdfs:label 'Matched Tier Code' ;
    rdfs:comment 'Code of the tier status actually granted to the member as a result of the status match. May differ from requested tier if a lower tier was approved.' ;
    rdfs:domain ind:StatusMatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchedTierEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Matched Tier Effective Date' ;
    rdfs:comment 'Date when the matched tier status becomes active for the member. Null if request was denied or is still pending.' ;
    rdfs:domain ind:StatusMatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:matchedTierExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Matched Tier Expiry Date' ;
    rdfs:comment 'Date when the matched tier status expires. For challenge matches, this is typically set after successful challenge completion. Null if request was denied or is still pending.' ;
    rdfs:domain ind:StatusMatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:progressPercentage rdf:type rdf:Property ;
    rdfs:label 'Progress Percentage' ;
    rdfs:comment 'Percentage of challenge requirements completed, calculated as the minimum progress across all qualifying metrics (miles, segments, spend).' ;
    rdfs:domain ind:StatusMatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proofOfStatusDocumentType rdf:type rdf:Property ;
    rdfs:label 'Proof Of Status Document Type' ;
    rdfs:comment 'Type of documentation provided by the member to prove their elite status with the competing airline.' ;
    rdfs:domain ind:StatusMatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proofOfStatusReference rdf:type rdf:Property ;
    rdfs:label 'Proof Of Status Reference' ;
    rdfs:comment 'Reference identifier or storage location for the uploaded proof of status documentation (e.g., document management system ID, cloud storage path).' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualifyingMilesAchieved rdf:type rdf:Property ;
    rdfs:label 'Qualifying Miles Achieved' ;
    rdfs:comment 'Number of qualifying miles the member has earned toward the challenge requirement as of the current date.' ;
    rdfs:domain ind:StatusMatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualifyingMilesRequired rdf:type rdf:Property ;
    rdfs:label 'Qualifying Miles Required' ;
    rdfs:comment 'Number of qualifying miles the member must earn during the challenge period to retain the matched tier. Null for instant match requests.' ;
    rdfs:domain ind:StatusMatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualifyingSegmentsAchieved rdf:type rdf:Property ;
    rdfs:label 'Qualifying Segments Achieved' ;
    rdfs:comment 'Number of qualifying flight segments the member has completed toward the challenge requirement as of the current date.' ;
    rdfs:domain ind:StatusMatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualifyingSegmentsRequired rdf:type rdf:Property ;
    rdfs:label 'Qualifying Segments Required' ;
    rdfs:comment 'Number of qualifying flight segments the member must complete during the challenge period. Null for instant match requests.' ;
    rdfs:domain ind:StatusMatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualifyingSpendAchieved rdf:type rdf:Property ;
    rdfs:label 'Qualifying Spend Achieved' ;
    rdfs:comment 'Monetary spend amount the member has achieved toward the challenge requirement as of the current date.' ;
    rdfs:domain ind:StatusMatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualifyingSpendRequired rdf:type rdf:Property ;
    rdfs:label 'Qualifying Spend Required' ;
    rdfs:comment 'Monetary spend amount the member must achieve during the challenge period. Null for instant match requests.' ;
    rdfs:domain ind:StatusMatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requestDate rdf:type rdf:Property ;
    rdfs:label 'Request Date' ;
    rdfs:comment 'Date when the member submitted the status match or tier challenge request.' ;
    rdfs:domain ind:StatusMatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestNumber rdf:type rdf:Property ;
    rdfs:label 'Request Number' ;
    rdfs:comment 'Externally visible unique reference number for the status match request, formatted as SM followed by 10 digits.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestStatus rdf:type rdf:Property ;
    rdfs:label 'Request Status' ;
    rdfs:comment 'Current lifecycle status of the status match request. [ENUM-REF-CANDIDATE: submitted|under_review|approved|denied|expired|withdrawn|completed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestType rdf:type rdf:Property ;
    rdfs:label 'Request Type' ;
    rdfs:comment 'Type of status match request: instant match (immediate tier grant), challenge with conditions (earn tier by meeting activity requirements), courtesy match (discretionary grant), or reciprocal match (partner airline agreement).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedTierCode rdf:type rdf:Property ;
    rdfs:label 'Requested Tier Code' ;
    rdfs:comment 'Code of the tier status the member is requesting to be matched to in the airline\'s FFP.' ;
    rdfs:domain ind:StatusMatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewDate rdf:type rdf:Property ;
    rdfs:label 'Review Date' ;
    rdfs:comment 'Date when the status match request was reviewed and a decision was made.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceChannel rdf:type rdf:Property ;
    rdfs:label 'Source Channel' ;
    rdfs:comment 'Channel through which the member submitted the status match request.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierQualificationId rdf:type rdf:Property ;
    rdfs:label 'Tier Qualification Id' ;
    rdfs:comment 'Unique identifier for the tier qualification record. Primary key.' ;
    rdfs:domain ind:TierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualificationCycleId rdf:type rdf:Property ;
    rdfs:label 'Qualification Cycle Id' ;
    rdfs:comment 'Identifier of the qualification cycle (annual or special) during which this tier qualification was evaluated.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QualificationCycle .

ind:adjudicationNotes rdf:type rdf:Property ;
    rdfs:label 'Adjudication Notes' ;
    rdfs:comment 'Free-text notes recorded by FFP administrators during the adjudication of status match, tier challenge, or special qualification cases.' ;
    rdfs:domain ind:TierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:challengeActivityAchieved rdf:type rdf:Property ;
    rdfs:label 'Challenge Activity Achieved' ;
    rdfs:comment 'Description of the actual activity achieved by the member during the tier challenge period, used to determine challenge success.' ;
    rdfs:domain ind:TierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:challengeActivityRequired rdf:type rdf:Property ;
    rdfs:label 'Challenge Activity Required' ;
    rdfs:comment 'Description of the activity requirements (e.g., number of flights, miles, or spend) that the member must achieve during the tier challenge period to qualify.' ;
    rdfs:domain ind:TierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:extensionExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Extension Expiry Date' ;
    rdfs:comment 'Date on which the tier extension period expires if an extension was granted.' ;
    rdfs:domain ind:TierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:extensionGrantedFlag rdf:type rdf:Property ;
    rdfs:label 'Extension Granted Flag' ;
    rdfs:comment 'Indicates whether a tier extension or grace period was granted to the member (True if extension granted, False otherwise).' ;
    rdfs:domain ind:TierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:extensionReason rdf:type rdf:Property ;
    rdfs:label 'Extension Reason' ;
    rdfs:comment 'Business reason for granting a tier extension (e.g., medical hardship, service recovery, loyalty gesture, pandemic exception).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lifetimeMilesAccumulated rdf:type rdf:Property ;
    rdfs:label 'Lifetime Miles Accumulated' ;
    rdfs:comment 'Cumulative lifetime qualifying miles accumulated by the member across all qualification cycles, used for lifetime status determination.' ;
    rdfs:domain ind:TierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:matchApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Match Approval Date' ;
    rdfs:comment 'Date on which the status match or tier challenge request was approved by the FFP administration team.' ;
    rdfs:domain ind:TierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualificationSourceBreakdown rdf:type rdf:Property ;
    rdfs:label 'Qualification Source Breakdown' ;
    rdfs:comment 'Detailed breakdown of the sources contributing to the qualification (e.g., own flights, partner airline flights, credit card spend, hotel stays, car rentals) with corresponding qualifying miles or segments.' ;
    rdfs:domain ind:TierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationType rdf:type rdf:Property ;
    rdfs:label 'Qualification Type' ;
    rdfs:comment 'Type of qualification event: standard annual qualification based on activity, status match from competing airline, tier challenge program, lifetime status award, promotional grant, or courtesy status.' ;
    rdfs:domain ind:TierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationYear rdf:type rdf:Property ;
    rdfs:label 'Qualification Year' ;
    rdfs:comment 'Calendar year in which the tier qualification was earned or evaluated.' ;
    rdfs:domain ind:TierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualifyingMilesEarned rdf:type rdf:Property ;
    rdfs:label 'Qualifying Miles Earned' ;
    rdfs:comment 'Total qualifying miles (QM) earned by the member during the qualification period. Used to determine tier eligibility.' ;
    rdfs:domain ind:TierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualifyingSegmentsEarned rdf:type rdf:Property ;
    rdfs:label 'Qualifying Segments Earned' ;
    rdfs:comment 'Total number of qualifying flight segments (QS) flown by the member during the qualification period. Used to determine tier eligibility.' ;
    rdfs:domain ind:TierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualifyingSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Qualifying Spend Amount' ;
    rdfs:comment 'Total qualifying spend (QSP) amount in base currency spent by the member on eligible flights and services during the qualification period. Used to determine tier eligibility.' ;
    rdfs:domain ind:TierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rolloverMiles rdf:type rdf:Property ;
    rdfs:label 'Rollover Miles' ;
    rdfs:comment 'Excess qualifying miles earned beyond the tier threshold that may roll over to the next qualification cycle or contribute to lifetime status.' ;
    rdfs:domain ind:TierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tierAchieved rdf:type rdf:Property ;
    rdfs:label 'Tier Achieved' ;
    rdfs:comment 'The elite tier level achieved by the member as a result of this qualification (e.g., Silver, Gold, Platinum, Diamond, or lifetime tiers). [ENUM-REF-CANDIDATE: base|silver|gold|platinum|diamond|lifetime_gold|lifetime_platinum — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Tier Effective Date' ;
    rdfs:comment 'Date on which the achieved tier status becomes active and member benefits commence.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tierExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Tier Expiry Date' ;
    rdfs:comment 'Date on which the achieved tier status expires unless re-qualified. Null for lifetime status.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tierThresholdMiles rdf:type rdf:Property ;
    rdfs:label 'Tier Threshold Miles' ;
    rdfs:comment 'Minimum qualifying miles (QM) threshold required to achieve the tier for this qualification cycle.' ;
    rdfs:domain ind:TierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tierThresholdSegments rdf:type rdf:Property ;
    rdfs:label 'Tier Threshold Segments' ;
    rdfs:comment 'Minimum qualifying segments (QS) threshold required to achieve the tier for this qualification cycle.' ;
    rdfs:domain ind:TierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tierThresholdSpend rdf:type rdf:Property ;
    rdfs:label 'Tier Threshold Spend' ;
    rdfs:comment 'Minimum qualifying spend (QSP) threshold required to achieve the tier for this qualification cycle.' ;
    rdfs:domain ind:TierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:awardBookingDiscountPercent rdf:type rdf:Property ;
    rdfs:label 'Award Booking Discount Percent' ;
    rdfs:comment 'Percentage discount applied to the mileage cost of award bookings for members at this tier level (e.g., 10.00 for 10% discount). Zero if no discount is provided.' ;
    rdfs:domain ind:TierStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:benefitsSummary rdf:type rdf:Property ;
    rdfs:label 'Benefits Summary' ;
    rdfs:comment 'Comprehensive text description of all benefits, privileges, and entitlements associated with this tier level. Used for member communications, marketing materials, and customer service reference.' ;
    rdfs:domain ind:TierStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bonusMileMultiplier rdf:type rdf:Property ;
    rdfs:label 'Bonus Mile Multiplier' ;
    rdfs:comment 'Multiplier applied to base miles earned on eligible flights for members holding this tier status (e.g., 1.25 for 25% bonus, 1.50 for 50% bonus). Used to calculate total accrued miles including tier bonuses.' ;
    rdfs:domain ind:TierStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lifetimeStatusEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Lifetime Status Eligible Flag' ;
    rdfs:comment 'Indicates whether achieving this tier level contributes toward lifetime status qualification. True if this tier counts toward lifetime elite status milestones.' ;
    rdfs:domain ind:TierStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loungeAccessFlag rdf:type rdf:Property ;
    rdfs:label 'Lounge Access Flag' ;
    rdfs:comment 'Indicates whether members at this tier level have complimentary access to airline lounges (e.g., business class lounges, first class lounges, partner lounges). True if lounge access is a tier benefit.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorityBaggageFlag rdf:type rdf:Property ;
    rdfs:label 'Priority Baggage Flag' ;
    rdfs:comment 'Indicates whether members at this tier level receive priority baggage handling, ensuring their checked luggage is among the first delivered at baggage claim. True if priority baggage handling is included.' ;
    rdfs:domain ind:TierStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorityCheckinFlag rdf:type rdf:Property ;
    rdfs:label 'Priority Checkin Flag' ;
    rdfs:comment 'Indicates whether members at this tier level have access to priority check-in counters and expedited check-in processes. True if priority check-in is a tier benefit.' ;
    rdfs:domain ind:TierStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualificationMilesThreshold rdf:type rdf:Property ;
    rdfs:label 'Qualification Miles Threshold' ;
    rdfs:comment 'Minimum number of qualifying miles a member must earn within the qualification period to achieve or maintain this tier status. Measured in miles flown on eligible flights.' ;
    rdfs:domain ind:TierStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualificationPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Qualification Period Months' ;
    rdfs:comment 'Number of months over which qualification activity is measured (e.g., 12 for calendar year, 24 for rolling two-year period). Defines the window for accumulating qualifying miles, segments, or spend.' ;
    rdfs:domain ind:TierStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualificationSegmentsThreshold rdf:type rdf:Property ;
    rdfs:label 'Qualification Segments Threshold' ;
    rdfs:comment 'Minimum number of qualifying flight segments a member must complete within the qualification period to achieve or maintain this tier status. One segment equals one takeoff and landing.' ;
    rdfs:domain ind:TierStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualificationSpendThreshold rdf:type rdf:Property ;
    rdfs:label 'Qualification Spend Threshold' ;
    rdfs:comment 'Minimum monetary spend amount on eligible flights required within the qualification period to achieve or maintain this tier status. Typically measured in the program\'s base currency.' ;
    rdfs:domain ind:TierStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tierCode rdf:type rdf:Property ;
    rdfs:label 'Tier Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the tier level within the FFP system (e.g., SLV, GLD, PLT, EXPL). Used as business identifier in operational systems.' ;
    rdfs:domain ind:TierStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierName rdf:type rdf:Property ;
    rdfs:label 'Tier Name' ;
    rdfs:comment 'Full marketing name of the tier level (e.g., Silver, Gold, Platinum, Executive Platinum). Human-readable label displayed to members and in customer communications.' ;
    rdfs:domain ind:TierStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierStatusStatus rdf:type rdf:Property ;
    rdfs:label 'Tier Status Status' ;
    rdfs:comment 'Current lifecycle status of the tier level within the program. Active tiers are available for member qualification; discontinued tiers are legacy levels no longer offered but may still have active members.' ;
    rdfs:domain ind:TierStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierValidityMonths rdf:type rdf:Property ;
    rdfs:label 'Tier Validity Months' ;
    rdfs:comment 'Number of months the tier status remains valid once earned, before re-qualification is required. Common values are 12 (annual) or 24 (biennial).' ;
    rdfs:domain ind:TierStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:upgradeEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Upgrade Eligibility Flag' ;
    rdfs:comment 'Indicates whether members at this tier level are eligible for complimentary or mileage-based cabin upgrades (e.g., economy to business, business to first). True if upgrade benefits are included.' ;
    rdfs:domain ind:TierStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:upgradeRequestId rdf:type rdf:Property ;
    rdfs:label 'Upgrade Request Id' ;
    rdfs:comment 'Unique identifier for the upgrade request. Primary key for the upgrade request entity.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UpgradeRequest .

ind:currentCabinClassId rdf:type rdf:Property ;
    rdfs:label 'Current Cabin Class Id' ;
    rdfs:comment 'Foreign key linking to inventory.cabin_class. Business justification: Upgrade eligibility rules depend on current cabin class. Normalizes current_cabin_class text column. Required for upgrade policy enforcement and operational upgrade clearance workflows.' ;
    rdfs:domain ind:UpgradeRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CabinClass .

ind:companionUpgradeFlag rdf:type rdf:Property ;
    rdfs:label 'Companion Upgrade Flag' ;
    rdfs:comment 'Indicates whether this upgrade request includes a companion passenger traveling on the same PNR and eligible for upgrade under the member\'s benefits.' ;
    rdfs:domain ind:UpgradeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fareClassCode rdf:type rdf:Property ;
    rdfs:label 'Fare Class Code' ;
    rdfs:comment 'Single-letter fare class booking code of the original ticket, which influences upgrade eligibility and priority.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milesDeducted rdf:type rdf:Property ;
    rdfs:label 'Miles Deducted' ;
    rdfs:comment 'Number of frequent flyer miles deducted from the member\'s account for a miles-based or co-pay upgrade. Null for complimentary elite upgrades.' ;
    rdfs:domain ind:UpgradeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requestChannel rdf:type rdf:Property ;
    rdfs:label 'Request Channel' ;
    rdfs:comment 'Channel through which the upgrade request was submitted: web portal, mobile application, call center agent, airport self-service kiosk, gate agent, or partner airline portal.' ;
    rdfs:domain ind:UpgradeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedCabinClass rdf:type rdf:Property ;
    rdfs:label 'Requested Cabin Class' ;
    rdfs:comment 'The target cabin class to which the passenger is requesting an upgrade.' ;
    rdfs:domain ind:UpgradeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seatNumberAssigned rdf:type rdf:Property ;
    rdfs:label 'Seat Number Assigned' ;
    rdfs:comment 'Specific seat number assigned to the passenger in the upgraded cabin once the upgrade is cleared. Format: row number followed by seat letter.' ;
    rdfs:domain ind:UpgradeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upgradePriorityScore rdf:type rdf:Property ;
    rdfs:label 'Upgrade Priority Score' ;
    rdfs:comment 'Calculated priority score determining the member\'s position in the upgrade queue, based on factors such as tier status, fare class, lifetime miles, and request timing.' ;
    rdfs:domain ind:UpgradeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adComplianceId rdf:type rdf:Property ;
    rdfs:label 'Ad Compliance Id' ;
    rdfs:comment 'Unique identifier for the airworthiness directive compliance record.' ;
    rdfs:domain ind:AdCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:alertId rdf:type rdf:Property ;
    rdfs:label 'Alert Id' ;
    rdfs:comment 'Foreign key linking to safety.alert. Business justification: Safety alerts may reference ADs requiring compliance (urgent AD implementation alerts). Link supports integrated regulatory compliance tracking, enables alert-driven AD prioritization, and tracks aler' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Alert .

ind:componentId rdf:type rdf:Property ;
    rdfs:label 'Component Id' ;
    rdfs:comment 'Reference to the specific aircraft component (engine, APU, landing gear, etc.) to which this airworthiness directive applies, if component-specific.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Component .

ind:maintenanceAirworthinessDirectiveId rdf:type rdf:Property ;
    rdfs:label 'Maintenance Airworthiness Directive Id' ;
    rdfs:comment 'Foreign key linking to maintenance.airworthiness_directive. Business justification: AD compliance tracks compliance with a specific airworthiness directive. The ad_compliance table has ad_number, ad_title, and issuing_authority but no FK to airworthiness_directive. Adding maintenance' ;
    rdfs:domain ind:AdCompliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AirworthinessDirective .

ind:triggeringOccurrenceId rdf:type rdf:Property ;
    rdfs:label 'Triggering Occurrence Id' ;
    rdfs:comment 'Foreign key linking to safety.occurrence. Business justification: AD compliance activities may be initiated by safety occurrences that reveal fleet-wide issues (e.g., incident exposes design flaw requiring emergency AD). Links occurrence-driven regulatory compliance' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Occurrence .

ind:workOrderId rdf:type rdf:Property ;
    rdfs:label 'Work Order Id' ;
    rdfs:comment 'Reference to the maintenance work order under which the airworthiness directive compliance action was performed.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkOrder .

ind:accomplishmentDate rdf:type rdf:Property ;
    rdfs:label 'Accomplishment Date' ;
    rdfs:comment 'The date on which the airworthiness directive compliance action was completed.' ;
    rdfs:domain ind:AdCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accomplishmentFlightCycles rdf:type rdf:Property ;
    rdfs:label 'Accomplishment Flight Cycles' ;
    rdfs:comment 'The total flight cycles (airframe or component) at the time the airworthiness directive compliance action was completed.' ;
    rdfs:domain ind:AdCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accomplishmentFlightHours rdf:type rdf:Property ;
    rdfs:label 'Accomplishment Flight Hours' ;
    rdfs:comment 'The total flight hours (airframe or component) at the time the airworthiness directive compliance action was completed.' ;
    rdfs:domain ind:AdCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Ad Effective Date' ;
    rdfs:comment 'The date on which the airworthiness directive becomes effective and compliance is required.' ;
    rdfs:domain ind:AdCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:amocApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Amoc Approval Date' ;
    rdfs:comment 'The date on which the alternative method of compliance was approved by the regulatory authority.' ;
    rdfs:domain ind:AdCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:applicability rdf:type rdf:Property ;
    rdfs:label 'Applicability' ;
    rdfs:comment 'Description of the aircraft models, serial numbers, or component part numbers to which this airworthiness directive applies.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifyingMechanicLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Certifying Mechanic License Number' ;
    rdfs:comment 'The license or certificate number of the mechanic who certified the airworthiness directive compliance action.' ;
    rdfs:domain ind:AdCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deferralReference rdf:type rdf:Property ;
    rdfs:label 'Deferral Reference' ;
    rdfs:comment 'Reference to the Minimum Equipment List (MEL) or Configuration Deviation List (CDL) item under which compliance with this airworthiness directive has been deferred.' ;
    rdfs:domain ind:AdCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextDueFlightCycles rdf:type rdf:Property ;
    rdfs:label 'Next Due Flight Cycles' ;
    rdfs:comment 'The flight cycles threshold at which the next repetitive airworthiness directive compliance action is due.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextDueFlightHours rdf:type rdf:Property ;
    rdfs:label 'Next Due Flight Hours' ;
    rdfs:comment 'The flight hours threshold at which the next repetitive airworthiness directive compliance action is due.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recordUpdatedBy rdf:type rdf:Property ;
    rdfs:label 'Record Updated By' ;
    rdfs:comment 'The user or system identifier that last updated this airworthiness directive compliance record.' ;
    rdfs:domain ind:AdCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repetitiveFlag rdf:type rdf:Property ;
    rdfs:label 'Repetitive Flag' ;
    rdfs:comment 'Indicates whether the airworthiness directive requires repetitive compliance actions (true) or is a one-time action (false).' ;
    rdfs:domain ind:AdCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:repetitiveIntervalCycles rdf:type rdf:Property ;
    rdfs:label 'Repetitive Interval Cycles' ;
    rdfs:comment 'The flight cycles interval at which the airworthiness directive compliance action must be repeated, if applicable.' ;
    rdfs:domain ind:AdCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:repetitiveIntervalDays rdf:type rdf:Property ;
    rdfs:label 'Repetitive Interval Days' ;
    rdfs:comment 'The calendar days interval at which the airworthiness directive compliance action must be repeated, if applicable.' ;
    rdfs:domain ind:AdCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:repetitiveIntervalHours rdf:type rdf:Property ;
    rdfs:label 'Repetitive Interval Hours' ;
    rdfs:comment 'The flight hours interval at which the airworthiness directive compliance action must be repeated, if applicable.' ;
    rdfs:domain ind:AdCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supersededByAdNumber rdf:type rdf:Property ;
    rdfs:label 'Superseded By Ad Number' ;
    rdfs:comment 'The airworthiness directive number that supersedes this AD, if applicable.' ;
    rdfs:domain ind:AdCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:airworthinessDirectiveId rdf:type rdf:Property ;
    rdfs:label 'Airworthiness Directive Id' ;
    rdfs:comment 'Primary key for airworthiness_directive' ;
    rdfs:domain ind:AirworthinessDirective ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adStatus rdf:type rdf:Property ;
    rdfs:label 'Ad Status' ;
    rdfs:comment 'Current lifecycle status of the AD. Active=currently enforceable, Superseded=replaced by newer AD, Cancelled=no longer applicable, Proposed=under review, Interim=temporary emergency AD.' ;
    rdfs:domain ind:AirworthinessDirective ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:airworthinessDirectiveDescription rdf:type rdf:Property ;
    rdfs:label 'Airworthiness Directive Description' ;
    rdfs:comment 'Detailed description of the unsafe condition, the corrective action required, and the rationale for the airworthiness directive.' ;
    rdfs:domain ind:AirworthinessDirective ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alternativeComplianceMethod rdf:type rdf:Property ;
    rdfs:label 'Alternative Compliance Method' ;
    rdfs:comment 'Description of approved Alternative Methods of Compliance (AMOC) that may be used in lieu of the prescribed action, if permitted by the issuing authority.' ;
    rdfs:domain ind:AirworthinessDirective ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceIntervalUnit rdf:type rdf:Property ;
    rdfs:label 'Compliance Interval Unit' ;
    rdfs:comment 'Unit of measure for repetitive compliance interval. FH=Flight Hours, FC=Flight Cycles, days/months/years=calendar time. Null for one-time ADs.' ;
    rdfs:domain ind:AirworthinessDirective ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceIntervalValue rdf:type rdf:Property ;
    rdfs:label 'Compliance Interval Value' ;
    rdfs:comment 'Numeric interval value for repetitive compliance actions (e.g., repeat inspection every 1000 flight hours). Null for one-time ADs.' ;
    rdfs:domain ind:AirworthinessDirective ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceThresholdUnit rdf:type rdf:Property ;
    rdfs:label 'Compliance Threshold Unit' ;
    rdfs:comment 'Unit of measure for compliance threshold. FH=Flight Hours, FC=Flight Cycles, days/months/years=calendar time.' ;
    rdfs:domain ind:AirworthinessDirective ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceThresholdValue rdf:type rdf:Property ;
    rdfs:label 'Compliance Threshold Value' ;
    rdfs:comment 'Numeric threshold value at which initial compliance action must be performed (e.g., 5000 flight hours, 2500 flight cycles, 180 calendar days).' ;
    rdfs:domain ind:AirworthinessDirective ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:componentType rdf:type rdf:Property ;
    rdfs:label 'Component Type' ;
    rdfs:comment 'Category of component affected by the AD. Airframe=aircraft structure, Engine=propulsion system, Propeller=propeller assembly, Appliance=accessory or system component, APU=Auxiliary Power Unit.' ;
    rdfs:domain ind:AirworthinessDirective ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedCostPerAircraft rdf:type rdf:Property ;
    rdfs:label 'Estimated Cost Per Aircraft' ;
    rdfs:comment 'Estimated cost in USD to comply with the AD per affected aircraft, including labor, parts, and downtime. Provided by issuing authority or operator estimate.' ;
    rdfs:domain ind:AirworthinessDirective ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedLaborHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Labor Hours' ;
    rdfs:comment 'Estimated labor hours required to perform the compliance action per aircraft, as provided by the issuing authority or manufacturer.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partNumberAffected rdf:type rdf:Property ;
    rdfs:label 'Part Number Affected' ;
    rdfs:comment 'Specific part number(s) of components affected by this AD. May include multiple part numbers if AD applies to a family of parts.' ;
    rdfs:domain ind:AirworthinessDirective ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relatedAdNumbers rdf:type rdf:Property ;
    rdfs:label 'Related Ad Numbers' ;
    rdfs:comment 'Comma-separated list of related AD numbers from other authorities addressing the same unsafe condition (e.g., FAA AD referencing equivalent EASA AD).' ;
    rdfs:domain ind:AirworthinessDirective ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serialNumberRange rdf:type rdf:Property ;
    rdfs:label 'Serial Number Range' ;
    rdfs:comment 'Serial number range of aircraft or components to which this AD applies (e.g., \'S/N 1001 through 5000\'). Null if AD applies to all serial numbers.' ;
    rdfs:domain ind:AirworthinessDirective ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subject rdf:type rdf:Property ;
    rdfs:label 'Subject' ;
    rdfs:comment 'Brief title or subject line describing the nature of the airworthiness directive (e.g., \'Engine Fan Blade Inspection\', \'Landing Gear Actuator Replacement\').' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededAdNumber rdf:type rdf:Property ;
    rdfs:label 'Superseded Ad Number' ;
    rdfs:comment 'AD number(s) that this directive supersedes or replaces. Multiple ADs may be listed if this AD consolidates previous directives. Null if no supersession.' ;
    rdfs:domain ind:AirworthinessDirective ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aogEventId rdf:type rdf:Property ;
    rdfs:label 'Aog Event Id' ;
    rdfs:comment 'Unique identifier for the AOG event record. Primary key.' ;
    rdfs:domain ind:AogEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedMaintenanceOrgId rdf:type rdf:Property ;
    rdfs:label 'Approved Maintenance Org Id' ;
    rdfs:comment 'Foreign key linking to maintenance.approved_maintenance_org. Business justification: AOG event is handled by a maintenance organization. The aog_event table has maintenance_organization_code (STRING) but no FK. Adding approved_maintenance_org_id FK normalizes this and removes redundan' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ApprovedMaintenanceOrg .

ind:declaringCrewMemberId rdf:type rdf:Property ;
    rdfs:label 'Declaring Crew Member Id' ;
    rdfs:comment 'Foreign key linking to crew.crew_member. Business justification: Commander/crew member declares AOG based on operational assessment. Complements employee_id with crew-specific context (qualifications, authority). Business process: AOG declaration authority tracking' ;
    rdfs:domain ind:AogEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Member .

ind:impactedFlightRevenuePerformanceId rdf:type rdf:Property ;
    rdfs:label 'Impacted Flight Revenue Performance Id' ;
    rdfs:comment 'Foreign key linking to revenue.flight_revenue_performance. Business justification: AOG events directly cause flight cancellations with measurable revenue loss. Airlines track revenue impact per AOG incident for financial reporting, insurance claims, vendor penalty assessment, and ex' ;
    rdfs:domain ind:AogEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FlightRevenuePerformance .

ind:primaryAogEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Aog Employee Id' ;
    rdfs:comment 'Employee identifier of the AOG coordinator responsible for managing the recovery and resolution of this AOG event.' ;
    rdfs:domain ind:AogEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:resolutionWorkOrderId rdf:type rdf:Property ;
    rdfs:label 'Resolution Work Order Id' ;
    rdfs:comment 'Foreign key linking to maintenance.work_order. Business justification: AOG event is resolved via a work order. The aog_event table has resolution_work_order_number (STRING) but no FK. Adding resolution_work_order_id FK normalizes this and removes redundant resolution_wor' ;
    rdfs:domain ind:AogEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkOrder .

ind:actualRtsTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Rts Timestamp' ;
    rdfs:comment 'The actual date and time when the aircraft was certified airworthy and returned to operational service following AOG resolution.' ;
    rdfs:domain ind:AogEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:airworthinessDirectiveReference rdf:type rdf:Property ;
    rdfs:label 'Airworthiness Directive Reference' ;
    rdfs:comment 'Reference to any applicable Airworthiness Directive that was related to or triggered the AOG event.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aogDeclarationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Aog Declaration Timestamp' ;
    rdfs:comment 'The precise date and time when the aircraft was officially declared AOG due to an unresolved technical defect or missing airworthy component.' ;
    rdfs:domain ind:AogEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:aogDurationHours rdf:type rdf:Property ;
    rdfs:label 'Aog Duration Hours' ;
    rdfs:comment 'Total duration in hours that the aircraft remained in AOG status, calculated from declaration timestamp to actual RTS timestamp.' ;
    rdfs:domain ind:AogEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:aogNotificationSentFlag rdf:type rdf:Property ;
    rdfs:label 'Aog Notification Sent Flag' ;
    rdfs:comment 'Boolean flag indicating whether automated AOG notification was sent to operations control, maintenance planning, and executive stakeholders.' ;
    rdfs:domain ind:AogEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:aogSeverityLevel rdf:type rdf:Property ;
    rdfs:label 'Aog Severity Level' ;
    rdfs:comment 'Classification of the AOG event severity based on operational impact, safety implications, and recovery complexity.' ;
    rdfs:domain ind:AogEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aogStatus rdf:type rdf:Property ;
    rdfs:label 'Aog Status' ;
    rdfs:comment 'Current lifecycle status of the AOG event tracking its progression from declaration through resolution. [ENUM-REF-CANDIDATE: declared|in_progress|parts_ordered|parts_received|work_in_progress|resolved|closed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AogEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ataChapter rdf:type rdf:Property ;
    rdfs:label 'Ata Chapter' ;
    rdfs:comment 'The ATA 100 specification chapter code identifying the aircraft system affected (e.g., 32 for Landing Gear, 71 for Power Plant).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentPartNumber rdf:type rdf:Property ;
    rdfs:label 'Component Part Number' ;
    rdfs:comment 'The manufacturer part number of the failed or missing component that caused the AOG condition.' ;
    rdfs:domain ind:AogEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Component Serial Number' ;
    rdfs:comment 'The unique serial number of the specific component instance that failed or was missing.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectCode rdf:type rdf:Property ;
    rdfs:label 'Defect Code' ;
    rdfs:comment 'The standardized maintenance defect code from the airline\'s defect taxonomy that categorizes the technical failure.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedRevenueImpactUsd rdf:type rdf:Property ;
    rdfs:label 'Estimated Revenue Impact Usd' ;
    rdfs:comment 'Estimated financial impact in USD from lost revenue due to cancelled and delayed flights resulting from this AOG event.' ;
    rdfs:domain ind:AogEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedRtsTimestamp rdf:type rdf:Property ;
    rdfs:label 'Estimated Rts Timestamp' ;
    rdfs:comment 'The initially estimated date and time when the aircraft is expected to return to airworthy service status.' ;
    rdfs:domain ind:AogEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:groundingReason rdf:type rdf:Property ;
    rdfs:label 'Grounding Reason' ;
    rdfs:comment 'Detailed narrative description of the technical defect, failure, or missing component that caused the aircraft to be grounded.' ;
    rdfs:domain ind:AogEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorSupportRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Vendor Support Required Flag' ;
    rdfs:comment 'Boolean flag indicating whether external vendor or OEM technical support was required to resolve the AOG event.' ;
    rdfs:domain ind:AogEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:emergencyDrillId rdf:type rdf:Property ;
    rdfs:label 'Emergency Drill Id' ;
    rdfs:comment 'Foreign key linking to safety.emergency_drill. Business justification: MROs participate in emergency drills (aircraft recovery, hazmat response). Link tracks participation and performance, supports emergency response capability assessment, and demonstrates regulatory com' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EmergencyDrill .

ind:safetyCaseId rdf:type rdf:Property ;
    rdfs:label 'Safety Case Id' ;
    rdfs:comment 'Foreign key linking to safety.case. Business justification: Safety cases may involve MRO capabilities and approvals (novel maintenance procedures, alternative compliance methods). Link supports regulatory submission, documents MRO role in safety case implement' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Case .

ind:accountableManagerName rdf:type rdf:Property ;
    rdfs:label 'Accountable Manager Name' ;
    rdfs:comment 'Name of the accountable manager responsible for ensuring the maintenance organisation complies with Part-145 requirements.' ;
    rdfs:domain ind:ApprovedMaintenanceOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:airframeRatingFlag rdf:type rdf:Property ;
    rdfs:label 'Airframe Rating Flag' ;
    rdfs:comment 'Indicates whether the organisation holds airframe maintenance rating approval.' ;
    rdfs:domain ind:ApprovedMaintenanceOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:aogSupportAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Aog Support Available Flag' ;
    rdfs:comment 'Indicates whether the maintenance organisation provides 24/7 AOG (Aircraft on Ground) emergency support services.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvalExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Approval Expiry Date' ;
    rdfs:comment 'Date when the Part-145 approval certificate expires and requires renewal. Null if approval has no fixed expiry (continuous validity subject to surveillance).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvalIssueDate rdf:type rdf:Property ;
    rdfs:label 'Approval Issue Date' ;
    rdfs:comment 'Date when the Part-145 approval certificate was originally issued by the regulatory authority.' ;
    rdfs:domain ind:ApprovedMaintenanceOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvalScope rdf:type rdf:Property ;
    rdfs:label 'Approval Scope' ;
    rdfs:comment 'Textual description of the maintenance capabilities and ratings covered by the approval (e.g., \'Airframe rating: Boeing 737 series, Airbus A320 family; Engine rating: CFM56-7B; Component rating: Landing gear, hydraulics\').' ;
    rdfs:domain ind:ApprovedMaintenanceOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apuRatingFlag rdf:type rdf:Property ;
    rdfs:label 'Apu Rating Flag' ;
    rdfs:comment 'Indicates whether the organisation holds Auxiliary Power Unit (APU) maintenance rating approval.' ;
    rdfs:domain ind:ApprovedMaintenanceOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:auditFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Audit Findings Count' ;
    rdfs:comment 'Number of open audit findings or corrective action requests from the last audit.' ;
    rdfs:domain ind:ApprovedMaintenanceOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:avionicsRatingFlag rdf:type rdf:Property ;
    rdfs:label 'Avionics Rating Flag' ;
    rdfs:comment 'Indicates whether the organisation holds avionics and electrical systems maintenance rating approval.' ;
    rdfs:domain ind:ApprovedMaintenanceOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capabilityListReference rdf:type rdf:Property ;
    rdfs:label 'Capability List Reference' ;
    rdfs:comment 'Reference identifier or document number for the detailed capability list (CoA appendix) that enumerates specific aircraft types, engines, and components the organisation is approved to maintain.' ;
    rdfs:domain ind:ApprovedMaintenanceOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentRatingFlag rdf:type rdf:Property ;
    rdfs:label 'Component Rating Flag' ;
    rdfs:comment 'Indicates whether the organisation holds component maintenance rating approval (e.g., landing gear, avionics, hydraulics).' ;
    rdfs:domain ind:ApprovedMaintenanceOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:engineRatingFlag rdf:type rdf:Property ;
    rdfs:label 'Engine Rating Flag' ;
    rdfs:comment 'Indicates whether the organisation holds engine maintenance rating approval.' ;
    rdfs:domain ind:ApprovedMaintenanceOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:organizationCode rdf:type rdf:Property ;
    rdfs:label 'Organization Code' ;
    rdfs:comment 'Internal short code or identifier for the maintenance organisation used in operational systems.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organizationName rdf:type rdf:Property ;
    rdfs:label 'Organization Name' ;
    rdfs:comment 'Legal name of the approved maintenance organisation (AMO) as registered with the issuing authority.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organizationType rdf:type rdf:Property ;
    rdfs:label 'Organization Type' ;
    rdfs:comment 'Classification of the maintenance organisation: internal base maintenance, internal line maintenance, third-party MRO provider, OEM service center, component repair shop, or engine overhaul shop.' ;
    rdfs:domain ind:ApprovedMaintenanceOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredVendorFlag rdf:type rdf:Property ;
    rdfs:label 'Preferred Vendor Flag' ;
    rdfs:comment 'Indicates whether this maintenance organisation is designated as a preferred or strategic vendor for outsourced MRO services.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityRating rdf:type rdf:Property ;
    rdfs:label 'Quality Rating' ;
    rdfs:comment 'Internal quality performance rating score for the maintenance organisation, typically on a scale of 0.00 to 5.00, based on defect rates, on-time delivery, and audit results.' ;
    rdfs:domain ind:ApprovedMaintenanceOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:apuStatusId rdf:type rdf:Property ;
    rdfs:label 'Apu Status Id' ;
    rdfs:comment 'Unique identifier for the APU status record. Primary key.' ;
    rdfs:domain ind:ApuStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastDefectReportId rdf:type rdf:Property ;
    rdfs:label 'Last Defect Report Id' ;
    rdfs:comment 'Reference to the most recent defect report raised against this APU, if any.' ;
    rdfs:domain ind:ApuStatus ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DefectReport .

ind:lastWorkOrderId rdf:type rdf:Property ;
    rdfs:label 'Last Work Order Id' ;
    rdfs:comment 'Reference to the most recent maintenance work order performed on this APU.' ;
    rdfs:domain ind:ApuStatus ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkOrder .

ind:airworthinessCertificateExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Airworthiness Certificate Expiry Date' ;
    rdfs:comment 'Expiry date of the APU airworthiness certificate. APU must not be operated beyond this date without certificate renewal.' ;
    rdfs:domain ind:ApuStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:airworthinessCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Airworthiness Certificate Number' ;
    rdfs:comment 'Certificate number issued by the aviation authority confirming the APU meets airworthiness standards and is approved for installation.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apuPartNumber rdf:type rdf:Property ;
    rdfs:label 'Apu Part Number' ;
    rdfs:comment 'Manufacturer part number identifying the APU model and configuration. Used for parts catalog and maintenance program applicability.' ;
    rdfs:domain ind:ApuStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:borescopeInspectionIntervalHours rdf:type rdf:Property ;
    rdfs:label 'Borescope Inspection Interval Hours' ;
    rdfs:comment 'Operating hours interval between borescope inspections as specified in the APU maintenance program.' ;
    rdfs:domain ind:ApuStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cyclesSinceNew rdf:type rdf:Property ;
    rdfs:label 'Cycles Since New' ;
    rdfs:comment 'Total operating cycles accumulated by the APU since it was manufactured (never reset, even after overhaul).' ;
    rdfs:domain ind:ApuStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hoursSinceNew rdf:type rdf:Property ;
    rdfs:label 'Hours Since New' ;
    rdfs:comment 'Total operating hours accumulated by the APU since it was manufactured (never reset, even after overhaul).' ;
    rdfs:domain ind:ApuStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hoursSinceOverhaul rdf:type rdf:Property ;
    rdfs:label 'Hours Since Overhaul' ;
    rdfs:comment 'Operating hours accumulated since the last major overhaul or shop visit. Reset to zero after overhaul. Used to determine next overhaul due.' ;
    rdfs:domain ind:ApuStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:installationFlightCycles rdf:type rdf:Property ;
    rdfs:label 'Installation Flight Cycles' ;
    rdfs:comment 'Total aircraft flight cycles at the time the APU was installed. Used as baseline for calculating APU cycles-on-wing.' ;
    rdfs:domain ind:ApuStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:installationFlightHours rdf:type rdf:Property ;
    rdfs:label 'Installation Flight Hours' ;
    rdfs:comment 'Total aircraft flight hours at the time the APU was installed. Used as baseline for calculating APU time-on-wing.' ;
    rdfs:domain ind:ApuStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastBorescopeInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Last Borescope Inspection Date' ;
    rdfs:comment 'Date of the most recent borescope inspection of the APU hot section. Borescope inspections are performed to assess internal condition without disassembly.' ;
    rdfs:domain ind:ApuStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastBorescopeInspectionHours rdf:type rdf:Property ;
    rdfs:label 'Last Borescope Inspection Hours' ;
    rdfs:comment 'Total APU operating hours at the time of the last borescope inspection. Used to calculate next inspection due.' ;
    rdfs:domain ind:ApuStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastOverhaulOrganization rdf:type rdf:Property ;
    rdfs:label 'Last Overhaul Organization' ;
    rdfs:comment 'Name or code of the Part-145 approved maintenance organization that performed the last APU overhaul.' ;
    rdfs:domain ind:ApuStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:melDeferralReference rdf:type rdf:Property ;
    rdfs:label 'Mel Deferral Reference' ;
    rdfs:comment 'Reference to the active MEL deferral if the APU is currently operating under a deferral. Empty if APU is fully serviceable.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextBorescopeInspectionDueHours rdf:type rdf:Property ;
    rdfs:label 'Next Borescope Inspection Due Hours' ;
    rdfs:comment 'Total APU operating hours at which the next borescope inspection is due.' ;
    rdfs:domain ind:ApuStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextOverhaulDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Overhaul Due Date' ;
    rdfs:comment 'Calendar date by which the next APU overhaul must be completed, based on the calendar interval limit.' ;
    rdfs:domain ind:ApuStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:overhaulIntervalCycles rdf:type rdf:Property ;
    rdfs:label 'Overhaul Interval Cycles' ;
    rdfs:comment 'Manufacturer-specified or operator-approved interval in operating cycles between major overhauls. Defines when the next overhaul is due.' ;
    rdfs:domain ind:ApuStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overhaulIntervalHours rdf:type rdf:Property ;
    rdfs:label 'Overhaul Interval Hours' ;
    rdfs:comment 'Manufacturer-specified or operator-approved interval in operating hours between major overhauls. Defines when the next overhaul is due.' ;
    rdfs:domain ind:ApuStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overhaulIntervalMonths rdf:type rdf:Property ;
    rdfs:label 'Overhaul Interval Months' ;
    rdfs:comment 'Calendar time interval in months between major overhauls, whichever limit is reached first (hours, cycles, or months).' ;
    rdfs:domain ind:ApuStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ownerOrganization rdf:type rdf:Property ;
    rdfs:label 'Owner Organization' ;
    rdfs:comment 'Legal owner of the APU (airline, lessor, or leasing company). May differ from the aircraft operator.' ;
    rdfs:domain ind:ApuStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remainingCyclesToOverhaul rdf:type rdf:Property ;
    rdfs:label 'Remaining Cycles To Overhaul' ;
    rdfs:comment 'Operating cycles remaining until the next overhaul is due. Calculated as next_overhaul_due_cycles minus total_apu_cycles.' ;
    rdfs:domain ind:ApuStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:remainingHoursToOverhaul rdf:type rdf:Property ;
    rdfs:label 'Remaining Hours To Overhaul' ;
    rdfs:comment 'Operating hours remaining until the next overhaul is due. Calculated as next_overhaul_due_hours minus total_apu_hours.' ;
    rdfs:domain ind:ApuStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:removalReason rdf:type rdf:Property ;
    rdfs:label 'Removal Reason' ;
    rdfs:comment 'Reason for APU removal from the aircraft (e.g., scheduled overhaul, unscheduled failure, aircraft retirement, component upgrade).' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Serviceability Status' ;
    rdfs:comment 'Current operational and airworthiness status of the APU. Serviceable means the APU is fully operational and meets all airworthiness requirements. Unserviceable indicates the APU has a defect that prevents operation. Deferred indicates operation under MEL deferral.' ;
    rdfs:domain ind:ApuStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageLocation rdf:type rdf:Property ;
    rdfs:label 'Storage Location' ;
    rdfs:comment 'Physical storage location or warehouse code where the APU is stored if removed from aircraft. Empty if currently installed.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalApuCycles rdf:type rdf:Property ;
    rdfs:label 'Total Apu Cycles' ;
    rdfs:comment 'Cumulative start-stop cycles of the APU since new or since last zero-time overhaul. One cycle equals one start and shutdown sequence.' ;
    rdfs:domain ind:ApuStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalApuHours rdf:type rdf:Property ;
    rdfs:label 'Total Apu Hours' ;
    rdfs:comment 'Cumulative operating hours of the APU since new or since last zero-time overhaul. Primary maintenance interval parameter for APU maintenance program.' ;
    rdfs:domain ind:ApuStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:authorisationScope rdf:type rdf:Property ;
    rdfs:label 'Authorisation Scope' ;
    rdfs:comment 'The scope of maintenance tasks and ATA chapters the certifying staff member is authorized to sign off under the Part-145 approval. May include limitations or exclusions (e.g., authorized for line maintenance only, not base maintenance; authorized for ATA 32 Landing Gear but not ATA 71 Powerplant).' ;
    rdfs:domain ind:CertifyingStaff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizationEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Authorization Effective Date' ;
    rdfs:comment 'The date from which the certifying staff member is authorized to issue CRS under the current Part-145 organisation. Used to validate the legitimacy of historical sign-offs.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authorizationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Authorization Expiry Date' ;
    rdfs:comment 'The date on which the certifying staff member\'s authorization under the current Part-145 organisation expires or is withdrawn. Null if authorization is open-ended pending employment or contract status.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authorizationReference rdf:type rdf:Property ;
    rdfs:label 'Authorization Reference' ;
    rdfs:comment 'The internal authorization or stamp number assigned by the Part-145 organisation to this certifying staff member. This reference appears on Certificates of Release to Service (CRS) and work orders to trace who certified the maintenance.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employmentEndDate rdf:type rdf:Property ;
    rdfs:label 'Employment End Date' ;
    rdfs:comment 'The date on which the certifying staff member\'s employment or contract with the maintenance organisation ended. Null if currently employed.' ;
    rdfs:domain ind:CertifyingStaff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:employmentStartDate rdf:type rdf:Property ;
    rdfs:label 'Employment Start Date' ;
    rdfs:comment 'The date on which the certifying staff member commenced employment or contract with the current maintenance organisation.' ;
    rdfs:domain ind:CertifyingStaff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fullName rdf:type rdf:Property ;
    rdfs:label 'Full Name' ;
    rdfs:comment 'The full legal name of the certifying staff member as it appears on their licence and official identification documents.' ;
    rdfs:domain ind:CertifyingStaff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastRecencyActivityDate rdf:type rdf:Property ;
    rdfs:label 'Last Recency Activity Date' ;
    rdfs:comment 'The date of the most recent maintenance activity that counts toward recency requirements. Used to calculate whether the certifying staff member remains current.' ;
    rdfs:domain ind:CertifyingStaff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenceCategory rdf:type rdf:Property ;
    rdfs:label 'Licence Category' ;
    rdfs:comment 'The category of aircraft maintenance licence held. EASA categories: A (line maintenance), B1 (mechanical systems), B2 (avionics), B3 (non-pressurized piston aircraft), C (base maintenance). FAA: A&P (Airframe and Powerplant).' ;
    rdfs:domain ind:CertifyingStaff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenceExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Licence Expiry Date' ;
    rdfs:comment 'The date on which the aircraft maintenance licence expires and must be renewed. Critical for compliance tracking and work assignment eligibility.' ;
    rdfs:domain ind:CertifyingStaff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenceIssueDate rdf:type rdf:Property ;
    rdfs:label 'Licence Issue Date' ;
    rdfs:comment 'The date on which the aircraft maintenance licence was originally issued by the regulatory authority.' ;
    rdfs:domain ind:CertifyingStaff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenceSubcategory rdf:type rdf:Property ;
    rdfs:label 'Licence Subcategory' ;
    rdfs:comment 'The subcategory or endorsement within the licence category, such as B1.1 (turbine aeroplanes), B1.2 (piston aeroplanes), B1.3 (turbine helicopters), B1.4 (piston helicopters), B2 (avionics). Defines the specific aircraft propulsion and structural systems the licence holder is qualified for.' ;
    rdfs:domain ind:CertifyingStaff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextTrainingDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Training Due Date' ;
    rdfs:comment 'The date by which the certifying staff member must complete their next recurrent training to maintain authorization. Critical for proactive compliance management.' ;
    rdfs:domain ind:CertifyingStaff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:part145OrganizationCode rdf:type rdf:Property ;
    rdfs:label 'Part 145 Organization Code' ;
    rdfs:comment 'The approval code of the Part-145 maintenance organisation that currently employs or contracts this certifying staff member. This links the individual to the approved maintenance organisation under which they are authorized to issue Certificates of Release to Service (CRS).' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recencyExperienceStatus rdf:type rdf:Property ;
    rdfs:label 'Recency Experience Status' ;
    rdfs:comment 'Indicates whether the certifying staff member has maintained the required recency of experience (e.g., performed maintenance within the last 2 years on the relevant aircraft type) as mandated by Part-66 and Part-145. Current = meets recency requirements; Lapsed = recency expired, requalification needed; Suspended = temporarily not authorized.' ;
    rdfs:domain ind:CertifyingStaff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftPattern rdf:type rdf:Property ;
    rdfs:label 'Shift Pattern' ;
    rdfs:comment 'The typical shift or roster pattern for the certifying staff member (e.g., day shift, night shift, rotating 4-on-3-off, on-call). Used for crew scheduling and availability planning.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:staffNumber rdf:type rdf:Property ;
    rdfs:label 'Staff Number' ;
    rdfs:comment 'The externally-known employee or contractor identifier assigned by the maintenance organization or airline HR system. Used for payroll, access control, and work order assignment.' ;
    rdfs:domain ind:CertifyingStaff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Training Completion Date' ;
    rdfs:comment 'The date on which the certifying staff member completed their most recent mandatory training (e.g., type rating course, human factors, dangerous goods, SMS). Used for compliance tracking and audit trails.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:typeRatings rdf:type rdf:Property ;
    rdfs:label 'Type Ratings' ;
    rdfs:comment 'Comma-separated list of aircraft type ratings held by the certifying staff member (e.g., B737, A320, B777, A350). Type ratings authorize the individual to certify maintenance on specific aircraft models.' ;
    rdfs:domain ind:CertifyingStaff ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkId rdf:type rdf:Property ;
    rdfs:label 'Check Id' ;
    rdfs:comment 'Primary key for check' ;
    rdfs:domain ind:Check ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maintenanceProgramId rdf:type rdf:Property ;
    rdfs:label 'Maintenance Program Id' ;
    rdfs:comment 'Reference to the overarching maintenance program that defines the schedule and requirements for this check type. Links to the regulatory-approved maintenance plan.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Program .

ind:maintenanceStationId rdf:type rdf:Property ;
    rdfs:label 'Maintenance Station Id' ;
    rdfs:comment 'Foreign key linking to airport.station. Business justification: Maintenance checks (A/C/D checks) performed at specific stations. Links maintenance_station_code to station.station_id for hangar capacity planning, check performance tracking by location, and regulat' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Station .

ind:actualInductionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Induction Date' ;
    rdfs:comment 'The actual date when the aircraft entered the maintenance facility and work commenced. May differ from scheduled date due to operational constraints.' ;
    rdfs:domain ind:Check ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualManHours rdf:type rdf:Property ;
    rdfs:label 'Actual Man Hours' ;
    rdfs:comment 'The actual total labor hours consumed during execution of this maintenance check. Used for cost accounting and efficiency analysis.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Actual Release Date' ;
    rdfs:comment 'The actual date when the aircraft was certified airworthy and released back to operational service after completion of the maintenance check.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:airworthinessDirectivesComplied rdf:type rdf:Property ;
    rdfs:label 'Airworthiness Directives Complied' ;
    rdfs:comment 'The number of mandatory Airworthiness Directives (ADs) complied with during this maintenance check. ADs are legally enforceable safety regulations issued by aviation authorities.' ;
    rdfs:domain ind:Check ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:aogEventFlag rdf:type rdf:Property ;
    rdfs:label 'Aog Event Flag' ;
    rdfs:comment 'Boolean indicator of whether this maintenance check was triggered by or resulted in an Aircraft on Ground event, indicating unscheduled downtime with high operational impact.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:checkStatus rdf:type rdf:Property ;
    rdfs:label 'Check Status' ;
    rdfs:comment 'Current lifecycle status of the maintenance check event. Tracks progression from planning through execution to completion or cancellation.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectsFoundCount rdf:type rdf:Property ;
    rdfs:label 'Defects Found Count' ;
    rdfs:comment 'The total number of defects, discrepancies, or non-conformities identified during execution of this maintenance check. Used for quality and reliability analysis.' ;
    rdfs:domain ind:Check ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:downtimeDays rdf:type rdf:Property ;
    rdfs:label 'Downtime Days' ;
    rdfs:comment 'The total number of days the aircraft was out of service for this maintenance check, calculated from induction to release. Critical for fleet utilization metrics.' ;
    rdfs:domain ind:Check ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dueFlightCycles rdf:type rdf:Property ;
    rdfs:label 'Due Flight Cycles' ;
    rdfs:comment 'The cumulative aircraft flight cycles (takeoff-landing pairs) at which this maintenance check is due. Critical for structural fatigue monitoring.' ;
    rdfs:domain ind:Check ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dueFlightHours rdf:type rdf:Property ;
    rdfs:label 'Due Flight Hours' ;
    rdfs:comment 'The cumulative aircraft flight hours at which this maintenance check is due. One of three interval metrics (hours, cycles, calendar) used to trigger maintenance.' ;
    rdfs:domain ind:Check ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:intervalDays rdf:type rdf:Property ;
    rdfs:label 'Interval Days' ;
    rdfs:comment 'The calendar day interval between occurrences of this check type as defined in the maintenance program. For example, A-checks typically occur every 500-800 flight hours or 200-300 cycles or 60-90 days, whichever comes first.' ;
    rdfs:domain ind:Check ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:intervalFlightCycles rdf:type rdf:Property ;
    rdfs:label 'Interval Flight Cycles' ;
    rdfs:comment 'The flight cycle interval between occurrences of this check type as defined in the maintenance program.' ;
    rdfs:domain ind:Check ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:intervalFlightHours rdf:type rdf:Property ;
    rdfs:label 'Interval Flight Hours' ;
    rdfs:comment 'The flight hour interval between occurrences of this check type as defined in the maintenance program.' ;
    rdfs:domain ind:Check ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:melDeferralsCount rdf:type rdf:Property ;
    rdfs:label 'Mel Deferrals Count' ;
    rdfs:comment 'The number of defects deferred under Minimum Equipment List provisions during this check, allowing aircraft return to service with specific inoperative equipment.' ;
    rdfs:domain ind:Check ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedManHours rdf:type rdf:Property ;
    rdfs:label 'Planned Man Hours' ;
    rdfs:comment 'The estimated total labor hours required to complete this maintenance check, used for resource planning and cost estimation.' ;
    rdfs:domain ind:Check ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:releaseCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Release Certificate Number' ;
    rdfs:comment 'The unique identifier of the Certificate of Release to Service issued upon completion of this maintenance check, certifying the aircraft is airworthy.' ;
    rdfs:domain ind:Check ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledInductionDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Induction Date' ;
    rdfs:comment 'The planned date when the aircraft will enter the maintenance facility to begin this check. Used for capacity planning and aircraft rotation scheduling.' ;
    rdfs:domain ind:Check ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Release Date' ;
    rdfs:comment 'The planned date when the aircraft is expected to be released back to service after completion of the maintenance check.' ;
    rdfs:domain ind:Check ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:serviceBulletinsIncorporated rdf:type rdf:Property ;
    rdfs:label 'Service Bulletins Incorporated' ;
    rdfs:comment 'The number of manufacturer service bulletins (recommended but not mandatory modifications or inspections) incorporated during this maintenance check.' ;
    rdfs:domain ind:Check ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalCostAmount rdf:type rdf:Property ;
    rdfs:label 'Total Cost Amount' ;
    rdfs:comment 'The total cost incurred for this maintenance check including labor, parts, materials, and overhead. Used for maintenance budget tracking and cost per flight hour analysis.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:failureOccurrenceId rdf:type rdf:Property ;
    rdfs:label 'Failure Occurrence Id' ;
    rdfs:comment 'Foreign key linking to safety.occurrence. Business justification: Component failures causing safety occurrences need direct linkage for reliability analysis and fleet-wide risk assessment. Enables component-level safety performance tracking, supports manufacturer re' ;
    rdfs:domain ind:Component ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Occurrence .

ind:hazardId rdf:type rdf:Property ;
    rdfs:label 'Hazard Id' ;
    rdfs:comment 'Foreign key linking to safety.hazard. Business justification: Specific components may be associated with identified hazards (design flaws, known failure modes). Link supports component-level risk tracking, informs procurement decisions, and enables targeted moni' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Hazard .

ind:airworthinessCertificateDate rdf:type rdf:Property ;
    rdfs:label 'Airworthiness Certificate Date' ;
    rdfs:comment 'Issue date of the current airworthiness release certificate for this component.' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:airworthinessCertificateType rdf:type rdf:Property ;
    rdfs:label 'Airworthiness Certificate Type' ;
    rdfs:comment 'Type of airworthiness release certificate accompanying this component. EASA Form 1, FAA Form 8130-3, and CAA CRS are the most common authorized release certificates.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchNumber rdf:type rdf:Property ;
    rdfs:label 'Batch Number' ;
    rdfs:comment 'Manufacturing batch or lot number for batch-tracked components. Used for traceability in case of manufacturing defects or airworthiness directives. Null for serialized-only components.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentDescription rdf:type rdf:Property ;
    rdfs:label 'Component Description' ;
    rdfs:comment 'Detailed textual description of the component including type, function, and key characteristics. Used for identification and maintenance planning.' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionCode rdf:type rdf:Property ;
    rdfs:label 'Condition Code' ;
    rdfs:comment 'Two-letter ATA Spec 2000 condition code indicating the maintenance and airworthiness status of the component (e.g., AR=As Removed, OH=Overhauled, NE=New, RP=Repaired, SV=Serviceable).' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalityClassification rdf:type rdf:Property ;
    rdfs:label 'Criticality Classification' ;
    rdfs:comment 'Classification of the components criticality to flight operations and safety. AOG-critical components ground the aircraft if unserviceable, flight-safety components affect airworthiness, operational components affect dispatch reliability.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentLocationCode rdf:type rdf:Property ;
    rdfs:label 'Current Location Code' ;
    rdfs:comment 'Code identifying the specific location where the component is currently held. May be aircraft registration, shop code, warehouse code, or station code depending on location type.' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentLocationType rdf:type rdf:Property ;
    rdfs:label 'Current Location Type' ;
    rdfs:comment 'Type of location where the component is currently held. Aircraft indicates installed on aircraft, shop indicates undergoing maintenance, store indicates warehouse inventory, quarantine indicates awaiting inspection, scrap indicates condemned.' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cyclesRemainingToLimit rdf:type rdf:Property ;
    rdfs:label 'Cycles Remaining To Limit' ;
    rdfs:comment 'Flight cycles remaining before the component reaches its life limit or next scheduled maintenance event. Null if not applicable or unlimited.' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lifeLimitedPartFlag rdf:type rdf:Property ;
    rdfs:label 'Life Limited Part Flag' ;
    rdfs:comment 'Indicates whether this component is a life-limited part subject to mandatory retirement at specified life limits per airworthiness directives. True if LLP, false otherwise.' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maintenanceOrganizationCode rdf:type rdf:Property ;
    rdfs:label 'Maintenance Organization Code' ;
    rdfs:comment 'Approval code of the Part-145 approved maintenance organization that last performed maintenance or issued the airworthiness certificate for this component.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturerCode rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Code' ;
    rdfs:comment 'Standardized code identifying the component manufacturer. Typically ICAO or industry-standard manufacturer identifier.' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerType rdf:type rdf:Property ;
    rdfs:label 'Owner Type' ;
    rdfs:comment 'Ownership classification of the component. Owned indicates airline-owned, leased indicates leased from lessor, pooled indicates part of rotable pool agreement, consignment indicates supplier-owned inventory.' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rotableFlag rdf:type rdf:Property ;
    rdfs:label 'Rotable Flag' ;
    rdfs:comment 'Indicates whether this component is a rotable (repairable) part that can be overhauled and returned to service, as opposed to expendable parts. True if rotable, false if expendable.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shelfLifeExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Expiry Date' ;
    rdfs:comment 'Date when the component reaches the end of its shelf life and must be inspected, tested, or scrapped. Applicable to time-sensitive components such as rubber seals, batteries, and life vests. Null if not applicable.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:timeRemainingToLimit rdf:type rdf:Property ;
    rdfs:label 'Time Remaining To Limit' ;
    rdfs:comment 'Flight hours remaining before the component reaches its life limit or next scheduled maintenance event. Measured in hours. Null if not applicable or unlimited.' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCyclesSinceNew rdf:type rdf:Property ;
    rdfs:label 'Total Cycles Since New' ;
    rdfs:comment 'Cumulative flight cycles (takeoff/landing cycles) accumulated by this component since original manufacture. Critical for fatigue-sensitive components and LLP tracking.' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalTimeSinceNew rdf:type rdf:Property ;
    rdfs:label 'Total Time Since New' ;
    rdfs:comment 'Cumulative flight hours accumulated by this component since original manufacture. Measured in hours. Critical for life-limited part tracking and maintenance scheduling.' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:componentRemovalId rdf:type rdf:Property ;
    rdfs:label 'Component Removal Id' ;
    rdfs:comment 'Unique identifier for the component removal transaction. Primary key for the component removal record.' ;
    rdfs:domain ind:ComponentRemoval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:removedComponentId rdf:type rdf:Property ;
    rdfs:label 'Removed Component Id' ;
    rdfs:comment 'Foreign key linking to maintenance.component. Business justification: Component removal tracks the specific component being removed. The component_removal table has removed_component_part_number and removed_component_serial_number but no FK. Adding removed_component_id ' ;
    rdfs:domain ind:ComponentRemoval ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Component .

ind:replacementPurchaseOrderId rdf:type rdf:Property ;
    rdfs:label 'Replacement Purchase Order Id' ;
    rdfs:comment 'Foreign key linking to procurement.purchase_order. Business justification: Links removed unserviceable component to replacement part PO for warranty processing and cost allocation. Real process: warranty claims require proof of replacement part procurement; finance allocates' ;
    rdfs:domain ind:ComponentRemoval ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PurchaseOrder .

ind:wildlifeStrikeId rdf:type rdf:Property ;
    rdfs:label 'Wildlife Strike Id' ;
    rdfs:comment 'Foreign key linking to safety.wildlife_strike. Business justification: Wildlife strikes frequently necessitate component removal (engine fan blades, radome). Link supports damage assessment, tracks strike-related component costs, and informs wildlife strike risk analysis' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WildlifeStrike .

ind:adReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Ad Reference Number' ;
    rdfs:comment 'Reference number of the airworthiness directive that mandated the component removal, if applicable. ADs are mandatory safety directives issued by aviation authorities.' ;
    rdfs:domain ind:ComponentRemoval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aircraftTotalCyclesAtRemoval rdf:type rdf:Property ;
    rdfs:label 'Aircraft Total Cycles At Removal' ;
    rdfs:comment 'Cumulative total flight cycles (takeoff and landing pairs) recorded on the aircraft at the time the component was removed. Critical for fatigue-sensitive component tracking.' ;
    rdfs:domain ind:ComponentRemoval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:aircraftTotalHoursAtRemoval rdf:type rdf:Property ;
    rdfs:label 'Aircraft Total Hours At Removal' ;
    rdfs:comment 'Cumulative total flight hours recorded on the aircraft at the time the component was removed. Used for component life tracking and trend analysis.' ;
    rdfs:domain ind:ComponentRemoval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ataPositionCode rdf:type rdf:Property ;
    rdfs:label 'Ata Position Code' ;
    rdfs:comment 'Specific location code on the aircraft where the component is installed (e.g., LH-ENG-1 for left engine position 1). Defines the physical mounting point.' ;
    rdfs:domain ind:ComponentRemoval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentCyclesAtRemoval rdf:type rdf:Property ;
    rdfs:label 'Component Cycles At Removal' ;
    rdfs:comment 'Total operating cycles accumulated by the removed component since new or since last overhaul. Critical for life-limited parts tracking.' ;
    rdfs:domain ind:ComponentRemoval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:componentCyclesSinceNew rdf:type rdf:Property ;
    rdfs:label 'Component Cycles Since New' ;
    rdfs:comment 'Total cycles the removed component has operated since it was manufactured (cycles since new). Never resets, tracks full component life.' ;
    rdfs:domain ind:ComponentRemoval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:componentHoursAtRemoval rdf:type rdf:Property ;
    rdfs:label 'Component Hours At Removal' ;
    rdfs:comment 'Total operating hours accumulated by the removed component since new or since last overhaul. Used to determine remaining life and maintenance intervals.' ;
    rdfs:domain ind:ComponentRemoval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:componentTimeSinceNewHours rdf:type rdf:Property ;
    rdfs:label 'Component Time Since New Hours' ;
    rdfs:comment 'Total hours the removed component has operated since it was manufactured (time since new). Never resets, tracks full component life.' ;
    rdfs:domain ind:ComponentRemoval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:crsReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Crs Reference Number' ;
    rdfs:comment 'Reference number of the Certificate of Release to Service document that authorizes the aircraft to return to operation after the component installation. Required by EASA Part-145.' ;
    rdfs:domain ind:ComponentRemoval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:installationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Installation Timestamp' ;
    rdfs:comment 'Precise date and time when the replacement component installation was completed and recorded in the maintenance system.' ;
    rdfs:domain ind:ComponentRemoval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:installedComponentConditionCode rdf:type rdf:Property ;
    rdfs:label 'Installed Component Condition Code' ;
    rdfs:comment 'Condition of the replacement component at installation: new from manufacturer, overhauled (zero-timed), serviceable (used but airworthy), or repaired.' ;
    rdfs:domain ind:ComponentRemoval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:installedComponentPartNumber rdf:type rdf:Property ;
    rdfs:label 'Installed Component Part Number' ;
    rdfs:comment 'Manufacturer part number of the replacement component that was installed on the aircraft. May be same or alternate part number as removed component.' ;
    rdfs:domain ind:ComponentRemoval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:installedComponentSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Installed Component Serial Number' ;
    rdfs:comment 'Unique serial number of the replacement component that was installed. Establishes the new fitment record for the aircraft position.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:removalReasonCode rdf:type rdf:Property ;
    rdfs:label 'Removal Reason Code' ;
    rdfs:comment 'Classification of why the component was removed: scheduled maintenance, unscheduled failure, defect found, upgrade/modification, inspection requirement, life-limited part expiry, or airworthiness directive compliance. [ENUM-REF-CANDIDATE: scheduled|unscheduled|defect|upgrade|inspection|life_limit|ad_compliance — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:removalReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Removal Reason Description' ;
    rdfs:comment 'Detailed free-text explanation of the reason for component removal, including any defect descriptions, pilot reports, or maintenance findings that triggered the removal.' ;
    rdfs:domain ind:ComponentRemoval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:removalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Removal Timestamp' ;
    rdfs:comment 'Precise date and time when the component removal was completed and recorded in the maintenance system.' ;
    rdfs:domain ind:ComponentRemoval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:removedComponentConditionCode rdf:type rdf:Property ;
    rdfs:label 'Removed Component Condition Code' ;
    rdfs:comment 'Assessment of the removed component condition: serviceable (can be reused as-is), unserviceable (requires maintenance), repairable (can be overhauled), beyond repair, or scrap (must be disposed).' ;
    rdfs:domain ind:ComponentRemoval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sbReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Sb Reference Number' ;
    rdfs:comment 'Reference number of the manufacturer service bulletin that recommended or required the component removal, if applicable. Service bulletins are OEM-issued maintenance instructions.' ;
    rdfs:domain ind:ComponentRemoval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyClaimFlag rdf:type rdf:Property ;
    rdfs:label 'Warranty Claim Flag' ;
    rdfs:comment 'Boolean indicator of whether the component removal is eligible for warranty claim against the manufacturer or vendor. True indicates warranty coverage applies.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:defectReportId rdf:type rdf:Property ;
    rdfs:label 'Defect Report Id' ;
    rdfs:comment 'Unique identifier for the aircraft defect report record. Primary key.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DefectReport .

ind:airspaceDeviationId rdf:type rdf:Property ;
    rdfs:label 'Airspace Deviation Id' ;
    rdfs:comment 'Foreign key linking to safety.airspace_deviation. Business justification: Airspace deviations may reveal equipment defects (autopilot malfunction, navigation system failure). Link supports causal analysis, tracks deviation-driven maintenance, and enables identification of e' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AirspaceDeviation .

ind:discoveryStationId rdf:type rdf:Property ;
    rdfs:label 'Discovery Station Id' ;
    rdfs:comment 'Foreign key linking to airport.station. Business justification: Defects discovered at specific airport stations. Links discovery_station_code to station.station_id for quality tracking by location, identifying stations with high defect discovery rates, and targeti' ;
    rdfs:domain ind:DefectReport ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Station .

ind:fdrEventId rdf:type rdf:Property ;
    rdfs:label 'Fdr Event Id' ;
    rdfs:comment 'Foreign key linking to safety.fdr_event. Business justification: FDR events may correlate with defect reports (hard landings, overspeed events requiring inspection). Link supports integrated analysis of flight data and maintenance findings, validates FDR exceedance' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FdrEvent .

ind:identifiedHazardId rdf:type rdf:Property ;
    rdfs:label 'Identified Hazard Id' ;
    rdfs:comment 'Foreign key linking to safety.hazard. Business justification: Defects may identify new hazards or confirm existing ones (e.g., recurring defect pattern reveals systemic hazard). Link supports SMS hazard register updates, enables defect-driven hazard identificati' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Hazard .

ind:investigationId rdf:type rdf:Property ;
    rdfs:label 'Investigation Id' ;
    rdfs:comment 'Foreign key linking to safety.investigation. Business justification: Defects often trigger formal safety investigations; linking enables tracking investigation outcomes back to originating defect. Critical for SMS closed-loop corrective action tracking and regulatory i' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Investigation .

ind:primaryDefectReportedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Defect Reported By Employee Id' ;
    rdfs:comment 'Identifier of the employee who reported the defect.' ;
    rdfs:domain ind:DefectReport ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:reportingCrewMemberId rdf:type rdf:Property ;
    rdfs:label 'Reporting Crew Member Id' ;
    rdfs:comment 'Foreign key linking to crew.crew_member. Business justification: Flight/cabin crew discover and report defects during operations. Complements existing employee_id FK with crew-specific context (qualifications, recency, position). Business process: defect discovery ' ;
    rdfs:domain ind:DefectReport ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Member .

ind:runwayIncursionId rdf:type rdf:Property ;
    rdfs:label 'Runway Incursion Id' ;
    rdfs:comment 'Foreign key linking to safety.runway_incursion. Business justification: Runway incursions may result in aircraft damage requiring defect reports (tire damage, gear inspection). Link supports incident investigation, tracks incursion-related maintenance, and enables analysi' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RunwayIncursion .

ind:aogFlag rdf:type rdf:Property ;
    rdfs:label 'Aog Flag' ;
    rdfs:comment 'Indicates whether this defect has grounded the aircraft, preventing dispatch until rectified. True if AOG, false otherwise.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cdlApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Cdl Applicable Flag' ;
    rdfs:comment 'Indicates whether the defect is eligible for deferral under the aircraft Configuration Deviation List (CDL) for missing or inoperative external components. True if CDL item exists, false otherwise.' ;
    rdfs:domain ind:DefectReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:closedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Closed Timestamp' ;
    rdfs:comment 'Date and time when the defect report was formally closed after verification and sign-off. Null if not yet closed.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:defectNumber rdf:type rdf:Property ;
    rdfs:label 'Defect Number' ;
    rdfs:comment 'Business identifier for the defect report, typically generated by AMOS or technical log system. Externally referenced in work orders and maintenance records.' ;
    rdfs:domain ind:DefectReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectStatus rdf:type rdf:Property ;
    rdfs:label 'Defect Status' ;
    rdfs:comment 'Current lifecycle status of the defect report (open - awaiting action, deferred - MEL/CDL deferral applied, rectified - repair completed, closed - verified and signed off, cancelled - invalid report).' ;
    rdfs:domain ind:DefectReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deferralExpiryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Deferral Expiry Timestamp' ;
    rdfs:comment 'Date and time by which the deferred defect must be rectified per MEL/CDL category. Null if not deferred or if defect is already rectified.' ;
    rdfs:domain ind:DefectReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:discoveryPhase rdf:type rdf:Property ;
    rdfs:label 'Discovery Phase' ;
    rdfs:comment 'Operational phase during which the defect was discovered (pre-flight inspection, in-flight, post-flight walk-around, hangar maintenance, line maintenance, or base maintenance check).' ;
    rdfs:domain ind:DefectReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discoveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Discovery Timestamp' ;
    rdfs:comment 'Date and time when the defect was discovered. Principal business event timestamp for the defect lifecycle.' ;
    rdfs:domain ind:DefectReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:melItemReference rdf:type rdf:Property ;
    rdfs:label 'Mel Item Reference' ;
    rdfs:comment 'MEL item number or reference code authorizing deferral of this defect. Null if not deferred under MEL.' ;
    rdfs:domain ind:DefectReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partNumberReplaced rdf:type rdf:Property ;
    rdfs:label 'Part Number Replaced' ;
    rdfs:comment 'Manufacturer part number of the component replaced during rectification. Null if no part replacement occurred.' ;
    rdfs:domain ind:DefectReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rectificationActionDescription rdf:type rdf:Property ;
    rdfs:label 'Rectification Action Description' ;
    rdfs:comment 'Detailed description of the corrective action taken to rectify the defect, including parts replaced, repairs performed, and tests conducted. Null if not yet rectified.' ;
    rdfs:domain ind:DefectReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rectificationStationCode rdf:type rdf:Property ;
    rdfs:label 'Rectification Station Code' ;
    rdfs:comment 'IATA three-letter airport code of the station where the defect was rectified. Null if not yet rectified.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rectificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Rectification Timestamp' ;
    rdfs:comment 'Date and time when the defect rectification work was completed. Null if not yet rectified.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reportedByRole rdf:type rdf:Property ;
    rdfs:label 'Reported By Role' ;
    rdfs:comment 'Role of the person who reported the defect (flight crew, cabin crew, maintenance technician, quality inspector, or engineer).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyReportableFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Reportable Flag' ;
    rdfs:comment 'Indicates whether this defect meets regulatory criteria for mandatory safety occurrence reporting to aviation authorities (FAA, EASA, national CAA). True if reportable, false otherwise.' ;
    rdfs:domain ind:DefectReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serialNumberInstalled rdf:type rdf:Property ;
    rdfs:label 'Serial Number Installed' ;
    rdfs:comment 'Serial number of the serviceable component installed on the aircraft during rectification. Null if no part installation occurred.' ;
    rdfs:domain ind:DefectReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serialNumberRemoved rdf:type rdf:Property ;
    rdfs:label 'Serial Number Removed' ;
    rdfs:comment 'Serial number of the defective component removed from the aircraft. Null if no part removal occurred.' ;
    rdfs:domain ind:DefectReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engineeringOrderId rdf:type rdf:Property ;
    rdfs:label 'Engineering Order Id' ;
    rdfs:comment 'Unique identifier for the engineering order. Primary key.' ;
    rdfs:domain ind:EngineeringOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:implementingCorrectiveActionId rdf:type rdf:Property ;
    rdfs:label 'Implementing Corrective Action Id' ;
    rdfs:comment 'Foreign key linking to safety.corrective_action. Business justification: Engineering orders (modifications, STCs) often implement corrective actions from safety recommendations. Links design changes to safety actions, tracks major modification implementation, and supports ' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CorrectiveAction .

ind:implementingRecommendationId rdf:type rdf:Property ;
    rdfs:label 'Implementing Recommendation Id' ;
    rdfs:comment 'Foreign key linking to safety.recommendation. Business justification: Engineering orders implement design/modification recommendations from safety investigations. Critical for tracking major safety improvements, supports regulatory approval of recommendation-driven modi' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Recommendation .

ind:primaryEngineeringEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Engineering Employee Id' ;
    rdfs:comment 'Employee identifier or license number of the certifying engineer who approved this engineering order.' ;
    rdfs:domain ind:EngineeringOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:camoOrganizationCode rdf:type rdf:Property ;
    rdfs:label 'Camo Organization Code' ;
    rdfs:comment 'EASA Part-M Subpart G CAMO approval number of the organization managing the continuing airworthiness for this engineering order.' ;
    rdfs:domain ind:EngineeringOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceDueDate rdf:type rdf:Property ;
    rdfs:label 'Compliance Due Date' ;
    rdfs:comment 'Calendar date by which this engineering order must be complied with, if a time-based compliance threshold applies.' ;
    rdfs:domain ind:EngineeringOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceDueFlightCycles rdf:type rdf:Property ;
    rdfs:label 'Compliance Due Flight Cycles' ;
    rdfs:comment 'Aircraft total flight cycles at which this engineering order must be complied with, if a cycle-based compliance threshold applies.' ;
    rdfs:domain ind:EngineeringOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceDueFlightHours rdf:type rdf:Property ;
    rdfs:label 'Compliance Due Flight Hours' ;
    rdfs:comment 'Aircraft total flight hours at which this engineering order must be complied with, if a flight-hour-based compliance threshold applies.' ;
    rdfs:domain ind:EngineeringOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:designApprovalReference rdf:type rdf:Property ;
    rdfs:label 'Design Approval Reference' ;
    rdfs:comment 'Reference to the design approval document: EASA Form 1, FAA Form 337, DER (Designated Engineering Representative) approval, or STC number authorizing the modification.' ;
    rdfs:domain ind:EngineeringOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivity rdf:type rdf:Property ;
    rdfs:label 'Effectivity' ;
    rdfs:comment 'Effectivity statement defining which aircraft, serial numbers, or configurations this engineering order applies to (e.g., all aircraft, specific MSN range, or configuration-dependent).' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eoNumber rdf:type rdf:Property ;
    rdfs:label 'Eo Number' ;
    rdfs:comment 'The externally-known business identifier for the engineering order, typically formatted as EO- followed by alphanumeric code.' ;
    rdfs:domain ind:EngineeringOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eoRevision rdf:type rdf:Property ;
    rdfs:label 'Eo Revision' ;
    rdfs:comment 'Revision level of the engineering order, incremented when the order is modified or updated.' ;
    rdfs:domain ind:EngineeringOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eoStatus rdf:type rdf:Property ;
    rdfs:label 'Eo Status' ;
    rdfs:comment 'Current lifecycle status of the engineering order in the approval and execution workflow.' ;
    rdfs:domain ind:EngineeringOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eoType rdf:type rdf:Property ;
    rdfs:label 'Eo Type' ;
    rdfs:comment 'Classification of the engineering order: structural repair, modification, STC (Supplemental Type Certificate), deviation from type design, design change, or service bulletin incorporation.' ;
    rdfs:domain ind:EngineeringOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedCostUsd rdf:type rdf:Property ;
    rdfs:label 'Estimated Cost Usd' ;
    rdfs:comment 'Estimated total cost in US dollars to accomplish the engineering order, including labor, parts, and materials.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modificationDescription rdf:type rdf:Property ;
    rdfs:label 'Modification Description' ;
    rdfs:comment 'Detailed technical description of the structural repair, modification, or deviation being authorized by this engineering order.' ;
    rdfs:domain ind:EngineeringOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relatedAdNumber rdf:type rdf:Property ;
    rdfs:label 'Related Ad Number' ;
    rdfs:comment 'Airworthiness Directive number if this engineering order is issued in response to or in compliance with an AD. Null if not AD-related.' ;
    rdfs:domain ind:EngineeringOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relatedSbNumber rdf:type rdf:Property ;
    rdfs:label 'Related Sb Number' ;
    rdfs:comment 'Manufacturer Service Bulletin number if this engineering order implements or references an SB. Null if not SB-related.' ;
    rdfs:domain ind:EngineeringOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stcNumber rdf:type rdf:Property ;
    rdfs:label 'Stc Number' ;
    rdfs:comment 'STC number if the engineering order implements a supplemental type certificate modification. Null if not applicable.' ;
    rdfs:domain ind:EngineeringOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByEoNumber rdf:type rdf:Property ;
    rdfs:label 'Superseded By Eo Number' ;
    rdfs:comment 'EO number of the engineering order that supersedes this one. Null if not superseded.' ;
    rdfs:domain ind:EngineeringOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastId rdf:type rdf:Property ;
    rdfs:label 'Forecast Id' ;
    rdfs:comment 'Primary key for forecast' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:airworthinessDirectiveNumber rdf:type rdf:Property ;
    rdfs:label 'Airworthiness Directive Number' ;
    rdfs:comment 'Official AD number issued by the aviation authority (FAA, EASA, etc.) when the forecast pertains to a repetitive AD compliance interval.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageDailyUtilizationCycles rdf:type rdf:Property ;
    rdfs:label 'Average Daily Utilization Cycles' ;
    rdfs:comment 'Average flight cycles per day for this aircraft over the recent historical period, used to project future due dates from cycle-based intervals.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calculationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Calculation Timestamp' ;
    rdfs:comment 'Date and time when this forecast record was calculated or last recalculated. Used to track forecast freshness and trigger recalculation cycles.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:confidenceLevel rdf:type rdf:Property ;
    rdfs:label 'Confidence Level' ;
    rdfs:comment 'Qualitative assessment of forecast accuracy based on data quality, utilization stability, and planning assumptions. High indicates stable utilization and reliable data; low indicates volatile operations or incomplete data.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentFlightCycles rdf:type rdf:Property ;
    rdfs:label 'Current Flight Cycles' ;
    rdfs:comment 'Current cumulative flight cycles on the aircraft or component at the time of forecast calculation. Baseline for projecting due thresholds.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:currentFlightHours rdf:type rdf:Property ;
    rdfs:label 'Current Flight Hours' ;
    rdfs:comment 'Current cumulative flight hours on the aircraft or component at the time of forecast calculation. Baseline for projecting due thresholds.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedDowntimeDays rdf:type rdf:Property ;
    rdfs:label 'Estimated Downtime Days' ;
    rdfs:comment 'Projected number of days the aircraft will be out of service (AOG or in maintenance) to complete the forecasted maintenance event.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:forecastStatus rdf:type rdf:Property ;
    rdfs:label 'Forecast Status' ;
    rdfs:comment 'Current lifecycle status of the forecast record. Active forecasts are used for planning; superseded forecasts have been replaced by newer calculations; completed forecasts correspond to executed maintenance events.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastType rdf:type rdf:Property ;
    rdfs:label 'Forecast Type' ;
    rdfs:comment 'Category of maintenance event being forecasted: scheduled check (A/C/D), life-limited part retirement, airworthiness directive repetitive interval, or APU overhaul.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hangarSlotReservationRequired rdf:type rdf:Property ;
    rdfs:label 'Hangar Slot Reservation Required' ;
    rdfs:comment 'Indicates whether this forecasted maintenance event requires advance reservation of hangar capacity and maintenance slots at a Part-145 facility.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maintenanceStationCode rdf:type rdf:Property ;
    rdfs:label 'Maintenance Station Code' ;
    rdfs:comment 'Three-letter IATA or ICAO station code of the planned maintenance facility or base where the forecasted maintenance is expected to be performed.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceTaskCode rdf:type rdf:Property ;
    rdfs:label 'Maintenance Task Code' ;
    rdfs:comment 'Alphanumeric code identifying the specific maintenance task or check from the Maintenance Planning Document (MPD) or maintenance program.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningHorizonDays rdf:type rdf:Property ;
    rdfs:label 'Planning Horizon Days' ;
    rdfs:comment 'Number of days from the forecast calculation date to the projected due date. Indicates how far in advance this maintenance event is being planned.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:projectedDueDate rdf:type rdf:Property ;
    rdfs:label 'Projected Due Date' ;
    rdfs:comment 'Forecasted calendar date when the maintenance event is expected to become due based on current utilization trends and remaining intervals.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:projectedDueFlightCycles rdf:type rdf:Property ;
    rdfs:label 'Projected Due Flight Cycles' ;
    rdfs:comment 'Forecasted cumulative flight cycles (takeoff-landing pairs) at which the maintenance event will become due. Used for cycle-based maintenance intervals.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:projectedDueFlightHours rdf:type rdf:Property ;
    rdfs:label 'Projected Due Flight Hours' ;
    rdfs:comment 'Forecasted cumulative flight hours at which the maintenance event will become due. Used for hour-based maintenance intervals.' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remainingFlightCycles rdf:type rdf:Property ;
    rdfs:label 'Remaining Flight Cycles' ;
    rdfs:comment 'Calculated remaining flight cycles until the maintenance event becomes due (projected_due_flight_cycles minus current_flight_cycles).' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:remainingFlightHours rdf:type rdf:Property ;
    rdfs:label 'Remaining Flight Hours' ;
    rdfs:comment 'Calculated remaining flight hours until the maintenance event becomes due (projected_due_flight_hours minus current_flight_hours).' ;
    rdfs:domain ind:Forecast ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:llpStatusId rdf:type rdf:Property ;
    rdfs:label 'Llp Status Id' ;
    rdfs:comment 'Unique identifier for the life-limited part status record. Primary key.' ;
    rdfs:domain ind:LlpStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:removalWorkOrderId rdf:type rdf:Property ;
    rdfs:label 'Removal Work Order Id' ;
    rdfs:comment 'Reference to the maintenance work order under which the LLP was removed. Provides traceability to the removal event.' ;
    rdfs:domain ind:LlpStatus ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkOrder .

ind:accumulatedLife rdf:type rdf:Property ;
    rdfs:label 'Accumulated Life' ;
    rdfs:comment 'The total life consumed by the LLP since new or since last overhaul, expressed in the unit defined by life_limit_type. Updated after each flight or maintenance event.' ;
    rdfs:domain ind:LlpStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:airworthinessDirectiveCompliance rdf:type rdf:Property ;
    rdfs:label 'Airworthiness Directive Compliance' ;
    rdfs:comment 'Indicates whether the LLP is compliant with all applicable Airworthiness Directives issued by aviation authorities. Non-compliance may ground the aircraft.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertThreshold rdf:type rdf:Property ;
    rdfs:label 'Alert Threshold' ;
    rdfs:comment 'The remaining life value at which maintenance planning alerts are triggered. Typically set to allow sufficient lead time for part procurement and scheduling (e.g., 1000 cycles before limit).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertThresholdPercentage rdf:type rdf:Property ;
    rdfs:label 'Alert Threshold Percentage' ;
    rdfs:comment 'Alert threshold expressed as a percentage of certified life limit. Typically set between 5% and 15% remaining life.' ;
    rdfs:domain ind:LlpStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certifiedLifeLimit rdf:type rdf:Property ;
    rdfs:label 'Certified Life Limit' ;
    rdfs:comment 'The maximum allowable life of the LLP as certified by the manufacturer and approved by the aviation authority. Expressed in the unit defined by life_limit_type (e.g., 20000 cycles, 50000 flight hours). The part MUST be retired at or before this limit.' ;
    rdfs:domain ind:LlpStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:installationCyclesAtInstall rdf:type rdf:Property ;
    rdfs:label 'Installation Cycles At Install' ;
    rdfs:comment 'The accumulated cycles on the LLP at the time of installation on the current aircraft or component. Used to calculate total life consumption.' ;
    rdfs:domain ind:LlpStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:installationFlightNumber rdf:type rdf:Property ;
    rdfs:label 'Installation Flight Number' ;
    rdfs:comment 'Flight number or operational reference at the time of LLP installation. Provides traceability to the installation event.' ;
    rdfs:domain ind:LlpStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastUpdateTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Update Timestamp' ;
    rdfs:comment 'Timestamp when the LLP status record was last updated with new accumulated life data. Critical for data currency verification.' ;
    rdfs:domain ind:LlpStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lifeLimitType rdf:type rdf:Property ;
    rdfs:label 'Life Limit Type' ;
    rdfs:comment 'The unit of measure by which the LLP life is tracked: cycles (takeoff/landing cycles), flight hours, calendar days, or a combination. Defined by the manufacturer and certified by the aviation authority.' ;
    rdfs:domain ind:LlpStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:llpCategory rdf:type rdf:Property ;
    rdfs:label 'Llp Category' ;
    rdfs:comment 'Classification of the LLP by component type. Engine LLPs (discs, shafts, hubs) and landing gear components are the most common.' ;
    rdfs:domain ind:LlpStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:llpStatusStatus rdf:type rdf:Property ;
    rdfs:label 'Llp Status Status' ;
    rdfs:comment 'Current operational status of the LLP: serviceable (within normal operating range), alert (approaching threshold), critical (near limit), expired (at or beyond limit, must be removed), removed (no longer installed).' ;
    rdfs:domain ind:LlpStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextInspectionDueLife rdf:type rdf:Property ;
    rdfs:label 'Next Inspection Due Life' ;
    rdfs:comment 'The accumulated life value at which the next scheduled inspection of the LLP is due. May be required before the certified life limit.' ;
    rdfs:domain ind:LlpStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overhaulCount rdf:type rdf:Property ;
    rdfs:label 'Overhaul Count' ;
    rdfs:comment 'Number of times the LLP has been overhauled or refurbished. Some LLPs may be overhauled with life extension, others are single-life components.' ;
    rdfs:domain ind:LlpStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:remainingLife rdf:type rdf:Property ;
    rdfs:label 'Remaining Life' ;
    rdfs:comment 'The remaining life before the LLP reaches its certified limit, calculated as certified_life_limit minus accumulated_life. Critical for maintenance planning and AOG prevention.' ;
    rdfs:domain ind:LlpStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:remainingLifePercentage rdf:type rdf:Property ;
    rdfs:label 'Remaining Life Percentage' ;
    rdfs:comment 'Percentage of remaining life relative to the certified limit, calculated as (remaining_life / certified_life_limit) * 100. Used for threshold alerting and planning.' ;
    rdfs:domain ind:LlpStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceBulletinCompliance rdf:type rdf:Property ;
    rdfs:label 'Service Bulletin Compliance' ;
    rdfs:comment 'Indicates whether the LLP is compliant with all applicable manufacturer Service Bulletins. Some SBs are mandatory for continued airworthiness.' ;
    rdfs:domain ind:LlpStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialRequestId rdf:type rdf:Property ;
    rdfs:label 'Material Request Id' ;
    rdfs:comment 'Primary key for material_request' ;
    rdfs:domain ind:MaterialRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryMaterialRequestorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Material Requestor Employee Id' ;
    rdfs:comment 'Identifier of the maintenance planner, technician, or engineer who raised the material requisition.' ;
    rdfs:domain ind:MaterialRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryMaterialEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Material Employee Id' ;
    rdfs:comment 'System user identifier of the person who last modified this material request record.' ;
    rdfs:domain ind:MaterialRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:partDescription rdf:type rdf:Property ;
    rdfs:label 'Part Description' ;
    rdfs:comment 'Detailed textual description of the part, consumable, or tooling item being requested to aid identification and verification.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityIssued rdf:type rdf:Property ;
    rdfs:label 'Quantity Issued' ;
    rdfs:comment 'The actual quantity of the part or material issued from stores to fulfil this request. May differ from quantity requested due to partial fulfilment or substitution.' ;
    rdfs:domain ind:MaterialRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityRequested rdf:type rdf:Property ;
    rdfs:label 'Quantity Requested' ;
    rdfs:comment 'The quantity of the part or material requested for the maintenance work order.' ;
    rdfs:domain ind:MaterialRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requestedDate rdf:type rdf:Property ;
    rdfs:label 'Requested Date' ;
    rdfs:comment 'The date when the material requisition was created and submitted by the maintenance planner or technician.' ;
    rdfs:domain ind:MaterialRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requiredByDate rdf:type rdf:Property ;
    rdfs:label 'Required By Date' ;
    rdfs:comment 'The target date by which the material must be available to support the scheduled maintenance work order execution.' ;
    rdfs:domain ind:MaterialRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requisitionNumber rdf:type rdf:Property ;
    rdfs:label 'Requisition Number' ;
    rdfs:comment 'Externally-known unique requisition number assigned to this material request for tracking and reference purposes.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnQuantity rdf:type rdf:Property ;
    rdfs:label 'Return Quantity' ;
    rdfs:comment 'The quantity of material returned to store if the full issued quantity was not consumed during maintenance execution.' ;
    rdfs:domain ind:MaterialRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnToStoreFlag rdf:type rdf:Property ;
    rdfs:label 'Return To Store Flag' ;
    rdfs:comment 'Indicates whether unused material from this requisition was returned to store inventory after work order completion.' ;
    rdfs:domain ind:MaterialRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:storeLocationCode rdf:type rdf:Property ;
    rdfs:label 'Store Location Code' ;
    rdfs:comment 'Code identifying the warehouse, store, or inventory location from which the material is to be issued.' ;
    rdfs:domain ind:MaterialRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substitutePartNumber rdf:type rdf:Property ;
    rdfs:label 'Substitute Part Number' ;
    rdfs:comment 'The part number of the substitute material that was issued if the originally requested part was unavailable.' ;
    rdfs:domain ind:MaterialRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:substitutionFlag rdf:type rdf:Property ;
    rdfs:label 'Substitution Flag' ;
    rdfs:comment 'Indicates whether an alternative or substitute part was issued in place of the originally requested part number.' ;
    rdfs:domain ind:MaterialRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalCost rdf:type rdf:Property ;
    rdfs:label 'Total Cost' ;
    rdfs:comment 'The total cost of the material requisition calculated as quantity issued multiplied by unit cost.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitCost rdf:type rdf:Property ;
    rdfs:label 'Unit Cost' ;
    rdfs:comment 'The cost per unit of the material at the time of requisition, used for inventory valuation and cost tracking.' ;
    rdfs:domain ind:MaterialRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:melDeferralId rdf:type rdf:Property ;
    rdfs:label 'Mel Deferral Id' ;
    rdfs:comment 'Unique identifier for the MEL deferral instance. Primary key.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MelDeferral .

ind:acceptingCommanderCrewMemberId rdf:type rdf:Property ;
    rdfs:label 'Accepting Commander Crew Member Id' ;
    rdfs:comment 'Foreign key linking to crew.crew_member. Business justification: Commander accepts MEL deferral and operational restrictions before flight. Business process: crew acceptance of deferred defects, operational decision tracking, regulatory compliance (commander must a' ;
    rdfs:domain ind:MelDeferral ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Member .

ind:deferralStationId rdf:type rdf:Property ;
    rdfs:label 'Deferral Station Id' ;
    rdfs:comment 'Foreign key linking to airport.station. Business justification: MEL deferrals opened at specific stations. Links deferral_station_code to station.station_id for regulatory compliance tracking by location, identifying stations with high deferral rates, and ensuring' ;
    rdfs:domain ind:MelDeferral ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Station .

ind:maintenanceMelItemId rdf:type rdf:Property ;
    rdfs:label 'Maintenance Mel Item Id' ;
    rdfs:comment 'Foreign key linking to maintenance.mel_item. Business justification: MEL deferral is based on a MEL item definition. The mel_deferral table has mel_item_reference (STRING) but no FK. Adding maintenance_mel_item_id FK normalizes this and removes redundant mel_item_refer' ;
    rdfs:domain ind:MelDeferral ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MelItem .

ind:primaryMelCertifyingStaffId rdf:type rdf:Property ;
    rdfs:label 'Primary Mel Certifying Staff Id' ;
    rdfs:comment 'Identifier of the Part-145 certified maintenance engineer or certifying staff who authorized the MEL deferral.' ;
    rdfs:domain ind:MelDeferral ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CertifyingStaff .

ind:aogRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Aog Risk Flag' ;
    rdfs:comment 'Boolean flag indicating whether this deferral poses a high risk of causing an AOG event if not rectified promptly (true) or not (false).' ;
    rdfs:domain ind:MelDeferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certifyingStaffLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Certifying Staff License Number' ;
    rdfs:comment 'The license or authorization number of the certifying staff who approved the deferral.' ;
    rdfs:domain ind:MelDeferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureRemarks rdf:type rdf:Property ;
    rdfs:label 'Closure Remarks' ;
    rdfs:comment 'Free-text remarks or notes recorded when the deferral was closed, including any follow-up actions or observations.' ;
    rdfs:domain ind:MelDeferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deferralDescription rdf:type rdf:Property ;
    rdfs:label 'Deferral Description' ;
    rdfs:comment 'Free-text description of the inoperative item and the nature of the deferral, including any operational restrictions or procedures.' ;
    rdfs:domain ind:MelDeferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deferralOpenDate rdf:type rdf:Property ;
    rdfs:label 'Deferral Open Date' ;
    rdfs:comment 'The date on which the MEL deferral was opened and the item was deferred from service.' ;
    rdfs:domain ind:MelDeferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deferralOpenTimestamp rdf:type rdf:Property ;
    rdfs:label 'Deferral Open Timestamp' ;
    rdfs:comment 'The precise timestamp when the MEL deferral was opened in the maintenance system.' ;
    rdfs:domain ind:MelDeferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deferralStatus rdf:type rdf:Property ;
    rdfs:label 'Deferral Status' ;
    rdfs:comment 'Current lifecycle status of the MEL deferral: open (active), extended (interval extended), rectified (repair completed), closed (administratively closed), expired (exceeded allowed interval).' ;
    rdfs:domain ind:MelDeferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:extensionAuthority rdf:type rdf:Property ;
    rdfs:label 'Extension Authority' ;
    rdfs:comment 'The name or identifier of the authority (e.g., Chief Engineer, Maintenance Control) who approved the deferral extension.' ;
    rdfs:domain ind:MelDeferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:extensionCount rdf:type rdf:Property ;
    rdfs:label 'Extension Count' ;
    rdfs:comment 'The number of times the deferral expiry date has been extended beyond the original MEL category interval.' ;
    rdfs:domain ind:MelDeferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:flightCyclesAtDeferral rdf:type rdf:Property ;
    rdfs:label 'Flight Cycles At Deferral' ;
    rdfs:comment 'The total accumulated flight cycles (takeoff-landing cycles) on the aircraft at the time the MEL deferral was opened.' ;
    rdfs:domain ind:MelDeferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:flightHoursAtDeferral rdf:type rdf:Property ;
    rdfs:label 'Flight Hours At Deferral' ;
    rdfs:comment 'The total accumulated flight hours (block hours) on the aircraft at the time the MEL deferral was opened.' ;
    rdfs:domain ind:MelDeferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastExtensionDate rdf:type rdf:Property ;
    rdfs:label 'Last Extension Date' ;
    rdfs:comment 'The date of the most recent extension of the deferral expiry date. Null if never extended.' ;
    rdfs:domain ind:MelDeferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maintenanceProceduresApplied rdf:type rdf:Property ;
    rdfs:label 'Maintenance Procedures Applied' ;
    rdfs:comment 'Description of any maintenance procedures or placarding actions performed when the deferral was opened (e.g., circuit breaker collared, placard installed).' ;
    rdfs:domain ind:MelDeferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationalRestrictions rdf:type rdf:Property ;
    rdfs:label 'Operational Restrictions' ;
    rdfs:comment 'Specific operational restrictions or limitations imposed by the MEL deferral (e.g., flight altitude limits, route restrictions, weather minimums).' ;
    rdfs:domain ind:MelDeferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rectificationDate rdf:type rdf:Property ;
    rdfs:label 'Rectification Date' ;
    rdfs:comment 'The date on which the deferred item was rectified and returned to service. Null if not yet rectified.' ;
    rdfs:domain ind:MelDeferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryNotificationRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Required' ;
    rdfs:comment 'Boolean flag indicating whether this deferral requires notification to the civil aviation authority (true) or not (false).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:melItemId rdf:type rdf:Property ;
    rdfs:label 'Mel Item Id' ;
    rdfs:comment 'Primary key for mel_item' ;
    rdfs:domain ind:MelItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ataSection rdf:type rdf:Property ;
    rdfs:label 'Ata Section' ;
    rdfs:comment 'Two-digit ATA section code within the chapter, providing finer system categorization.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ataSubject rdf:type rdf:Property ;
    rdfs:label 'Ata Subject' ;
    rdfs:comment 'Two-digit ATA subject code providing the most granular system classification.' ;
    rdfs:domain ind:MelItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deferralCategory rdf:type rdf:Property ;
    rdfs:label 'Deferral Category' ;
    rdfs:comment 'The MEL category defining the maximum time an item may remain inoperative: A (no time limit with conditions), B (3 consecutive calendar days), C (10 consecutive calendar days), D (120 consecutive calendar days).' ;
    rdfs:domain ind:MelItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatchConditions rdf:type rdf:Property ;
    rdfs:label 'Dispatch Conditions' ;
    rdfs:comment 'Additional conditions or restrictions for dispatch with this item inoperative (e.g., \'Day VFR only\', \'Maximum altitude FL250\', \'Reduced passenger capacity\').' ;
    rdfs:domain ind:MelItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceProcedures rdf:type rdf:Property ;
    rdfs:label 'Maintenance Procedures' ;
    rdfs:comment 'Specific maintenance actions required before dispatch with this item inoperative (e.g., \'Deactivate and placard\', \'Secure and stow equipment\').' ;
    rdfs:domain ind:MelItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumDeferralDays rdf:type rdf:Property ;
    rdfs:label 'Maximum Deferral Days' ;
    rdfs:comment 'The maximum number of consecutive calendar days the item may remain inoperative before rectification is required. Null for Category A items with no time limit.' ;
    rdfs:domain ind:MelItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:melItemNumber rdf:type rdf:Property ;
    rdfs:label 'Mel Item Number' ;
    rdfs:comment 'The unique MEL item number following ATA chapter structure (e.g., 21-31-01, 34-12-02A). This is the externally-known identifier for the MEL item.' ;
    rdfs:domain ind:MelItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:melItemStatus rdf:type rdf:Property ;
    rdfs:label 'Mel Item Status' ;
    rdfs:comment 'Current lifecycle status of this MEL item configuration: active (in use), superseded (replaced by newer revision), withdrawn (no longer applicable), pending_approval (awaiting regulatory acceptance).' ;
    rdfs:domain ind:MelItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mmelReference rdf:type rdf:Property ;
    rdfs:label 'Mmel Reference' ;
    rdfs:comment 'Reference to the corresponding Master MEL item number and revision from the aircraft manufacturer or regulatory authority MMEL document.' ;
    rdfs:domain ind:MelItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mmelRevisionDate rdf:type rdf:Property ;
    rdfs:label 'Mmel Revision Date' ;
    rdfs:comment 'The effective date of the MMEL revision from which this MEL item was derived.' ;
    rdfs:domain ind:MelItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:numberInstalled rdf:type rdf:Property ;
    rdfs:label 'Number Installed' ;
    rdfs:comment 'The total number of units of this system or component installed on the aircraft type.' ;
    rdfs:domain ind:MelItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numberRequiredDispatch rdf:type rdf:Property ;
    rdfs:label 'Number Required Dispatch' ;
    rdfs:comment 'The minimum number of units that must be operative for the aircraft to be dispatched under this MEL item.' ;
    rdfs:domain ind:MelItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operationalProcedures rdf:type rdf:Property ;
    rdfs:label 'Operational Procedures' ;
    rdfs:comment 'Specific operational procedures, limitations, or restrictions that flight crew must follow when dispatching with this item inoperative (e.g., \'Flight in icing conditions prohibited\').' ;
    rdfs:domain ind:MelItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatorMelRevision rdf:type rdf:Property ;
    rdfs:label 'Operator Mel Revision' ;
    rdfs:comment 'The operator-specific MEL document revision number under which this item is published.' ;
    rdfs:domain ind:MelItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:placardLocation rdf:type rdf:Property ;
    rdfs:label 'Placard Location' ;
    rdfs:comment 'The specific location where the placard must be installed (e.g., \'Overhead panel\', \'Seat 12A armrest\', \'Flight deck door\').' ;
    rdfs:domain ind:MelItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:placardRequired rdf:type rdf:Property ;
    rdfs:label 'Placard Required' ;
    rdfs:comment 'Indicates whether a placard must be installed in the cockpit or cabin to inform crew of the inoperative item.' ;
    rdfs:domain ind:MelItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:placardText rdf:type rdf:Property ;
    rdfs:label 'Placard Text' ;
    rdfs:comment 'The exact text that must appear on the placard if placard_required is true (e.g., \'INOP\', \'DO NOT USE\').' ;
    rdfs:domain ind:MelItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryApprovalReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Reference' ;
    rdfs:comment 'Reference to the regulatory authority approval document or letter of acceptance for this MEL item (e.g., FAA OpSpec D085, EASA Part-CAT approval).' ;
    rdfs:domain ind:MelItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programId rdf:type rdf:Property ;
    rdfs:label 'Program Id' ;
    rdfs:comment 'Primary key for program' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Program .

ind:adComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Ad Compliance Status' ;
    rdfs:comment 'Overall compliance status of Airworthiness Directives (ADs) incorporated into this maintenance program.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aocNumber rdf:type rdf:Property ;
    rdfs:label 'Aoc Number' ;
    rdfs:comment 'Air Operator Certificate number under which this maintenance program is approved and operated.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:camoOrganization rdf:type rdf:Property ;
    rdfs:label 'Camo Organization' ;
    rdfs:comment 'Name or identifier of the EASA Part-M Subpart G CAMO responsible for managing the continuing airworthiness under this program.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivityConfiguration rdf:type rdf:Property ;
    rdfs:label 'Effectivity Configuration' ;
    rdfs:comment 'Specific aircraft configuration, modification state, or service bulletin incorporation status defining the applicability of this maintenance program.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivitySerialNumbers rdf:type rdf:Property ;
    rdfs:label 'Effectivity Serial Numbers' ;
    rdfs:comment 'Comma-separated list or range of aircraft manufacturer serial numbers (MSN) to which this maintenance program applies. Null for type-level programs applicable to all aircraft of the type.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationApprovalReference rdf:type rdf:Property ;
    rdfs:label 'Escalation Approval Reference' ;
    rdfs:comment 'Regulatory approval reference for any interval escalation applied to this maintenance program. Null if no escalation.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationFactor rdf:type rdf:Property ;
    rdfs:label 'Escalation Factor' ;
    rdfs:comment 'Multiplier applied to maintenance intervals for escalation purposes (e.g., 1.05 for 5% escalation). Null if no escalation is approved.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:intervalStructure rdf:type rdf:Property ;
    rdfs:label 'Interval Structure' ;
    rdfs:comment 'Primary interval structure used by this maintenance program to schedule tasks: flight hours (FH), flight cycles (FC), calendar days (DY), or combined thresholds.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedBy rdf:type rdf:Property ;
    rdfs:label 'Modified By' ;
    rdfs:comment 'User identifier or name of the person who last modified this maintenance program record.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mpdBaseline rdf:type rdf:Property ;
    rdfs:label 'Mpd Baseline' ;
    rdfs:comment 'Manufacturer\'s Maintenance Planning Document (MPD) baseline version or revision that forms the foundation of this approved maintenance program (e.g., \'Boeing D622W001 Rev 45\', \'Airbus A320 MPD Rev 38\').' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatorName rdf:type rdf:Property ;
    rdfs:label 'Operator Name' ;
    rdfs:comment 'Legal name of the airline or aircraft operator to whom this maintenance program is issued and approved.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:part145Organization rdf:type rdf:Property ;
    rdfs:label 'Part 145 Organization' ;
    rdfs:comment 'Name or identifier of the EASA Part-145 or FAA Part 145 approved maintenance organization responsible for executing this maintenance program.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programDescription rdf:type rdf:Property ;
    rdfs:label 'Program Description' ;
    rdfs:comment 'Detailed textual description of the maintenance program scope, objectives, and key features.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reliabilityProgramReference rdf:type rdf:Property ;
    rdfs:label 'Reliability Program Reference' ;
    rdfs:comment 'Reference to the associated aircraft reliability program or monitoring system that feeds data into maintenance program adjustments.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revision rdf:type rdf:Property ;
    rdfs:label 'Revision' ;
    rdfs:comment 'Revision or version identifier of the maintenance program as approved by the regulatory authority (e.g., \'Rev 12\', \'2023-01\', \'V3.5\').' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sbIncorporationStatus rdf:type rdf:Property ;
    rdfs:label 'Sb Incorporation Status' ;
    rdfs:comment 'Status of manufacturer Service Bulletin (SB) incorporation into this maintenance program.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseId rdf:type rdf:Property ;
    rdfs:label 'Release Id' ;
    rdfs:comment 'Primary key for release' ;
    rdfs:domain ind:Release ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:aircraftTotalCyclesAtRelease rdf:type rdf:Property ;
    rdfs:label 'Aircraft Total Cycles At Release' ;
    rdfs:comment 'Cumulative total flight cycles (takeoff and landing pairs) recorded on the aircraft at the time of release to service. Used for fatigue-sensitive component life tracking.' ;
    rdfs:domain ind:Release ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:aircraftTotalHoursAtRelease rdf:type rdf:Property ;
    rdfs:label 'Aircraft Total Hours At Release' ;
    rdfs:comment 'Cumulative total flight hours (block hours) recorded on the aircraft at the time of release to service. Critical for life-limited parts tracking and maintenance interval calculations.' ;
    rdfs:domain ind:Release ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:certifyingStaffAuthorizationReference rdf:type rdf:Property ;
    rdfs:label 'Certifying Staff Authorization Reference' ;
    rdfs:comment 'Internal authorization or stamp number issued by the Part-145 organization to the certifying staff, confirming their scope of approval within the AMO.' ;
    rdfs:domain ind:Release ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentCyclesAtRelease rdf:type rdf:Property ;
    rdfs:label 'Component Cycles At Release' ;
    rdfs:comment 'Total operating cycles accumulated on the component at the time of release, applicable for component-level maintenance releases. Tracks cycles-since-new or cycles-since-overhaul.' ;
    rdfs:domain ind:Release ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:componentHoursAtRelease rdf:type rdf:Property ;
    rdfs:label 'Component Hours At Release' ;
    rdfs:comment 'Total operating hours accumulated on the component at the time of release, applicable for component-level maintenance releases. Tracks time-since-new or time-since-overhaul.' ;
    rdfs:domain ind:Release ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:crsNumber rdf:type rdf:Property ;
    rdfs:label 'Crs Number' ;
    rdfs:comment 'Unique externally-known certificate number issued by the Part-145 approved maintenance organization certifying airworthiness release. Legally mandated document identifier.' ;
    rdfs:domain ind:Release ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalSignatureHash rdf:type rdf:Property ;
    rdfs:label 'Digital Signature Hash' ;
    rdfs:comment 'Cryptographic hash of the digital signature applied to the electronic CRS document, ensuring authenticity and non-repudiation of the release certification.' ;
    rdfs:domain ind:Release ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceType rdf:type rdf:Property ;
    rdfs:label 'Maintenance Type' ;
    rdfs:comment 'Classification of the maintenance activity certified by this release: scheduled check, unscheduled defect repair, airworthiness directive compliance, service bulletin incorporation, MEL rectification, AOG recovery, component overhaul, or aircraft modification. [ENUM-REF-CANDIDATE: scheduled|unscheduled|ad_compliance|sb_incorporation|mel_deferral_rectification|aog_recovery|component_overhaul|modification — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Release ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextDueCycles rdf:type rdf:Property ;
    rdfs:label 'Next Due Cycles' ;
    rdfs:comment 'Aircraft total cycles at which the next scheduled maintenance action is due, as established or updated by this release. Used for maintenance planning and scheduling.' ;
    rdfs:domain ind:Release ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextDueHours rdf:type rdf:Property ;
    rdfs:label 'Next Due Hours' ;
    rdfs:comment 'Aircraft total hours at which the next scheduled maintenance action is due, as established or updated by this release. Used for maintenance planning and scheduling.' ;
    rdfs:domain ind:Release ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:openItemsDescription rdf:type rdf:Property ;
    rdfs:label 'Open Items Description' ;
    rdfs:comment 'Description of any open maintenance items, deferred defects, or limitations that remain after this release. Documents any MEL deferrals or work not completed that affect operational capability.' ;
    rdfs:domain ind:Release ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationalLimitations rdf:type rdf:Property ;
    rdfs:label 'Operational Limitations' ;
    rdfs:comment 'Any operational restrictions or limitations imposed on the aircraft or component as a result of the maintenance performed or deferred items. May include speed, altitude, or route restrictions.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseCategory rdf:type rdf:Property ;
    rdfs:label 'Release Category' ;
    rdfs:comment 'Category of asset for which this release to service is issued: complete aircraft, engine, APU (Auxiliary Power Unit), line-replaceable component, or cabin interior.' ;
    rdfs:domain ind:Release ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeOfWorkDescription rdf:type rdf:Property ;
    rdfs:label 'Scope Of Work Description' ;
    rdfs:comment 'Detailed narrative description of the maintenance tasks, inspections, repairs, modifications, or component replacements performed under this release. Summarizes the work certified as airworthy.' ;
    rdfs:domain ind:Release ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reliabilityEventId rdf:type rdf:Property ;
    rdfs:label 'Reliability Event Id' ;
    rdfs:comment 'Unique identifier for the reliability event record. Primary key for the reliability event entity.' ;
    rdfs:domain ind:ReliabilityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:partMasterId rdf:type rdf:Property ;
    rdfs:label 'Part Master Id' ;
    rdfs:comment 'Foreign key linking to procurement.part_master. Business justification: Captures which part number experienced reliability event (delay, repeat defect) for MSG-3 analysis and manufacturer notification. Real process: reliability engineers analyze event rates by part number' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PartMaster .

ind:aircraftTotalCyclesAtEvent rdf:type rdf:Property ;
    rdfs:label 'Aircraft Total Cycles At Event' ;
    rdfs:comment 'The cumulative total flight cycles (takeoff/landing cycles) of the aircraft at the time the reliability event occurred.' ;
    rdfs:domain ind:ReliabilityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:aircraftTotalHoursAtEvent rdf:type rdf:Property ;
    rdfs:label 'Aircraft Total Hours At Event' ;
    rdfs:comment 'The cumulative total flight hours (airframe hours) of the aircraft at the time the reliability event occurred.' ;
    rdfs:domain ind:ReliabilityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:alertLevel rdf:type rdf:Property ;
    rdfs:label 'Alert Level' ;
    rdfs:comment 'The alert level assigned to this reliability event based on frequency and severity thresholds: green (within normal limits), amber (approaching alert threshold), red (exceeds alert threshold, requires immediate action).' ;
    rdfs:domain ind:ReliabilityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chronicEventFlag rdf:type rdf:Property ;
    rdfs:label 'Chronic Event Flag' ;
    rdfs:comment 'Boolean indicator (True/False) identifying whether this reliability event is part of a chronic (recurring) reliability issue requiring fleet-wide attention or MSG-3 task review.' ;
    rdfs:domain ind:ReliabilityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:correctiveAction rdf:type rdf:Property ;
    rdfs:label 'Corrective Action' ;
    rdfs:comment 'Description of the corrective maintenance action or operational procedure change implemented to resolve the reliability event and prevent recurrence.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventDate rdf:type rdf:Property ;
    rdfs:label 'Event Date' ;
    rdfs:comment 'The calendar date on which the reliability event occurred (format: yyyy-MM-dd).' ;
    rdfs:domain ind:ReliabilityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:manufacturerSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Serial Number' ;
    rdfs:comment 'The unique serial number assigned by the aircraft manufacturer to this specific airframe.' ;
    rdfs:domain ind:ReliabilityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:msg3TaskReference rdf:type rdf:Property ;
    rdfs:label 'Msg3 Task Reference' ;
    rdfs:comment 'Reference to the MSG-3 scheduled maintenance task that may require effectiveness review based on this reliability event.' ;
    rdfs:domain ind:ReliabilityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pirepReference rdf:type rdf:Property ;
    rdfs:label 'Pirep Reference' ;
    rdfs:comment 'Reference number or identifier of the pilot report (PIREP) that documented the in-flight reliability event.' ;
    rdfs:domain ind:ReliabilityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repeatEventFlag rdf:type rdf:Property ;
    rdfs:label 'Repeat Event Flag' ;
    rdfs:comment 'Boolean indicator (True/False) identifying whether this reliability event is a repeat occurrence of a previously reported issue on the same aircraft or component.' ;
    rdfs:domain ind:ReliabilityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportingPeriod rdf:type rdf:Property ;
    rdfs:label 'Reporting Period' ;
    rdfs:comment 'The year-month reporting period for monthly reliability reporting aggregation (format: YYYY-MM).' ;
    rdfs:domain ind:ReliabilityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceBulletinId rdf:type rdf:Property ;
    rdfs:label 'Service Bulletin Id' ;
    rdfs:comment 'Unique identifier for the service bulletin record. Primary key.' ;
    rdfs:domain ind:ServiceBulletin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:associatedMaintenanceMaintenanceAirworthinessDirectiveId rdf:type rdf:Property ;
    rdfs:label 'Associated Maintenance Maintenance Airworthiness Directive Id' ;
    rdfs:comment 'Foreign key linking to maintenance.airworthiness_directive. Business justification: Service bulletin may be associated with an airworthiness directive. The service_bulletin table has associated_ad_number (STRING) but no FK. Adding associated_maintenance_airworthiness_directive_id FK ' ;
    rdfs:domain ind:ServiceBulletin ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AirworthinessDirective .

ind:aircraftModelApplicability rdf:type rdf:Property ;
    rdfs:label 'Aircraft Model Applicability' ;
    rdfs:comment 'Aircraft model designations to which this service bulletin applies (e.g., \'A320-200\', \'Boeing 737-800\', \'Embraer E190\'). May include multiple models separated by commas.' ;
    rdfs:domain ind:ServiceBulletin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bulletinCategory rdf:type rdf:Property ;
    rdfs:label 'Bulletin Category' ;
    rdfs:comment 'Classification of the service bulletin indicating the urgency and compliance requirement. Mandatory bulletins are typically linked to Airworthiness Directives (ADs), while Recommended and Optional bulletins are at operator discretion.' ;
    rdfs:domain ind:ServiceBulletin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bulletinNumber rdf:type rdf:Property ;
    rdfs:label 'Bulletin Number' ;
    rdfs:comment 'Official service bulletin number issued by the Original Equipment Manufacturer (OEM). Format varies by manufacturer (e.g., Boeing SB format: 737-57-1234, Airbus SB format: A320-32-1045).' ;
    rdfs:domain ind:ServiceBulletin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bulletinTitle rdf:type rdf:Property ;
    rdfs:label 'Bulletin Title' ;
    rdfs:comment 'Descriptive title of the service bulletin summarizing the subject matter and purpose of the modification or inspection.' ;
    rdfs:domain ind:ServiceBulletin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bulletinType rdf:type rdf:Property ;
    rdfs:label 'Bulletin Type' ;
    rdfs:comment 'Type of technical communication issued by the OEM. Service Bulletins are formal modification instructions, Service Letters are informational, Alert Service Bulletins address urgent safety issues.' ;
    rdfs:domain ind:ServiceBulletin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Compliance Completion Date' ;
    rdfs:comment 'Date when compliance with the service bulletin was completed across the applicable fleet. Null if compliance is not yet complete. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:ServiceBulletin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceThreshold rdf:type rdf:Property ;
    rdfs:label 'Compliance Threshold' ;
    rdfs:comment 'Compliance deadline or threshold expressed in flight hours, flight cycles, calendar time, or next scheduled maintenance event (e.g., \'Within 12 months\', \'Before 10,000 flight hours\', \'At next C-Check\').' ;
    rdfs:domain ind:ServiceBulletin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engineModelApplicability rdf:type rdf:Property ;
    rdfs:label 'Engine Model Applicability' ;
    rdfs:comment 'Engine model designations to which this service bulletin applies (e.g., \'CFM56-5B\', \'PW1100G\', \'Trent 1000\'). Null if bulletin does not apply to engines.' ;
    rdfs:domain ind:ServiceBulletin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedManHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Man Hours' ;
    rdfs:comment 'OEM-estimated labor hours required to complete the service bulletin task. Used for maintenance planning and cost estimation.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isActive rdf:type rdf:Property ;
    rdfs:label 'Is Active' ;
    rdfs:comment 'Indicates whether the service bulletin is currently active and applicable. False if the bulletin has been superseded, cancelled, or completed across the fleet.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:oemName rdf:type rdf:Property ;
    rdfs:label 'Oem Name' ;
    rdfs:comment 'Name of the manufacturer or supplier that issued the service bulletin (e.g., Airbus, Boeing, CFM International, Pratt & Whitney). [ENUM-REF-CANDIDATE: Airbus|Boeing|Bombardier|Embraer|ATR|CFM International|Pratt & Whitney|Rolls-Royce|General Electric|Honeywell|Collins Aerospace|Safran|Thales|Liebherr|Goodrich — 15 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ServiceBulletin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partNumbersAffected rdf:type rdf:Property ;
    rdfs:label 'Part Numbers Affected' ;
    rdfs:comment 'Comma-separated list of part numbers (P/N) affected by this service bulletin. Identifies components requiring modification, inspection, or replacement.' ;
    rdfs:domain ind:ServiceBulletin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonForIssue rdf:type rdf:Property ;
    rdfs:label 'Reason For Issue' ;
    rdfs:comment 'Business or technical justification for issuing the service bulletin (e.g., \'Prevent premature wear\', \'Improve reliability\', \'Address safety concern\', \'Regulatory compliance\').' ;
    rdfs:domain ind:ServiceBulletin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relatedBulletinNumbers rdf:type rdf:Property ;
    rdfs:label 'Related Bulletin Numbers' ;
    rdfs:comment 'Comma-separated list of related service bulletin numbers that should be reviewed or implemented in conjunction with this bulletin.' ;
    rdfs:domain ind:ServiceBulletin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionDate rdf:type rdf:Property ;
    rdfs:label 'Revision Date' ;
    rdfs:comment 'Date of the most recent revision to the service bulletin. Null if no revisions have been issued. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:ServiceBulletin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:supersededBulletinNumber rdf:type rdf:Property ;
    rdfs:label 'Superseded Bulletin Number' ;
    rdfs:comment 'Service bulletin number that this bulletin supersedes or replaces. Null if this is the original bulletin with no predecessor.' ;
    rdfs:domain ind:ServiceBulletin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalDescription rdf:type rdf:Property ;
    rdfs:label 'Technical Description' ;
    rdfs:comment 'Detailed technical description of the modification, inspection, or replacement procedure outlined in the service bulletin. Summarizes the work scope and technical rationale.' ;
    rdfs:domain ind:ServiceBulletin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalLogId rdf:type rdf:Property ;
    rdfs:label 'Technical Log Id' ;
    rdfs:comment 'Unique identifier for the aircraft technical log sector page record. Primary key.' ;
    rdfs:domain ind:TechnicalLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:commanderCrewMemberId rdf:type rdf:Property ;
    rdfs:label 'Commander Crew Member Id' ;
    rdfs:comment 'Foreign key linking to crew.crew_member. Business justification: Aircraft commander signs technical log accepting aircraft airworthiness. Complements employee_id with crew operational context. Business process: commander accountability for airworthiness acceptance,' ;
    rdfs:domain ind:TechnicalLog ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Member .

ind:departureStationId rdf:type rdf:Property ;
    rdfs:label 'Departure Station Id' ;
    rdfs:comment 'Foreign key linking to airport.station. Business justification: Technical logs record aircraft status at departure station. Links departure_station_code to station.station_id for airworthiness tracking by location, pre-flight inspection quality monitoring, and reg' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Station .

ind:maintenanceReleaseId rdf:type rdf:Property ;
    rdfs:label 'Maintenance Release Id' ;
    rdfs:comment 'Foreign key linking to maintenance.release. Business justification: Technical log references a Certificate of Release to Service. The technical_log table has crs_reference_number (STRING) but no FK. Adding maintenance_release_id FK normalizes this and removes redundan' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Release .

ind:aircraftTotalCycles rdf:type rdf:Property ;
    rdfs:label 'Aircraft Total Cycles' ;
    rdfs:comment 'The cumulative total flight cycles (takeoff and landing pairs) at the end of this sector. Critical for fatigue-sensitive component life tracking.' ;
    rdfs:domain ind:TechnicalLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:aircraftTotalHours rdf:type rdf:Property ;
    rdfs:label 'Aircraft Total Hours' ;
    rdfs:comment 'The cumulative total airframe hours at the end of this sector. Critical for maintenance scheduling and airworthiness compliance.' ;
    rdfs:domain ind:TechnicalLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:arrivalStationCode rdf:type rdf:Property ;
    rdfs:label 'Arrival Station Code' ;
    rdfs:comment 'The three-letter IATA airport code for the arrival station (e.g., LHR, JFK, SIN).' ;
    rdfs:domain ind:TechnicalLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockOffTimestamp rdf:type rdf:Property ;
    rdfs:label 'Block Off Timestamp' ;
    rdfs:comment 'The timestamp when the aircraft pushed back from the gate or commenced taxi for departure (Out time in OOOI). Marks the start of block hours.' ;
    rdfs:domain ind:TechnicalLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:blockOnTimestamp rdf:type rdf:Property ;
    rdfs:label 'Block On Timestamp' ;
    rdfs:comment 'The timestamp when the aircraft arrived at the gate and parking brake was set (In time in OOOI). Marks the end of block hours.' ;
    rdfs:domain ind:TechnicalLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:crsIssuedFlag rdf:type rdf:Property ;
    rdfs:label 'Crs Issued Flag' ;
    rdfs:comment 'Indicates whether a Certificate of Release to Service was issued for maintenance work performed before or during this sector. True if CRS was issued, false otherwise.' ;
    rdfs:domain ind:TechnicalLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:defectsRaisedCount rdf:type rdf:Property ;
    rdfs:label 'Defects Raised Count' ;
    rdfs:comment 'The number of new defects or discrepancies raised by the crew during or after this sector. Links to individual defect records.' ;
    rdfs:domain ind:TechnicalLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deferredDefectsCarriedForward rdf:type rdf:Property ;
    rdfs:label 'Deferred Defects Carried Forward' ;
    rdfs:comment 'A summary or list of deferred defect reference numbers carried forward from previous sectors and still active on this flight. Provides continuity of airworthiness status.' ;
    rdfs:domain ind:TechnicalLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelRemainingKg rdf:type rdf:Property ;
    rdfs:label 'Fuel Remaining Kg' ;
    rdfs:comment 'The quantity of fuel remaining at the end of the sector, measured in kilograms. Used for fuel planning and anomaly detection.' ;
    rdfs:domain ind:TechnicalLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:landingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Landing Timestamp' ;
    rdfs:comment 'The timestamp when the aircraft touched down on the runway (On time in OOOI). Used for flight cycle counting.' ;
    rdfs:domain ind:TechnicalLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:melItemsActiveCount rdf:type rdf:Property ;
    rdfs:label 'Mel Items Active Count' ;
    rdfs:comment 'The number of MEL deferred defects active and carried forward on this sector. Indicates aircraft dispatch with inoperative equipment under MEL authority.' ;
    rdfs:domain ind:TechnicalLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:oilUpliftLitres rdf:type rdf:Property ;
    rdfs:label 'Oil Uplift Litres' ;
    rdfs:comment 'The quantity of engine oil uplifted for this sector, measured in litres. Monitored for engine health and consumption trends.' ;
    rdfs:domain ind:TechnicalLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preFlightInspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Pre Flight Inspection Status' ;
    rdfs:comment 'The outcome of the commander\'s pre-flight walk-around inspection. Indicates whether the aircraft was found airworthy or defects were noted.' ;
    rdfs:domain ind:TechnicalLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sectorDate rdf:type rdf:Property ;
    rdfs:label 'Sector Date' ;
    rdfs:comment 'The calendar date on which this flight sector was operated, in UTC.' ;
    rdfs:domain ind:TechnicalLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:takeoffTimestamp rdf:type rdf:Property ;
    rdfs:label 'Takeoff Timestamp' ;
    rdfs:comment 'The timestamp when the aircraft became airborne (Off time in OOOI). Used for flight cycle counting.' ;
    rdfs:domain ind:TechnicalLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:technicalLogStatus rdf:type rdf:Property ;
    rdfs:label 'Technical Log Status' ;
    rdfs:comment 'The current status of this technical log sector page record. Open indicates the sector is in progress or pending closure; closed indicates all entries are complete and signed off.' ;
    rdfs:domain ind:TechnicalLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visitId rdf:type rdf:Property ;
    rdfs:label 'Visit Id' ;
    rdfs:comment 'Primary key for visit' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualReleaseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Release Timestamp' ;
    rdfs:comment 'Precise timestamp when the aircraft was released from maintenance, including time zone. Used for on-time performance and turnaround time analysis.' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:adComplianceCount rdf:type rdf:Property ;
    rdfs:label 'Ad Compliance Count' ;
    rdfs:comment 'Number of airworthiness directives complied with during this maintenance visit. Critical for regulatory compliance tracking.' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:aircraftTotalCyclesAtInduction rdf:type rdf:Property ;
    rdfs:label 'Aircraft Total Cycles At Induction' ;
    rdfs:comment 'Cumulative total flight cycles (takeoff/landing pairs) of the aircraft at the time of maintenance visit induction. Used for cycle-based maintenance tracking.' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:aircraftTotalFlightHoursAtInduction rdf:type rdf:Property ;
    rdfs:label 'Aircraft Total Flight Hours At Induction' ;
    rdfs:comment 'Cumulative total flight hours (block hours) of the aircraft at the time of maintenance visit induction. Used for interval-based maintenance tracking.' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:crsIssueDate rdf:type rdf:Property ;
    rdfs:label 'Crs Issue Date' ;
    rdfs:comment 'Date when the Certificate of Release to Service (EASA Form 1 / FAA Form 337 equivalent) was issued, certifying the aircraft is airworthy and released from maintenance.' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:defectCount rdf:type rdf:Property ;
    rdfs:label 'Defect Count' ;
    rdfs:comment 'Total number of defects or discrepancies identified and rectified during this maintenance visit. Used for quality and reliability analysis.' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:delayHours rdf:type rdf:Property ;
    rdfs:label 'Delay Hours' ;
    rdfs:comment 'Total delay in hours between planned release date and actual release date. Negative values indicate early completion. Used for schedule adherence and performance analysis.' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:delayReasonCategory rdf:type rdf:Property ;
    rdfs:label 'Delay Reason Category' ;
    rdfs:comment 'Primary category explaining any delay in the maintenance visit: on_time (no delay), parts_delay (awaiting material), technical_finding (unexpected defects), resource_constraint (labor/tooling shortage), weather (environmental), vendor_delay (external supplier), scope_change (work scope expansion). [ENUM-REF-CANDIDATE: on_time|parts_delay|technical_finding|resource_constraint|weather|vendor_delay|scope_change — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Estimated Release Date' ;
    rdfs:comment 'Current estimated date for aircraft release, updated as work progresses. May differ from planned date due to findings or delays.' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inductionDate rdf:type rdf:Property ;
    rdfs:label 'Induction Date' ;
    rdfs:comment 'Date when the aircraft was inducted into the maintenance facility and work commenced. Marks the start of the visit lifecycle.' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:inductionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Induction Timestamp' ;
    rdfs:comment 'Precise timestamp when the aircraft was inducted into the maintenance facility, including time zone. Used for detailed scheduling and SLA tracking.' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:llpReplacementCount rdf:type rdf:Property ;
    rdfs:label 'Llp Replacement Count' ;
    rdfs:comment 'Number of life-limited parts replaced during this maintenance visit. Critical for airworthiness and component life tracking.' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:melDeferralCount rdf:type rdf:Property ;
    rdfs:label 'Mel Deferral Count' ;
    rdfs:comment 'Number of MEL deferrals addressed or cleared during this maintenance visit. Used for dispatch reliability analysis.' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Planned Release Date' ;
    rdfs:comment 'Originally scheduled date for aircraft release back to service. Used for capacity planning and schedule recovery analysis.' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sbIncorporationCount rdf:type rdf:Property ;
    rdfs:label 'Sb Incorporation Count' ;
    rdfs:comment 'Number of manufacturer service bulletins incorporated during this maintenance visit. Used for fleet modification tracking.' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalLabourCostUsd rdf:type rdf:Property ;
    rdfs:label 'Total Labour Cost Usd' ;
    rdfs:comment 'Total labor cost for all maintenance work performed during this visit, in US dollars. Calculated from man-hours and labor rates.' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalManHoursActual rdf:type rdf:Property ;
    rdfs:label 'Total Man Hours Actual' ;
    rdfs:comment 'Total actual labor hours expended on all maintenance tasks in this visit. Used for cost tracking and productivity analysis.' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalManHoursPlanned rdf:type rdf:Property ;
    rdfs:label 'Total Man Hours Planned' ;
    rdfs:comment 'Total planned labor hours for all maintenance tasks in this visit, used for resource planning and capacity management.' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalMaterialCostUsd rdf:type rdf:Property ;
    rdfs:label 'Total Material Cost Usd' ;
    rdfs:comment 'Total cost of all parts, components, consumables, and materials used during this maintenance visit, in US dollars. Excludes labor costs.' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalVisitCostUsd rdf:type rdf:Property ;
    rdfs:label 'Total Visit Cost Usd' ;
    rdfs:comment 'Total cost of the maintenance visit including labor, material, overhead, and facility charges, in US dollars. Used for MRO commercial management and budget tracking.' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:visitStatus rdf:type rdf:Property ;
    rdfs:label 'Visit Status' ;
    rdfs:comment 'Current lifecycle status of the maintenance visit: planned (scheduled but not started), inducted (aircraft received at facility), in_progress (work underway), inspection (quality assurance), awaiting_parts (work paused for material), released (aircraft returned to service), cancelled (visit aborted). [ENUM-REF-CANDIDATE: planned|inducted|in_progress|inspection|awaiting_parts|released|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visitType rdf:type rdf:Property ;
    rdfs:label 'Visit Type' ;
    rdfs:comment 'Classification of maintenance visit: line (routine checks at gate/hangar), base (scheduled major checks), heavy (C/D checks), engine_shop (engine overhaul), component_shop (component repair), aog_recovery (Aircraft on Ground emergency repair).' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workOrderCount rdf:type rdf:Property ;
    rdfs:label 'Work Order Count' ;
    rdfs:comment 'Total number of individual work orders or work packages executed during this maintenance visit. Used for complexity and scope tracking.' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:workScopeSummary rdf:type rdf:Property ;
    rdfs:label 'Work Scope Summary' ;
    rdfs:comment 'High-level textual summary of the maintenance work scope, including major tasks, inspections, modifications, and component replacements planned or performed during this visit.' ;
    rdfs:domain ind:Visit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressingAuditFindingId rdf:type rdf:Property ;
    rdfs:label 'Addressing Audit Finding Id' ;
    rdfs:comment 'Foreign key linking to safety.audit_finding. Business justification: Work orders may be raised to address audit findings (corrective maintenance for non-compliances). Link tracks finding closure and corrective action implementation, supports audit follow-up, and demons' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AuditFinding .

ind:complianceAlertId rdf:type rdf:Property ;
    rdfs:label 'Compliance Alert Id' ;
    rdfs:comment 'Foreign key linking to safety.alert. Business justification: Safety alerts may mandate maintenance actions (urgent inspections, modifications). Link tracks alert compliance, supports regulatory response tracking, and demonstrates timely implementation of safety' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Alert .

ind:mitigatingHazardId rdf:type rdf:Property ;
    rdfs:label 'Mitigating Hazard Id' ;
    rdfs:comment 'Foreign key linking to safety.hazard. Business justification: Work orders may be generated to mitigate identified hazards (e.g., proactive modification to address known risk). Link tracks hazard control implementation, supports SMS hazard register closure, and d' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Hazard .

ind:originatingOccurrenceId rdf:type rdf:Property ;
    rdfs:label 'Originating Occurrence Id' ;
    rdfs:comment 'Foreign key linking to safety.occurrence. Business justification: Work orders frequently originate from safety occurrences (bird strikes, incidents, accidents). Real-world airline process: occurrence triggers corrective maintenance work. Critical for causal tracking' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Occurrence .

ind:performingVendorId rdf:type rdf:Property ;
    rdfs:label 'Performing Vendor Id' ;
    rdfs:comment 'Foreign key linking to procurement.vendor. Business justification: MRO work orders frequently subcontracted to external Part-145 vendors. Tracks performing vendor (distinct from approved_maintenance_org approval holder) for invoice reconciliation, vendor performance ' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:actualCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Timestamp' ;
    rdfs:comment 'Actual date and time when maintenance work was completed and aircraft returned to service. Used for turnaround time analysis and maintenance efficiency metrics.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualLaborCost rdf:type rdf:Property ;
    rdfs:label 'Actual Labor Cost' ;
    rdfs:comment 'Actual labor cost incurred for the work order in the airlines reporting currency, calculated from actual man-hours and labor rates. Used for cost accounting and variance analysis.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualMaterialCost rdf:type rdf:Property ;
    rdfs:label 'Actual Material Cost' ;
    rdfs:comment 'Actual material and parts cost incurred for the work order in the airlines reporting currency, aggregated from material requisitions and component removals. Used for cost accounting and inventory valuation.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Start Timestamp' ;
    rdfs:comment 'Actual date and time when maintenance work commenced. Used for schedule adherence tracking and labor cost allocation.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:adReference rdf:type rdf:Property ;
    rdfs:label 'Ad Reference' ;
    rdfs:comment 'Reference to the Airworthiness Directive number if this work order is compliance with a mandatory AD. Format varies by authority (e.g., FAA AD 2023-01-01, EASA AD 2023-0001).' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ataChapterCode rdf:type rdf:Property ;
    rdfs:label 'Ata Chapter Code' ;
    rdfs:comment 'ATA 100 system chapter code identifying the aircraft system or component this work order addresses. Format is two-digit chapter, optional two-digit section, optional two-digit subject (e.g., 32 for Landing Gear, 32-41 for Wheels and Brakes).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crsReference rdf:type rdf:Property ;
    rdfs:label 'Crs Reference' ;
    rdfs:comment 'Reference number of the Certificate of Release to Service issued upon work order completion. Required for airworthiness compliance and regulatory audit trail.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downtimeHours rdf:type rdf:Property ;
    rdfs:label 'Downtime Hours' ;
    rdfs:comment 'Total aircraft out-of-service hours from work order start to completion. Used for aircraft utilization analysis and maintenance efficiency metrics. Calculated as the difference between actual start and actual completion timestamps.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedLaborCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Labor Cost' ;
    rdfs:comment 'Planned labor cost for the work order in the airlines reporting currency, calculated from estimated man-hours and labor rates. Used for budgeting and cost forecasting.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedMaterialCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Material Cost' ;
    rdfs:comment 'Planned material and parts cost for the work order in the airlines reporting currency. Includes consumables, rotables, and expendables. Used for budgeting and inventory planning.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maintenanceCheckType rdf:type rdf:Property ;
    rdfs:label 'Maintenance Check Type' ;
    rdfs:comment 'The maintenance program check interval or package this work order belongs to. A-check through D-check represent increasing scope and interval; daily/weekly/transit are operational checks; line maintenance is performed at the gate; base maintenance is performed in hangar; component maintenance is off-wing shop work. [ENUM-REF-CANDIDATE: a_check|b_check|c_check|d_check|daily|weekly|transit|line|base|component — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originatingSource rdf:type rdf:Property ;
    rdfs:label 'Originating Source' ;
    rdfs:comment 'The trigger or authority that initiated this work order. AD (Airworthiness Directive) indicates mandatory regulatory action; SB (Service Bulletin) indicates manufacturer recommendation; MEL indicates deferred defect; defect indicates pilot or engineer report; interval indicates scheduled maintenance program; modification indicates design change; inspection indicates regulatory or operational audit. [ENUM-REF-CANDIDATE: ad|sb|mel|defect|interval|modification|inspection — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:part145ApprovalReference rdf:type rdf:Property ;
    rdfs:label 'Part 145 Approval Reference' ;
    rdfs:comment 'Reference to the Part-145 maintenance organisation approval certificate number under which this work was performed. Required for regulatory compliance and airworthiness release.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sbReference rdf:type rdf:Property ;
    rdfs:label 'Sb Reference' ;
    rdfs:comment 'Reference to the manufacturer Service Bulletin number if this work order implements a recommended modification or inspection. Format varies by OEM (e.g., Boeing SB 737-32-1234, Airbus SB A320-32-1234).' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Completion Timestamp' ;
    rdfs:comment 'Planned date and time when maintenance work is scheduled to be completed. Used for aircraft return-to-service planning and slot management.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Timestamp' ;
    rdfs:comment 'Planned date and time when maintenance work is scheduled to begin. Used for resource planning and aircraft availability forecasting.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:signOffTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sign Off Timestamp' ;
    rdfs:comment 'Date and time when the certifying engineer signed off the work order and issued the Certificate of Release to Service (CRS). Marks the official completion and airworthiness release.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:workOrderStatus rdf:type rdf:Property ;
    rdfs:label 'Work Order Status' ;
    rdfs:comment 'Current lifecycle state of the work order. Open indicates work is scheduled but not started; in-progress indicates active execution; deferred indicates MEL (Minimum Equipment List) deferral or resource constraint; completed indicates work finished pending sign-off; closed indicates final approval and record closure; cancelled indicates work order voided.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workOrderType rdf:type rdf:Property ;
    rdfs:label 'Work Order Type' ;
    rdfs:comment 'Classification of the work order by maintenance category. Scheduled includes routine checks and intervals; unscheduled covers reactive maintenance; AOG (Aircraft on Ground) indicates critical grounding events; modification covers STC (Supplemental Type Certificate) and design changes; inspection includes regulatory and operational checks; defect rectification addresses reported discrepancies.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workOrderTaskId rdf:type rdf:Property ;
    rdfs:label 'Work Order Task Id' ;
    rdfs:comment 'Unique identifier for the work order task line item. Primary key.' ;
    rdfs:domain ind:WorkOrderTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:crewTechnicianCrewMemberId rdf:type rdf:Property ;
    rdfs:label 'Crew Technician Crew Member Id' ;
    rdfs:comment 'Foreign key linking to crew.crew_member. Business justification: Dual-role crew members (pilot-engineers, flight engineers with A&P) perform line maintenance tasks. Business process: dual-role workforce utilization tracking, labor cost allocation, regulatory compli' ;
    rdfs:domain ind:WorkOrderTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Member .

ind:inspectorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Inspector Employee Id' ;
    rdfs:comment 'Reference to the certified inspector who performed independent inspection and verification of the completed task. Required for critical tasks and return-to-service certification.' ;
    rdfs:domain ind:WorkOrderTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryWorkTechnicianEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Work Technician Employee Id' ;
    rdfs:comment 'Reference to the certified aircraft maintenance technician who performed the work. Links to employee/crew master data.' ;
    rdfs:domain ind:WorkOrderTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualLaborHours rdf:type rdf:Property ;
    rdfs:label 'Actual Labor Hours' ;
    rdfs:comment 'Actual labor hours expended to complete this task, captured for cost accounting, productivity analysis, and future task planning.' ;
    rdfs:domain ind:WorkOrderTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deferralFlag rdf:type rdf:Property ;
    rdfs:label 'Deferral Flag' ;
    rdfs:comment 'Boolean indicator whether this task has been deferred under MEL or other approved deferral provisions. True indicates the task is deferred and must be tracked for completion within allowable limits.' ;
    rdfs:domain ind:WorkOrderTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inspectorLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Inspector License Number' ;
    rdfs:comment 'The Part-66 or equivalent aircraft maintenance license number of the inspector who verified the task, required for regulatory traceability and airworthiness certification.' ;
    rdfs:domain ind:WorkOrderTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectorSignoffTimestamp rdf:type rdf:Property ;
    rdfs:label 'Inspector Signoff Timestamp' ;
    rdfs:comment 'Date and time when the inspector signed off the task verification, certifying that the work meets airworthiness standards and approved procedures.' ;
    rdfs:domain ind:WorkOrderTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:materialsCostAmount rdf:type rdf:Property ;
    rdfs:label 'Materials Cost Amount' ;
    rdfs:comment 'Total cost of materials, parts, and consumables used in this task, captured for maintenance cost accounting and budget tracking.' ;
    rdfs:domain ind:WorkOrderTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:removedComponentSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Removed Component Serial Number' ;
    rdfs:comment 'Serial number of the component removed during a replacement task, required for component tracking, warranty claims, and rotable pool management.' ;
    rdfs:domain ind:WorkOrderTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skillTradeRequired rdf:type rdf:Property ;
    rdfs:label 'Skill Trade Required' ;
    rdfs:comment 'The specialized maintenance trade or skill category required to perform this task (avionics, airframe, powerplant, electrical, hydraulic, composite). Determines technician assignment and certification requirements.' ;
    rdfs:domain ind:WorkOrderTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskCardReference rdf:type rdf:Property ;
    rdfs:label 'Task Card Reference' ;
    rdfs:comment 'Reference number or code of the maintenance task card, job card, or work instruction document that defines this task. Links to approved maintenance procedures.' ;
    rdfs:domain ind:WorkOrderTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Task Completion Timestamp' ;
    rdfs:comment 'Date and time when this task was completed and signed off, marking the end of work and enabling aircraft return-to-service processing.' ;
    rdfs:domain ind:WorkOrderTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:taskNotes rdf:type rdf:Property ;
    rdfs:label 'Task Notes' ;
    rdfs:comment 'Free-text field for technician notes, observations, findings, or special instructions related to this task. Captures important context not covered by structured fields.' ;
    rdfs:domain ind:WorkOrderTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskPriority rdf:type rdf:Property ;
    rdfs:label 'Task Priority' ;
    rdfs:comment 'Priority level assigned to this task for scheduling and resource allocation: critical (AOG/safety), high (operational impact), medium (scheduled), low (routine).' ;
    rdfs:domain ind:WorkOrderTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Task Sequence Number' ;
    rdfs:comment 'Sequential ordering of this task within the parent work order, used to control execution sequence and dependencies.' ;
    rdfs:domain ind:WorkOrderTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:taskStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Task Start Timestamp' ;
    rdfs:comment 'Date and time when work on this task was initiated, used for labor tracking, downtime analysis, and task duration measurement.' ;
    rdfs:domain ind:WorkOrderTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:technicianLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Technician License Number' ;
    rdfs:comment 'The Part-66 or equivalent aircraft maintenance license number of the technician who performed the task, required for regulatory traceability and certification compliance.' ;
    rdfs:domain ind:WorkOrderTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicianSignoffTimestamp rdf:type rdf:Property ;
    rdfs:label 'Technician Signoff Timestamp' ;
    rdfs:comment 'Date and time when the technician signed off the completed task, certifying that the work was performed in accordance with approved data and procedures.' ;
    rdfs:domain ind:WorkOrderTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:workLocation rdf:type rdf:Property ;
    rdfs:label 'Work Location' ;
    rdfs:comment 'Physical location where the task is performed: hangar (heavy maintenance), line (gate/ramp), shop (component workshop), vendor (external MRO facility).' ;
    rdfs:domain ind:WorkOrderTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:abTestId rdf:type rdf:Property ;
    rdfs:label 'Ab Test Id' ;
    rdfs:comment 'Unique identifier for the A/B or multivariate test. Primary key.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AbTest .

ind:testOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Test Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Test owner is an employee responsible for test design, hypothesis validation, and results analysis. Airlines track test ownership for accountability, methodology validation, and performance optimizati' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual End Timestamp' ;
    rdfs:comment 'Actual date and time when the test was concluded and data collection stopped.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cabinClassFocus rdf:type rdf:Property ;
    rdfs:label 'Cabin Class Focus' ;
    rdfs:comment 'Cabin class targeted by the test, if the experiment is specific to a travel class.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlVariantDescription rdf:type rdf:Property ;
    rdfs:label 'Control Variant Description' ;
    rdfs:comment 'Detailed description of the control (baseline) variant used in the test.' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalChannel rdf:type rdf:Property ;
    rdfs:label 'Digital Channel' ;
    rdfs:comment 'The digital marketing channel where the test is being conducted.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ffpTierFocus rdf:type rdf:Property ;
    rdfs:label 'Ffp Tier Focus' ;
    rdfs:comment 'Specific FFP loyalty tier targeted by the test (e.g., Silver, Gold, Platinum), if applicable.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hypothesis rdf:type rdf:Property ;
    rdfs:label 'Hypothesis' ;
    rdfs:comment 'The business hypothesis being tested, describing the expected outcome and rationale for the experiment.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumDetectableEffect rdf:type rdf:Property ;
    rdfs:label 'Minimum Detectable Effect' ;
    rdfs:comment 'The smallest effect size that the test is designed to detect with statistical confidence, expressed as a decimal (e.g., 0.0200 for 2% lift).' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:owningTeam rdf:type rdf:Property ;
    rdfs:label 'Owning Team' ;
    rdfs:comment 'Marketing team or business unit responsible for the test (e.g., Digital Marketing, Email Marketing, Revenue Management).' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pValue rdf:type rdf:Property ;
    rdfs:label 'P Value' ;
    rdfs:comment 'The probability that the observed difference between variants occurred by chance, used to assess statistical significance.' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedEndDate rdf:type rdf:Property ;
    rdfs:label 'Planned End Date' ;
    rdfs:comment 'Scheduled date for the test to conclude.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedStartDate rdf:type rdf:Property ;
    rdfs:label 'Planned Start Date' ;
    rdfs:comment 'Scheduled date for the test to begin.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:primarySuccessMetric rdf:type rdf:Property ;
    rdfs:label 'Primary Success Metric' ;
    rdfs:comment 'The primary metric used to determine test success, such as conversion rate, click-through rate (CTR), revenue per visitor (RPV), or booking completion rate.' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeFocus rdf:type rdf:Property ;
    rdfs:label 'Route Focus' ;
    rdfs:comment 'Specific route or origin-destination pair targeted by the test, if applicable (e.g., JFK-LHR, LAX-NRT).' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleSizeTarget rdf:type rdf:Property ;
    rdfs:label 'Sample Size Target' ;
    rdfs:comment 'Target number of observations (visitors, impressions, or conversions) required to achieve statistical power.' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:secondaryMetrics rdf:type rdf:Property ;
    rdfs:label 'Secondary Metrics' ;
    rdfs:comment 'Additional metrics tracked to understand broader impact, such as engagement rate, bounce rate, average order value, or ancillary attachment rate.' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statisticalConfidenceThreshold rdf:type rdf:Property ;
    rdfs:label 'Statistical Confidence Threshold' ;
    rdfs:comment 'The confidence level required to declare statistical significance, typically 0.950 (95%) or 0.990 (99%).' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:statisticalSignificanceAchieved rdf:type rdf:Property ;
    rdfs:label 'Statistical Significance Achieved' ;
    rdfs:comment 'Indicates whether the test results achieved the required statistical confidence threshold (True) or not (False).' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetAudienceSegment rdf:type rdf:Property ;
    rdfs:label 'Target Audience Segment' ;
    rdfs:comment 'Customer segment or audience targeted by the test, such as Frequent Flyer Program (FFP) tier, geographic market, or behavioral cohort.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testCode rdf:type rdf:Property ;
    rdfs:label 'Test Code' ;
    rdfs:comment 'Business-readable unique code for the test, used for operational reference and reporting.' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testName rdf:type rdf:Property ;
    rdfs:label 'Test Name' ;
    rdfs:comment 'Descriptive name of the A/B or multivariate test for business identification.' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testPlatform rdf:type rdf:Property ;
    rdfs:label 'Test Platform' ;
    rdfs:comment 'Technology platform or tool used to execute the test (e.g., Optimizely, Adobe Target, Google Optimize, internal experimentation platform).' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testStatus rdf:type rdf:Property ;
    rdfs:label 'Test Status' ;
    rdfs:comment 'Current lifecycle status of the test: draft (being designed), approved (ready to launch), running (actively collecting data), paused (temporarily stopped), concluded (completed with results), or cancelled (terminated without conclusion).' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:testType rdf:type rdf:Property ;
    rdfs:label 'Test Type' ;
    rdfs:comment 'Type of experiment design: A/B (two variants), multivariate (multiple factors), split URL (different landing pages), sequential (phased rollout), or bandit (adaptive allocation).' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trafficSplitPercentage rdf:type rdf:Property ;
    rdfs:label 'Traffic Split Percentage' ;
    rdfs:comment 'Distribution of traffic across variants, expressed as percentages (e.g., 50/50 for A/B, 33/33/34 for three-way split).' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatmentVariantDescription rdf:type rdf:Property ;
    rdfs:label 'Treatment Variant Description' ;
    rdfs:comment 'Detailed description of the treatment (experimental) variant(s) being tested against the control.' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variantCount rdf:type rdf:Property ;
    rdfs:label 'Variant Count' ;
    rdfs:comment 'Total number of variants in the test, including control and all treatment variants.' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:winningVariant rdf:type rdf:Property ;
    rdfs:label 'Winning Variant' ;
    rdfs:comment 'Identifier of the variant that achieved the best performance on the primary success metric, determined after test conclusion.' ;
    rdfs:domain ind:AbTest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activationDate rdf:type rdf:Property ;
    rdfs:label 'Activation Date' ;
    rdfs:comment 'Date when this segment was first activated and made available for campaign use.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:audienceSegmentDescription rdf:type rdf:Property ;
    rdfs:label 'Audience Segment Description' ;
    rdfs:comment 'Extended business description of the segment, its purpose, and intended use cases.' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:audienceSegmentStatus rdf:type rdf:Property ;
    rdfs:label 'Audience Segment Status' ;
    rdfs:comment 'Current lifecycle status of the segment: active (in use), inactive (paused), draft (under development), archived (historical reference), or deprecated (replaced by newer segment).' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessObjective rdf:type rdf:Property ;
    rdfs:label 'Business Objective' ;
    rdfs:comment 'Strategic business goal this segment supports (e.g., \'Increase premium cabin bookings\', \'Reduce churn of high-value customers\', \'Drive ancillary revenue\').' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignCount rdf:type rdf:Property ;
    rdfs:label 'Campaign Count' ;
    rdfs:comment 'Number of marketing campaigns that have used this segment (lifetime count).' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:consentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Consent Required Flag' ;
    rdfs:comment 'Indicates whether explicit passenger consent is required to include them in this segment for marketing purposes.' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deactivationDate rdf:type rdf:Property ;
    rdfs:label 'Deactivation Date' ;
    rdfs:comment 'Date when this segment was deactivated or archived. Null if currently active.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:definitionCriteria rdf:type rdf:Property ;
    rdfs:label 'Definition Criteria' ;
    rdfs:comment 'Detailed textual description of the rules or criteria that define membership in this segment (e.g., \'Passengers who flew business class 3+ times in last 12 months on transatlantic routes\').' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:derivationMethod rdf:type rdf:Property ;
    rdfs:label 'Derivation Method' ;
    rdfs:comment 'Method used to derive segment membership: rule-based (SQL/business rules), ML clustering (unsupervised learning), ML classification (supervised model), manual upload (CSV import), or third-party (external data provider).' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusionCriteria rdf:type rdf:Property ;
    rdfs:label 'Exclusion Criteria' ;
    rdfs:comment 'Rules defining which passengers should be explicitly excluded from this segment (e.g., \'Passengers who opted out of marketing\', \'Employees\', \'VIP blacklist\').' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastRefreshTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Refresh Timestamp' ;
    rdfs:comment 'Timestamp when the segment membership was last recalculated and the segment_size was last updated.' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:loyaltyTierFilter rdf:type rdf:Property ;
    rdfs:label 'Loyalty Tier Filter' ;
    rdfs:comment 'Loyalty tier(s) included in this segment if loyalty-tier-based (e.g., \'Gold\', \'Platinum\', \'Silver|Gold\'). Null if not loyalty-based.' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxRfmScore rdf:type rdf:Property ;
    rdfs:label 'Max Rfm Score' ;
    rdfs:comment 'Maximum RFM score threshold for inclusion in this segment if RFM-based. Null if not RFM-based.' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minRfmScore rdf:type rdf:Property ;
    rdfs:label 'Min Rfm Score' ;
    rdfs:comment 'Minimum RFM score threshold for inclusion in this segment if RFM-based. Null if not RFM-based.' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:modelCode rdf:type rdf:Property ;
    rdfs:label 'Model Code' ;
    rdfs:comment 'Identifier of the ML model used to generate this segment if derivation_method is ML-based. Null for rule-based segments.' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modelVersion rdf:type rdf:Property ;
    rdfs:label 'Model Version' ;
    rdfs:comment 'Version number of the ML model used. Null for rule-based segments.' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextRefreshDate rdf:type rdf:Property ;
    rdfs:label 'Next Refresh Date' ;
    rdfs:comment 'Scheduled date for the next segment membership refresh. Null for on-demand or static segments.' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:performanceMetric rdf:type rdf:Property ;
    rdfs:label 'Performance Metric' ;
    rdfs:comment 'Key performance indicator used to measure the effectiveness of campaigns targeting this segment (e.g., \'Conversion Rate\', \'Revenue per Passenger (RPP)\', \'Click-Through Rate (CTR)\').' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refreshFrequency rdf:type rdf:Property ;
    rdfs:label 'Refresh Frequency' ;
    rdfs:comment 'How often the segment membership is recalculated: real-time (streaming), daily, weekly, monthly, quarterly, on-demand (manual trigger), or static (one-time definition). [ENUM-REF-CANDIDATE: real_time|daily|weekly|monthly|quarterly|on_demand|static — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeAffinity rdf:type rdf:Property ;
    rdfs:label 'Route Affinity' ;
    rdfs:comment 'Specific route networks or city pairs this segment has affinity for (e.g., \'Transatlantic\', \'Domestic US\', \'Asia-Pacific long-haul\'). Null if not route-specific.' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentCode rdf:type rdf:Property ;
    rdfs:label 'Segment Code' ;
    rdfs:comment 'Short alphanumeric code used to reference the segment in campaigns and operational systems.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentName rdf:type rdf:Property ;
    rdfs:label 'Segment Name' ;
    rdfs:comment 'Human-readable name of the audience segment (e.g., High-Value Transatlantic Travellers, Lapsed Frequent Flyers, Business Class Prospects).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentSize rdf:type rdf:Property ;
    rdfs:label 'Segment Size' ;
    rdfs:comment 'Number of unique passengers currently assigned to this segment (last calculated count).' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tags rdf:type rdf:Property ;
    rdfs:label 'Tags' ;
    rdfs:comment 'Comma-separated list of tags or labels for categorization and search (e.g., \'premium\', \'retention\', \'acquisition\', \'seasonal\').' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetChannel rdf:type rdf:Property ;
    rdfs:label 'Target Channel' ;
    rdfs:comment 'Primary marketing channels where this segment is intended to be used (e.g., \'email\', \'mobile app push\', \'digital display\', \'direct mail\'). Pipe-separated if multiple.' ;
    rdfs:domain ind:AudienceSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creationDate rdf:type rdf:Property ;
    rdfs:label 'Creation Date' ;
    rdfs:comment 'Date when this segment definition was first created.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:brandAssetId rdf:type rdf:Property ;
    rdfs:label 'Brand Asset Id' ;
    rdfs:comment 'Unique identifier for the brand asset record. Primary key for the brand asset master data.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BrandAsset .

ind:approvedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Approved By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Brand asset approval requires employee authorization for brand compliance, legal clearance, and usage rights. Airlines track approver identity for audit trails, brand governance, and regulatory compli' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:archiveDate rdf:type rdf:Property ;
    rdfs:label 'Archive Date' ;
    rdfs:comment 'Date when the brand asset was archived or retired from active use. Supports lifecycle management and historical tracking.' ;
    rdfs:domain ind:BrandAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:archiveReason rdf:type rdf:Property ;
    rdfs:label 'Archive Reason' ;
    rdfs:comment 'Explanation for why the brand asset was archived. Examples include campaign completion, brand refresh, regulatory change, or asset obsolescence.' ;
    rdfs:domain ind:BrandAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetCode rdf:type rdf:Property ;
    rdfs:label 'Asset Code' ;
    rdfs:comment 'Unique business identifier or catalog code for the brand asset. Used for external reference and cross-system integration.' ;
    rdfs:domain ind:BrandAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetFormat rdf:type rdf:Property ;
    rdfs:label 'Asset Format' ;
    rdfs:comment 'File format or media type of the brand asset. Determines compatibility with production systems and distribution channels. [ENUM-REF-CANDIDATE: pdf|jpg|png|svg|mp4|mov|ai|psd|eps|indd — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BrandAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetName rdf:type rdf:Property ;
    rdfs:label 'Asset Name' ;
    rdfs:comment 'Human-readable name or title of the brand asset. Used for identification and search within the digital asset management system.' ;
    rdfs:domain ind:BrandAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandProgramme rdf:type rdf:Property ;
    rdfs:label 'Brand Programme' ;
    rdfs:comment 'Name of the overarching brand programme or strategic initiative to which this asset belongs. Examples include loyalty programme branding, alliance branding, or sustainability campaigns.' ;
    rdfs:domain ind:BrandAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandTerritory rdf:type rdf:Property ;
    rdfs:label 'Brand Territory' ;
    rdfs:comment 'Geographic or organizational scope of the brand asset. Defines where the asset is authorized for use within the airline\'s brand architecture.' ;
    rdfs:domain ind:BrandAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:colorProfile rdf:type rdf:Property ;
    rdfs:label 'Color Profile' ;
    rdfs:comment 'Color space or profile used in the asset. Critical for ensuring color consistency across digital and print production channels.' ;
    rdfs:domain ind:BrandAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:copyrightHolder rdf:type rdf:Property ;
    rdfs:label 'Copyright Holder' ;
    rdfs:comment 'Legal entity or individual holding copyright ownership of the brand asset. Critical for intellectual property management and licensing compliance.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileReference rdf:type rdf:Property ;
    rdfs:label 'File Reference' ;
    rdfs:comment 'Storage location or URI reference to the physical asset file in the digital asset management system or content delivery network.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileSizeMb rdf:type rdf:Property ;
    rdfs:label 'File Size Mb' ;
    rdfs:comment 'Size of the asset file in megabytes. Important for storage planning and distribution bandwidth considerations.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:keywords rdf:type rdf:Property ;
    rdfs:label 'Keywords' ;
    rdfs:comment 'Comma-separated list of keywords or tags for asset categorization and search optimization. Facilitates discovery and retrieval in digital asset management systems.' ;
    rdfs:domain ind:BrandAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedDate rdf:type rdf:Property ;
    rdfs:label 'Last Modified Date' ;
    rdfs:comment 'Date when the brand asset file or metadata was last updated. Supports version control and change tracking.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseType rdf:type rdf:Property ;
    rdfs:label 'License Type' ;
    rdfs:comment 'Type of license governing the use of the brand asset. Determines legal permissions and restrictions for asset deployment.' ;
    rdfs:domain ind:BrandAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolution rdf:type rdf:Property ;
    rdfs:label 'Resolution' ;
    rdfs:comment 'Resolution specification for image or video assets, typically expressed as width x height in pixels or as DPI (dots per inch) for print assets.' ;
    rdfs:domain ind:BrandAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:territoryCode rdf:type rdf:Property ;
    rdfs:label 'Territory Code' ;
    rdfs:comment 'Three-letter ISO country code or regional identifier specifying the geographic market for market-specific assets. Empty for global assets.' ;
    rdfs:domain ind:BrandAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageRestrictions rdf:type rdf:Property ;
    rdfs:label 'Usage Restrictions' ;
    rdfs:comment 'Specific restrictions or prohibitions on asset usage. May include channel restrictions, co-branding limitations, or regulatory constraints.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usageRights rdf:type rdf:Property ;
    rdfs:label 'Usage Rights' ;
    rdfs:comment 'Description of authorized usage rights, licensing terms, and distribution permissions for the brand asset. Defines legal boundaries for asset deployment.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookingClassRestriction rdf:type rdf:Property ;
    rdfs:label 'Booking Class Restriction' ;
    rdfs:comment 'Specific fare booking classes (RBD - Revenue Booking Designator) eligible for the campaign offer, controlling inventory availability and revenue management.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookingWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Booking Window End' ;
    rdfs:comment 'Latest date when customers can make bookings under this campaign, controlling the purchase period for promotional offers.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bookingWindowStart rdf:type rdf:Property ;
    rdfs:label 'Booking Window Start' ;
    rdfs:comment 'Earliest date when customers can make bookings under this campaign, controlling the purchase period for promotional offers.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:budgetAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Amount' ;
    rdfs:comment 'Total allocated budget for the campaign, representing the financial resources committed to execution across all channels and activities.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetCurrency rdf:type rdf:Property ;
    rdfs:label 'Budget Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the budget amount, ensuring consistent financial reporting across multi-currency operations.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignCode rdf:type rdf:Property ;
    rdfs:label 'Campaign Code' ;
    rdfs:comment 'Externally-known unique business identifier for the campaign, used in tracking URLs, promotional materials, and cross-system references.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignDescription rdf:type rdf:Property ;
    rdfs:label 'Campaign Description' ;
    rdfs:comment 'Detailed narrative description of the campaign purpose, strategy, target audience, and expected business outcomes.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignName rdf:type rdf:Property ;
    rdfs:label 'Campaign Name' ;
    rdfs:comment 'Human-readable name of the marketing campaign as displayed in reporting and campaign management systems.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignStatus rdf:type rdf:Property ;
    rdfs:label 'Campaign Status' ;
    rdfs:comment 'Current lifecycle state of the campaign, indicating its operational readiness and execution phase.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignType rdf:type rdf:Property ;
    rdfs:label 'Campaign Type' ;
    rdfs:comment 'Primary channel or medium through which the campaign is executed. [ENUM-REF-CANDIDATE: email|digital|social|sem|seo|display|out_of_home|print|tv|radio|co_branded|partnership|sponsorship — promote to reference product]' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creativeTheme rdf:type rdf:Property ;
    rdfs:label 'Creative Theme' ;
    rdfs:comment 'Overarching creative concept or messaging theme used across campaign assets, ensuring brand consistency and message coherence.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:objective rdf:type rdf:Property ;
    rdfs:label 'Objective' ;
    rdfs:comment 'Primary business goal of the campaign, defining the intended outcome and success criteria.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originDestinationFocus rdf:type rdf:Property ;
    rdfs:label 'Origin Destination Focus' ;
    rdfs:comment 'Specific route or city-pair that the campaign promotes, using IATA airport codes or route identifiers (e.g., JFK-LHR, LAX-NRT).' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionalOffer rdf:type rdf:Property ;
    rdfs:label 'Promotional Offer' ;
    rdfs:comment 'Description of the specific offer, discount, or incentive featured in the campaign, such as bonus miles, fare discounts, or upgrade opportunities.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetMarket rdf:type rdf:Property ;
    rdfs:label 'Target Market' ;
    rdfs:comment 'Geographic or demographic market segment that the campaign is designed to reach, such as specific countries, regions, or customer segments.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:travelDateRangeEnd rdf:type rdf:Property ;
    rdfs:label 'Travel Date Range End' ;
    rdfs:comment 'Latest travel date for which bookings made under this campaign are valid, defining the travel window for promotional offers.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:travelDateRangeStart rdf:type rdf:Property ;
    rdfs:label 'Travel Date Range Start' ;
    rdfs:comment 'Earliest travel date for which bookings made under this campaign are valid, defining the travel window for promotional offers.' ;
    rdfs:domain ind:Campaign ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:campaignExecutionId rdf:type rdf:Property ;
    rdfs:label 'Campaign Execution Id' ;
    rdfs:comment 'Unique identifier for the campaign execution record. Primary key.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CampaignExecution .

ind:digitalCampaignCreativeId rdf:type rdf:Property ;
    rdfs:label 'Digital Campaign Creative Id' ;
    rdfs:comment 'Foreign key linking to marketing.digital_campaign_creative. Business justification: campaign_execution currently has creative_version_id (BIGINT) which should reference the specific creative used in the execution. Normalizing to digital_campaign_creative_id FK to marketing.digital_ca' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DigitalCampaignCreative .

ind:abTestVariant rdf:type rdf:Property ;
    rdfs:label 'Ab Test Variant' ;
    rdfs:comment 'The test variant identifier for this execution if part of an A/B or multivariate test (e.g., A, B, C, or control). Null if not part of a test.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attributedRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Attributed Revenue Amount' ;
    rdfs:comment 'The total revenue attributed to conversions from this campaign execution, based on the attribution model defined for the campaign.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:attributedRevenueCurrency rdf:type rdf:Property ;
    rdfs:label 'Attributed Revenue Currency' ;
    rdfs:comment 'The three-letter ISO 4217 currency code for the attributed revenue amount.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bounceRatePercent rdf:type rdf:Property ;
    rdfs:label 'Bounce Rate Percent' ;
    rdfs:comment 'The percentage of sent messages that bounced, calculated as (bounced_count / send_volume) * 100.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bouncedCount rdf:type rdf:Property ;
    rdfs:label 'Bounced Count' ;
    rdfs:comment 'The number of messages that bounced (hard or soft) and were not delivered to the intended recipient.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clickThroughRatePercent rdf:type rdf:Property ;
    rdfs:label 'Click Through Rate Percent' ;
    rdfs:comment 'The percentage of delivered messages that received at least one click, calculated as (clicked_count / delivered_count) * 100. Key performance indicator for engagement.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:clickedCount rdf:type rdf:Property ;
    rdfs:label 'Clicked Count' ;
    rdfs:comment 'The number of unique recipients who clicked on at least one link or call-to-action within the message.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contactsReached rdf:type rdf:Property ;
    rdfs:label 'Contacts Reached' ;
    rdfs:comment 'The actual number of contacts successfully reached by this execution. May be less than target due to invalid addresses, opt-outs, or delivery failures.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:conversionRatePercent rdf:type rdf:Property ;
    rdfs:label 'Conversion Rate Percent' ;
    rdfs:comment 'The percentage of delivered messages that resulted in a conversion, calculated as (converted_count / delivered_count) * 100.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:convertedCount rdf:type rdf:Property ;
    rdfs:label 'Converted Count' ;
    rdfs:comment 'The number of recipients who completed the desired conversion action (booking, purchase, enrollment) attributed to this execution.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveredCount rdf:type rdf:Property ;
    rdfs:label 'Delivered Count' ;
    rdfs:comment 'The number of messages successfully delivered to recipient inboxes or devices without bounce or rejection.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryRatePercent rdf:type rdf:Property ;
    rdfs:label 'Delivery Rate Percent' ;
    rdfs:comment 'The percentage of sent messages that were successfully delivered, calculated as (delivered_count / send_volume) * 100.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deploymentPlatform rdf:type rdf:Property ;
    rdfs:label 'Deployment Platform' ;
    rdfs:comment 'The marketing automation or channel platform used to deploy this execution (e.g., Salesforce Marketing Cloud, Adobe Campaign, Google Ads, Facebook Ads Manager).' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:errorCount rdf:type rdf:Property ;
    rdfs:label 'Error Count' ;
    rdfs:comment 'The total number of errors encountered during execution deployment, including system errors, validation failures, and integration issues.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:errorMessage rdf:type rdf:Property ;
    rdfs:label 'Error Message' ;
    rdfs:comment 'Detailed error message or log summary describing any failures or issues encountered during execution. Null if execution completed without errors.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionCostAmount rdf:type rdf:Property ;
    rdfs:label 'Execution Cost Amount' ;
    rdfs:comment 'The total cost incurred for this campaign execution, including platform fees, send costs, and creative production costs.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:executionCostCurrency rdf:type rdf:Property ;
    rdfs:label 'Execution Cost Currency' ;
    rdfs:comment 'The three-letter ISO 4217 currency code for the execution cost amount.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionName rdf:type rdf:Property ;
    rdfs:label 'Execution Name' ;
    rdfs:comment 'Human-readable name describing this specific execution instance, typically including channel and segment information.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionNumber rdf:type rdf:Property ;
    rdfs:label 'Execution Number' ;
    rdfs:comment 'Business identifier for this campaign execution, unique within the campaign context. Used for operational tracking and reporting.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:executionStatus rdf:type rdf:Property ;
    rdfs:label 'Execution Status' ;
    rdfs:comment 'Current lifecycle status of the campaign execution. Tracks progression from draft through deployment to completion or failure.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalExecutionReference rdf:type rdf:Property ;
    rdfs:label 'External Execution Reference' ;
    rdfs:comment 'The execution identifier from the external deployment platform, used for reconciliation and detailed drill-down in the source system.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openRatePercent rdf:type rdf:Property ;
    rdfs:label 'Open Rate Percent' ;
    rdfs:comment 'The percentage of delivered messages that were opened, calculated as (opened_count / delivered_count) * 100.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:openedCount rdf:type rdf:Property ;
    rdfs:label 'Opened Count' ;
    rdfs:comment 'The number of unique recipients who opened the message. Applicable primarily to email and push notification channels.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sendVolume rdf:type rdf:Property ;
    rdfs:label 'Send Volume' ;
    rdfs:comment 'The total number of messages sent during this execution. May include retries and multiple sends to the same contact.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetAudienceSize rdf:type rdf:Property ;
    rdfs:label 'Target Audience Size' ;
    rdfs:comment 'The total number of contacts (passengers or prospects) in the audience segment targeted for this execution.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unsubscribeRatePercent rdf:type rdf:Property ;
    rdfs:label 'Unsubscribe Rate Percent' ;
    rdfs:comment 'The percentage of delivered messages that resulted in an unsubscribe, calculated as (unsubscribed_count / delivered_count) * 100.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unsubscribedCount rdf:type rdf:Property ;
    rdfs:label 'Unsubscribed Count' ;
    rdfs:comment 'The number of recipients who opted out or unsubscribed from future communications as a result of this execution.' ;
    rdfs:domain ind:CampaignExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:passengerProfileId rdf:type rdf:Property ;
    rdfs:label 'Passenger Profile Id' ;
    rdfs:comment 'Reference to the authenticated passenger profile who responded. Null for anonymous visitors.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Profile .

ind:pricingRecordId rdf:type rdf:Property ;
    rdfs:label 'Pricing Record Id' ;
    rdfs:comment 'Foreign key linking to revenue.pricing_record. Business justification: Tracks which campaign interactions led to specific pricing quotes, critical for conversion funnel analysis and measuring campaign effectiveness at quote stage. Airlines analyze quote-to-book conversio' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PricingRecord .

ind:anonymousVisitorReference rdf:type rdf:Property ;
    rdfs:label 'Anonymous Visitor Reference' ;
    rdfs:comment 'Anonymous identifier for non-authenticated interactions, typically a browser cookie or device fingerprint.' ;
    rdfs:domain ind:CampaignResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:browser rdf:type rdf:Property ;
    rdfs:label 'Browser' ;
    rdfs:comment 'Web browser used for the response interaction (e.g., Chrome, Safari, Firefox, Edge).' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callToAction rdf:type rdf:Property ;
    rdfs:label 'Call To Action' ;
    rdfs:comment 'Specific call-to-action element that was clicked or engaged with (e.g., \'Book Now\', \'Learn More\', \'View Deals\').' ;
    rdfs:domain ind:CampaignResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complaintType rdf:type rdf:Property ;
    rdfs:label 'Complaint Type' ;
    rdfs:comment 'Type of complaint registered if response_type is complaint: spam, inappropriate_content, frequency (too many emails), other.' ;
    rdfs:domain ind:CampaignResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionFlag rdf:type rdf:Property ;
    rdfs:label 'Conversion Flag' ;
    rdfs:comment 'Boolean indicator whether this response resulted in a booking conversion (True) or not (False).' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:emailClient rdf:type rdf:Property ;
    rdfs:label 'Email Client' ;
    rdfs:comment 'Email client application used to open the email (e.g., Outlook, Gmail, Apple Mail). Applicable for email channel responses.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementScore rdf:type rdf:Property ;
    rdfs:label 'Engagement Score' ;
    rdfs:comment 'Calculated engagement score for this response based on interaction depth, time spent, and actions taken. Scale 0-100.' ;
    rdfs:domain ind:CampaignResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:formData rdf:type rdf:Property ;
    rdfs:label 'Form Data' ;
    rdfs:comment 'JSON or delimited string containing form field data submitted if response_type is form_submission. Null otherwise.' ;
    rdfs:domain ind:CampaignResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:landingPageUrl rdf:type rdf:Property ;
    rdfs:label 'Landing Page Url' ;
    rdfs:comment 'Full URL of the landing page where the user arrived after clicking through from the campaign.' ;
    rdfs:domain ind:CampaignResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingSystem rdf:type rdf:Property ;
    rdfs:label 'Operating System' ;
    rdfs:comment 'Operating system of the device used for the response (e.g., iOS, Android, Windows, macOS).' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referrerUrl rdf:type rdf:Property ;
    rdfs:label 'Referrer Url' ;
    rdfs:comment 'URL of the page that referred the user to the landing page, if available.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Response Timestamp' ;
    rdfs:comment 'Exact date and time when the response action occurred, in format yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:responseType rdf:type rdf:Property ;
    rdfs:label 'Response Type' ;
    rdfs:comment 'Type of response action taken by the recipient: click (link click), open (email open), conversion (booking completed), unsubscribe (opt-out), complaint (spam report), form_submission (lead capture).' ;
    rdfs:domain ind:CampaignResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionReference rdf:type rdf:Property ;
    rdfs:label 'Session Reference' ;
    rdfs:comment 'Web or app session identifier linking multiple interactions within the same user session.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeToConversionSeconds rdf:type rdf:Property ;
    rdfs:label 'Time To Conversion Seconds' ;
    rdfs:comment 'Number of seconds elapsed between the campaign send time and the conversion event. Null for non-conversion responses.' ;
    rdfs:domain ind:CampaignResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unsubscribeReason rdf:type rdf:Property ;
    rdfs:label 'Unsubscribe Reason' ;
    rdfs:comment 'Reason provided by the user for unsubscribing, if response_type is unsubscribe. Null otherwise.' ;
    rdfs:domain ind:CampaignResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utmCampaign rdf:type rdf:Property ;
    rdfs:label 'Utm Campaign' ;
    rdfs:comment 'UTM campaign parameter identifying the specific campaign name or code.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utmContent rdf:type rdf:Property ;
    rdfs:label 'Utm Content' ;
    rdfs:comment 'UTM content parameter used to differentiate similar content or links within the same campaign (e.g., A/B test variants).' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utmMedium rdf:type rdf:Property ;
    rdfs:label 'Utm Medium' ;
    rdfs:comment 'UTM medium parameter identifying the marketing medium (e.g., email, cpc, social).' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utmSource rdf:type rdf:Property ;
    rdfs:label 'Utm Source' ;
    rdfs:comment 'UTM source parameter identifying the traffic source (e.g., newsletter, facebook, google).' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coMarketingAgreementId rdf:type rdf:Property ;
    rdfs:label 'Co Marketing Agreement Id' ;
    rdfs:comment 'Unique identifier for the co-marketing agreement record. Primary key.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CoMarketingAgreement .

ind:partnerOrganizationId rdf:type rdf:Property ;
    rdfs:label 'Partner Organization Id' ;
    rdfs:comment 'Reference to the commercial partner organization (tourism board, hotel chain, car rental company, credit card issuer, destination marketing organization, or OTA).' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PartnerOrganization .

ind:agreementManager rdf:type rdf:Property ;
    rdfs:label 'Agreement Manager' ;
    rdfs:comment 'Name or identifier of the airline employee serving as the primary point of contact and manager for this co-marketing agreement.' ;
    rdfs:domain ind:CoMarketingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Agreement Reference Number' ;
    rdfs:comment 'External business identifier for the co-marketing agreement, used in contracts and partner communications.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementType rdf:type rdf:Property ;
    rdfs:label 'Agreement Type' ;
    rdfs:comment 'Classification of the co-marketing agreement defining the nature of the partnership and marketing collaboration model.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:airlineContributionAmount rdf:type rdf:Property ;
    rdfs:label 'Airline Contribution Amount' ;
    rdfs:comment 'Financial contribution committed by the airline to the co-marketing agreement budget.' ;
    rdfs:domain ind:CoMarketingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:campaignDeliverables rdf:type rdf:Property ;
    rdfs:label 'Campaign Deliverables' ;
    rdfs:comment 'Detailed description of the marketing deliverables, activities, and outputs committed under the co-marketing agreement (e.g., digital campaigns, print advertising, event sponsorships, content creation).' ;
    rdfs:domain ind:CoMarketingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Contract Document Reference' ;
    rdfs:comment 'Reference identifier or file path to the signed legal contract document for the co-marketing agreement.' ;
    rdfs:domain ind:CoMarketingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusivityFlag rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Flag' ;
    rdfs:comment 'Indicates whether the agreement grants exclusive co-marketing rights within a specific category or geography, preventing similar agreements with competing partners.' ;
    rdfs:domain ind:CoMarketingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jointBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Joint Budget Amount' ;
    rdfs:comment 'Total combined marketing budget committed by both the airline and partner for the duration of the agreement.' ;
    rdfs:domain ind:CoMarketingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:legalEntity rdf:type rdf:Property ;
    rdfs:label 'Legal Entity' ;
    rdfs:comment 'Name of the airline legal entity that is the contracting party for this co-marketing agreement.' ;
    rdfs:domain ind:CoMarketingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:owningCommercialTeam rdf:type rdf:Property ;
    rdfs:label 'Owning Commercial Team' ;
    rdfs:comment 'Name of the airline commercial or marketing team responsible for managing the co-marketing agreement and partner relationship.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerContributionAmount rdf:type rdf:Property ;
    rdfs:label 'Partner Contribution Amount' ;
    rdfs:comment 'Financial contribution committed by the partner organization to the co-marketing agreement budget.' ;
    rdfs:domain ind:CoMarketingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceMetrics rdf:type rdf:Property ;
    rdfs:label 'Performance Metrics' ;
    rdfs:comment 'Key performance indicators and success metrics defined to measure the effectiveness of the co-marketing agreement (e.g., incremental bookings, brand awareness lift, revenue targets).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalTerms rdf:type rdf:Property ;
    rdfs:label 'Renewal Terms' ;
    rdfs:comment 'Contractual terms and conditions governing the renewal or extension of the co-marketing agreement beyond the initial term.' ;
    rdfs:domain ind:CoMarketingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetPassengerSegment rdf:type rdf:Property ;
    rdfs:label 'Target Passenger Segment' ;
    rdfs:comment 'Description of the passenger segments or customer profiles targeted by the co-marketing agreement (e.g., leisure travelers, business travelers, FFP elite members).' ;
    rdfs:domain ind:CoMarketingAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Termination Notice Days' ;
    rdfs:comment 'Number of days advance notice required by either party to terminate the co-marketing agreement.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:communicationPreferenceId rdf:type rdf:Property ;
    rdfs:label 'Communication Preference Id' ;
    rdfs:comment 'Unique identifier for the communication preference record. Primary key.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:communicationCategory rdf:type rdf:Property ;
    rdfs:label 'Communication Category' ;
    rdfs:comment 'The type of marketing communication content. Distinct from operational notifications which are governed separately. Categories include promotional offers, flight deals, loyalty program updates, travel inspiration content, partner offers, and survey invitations.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Consent Expiry Date' ;
    rdfs:comment 'The date on which the passengers marketing consent expires and must be re-confirmed. Null if consent does not expire. Used in jurisdictions requiring periodic consent renewal.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:consentVersion rdf:type rdf:Property ;
    rdfs:label 'Consent Version' ;
    rdfs:comment 'Version identifier of the consent language and terms presented to the passenger at the time of opt-in. Enables tracking of consent under different privacy policy versions for regulatory compliance.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactCount rdf:type rdf:Property ;
    rdfs:label 'Contact Count' ;
    rdfs:comment 'The cumulative number of marketing messages sent to the passenger via this channel and category combination since opt-in. Used for frequency capping and engagement analysis.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:doubleOptInConfirmed rdf:type rdf:Property ;
    rdfs:label 'Double Opt In Confirmed' ;
    rdfs:comment 'Indicates whether the passenger has confirmed their opt-in through a double opt-in process (e.g., clicking a confirmation link in an email). True indicates confirmed, False indicates pending confirmation or single opt-in only.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:frequencyPreference rdf:type rdf:Property ;
    rdfs:label 'Frequency Preference' ;
    rdfs:comment 'Passenger-stated preference for how frequently they wish to receive marketing communications in this category and channel. Used to throttle message delivery and respect customer engagement preferences.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:globalUnsubscribeFlag rdf:type rdf:Property ;
    rdfs:label 'Global Unsubscribe Flag' ;
    rdfs:comment 'Indicates whether the passenger has opted out of ALL marketing communications across all channels and categories. True indicates global opt-out, False indicates channel/category-specific preferences apply.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ipAddressAtConsent rdf:type rdf:Property ;
    rdfs:label 'Ip Address At Consent' ;
    rdfs:comment 'The IP address from which the passenger provided their marketing consent. Captured for audit trail and fraud prevention purposes. May be considered PII in some jurisdictions.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languagePreference rdf:type rdf:Property ;
    rdfs:label 'Language Preference' ;
    rdfs:comment 'Two-letter ISO 639-1 language code indicating the passengers preferred language for receiving marketing communications. Ensures messages are delivered in the passengers language of choice.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastContactTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Contact Timestamp' ;
    rdfs:comment 'The date and time when the passenger was last contacted via this channel and category combination. Used to enforce frequency preferences and prevent over-communication.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:optInSource rdf:type rdf:Property ;
    rdfs:label 'Opt In Source' ;
    rdfs:comment 'The touchpoint or channel through which the passenger provided their marketing communication consent. Captures the origin of the opt-in action for audit and compliance purposes. [ENUM-REF-CANDIDATE: web|mobile_app|call_centre|airport_kiosk|booking_flow|loyalty_enrollment|third_party — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optInStatus rdf:type rdf:Property ;
    rdfs:label 'Opt In Status' ;
    rdfs:comment 'Indicates whether the passenger has opted in to receive marketing communications for this channel and category combination. True indicates consent granted, False indicates consent not granted or withdrawn.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optInTimestamp rdf:type rdf:Property ;
    rdfs:label 'Opt In Timestamp' ;
    rdfs:comment 'The date and time when the passenger granted consent to receive marketing communications for this channel and category. Null if passenger has never opted in.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:optOutTimestamp rdf:type rdf:Property ;
    rdfs:label 'Opt Out Timestamp' ;
    rdfs:comment 'The date and time when the passenger withdrew consent or opted out of receiving marketing communications for this channel and category. Null if passenger has not opted out.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:preferenceSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Preference Source System' ;
    rdfs:comment 'The operational system of record that captured or last updated this communication preference. Examples include Amadeus Altea PSS, Oracle Loyalty Cloud, airline website, mobile app. Used for data lineage and troubleshooting.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferenceStatus rdf:type rdf:Property ;
    rdfs:label 'Preference Status' ;
    rdfs:comment 'Current lifecycle status of the communication preference record. Active indicates the preference is in effect and should be honored by marketing suppression logic. Inactive indicates the preference is no longer valid. Suspended indicates temporary hold. Expired indicates the consent period has lapsed.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suppressionReason rdf:type rdf:Property ;
    rdfs:label 'Suppression Reason' ;
    rdfs:comment 'Free-text field capturing the reason why a passenger opted out or why their preference was suppressed. Used for customer service, analytics, and continuous improvement of marketing programs.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPartySharingConsent rdf:type rdf:Property ;
    rdfs:label 'Third Party Sharing Consent' ;
    rdfs:comment 'Indicates whether the passenger has consented to sharing their contact information with third-party partners for marketing purposes. True indicates consent granted, False indicates consent not granted.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:userAgentAtConsent rdf:type rdf:Property ;
    rdfs:label 'User Agent At Consent' ;
    rdfs:comment 'The browser user agent string captured at the time of consent. Used for audit trail and to understand the device/platform context of the opt-in.' ;
    rdfs:domain ind:CommunicationPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitorFareWatchId rdf:type rdf:Property ;
    rdfs:label 'Competitor Fare Watch Id' ;
    rdfs:comment 'Unique identifier for the competitor fare observation record.' ;
    rdfs:domain ind:CompetitorFareWatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allianceAffiliation rdf:type rdf:Property ;
    rdfs:label 'Alliance Affiliation' ;
    rdfs:comment 'The global airline alliance membership of the competitor carrier, if applicable.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codeshareFlag rdf:type rdf:Property ;
    rdfs:label 'Codeshare Flag' ;
    rdfs:comment 'Indicates whether the observed fare is for a codeshare flight operated by a partner carrier (true) or a flight operated by the marketing carrier itself (false).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:collectionMethod rdf:type rdf:Property ;
    rdfs:label 'Collection Method' ;
    rdfs:comment 'The technical method or process used to capture the competitor fare observation.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitorCarrierCode rdf:type rdf:Property ;
    rdfs:label 'Competitor Carrier Code' ;
    rdfs:comment 'Two-character IATA airline code identifying the competitor carrier whose fare was observed.' ;
    rdfs:domain ind:CompetitorFareWatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competitorFlightNumber rdf:type rdf:Property ;
    rdfs:label 'Competitor Flight Number' ;
    rdfs:comment 'The specific flight number operated by the competitor carrier for which the fare was observed, combining carrier code and numeric flight identifier.' ;
    rdfs:domain ind:CompetitorFareWatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fareConditionsSummary rdf:type rdf:Property ;
    rdfs:label 'Fare Conditions Summary' ;
    rdfs:comment 'Textual summary of key fare rules and restrictions observed, including refundability, change fees, minimum stay, and other material conditions.' ;
    rdfs:domain ind:CompetitorFareWatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fareType rdf:type rdf:Property ;
    rdfs:label 'Fare Type' ;
    rdfs:comment 'Classification of the observed fare indicating whether it is a standard published fare, private negotiated rate, promotional offer, or opaque fare.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdsSystemCode rdf:type rdf:Property ;
    rdfs:label 'Gds System Code' ;
    rdfs:comment 'Two-character code identifying the specific GDS system used for fare collection, if applicable (e.g., 1A for Amadeus, 1B for Abacus, 1G for Galileo, 1P for Worldspan, 1S for Sabre, 1V for Apollo).' ;
    rdfs:domain ind:CompetitorFareWatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketSegment rdf:type rdf:Property ;
    rdfs:label 'Market Segment' ;
    rdfs:comment 'The target customer segment or market classification for the observed fare (leisure, business, visiting friends and relatives, group, corporate).' ;
    rdfs:domain ind:CompetitorFareWatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberOfStops rdf:type rdf:Property ;
    rdfs:label 'Number Of Stops' ;
    rdfs:comment 'The number of intermediate stops or connections included in the observed fare itinerary (0 for nonstop, 1+ for connecting flights).' ;
    rdfs:domain ind:CompetitorFareWatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:observationStatus rdf:type rdf:Property ;
    rdfs:label 'Observation Status' ;
    rdfs:comment 'The current status of the fare observation record in the competitive intelligence system.' ;
    rdfs:domain ind:CompetitorFareWatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:observationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Observation Timestamp' ;
    rdfs:comment 'The exact date and time when the competitor fare was observed and captured from the data source.' ;
    rdfs:domain ind:CompetitorFareWatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:observedFareAmount rdf:type rdf:Property ;
    rdfs:label 'Observed Fare Amount' ;
    rdfs:comment 'The base fare amount observed for the competitor offering, excluding taxes and fees.' ;
    rdfs:domain ind:CompetitorFareWatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otaPlatformName rdf:type rdf:Property ;
    rdfs:label 'Ota Platform Name' ;
    rdfs:comment 'Name of the online travel agency or metasearch platform from which the fare was observed, if applicable.' ;
    rdfs:domain ind:CompetitorFareWatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnTravelDate rdf:type rdf:Property ;
    rdfs:label 'Return Travel Date' ;
    rdfs:comment 'The return departure date for round-trip fares, null for one-way observations.' ;
    rdfs:domain ind:CompetitorFareWatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:roundTripFlag rdf:type rdf:Property ;
    rdfs:label 'Round Trip Flag' ;
    rdfs:comment 'Indicates whether the observed fare is for a round-trip journey (true) or one-way travel (false).' ;
    rdfs:domain ind:CompetitorFareWatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scrapingSessionReference rdf:type rdf:Property ;
    rdfs:label 'Scraping Session Reference' ;
    rdfs:comment 'Identifier for the automated data collection session or batch run during which this fare observation was captured, enabling traceability and quality audits.' ;
    rdfs:domain ind:CompetitorFareWatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seatsAvailableCount rdf:type rdf:Property ;
    rdfs:label 'Seats Available Count' ;
    rdfs:comment 'The number of seats available in the observed booking class at the time of observation, if disclosed by the source system.' ;
    rdfs:domain ind:CompetitorFareWatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:taxesFeesAmount rdf:type rdf:Property ;
    rdfs:label 'Taxes Fees Amount' ;
    rdfs:comment 'The total amount of taxes, government fees, and carrier-imposed surcharges included in the total fare.' ;
    rdfs:domain ind:CompetitorFareWatch ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalFareAmount rdf:type rdf:Property ;
    rdfs:label 'Total Fare Amount' ;
    rdfs:comment 'The all-in fare amount including base fare, taxes, fees, and surcharges as displayed to the customer.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:destinationContentId rdf:type rdf:Property ;
    rdfs:label 'Destination Content Id' ;
    rdfs:comment 'Unique identifier for the destination content asset. Primary key.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DestinationContent .

ind:destinationStationId rdf:type rdf:Property ;
    rdfs:label 'Destination Station Id' ;
    rdfs:comment 'Foreign key linking to airport.station. Business justification: Destination content promotes travel to specific stations/cities for route development and destination awareness. Real business process: content marketing effectiveness measurement by destination stati' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Station .

ind:associatedRoutes rdf:type rdf:Property ;
    rdfs:label 'Associated Routes' ;
    rdfs:comment 'Comma-separated list of route codes or origin-destination pairs that this content supports, enabling route-specific marketing.' ;
    rdfs:domain ind:DestinationContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorName rdf:type rdf:Property ;
    rdfs:label 'Author Name' ;
    rdfs:comment 'Name of the content creator or author responsible for producing this destination content.' ;
    rdfs:domain ind:DestinationContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageTimeOnPageSeconds rdf:type rdf:Property ;
    rdfs:label 'Average Time On Page Seconds' ;
    rdfs:comment 'Average duration in seconds that users spend viewing this content, indicating engagement level.' ;
    rdfs:domain ind:DestinationContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contentCode rdf:type rdf:Property ;
    rdfs:label 'Content Code' ;
    rdfs:comment 'Unique business identifier code for the content asset, used for external reference and content management system integration.' ;
    rdfs:domain ind:DestinationContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentStatus rdf:type rdf:Property ;
    rdfs:label 'Content Status' ;
    rdfs:comment 'Current lifecycle status of the destination content asset in the content management workflow.' ;
    rdfs:domain ind:DestinationContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentType rdf:type rdf:Property ;
    rdfs:label 'Content Type' ;
    rdfs:comment 'Classification of the content format and purpose for destination marketing.' ;
    rdfs:domain ind:DestinationContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationContentDescription rdf:type rdf:Property ;
    rdfs:label 'Destination Content Description' ;
    rdfs:comment 'Detailed narrative description of the destination content, including key highlights and intended messaging.' ;
    rdfs:domain ind:DestinationContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fileFormat rdf:type rdf:Property ;
    rdfs:label 'File Format' ;
    rdfs:comment 'Technical file format of the content asset, such as HTML, PDF, MP4, JPG, or PNG.' ;
    rdfs:domain ind:DestinationContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageCode rdf:type rdf:Property ;
    rdfs:label 'Language Code' ;
    rdfs:comment 'ISO 639-1 two-letter language code indicating the language of the content.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pageViews rdf:type rdf:Property ;
    rdfs:label 'Page Views' ;
    rdfs:comment 'Total number of times this content has been viewed across all digital channels.' ;
    rdfs:domain ind:DestinationContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:promotionalOfferReference rdf:type rdf:Property ;
    rdfs:label 'Promotional Offer Reference' ;
    rdfs:comment 'Reference code or identifier linking this content to a specific promotional offer or campaign incentive.' ;
    rdfs:domain ind:DestinationContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seoKeywords rdf:type rdf:Property ;
    rdfs:label 'Seo Keywords' ;
    rdfs:comment 'Comma-separated list of search engine optimization keywords and phrases to improve content discoverability.' ;
    rdfs:domain ind:DestinationContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:socialShares rdf:type rdf:Property ;
    rdfs:label 'Social Shares' ;
    rdfs:comment 'Total count of times this content has been shared on social media platforms.' ;
    rdfs:domain ind:DestinationContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:title rdf:type rdf:Property ;
    rdfs:label 'Title' ;
    rdfs:comment 'The display title of the destination content asset as shown to customers across digital channels.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:abTestVariantId rdf:type rdf:Property ;
    rdfs:label 'Ab Test Variant Id' ;
    rdfs:comment 'Identifier for the A/B test variant or multivariate test cell this creative belongs to. Enables performance comparison across test groups.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AbTestVariant .

ind:assetFilePath rdf:type rdf:Property ;
    rdfs:label 'Asset File Path' ;
    rdfs:comment 'File system path or cloud storage location where the creative asset file is stored. Used for asset retrieval and management.' ;
    rdfs:domain ind:DigitalCampaignCreative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetFileSizeKb rdf:type rdf:Property ;
    rdfs:label 'Asset File Size Kb' ;
    rdfs:comment 'File size of the creative asset in kilobytes. Important for load time optimization and technical specifications.' ;
    rdfs:domain ind:DigitalCampaignCreative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bodyCopy rdf:type rdf:Property ;
    rdfs:label 'Body Copy' ;
    rdfs:comment 'Main body text or descriptive content of the creative. Supporting message that elaborates on the headline.' ;
    rdfs:domain ind:DigitalCampaignCreative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Brand Compliance Flag' ;
    rdfs:comment 'Boolean flag indicating whether the creative has been reviewed and confirmed to comply with brand guidelines and standards.' ;
    rdfs:domain ind:DigitalCampaignCreative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:callToActionText rdf:type rdf:Property ;
    rdfs:label 'Call To Action Text' ;
    rdfs:comment 'Text displayed on the call-to-action button or link (e.g., Book Now, Learn More, Sign Up). Drives user engagement and conversion.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creativeCode rdf:type rdf:Property ;
    rdfs:label 'Creative Code' ;
    rdfs:comment 'Unique business identifier or SKU for the creative asset, used for tracking and cross-system reference.' ;
    rdfs:domain ind:DigitalCampaignCreative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creativeName rdf:type rdf:Property ;
    rdfs:label 'Creative Name' ;
    rdfs:comment 'Human-readable name or title of the creative execution for identification and reporting purposes.' ;
    rdfs:domain ind:DigitalCampaignCreative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creativeType rdf:type rdf:Property ;
    rdfs:label 'Creative Type' ;
    rdfs:comment 'Classification of the creative format or execution type. Defines the medium and technical format of the creative asset. [ENUM-REF-CANDIDATE: banner_ad|rich_media|email_html|landing_page|video_preroll|social_image|social_video|push_notification|display_ad|native_ad — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DigitalCampaignCreative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationUrl rdf:type rdf:Property ;
    rdfs:label 'Destination Url' ;
    rdfs:comment 'Target landing page or destination URL where users are directed when they click on the creative. Includes tracking parameters.' ;
    rdfs:domain ind:DigitalCampaignCreative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formatDimensions rdf:type rdf:Property ;
    rdfs:label 'Format Dimensions' ;
    rdfs:comment 'Technical dimensions or specifications of the creative asset (e.g., 300x250, 728x90, 1920x1080, responsive). Captures size and aspect ratio.' ;
    rdfs:domain ind:DigitalCampaignCreative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:goLiveDate rdf:type rdf:Property ;
    rdfs:label 'Go Live Date' ;
    rdfs:comment 'Date when the creative is scheduled to go live and begin serving to audiences. Start of active campaign period.' ;
    rdfs:domain ind:DigitalCampaignCreative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:headlineCopy rdf:type rdf:Property ;
    rdfs:label 'Headline Copy' ;
    rdfs:comment 'Primary headline or title text displayed in the creative. Main attention-grabbing message for the audience.' ;
    rdfs:domain ind:DigitalCampaignCreative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isHighPerformer rdf:type rdf:Property ;
    rdfs:label 'Is High Performer' ;
    rdfs:comment 'Boolean flag indicating whether this creative has been identified as a high-performing asset based on engagement or conversion metrics.' ;
    rdfs:domain ind:DigitalCampaignCreative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Legal Compliance Flag' ;
    rdfs:comment 'Boolean flag indicating whether the creative has been reviewed and confirmed to comply with legal and regulatory requirements (e.g., advertising standards, consumer protection).' ;
    rdfs:domain ind:DigitalCampaignCreative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bounceReason rdf:type rdf:Property ;
    rdfs:label 'Bounce Reason' ;
    rdfs:comment 'Detailed reason or SMTP error message explaining why the email bounced. Null if delivered successfully.' ;
    rdfs:domain ind:EmailSend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bounceType rdf:type rdf:Property ;
    rdfs:label 'Bounce Type' ;
    rdfs:comment 'Classification of bounce reason when delivery_status indicates a bounce. Null if delivered successfully.' ;
    rdfs:domain ind:EmailSend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clickFlag rdf:type rdf:Property ;
    rdfs:label 'Click Flag' ;
    rdfs:comment 'Indicates whether the recipient clicked any link within the email. True if clicked, False otherwise.' ;
    rdfs:domain ind:EmailSend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clickedUrl rdf:type rdf:Property ;
    rdfs:label 'Clicked Url' ;
    rdfs:comment 'The first URL clicked by the recipient within the email. Null if no clicks recorded.' ;
    rdfs:domain ind:EmailSend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:espProvider rdf:type rdf:Property ;
    rdfs:label 'Esp Provider' ;
    rdfs:comment 'Name of the email service provider used to send this email (e.g., SendGrid, Mailchimp, Adobe Campaign).' ;
    rdfs:domain ind:EmailSend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstClickTimestamp rdf:type rdf:Property ;
    rdfs:label 'First Click Timestamp' ;
    rdfs:comment 'Date and time of the first recorded click event for any link in this email. Null if never clicked. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX' ;
    rdfs:domain ind:EmailSend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:firstOpenTimestamp rdf:type rdf:Property ;
    rdfs:label 'First Open Timestamp' ;
    rdfs:comment 'Date and time of the first recorded open event for this email. Null if never opened. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX' ;
    rdfs:domain ind:EmailSend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fromAddress rdf:type rdf:Property ;
    rdfs:label 'From Address' ;
    rdfs:comment 'Email address used in the From field of the email header.' ;
    rdfs:domain ind:EmailSend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:messageReference rdf:type rdf:Property ;
    rdfs:label 'Message Reference' ;
    rdfs:comment 'Unique message identifier assigned by the email service provider or SMTP server for tracking and troubleshooting.' ;
    rdfs:domain ind:EmailSend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openCity rdf:type rdf:Property ;
    rdfs:label 'Open City' ;
    rdfs:comment 'City name where the email was opened, derived from IP geolocation. Null if not opened or location unavailable.' ;
    rdfs:domain ind:EmailSend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openCountryCode rdf:type rdf:Property ;
    rdfs:label 'Open Country Code' ;
    rdfs:comment 'Three-letter ISO country code representing the geographic location where the email was opened, derived from IP address. Null if not opened.' ;
    rdfs:domain ind:EmailSend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openFlag rdf:type rdf:Property ;
    rdfs:label 'Open Flag' ;
    rdfs:comment 'Indicates whether the recipient opened the email (tracked via pixel or image load). True if opened, False otherwise.' ;
    rdfs:domain ind:EmailSend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:personalizationFlag rdf:type rdf:Property ;
    rdfs:label 'Personalization Flag' ;
    rdfs:comment 'Indicates whether the email content was personalized for the recipient (e.g., name, FFP tier, route preferences). True if personalized, False otherwise.' ;
    rdfs:domain ind:EmailSend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recipientEmailAddress rdf:type rdf:Property ;
    rdfs:label 'Recipient Email Address' ;
    rdfs:comment 'Email address to which the message was sent. May be anonymous or linked to passenger profile.' ;
    rdfs:domain ind:EmailSend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replyToAddress rdf:type rdf:Property ;
    rdfs:label 'Reply To Address' ;
    rdfs:comment 'Email address specified in the Reply-To field for recipient responses.' ;
    rdfs:domain ind:EmailSend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sendPriority rdf:type rdf:Property ;
    rdfs:label 'Send Priority' ;
    rdfs:comment 'Priority level assigned to this email send for queue processing and delivery scheduling.' ;
    rdfs:domain ind:EmailSend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sendTimestamp rdf:type rdf:Property ;
    rdfs:label 'Send Timestamp' ;
    rdfs:comment 'Date and time when the email was dispatched from the email service provider. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX' ;
    rdfs:domain ind:EmailSend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:spamComplaintFlag rdf:type rdf:Property ;
    rdfs:label 'Spam Complaint Flag' ;
    rdfs:comment 'Indicates whether the recipient marked this email as spam or junk. True if complaint filed, False otherwise.' ;
    rdfs:domain ind:EmailSend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:spamComplaintTimestamp rdf:type rdf:Property ;
    rdfs:label 'Spam Complaint Timestamp' ;
    rdfs:comment 'Date and time when the spam complaint was registered. Null if no complaint. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX' ;
    rdfs:domain ind:EmailSend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:subjectLine rdf:type rdf:Property ;
    rdfs:label 'Subject Line' ;
    rdfs:comment 'Subject line text of the email as sent to the recipient. May be personalized or A/B tested.' ;
    rdfs:domain ind:EmailSend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suppressionListFlag rdf:type rdf:Property ;
    rdfs:label 'Suppression List Flag' ;
    rdfs:comment 'Indicates whether this email address is on a suppression list (bounce, unsubscribe, complaint) at the time of send. True if suppressed, False otherwise.' ;
    rdfs:domain ind:EmailSend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalClickCount rdf:type rdf:Property ;
    rdfs:label 'Total Click Count' ;
    rdfs:comment 'Total number of link clicks recorded for this email (includes multiple clicks by same user).' ;
    rdfs:domain ind:EmailSend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalOpenCount rdf:type rdf:Property ;
    rdfs:label 'Total Open Count' ;
    rdfs:comment 'Total number of times the email was opened by the recipient (includes multiple opens by same user).' ;
    rdfs:domain ind:EmailSend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unsubscribeFlag rdf:type rdf:Property ;
    rdfs:label 'Unsubscribe Flag' ;
    rdfs:comment 'Indicates whether the recipient unsubscribed from the mailing list as a result of this email. True if unsubscribed, False otherwise.' ;
    rdfs:domain ind:EmailSend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unsubscribeTimestamp rdf:type rdf:Property ;
    rdfs:label 'Unsubscribe Timestamp' ;
    rdfs:comment 'Date and time when the recipient unsubscribed. Null if no unsubscribe event. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX' ;
    rdfs:domain ind:EmailSend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:commissioningManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Commissioning Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Commissioning manager is an employee responsible for research scope, budget approval, and strategic alignment. Airlines track research ownership for accountability, budget control, and strategic decis' ;
    rdfs:domain ind:MarketResearchStudy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:agencyContactEmail rdf:type rdf:Property ;
    rdfs:label 'Agency Contact Email' ;
    rdfs:comment 'Email address of the primary contact at the external research agency.' ;
    rdfs:domain ind:MarketResearchStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyContactName rdf:type rdf:Property ;
    rdfs:label 'Agency Contact Name' ;
    rdfs:comment 'Primary contact person at the external research agency responsible for the study execution.' ;
    rdfs:domain ind:MarketResearchStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissioningDepartment rdf:type rdf:Property ;
    rdfs:label 'Commissioning Department' ;
    rdfs:comment 'The internal department or business unit that commissioned or requested the market research study, such as Marketing, Commercial Strategy, Revenue Management, or Network Planning.' ;
    rdfs:domain ind:MarketResearchStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityLevel rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Level' ;
    rdfs:comment 'The data classification or confidentiality level assigned to the study findings and report, governing access and distribution.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataCollectionChannel rdf:type rdf:Property ;
    rdfs:label 'Data Collection Channel' ;
    rdfs:comment 'The channel or medium through which research data was collected, such as online survey, telephone interview, in-person focus group, mobile app, email, or social media.' ;
    rdfs:domain ind:MarketResearchStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalAgencyName rdf:type rdf:Property ;
    rdfs:label 'External Agency Name' ;
    rdfs:comment 'Name of the external market research agency or consulting firm contracted to conduct the study, if applicable. Null if conducted internally.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fieldworkEndDate rdf:type rdf:Property ;
    rdfs:label 'Fieldwork End Date' ;
    rdfs:comment 'The date when data collection or fieldwork activities concluded for the study.' ;
    rdfs:domain ind:MarketResearchStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fieldworkStartDate rdf:type rdf:Property ;
    rdfs:label 'Fieldwork Start Date' ;
    rdfs:comment 'The date when data collection or fieldwork activities began for the study.' ;
    rdfs:domain ind:MarketResearchStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:keyFindingsSummary rdf:type rdf:Property ;
    rdfs:label 'Key Findings Summary' ;
    rdfs:comment 'High-level summary of the key findings, insights, and conclusions from the market research study. Provides strategic intelligence for decision-making.' ;
    rdfs:domain ind:MarketResearchStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketResearchStudyStatus rdf:type rdf:Property ;
    rdfs:label 'Market Research Study Status' ;
    rdfs:comment 'Current lifecycle status of the market research study. Indicates whether the study is planned, in fieldwork phase, under analysis, completed, cancelled, or on hold.' ;
    rdfs:domain ind:MarketResearchStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Report Document Url' ;
    rdfs:comment 'URL or file path to the final research report document stored in the enterprise document management system.' ;
    rdfs:domain ind:MarketResearchStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:researchMethodology rdf:type rdf:Property ;
    rdfs:label 'Research Methodology' ;
    rdfs:comment 'The research approach or methodology employed for the study, such as quantitative survey, qualitative focus group, ethnographic research, secondary desk research, mixed methods, or conjoint analysis.' ;
    rdfs:domain ind:MarketResearchStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseRatePercent rdf:type rdf:Property ;
    rdfs:label 'Response Rate Percent' ;
    rdfs:comment 'The percentage of invited participants who completed the survey or participated in the research, calculated as (completed responses / total invitations) * 100.' ;
    rdfs:domain ind:MarketResearchStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sampleSize rdf:type rdf:Property ;
    rdfs:label 'Sample Size' ;
    rdfs:comment 'The planned or actual number of respondents or participants included in the research study.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:strategicPriority rdf:type rdf:Property ;
    rdfs:label 'Strategic Priority' ;
    rdfs:comment 'The strategic importance or priority level assigned to this research study by the commissioning team or executive leadership.' ;
    rdfs:domain ind:MarketResearchStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyCode rdf:type rdf:Property ;
    rdfs:label 'Study Code' ;
    rdfs:comment 'Unique business identifier or reference code assigned to the study for tracking and reporting purposes.' ;
    rdfs:domain ind:MarketResearchStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyEndDate rdf:type rdf:Property ;
    rdfs:label 'Study End Date' ;
    rdfs:comment 'The date when the market research study was completed, including final analysis and reporting.' ;
    rdfs:domain ind:MarketResearchStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:studyName rdf:type rdf:Property ;
    rdfs:label 'Study Name' ;
    rdfs:comment 'The official name or title of the market research study as commissioned by the marketing or commercial team.' ;
    rdfs:domain ind:MarketResearchStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:studyStartDate rdf:type rdf:Property ;
    rdfs:label 'Study Start Date' ;
    rdfs:comment 'The date when the market research study officially commenced, including planning or fieldwork initiation.' ;
    rdfs:domain ind:MarketResearchStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:studyType rdf:type rdf:Property ;
    rdfs:label 'Study Type' ;
    rdfs:comment 'The category or type of market research study. Examples include brand tracking, competitive benchmarking, route demand study, passenger needs assessment, concept testing, pricing sensitivity analysis, conjoint analysis, and customer satisfaction research.' ;
    rdfs:domain ind:MarketResearchStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetDemographic rdf:type rdf:Property ;
    rdfs:label 'Target Demographic' ;
    rdfs:comment 'Description of the target population or demographic segment for the research study, such as business travelers, leisure passengers, millennials, frequent flyers, or specific FFP tier members.' ;
    rdfs:domain ind:MarketResearchStudy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attributionWindowDays rdf:type rdf:Property ;
    rdfs:label 'Attribution Window Days' ;
    rdfs:comment 'Number of days after channel interaction during which conversions are attributed to this channel for marketing attribution analysis.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:channelDescription rdf:type rdf:Property ;
    rdfs:label 'Channel Description' ;
    rdfs:comment 'Detailed description of the marketing channel, including its purpose, target audience characteristics, and typical use cases for campaign delivery.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelName rdf:type rdf:Property ;
    rdfs:label 'Channel Name' ;
    rdfs:comment 'Human-readable name of the marketing channel used for passenger engagement and campaign delivery.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentFramework rdf:type rdf:Property ;
    rdfs:label 'Consent Framework' ;
    rdfs:comment 'Primary regulatory consent framework governing the use of this channel for marketing purposes. [ENUM-REF-CANDIDATE: gdpr|casl|can_spam|ccpa|lgpd|none|pecr|pipeda|appi — promote to reference product]' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costModel rdf:type rdf:Property ;
    rdfs:label 'Cost Model' ;
    rdfs:comment 'Pricing model for this channel: CPM (Cost Per Mille/thousand impressions), CPC (Cost Per Click), CPA (Cost Per Acquisition), fixed fee, hybrid, or free (owned channels).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costPerUnit rdf:type rdf:Property ;
    rdfs:label 'Cost Per Unit' ;
    rdfs:comment 'Standard cost per unit of the cost model (e.g., cost per thousand impressions for CPM, cost per click for CPC). Null for free or fixed-fee channels.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dataRetentionDays rdf:type rdf:Property ;
    rdfs:label 'Data Retention Days' ;
    rdfs:comment 'Number of days that campaign interaction data (opens, clicks, conversions) is retained for this channel, per regulatory and internal data governance policies.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deactivationReason rdf:type rdf:Property ;
    rdfs:label 'Deactivation Reason' ;
    rdfs:comment 'Business reason for deactivating this channel (e.g., poor performance, vendor contract termination, regulatory changes, strategic shift). Null for active channels.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doubleOptInRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Double Opt In Required Flag' ;
    rdfs:comment 'Indicates whether double opt-in (confirmation of consent) is required for this channel to comply with regulatory or internal policy requirements.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ffpIntegrationFlag rdf:type rdf:Property ;
    rdfs:label 'Ffp Integration Flag' ;
    rdfs:comment 'Indicates whether this channel is integrated with the airline\'s Frequent Flyer Program for targeted loyalty member communications.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:frequencyCapEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Frequency Cap Enabled Flag' ;
    rdfs:comment 'Indicates whether frequency capping (limiting the number of messages per customer per time period) is enabled for this channel to prevent over-communication.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:geographicAvailability rdf:type rdf:Property ;
    rdfs:label 'Geographic Availability' ;
    rdfs:comment 'Geographic markets or regions where this channel is available for campaign delivery (e.g., global, specific country codes, regional groupings).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:integrationStatus rdf:type rdf:Property ;
    rdfs:label 'Integration Status' ;
    rdfs:comment 'Current technical integration status of the channel with airline marketing systems and customer data platforms.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxFrequencyPerDay rdf:type rdf:Property ;
    rdfs:label 'Max Frequency Per Day' ;
    rdfs:comment 'Maximum number of messages allowed per customer per day through this channel when frequency capping is enabled. Null if no daily cap applies.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxFrequencyPerWeek rdf:type rdf:Property ;
    rdfs:label 'Max Frequency Per Week' ;
    rdfs:comment 'Maximum number of messages allowed per customer per week through this channel when frequency capping is enabled. Null if no weekly cap applies.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ownerTeam rdf:type rdf:Property ;
    rdfs:label 'Owner Team' ;
    rdfs:comment 'Internal business unit or team responsible for managing and operating this marketing channel.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:personalizationCapability rdf:type rdf:Property ;
    rdfs:label 'Personalization Capability' ;
    rdfs:comment 'Level of message personalization supported by this channel: none (broadcast only), basic (name/segment), advanced (behavioral), or dynamic (real-time).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformName rdf:type rdf:Property ;
    rdfs:label 'Platform Name' ;
    rdfs:comment 'Name of the technology platform or vendor system used to deliver campaigns through this channel (e.g., Salesforce Marketing Cloud, Braze, Google Ads).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platformVendor rdf:type rdf:Property ;
    rdfs:label 'Platform Vendor' ;
    rdfs:comment 'Name of the vendor or service provider that operates the platform for this channel.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pnrIntegrationFlag rdf:type rdf:Property ;
    rdfs:label 'Pnr Integration Flag' ;
    rdfs:comment 'Indicates whether this channel is integrated with the Passenger Service System to enable booking-triggered and journey-based communications.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reachPotential rdf:type rdf:Property ;
    rdfs:label 'Reach Potential' ;
    rdfs:comment 'Estimated audience reach potential of this channel: high (millions of passengers), medium (hundreds of thousands), or low (targeted segments).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:realTimeCapabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Real Time Capability Flag' ;
    rdfs:comment 'Indicates whether this channel supports real-time or near-real-time message delivery for time-sensitive campaigns (e.g., flight delay notifications, flash sales).' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaDeliveryTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Sla Delivery Time Minutes' ;
    rdfs:comment 'Contractual or expected maximum time in minutes from campaign trigger to message delivery for this channel. Used for operational and time-sensitive campaigns.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trackingCapability rdf:type rdf:Property ;
    rdfs:label 'Tracking Capability' ;
    rdfs:comment 'Level of campaign performance tracking available for this channel: full (impressions, clicks, conversions), partial (limited metrics), or none.' ;
    rdfs:domain ind:Channel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventId rdf:type rdf:Property ;
    rdfs:label 'Event Id' ;
    rdfs:comment 'Unique identifier for the marketing event record. Primary key.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualAttendance rdf:type rdf:Property ;
    rdfs:label 'Actual Attendance' ;
    rdfs:comment 'Confirmed number of attendees who actually participated in the marketing event, recorded post-event for performance measurement.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Actual Spend Amount' ;
    rdfs:comment 'Total actual expenditure incurred for the marketing event, recorded post-event for financial reconciliation and ROI analysis.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:boothNumber rdf:type rdf:Property ;
    rdfs:label 'Booth Number' ;
    rdfs:comment 'Assigned booth, stand, or exhibition space number at the event venue where the airline is represented.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boothSizeSqm rdf:type rdf:Property ;
    rdfs:label 'Booth Size Sqm' ;
    rdfs:comment 'Total floor area in square meters of the airline\'s exhibition booth or display space at the event.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedAttendance rdf:type rdf:Property ;
    rdfs:label 'Estimated Attendance' ;
    rdfs:comment 'Projected number of attendees expected to participate in the marketing event, used for planning and resource allocation.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eventName rdf:type rdf:Property ;
    rdfs:label 'Event Name' ;
    rdfs:comment 'Full name of the marketing event as it appears in promotional materials and internal documentation.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hostCity rdf:type rdf:Property ;
    rdfs:label 'Host City' ;
    rdfs:comment 'Name of the city where the marketing event is taking place.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hostCountryCode rdf:type rdf:Property ;
    rdfs:label 'Host Country Code' ;
    rdfs:comment 'Three-letter ISO country code for the country hosting the marketing event.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadGenerationTarget rdf:type rdf:Property ;
    rdfs:label 'Lead Generation Target' ;
    rdfs:comment 'Target number of qualified leads or prospect contacts the airline aims to capture during the marketing event.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:leadsCaptured rdf:type rdf:Property ;
    rdfs:label 'Leads Captured' ;
    rdfs:comment 'Actual number of qualified leads or prospect contacts captured during the marketing event, recorded post-event.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:managerEmail rdf:type rdf:Property ;
    rdfs:label 'Manager Email' ;
    rdfs:comment 'Email address of the event manager for coordination and communication purposes.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managerName rdf:type rdf:Property ;
    rdfs:label 'Manager Name' ;
    rdfs:comment 'Full name of the individual responsible for managing and coordinating all aspects of the marketing event.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketRegion rdf:type rdf:Property ;
    rdfs:label 'Market Region' ;
    rdfs:comment 'Geographic market or region that the event is targeting for passenger acquisition or brand presence.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:participationType rdf:type rdf:Property ;
    rdfs:label 'Participation Type' ;
    rdfs:comment 'The airline\'s role and level of involvement in the marketing event.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerOrganizations rdf:type rdf:Property ;
    rdfs:label 'Partner Organizations' ;
    rdfs:comment 'Names of external organizations, tourism boards, or partner airlines collaborating on the marketing event.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postEventOutcomeNotes rdf:type rdf:Property ;
    rdfs:label 'Post Event Outcome Notes' ;
    rdfs:comment 'Free-text summary of key outcomes, learnings, successes, and areas for improvement captured after the marketing event concludes.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roiScore rdf:type rdf:Property ;
    rdfs:label 'Roi Score' ;
    rdfs:comment 'Calculated return on investment score for the marketing event, expressed as a ratio or percentage, measuring financial effectiveness.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:strategicObjective rdf:type rdf:Property ;
    rdfs:label 'Strategic Objective' ;
    rdfs:comment 'High-level business goal or strategic priority that the marketing event is designed to support, such as brand awareness, route launch, or customer acquisition.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetAudience rdf:type rdf:Property ;
    rdfs:label 'Target Audience' ;
    rdfs:comment 'Primary audience segment that the marketing event is designed to reach and engage.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:venueAddress rdf:type rdf:Property ;
    rdfs:label 'Venue Address' ;
    rdfs:comment 'Full street address of the event venue including building number, street name, and any suite or floor information.' ;
    rdfs:domain ind:Event ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:venueName rdf:type rdf:Property ;
    rdfs:label 'Venue Name' ;
    rdfs:comment 'Name of the specific venue, convention center, hotel, or facility where the event is held.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spendId rdf:type rdf:Property ;
    rdfs:label 'Spend Id' ;
    rdfs:comment 'Unique identifier for the marketing spend record. Primary key for this entity.' ;
    rdfs:domain ind:Spend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fiscalMonth rdf:type rdf:Property ;
    rdfs:label 'Fiscal Month' ;
    rdfs:comment 'Fiscal month (1-12) to which this marketing spend is attributed. Used for monthly budget tracking and trend analysis.' ;
    rdfs:domain ind:Spend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fiscalQuarter rdf:type rdf:Property ;
    rdfs:label 'Fiscal Quarter' ;
    rdfs:comment 'Fiscal quarter to which this marketing spend is attributed. Used for quarterly budget tracking and seasonal spend analysis.' ;
    rdfs:domain ind:Spend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passengerSegment rdf:type rdf:Property ;
    rdfs:label 'Passenger Segment' ;
    rdfs:comment 'Target passenger segment for this marketing spend (e.g., business, leisure, premium, economy). Used for segment-specific marketing effectiveness analysis.' ;
    rdfs:domain ind:Spend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Planned Spend Amount' ;
    rdfs:comment 'Budgeted or planned expenditure amount for this marketing activity. Used for variance analysis against actual spend.' ;
    rdfs:domain ind:Spend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:routeGroup rdf:type rdf:Property ;
    rdfs:label 'Route Group' ;
    rdfs:comment 'Route group or network segment targeted by this marketing spend (e.g., domestic, international, long-haul). Specific to airline marketing spend attribution.' ;
    rdfs:domain ind:Spend ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spendType rdf:type rdf:Property ;
    rdfs:label 'Spend Type' ;
    rdfs:comment 'Classification of the marketing expenditure by nature of cost. Determines how the spend is categorized for budget tracking and ROI analysis.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Created By User Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Survey creator is an employee responsible for survey design, deployment, and data quality. Airlines track survey ownership for accountability, methodology validation, and performance measurement. Deno' ;
    rdfs:domain ind:NpsSurvey ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:activeStatus rdf:type rdf:Property ;
    rdfs:label 'Active Status' ;
    rdfs:comment 'Current operational status of the survey programme: active (currently distributing), inactive (ended), paused (temporarily suspended), draft (not yet launched), or archived (historical record).' ;
    rdfs:domain ind:NpsSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedCompletionMinutes rdf:type rdf:Property ;
    rdfs:label 'Estimated Completion Minutes' ;
    rdfs:comment 'The estimated time in minutes required for a respondent to complete the survey, communicated to passengers to set expectations.' ;
    rdfs:domain ind:NpsSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:incentiveDescription rdf:type rdf:Property ;
    rdfs:label 'Incentive Description' ;
    rdfs:comment 'Description of the incentive offered to survey respondents (e.g., \'500 bonus FFP miles\', \'Entry into monthly prize draw for 2 free tickets\'). Nullable if no incentive is offered.' ;
    rdfs:domain ind:NpsSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incentiveOffered rdf:type rdf:Property ;
    rdfs:label 'Incentive Offered' ;
    rdfs:comment 'Boolean flag indicating whether this survey programme offers an incentive for completion (e.g., FFP miles, prize draw entry, discount voucher).' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:privacyNoticeVersion rdf:type rdf:Property ;
    rdfs:label 'Privacy Notice Version' ;
    rdfs:comment 'Version identifier of the privacy notice and data protection disclosure presented to survey respondents, ensuring GDPR and regulatory compliance.' ;
    rdfs:domain ind:NpsSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:questionCount rdf:type rdf:Property ;
    rdfs:label 'Question Count' ;
    rdfs:comment 'The total number of questions in the survey instrument, used to estimate completion time and response burden.' ;
    rdfs:domain ind:NpsSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responseTargetCount rdf:type rdf:Property ;
    rdfs:label 'Response Target Count' ;
    rdfs:comment 'The target number of completed survey responses the programme aims to collect for statistical validity and business insight.' ;
    rdfs:domain ind:NpsSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responseWindowDays rdf:type rdf:Property ;
    rdfs:label 'Response Window Days' ;
    rdfs:comment 'The number of days after the trigger event during which the survey remains open for passenger response (e.g., 7 days post-flight).' ;
    rdfs:domain ind:NpsSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:samplingRatePercent rdf:type rdf:Property ;
    rdfs:label 'Sampling Rate Percent' ;
    rdfs:comment 'The percentage of eligible passengers who are randomly selected to receive the survey (e.g., 10.00 means 10% of eligible passengers are surveyed). Used to manage survey volume and avoid over-surveying.' ;
    rdfs:domain ind:NpsSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:surveyCloseDate rdf:type rdf:Property ;
    rdfs:label 'Survey Close Date' ;
    rdfs:comment 'The date when this survey programme ends and stops distributing new surveys. Nullable for ongoing programmes.' ;
    rdfs:domain ind:NpsSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:surveyCode rdf:type rdf:Property ;
    rdfs:label 'Survey Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the survey programme for operational reference and reporting (e.g., \'NPS_PF_2024Q1\', \'CSAT_LNG\').' ;
    rdfs:domain ind:NpsSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyInstrumentVersion rdf:type rdf:Property ;
    rdfs:label 'Survey Instrument Version' ;
    rdfs:comment 'Version identifier of the survey questionnaire and question set (e.g., \'v1.0\', \'v2.3\') to track changes in survey design over time and ensure comparability of results.' ;
    rdfs:domain ind:NpsSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyLanguageCodes rdf:type rdf:Property ;
    rdfs:label 'Survey Language Codes' ;
    rdfs:comment 'Comma-separated list of ISO 639-1 two-letter language codes in which this survey is available (e.g., \'EN,FR,DE,ES,ZH\') to support multilingual passenger base.' ;
    rdfs:domain ind:NpsSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyName rdf:type rdf:Property ;
    rdfs:label 'Survey Name' ;
    rdfs:comment 'Business-friendly name of the NPS or customer satisfaction survey programme (e.g., \'Post-Flight NPS Q1 2024\', \'Lounge Experience CSAT\').' ;
    rdfs:domain ind:NpsSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyOpenDate rdf:type rdf:Property ;
    rdfs:label 'Survey Open Date' ;
    rdfs:comment 'The date when this survey programme becomes active and begins distributing surveys to eligible passengers.' ;
    rdfs:domain ind:NpsSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:surveyType rdf:type rdf:Property ;
    rdfs:label 'Survey Type' ;
    rdfs:comment 'Classification of the survey methodology: transactional NPS (post-event), relational NPS (periodic brand health), CSAT (Customer Satisfaction Score), CES (Customer Effort Score), or custom survey format.' ;
    rdfs:domain ind:NpsSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyUrlTemplate rdf:type rdf:Property ;
    rdfs:label 'Survey Url Template' ;
    rdfs:comment 'The URL template or base link for the online survey instrument, with placeholders for personalization tokens (e.g., passenger ID, flight number). Used for email and digital distribution.' ;
    rdfs:domain ind:NpsSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyVendor rdf:type rdf:Property ;
    rdfs:label 'Survey Vendor' ;
    rdfs:comment 'Name of the third-party survey platform or vendor used to administer this survey (e.g., \'Qualtrics\', \'Medallia\', \'SurveyMonkey\', \'In-house Platform\').' ;
    rdfs:domain ind:NpsSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyVendorProgrammeCode rdf:type rdf:Property ;
    rdfs:label 'Survey Vendor Programme Code' ;
    rdfs:comment 'The unique identifier assigned by the survey vendor platform to this survey programme, used for integration and data retrieval from the vendor system.' ;
    rdfs:domain ind:NpsSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetAudienceCriteria rdf:type rdf:Property ;
    rdfs:label 'Target Audience Criteria' ;
    rdfs:comment 'Business rules defining which passengers or customer segments are eligible to receive this survey (e.g., \'All passengers on long-haul flights\', \'FFP Gold and Platinum members\', \'Business class passengers on transatlantic routes\').' ;
    rdfs:domain ind:NpsSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:triggerEvent rdf:type rdf:Property ;
    rdfs:label 'Trigger Event' ;
    rdfs:comment 'The customer touchpoint or business event that triggers distribution of this survey (e.g., post-flight, post-check-in, post-lounge-visit, post-contact-centre-interaction, periodic brand survey). [ENUM-REF-CANDIDATE: post_flight|post_checkin|post_lounge_visit|post_contact_centre|post_booking|post_baggage_claim|periodic|custom — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:NpsSurvey ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passengerTouchpointId rdf:type rdf:Property ;
    rdfs:label 'Passenger Touchpoint Id' ;
    rdfs:comment 'Unique identifier for each passenger touchpoint interaction record.' ;
    rdfs:domain ind:PassengerTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contentViewed rdf:type rdf:Property ;
    rdfs:label 'Content Viewed' ;
    rdfs:comment 'Description or identifier of the content, page, or screen viewed during the touchpoint (e.g., URL path, page title, IFE content ID).' ;
    rdfs:domain ind:PassengerTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionType rdf:type rdf:Property ;
    rdfs:label 'Conversion Type' ;
    rdfs:comment 'Type of conversion that occurred as a result of this touchpoint, if any.' ;
    rdfs:domain ind:PassengerTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerSegment rdf:type rdf:Property ;
    rdfs:label 'Customer Segment' ;
    rdfs:comment 'Marketing or customer segment classification of the passenger at the time of the touchpoint (e.g., business traveler, leisure, VIP).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Engagement Duration Seconds' ;
    rdfs:comment 'Duration of the touchpoint interaction in seconds (e.g., time spent on page, call duration, IFE session length).' ;
    rdfs:domain ind:PassengerTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:geographicCity rdf:type rdf:Property ;
    rdfs:label 'Geographic City' ;
    rdfs:comment 'City name where the touchpoint interaction occurred, derived from IP geolocation or device location.' ;
    rdfs:domain ind:PassengerTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicCountryCode rdf:type rdf:Property ;
    rdfs:label 'Geographic Country Code' ;
    rdfs:comment 'Three-letter ISO country code representing the geographic location of the touchpoint interaction.' ;
    rdfs:domain ind:PassengerTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interactionDepth rdf:type rdf:Property ;
    rdfs:label 'Interaction Depth' ;
    rdfs:comment 'Measure of interaction depth such as scroll depth percentage, pages per session, or clicks within the touchpoint.' ;
    rdfs:domain ind:PassengerTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pageUrl rdf:type rdf:Property ;
    rdfs:label 'Page Url' ;
    rdfs:comment 'Full URL of the web page or app screen viewed during the touchpoint, if applicable.' ;
    rdfs:domain ind:PassengerTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueAmount rdf:type rdf:Property ;
    rdfs:label 'Revenue Amount' ;
    rdfs:comment 'Revenue amount directly attributed to this touchpoint interaction, if a purchase or booking occurred.' ;
    rdfs:domain ind:PassengerTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueCurrency rdf:type rdf:Property ;
    rdfs:label 'Revenue Currency' ;
    rdfs:comment 'Three-letter ISO currency code for the revenue amount attributed to this touchpoint.' ;
    rdfs:domain ind:PassengerTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:touchpointStatus rdf:type rdf:Property ;
    rdfs:label 'Touchpoint Status' ;
    rdfs:comment 'Status of the touchpoint interaction indicating whether it was completed successfully or abandoned.' ;
    rdfs:domain ind:PassengerTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:touchpointTimestamp rdf:type rdf:Property ;
    rdfs:label 'Touchpoint Timestamp' ;
    rdfs:comment 'Precise date and time when the passenger touchpoint interaction occurred, in format yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:PassengerTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:touchpointType rdf:type rdf:Property ;
    rdfs:label 'Touchpoint Type' ;
    rdfs:comment 'Classification of the marketing or commercial touchpoint interaction type. [ENUM-REF-CANDIDATE: website_visit|mobile_app_session|email_open|email_click|ad_impression|ad_click|call_center_contact|airport_kiosk|checkin_counter|gate_interaction|lounge_visit|ife_engagement|chatbot_session|sms_interaction|push_notification|social_media_interaction — promote to reference product]' ;
    rdfs:domain ind:PassengerTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utmTerm rdf:type rdf:Property ;
    rdfs:label 'Utm Term' ;
    rdfs:comment 'UTM term parameter identifying paid search keywords for campaign attribution.' ;
    rdfs:domain ind:PassengerTouchpoint ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fareId rdf:type rdf:Property ;
    rdfs:label 'Fare Id' ;
    rdfs:comment 'Foreign key linking to revenue.fare. Business justification: Links promotional fare campaigns to actual fare records in revenue system for pricing execution, inventory control, and yield management. Airlines must connect marketing promotions to operational fare' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fare .

ind:primaryPromotionalEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Promotional Employee Id' ;
    rdfs:comment 'User identifier of the marketing or revenue management staff member who created this promotional fare record.' ;
    rdfs:domain ind:PromotionalFare ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:bookingWindowEndDate rdf:type rdf:Property ;
    rdfs:label 'Booking Window End Date' ;
    rdfs:comment 'Last date on which passengers can book this promotional fare.' ;
    rdfs:domain ind:PromotionalFare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bookingWindowStartDate rdf:type rdf:Property ;
    rdfs:label 'Booking Window Start Date' ;
    rdfs:comment 'First date on which passengers can book this promotional fare.' ;
    rdfs:domain ind:PromotionalFare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:changeableFlag rdf:type rdf:Property ;
    rdfs:label 'Changeable Flag' ;
    rdfs:comment 'Indicates whether tickets purchased under this promotional fare allow date or flight changes. True = changeable, False = non-changeable.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discountPercentage rdf:type rdf:Property ;
    rdfs:label 'Discount Percentage' ;
    rdfs:comment 'Percentage discount off the standard published fare, if applicable. Null if promotional fare is an absolute amount.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:distributionChannels rdf:type rdf:Property ;
    rdfs:label 'Distribution Channels' ;
    rdfs:comment 'Comma-separated list of channels through which this promotional fare is available (e.g., \'website\', \'mobile_app\', \'GDS\', \'call_center\', \'travel_agent\').' ;
    rdfs:domain ind:PromotionalFare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumStayDays rdf:type rdf:Property ;
    rdfs:label 'Maximum Stay Days' ;
    rdfs:comment 'Maximum number of days the passenger may stay at the destination under this promotional fare. Null if no maximum stay restriction.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumStayDays rdf:type rdf:Property ;
    rdfs:label 'Minimum Stay Days' ;
    rdfs:comment 'Minimum number of days the passenger must stay at the destination to qualify for this promotional fare. Null if no minimum stay required.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:promotionalFareStatus rdf:type rdf:Property ;
    rdfs:label 'Promotional Fare Status' ;
    rdfs:comment 'Current lifecycle status of the promotional fare offer.' ;
    rdfs:domain ind:PromotionalFare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seatAllocationTotal rdf:type rdf:Property ;
    rdfs:label 'Seat Allocation Total' ;
    rdfs:comment 'Total number of seats allocated across all flights for this promotional fare offer. Null if unlimited.' ;
    rdfs:domain ind:PromotionalFare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seatCapPerFlight rdf:type rdf:Property ;
    rdfs:label 'Seat Cap Per Flight' ;
    rdfs:comment 'Maximum number of promotional fare seats available on any single flight. Null if no per-flight cap.' ;
    rdfs:domain ind:PromotionalFare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:travelWindowEndDate rdf:type rdf:Property ;
    rdfs:label 'Travel Window End Date' ;
    rdfs:comment 'Last date of travel for which this promotional fare is valid.' ;
    rdfs:domain ind:PromotionalFare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:travelWindowStartDate rdf:type rdf:Property ;
    rdfs:label 'Travel Window Start Date' ;
    rdfs:comment 'First date of travel for which this promotional fare is valid.' ;
    rdfs:domain ind:PromotionalFare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:segmentMembershipId rdf:type rdf:Property ;
    rdfs:label 'Segment Membership Id' ;
    rdfs:comment 'Unique identifier for the segment membership record. Primary key for the segment membership association entity.' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignmentConfidenceScore rdf:type rdf:Property ;
    rdfs:label 'Assignment Confidence Score' ;
    rdfs:comment 'Confidence score for machine learning-derived segment memberships, ranging from 0.0000 to 1.0000. Higher values indicate greater model confidence in the segment assignment. Null for rule-based or manual assignments.' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignmentReasonCode rdf:type rdf:Property ;
    rdfs:label 'Assignment Reason Code' ;
    rdfs:comment 'Code indicating the specific business rule, model feature, or trigger that caused the passenger to be assigned to this segment. Supports explainability and audit requirements.' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Assignment Reason Description' ;
    rdfs:comment 'Human-readable explanation of why the passenger was assigned to this segment. Provides business context for the assignment decision.' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:campaignEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Campaign Eligibility Flag' ;
    rdfs:comment 'Indicates whether this segment membership makes the passenger eligible for targeted marketing campaigns. False may indicate suppression due to opt-out, regulatory restrictions, or business rules.' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastCampaignContactDate rdf:type rdf:Property ;
    rdfs:label 'Last Campaign Contact Date' ;
    rdfs:comment 'The most recent date when the passenger was contacted as part of a campaign targeting this segment. Used for frequency capping and contact optimization.' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:membershipEndDate rdf:type rdf:Property ;
    rdfs:label 'Membership End Date' ;
    rdfs:comment 'The date when the passenger exited this segment. Null if the passenger is currently an active member of the segment. Represents the effective-until date for segment membership.' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:membershipStartDate rdf:type rdf:Property ;
    rdfs:label 'Membership Start Date' ;
    rdfs:comment 'The date when the passenger became a member of this segment. Represents the effective-from date for segment membership.' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:optOutFlag rdf:type rdf:Property ;
    rdfs:label 'Opt Out Flag' ;
    rdfs:comment 'Indicates whether the passenger has opted out of marketing communications for this specific segment. True indicates opt-out, false indicates consent to receive segment-targeted communications.' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:segmentEntryChannel rdf:type rdf:Property ;
    rdfs:label 'Segment Entry Channel' ;
    rdfs:comment 'The marketing channel or touchpoint that triggered the passengers entry into this segment. Examples include web, mobile app, email campaign, call center, airport kiosk, social media.' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentExitReason rdf:type rdf:Property ;
    rdfs:label 'Segment Exit Reason' ;
    rdfs:comment 'Reason code or description explaining why the passenger exited this segment. Examples include criteria no longer met, manual removal, segment sunset, passenger churn, data quality issue.' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentVersion rdf:type rdf:Property ;
    rdfs:label 'Segment Version' ;
    rdfs:comment 'Version identifier of the segment definition at the time of assignment. Enables tracking of segment membership against evolving segment criteria and supports retrospective attribution analysis.' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCampaignResponses rdf:type rdf:Property ;
    rdfs:label 'Total Campaign Responses' ;
    rdfs:comment 'Cumulative count of campaign responses (clicks, conversions, bookings) attributed to this segment membership. Supports segment performance measurement and ROI analysis.' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalCampaignsReceived rdf:type rdf:Property ;
    rdfs:label 'Total Campaigns Received' ;
    rdfs:comment 'Cumulative count of marketing campaigns the passenger has received while being a member of this segment. Supports frequency analysis and campaign fatigue monitoring.' ;
    rdfs:domain ind:SegmentMembership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:socialMediaPostId rdf:type rdf:Property ;
    rdfs:label 'Social Media Post Id' ;
    rdfs:comment 'Unique identifier for the social media post record.' ;
    rdfs:domain ind:SocialMediaPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountHandle rdf:type rdf:Property ;
    rdfs:label 'Account Handle' ;
    rdfs:comment 'The airline\'s social media account handle or username on the platform (e.g., @AirlineName).' ;
    rdfs:domain ind:SocialMediaPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualPublishTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Publish Timestamp' ;
    rdfs:comment 'The actual date and time when the post was successfully published to the platform.' ;
    rdfs:domain ind:SocialMediaPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:boostedSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Boosted Spend Amount' ;
    rdfs:comment 'The amount spent to boost or promote this post, if applicable.' ;
    rdfs:domain ind:SocialMediaPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:boostedSpendCurrency rdf:type rdf:Property ;
    rdfs:label 'Boosted Spend Currency' ;
    rdfs:comment 'The three-letter ISO 4217 currency code for the boosted spend amount.' ;
    rdfs:domain ind:SocialMediaPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:comments rdf:type rdf:Property ;
    rdfs:label 'Comments' ;
    rdfs:comment 'Total number of comments posted by users on this post.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentText rdf:type rdf:Property ;
    rdfs:label 'Content Text' ;
    rdfs:comment 'The text content or caption of the social media post, including hashtags and mentions.' ;
    rdfs:domain ind:SocialMediaPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementRate rdf:type rdf:Property ;
    rdfs:label 'Engagement Rate' ;
    rdfs:comment 'Calculated engagement rate as a percentage, representing total engagements (likes, comments, shares, saves) divided by reach or impressions.' ;
    rdfs:domain ind:SocialMediaPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hashtags rdf:type rdf:Property ;
    rdfs:label 'Hashtags' ;
    rdfs:comment 'Comma-separated list of hashtags used in the post for discoverability and campaign tracking.' ;
    rdfs:domain ind:SocialMediaPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impressions rdf:type rdf:Property ;
    rdfs:label 'Impressions' ;
    rdfs:comment 'Total number of times the post was displayed to users, regardless of whether it was clicked or engaged with.' ;
    rdfs:domain ind:SocialMediaPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:likes rdf:type rdf:Property ;
    rdfs:label 'Likes' ;
    rdfs:comment 'Total number of likes or reactions the post received.' ;
    rdfs:domain ind:SocialMediaPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:linkClicks rdf:type rdf:Property ;
    rdfs:label 'Link Clicks' ;
    rdfs:comment 'Total number of clicks on links embedded in the post content.' ;
    rdfs:domain ind:SocialMediaPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mediaAttachmentReference rdf:type rdf:Property ;
    rdfs:label 'Media Attachment Reference' ;
    rdfs:comment 'Reference identifier or URI to the media assets (images, videos, graphics) attached to the post, stored in the brand asset management system.' ;
    rdfs:domain ind:SocialMediaPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mentions rdf:type rdf:Property ;
    rdfs:label 'Mentions' ;
    rdfs:comment 'Comma-separated list of user handles or accounts mentioned in the post.' ;
    rdfs:domain ind:SocialMediaPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platform rdf:type rdf:Property ;
    rdfs:label 'Platform' ;
    rdfs:comment 'The social media platform where the post is published (Instagram, Facebook, X/Twitter, LinkedIn, TikTok, YouTube). [ENUM-REF-CANDIDATE: Instagram|Facebook|X|LinkedIn|TikTok|YouTube|WeChat|LINE — promote to reference product]' ;
    rdfs:domain ind:SocialMediaPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Post Reference Number' ;
    rdfs:comment 'Business-facing unique reference code for the social media post, used for tracking and governance.' ;
    rdfs:domain ind:SocialMediaPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postStatus rdf:type rdf:Property ;
    rdfs:label 'Post Status' ;
    rdfs:comment 'Current lifecycle status of the post: draft (being created), scheduled (queued for publishing), published (live), deleted (removed), failed (publishing error).' ;
    rdfs:domain ind:SocialMediaPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postType rdf:type rdf:Property ;
    rdfs:label 'Post Type' ;
    rdfs:comment 'Classification of the post type: organic (unpaid), boosted (promoted organic), paid dark post (paid without organic presence), story, reel, carousel.' ;
    rdfs:domain ind:SocialMediaPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postUrl rdf:type rdf:Property ;
    rdfs:label 'Post Url' ;
    rdfs:comment 'The direct URL link to the published post on the social media platform.' ;
    rdfs:domain ind:SocialMediaPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reach rdf:type rdf:Property ;
    rdfs:label 'Reach' ;
    rdfs:comment 'Total number of unique users who saw the post at least once.' ;
    rdfs:domain ind:SocialMediaPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:saves rdf:type rdf:Property ;
    rdfs:label 'Saves' ;
    rdfs:comment 'Total number of times users saved or bookmarked the post for later viewing.' ;
    rdfs:domain ind:SocialMediaPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scheduledPublishTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Publish Timestamp' ;
    rdfs:comment 'The planned date and time when the post is scheduled to be published to the platform.' ;
    rdfs:domain ind:SocialMediaPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:sentimentScore rdf:type rdf:Property ;
    rdfs:label 'Sentiment Score' ;
    rdfs:comment 'Aggregated sentiment score derived from user comments and reactions, typically ranging from -1.0 (negative) to +1.0 (positive).' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shares rdf:type rdf:Property ;
    rdfs:label 'Shares' ;
    rdfs:comment 'Total number of times the post was shared or reposted by users.' ;
    rdfs:domain ind:SocialMediaPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:videoViews rdf:type rdf:Property ;
    rdfs:label 'Video Views' ;
    rdfs:comment 'Total number of video views if the post contains video content, measured according to platform-specific view thresholds.' ;
    rdfs:domain ind:SocialMediaPost ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sponsorshipId rdf:type rdf:Property ;
    rdfs:label 'Sponsorship Id' ;
    rdfs:comment 'Unique identifier for the sponsorship agreement record. Primary key.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Sponsorship .

ind:activationStatus rdf:type rdf:Property ;
    rdfs:label 'Activation Status' ;
    rdfs:comment 'Current operational state of the sponsorship: active (rights being exercised), inactive (signed but not yet started), pending (under negotiation), suspended (temporarily paused), expired (term ended), or terminated (cancelled before term end).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualValue rdf:type rdf:Property ;
    rdfs:label 'Annual Value' ;
    rdfs:comment 'Average annual monetary value of the sponsorship, calculated by dividing contracted value by term in years.' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brandAlignmentScore rdf:type rdf:Property ;
    rdfs:label 'Brand Alignment Score' ;
    rdfs:comment 'Internal assessment score (typically 1-10) measuring how well the sponsorship aligns with the airline\'s brand values, target demographics, and strategic positioning.' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractSignedDate rdf:type rdf:Property ;
    rdfs:label 'Contract Signed Date' ;
    rdfs:comment 'The date when the sponsorship agreement was formally executed by both parties, in yyyy-MM-dd format.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractTermMonths rdf:type rdf:Property ;
    rdfs:label 'Contract Term Months' ;
    rdfs:comment 'Duration of the sponsorship agreement expressed in months, calculated from start to end date.' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractedValue rdf:type rdf:Property ;
    rdfs:label 'Contracted Value' ;
    rdfs:comment 'Total monetary value of the sponsorship agreement over its full term, representing the airline\'s financial commitment.' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exclusivityCategory rdf:type rdf:Property ;
    rdfs:label 'Exclusivity Category' ;
    rdfs:comment 'The product or service category in which the airline holds exclusive sponsorship rights (e.g., \'official airline\', \'exclusive aviation partner\'), preventing competitor sponsorships in the same category.' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicMarket rdf:type rdf:Property ;
    rdfs:label 'Geographic Market' ;
    rdfs:comment 'Primary geographic market or country where the sponsorship has brand visibility and activation, using ISO 3166-1 alpha-3 country code (e.g., USA, GBR, AUS).' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hospitalityEntitlement rdf:type rdf:Property ;
    rdfs:label 'Hospitality Entitlement' ;
    rdfs:comment 'Description of hospitality benefits included in the sponsorship, such as number of VIP tickets, suite access, meet-and-greet opportunities, and event passes.' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:logoPlacementRights rdf:type rdf:Property ;
    rdfs:label 'Logo Placement Rights' ;
    rdfs:comment 'Specific locations and formats where the airline logo may be displayed (e.g., jersey front, stadium signage, broadcast overlays, digital assets).' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentStructure rdf:type rdf:Property ;
    rdfs:label 'Payment Structure' ;
    rdfs:comment 'The schedule and method by which sponsorship fees are paid to the partner organization.' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceKpiDescription rdf:type rdf:Property ;
    rdfs:label 'Performance Kpi Description' ;
    rdfs:comment 'Description of the key performance indicators used to measure sponsorship effectiveness, such as brand awareness lift, media impressions, social media engagement, or incremental bookings.' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionalScope rdf:type rdf:Property ;
    rdfs:label 'Regional Scope' ;
    rdfs:comment 'Geographic reach of the sponsorship activation: local (city/metro), national (single country), regional (multi-country area), or global (worldwide visibility).' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Deadline Date' ;
    rdfs:comment 'The date by which the airline must notify the partner of intent to renew, in yyyy-MM-dd format. Nullable if no renewal option exists.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalOptionDetails rdf:type rdf:Property ;
    rdfs:label 'Renewal Option Details' ;
    rdfs:comment 'Description of renewal terms, including notice period required, pricing adjustment mechanisms, and any conditions precedent for exercising the renewal option.' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rightsPackageDescription rdf:type rdf:Property ;
    rdfs:label 'Rights Package Description' ;
    rdfs:comment 'Comprehensive description of the sponsorship benefits and rights granted, including logo placement locations, hospitality ticket allocations, co-branded advertising opportunities, route promotion rights, social media mentions, and other activation entitlements.' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorshipCategory rdf:type rdf:Property ;
    rdfs:label 'Sponsorship Category' ;
    rdfs:comment 'High-level classification of the sponsorship by thematic area to support portfolio analysis and strategic alignment. [ENUM-REF-CANDIDATE: sports|entertainment|culture|tourism|community|sustainability|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorshipCode rdf:type rdf:Property ;
    rdfs:label 'Sponsorship Code' ;
    rdfs:comment 'Internal alphanumeric code used to uniquely identify and track the sponsorship in financial and marketing systems.' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorshipName rdf:type rdf:Property ;
    rdfs:label 'Sponsorship Name' ;
    rdfs:comment 'The official name or title of the sponsorship agreement as recognized in marketing materials and contracts.' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorshipType rdf:type rdf:Property ;
    rdfs:label 'Sponsorship Type' ;
    rdfs:comment 'Classification of the sponsorship level and nature: title sponsor (highest tier, brand in event name), presenting sponsor (secondary tier), official airline partner (category exclusivity), jersey sponsor (logo on team uniform), stadium naming rights (venue branding), or event sponsor (single event support).' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:terminationClauseSummary rdf:type rdf:Property ;
    rdfs:label 'Termination Clause Summary' ;
    rdfs:comment 'Summary of conditions under which either party may terminate the sponsorship agreement early, including notice periods and financial penalties.' ;
    rdfs:domain ind:Sponsorship ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorshipActivationId rdf:type rdf:Property ;
    rdfs:label 'Sponsorship Activation Id' ;
    rdfs:comment 'Unique identifier for the sponsorship activation event. Primary key for this transactional record capturing a specific deliverable execution under a sponsorship agreement.' ;
    rdfs:domain ind:SponsorshipActivation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:activationManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Activation Manager Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Activation manager is an employee responsible for sponsorship execution, deliverable tracking, and partner relationship management. Airlines track activation ownership for accountability, performance ' ;
    rdfs:domain ind:SponsorshipActivation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:contractDeliverableId rdf:type rdf:Property ;
    rdfs:label 'Contract Deliverable Id' ;
    rdfs:comment 'Reference to the specific deliverable line item in the sponsorship contract that this activation fulfills. Enables tracking of contract fulfillment and rights utilization.' ;
    rdfs:domain ind:Marketing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContractDeliverable .

ind:activationEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Activation End Timestamp' ;
    rdfs:comment 'Precise date and time when the activation event concluded. Enables calculation of activation duration and supports time-based performance analysis.' ;
    rdfs:domain ind:SponsorshipActivation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:activationReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Activation Reference Number' ;
    rdfs:comment 'Business-facing unique reference code or number assigned to this activation event for tracking and reporting purposes. Used in communications with sponsors and internal stakeholders.' ;
    rdfs:domain ind:SponsorshipActivation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activationStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Activation Start Timestamp' ;
    rdfs:comment 'Precise date and time when the activation event began. Used for time-bound activations such as hospitality events, press conferences, or limited-duration digital campaigns.' ;
    rdfs:domain ind:SponsorshipActivation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:activationType rdf:type rdf:Property ;
    rdfs:label 'Activation Type' ;
    rdfs:comment 'Category of sponsorship activation deliverable executed. Defines the nature of the marketing touchpoint or brand exposure delivered to the sponsor under the agreement. [ENUM-REF-CANDIDATE: hospitality_event|co_branded_campaign|airport_activation|social_media_post|press_event|in_stadium_branding|lounge_branding|aircraft_livery|digital_display|experiential_activation — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SponsorshipActivation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualAudienceReach rdf:type rdf:Property ;
    rdfs:label 'Actual Audience Reach' ;
    rdfs:comment 'Verified number of individuals who were exposed to the sponsorship activation based on post-event measurement. Critical for ROI analysis and sponsor value reporting.' ;
    rdfs:domain ind:SponsorshipActivation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualSpendUsd rdf:type rdf:Property ;
    rdfs:label 'Actual Spend Usd' ;
    rdfs:comment 'Total actual expenditure incurred to execute this activation event, expressed in US dollars. Includes production costs, venue fees, staffing, and all direct activation expenses.' ;
    rdfs:domain ind:SponsorshipActivation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetedSpendUsd rdf:type rdf:Property ;
    rdfs:label 'Budgeted Spend Usd' ;
    rdfs:comment 'Planned budget allocated for this activation event, expressed in US dollars. Used for budget variance analysis and financial planning of sponsorship programs.' ;
    rdfs:domain ind:SponsorshipActivation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contentUrl rdf:type rdf:Property ;
    rdfs:label 'Content Url' ;
    rdfs:comment 'Web address or link to the digital content created for this activation. Enables direct access to social media posts, landing pages, or digital assets produced.' ;
    rdfs:domain ind:SponsorshipActivation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverableDescription rdf:type rdf:Property ;
    rdfs:label 'Deliverable Description' ;
    rdfs:comment 'Detailed narrative description of what was delivered during this activation event. Documents the specific sponsorship rights exercised and the execution details for sponsor reporting.' ;
    rdfs:domain ind:SponsorshipActivation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engagementCount rdf:type rdf:Property ;
    rdfs:label 'Engagement Count' ;
    rdfs:comment 'Number of direct interactions or engagements with the activation (clicks, shares, likes, physical interactions). Measures active audience participation beyond passive exposure.' ;
    rdfs:domain ind:SponsorshipActivation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedAudienceReach rdf:type rdf:Property ;
    rdfs:label 'Estimated Audience Reach' ;
    rdfs:comment 'Projected number of individuals exposed to the sponsorship activation. Used for pre-event planning and to estimate the marketing value delivered to the sponsor.' ;
    rdfs:domain ind:SponsorshipActivation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:impressionsCount rdf:type rdf:Property ;
    rdfs:label 'Impressions Count' ;
    rdfs:comment 'Total number of times the sponsorship branding or message was displayed or viewed during the activation. Used for digital and physical media performance measurement.' ;
    rdfs:domain ind:SponsorshipActivation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isContractuallyRequired rdf:type rdf:Property ;
    rdfs:label 'Is Contractually Required' ;
    rdfs:comment 'Boolean flag indicating whether this activation was a mandatory deliverable under the sponsorship contract (true) or a value-added bonus activation (false). Critical for compliance tracking.' ;
    rdfs:domain ind:SponsorshipActivation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:locationType rdf:type rdf:Property ;
    rdfs:label 'Location Type' ;
    rdfs:comment 'Classification of the physical or digital location where the activation took place. Supports geographic and channel-based performance analysis of sponsorship activations. [ENUM-REF-CANDIDATE: airport|aircraft|lounge|stadium|digital|event_venue|city|route|hub — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SponsorshipActivation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mediaValueUsd rdf:type rdf:Property ;
    rdfs:label 'Media Value Usd' ;
    rdfs:comment 'Estimated equivalent advertising value of the exposure delivered through this activation, expressed in US dollars. Calculated based on reach, impressions, and industry media rate benchmarks.' ;
    rdfs:domain ind:SponsorshipActivation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:outcomeNotes rdf:type rdf:Property ;
    rdfs:label 'Outcome Notes' ;
    rdfs:comment 'Free-text field capturing qualitative outcomes, learnings, sponsor feedback, and operational notes from the activation. Supports continuous improvement and sponsor relationship management.' ;
    rdfs:domain ind:SponsorshipActivation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsibleTeam rdf:type rdf:Property ;
    rdfs:label 'Responsible Team' ;
    rdfs:comment 'Name of the internal marketing team or department responsible for executing this activation. Supports accountability tracking and resource allocation analysis.' ;
    rdfs:domain ind:SponsorshipActivation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Sponsor Approval Status' ;
    rdfs:comment 'Indicates whether the sponsor reviewed and approved the activation execution or deliverable. Critical for contract compliance and sponsor satisfaction tracking.' ;
    rdfs:domain ind:SponsorshipActivation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorFeedback rdf:type rdf:Property ;
    rdfs:label 'Sponsor Feedback' ;
    rdfs:comment 'Direct feedback or comments provided by the sponsor regarding the activation execution and quality. Used for relationship management and service improvement.' ;
    rdfs:domain ind:SponsorshipActivation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surveyResponseId rdf:type rdf:Property ;
    rdfs:label 'Survey Response Id' ;
    rdfs:comment 'Unique identifier for the survey response record. Primary key.' ;
    rdfs:domain ind:SurveyResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:anonymousToken rdf:type rdf:Property ;
    rdfs:label 'Anonymous Token' ;
    rdfs:comment 'Unique token for unauthenticated survey responses to prevent duplicate submissions while preserving anonymity. MD5 hash format.' ;
    rdfs:domain ind:SurveyResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cesScore rdf:type rdf:Property ;
    rdfs:label 'Ces Score' ;
    rdfs:comment 'Customer effort score measuring ease of experience, typically on a 1-7 scale. Lower scores indicate less effort required.' ;
    rdfs:domain ind:SurveyResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:csatScore rdf:type rdf:Property ;
    rdfs:label 'Csat Score' ;
    rdfs:comment 'Customer satisfaction score, typically on a 1-5 scale. Measures satisfaction with specific service touchpoint.' ;
    rdfs:domain ind:SurveyResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:incentiveType rdf:type rdf:Property ;
    rdfs:label 'Incentive Type' ;
    rdfs:comment 'Type of incentive offered for survey completion: frequent flyer miles, discount voucher, prize draw entry, or none.' ;
    rdfs:domain ind:SurveyResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipCountryCode rdf:type rdf:Property ;
    rdfs:label 'Ip Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code derived from respondent IP address. Used for geographic analysis of response patterns.' ;
    rdfs:domain ind:SurveyResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isVerifiedPassenger rdf:type rdf:Property ;
    rdfs:label 'Is Verified Passenger' ;
    rdfs:comment 'Boolean flag indicating whether the respondent was verified as an actual passenger on the referenced flight through PNR or booking validation.' ;
    rdfs:domain ind:SurveyResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:npsCategory rdf:type rdf:Property ;
    rdfs:label 'Nps Category' ;
    rdfs:comment 'Classification of the NPS score: Promoter (9-10), Passive (7-8), or Detractor (0-6).' ;
    rdfs:domain ind:SurveyResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:npsScore rdf:type rdf:Property ;
    rdfs:label 'Nps Score' ;
    rdfs:comment 'Numeric score from 0 to 10 indicating likelihood to recommend the airline. Core metric for NPS calculation.' ;
    rdfs:domain ind:SurveyResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responseChannel rdf:type rdf:Property ;
    rdfs:label 'Response Channel' ;
    rdfs:comment 'Channel through which the survey response was submitted: email link, mobile app, in-flight entertainment system, SMS, web portal, or airport kiosk.' ;
    rdfs:domain ind:SurveyResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseLanguage rdf:type rdf:Property ;
    rdfs:label 'Response Language' ;
    rdfs:comment 'Three-letter ISO 639-2 language code indicating the language in which the survey was completed.' ;
    rdfs:domain ind:SurveyResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Response Time Seconds' ;
    rdfs:comment 'Time elapsed in seconds from survey invitation to submission. Used to identify rushed or thoughtful responses.' ;
    rdfs:domain ind:SurveyResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sentimentCategory rdf:type rdf:Property ;
    rdfs:label 'Sentiment Category' ;
    rdfs:comment 'Categorical classification of sentiment derived from verbatim feedback: Positive, Neutral, Negative, or Mixed.' ;
    rdfs:domain ind:SurveyResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceRecoveryTriggered rdf:type rdf:Property ;
    rdfs:label 'Service Recovery Triggered' ;
    rdfs:comment 'Boolean flag indicating whether this response triggered an automated service recovery workflow due to low satisfaction score or negative sentiment.' ;
    rdfs:domain ind:SurveyResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:surveyCompletionRate rdf:type rdf:Property ;
    rdfs:label 'Survey Completion Rate' ;
    rdfs:comment 'Percentage of survey questions completed by the respondent. Used to assess response quality and engagement.' ;
    rdfs:domain ind:SurveyResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:surveySentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Survey Sent Timestamp' ;
    rdfs:comment 'Date and time when the survey invitation was sent to the passenger. Used to calculate response time.' ;
    rdfs:domain ind:SurveyResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:surveyVersion rdf:type rdf:Property ;
    rdfs:label 'Survey Version' ;
    rdfs:comment 'Version identifier of the survey instrument used. Tracks survey design changes over time for longitudinal analysis.' ;
    rdfs:domain ind:SurveyResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:topicTags rdf:type rdf:Property ;
    rdfs:label 'Topic Tags' ;
    rdfs:comment 'Comma-separated list of topics identified in verbatim feedback through text analytics (e.g., baggage, crew, punctuality, cleanliness).' ;
    rdfs:domain ind:SurveyResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verbatimFeedback rdf:type rdf:Property ;
    rdfs:label 'Verbatim Feedback' ;
    rdfs:comment 'Open-text feedback provided by the passenger in their own words. Used for qualitative analysis and sentiment mining.' ;
    rdfs:domain ind:SurveyResponse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accessibilityProfileId rdf:type rdf:Property ;
    rdfs:label 'Accessibility Profile Id' ;
    rdfs:comment 'Unique identifier for the accessibility profile record. Primary key.' ;
    rdfs:domain ind:AccessibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mobilityEquipmentVendorId rdf:type rdf:Property ;
    rdfs:label 'Mobility Equipment Vendor Id' ;
    rdfs:comment 'Foreign key linking to procurement.vendor. Business justification: Passengers with mobility aids requiring specialized handling (battery-powered wheelchairs, medical equipment) often need vendor-provided equipment or services at stations. Airlines track which ground ' ;
    rdfs:domain ind:AccessibilityProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:revenueEmdId rdf:type rdf:Property ;
    rdfs:label 'Revenue Emd Id' ;
    rdfs:comment 'Foreign key linking to revenue.emd. Business justification: Accessibility services (wheelchairs, oxygen, medical equipment, stretchers) are often chargeable ancillaries documented via EMDs. Links PRM service profiles to revenue records for billing, EMD reconci' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RevenueEmd .

ind:ambulatoryStatus rdf:type rdf:Property ;
    rdfs:label 'Ambulatory Status' ;
    rdfs:comment 'Passengers ability to walk and move independently. Determines boarding method, seating restrictions, and emergency evacuation capability.' ;
    rdfs:domain ind:AccessibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assistanceAtArrivalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Assistance At Arrival Required Flag' ;
    rdfs:comment 'Indicates whether the passenger requires ground handling assistance at arrival airport (deplaning, baggage claim, customs, onward connection). Triggers PRM service request to ground handler.' ;
    rdfs:domain ind:AccessibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assistanceAtDepartureRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Assistance At Departure Required Flag' ;
    rdfs:comment 'Indicates whether the passenger requires ground handling assistance at departure airport (check-in, security, gate, boarding). Triggers PRM service request to ground handler.' ;
    rdfs:domain ind:AccessibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assistanceAtTransitRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Assistance At Transit Required Flag' ;
    rdfs:comment 'Indicates whether the passenger requires ground handling assistance during transit or connection. Ensures continuity of care between flights.' ;
    rdfs:domain ind:AccessibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:boardingMethodPreference rdf:type rdf:Property ;
    rdfs:label 'Boarding Method Preference' ;
    rdfs:comment 'Preferred method for boarding the aircraft. Pre-board allows extra time; ambulift is a hydraulic lift vehicle; aisle chair is a narrow wheelchair for aircraft aisle; carry-onboard means passenger is carried by assistance personnel.' ;
    rdfs:domain ind:AccessibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cognitiveAssistanceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Cognitive Assistance Required Flag' ;
    rdfs:comment 'Indicates whether the passenger requires cognitive or developmental disability assistance. May require simplified instructions, extra time, or companion support.' ;
    rdfs:domain ind:AccessibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:companionTravelerRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Companion Traveler Required Flag' ;
    rdfs:comment 'Indicates whether the passenger is required to travel with a companion or safety assistant due to the severity of their disability. May be mandated by airline medical policy.' ;
    rdfs:domain ind:AccessibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hearingImpairmentLevel rdf:type rdf:Property ;
    rdfs:label 'Hearing Impairment Level' ;
    rdfs:comment 'Degree of hearing impairment. Determines need for visual safety briefings, written communication, and assistive listening devices.' ;
    rdfs:domain ind:AccessibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastVerifiedDate rdf:type rdf:Property ;
    rdfs:label 'Last Verified Date' ;
    rdfs:comment 'Date when the accessibility profile information was last verified or updated by the passenger or airline staff. Used for data quality and compliance auditing.' ;
    rdfs:domain ind:AccessibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:medicalClearanceExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Medical Clearance Expiry Date' ;
    rdfs:comment 'Date until which the medical clearance (MEDIF) is valid. Passenger cannot travel after this date without renewed clearance.' ;
    rdfs:domain ind:AccessibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:medicalClearanceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Medical Clearance Required Flag' ;
    rdfs:comment 'Indicates whether the passenger requires medical clearance (MEDIF form) from airline medical services before travel. Triggered by certain medical conditions or equipment.' ;
    rdfs:domain ind:AccessibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:medicalEquipmentCarried rdf:type rdf:Property ;
    rdfs:label 'Medical Equipment Carried' ;
    rdfs:comment 'Description of medical equipment the passenger carries onboard (CPAP, portable oxygen concentrator, nebulizer, insulin pump). Free-text field for crew awareness and stowage planning.' ;
    rdfs:domain ind:AccessibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mobilityAidBatteryType rdf:type rdf:Property ;
    rdfs:label 'Mobility Aid Battery Type' ;
    rdfs:comment 'Type of battery powering the mobility aid device. Critical for dangerous goods compliance and cargo hold safety. Lithium-ion batteries have specific IATA DGR restrictions.' ;
    rdfs:domain ind:AccessibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mobilityAidBatteryWattHours rdf:type rdf:Property ;
    rdfs:label 'Mobility Aid Battery Watt Hours' ;
    rdfs:comment 'Energy capacity of the mobility aid battery in watt-hours. Required for lithium battery compliance checks per IATA DGR (batteries over 300Wh require special handling).' ;
    rdfs:domain ind:AccessibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mobilityAidFoldableFlag rdf:type rdf:Property ;
    rdfs:label 'Mobility Aid Foldable Flag' ;
    rdfs:comment 'Indicates whether the mobility aid device can be folded or disassembled for stowage. Affects cargo hold space allocation and handling procedures.' ;
    rdfs:domain ind:AccessibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mobilityAidHeightCm rdf:type rdf:Property ;
    rdfs:label 'Mobility Aid Height Cm' ;
    rdfs:comment 'Height dimension of the mobility aid device in centimeters. Used to determine cargo hold compatibility and stowage location.' ;
    rdfs:domain ind:AccessibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mobilityAidLengthCm rdf:type rdf:Property ;
    rdfs:label 'Mobility Aid Length Cm' ;
    rdfs:comment 'Length dimension of the mobility aid device in centimeters. Used to determine cargo hold compatibility and stowage location.' ;
    rdfs:domain ind:AccessibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mobilityAidType rdf:type rdf:Property ;
    rdfs:label 'Mobility Aid Type' ;
    rdfs:comment 'Type of mobility aid device used by the passenger. Determines handling and stowage requirements. [ENUM-REF-CANDIDATE: manual_wheelchair|electric_wheelchair|mobility_scooter|walker|cane|crutches|prosthetic|none — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AccessibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mobilityAidWeightKg rdf:type rdf:Property ;
    rdfs:label 'Mobility Aid Weight Kg' ;
    rdfs:comment 'Weight of the mobility aid device in kilograms. Required for cargo hold planning and aircraft weight and balance calculations.' ;
    rdfs:domain ind:AccessibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mobilityAidWidthCm rdf:type rdf:Property ;
    rdfs:label 'Mobility Aid Width Cm' ;
    rdfs:comment 'Width dimension of the mobility aid device in centimeters. Used to determine cargo hold compatibility and stowage location.' ;
    rdfs:domain ind:AccessibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oxygenFlowRateLpm rdf:type rdf:Property ;
    rdfs:label 'Oxygen Flow Rate Lpm' ;
    rdfs:comment 'Prescribed oxygen flow rate in liters per minute. Required for aircraft oxygen system configuration and medical clearance.' ;
    rdfs:domain ind:AccessibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oxygenRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Oxygen Required Flag' ;
    rdfs:comment 'Indicates whether the passenger requires supplemental oxygen during flight. Requires advance coordination with medical services and aircraft equipment availability.' ;
    rdfs:domain ind:AccessibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferredSeatingLocation rdf:type rdf:Property ;
    rdfs:label 'Preferred Seating Location' ;
    rdfs:comment 'Passengers preferred seating location based on accessibility needs. Bulkhead seats provide extra space for mobility aids; aisle seats facilitate lavatory access.' ;
    rdfs:domain ind:AccessibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prmCategory rdf:type rdf:Property ;
    rdfs:label 'Prm Category' ;
    rdfs:comment 'IATA standard PRM category code. WCHR=wheelchair for ramp, WCHS=wheelchair for stairs, WCHC=wheelchair for cabin seat, WCBD=dry cell battery wheelchair, WCBW=wet cell battery wheelchair, WCMP=manual wheelchair, BLND=blind, DEAF=deaf, DPNA=disabled passenger needing assistance, MAAS=meet and assist. [ENUM-REF-CANDIDATE: WCHR|WCHS|WCHC|WCBD|WCBW|WCMP|BLND|DEAF|DPNA|MAAS — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AccessibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileEffectiveFromDate rdf:type rdf:Property ;
    rdfs:label 'Profile Effective From Date' ;
    rdfs:comment 'Date from which this accessibility profile becomes effective and can be used for booking and SSR generation.' ;
    rdfs:domain ind:AccessibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:profileEffectiveToDate rdf:type rdf:Property ;
    rdfs:label 'Profile Effective To Date' ;
    rdfs:comment 'Date until which this accessibility profile remains valid. Nullable for indefinite profiles; populated for time-limited medical clearances.' ;
    rdfs:domain ind:AccessibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:profileStatus rdf:type rdf:Property ;
    rdfs:label 'Profile Status' ;
    rdfs:comment 'Current lifecycle status of the accessibility profile. Active profiles are used for SSR generation; expired profiles require renewal of medical documentation.' ;
    rdfs:domain ind:Passenger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seatingRestrictionNotes rdf:type rdf:Property ;
    rdfs:label 'Seating Restriction Notes' ;
    rdfs:comment 'Free-text notes on seating restrictions or requirements (e.g., cannot sit in exit row, requires adjacent seat for companion, needs armrest removal). Used by inventory and departure control systems.' ;
    rdfs:domain ind:AccessibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceAnimalFlag rdf:type rdf:Property ;
    rdfs:label 'Service Animal Flag' ;
    rdfs:comment 'Indicates whether the passenger travels with a trained service animal (guide dog, hearing dog, psychiatric service animal). Requires cabin accommodation and documentation.' ;
    rdfs:domain ind:AccessibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceAnimalType rdf:type rdf:Property ;
    rdfs:label 'Service Animal Type' ;
    rdfs:comment 'Type of trained service animal accompanying the passenger. Determines seating location and cabin crew briefing requirements.' ;
    rdfs:domain ind:AccessibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stretcherRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Stretcher Required Flag' ;
    rdfs:comment 'Indicates whether the passenger requires stretcher accommodation. Requires removal of multiple seat rows and advance aircraft configuration.' ;
    rdfs:domain ind:AccessibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:visualImpairmentLevel rdf:type rdf:Property ;
    rdfs:label 'Visual Impairment Level' ;
    rdfs:comment 'Degree of visual impairment. Determines need for sighted guide, Braille materials, audio announcements, and service animal accommodation.' ;
    rdfs:domain ind:AccessibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apisSubmissionId rdf:type rdf:Property ;
    rdfs:label 'Apis Submission Id' ;
    rdfs:comment 'Unique identifier for the APIS submission record. Primary key.' ;
    rdfs:domain ind:ApisSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalSubmissionApisSubmissionId rdf:type rdf:Property ;
    rdfs:label 'Original Submission Apis Submission Id' ;
    rdfs:comment 'Reference to the original APIS submission record if this is a resubmission or correction. Null for original submissions.' ;
    rdfs:domain ind:ApisSubmission ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ApisSubmission .

ind:authorityResponseCode rdf:type rdf:Property ;
    rdfs:label 'Authority Response Code' ;
    rdfs:comment 'Response code returned by the border control authority indicating acceptance, rejection reason, or error condition. Codes vary by authority (e.g., CBP response codes, UKBF codes).' ;
    rdfs:domain ind:ApisSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorityResponseMessage rdf:type rdf:Property ;
    rdfs:label 'Authority Response Message' ;
    rdfs:comment 'Human-readable message returned by the border control authority providing additional detail on the submission outcome or rejection reason.' ;
    rdfs:domain ind:ApisSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorityResponseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Authority Response Timestamp' ;
    rdfs:comment 'Date and time when the border control authority returned a response to the APIS submission.' ;
    rdfs:domain ind:ApisSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:borderAuthorityCode rdf:type rdf:Property ;
    rdfs:label 'Border Authority Code' ;
    rdfs:comment 'Code identifying the specific border control authority that received the submission (e.g., CBP for US Customs and Border Protection, UKBF for UK Border Force, EES for EU Entry/Exit System).' ;
    rdfs:domain ind:ApisSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceMandate rdf:type rdf:Property ;
    rdfs:label 'Compliance Mandate' ;
    rdfs:comment 'The specific regulatory mandate or legal requirement under which this APIS submission was made (e.g., US CBP APIS Final Rule, EU Entry/Exit System Regulation 2017/2226, ICAO Annex 9 Standard 3.47).' ;
    rdfs:domain ind:ApisSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Document Expiry Date' ;
    rdfs:comment 'Expiration date of the travel document as submitted to border control authorities. Snapshot at time of submission.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:documentIssuingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Document Issuing Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 code of the country that issued the travel document submitted in the APIS data.' ;
    rdfs:domain ind:ApisSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:messageReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Message Reference Number' ;
    rdfs:comment 'Unique reference number assigned to the APIS transmission message by the sending system or border control authority for tracking and reconciliation purposes.' ;
    rdfs:domain ind:ApisSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passengerDateOfBirth rdf:type rdf:Property ;
    rdfs:label 'Passenger Date Of Birth' ;
    rdfs:comment 'Date of birth of the passenger as submitted to border control authorities. Snapshot at time of submission.' ;
    rdfs:domain ind:ApisSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:passengerGender rdf:type rdf:Property ;
    rdfs:label 'Passenger Gender' ;
    rdfs:comment 'Gender of the passenger as recorded on the travel document submitted to border control authorities (M=Male, F=Female, X=Unspecified/Other). Snapshot at time of submission.' ;
    rdfs:domain ind:ApisSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passengerGivenName rdf:type rdf:Property ;
    rdfs:label 'Passenger Given Name' ;
    rdfs:comment 'Given name(s) (first and middle names) of the passenger as they appear on the travel document submitted to border control authorities. Snapshot at time of submission.' ;
    rdfs:domain ind:ApisSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passengerNationalityCode rdf:type rdf:Property ;
    rdfs:label 'Passenger Nationality Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 code representing the nationality of the passenger as submitted to border control authorities. Snapshot at time of submission.' ;
    rdfs:domain ind:ApisSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passengerSurname rdf:type rdf:Property ;
    rdfs:label 'Passenger Surname' ;
    rdfs:comment 'Surname (family name) of the passenger as it appears on the travel document submitted to border control authorities. Snapshot at time of submission.' ;
    rdfs:domain ind:ApisSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resubmissionFlag rdf:type rdf:Property ;
    rdfs:label 'Resubmission Flag' ;
    rdfs:comment 'Indicates whether this submission is a resubmission of previously rejected or corrected APIS data (True) or an original submission (False).' ;
    rdfs:domain ind:ApisSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduledArrivalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Arrival Timestamp' ;
    rdfs:comment 'Scheduled arrival date and time of the flight leg for which APIS data was submitted.' ;
    rdfs:domain ind:ApisSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledDepartureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Departure Timestamp' ;
    rdfs:comment 'Scheduled departure date and time of the flight leg for which APIS data was submitted.' ;
    rdfs:domain ind:ApisSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:submissionChannel rdf:type rdf:Property ;
    rdfs:label 'Submission Channel' ;
    rdfs:comment 'Technical channel or interface used to transmit the APIS data (e.g., SITA Type B message, XML web service, EDI, proprietary API).' ;
    rdfs:domain ind:Passenger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Submission Source System' ;
    rdfs:comment 'Name or code of the operational system that generated and transmitted the APIS submission (e.g., Amadeus Altéa DCS, Sabre AirCentre, SITA Horizon).' ;
    rdfs:domain ind:ApisSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionStatus rdf:type rdf:Property ;
    rdfs:label 'Submission Status' ;
    rdfs:comment 'Current lifecycle status of the APIS submission: pending (awaiting authority response), accepted (approved by border control), rejected (denied by border control), error (technical transmission failure), cancelled (submission withdrawn).' ;
    rdfs:domain ind:ApisSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentId rdf:type rdf:Property ;
    rdfs:label 'Consent Id' ;
    rdfs:comment 'Primary key for consent' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dataSubjectRequestId rdf:type rdf:Property ;
    rdfs:label 'Data Subject Request Id' ;
    rdfs:comment 'Reference to a data subject access request (DSAR), right-to-erasure request, or data portability request that triggered this consent record update. Null if the consent was not updated as part of a formal data subject request.' ;
    rdfs:domain ind:Passenger ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DataSubjectRequest .

ind:auditTrail rdf:type rdf:Property ;
    rdfs:label 'Audit Trail' ;
    rdfs:comment 'A structured log or reference to detailed audit records capturing all consent lifecycle events (granted, modified, withdrawn, expired). Supports regulatory audit and dispute resolution.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentStatus rdf:type rdf:Property ;
    rdfs:label 'Consent Status' ;
    rdfs:comment 'Current lifecycle status of the consent. Indicates whether the passenger has granted, withdrawn, or is pending decision on the consent request. Expired indicates consent has passed its validity period.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentType rdf:type rdf:Property ;
    rdfs:label 'Consent Type' ;
    rdfs:comment 'The category of consent granted or withheld by the passenger. Defines the specific data processing activity for which consent is required under GDPR, CCPA, PDPA, or other applicable data protection regulations.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dpoReviewFlag rdf:type rdf:Property ;
    rdfs:label 'Dpo Review Flag' ;
    rdfs:comment 'Boolean indicator of whether this consent record has been reviewed or flagged for review by the airline\'s Data Protection Officer (DPO). Used for high-risk or disputed consent cases.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:grantedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Granted Timestamp' ;
    rdfs:comment 'The date and time when the passenger granted consent. Recorded in ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX). Required for GDPR and CCPA audit trails.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:jurisdictionCode rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Code' ;
    rdfs:comment 'The three-letter ISO 3166-1 alpha-3 country code representing the legal jurisdiction under which this consent was collected. Determines applicable data protection regulation (GDPR for EU, CCPA for California, PDPA for Singapore, etc.).' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalBasis rdf:type rdf:Property ;
    rdfs:label 'Legal Basis' ;
    rdfs:comment 'The lawful basis under GDPR Article 6 for processing the passenger\'s personal data. While this product focuses on consent, other legal bases may apply for specific processing activities.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minorConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Minor Consent Flag' ;
    rdfs:comment 'Boolean indicator of whether this consent record pertains to a minor (passenger under the age of consent in the applicable jurisdiction). Triggers additional parental consent and verification requirements under GDPR Article 8 and COPPA.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optInFlag rdf:type rdf:Property ;
    rdfs:label 'Opt In Flag' ;
    rdfs:comment 'Boolean indicator of whether the consent was obtained via opt-in (true) or opt-out (false) mechanism. GDPR requires opt-in for most marketing and profiling activities.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentalConsentVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Parental Consent Verified Flag' ;
    rdfs:comment 'Boolean indicator of whether parental or guardian consent has been verified for a minor passenger. Null if minor_consent_flag is false. Required for GDPR Article 8 and COPPA compliance.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:processingPurpose rdf:type rdf:Property ;
    rdfs:label 'Processing Purpose' ;
    rdfs:comment 'The specific purpose for which the passenger\'s data will be processed under this consent. Examples include marketing communications, service personalization, loyalty program analytics, or partner offers. Required for GDPR Article 13 transparency.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalDueDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Due Date' ;
    rdfs:comment 'The date by which the airline should proactively request consent renewal from the passenger. Used for consent lifecycle management and regulatory compliance in jurisdictions requiring periodic re-consent.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:textSnapshot rdf:type rdf:Property ;
    rdfs:label 'Text Snapshot' ;
    rdfs:comment 'A snapshot or reference to the exact consent text presented to the passenger at the time of consent. Supports audit and dispute resolution by preserving the wording the passenger agreed to.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPartySharingScope rdf:type rdf:Property ;
    rdfs:label 'Third Party Sharing Scope' ;
    rdfs:comment 'Description of the third-party entities or categories of entities with whom passenger data may be shared under this consent. Required for transparency under GDPR Article 13 and CCPA Section 1798.100(b).' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:userAgent rdf:type rdf:Property ;
    rdfs:label 'User Agent' ;
    rdfs:comment 'The user agent string of the browser or application used by the passenger to provide consent. Supports technical audit and fraud detection.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withdrawnTimestamp rdf:type rdf:Property ;
    rdfs:label 'Withdrawn Timestamp' ;
    rdfs:comment 'The date and time when the passenger withdrew their consent. Null if consent has not been withdrawn. Recorded in ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX). Required for right-to-erasure compliance.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:contactDetailId rdf:type rdf:Property ;
    rdfs:label 'Contact Detail Id' ;
    rdfs:comment 'Unique identifier for the contact detail record. Primary key.' ;
    rdfs:domain ind:ContactDetail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contactChannel rdf:type rdf:Property ;
    rdfs:label 'Contact Channel' ;
    rdfs:comment 'The communication channel or medium through which this contact method operates (voice, SMS, email, postal, WhatsApp, app notification). Distinct from contact_type which defines the category.' ;
    rdfs:domain ind:ContactDetail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactStatus rdf:type rdf:Property ;
    rdfs:label 'Contact Status' ;
    rdfs:comment 'The current lifecycle status of this contact detail: active (in use), inactive (not in use), bounced (delivery failed), invalid (format error), pending_verification (awaiting confirmation).' ;
    rdfs:domain ind:ContactDetail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactType rdf:type rdf:Property ;
    rdfs:label 'Contact Type' ;
    rdfs:comment 'The category of contact channel: email, mobile phone, home phone, work phone, postal address, or emergency contact.' ;
    rdfs:domain ind:ContactDetail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyContactRelationship rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Relationship' ;
    rdfs:comment 'The relationship of the emergency contact to the passenger (spouse, parent, child, sibling, friend, other). Populated only when contact_type is emergency.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPreferred rdf:type rdf:Property ;
    rdfs:label 'Is Preferred' ;
    rdfs:comment 'Flag indicating whether this is the passengers preferred contact method for operational and marketing communications. Only one contact per type should be marked preferred.' ;
    rdfs:domain ind:ContactDetail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVerified rdf:type rdf:Property ;
    rdfs:label 'Is Verified' ;
    rdfs:comment 'Flag indicating whether this contact detail has been verified (e.g., email confirmed via link, phone verified via OTP). Supports data quality and fraud prevention.' ;
    rdfs:domain ind:ContactDetail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastUsedDate rdf:type rdf:Property ;
    rdfs:label 'Last Used Date' ;
    rdfs:comment 'The date when this contact detail was last used for communication (email sent, SMS delivered, call made). Supports contact data quality and hygiene.' ;
    rdfs:domain ind:Passenger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:optInDate rdf:type rdf:Property ;
    rdfs:label 'Opt In Date' ;
    rdfs:comment 'The date when the passenger provided consent for communications via this contact channel. Required for audit and compliance purposes.' ;
    rdfs:domain ind:ContactDetail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:optInMarketing rdf:type rdf:Property ;
    rdfs:label 'Opt In Marketing' ;
    rdfs:comment 'Flag indicating whether the passenger has consented to receive marketing communications via this contact channel. Required for GDPR and CAN-SPAM compliance.' ;
    rdfs:domain ind:ContactDetail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optInOperational rdf:type rdf:Property ;
    rdfs:label 'Opt In Operational' ;
    rdfs:comment 'Flag indicating whether the passenger has consented to receive operational communications (flight status, IROP notifications, gate changes) via this contact channel. Typically defaults to true for service delivery.' ;
    rdfs:domain ind:ContactDetail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optOutDate rdf:type rdf:Property ;
    rdfs:label 'Opt Out Date' ;
    rdfs:comment 'The date when the passenger withdrew consent for communications via this contact channel. Supports unsubscribe tracking and compliance.' ;
    rdfs:domain ind:ContactDetail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:phoneCountryCode rdf:type rdf:Property ;
    rdfs:label 'Phone Country Code' ;
    rdfs:comment 'The international dialing code for the phone number (e.g., +1 for USA, +44 for UK). Supports global passenger contact management.' ;
    rdfs:domain ind:ContactDetail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:corporateTravellerId rdf:type rdf:Property ;
    rdfs:label 'Corporate Traveller Id' ;
    rdfs:comment 'Unique identifier for the corporate traveller relationship record. Primary key.' ;
    rdfs:domain ind:CorporateTraveller ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:corporateContractId rdf:type rdf:Property ;
    rdfs:label 'Corporate Contract Id' ;
    rdfs:comment 'Foreign key linking to revenue.corporate_contract. Business justification: Corporate travelers are governed by negotiated contracts specifying discounts, fare rules, and billing terms. Essential for fare validation at booking, discount application, contract compliance report' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CorporateContract .

ind:preferredCabinClassId rdf:type rdf:Property ;
    rdfs:label 'Preferred Cabin Class Id' ;
    rdfs:comment 'Foreign key linking to inventory.cabin_class. Business justification: Corporate travel policies enforce cabin class restrictions (e.g., economy only, business for long-haul). Booking systems validate reservations against corporate policy rules. Policy enforcement and co' ;
    rdfs:domain ind:CorporateTraveller ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CabinClass .

ind:preferredRouteId rdf:type rdf:Property ;
    rdfs:label 'Preferred Route Id' ;
    rdfs:comment 'Foreign key linking to route.route. Business justification: Corporate travel policies often restrict or prefer specific routes based on negotiated corporate agreements and duty-of-care requirements. Corporate booking tools enforce policy compliance by validati' ;
    rdfs:domain ind:Passenger ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Route .

ind:affiliationStatus rdf:type rdf:Property ;
    rdfs:label 'Affiliation Status' ;
    rdfs:comment 'Current lifecycle status of the corporate traveller affiliation. Active = currently valid; suspended = temporarily inactive; terminated = ended; pending = awaiting activation.' ;
    rdfs:domain ind:CorporateTraveller ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approverEmail rdf:type rdf:Property ;
    rdfs:label 'Approver Email' ;
    rdfs:comment 'Email address of the travel approver for notification and approval workflow purposes.' ;
    rdfs:domain ind:CorporateTraveller ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approverName rdf:type rdf:Property ;
    rdfs:label 'Approver Name' ;
    rdfs:comment 'Name of the manager or approver responsible for authorizing travel bookings for this corporate traveller.' ;
    rdfs:domain ind:CorporateTraveller ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyName rdf:type rdf:Property ;
    rdfs:label 'Company Name' ;
    rdfs:comment 'Legal or trading name of the corporate entity to which this traveller is affiliated.' ;
    rdfs:domain ind:CorporateTraveller ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:corporateAccountCode rdf:type rdf:Property ;
    rdfs:label 'Corporate Account Code' ;
    rdfs:comment 'Unique alphanumeric code identifying the corporate travel account or negotiated corporate agreement. This is the business identifier used in booking systems and invoicing.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:corporateBillingAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Corporate Billing Address Line 1' ;
    rdfs:comment 'First line of the corporate billing address for invoicing and financial reconciliation.' ;
    rdfs:domain ind:CorporateTraveller ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:corporateBillingAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Corporate Billing Address Line 2' ;
    rdfs:comment 'Second line of the corporate billing address (suite, floor, building name).' ;
    rdfs:domain ind:CorporateTraveller ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:corporateBillingCity rdf:type rdf:Property ;
    rdfs:label 'Corporate Billing City' ;
    rdfs:comment 'City of the corporate billing address.' ;
    rdfs:domain ind:CorporateTraveller ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:corporateBillingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Corporate Billing Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the corporate billing address.' ;
    rdfs:domain ind:CorporateTraveller ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:corporateBillingPostalCode rdf:type rdf:Property ;
    rdfs:label 'Corporate Billing Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the corporate billing address.' ;
    rdfs:domain ind:CorporateTraveller ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:corporateBillingStateProvince rdf:type rdf:Property ;
    rdfs:label 'Corporate Billing State Province' ;
    rdfs:comment 'State or province of the corporate billing address.' ;
    rdfs:domain ind:CorporateTraveller ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:corporateContactEmail rdf:type rdf:Property ;
    rdfs:label 'Corporate Contact Email' ;
    rdfs:comment 'Email address of the corporate travel coordinator for account management and communication.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:corporateContactName rdf:type rdf:Property ;
    rdfs:label 'Corporate Contact Name' ;
    rdfs:comment 'Name of the primary corporate travel coordinator or contact person at the corporate entity for this account.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:corporateContactPhone rdf:type rdf:Property ;
    rdfs:label 'Corporate Contact Phone' ;
    rdfs:comment 'Phone number of the corporate travel coordinator.' ;
    rdfs:domain ind:CorporateTraveller ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:corporateTier rdf:type rdf:Property ;
    rdfs:label 'Corporate Tier' ;
    rdfs:comment 'Classification of the corporate account based on volume, revenue, or strategic importance. SME = Small/Medium Enterprise; preferred = mid-tier negotiated rates; strategic = top-tier partnership; global/regional/local = geographic scope of agreement.' ;
    rdfs:domain ind:CorporateTraveller ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:corporateTravelPolicyReference rdf:type rdf:Property ;
    rdfs:label 'Corporate Travel Policy Reference' ;
    rdfs:comment 'Reference code or identifier for the specific corporate travel policy governing this traveller\'s bookings, including fare class restrictions, advance purchase rules, and approval workflows.' ;
    rdfs:domain ind:CorporateTraveller ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departmentName rdf:type rdf:Property ;
    rdfs:label 'Department Name' ;
    rdfs:comment 'Name of the department or business unit within the corporate entity to which the employee belongs.' ;
    rdfs:domain ind:CorporateTraveller ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dutyOfCareFlag rdf:type rdf:Property ;
    rdfs:label 'Duty Of Care Flag' ;
    rdfs:comment 'Indicates whether this corporate traveller is enrolled in duty-of-care tracking and emergency notification services. True = enrolled; False = not enrolled.' ;
    rdfs:domain ind:CorporateTraveller ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobTitle rdf:type rdf:Property ;
    rdfs:label 'Job Title' ;
    rdfs:comment 'Job title or role of the employee within the corporate entity. Used for travel policy enforcement and duty-of-care segmentation.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastBookingDate rdf:type rdf:Property ;
    rdfs:label 'Last Booking Date' ;
    rdfs:comment 'Date of the most recent booking made under this corporate traveller affiliation. Used for activity tracking and account review.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:negotiatedFareCode rdf:type rdf:Property ;
    rdfs:label 'Negotiated Fare Code' ;
    rdfs:comment 'Fare code or corporate discount code applicable to this traveller under the corporate agreement. Used in booking and pricing systems to apply negotiated rates.' ;
    rdfs:domain ind:CorporateTraveller ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalBookingsCount rdf:type rdf:Property ;
    rdfs:label 'Total Bookings Count' ;
    rdfs:comment 'Cumulative count of bookings made under this corporate traveller affiliation since inception. Used for volume tracking and tier qualification.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:travelArrangerIataCode rdf:type rdf:Property ;
    rdfs:label 'Travel Arranger Iata Code' ;
    rdfs:comment 'Eight-digit IATA numeric code identifying the travel management company or travel agency arranging bookings for this corporate traveller.' ;
    rdfs:domain ind:CorporateTraveller ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:travelArrangerName rdf:type rdf:Property ;
    rdfs:label 'Travel Arranger Name' ;
    rdfs:comment 'Name of the travel management company (TMC) or travel arranger responsible for booking travel for this corporate traveller.' ;
    rdfs:domain ind:CorporateTraveller ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vipStatusFlag rdf:type rdf:Property ;
    rdfs:label 'Vip Status Flag' ;
    rdfs:comment 'Indicates whether this corporate traveller has VIP status requiring special handling, priority service, or executive-level support. True = VIP; False = standard.' ;
    rdfs:domain ind:CorporateTraveller ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loyaltyLinkageId rdf:type rdf:Property ;
    rdfs:label 'Loyalty Linkage Id' ;
    rdfs:comment 'Unique identifier for the loyalty program linkage record. Primary key.' ;
    rdfs:domain ind:LoyaltyLinkage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allianceCode rdf:type rdf:Property ;
    rdfs:label 'Alliance Code' ;
    rdfs:comment 'The global airline alliance to which the FFP program belongs (Star Alliance, oneworld, SkyTeam). None indicates the program is not part of a major alliance or is the airline\'s own non-alliance program.' ;
    rdfs:domain ind:LoyaltyLinkage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoRecognitionEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Recognition Enabled Flag' ;
    rdfs:comment 'Boolean flag indicating whether automatic tier recognition and benefit application is enabled for this linkage at check-in, boarding, and service touchpoints. True enables automatic recognition; False requires manual override.' ;
    rdfs:domain ind:LoyaltyLinkage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ffpProgramCode rdf:type rdf:Property ;
    rdfs:label 'Ffp Program Code' ;
    rdfs:comment 'IATA two-letter or three-character airline code identifying the loyalty program (e.g., UA for United MileagePlus, BA for British Airways Executive Club, LH for Lufthansa Miles & More). Includes own airline and partner programs within alliances (Star Alliance, oneworld, SkyTeam).' ;
    rdfs:domain ind:LoyaltyLinkage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastSyncTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Sync Timestamp' ;
    rdfs:comment 'The timestamp when this loyalty linkage record was last synchronized with the source loyalty system (e.g., Oracle Loyalty Cloud, partner FFP API). Used for data freshness monitoring and incremental load orchestration.' ;
    rdfs:domain ind:LoyaltyLinkage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastVerifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Verified Timestamp' ;
    rdfs:comment 'The timestamp when the linkage and tier status were last verified or synchronized with the authoritative loyalty system. Used to determine data freshness and trigger re-verification workflows.' ;
    rdfs:domain ind:LoyaltyLinkage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:linkageSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Linkage Source System' ;
    rdfs:comment 'The operational system or channel from which this loyalty linkage was created or last updated (e.g., Amadeus Altéa PSS, Oracle Loyalty Cloud, Mobile App, Web Portal, Customer Service, GDS).' ;
    rdfs:domain ind:LoyaltyLinkage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linkageStatus rdf:type rdf:Property ;
    rdfs:label 'Linkage Status' ;
    rdfs:comment 'Current status of the loyalty program linkage. Active indicates the linkage is operational and tier benefits apply. Suspended indicates temporary hold (e.g., fraud investigation). Unlinked indicates the passenger has removed the association. Pending verification indicates awaiting confirmation from the FFP. Expired indicates the membership has lapsed. Merged indicates the membership was consolidated into another record.' ;
    rdfs:domain ind:LoyaltyLinkage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linkageType rdf:type rdf:Property ;
    rdfs:label 'Linkage Type' ;
    rdfs:comment 'Classification of the loyalty linkage. Primary indicates the passenger\'s main FFP membership with the airline. Secondary indicates an additional membership. Partner indicates a linked membership with a codeshare or alliance partner. Reciprocal indicates a mutual recognition agreement membership.' ;
    rdfs:domain ind:LoyaltyLinkage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linkedDate rdf:type rdf:Property ;
    rdfs:label 'Linked Date' ;
    rdfs:comment 'The date on which this loyalty program membership was first linked to the passenger profile.' ;
    rdfs:domain ind:LoyaltyLinkage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reciprocalBenefitEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Reciprocal Benefit Eligible Flag' ;
    rdfs:comment 'Boolean flag indicating whether this linkage qualifies for reciprocal benefits under alliance or partnership agreements (e.g., lounge access, priority boarding on partner airlines). True indicates eligibility; False indicates ineligible or restricted.' ;
    rdfs:domain ind:LoyaltyLinkage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recognitionPriority rdf:type rdf:Property ;
    rdfs:label 'Recognition Priority' ;
    rdfs:comment 'Numeric priority order for tier recognition when a passenger has multiple linked FFP memberships. Lower numbers indicate higher priority (1 = highest). Used at check-in and boarding to determine which tier benefits to apply.' ;
    rdfs:domain ind:LoyaltyLinkage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:syncStatus rdf:type rdf:Property ;
    rdfs:label 'Sync Status' ;
    rdfs:comment 'Status of the most recent synchronization attempt with the source loyalty system. Success indicates data is current. Failed indicates synchronization error. Pending indicates sync in progress. Skipped indicates sync was bypassed. Partial indicates incomplete data received.' ;
    rdfs:domain ind:LoyaltyLinkage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unlinkedDate rdf:type rdf:Property ;
    rdfs:label 'Unlinked Date' ;
    rdfs:comment 'The date on which this loyalty program membership was unlinked from the passenger profile. Null if the linkage is still active or has never been unlinked.' ;
    rdfs:domain ind:LoyaltyLinkage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:unlinkedReasonCode rdf:type rdf:Property ;
    rdfs:label 'Unlinked Reason Code' ;
    rdfs:comment 'The reason code explaining why the loyalty linkage was unlinked. Null if the linkage has never been unlinked.' ;
    rdfs:domain ind:LoyaltyLinkage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minorGuardianId rdf:type rdf:Property ;
    rdfs:label 'Minor Guardian Id' ;
    rdfs:comment 'Unique identifier for the minor-guardian relationship record. Primary key.' ;
    rdfs:domain ind:MinorGuardian ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:acceptingCrewMemberId rdf:type rdf:Property ;
    rdfs:label 'Accepting Crew Member Id' ;
    rdfs:comment 'Foreign key linking to crew.crew_member. Business justification: Unaccompanied minor programs require airlines to document which cabin crew member accepted custody of the child at departure and handover. Legal liability and duty-of-care mandate. Crew member signs h' ;
    rdfs:domain ind:MinorGuardian ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Member .

ind:authorizationDocumentExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Authorization Document Expiry Date' ;
    rdfs:comment 'Expiration date of the authorization document, if applicable. Ensures authorization is valid for the travel date.' ;
    rdfs:domain ind:MinorGuardian ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authorizationDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Authorization Document Reference' ;
    rdfs:comment 'Reference number or identifier of the authorization document. Used for audit trail and compliance verification.' ;
    rdfs:domain ind:MinorGuardian ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizationDocumentType rdf:type rdf:Property ;
    rdfs:label 'Authorization Document Type' ;
    rdfs:comment 'Type of legal authorization document provided to permit the minor to travel unaccompanied. Required for regulatory compliance and liability protection.' ;
    rdfs:domain ind:MinorGuardian ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dropoffAuthorizationFlag rdf:type rdf:Property ;
    rdfs:label 'Dropoff Authorization Flag' ;
    rdfs:comment 'Indicates whether this guardian is authorized to drop off the minor at the origin airport. True if authorized, False otherwise. Used for origin handover verification.' ;
    rdfs:domain ind:MinorGuardian ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:guardianAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Guardian Address Line 1' ;
    rdfs:comment 'Primary street address line for the guardian. Required for emergency contact and legal documentation.' ;
    rdfs:domain ind:MinorGuardian ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guardianAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Guardian Address Line 2' ;
    rdfs:comment 'Secondary address line for the guardian (apartment, suite, unit number). Optional address component.' ;
    rdfs:domain ind:MinorGuardian ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guardianAlternatePhoneNumber rdf:type rdf:Property ;
    rdfs:label 'Guardian Alternate Phone Number' ;
    rdfs:comment 'Secondary contact phone number for the guardian. Used as backup contact channel during UMNR service delivery.' ;
    rdfs:domain ind:MinorGuardian ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guardianCity rdf:type rdf:Property ;
    rdfs:label 'Guardian City' ;
    rdfs:comment 'City or municipality of the guardian residence. Part of the complete contact address.' ;
    rdfs:domain ind:MinorGuardian ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guardianCountryCode rdf:type rdf:Property ;
    rdfs:label 'Guardian Country Code' ;
    rdfs:comment 'Three-letter ISO country code of the guardian residence country (e.g., USA, CAN, GBR). Required for international UMNR services.' ;
    rdfs:domain ind:MinorGuardian ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guardianEmailAddress rdf:type rdf:Property ;
    rdfs:label 'Guardian Email Address' ;
    rdfs:comment 'Email address of the guardian. Used for pre-flight notifications, service confirmations, and post-flight communication.' ;
    rdfs:domain ind:MinorGuardian ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guardianFirstName rdf:type rdf:Property ;
    rdfs:label 'Guardian First Name' ;
    rdfs:comment 'First name or given name of the guardian. Used for identity verification during minor handover.' ;
    rdfs:domain ind:MinorGuardian ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guardianFullName rdf:type rdf:Property ;
    rdfs:label 'Guardian Full Name' ;
    rdfs:comment 'Full legal name of the authorized guardian or escort responsible for the unaccompanied minor. Required for handover procedures at origin and destination.' ;
    rdfs:domain ind:MinorGuardian ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guardianGovernmentIdNumber rdf:type rdf:Property ;
    rdfs:label 'Guardian Government Id Number' ;
    rdfs:comment 'Identification number from the guardian government-issued document. Recorded for liability and handover audit trail.' ;
    rdfs:domain ind:MinorGuardian ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guardianGovernmentIdType rdf:type rdf:Property ;
    rdfs:label 'Guardian Government Id Type' ;
    rdfs:comment 'Type of government-issued identification document presented by the guardian for identity verification during minor handover.' ;
    rdfs:domain ind:MinorGuardian ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guardianIdIssuingCountry rdf:type rdf:Property ;
    rdfs:label 'Guardian Id Issuing Country' ;
    rdfs:comment 'Three-letter ISO country code of the country that issued the guardian identification document (e.g., USA, GBR, CAN).' ;
    rdfs:domain ind:MinorGuardian ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guardianLastName rdf:type rdf:Property ;
    rdfs:label 'Guardian Last Name' ;
    rdfs:comment 'Last name or family name of the guardian. Used for identity verification during minor handover.' ;
    rdfs:domain ind:MinorGuardian ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guardianPhoneCountryCode rdf:type rdf:Property ;
    rdfs:label 'Guardian Phone Country Code' ;
    rdfs:comment 'International dialing code for the guardian phone number (e.g., +1, +44, +971). Ensures correct routing for international UMNR services.' ;
    rdfs:domain ind:MinorGuardian ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guardianPhoneNumber rdf:type rdf:Property ;
    rdfs:label 'Guardian Phone Number' ;
    rdfs:comment 'Primary contact phone number for the guardian. Used for operational communication during UMNR service delivery and irregular operations (IROP).' ;
    rdfs:domain ind:MinorGuardian ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guardianPostalCode rdf:type rdf:Property ;
    rdfs:label 'Guardian Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the guardian residence. Used for address validation and emergency contact.' ;
    rdfs:domain ind:MinorGuardian ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guardianRole rdf:type rdf:Property ;
    rdfs:label 'Guardian Role' ;
    rdfs:comment 'Operational role of the guardian in the UMNR service workflow. Determines which airport handover procedures apply.' ;
    rdfs:domain ind:MinorGuardian ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guardianStateProvince rdf:type rdf:Property ;
    rdfs:label 'Guardian State Province' ;
    rdfs:comment 'State, province, or administrative region of the guardian residence. Required for certain jurisdictions.' ;
    rdfs:domain ind:MinorGuardian ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guardianshipStatus rdf:type rdf:Property ;
    rdfs:label 'Guardianship Status' ;
    rdfs:comment 'Current lifecycle status of the guardian authorization record. Determines whether the guardian can be used for active UMNR bookings.' ;
    rdfs:domain ind:MinorGuardian ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickupAuthorizationFlag rdf:type rdf:Property ;
    rdfs:label 'Pickup Authorization Flag' ;
    rdfs:comment 'Indicates whether this guardian is authorized to pick up the minor at the destination airport. True if authorized, False otherwise. Critical for ground handling handover procedures.' ;
    rdfs:domain ind:MinorGuardian ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:relationshipToMinor rdf:type rdf:Property ;
    rdfs:label 'Relationship To Minor' ;
    rdfs:comment 'Nature of the relationship between the guardian and the unaccompanied minor. Determines authorization level and liability scope.' ;
    rdfs:domain ind:MinorGuardian ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pnrLinkId rdf:type rdf:Property ;
    rdfs:label 'Pnr Link Id' ;
    rdfs:comment 'Primary key for pnr_link' ;
    rdfs:domain ind:PnrLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bookingAgentEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Booking Agent Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Booking agents create/modify PNRs; essential for commission calculation, quality audits, fraud investigation, regulatory accountability (IATA agent tracking), and performance management. Standard airl' ;
    rdfs:domain ind:PnrLink ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryPnrPaxProfileId rdf:type rdf:Property ;
    rdfs:label 'Primary Pnr Pax Profile Id' ;
    rdfs:comment 'Foreign key reference to the passenger profile in the passenger domain. Identifies the individual traveler whose identity is linked to the PNR.' ;
    rdfs:domain ind:PnrLink ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Profile .

ind:apiDataSubmittedFlag rdf:type rdf:Property ;
    rdfs:label 'Api Data Submitted Flag' ;
    rdfs:comment 'Boolean flag indicating whether Advance Passenger Information (passport, visa, destination address) has been submitted to authorities for this passenger on this PNR. True if submitted; false if not yet submitted. Required for international travel compliance.' ;
    rdfs:domain ind:PnrLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:apisSubmissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Apis Submission Timestamp' ;
    rdfs:comment 'Date and time when API data was transmitted to border control authorities for this passenger. Null if not yet submitted. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:boardingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Boarding Timestamp' ;
    rdfs:comment 'Date and time when this passenger boarded the aircraft for the flight(s) on this PNR. Null if not yet boarded. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:bookingCreationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Booking Creation Timestamp' ;
    rdfs:comment 'Date and time when this passenger was first linked to the PNR in the reservation system. Represents the initial association event. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Passenger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:bookingRole rdf:type rdf:Property ;
    rdfs:label 'Booking Role' ;
    rdfs:comment 'Defines the passenger\'s role within the PNR booking. Lead passenger is the primary contact and decision-maker; accompanying passenger travels with the lead; infant is a child under 2; group leader manages a group booking; group member is part of a group.' ;
    rdfs:domain ind:Passenger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkInTimestamp rdf:type rdf:Property ;
    rdfs:label 'Check In Timestamp' ;
    rdfs:comment 'Date and time when this passenger checked in for the flight(s) on this PNR. Null if not yet checked in. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:infantOnLapIndicator rdf:type rdf:Property ;
    rdfs:label 'Infant On Lap Indicator' ;
    rdfs:comment 'Boolean flag indicating whether the infant is traveling on an adult\'s lap without a separate seat. True if on lap; false if infant has own seat. Impacts seat assignment and safety procedures.' ;
    rdfs:domain ind:PnrLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:knownTravelerNumber rdf:type rdf:Property ;
    rdfs:label 'Known Traveler Number' ;
    rdfs:comment 'TSA PreCheck, Global Entry, or other trusted traveler program number. Enables expedited security screening. Applicable primarily for US travel.' ;
    rdfs:domain ind:Passenger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linkStatus rdf:type rdf:Property ;
    rdfs:label 'Link Status' ;
    rdfs:comment 'Current lifecycle status of the passenger-PNR association. Active indicates valid link; cancelled indicates booking was cancelled; no_show indicates passenger did not appear for travel; checked_in indicates passenger has checked in; boarded indicates passenger has boarded; completed indicates travel is finished; suspended indicates temporary hold. [ENUM-REF-CANDIDATE: active|cancelled|no_show|checked_in|boarded|completed|suspended — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PnrLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nameAssociationType rdf:type rdf:Property ;
    rdfs:label 'Name Association Type' ;
    rdfs:comment 'Categorizes the type of passenger association within the PNR. Primary indicates the main traveler; infant_on_lap indicates a child under 2 traveling on an adult\'s lap without a separate seat; group_member indicates part of a group booking; accompanying indicates a passenger traveling with another; unaccompanied_minor indicates a child traveling alone; crew_deadhead indicates crew repositioning without duty.' ;
    rdfs:domain ind:Passenger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nameMismatchFlag rdf:type rdf:Property ;
    rdfs:label 'Name Mismatch Flag' ;
    rdfs:comment 'Boolean flag indicating whether the PNR passenger name differs from the legal name on the passenger profile. True if mismatch detected; false if names match. Used for data quality monitoring and potential identity verification issues.' ;
    rdfs:domain ind:PnrLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:passengerSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Passenger Sequence Number' ;
    rdfs:comment 'Sequential position of this passenger within the PNR. Used to maintain passenger order in multi-passenger bookings and for referencing specific passengers in PNR transactions.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pnrPassengerName rdf:type rdf:Property ;
    rdfs:label 'Pnr Passenger Name' ;
    rdfs:comment 'Passenger name exactly as it appears on the PNR booking. May differ from the legal name stored in the passenger profile due to name changes, spelling variations, or data entry differences. Used for ticket issuance and travel document verification.' ;
    rdfs:domain ind:PnrLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redressNumber rdf:type rdf:Property ;
    rdfs:label 'Redress Number' ;
    rdfs:comment 'Department of Homeland Security Traveler Redress Inquiry Program (DHS TRIP) number for passengers who have been misidentified in the past. Used to prevent false matches with watch lists. Applicable primarily for US travel.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seatPreference rdf:type rdf:Property ;
    rdfs:label 'Seat Preference' ;
    rdfs:comment 'Passenger\'s preferred seat location for this PNR. Window, aisle, or middle seat preference. Used for seat assignment optimization.' ;
    rdfs:domain ind:Passenger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceGds rdf:type rdf:Property ;
    rdfs:label 'Source Gds' ;
    rdfs:comment 'Identifies the Global Distribution System or booking channel that created the PNR association. Amadeus, Sabre, and Travelport are major GDS platforms; direct indicates airline\'s own PSS; other values indicate distribution channels. [ENUM-REF-CANDIDATE: amadeus|sabre|travelport|direct|travel_agent|online|mobile|call_center|airport — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PnrLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourcePss rdf:type rdf:Property ;
    rdfs:label 'Source Pss' ;
    rdfs:comment 'Name of the Passenger Service System that originated this PNR link record. Examples include Amadeus Altéa, Sabre SabreSonic, or proprietary airline PSS platforms. Enables traceability to the system of record.' ;
    rdfs:domain ind:PnrLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:travelDocumentExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Travel Document Expiry Date' ;
    rdfs:comment 'Expiration date of the travel document provided for this passenger on this PNR. Used to validate document validity for travel dates. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:PnrLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:travelDocumentIssuingCountry rdf:type rdf:Property ;
    rdfs:label 'Travel Document Issuing Country' ;
    rdfs:comment 'Three-letter ISO country code of the country that issued the travel document. Used for border control and visa requirement determination.' ;
    rdfs:domain ind:PnrLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:travelDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Travel Document Number' ;
    rdfs:comment 'Passport or other travel document number provided for this passenger on this PNR. Used for international travel verification and API submission. May differ from the document stored in the passenger profile if the passenger used a different document for this booking.' ;
    rdfs:domain ind:PnrLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:travelDocumentType rdf:type rdf:Property ;
    rdfs:label 'Travel Document Type' ;
    rdfs:comment 'Type of travel document provided for this passenger on this PNR. Passport is most common for international travel; national_id may be accepted for regional travel; visa indicates entry authorization; refugee_travel_document for refugees.' ;
    rdfs:domain ind:PnrLink ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredCityPairId rdf:type rdf:Property ;
    rdfs:label 'Preferred City Pair Id' ;
    rdfs:comment 'Foreign key linking to route.city_pair. Business justification: Route development and network planning teams analyze passenger home/preferred city pairs to identify underserved markets and optimize route networks. Marketing uses this for targeted route launch camp' ;
    rdfs:domain ind:Passenger ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CityPair .

ind:accessibilityRequirements rdf:type rdf:Property ;
    rdfs:label 'Accessibility Requirements' ;
    rdfs:comment 'Special assistance or accessibility needs for passengers with disabilities or reduced mobility. Free-text field capturing wheelchair requirements, visual/hearing impairments, service animal needs, medical equipment, etc. Detailed SSR codes stored in separate SSR product.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completenessScore rdf:type rdf:Property ;
    rdfs:label 'Completeness Score' ;
    rdfs:comment 'Calculated percentage score (0.00 to 100.00) indicating the completeness of the passenger profile based on presence of key fields (contact details, travel documents, preferences, loyalty linkage). Used for data quality monitoring and personalization readiness.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:countryOfResidence rdf:type rdf:Property ;
    rdfs:label 'Country Of Residence' ;
    rdfs:comment 'Country where the passenger permanently resides, represented as ISO 3166-1 alpha-3 country code. Used for customs declarations and passenger segmentation analytics.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creationSource rdf:type rdf:Property ;
    rdfs:label 'Creation Source' ;
    rdfs:comment 'System or channel through which the passenger profile was originally created. Tracks profile origin for data quality and channel analytics. GDS=Global Distribution System (Amadeus, Sabre, Travelport).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSharingConsent rdf:type rdf:Property ;
    rdfs:label 'Data Sharing Consent' ;
    rdfs:comment 'Indicates whether the passenger has consented to sharing their personal data with airline partners, codeshare airlines, and third-party service providers. True=consented, False=not consented.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:firstName rdf:type rdf:Property ;
    rdfs:label 'First Name' ;
    rdfs:comment 'Legal first name (given name) of the passenger as it appears on government-issued identification documents. Must match travel documents for international travel.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastName rdf:type rdf:Property ;
    rdfs:label 'Last Name' ;
    rdfs:comment 'Legal last name (surname/family name) of the passenger as it appears on government-issued identification documents. Must match travel documents for international travel.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingOptIn rdf:type rdf:Property ;
    rdfs:label 'Marketing Opt In' ;
    rdfs:comment 'Indicates whether the passenger has consented to receive marketing communications, promotional offers, and newsletters from the airline. True=opted in, False=opted out.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nationality rdf:type rdf:Property ;
    rdfs:label 'Nationality' ;
    rdfs:comment 'Nationality of the passenger represented as ISO 3166-1 alpha-3 country code. Required for visa validation, customs processing, and API submission to destination countries.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passengerType rdf:type rdf:Property ;
    rdfs:label 'Passenger Type' ;
    rdfs:comment 'Classification of passenger by age and travel status. ADT=Adult (12+ years), CHD=Child (2-11 years), INF=Infant (under 2 years), UMN=Unaccompanied Minor. Determines fare rules, seating requirements, and service protocols.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Email' ;
    rdfs:comment 'Primary email address for passenger communications, booking confirmations, flight notifications, and digital receipts. Display-only summary field; authoritative multi-valued contact store is the contact_detail product.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Phone' ;
    rdfs:comment 'Primary contact phone number for passenger communications, flight alerts, and operational notifications. E.164 international format recommended. Display-only summary field; authoritative multi-valued contact store is the contact_detail product.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suffix rdf:type rdf:Property ;
    rdfs:label 'Suffix' ;
    rdfs:comment 'Name suffix such as Jr, Sr, III, etc. Used to distinguish passengers with identical names.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unaccompaniedMinorGuardianName rdf:type rdf:Property ;
    rdfs:label 'Unaccompanied Minor Guardian Name' ;
    rdfs:comment 'Full name of the parent or legal guardian responsible for an unaccompanied minor passenger. Required for UMN bookings to coordinate drop-off and pick-up procedures.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unaccompaniedMinorGuardianPhone rdf:type rdf:Property ;
    rdfs:label 'Unaccompanied Minor Guardian Phone' ;
    rdfs:comment 'Contact phone number for the parent or legal guardian of an unaccompanied minor passenger. Used for coordination during travel and emergency contact.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vipIndicator rdf:type rdf:Property ;
    rdfs:label 'Vip Indicator' ;
    rdfs:comment 'Flag indicating whether the passenger is designated as a VIP requiring special handling, premium services, or executive attention. True=VIP status, False=standard passenger.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:profileHistoryId rdf:type rdf:Property ;
    rdfs:label 'Profile History Id' ;
    rdfs:comment 'Primary key for profile_history' ;
    rdfs:domain ind:ProfileHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reversedHistoryProfileHistoryId rdf:type rdf:Property ;
    rdfs:label 'Reversed History Profile History Id' ;
    rdfs:comment 'Foreign key reference to the pax_profile_history_id of the original change record that this entry reverses. Null for non-reversal changes. Creates an audit chain linking corrections to their original errors.' ;
    rdfs:domain ind:ProfileHistory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProfileHistory .

ind:agentLocationCode rdf:type rdf:Property ;
    rdfs:label 'Agent Location Code' ;
    rdfs:comment 'Three-letter IATA airport or city code representing the geographic location where the agent performed the change. Null for automated or self-service changes. Supports regional compliance and operational analysis.' ;
    rdfs:domain ind:ProfileHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditRetentionCategory rdf:type rdf:Property ;
    rdfs:label 'Audit Retention Category' ;
    rdfs:comment 'Classification determining the retention period for this audit record. STANDARD follows default policy, EXTENDED for high-value passengers or complex cases, LEGAL_HOLD for litigation or investigation, PERMANENT for regulatory or historical preservation.' ;
    rdfs:domain ind:ProfileHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:automatedProcessCode rdf:type rdf:Property ;
    rdfs:label 'Automated Process Code' ;
    rdfs:comment 'Identifier of the automated system process, batch job, or integration workflow that triggered the profile change. Null for human-initiated changes. Examples: NIGHTLY_DATA_QUALITY_JOB, GDS_SYNC_PROCESS, LOYALTY_TIER_RECALC.' ;
    rdfs:domain ind:ProfileHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeBatchReference rdf:type rdf:Property ;
    rdfs:label 'Change Batch Reference' ;
    rdfs:comment 'Identifier linking this change to a batch processing run or bulk update operation. Null for individual real-time changes. Enables rollback of entire batch operations and supports bulk change audit reporting.' ;
    rdfs:domain ind:ProfileHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Change Reason Description' ;
    rdfs:comment 'Free-text explanation providing additional context for the profile change. Captures agent notes, passenger comments, or automated process descriptions that supplement the reason code.' ;
    rdfs:domain ind:ProfileHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Change Source System' ;
    rdfs:comment 'The system or channel that originated the profile change. Identifies whether the mutation came from the core PSS, passenger self-service channels, agent-assisted channels, or external GDS platforms. [ENUM-REF-CANDIDATE: ALTEA_PSS|WEB_SELF_SERVICE|MOBILE_APP|CALL_CENTRE|GDS_AMADEUS|GDS_SABRE|GDS_TRAVELPORT — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ProfileHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeTimestamp rdf:type rdf:Property ;
    rdfs:label 'Change Timestamp' ;
    rdfs:comment 'Precise date and time when the profile change was committed to the system. Represents the business event time of the mutation. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:changeType rdf:type rdf:Property ;
    rdfs:label 'Change Type' ;
    rdfs:comment 'The nature of the data mutation: INSERT for new profile creation, UPDATE for field modifications, DELETE for logical deletion, MERGE for profile consolidation, GDPR_ERASURE for right-to-be-forgotten requests, CORRECTION for data quality remediation.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeValidationStatus rdf:type rdf:Property ;
    rdfs:label 'Change Validation Status' ;
    rdfs:comment 'The outcome of automated or manual validation checks applied to the profile change. VALIDATED indicates the change passed all business rules, PENDING_REVIEW requires human review, REJECTED indicates the change was blocked, AUTO_APPROVED for low-risk changes, MANUAL_OVERRIDE for supervisor-approved exceptions.' ;
    rdfs:domain ind:ProfileHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changedFieldName rdf:type rdf:Property ;
    rdfs:label 'Changed Field Name' ;
    rdfs:comment 'The specific attribute name in the pax_profile master record that was modified. Enables field-level audit granularity for compliance and data quality investigations.' ;
    rdfs:domain ind:ProfileHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSubjectConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Data Subject Consent Flag' ;
    rdfs:comment 'Boolean indicator of whether the passenger provided explicit consent for this specific data processing activity at the time of the change. True if consent was obtained, False otherwise. Supports GDPR consent management and audit requirements.' ;
    rdfs:domain ind:ProfileHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gdprLawfulBasis rdf:type rdf:Property ;
    rdfs:label 'Gdpr Lawful Basis' ;
    rdfs:comment 'The legal basis under GDPR Article 6 that justifies the processing and retention of this profile change record. Required for EU passenger data. Supports data subject access requests and regulatory audits.' ;
    rdfs:domain ind:ProfileHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newValue rdf:type rdf:Property ;
    rdfs:label 'New Value' ;
    rdfs:comment 'The value of the changed field after the mutation. Stored as string representation to accommodate all data types. Null for DELETE operations. Enables forward reconstruction of profile state evolution.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:previousValue rdf:type rdf:Property ;
    rdfs:label 'Previous Value' ;
    rdfs:comment 'The value of the changed field immediately before the mutation. Stored as string representation to accommodate all data types. Null for INSERT operations. Supports point-in-time reconstruction and rollback scenarios.' ;
    rdfs:domain ind:ProfileHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recordHash rdf:type rdf:Property ;
    rdfs:label 'Record Hash' ;
    rdfs:comment 'Cryptographic hash (SHA-256) of the complete change record payload. Ensures immutability and tamper detection for audit integrity. Supports forensic verification and regulatory compliance with audit trail non-repudiation requirements.' ;
    rdfs:domain ind:ProfileHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retentionExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Retention Expiry Date' ;
    rdfs:comment 'The date on which this audit record is eligible for deletion or archival per the airlines data retention policy and applicable regulatory requirements. Null for records with indefinite retention. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:ProfileHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transactionReference rdf:type rdf:Property ;
    rdfs:label 'Transaction Reference' ;
    rdfs:comment 'Unique identifier linking this profile change to the broader business transaction or session that triggered it. Enables correlation of profile mutations with reservation bookings, check-in events, or loyalty transactions.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:userAgentString rdf:type rdf:Property ;
    rdfs:label 'User Agent String' ;
    rdfs:comment 'The HTTP user agent string identifying the browser, mobile app version, or API client that submitted the profile change. Supports device analytics, compatibility troubleshooting, and fraud pattern detection.' ;
    rdfs:domain ind:ProfileHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ssrRecordId rdf:type rdf:Property ;
    rdfs:label 'Ssr Record Id' ;
    rdfs:comment 'Unique identifier for the SSR record instance. Primary key.' ;
    rdfs:domain ind:SsrRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:handlingCrewMemberId rdf:type rdf:Property ;
    rdfs:label 'Handling Crew Member Id' ;
    rdfs:comment 'Foreign key linking to crew.crew_member. Business justification: Airlines track which cabin crew member fulfilled special service requests (wheelchair assistance, medical needs, special meals) for quality assurance, training feedback, and incident investigation. Op' ;
    rdfs:domain ind:SsrRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Member .

ind:serviceProviderVendorId rdf:type rdf:Property ;
    rdfs:label 'Service Provider Vendor Id' ;
    rdfs:comment 'Foreign key linking to procurement.vendor. Business justification: Special service requests (wheelchairs, medical oxygen, special meals, unaccompanied minor escort) are fulfilled by contracted vendors tracked in procurement. Airlines must link SSR fulfillment to vend' ;
    rdfs:domain ind:SsrRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:confirmationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Confirmation Timestamp' ;
    rdfs:comment 'Date and time when the SSR was confirmed by the airline or service provider. Nullable if not yet confirmed.' ;
    rdfs:domain ind:SsrRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:equipmentRequired rdf:type rdf:Property ;
    rdfs:label 'Equipment Required' ;
    rdfs:comment 'Description of special equipment needed to fulfill this SSR (e.g., onboard wheelchair, oxygen concentrator, stretcher, incubator).' ;
    rdfs:domain ind:SsrRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfillmentNotes rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Notes' ;
    rdfs:comment 'Free-text notes recorded by ground staff or cabin crew documenting how the SSR was fulfilled, any issues encountered, or passenger feedback.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handlingInstructions rdf:type rdf:Property ;
    rdfs:label 'Handling Instructions' ;
    rdfs:comment 'Operational instructions for ground staff, cabin crew, or service providers on how to fulfill this SSR, including equipment needs, timing, and coordination requirements.' ;
    rdfs:domain ind:SsrRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isInterline rdf:type rdf:Property ;
    rdfs:label 'Is Interline' ;
    rdfs:comment 'Boolean flag indicating whether this SSR applies to an interline segment operated by a partner carrier (true) or an own-metal flight (false).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isStandingPreference rdf:type rdf:Property ;
    rdfs:label 'Is Standing Preference' ;
    rdfs:comment 'Boolean flag indicating whether this SSR was auto-populated from the passenger\'s standing travel preferences (true) or requested ad-hoc for this booking (false).' ;
    rdfs:domain ind:SsrRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mealCode rdf:type rdf:Property ;
    rdfs:label 'Meal Code' ;
    rdfs:comment 'Four-letter IATA meal code for dietary SSRs (e.g., VGML for vegetarian, KSML for kosher, DBML for diabetic). Applicable only when ssr_code is SPML.' ;
    rdfs:domain ind:SsrRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalClearanceStatus rdf:type rdf:Property ;
    rdfs:label 'Medical Clearance Status' ;
    rdfs:comment 'Status of medical clearance for SSRs requiring medical approval. Values: not_required, pending, approved, denied.' ;
    rdfs:domain ind:SsrRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresAdvanceNotice rdf:type rdf:Property ;
    rdfs:label 'Requires Advance Notice' ;
    rdfs:comment 'Boolean flag indicating whether this SSR type requires advance notice to the airline (true) or can be requested at check-in or boarding (false).' ;
    rdfs:domain ind:SsrRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresMedicalClearance rdf:type rdf:Property ;
    rdfs:label 'Requires Medical Clearance' ;
    rdfs:comment 'Boolean flag indicating whether this SSR requires medical clearance or MEDA form approval before confirmation (true for MEDA, OXYG, STCR SSRs).' ;
    rdfs:domain ind:SsrRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceDeliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Service Delivery Timestamp' ;
    rdfs:comment 'Date and time when the SSR service was actually delivered or completed. Nullable if not yet delivered.' ;
    rdfs:domain ind:SsrRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ssrCategory rdf:type rdf:Property ;
    rdfs:label 'Ssr Category' ;
    rdfs:comment 'High-level categorization of the SSR type for reporting and operational grouping (accessibility, medical, dietary, unaccompanied minor, pet transport, special baggage, other). [ENUM-REF-CANDIDATE: accessibility|medical|dietary|unaccompanied_minor|pet_transport|special_baggage|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ssrDescription rdf:type rdf:Property ;
    rdfs:label 'Ssr Description' ;
    rdfs:comment 'Free-text description providing additional details about the SSR, including handling instructions, meal preferences, medical conditions, or special equipment requirements.' ;
    rdfs:domain ind:SsrRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ssrStatus rdf:type rdf:Property ;
    rdfs:label 'Ssr Status' ;
    rdfs:comment 'Current lifecycle status of the SSR indicating whether the service has been requested, confirmed by the airline, waitlisted, cancelled, denied, or completed.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wheelchairType rdf:type rdf:Property ;
    rdfs:label 'Wheelchair Type' ;
    rdfs:comment 'Specific wheelchair assistance level for accessibility SSRs: WCHR (can walk stairs), WCHS (cannot walk stairs), WCHC (immobile, requires onboard wheelchair). Applicable only for wheelchair SSR codes.' ;
    rdfs:domain ind:SsrRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:travelIdentityDocumentId rdf:type rdf:Property ;
    rdfs:label 'Travel Identity Document Id' ;
    rdfs:comment 'Unique identifier for the travel identity document record. Primary key.' ;
    rdfs:domain ind:TravelIdentityDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:apisResponseCode rdf:type rdf:Property ;
    rdfs:label 'Apis Response Code' ;
    rdfs:comment 'Response code received from border control authority after APIS transmission. OK=cleared to board; INHIBITED=passenger denied boarding; CONDITIONAL=manual review required. Codes vary by country.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apisTransmissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Apis Transmission Timestamp' ;
    rdfs:comment 'Date and time when the document data was transmitted to border control authorities. Used to prove compliance with advance notification requirements (typically 72 hours before departure for USA).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:apisTransmittedFlag rdf:type rdf:Property ;
    rdfs:label 'Apis Transmitted Flag' ;
    rdfs:comment 'Indicates whether this documents data has been successfully transmitted to destination country border control authorities via APIS. Required for flights to USA, Canada, UK, EU, and many other jurisdictions.' ;
    rdfs:domain ind:TravelIdentityDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:documentImageUrl rdf:type rdf:Property ;
    rdfs:label 'Document Image Url' ;
    rdfs:comment 'Secure storage location (URI) of the scanned or photographed document image. Used for manual verification, fraud investigation, and regulatory compliance. Access restricted to authorized personnel only.' ;
    rdfs:domain ind:TravelIdentityDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentSource rdf:type rdf:Property ;
    rdfs:label 'Document Source' ;
    rdfs:comment 'Method by which the document data was captured. Manual_entry=agent typed data; OCR_scan=automated optical character recognition from image; Mobile_app=passenger self-service via mobile; GDS=received from Global Distribution System; API_integration=received from partner system.' ;
    rdfs:domain ind:TravelIdentityDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:givenNames rdf:type rdf:Property ;
    rdfs:label 'Given Names' ;
    rdfs:comment 'First and middle names as printed on the travel document. Must match PNR for secure flight and APIS compliance.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPrimaryDocument rdf:type rdf:Property ;
    rdfs:label 'Is Primary Document' ;
    rdfs:comment 'Flag indicating whether this is the passengers primary travel document for the current booking. A passenger may hold multiple documents (e.g., passport + national ID), but only one is designated primary for APIS reporting.' ;
    rdfs:domain ind:TravelIdentityDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:knownTravellerNumber rdf:type rdf:Property ;
    rdfs:label 'Known Traveller Number' ;
    rdfs:comment 'Trusted traveller program membership number (e.g., TSA PreCheck, Global Entry, NEXUS, SENTRI, APEC Business Travel Card). Enables expedited security screening and border clearance. Stored for automatic inclusion in secure flight data.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:knownTravellerProgram rdf:type rdf:Property ;
    rdfs:label 'Known Traveller Program' ;
    rdfs:comment 'Name of the trusted traveller program associated with the known traveller number. Determines which expedited lanes and services the passenger is eligible for.' ;
    rdfs:domain ind:TravelIdentityDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastUsedFlightDate rdf:type rdf:Property ;
    rdfs:label 'Last Used Flight Date' ;
    rdfs:comment 'Date of the most recent flight on which this document was used for travel. Helps identify stale or outdated document records and supports passenger profile analytics.' ;
    rdfs:domain ind:TravelIdentityDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mrzLine1 rdf:type rdf:Property ;
    rdfs:label 'Mrz Line1' ;
    rdfs:comment 'First line of the machine-readable zone at the bottom of the document. Contains document type, issuing country, and surname/given names in standardized format. Used for automated document scanning and APIS transmission.' ;
    rdfs:domain ind:TravelIdentityDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mrzLine2 rdf:type rdf:Property ;
    rdfs:label 'Mrz Line2' ;
    rdfs:comment 'Second line of the machine-readable zone. Contains document number, nationality, date of birth, gender, expiry date, and check digits. Enables rapid data capture via optical character recognition (OCR) at check-in kiosks and border control.' ;
    rdfs:domain ind:TravelIdentityDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mrzLine3 rdf:type rdf:Property ;
    rdfs:label 'Mrz Line3' ;
    rdfs:comment 'Third line of the machine-readable zone (present on some document types such as ID cards). Contains additional personal data and check digits.' ;
    rdfs:domain ind:TravelIdentityDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:placeOfBirth rdf:type rdf:Property ;
    rdfs:label 'Place Of Birth' ;
    rdfs:comment 'City and country of birth as printed on the travel document. Required for certain APIS destinations (e.g., USA, Canada) and visa applications.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secureFlightStatus rdf:type rdf:Property ;
    rdfs:label 'Secure Flight Status' ;
    rdfs:comment 'TSA Secure Flight screening result for USA-bound flights. Not_submitted=data not yet sent; Cleared=passenger approved for boarding; Inhibited=passenger denied boarding (no-fly list match); Conditional=requires additional screening or documentation.' ;
    rdfs:domain ind:TravelIdentityDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surname rdf:type rdf:Property ;
    rdfs:label 'Surname' ;
    rdfs:comment 'Family name or surname as printed on the travel document. Must match exactly with booking PNR (Passenger Name Record) for boarding pass issuance and border clearance.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Verification Timestamp' ;
    rdfs:comment 'Date and time when the document verification status was last updated. Used for audit trail and compliance reporting.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:visaRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Visa Required Flag' ;
    rdfs:comment 'Indicates whether a visa is required for the passengers itinerary based on nationality, destination, and transit countries. Calculated using IATA Timatic rules. If true, a separate visa document record must exist.' ;
    rdfs:domain ind:TravelIdentityDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:travelPreferenceId rdf:type rdf:Property ;
    rdfs:label 'Travel Preference Id' ;
    rdfs:comment 'Unique identifier for the travel preference record. Primary key.' ;
    rdfs:domain ind:TravelPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preferredDepartureAirportStationId rdf:type rdf:Property ;
    rdfs:label 'Preferred Departure Airport Station Id' ;
    rdfs:comment 'Foreign key linking to airport.station. Business justification: Travel preferences drive booking search personalization, corporate travel policy enforcement, and loyalty program targeting by home airport. Airlines use preferred departure station to optimize route ' ;
    rdfs:domain ind:TravelPreference ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Station .

ind:accessibilityRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Accessibility Requirement Flag' ;
    rdfs:comment 'Indicates whether the passenger has accessibility or special assistance requirements that should be considered during booking and service delivery. When true, detailed SSR records (WCHR, WCHS, WCHC, DEAF, BLIND, etc.) should be reviewed.' ;
    rdfs:domain ind:TravelPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:alliancePreference rdf:type rdf:Property ;
    rdfs:label 'Alliance Preference' ;
    rdfs:comment 'Passenger\'s preferred airline alliance for travel. Influences interline and codeshare booking recommendations to maximize FFP mileage accrual and benefits.' ;
    rdfs:domain ind:TravelPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ancillaryPreference rdf:type rdf:Property ;
    rdfs:label 'Ancillary Preference' ;
    rdfs:comment 'Passenger\'s preferred ancillary services for automatic offer targeting: extra baggage allowance, lounge access, priority boarding, fast-track security, in-flight wifi. Supports personalized EMD (Electronic Miscellaneous Document) generation.' ;
    rdfs:domain ind:TravelPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boardingPassFormatPreference rdf:type rdf:Property ;
    rdfs:label 'Boarding Pass Format Preference' ;
    rdfs:comment 'Passenger\'s preferred format for receiving boarding passes: mobile wallet, email PDF, print-at-home, or no preference. Supports digital transformation and sustainability initiatives.' ;
    rdfs:domain ind:TravelPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookingChannelPreference rdf:type rdf:Property ;
    rdfs:label 'Booking Channel Preference' ;
    rdfs:comment 'Passenger\'s preferred channel for making flight reservations. Used for channel-specific marketing and user experience optimization.' ;
    rdfs:domain ind:Passenger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cabinClassPreference rdf:type rdf:Property ;
    rdfs:label 'Cabin Class Preference' ;
    rdfs:comment 'Passenger\'s preferred cabin class for travel. Used by revenue management for personalized offer construction and upsell targeting.' ;
    rdfs:domain ind:TravelPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkInPreference rdf:type rdf:Property ;
    rdfs:label 'Check In Preference' ;
    rdfs:comment 'Passenger\'s preferred method for flight check-in. Used to send targeted reminders and optimize ground handling resource allocation.' ;
    rdfs:domain ind:TravelPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communicationChannelPreference rdf:type rdf:Property ;
    rdfs:label 'Communication Channel Preference' ;
    rdfs:comment 'Passenger\'s preferred channel for receiving airline communications (booking confirmations, flight status updates, promotional offers). Supports GDPR consent management.' ;
    rdfs:domain ind:TravelPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:connectionTimePreference rdf:type rdf:Property ;
    rdfs:label 'Connection Time Preference' ;
    rdfs:comment 'Passenger\'s preferred connection time for multi-leg journeys: minimum (MCT only), short (MCT + 30 min), medium (1-2 hours), long (2+ hours for lounge time). Influences itinerary construction and IROP reprotection.' ;
    rdfs:domain ind:TravelPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:directFlightPreferenceFlag rdf:type rdf:Property ;
    rdfs:label 'Direct Flight Preference Flag' ;
    rdfs:comment 'Indicates whether the passenger strongly prefers direct (non-stop) flights over connecting itineraries. Used for search result ranking and offer personalization.' ;
    rdfs:domain ind:TravelPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:frequentFlyerTierPreference rdf:type rdf:Property ;
    rdfs:label 'Frequent Flyer Tier Preference' ;
    rdfs:comment 'Passenger\'s target or preferred FFP tier level. Used for personalized upgrade offers and tier-based service customization. Links to loyalty tier status for benefit entitlement.' ;
    rdfs:domain ind:TravelPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:infantTravelFlag rdf:type rdf:Property ;
    rdfs:label 'Infant Travel Flag' ;
    rdfs:comment 'Indicates whether the passenger frequently travels with an infant (under 2 years). When true, bulkhead seating with bassinet availability is prioritized, and infant-specific SSRs are auto-generated.' ;
    rdfs:domain ind:TravelPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:languagePreferenceCode rdf:type rdf:Property ;
    rdfs:label 'Language Preference Code' ;
    rdfs:comment 'ISO 639-1 two-letter language code for the passenger\'s preferred communication language. Used for personalized communications, in-flight service, and customer service interactions.' ;
    rdfs:domain ind:TravelPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mealPreferenceCode rdf:type rdf:Property ;
    rdfs:label 'Meal Preference Code' ;
    rdfs:comment 'IATA standard 4-letter code for passenger\'s standing dietary meal preference (e.g., VGML=Vegetarian Vegan, KSML=Kosher, DBML=Diabetic, MOML=Muslim, AVML=Asian Vegetarian, HNML=Hindu, LCML=Low Calorie, NLML=Low Lactose, GFML=Gluten Free, BLML=Bland). This standing preference is used to auto-generate per-flight SSR meal requests.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationPreference rdf:type rdf:Property ;
    rdfs:label 'Notification Preference' ;
    rdfs:comment 'Passenger\'s preference for the types of notifications to receive: all (flight status, booking confirmations, promotions), flight_status_only (operational updates), booking_only (transactional), none (opt-out).' ;
    rdfs:domain ind:TravelPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:petTravelPreferenceFlag rdf:type rdf:Property ;
    rdfs:label 'Pet Travel Preference Flag' ;
    rdfs:comment 'Indicates whether the passenger frequently travels with pets (in-cabin or cargo). Used to auto-generate PETC (pet in cabin) or AVIH (animal in hold) SSRs and ensure compliance with pet travel regulations.' ;
    rdfs:domain ind:TravelPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferenceConfidenceScore rdf:type rdf:Property ;
    rdfs:label 'Preference Confidence Score' ;
    rdfs:comment 'Confidence score (0.00 to 100.00) indicating the reliability of inferred preferences based on historical booking patterns and ML model predictions. Higher scores indicate stronger preference signals.' ;
    rdfs:domain ind:TravelPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preferencePriority rdf:type rdf:Property ;
    rdfs:label 'Preference Priority' ;
    rdfs:comment 'Priority ranking (1=highest) for this preference when multiple preferences of the same type exist. Used to resolve conflicts during automated SSR generation and seat assignment.' ;
    rdfs:domain ind:TravelPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:preferenceSource rdf:type rdf:Property ;
    rdfs:label 'Preference Source' ;
    rdfs:comment 'Origin of the preference data: stated (explicitly provided by passenger), inferred (derived from booking history and behavior), imported (from partner FFP or GDS profile), default (system-assigned).' ;
    rdfs:domain ind:TravelPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferenceType rdf:type rdf:Property ;
    rdfs:label 'Preference Type' ;
    rdfs:comment 'Category of travel preference: seat (seating position), cabin (class of service), meal (dietary), airport (departure preference), airline (carrier preference), communication (channel preference), language (communication language). [ENUM-REF-CANDIDATE: seat|cabin|meal|airport|airline|communication|language — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TravelPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredAirlineCode rdf:type rdf:Property ;
    rdfs:label 'Preferred Airline Code' ;
    rdfs:comment 'IATA 2-character airline designator code for the passenger\'s preferred carrier. Used for codeshare and interline booking prioritization.' ;
    rdfs:domain ind:TravelPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seatLocationPreference rdf:type rdf:Property ;
    rdfs:label 'Seat Location Preference' ;
    rdfs:comment 'Passenger\'s preferred location within the cabin (front, middle, rear sections, exit row for extra legroom, bulkhead for bassinet or legroom). Influences automated seat assignment logic.' ;
    rdfs:domain ind:TravelPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seatPositionPreference rdf:type rdf:Property ;
    rdfs:label 'Seat Position Preference' ;
    rdfs:comment 'Passenger\'s preferred seat position within the aircraft cabin. Used by Altéa PSS for automated seat assignment and SSR generation.' ;
    rdfs:domain ind:TravelPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeOfDayPreference rdf:type rdf:Property ;
    rdfs:label 'Time Of Day Preference' ;
    rdfs:comment 'Passenger\'s preferred departure time of day. Used for personalized flight search results and schedule optimization.' ;
    rdfs:domain ind:TravelPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:travelCompanionPreference rdf:type rdf:Property ;
    rdfs:label 'Travel Companion Preference' ;
    rdfs:comment 'Passenger\'s typical travel companion profile (solo traveler, family with children, business colleagues, group travel). Used for personalized service delivery and seating arrangements.' ;
    rdfs:domain ind:TravelPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upgradePreferenceFlag rdf:type rdf:Property ;
    rdfs:label 'Upgrade Preference Flag' ;
    rdfs:comment 'Indicates whether the passenger prefers to be automatically considered for cabin upgrades when available (using miles, revenue, or operational upgrades). Used by revenue management for upgrade inventory allocation.' ;
    rdfs:domain ind:TravelPreference ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:travellerSegmentId rdf:type rdf:Property ;
    rdfs:label 'Traveller Segment Id' ;
    rdfs:comment 'Primary key for traveller_segment' ;
    rdfs:domain ind:TravellerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ancillaryPropensityScore rdf:type rdf:Property ;
    rdfs:label 'Ancillary Propensity Score' ;
    rdfs:comment 'Propensity score (0.0000 to 1.0000) indicating likelihood of purchasing ancillary services (seat selection, baggage, meals, lounge access). Used for upsell targeting.' ;
    rdfs:domain ind:TravellerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignmentDate rdf:type rdf:Property ;
    rdfs:label 'Assignment Date' ;
    rdfs:comment 'Date when the passenger was assigned to this segment. Used for segment tenure analysis and lifecycle tracking.' ;
    rdfs:domain ind:TravellerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cabinPreference rdf:type rdf:Property ;
    rdfs:label 'Cabin Preference' ;
    rdfs:comment 'Predominant cabin class preference observed or predicted for this passenger segment: first, business, premium economy, economy, or mixed (no clear preference).' ;
    rdfs:domain ind:TravellerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:churnRiskScore rdf:type rdf:Property ;
    rdfs:label 'Churn Risk Score' ;
    rdfs:comment 'Predictive score (0.0000 to 1.0000) indicating the likelihood of passenger churn (switching to competitor or ceasing travel). Higher score indicates higher risk.' ;
    rdfs:domain ind:TravellerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confidenceScore rdf:type rdf:Property ;
    rdfs:label 'Confidence Score' ;
    rdfs:comment 'Statistical confidence or probability score (0.0000 to 1.0000) indicating the model\'s certainty in this segment assignment. Applicable for ML-derived segments; null for rule-based assignments.' ;
    rdfs:domain ind:TravellerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:corporateAffiliationFlag rdf:type rdf:Property ;
    rdfs:label 'Corporate Affiliation Flag' ;
    rdfs:comment 'Indicates whether the passenger is affiliated with a corporate travel program or business account (true) or is a leisure/individual traveller (false).' ;
    rdfs:domain ind:TravellerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lifetimeValueTier rdf:type rdf:Property ;
    rdfs:label 'Lifetime Value Tier' ;
    rdfs:comment 'Lifetime value tier classification derived from historical and predicted revenue: platinum (highest value), gold, silver, bronze, or standard. Distinct from loyalty program tier.' ;
    rdfs:domain ind:TravellerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loyaltyEngagementLevel rdf:type rdf:Property ;
    rdfs:label 'Loyalty Engagement Level' ;
    rdfs:comment 'Level of engagement with the airline\'s FFP (Frequent Flyer Program): highly engaged (active accrual and redemption), engaged, moderately engaged, low engagement, or not enrolled.' ;
    rdfs:domain ind:TravellerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceSensitivityIndicator rdf:type rdf:Property ;
    rdfs:label 'Price Sensitivity Indicator' ;
    rdfs:comment 'Assessed price sensitivity level of the passenger segment: very high (highly price-sensitive, seeks lowest fares), high, medium, low, or very low (price-insensitive, values convenience/service).' ;
    rdfs:domain ind:TravellerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueContributionScore rdf:type rdf:Property ;
    rdfs:label 'Revenue Contribution Score' ;
    rdfs:comment 'Estimated or actual revenue contribution value associated with this passenger segment, used for value-based segmentation and prioritization. Currency in airline\'s base currency.' ;
    rdfs:domain ind:TravellerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:routePreferenceType rdf:type rdf:Property ;
    rdfs:label 'Route Preference Type' ;
    rdfs:comment 'Predominant route type preference: domestic, short-haul international, long-haul international, or mixed. Used for network planning and targeted offers.' ;
    rdfs:domain ind:TravellerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentCategory rdf:type rdf:Property ;
    rdfs:label 'Segment Category' ;
    rdfs:comment 'High-level classification of the segment type: value-based, behavior-based, lifecycle stage, propensity model, demographic, or geographic segmentation.' ;
    rdfs:domain ind:TravellerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentDescription rdf:type rdf:Property ;
    rdfs:label 'Segment Description' ;
    rdfs:comment 'Detailed textual description of the segment characteristics, targeting criteria, and business rationale. Used for segment documentation and stakeholder communication.' ;
    rdfs:domain ind:TravellerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentModelVersion rdf:type rdf:Property ;
    rdfs:label 'Segment Model Version' ;
    rdfs:comment 'Version identifier of the segmentation model or rule set used to assign this segment. Enables tracking of model evolution and reprocessing.' ;
    rdfs:domain ind:TravellerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentNotes rdf:type rdf:Property ;
    rdfs:label 'Segment Notes' ;
    rdfs:comment 'Free-text field for additional notes, comments, or context about this segment assignment. Used for manual overrides, special cases, or analyst annotations.' ;
    rdfs:domain ind:TravellerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentPriority rdf:type rdf:Property ;
    rdfs:label 'Segment Priority' ;
    rdfs:comment 'Numeric priority ranking (1=highest) used when a passenger belongs to multiple segments simultaneously. Determines which segment takes precedence for targeting and personalization.' ;
    rdfs:domain ind:TravellerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:segmentSource rdf:type rdf:Property ;
    rdfs:label 'Segment Source' ;
    rdfs:comment 'Origin of the segment assignment: rules engine (business rule-based), ML model (machine learning algorithm), manual (analyst-assigned), third-party (external data provider), or hybrid (combination of methods).' ;
    rdfs:domain ind:TravellerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Segment Source System' ;
    rdfs:comment 'Name or identifier of the system or model that generated the segment assignment (e.g., Sabre AirVision Revenue Management, internal propensity model, CRM segmentation engine).' ;
    rdfs:domain ind:TravellerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetingEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Targeting Eligible Flag' ;
    rdfs:comment 'Indicates whether this segment assignment makes the passenger eligible for targeted marketing campaigns and personalized offers (true) or should be excluded (false) due to opt-out or regulatory restrictions.' ;
    rdfs:domain ind:TravellerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:travelFrequencyBand rdf:type rdf:Property ;
    rdfs:label 'Travel Frequency Band' ;
    rdfs:comment 'Classification of passenger travel frequency based on flight count over a defined period: very high (frequent business traveller), high, medium, low, very low, or inactive (lapsed).' ;
    rdfs:domain ind:TravellerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:watchlistCheckId rdf:type rdf:Property ;
    rdfs:label 'Watchlist Check Id' ;
    rdfs:comment 'Primary key for watchlist_check' ;
    rdfs:domain ind:WatchlistCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:apiPnrIndicator rdf:type rdf:Property ;
    rdfs:label 'Api Pnr Indicator' ;
    rdfs:comment 'Indicates whether the screening was performed using API data, PNR data, or both.' ;
    rdfs:domain ind:WatchlistCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boardingPassIssued rdf:type rdf:Property ;
    rdfs:label 'Boarding Pass Issued' ;
    rdfs:comment 'Indicates whether a boarding pass was issued following the watchlist check clearance.' ;
    rdfs:domain ind:WatchlistCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataRetentionDate rdf:type rdf:Property ;
    rdfs:label 'Data Retention Date' ;
    rdfs:comment 'Date when this watchlist check record must be purged per regulatory data retention requirements.' ;
    rdfs:domain ind:WatchlistCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:matchReason rdf:type rdf:Property ;
    rdfs:label 'Match Reason' ;
    rdfs:comment 'Description of the reason for the match, including which passenger attributes triggered the screening alert.' ;
    rdfs:domain ind:WatchlistCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchScore rdf:type rdf:Property ;
    rdfs:label 'Match Score' ;
    rdfs:comment 'Numerical confidence score (0.00 to 100.00) indicating the likelihood of a true match when a potential match is detected.' ;
    rdfs:domain ind:WatchlistCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:matchStatus rdf:type rdf:Property ;
    rdfs:label 'Match Status' ;
    rdfs:comment 'Result of the watchlist screening check indicating whether the passenger matched any watchlist entries.' ;
    rdfs:domain ind:WatchlistCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Screening Jurisdiction' ;
    rdfs:comment 'Two or three-letter country or region code indicating the regulatory jurisdiction under which screening was performed.' ;
    rdfs:domain ind:WatchlistCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningProgram rdf:type rdf:Property ;
    rdfs:label 'Screening Program' ;
    rdfs:comment 'The regulatory or security program under which the watchlist check was performed.' ;
    rdfs:domain ind:WatchlistCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningSystem rdf:type rdf:Property ;
    rdfs:label 'Screening System' ;
    rdfs:comment 'Name or identifier of the automated screening system that performed the watchlist check.' ;
    rdfs:domain ind:WatchlistCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningVersion rdf:type rdf:Property ;
    rdfs:label 'Screening Version' ;
    rdfs:comment 'Version number of the screening algorithm or watchlist data used for the check.' ;
    rdfs:domain ind:WatchlistCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:selecteeIndicator rdf:type rdf:Property ;
    rdfs:label 'Selectee Indicator' ;
    rdfs:comment 'Indicates whether the passenger was designated for enhanced secondary screening (SSSS - Secondary Security Screening Selection).' ;
    rdfs:domain ind:WatchlistCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:watchlistName rdf:type rdf:Property ;
    rdfs:label 'Watchlist Name' ;
    rdfs:comment 'Name or identifier of the specific watchlist that triggered a match (e.g., No Fly List, Selectee List, OFAC SDN List).' ;
    rdfs:domain ind:WatchlistCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvedVendorListId rdf:type rdf:Property ;
    rdfs:label 'Approved Vendor List Id' ;
    rdfs:comment 'Unique identifier for the approved vendor list entry. Primary key for the AVL record.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditDate rdf:type rdf:Property ;
    rdfs:label 'Audit Date' ;
    rdfs:comment 'The date of the most recent quality audit conducted on the vendor. Null if no audit has been conducted.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditScore rdf:type rdf:Property ;
    rdfs:label 'Audit Score' ;
    rdfs:comment 'The most recent quality audit score for the vendor, typically expressed as a percentage (0-100). Used to track vendor quality performance and compliance. Null if no audit has been conducted.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conditionalApprovalRestrictions rdf:type rdf:Property ;
    rdfs:label 'Conditional Approval Restrictions' ;
    rdfs:comment 'Detailed description of any restrictions or conditions attached to the approval. Applicable when approval_status is conditional. May include quantity limits, usage restrictions, or additional oversight requirements.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:delistingDate rdf:type rdf:Property ;
    rdfs:label 'Delisting Date' ;
    rdfs:comment 'The date on which the vendor was permanently delisted from the approved vendor list. Null if never delisted.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:delistingReason rdf:type rdf:Property ;
    rdfs:label 'Delisting Reason' ;
    rdfs:comment 'The reason for permanently removing the vendor from the approved vendor list. Applicable when approval_status is delisted. May include severe quality failures, fraud, bankruptcy, or regulatory sanctions.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:easaPart145ApprovedFlag rdf:type rdf:Property ;
    rdfs:label 'Easa Part145 Approved Flag' ;
    rdfs:comment 'Indicates whether the vendor holds EASA Part-145 approval for maintenance organization. True = EASA Part-145 approved; False = not approved. Required for MRO parts suppliers in EASA jurisdictions.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:faaRepairStationCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Faa Repair Station Certificate Number' ;
    rdfs:comment 'The FAA-issued repair station certificate number for the vendor. Unique identifier for the repair station certification.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:faaRepairStationFlag rdf:type rdf:Property ;
    rdfs:label 'Faa Repair Station Flag' ;
    rdfs:comment 'Indicates whether the vendor holds FAA repair station certification. True = FAA certified repair station; False = not certified. Required for certain MRO parts suppliers in FAA jurisdictions.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Lead Time Days' ;
    rdfs:comment 'The standard procurement lead time in days from order placement to delivery for this vendor and part combination. Used for materials planning and inventory management.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Minimum Order Quantity' ;
    rdfs:comment 'The minimum order quantity required by the vendor for this part or category. Expressed in the parts unit of measure. Null if no minimum applies.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oemAuthorizationFlag rdf:type rdf:Property ;
    rdfs:label 'Oem Authorization Flag' ;
    rdfs:comment 'Indicates whether the vendor is authorized by the original equipment manufacturer to supply the part or material. True = OEM authorized; False = not OEM authorized. Critical for airworthiness compliance.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:oemAuthorizationReference rdf:type rdf:Property ;
    rdfs:label 'Oem Authorization Reference' ;
    rdfs:comment 'The reference number, certificate ID, or documentation reference for the OEM authorization. May include distributor agreement numbers or OEM approval letters.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityCertificationReference rdf:type rdf:Property ;
    rdfs:label 'Quality Certification Reference' ;
    rdfs:comment 'The certification number, certificate ID, or reference to the vendors quality system certification (e.g., ISO 9001:2015 certificate number, AS9100 registration number).' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualitySystemCertificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Quality System Certification Required Flag' ;
    rdfs:comment 'Indicates whether the vendor is required to maintain a quality management system certification (e.g., ISO 9001, AS9100) as a condition of approval. True = certification required; False = not required.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:soleSourceFlag rdf:type rdf:Property ;
    rdfs:label 'Sole Source Flag' ;
    rdfs:comment 'Indicates whether the vendor is the sole approved source for this part or category. True = sole source (no alternatives); False = multiple sources available. Critical for supply chain risk management.' ;
    rdfs:domain ind:ApprovedVendorList ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:suspensionDate rdf:type rdf:Property ;
    rdfs:label 'Suspension Date' ;
    rdfs:comment 'The date on which the vendors approval was suspended. Null if never suspended or currently not suspended.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requestedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Requested By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Catering orders are initiated by crew schedulers, cabin services coordinators, or flight ops employees. Tracks who requested specific meal counts and special meals. Essential for accountability when c' ;
    rdfs:domain ind:CateringOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualMealCountDelivered rdf:type rdf:Property ;
    rdfs:label 'Actual Meal Count Delivered' ;
    rdfs:comment 'Total number of meals actually delivered and uplifted, used to calculate variance against ordered quantity.' ;
    rdfs:domain ind:CateringOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualUpliftTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Uplift Timestamp' ;
    rdfs:comment 'Date and time when catering was physically loaded onto the aircraft, recorded by ground handling or catering supervisor.' ;
    rdfs:domain ind:CateringOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:beverageQuantityUnits rdf:type rdf:Property ;
    rdfs:label 'Beverage Quantity Units' ;
    rdfs:comment 'Total quantity of beverage units ordered, measured in standard service units (bottles, cans, cartons) as defined in the catering contract.' ;
    rdfs:domain ind:CateringOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:businessClassMealCount rdf:type rdf:Property ;
    rdfs:label 'Business Class Meal Count' ;
    rdfs:comment 'Total number of standard meals ordered for Business Class cabin, excluding special meals.' ;
    rdfs:domain ind:CateringOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cateringSupervisorName rdf:type rdf:Property ;
    rdfs:label 'Catering Supervisor Name' ;
    rdfs:comment 'Name of the catering supervisor who signed off on the order delivery and uplift, providing accountability for service completion.' ;
    rdfs:domain ind:CateringOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cateringSupervisorSignatureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Catering Supervisor Signature Timestamp' ;
    rdfs:comment 'Date and time when the catering supervisor signed off on the order, confirming completion of uplift.' ;
    rdfs:domain ind:CateringOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cateringUpliftStationCode rdf:type rdf:Property ;
    rdfs:label 'Catering Uplift Station Code' ;
    rdfs:comment 'Three-letter IATA airport code for the station where catering is physically loaded onto the aircraft. May differ from departure station for through flights.' ;
    rdfs:domain ind:CateringOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crewMealCount rdf:type rdf:Property ;
    rdfs:label 'Crew Meal Count' ;
    rdfs:comment 'Total number of meals ordered for operating crew members (flight deck and cabin crew).' ;
    rdfs:domain ind:CateringOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:departureStationCode rdf:type rdf:Property ;
    rdfs:label 'Departure Station Code' ;
    rdfs:comment 'Three-letter IATA airport code for the departure station of the flight leg.' ;
    rdfs:domain ind:CateringOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:economyClassMealCount rdf:type rdf:Property ;
    rdfs:label 'Economy Class Meal Count' ;
    rdfs:comment 'Total number of standard meals ordered for Economy Class cabin, excluding special meals.' ;
    rdfs:domain ind:CateringOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:firstClassMealCount rdf:type rdf:Property ;
    rdfs:label 'First Class Meal Count' ;
    rdfs:comment 'Total number of standard meals ordered for First Class cabin, excluding special meals.' ;
    rdfs:domain ind:CateringOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:galleyInsertCount rdf:type rdf:Property ;
    rdfs:label 'Galley Insert Count' ;
    rdfs:comment 'Number of galley inserts (meal trays, containers) required for this catering order.' ;
    rdfs:domain ind:CateringOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:orderPlacementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Order Placement Timestamp' ;
    rdfs:comment 'Date and time when the catering order was placed with the supplier. Principal business event timestamp for this transaction.' ;
    rdfs:domain ind:CateringOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:orderTotalCostAmount rdf:type rdf:Property ;
    rdfs:label 'Order Total Cost Amount' ;
    rdfs:comment 'Total cost of the catering order in the contract currency, including all meals, beverages, equipment, and service charges.' ;
    rdfs:domain ind:CateringOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:premiumEconomyMealCount rdf:type rdf:Property ;
    rdfs:label 'Premium Economy Meal Count' ;
    rdfs:comment 'Total number of standard meals ordered for Premium Economy cabin, excluding special meals.' ;
    rdfs:domain ind:CateringOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requiredDeliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Required Delivery Timestamp' ;
    rdfs:comment 'Date and time by which catering must be delivered to the aircraft for uplift, typically aligned with turnaround schedule.' ;
    rdfs:domain ind:CateringOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shortDeliveryReason rdf:type rdf:Property ;
    rdfs:label 'Short Delivery Reason' ;
    rdfs:comment 'Explanation for any shortfall in catering delivery, used for supplier performance tracking and operational analysis.' ;
    rdfs:domain ind:CateringOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialMealChmlCount rdf:type rdf:Property ;
    rdfs:label 'Special Meal Chml Count' ;
    rdfs:comment 'Number of child special meals ordered, identified by IATA SSR code CHML.' ;
    rdfs:domain ind:CateringOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:specialMealDbmlCount rdf:type rdf:Property ;
    rdfs:label 'Special Meal Dbml Count' ;
    rdfs:comment 'Number of diabetic special meals ordered, identified by IATA SSR code DBML.' ;
    rdfs:domain ind:CateringOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:specialMealKsmlCount rdf:type rdf:Property ;
    rdfs:label 'Special Meal Ksml Count' ;
    rdfs:comment 'Number of kosher special meals ordered, identified by IATA SSR code KSML.' ;
    rdfs:domain ind:CateringOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:specialMealMomlCount rdf:type rdf:Property ;
    rdfs:label 'Special Meal Moml Count' ;
    rdfs:comment 'Number of Muslim/Halal special meals ordered, identified by IATA SSR code MOML.' ;
    rdfs:domain ind:CateringOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:specialMealOtherCount rdf:type rdf:Property ;
    rdfs:label 'Special Meal Other Count' ;
    rdfs:comment 'Number of other special meals ordered (AVML, GFML, LFML, NLML, etc.) not captured in specific categories.' ;
    rdfs:domain ind:CateringOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:specialMealVgmlCount rdf:type rdf:Property ;
    rdfs:label 'Special Meal Vgml Count' ;
    rdfs:comment 'Number of vegetarian special meals ordered, identified by IATA Special Service Request (SSR) code VGML.' ;
    rdfs:domain ind:CateringOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trolleyCount rdf:type rdf:Property ;
    rdfs:label 'Trolley Count' ;
    rdfs:comment 'Number of service trolleys required for this catering order, used for in-flight meal and beverage service.' ;
    rdfs:domain ind:CateringOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:varianceQuantity rdf:type rdf:Property ;
    rdfs:label 'Variance Quantity' ;
    rdfs:comment 'Difference between ordered meal count and actual delivered count. Positive indicates over-delivery, negative indicates short-delivery.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractPriceScheduleId rdf:type rdf:Property ;
    rdfs:label 'Contract Price Schedule Id' ;
    rdfs:comment 'Unique identifier for the contract price schedule record. Primary key.' ;
    rdfs:domain ind:ContractPriceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supersededByScheduleContractPriceScheduleId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Schedule Contract Price Schedule Id' ;
    rdfs:comment 'Reference to the newer contract price schedule record that replaces this one, enabling price history tracking and audit trails.' ;
    rdfs:domain ind:ContractPriceSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ContractPriceSchedule .

ind:baseUnitPrice rdf:type rdf:Property ;
    rdfs:label 'Base Unit Price' ;
    rdfs:comment 'The agreed unit price for the material or service at the base volume tier, before any volume discounts, escalations, or adjustments are applied.' ;
    rdfs:domain ind:ContractPriceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:escalationCapPercentage rdf:type rdf:Property ;
    rdfs:label 'Escalation Cap Percentage' ;
    rdfs:comment 'Maximum percentage by which the price can increase in a single escalation period, protecting the buyer from excessive price volatility. Expressed as a percentage (e.g., 10.00 for 10% cap).' ;
    rdfs:domain ind:ContractPriceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:escalationFrequency rdf:type rdf:Property ;
    rdfs:label 'Escalation Frequency' ;
    rdfs:comment 'The frequency at which price escalation adjustments are applied based on the selected index.' ;
    rdfs:domain ind:ContractPriceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incoterm rdf:type rdf:Property ;
    rdfs:label 'Incoterm' ;
    rdfs:comment 'International Commercial Terms (Incoterms) defining the delivery terms, risk transfer point, and cost responsibilities between buyer and seller for this price schedule line. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumOrderQuantity rdf:type rdf:Property ;
    rdfs:label 'Maximum Order Quantity' ;
    rdfs:comment 'The maximum quantity that can be ordered under this price schedule line in a single purchase order. Nullable if no maximum applies.' ;
    rdfs:domain ind:ContractPriceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceEscalationIndexType rdf:type rdf:Property ;
    rdfs:label 'Price Escalation Index Type' ;
    rdfs:comment 'The type of economic index used for automatic price escalation adjustments. CPI=Consumer Price Index, PPI=Producer Price Index, FUEL=fuel price index (critical for aviation), LABOR=labor cost index, CUSTOM=custom index, NONE=no escalation.' ;
    rdfs:domain ind:ContractPriceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceValidityEndDate rdf:type rdf:Property ;
    rdfs:label 'Price Validity End Date' ;
    rdfs:comment 'The date on which this price schedule line expires and is no longer valid for new purchase orders. Nullable for open-ended pricing agreements.' ;
    rdfs:domain ind:ContractPriceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:priceValidityStartDate rdf:type rdf:Property ;
    rdfs:label 'Price Validity Start Date' ;
    rdfs:comment 'The date from which this price schedule line becomes effective and can be used for purchase order pricing.' ;
    rdfs:domain ind:ContractPriceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduleLineNumber rdf:type rdf:Property ;
    rdfs:label 'Schedule Line Number' ;
    rdfs:comment 'Sequential line number within the contract price schedule, used for ordering and referencing specific pricing entries.' ;
    rdfs:domain ind:ContractPriceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceCode rdf:type rdf:Property ;
    rdfs:label 'Service Code' ;
    rdfs:comment 'Unique identifier for the service covered by this price schedule line (e.g., ground handling, catering, maintenance services). Mutually exclusive with material_number for service-based contracts.' ;
    rdfs:domain ind:ContractPriceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorPartNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Part Number' ;
    rdfs:comment 'The vendor\'s own part number or service code for this item, used for cross-referencing and order communication.' ;
    rdfs:domain ind:ContractPriceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeTier1Breakpoint rdf:type rdf:Property ;
    rdfs:label 'Volume Tier 1 Breakpoint' ;
    rdfs:comment 'The minimum quantity threshold for the first volume tier. Orders at or above this quantity qualify for tier 1 pricing.' ;
    rdfs:domain ind:ContractPriceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeTier1Price rdf:type rdf:Property ;
    rdfs:label 'Volume Tier 1 Price' ;
    rdfs:comment 'The unit price applicable when the order quantity meets or exceeds the volume tier 1 breakpoint.' ;
    rdfs:domain ind:ContractPriceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeTier2Breakpoint rdf:type rdf:Property ;
    rdfs:label 'Volume Tier 2 Breakpoint' ;
    rdfs:comment 'The minimum quantity threshold for the second volume tier. Orders at or above this quantity qualify for tier 2 pricing.' ;
    rdfs:domain ind:ContractPriceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeTier2Price rdf:type rdf:Property ;
    rdfs:label 'Volume Tier 2 Price' ;
    rdfs:comment 'The unit price applicable when the order quantity meets or exceeds the volume tier 2 breakpoint.' ;
    rdfs:domain ind:ContractPriceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeTier3Breakpoint rdf:type rdf:Property ;
    rdfs:label 'Volume Tier 3 Breakpoint' ;
    rdfs:comment 'The minimum quantity threshold for the third volume tier. Orders at or above this quantity qualify for tier 3 pricing.' ;
    rdfs:domain ind:ContractPriceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeTier3Price rdf:type rdf:Property ;
    rdfs:label 'Volume Tier 3 Price' ;
    rdfs:comment 'The unit price applicable when the order quantity meets or exceeds the volume tier 3 breakpoint.' ;
    rdfs:domain ind:ContractPriceSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ownerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Owner Employee Id' ;
    rdfs:comment 'Reference to the procurement or fuel management employee responsible for managing this contract.' ;
    rdfs:domain ind:FuelContract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryFuelApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Fuel Approved By Employee Id' ;
    rdfs:comment 'Reference to the senior manager or executive who approved this fuel contract.' ;
    rdfs:domain ind:FuelContract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:amendmentCount rdf:type rdf:Property ;
    rdfs:label 'Amendment Count' ;
    rdfs:comment 'Total number of amendments made to the original contract since inception.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:basePricePerLitre rdf:type rdf:Property ;
    rdfs:label 'Base Price Per Litre' ;
    rdfs:comment 'Base fuel price per litre in the contract currency, before uplift fees and adjustments. Confidential commercial term.' ;
    rdfs:domain ind:FuelContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carbonIntensityGco2PerMj rdf:type rdf:Property ;
    rdfs:label 'Carbon Intensity Gco2 Per Mj' ;
    rdfs:comment 'Carbon intensity of the fuel in grams of CO2 equivalent per megajoule of energy, used for sustainability reporting and CORSIA compliance.' ;
    rdfs:domain ind:FuelContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractType rdf:type rdf:Property ;
    rdfs:label 'Contract Type' ;
    rdfs:comment 'Classification of the fuel contract: spot (short-term market rate), term (fixed period agreement), hedged (price-protected), into-plane (full-service fueling agreement including delivery).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractedVolumeLitresPerMonth rdf:type rdf:Property ;
    rdfs:label 'Contracted Volume Litres Per Month' ;
    rdfs:comment 'Monthly fuel volume commitment in litres that the airline agrees to uplift under this contract.' ;
    rdfs:domain ind:FuelContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryMethod rdf:type rdf:Property ;
    rdfs:label 'Delivery Method' ;
    rdfs:comment 'Physical method of fuel delivery at the airport: hydrant (underground pipeline to aircraft stand), bowser (mobile fuel truck), pipeline (direct line), truck (tanker delivery).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forceMajeureClauseFlag rdf:type rdf:Property ;
    rdfs:label 'Force Majeure Clause Flag' ;
    rdfs:comment 'Indicates whether the contract includes a force majeure clause allowing suspension of obligations during extraordinary events.' ;
    rdfs:domain ind:FuelContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hedgeContractReference rdf:type rdf:Property ;
    rdfs:label 'Hedge Contract Reference' ;
    rdfs:comment 'Reference identifier to the associated financial hedging instrument used to mitigate fuel price risk for this physical supply contract. Links to finance.hedge_contract.' ;
    rdfs:domain ind:FuelContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAmendmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Amendment Date' ;
    rdfs:comment 'Date of the most recent amendment or modification to the contract terms.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:minimumOfftakeCommitmentLitres rdf:type rdf:Property ;
    rdfs:label 'Minimum Offtake Commitment Litres' ;
    rdfs:comment 'Minimum total fuel volume in litres that the airline must uplift over the contract period to avoid penalties.' ;
    rdfs:domain ind:FuelContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricingMechanism rdf:type rdf:Property ;
    rdfs:label 'Pricing Mechanism' ;
    rdfs:comment 'Method used to determine fuel price: PLATTS-indexed (linked to PLATTS commodity index), fixed (predetermined price), formula (calculated based on agreed parameters), market-linked (tied to spot market rates).' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualitySpecificationReference rdf:type rdf:Property ;
    rdfs:label 'Quality Specification Reference' ;
    rdfs:comment 'Reference to the fuel quality standard that the supplier must meet (e.g., DEF STAN 91-091, ASTM D1655, IATA Guidance Material).' ;
    rdfs:domain ind:FuelContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityCertification rdf:type rdf:Property ;
    rdfs:label 'Sustainability Certification' ;
    rdfs:comment 'Certification standard for sustainable aviation fuel (SAF) if applicable, such as CORSIA-eligible, RSB (Roundtable on Sustainable Biomaterials), or ISCC (International Sustainability and Carbon Certification).' ;
    rdfs:domain ind:FuelContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upliftFeeCentsPerLitre rdf:type rdf:Property ;
    rdfs:label 'Uplift Fee Cents Per Litre' ;
    rdfs:comment 'Additional fee charged per litre for into-plane fueling service, expressed in cents. Confidential commercial term.' ;
    rdfs:domain ind:FuelContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeTolerancePercentage rdf:type rdf:Property ;
    rdfs:label 'Volume Tolerance Percentage' ;
    rdfs:comment 'Allowable percentage variance (plus or minus) from contracted monthly volume without penalty.' ;
    rdfs:domain ind:FuelContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualUpliftQuantity rdf:type rdf:Property ;
    rdfs:label 'Actual Uplift Quantity' ;
    rdfs:comment 'Actual quantity of fuel delivered and uplifted into the aircraft, measured in the unit specified by actual_uplift_quantity_unit.' ;
    rdfs:domain ind:FuelUpliftOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualUpliftQuantityUnit rdf:type rdf:Property ;
    rdfs:label 'Actual Uplift Quantity Unit' ;
    rdfs:comment 'Unit of measure for the actual uplifted fuel quantity (litres, kilograms, gallons, pounds).' ;
    rdfs:domain ind:FuelUpliftOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelReceiptDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Fuel Receipt Document Number' ;
    rdfs:comment 'Document number or reference from the fuel receipt provided by the into-plane agent, used for reconciliation.' ;
    rdfs:domain ind:FuelUpliftOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelingAgentName rdf:type rdf:Property ;
    rdfs:label 'Fueling Agent Name' ;
    rdfs:comment 'Name of the individual fueling agent or technician who performed the fuel uplift operation.' ;
    rdfs:domain ind:FuelUpliftOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelingEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Fueling End Timestamp' ;
    rdfs:comment 'Date and time when the fuel uplift operation was completed, in ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX).' ;
    rdfs:domain ind:FuelUpliftOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:orderPlacedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Order Placed Timestamp' ;
    rdfs:comment 'Date and time when the fuel uplift order was originally placed, in ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX). Represents the principal business event timestamp for this transaction.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:orderedQuantity rdf:type rdf:Property ;
    rdfs:label 'Ordered Quantity' ;
    rdfs:comment 'Quantity of fuel ordered for uplift, measured in the unit specified by ordered_quantity_unit.' ;
    rdfs:domain ind:FuelUpliftOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderedQuantityUnit rdf:type rdf:Property ;
    rdfs:label 'Ordered Quantity Unit' ;
    rdfs:comment 'Unit of measure for the ordered fuel quantity (litres, kilograms, gallons, pounds).' ;
    rdfs:domain ind:FuelUpliftOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualityCheckPassed rdf:type rdf:Property ;
    rdfs:label 'Quality Check Passed' ;
    rdfs:comment 'Indicates whether the fuel quality inspection passed all required standards (True) or failed (False).' ;
    rdfs:domain ind:FuelUpliftOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityCheckTimestamp rdf:type rdf:Property ;
    rdfs:label 'Quality Check Timestamp' ;
    rdfs:comment 'Date and time when the fuel quality check was performed, in ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX).' ;
    rdfs:domain ind:FuelUpliftOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:upliftOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Uplift Order Number' ;
    rdfs:comment 'Business-facing unique order number for this fuel uplift transaction, used for tracking and reconciliation.' ;
    rdfs:domain ind:FuelUpliftOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upliftStatus rdf:type rdf:Property ;
    rdfs:label 'Uplift Status' ;
    rdfs:comment 'Current lifecycle status of the fuel uplift order (ordered, in-progress, completed, disputed, cancelled).' ;
    rdfs:domain ind:FuelUpliftOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poLineId rdf:type rdf:Property ;
    rdfs:label 'Po Line Id' ;
    rdfs:comment 'Foreign key linking to procurement.po_line. Business justification: Goods receipts are against specific PO line items, not just the header. Currently uses po_line_item_number (INT) which is a line sequence number within the PO, not a FK. Adding po_line_id FK enables d' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PoLine .

ind:receivedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Received By Employee Id' ;
    rdfs:comment 'Identifier of the warehouse or receiving clerk who physically accepted and recorded the goods receipt. Provides accountability.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:certificateOfConformanceNumber rdf:type rdf:Property ;
    rdfs:label 'Certificate Of Conformance Number' ;
    rdfs:comment 'Vendor-issued certificate number confirming that parts meet specified requirements. Required for quality assurance and regulatory compliance.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionOnReceipt rdf:type rdf:Property ;
    rdfs:label 'Condition On Receipt' ;
    rdfs:comment 'Physical and functional condition of goods upon receipt. Determines whether parts can be immediately used or require inspection, repair, or disposal.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryNoteDate rdf:type rdf:Property ;
    rdfs:label 'Delivery Note Date' ;
    rdfs:comment 'Date on the vendor delivery note or packing slip. Used for lead time calculation and delivery performance analysis.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:grDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Gr Document Number' ;
    rdfs:comment 'Externally-known business identifier for the goods receipt document. Used for cross-system reference and audit trails.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grStatus rdf:type rdf:Property ;
    rdfs:label 'Gr Status' ;
    rdfs:comment 'Current lifecycle status of the goods receipt document. Tracks progression from initial posting through inspection to final completion or reversal.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Inspection Required Flag' ;
    rdfs:comment 'Indicates whether the received goods require quality inspection before being released to stock. True triggers inspection workflow.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:movementType rdf:type rdf:Property ;
    rdfs:label 'Movement Type' ;
    rdfs:comment 'SAP movement type code indicating the type of inventory transaction. Standard codes include 101 for GR against PO, 122 for return delivery.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:note rdf:type rdf:Property ;
    rdfs:label 'Note' ;
    rdfs:comment 'Free-text notes or comments recorded by the receiving clerk. Captures discrepancies, damage observations, or special handling instructions.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poLineItemNumber rdf:type rdf:Property ;
    rdfs:label 'Po Line Item Number' ;
    rdfs:comment 'Line item number within the purchase order for which goods are being received. Enables line-level matching for three-way verification.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quarantineFlag rdf:type rdf:Property ;
    rdfs:label 'Quarantine Flag' ;
    rdfs:comment 'Indicates whether goods are placed in quarantine status pending inspection or resolution of quality issues. Blocks inventory usage.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receivedQuantity rdf:type rdf:Property ;
    rdfs:label 'Received Quantity' ;
    rdfs:comment 'Actual quantity of goods received and accepted. Used for inventory update and variance analysis against PO quantity.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:receivingDate rdf:type rdf:Property ;
    rdfs:label 'Receiving Date' ;
    rdfs:comment 'Calendar date when goods were physically received at the station. Used for lead time analysis and supplier performance metrics.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:receivingStationCode rdf:type rdf:Property ;
    rdfs:label 'Receiving Station Code' ;
    rdfs:comment 'Three-letter IATA airport code or MRO base code where goods were physically received. Critical for inventory location tracking.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Receiving Timestamp' ;
    rdfs:comment 'Precise date and time when goods receipt was recorded in the system. Business event timestamp for the GR transaction.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:shelfLifeExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Expiration Date' ;
    rdfs:comment 'Date after which time-sensitive materials such as chemicals, sealants, or perishables are no longer usable. Triggers inventory aging alerts.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:storageLocationCode rdf:type rdf:Property ;
    rdfs:label 'Storage Location Code' ;
    rdfs:comment 'Specific warehouse or storage location code within the receiving station where goods are placed. Enables bin-level inventory tracking.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valuationAmount rdf:type rdf:Property ;
    rdfs:label 'Valuation Amount' ;
    rdfs:comment 'Total monetary value of the goods received in the transaction currency. Used for inventory valuation and financial posting.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorDeliveryNoteNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Delivery Note Number' ;
    rdfs:comment 'External delivery note or packing slip number provided by the vendor. Used for reconciliation and proof of delivery.' ;
    rdfs:domain ind:GoodsReceipt ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groundServiceOrderId rdf:type rdf:Property ;
    rdfs:label 'Ground Service Order Id' ;
    rdfs:comment 'Unique identifier for the ground service order. Primary key for this procurement-layer commercial service order record.' ;
    rdfs:domain ind:GroundServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualServiceEndTime rdf:type rdf:Property ;
    rdfs:label 'Actual Service End Time' ;
    rdfs:comment 'Actual timestamp when the ground service provider completed or terminated service delivery.' ;
    rdfs:domain ind:GroundServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualServiceStartTime rdf:type rdf:Property ;
    rdfs:label 'Actual Service Start Time' ;
    rdfs:comment 'Actual timestamp when the ground service provider commenced service delivery on the aircraft or at the gate.' ;
    rdfs:domain ind:GroundServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:contractedServiceLevel rdf:type rdf:Property ;
    rdfs:label 'Contracted Service Level' ;
    rdfs:comment 'Service level agreement tier contracted for this order, defining performance standards and response times.' ;
    rdfs:domain ind:GroundServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flightLegReference rdf:type rdf:Property ;
    rdfs:label 'Flight Leg Reference' ;
    rdfs:comment 'Reference to the specific flight leg (flight number and date) for which ground services are ordered. Format: carrier code + flight number + dash + date (YYYYMMDD).' ;
    rdfs:domain ind:GroundServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceReference rdf:type rdf:Property ;
    rdfs:label 'Invoice Reference' ;
    rdfs:comment 'Reference to the vendor invoice document associated with this ground service order for payment reconciliation.' ;
    rdfs:domain ind:GroundServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderValueAmount rdf:type rdf:Property ;
    rdfs:label 'Order Value Amount' ;
    rdfs:comment 'Total contracted value of this ground service order before adjustments, taxes, or penalties.' ;
    rdfs:domain ind:GroundServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduledServiceStartTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Service Start Time' ;
    rdfs:comment 'Contracted or planned start time for ground service delivery, typically aligned with aircraft arrival or turnaround schedule.' ;
    rdfs:domain ind:GroundServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:serviceCompletionStatus rdf:type rdf:Property ;
    rdfs:label 'Service Completion Status' ;
    rdfs:comment 'Operational completion status indicating whether the ground service provider successfully delivered the ordered services.' ;
    rdfs:domain ind:GroundServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Service Duration Minutes' ;
    rdfs:comment 'Total elapsed time in minutes from actual service start to actual service end.' ;
    rdfs:domain ind:GroundServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceQualityScore rdf:type rdf:Property ;
    rdfs:label 'Service Quality Score' ;
    rdfs:comment 'Quantitative quality rating (0.00 to 100.00) assigned to the vendor\'s service delivery performance for this order, based on timeliness, completeness, and adherence to standards.' ;
    rdfs:domain ind:GroundServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceScopeDescription rdf:type rdf:Property ;
    rdfs:label 'Service Scope Description' ;
    rdfs:comment 'Detailed textual description of the specific services included in this order, including any special requirements or non-standard tasks.' ;
    rdfs:domain ind:GroundServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:turnaroundReference rdf:type rdf:Property ;
    rdfs:label 'Turnaround Reference' ;
    rdfs:comment 'Reference to the operational aircraft turnaround event that this procurement service order supports.' ;
    rdfs:domain ind:GroundServiceOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mroExchangeOrderId rdf:type rdf:Property ;
    rdfs:label 'Mro Exchange Order Id' ;
    rdfs:comment 'Unique identifier for the MRO component exchange or loan transaction record.' ;
    rdfs:domain ind:MroExchangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryMroRequestedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Mro Requested By Employee Id' ;
    rdfs:comment 'Identifier of the maintenance engineer or planner who initiated this exchange order request.' ;
    rdfs:domain ind:MroExchangeOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:airworthinessReleaseDocument rdf:type rdf:Property ;
    rdfs:label 'Airworthiness Release Document' ;
    rdfs:comment 'Reference number of the EASA Form 1 / FAA Form 8130-3 or equivalent airworthiness release certificate accompanying the incoming serviceable component.' ;
    rdfs:domain ind:MroExchangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatchDate rdf:type rdf:Property ;
    rdfs:label 'Dispatch Date' ;
    rdfs:comment 'Date when the outgoing component was physically dispatched to the vendor or repair station.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exchangeFee rdf:type rdf:Property ;
    rdfs:label 'Exchange Fee' ;
    rdfs:comment 'Fixed fee charged by the vendor or pool operator for the component exchange transaction, excluding loan or rental charges.' ;
    rdfs:domain ind:MroExchangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exchangeOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Exchange Order Number' ;
    rdfs:comment 'Externally-known unique business identifier for this MRO exchange or loan transaction, used for vendor communication and tracking.' ;
    rdfs:domain ind:MroExchangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedReturnDate rdf:type rdf:Property ;
    rdfs:label 'Expected Return Date' ;
    rdfs:comment 'Contractually agreed or estimated date by which the replacement serviceable component is expected to be received.' ;
    rdfs:domain ind:MroExchangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:incomingCondition rdf:type rdf:Property ;
    rdfs:label 'Incoming Condition' ;
    rdfs:comment 'Airworthiness condition classification of the replacement component received: serviceable, overhauled, repaired, or as-new.' ;
    rdfs:domain ind:MroExchangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incomingSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Incoming Serial Number' ;
    rdfs:comment 'Unique serial number of the serviceable replacement component received from the vendor or component pool.' ;
    rdfs:domain ind:MroExchangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loanFeePerDay rdf:type rdf:Property ;
    rdfs:label 'Loan Fee Per Day' ;
    rdfs:comment 'Daily rental or loan fee charged for the temporary use of the replacement component from the pool, applicable for loan-type orders.' ;
    rdfs:domain ind:MroExchangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumLoanPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Maximum Loan Period Days' ;
    rdfs:comment 'Maximum number of days the component can be on loan before mandatory return or conversion to outright purchase, per pool agreement terms.' ;
    rdfs:domain ind:MroExchangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:outgoingCondition rdf:type rdf:Property ;
    rdfs:label 'Outgoing Condition' ;
    rdfs:comment 'Airworthiness condition classification of the component being sent out: serviceable, unserviceable, repairable, beyond-economic-repair, or time-expired.' ;
    rdfs:domain ind:MroExchangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outgoingSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Outgoing Serial Number' ;
    rdfs:comment 'Unique serial number of the unserviceable or time-expired component being sent out to the vendor for exchange or repair.' ;
    rdfs:domain ind:MroExchangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shippingMethod rdf:type rdf:Property ;
    rdfs:label 'Shipping Method' ;
    rdfs:comment 'Transportation method used for dispatching and receiving components: air-freight, ground, courier, or hand-carry (for AOG situations).' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalLoanCharges rdf:type rdf:Property ;
    rdfs:label 'Total Loan Charges' ;
    rdfs:comment 'Cumulative loan fees accrued based on the actual loan duration and daily rate, calculated at order closure.' ;
    rdfs:domain ind:MroExchangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trackingNumber rdf:type rdf:Property ;
    rdfs:label 'Tracking Number' ;
    rdfs:comment 'Carrier tracking number for the outgoing or incoming component shipment, enabling real-time logistics visibility.' ;
    rdfs:domain ind:MroExchangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Reference Number' ;
    rdfs:comment 'Vendor\'s internal reference or tracking number for this exchange transaction, used for reconciliation and dispute resolution.' ;
    rdfs:domain ind:MroExchangeOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workOrderReference rdf:type rdf:Property ;
    rdfs:label 'Work Order Reference' ;
    rdfs:comment 'Reference to the maintenance work order or Aircraft on Ground (AOG) event that triggered this component exchange requirement.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByPartMasterId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Part Master Id' ;
    rdfs:comment 'Identifier of the replacement part that supersedes this part when it becomes obsolete or phased out. Null if no superseding part exists.' ;
    rdfs:domain ind:PartMaster ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PartMaster .

ind:technicalOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Technical Owner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Airlines assign engineering employees as technical owners for part master records. Owner maintains airworthiness data, approves substitutions, manages obsolescence, and coordinates with OEMs. Essentia' ;
    rdfs:domain ind:PartMaster ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:airlineMaterialNumber rdf:type rdf:Property ;
    rdfs:label 'Airline Material Number' ;
    rdfs:comment 'Internal material number assigned by the airline for inventory and procurement management. Used across ERP and MRO systems.' ;
    rdfs:domain ind:PartMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:airworthinessApprovalReference rdf:type rdf:Property ;
    rdfs:label 'Airworthiness Approval Reference' ;
    rdfs:comment 'Reference to the airworthiness certification or approval for this part, such as FAA Parts Manufacturer Approval (PMA) number, EASA ETSO authorization, or OEM type certificate reference.' ;
    rdfs:domain ind:PartMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ataSectionCode rdf:type rdf:Property ;
    rdfs:label 'Ata Section Code' ;
    rdfs:comment 'Four-digit ATA section code providing granular classification within the ATA chapter (e.g., 32-41 for Wheels and Brakes).' ;
    rdfs:domain ind:PartMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:easaEtsoFlag rdf:type rdf:Property ;
    rdfs:label 'Easa Etso Flag' ;
    rdfs:comment 'Indicates whether this part holds EASA European Technical Standard Order authorization, required for installation on EASA-certified aircraft.' ;
    rdfs:domain ind:PartMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:easaPartClassification rdf:type rdf:Property ;
    rdfs:label 'Easa Part Classification' ;
    rdfs:comment 'EASA classification code for the part, required for compliance with European aviation regulations and Part-21 certification.' ;
    rdfs:domain ind:PartMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:faaPmaFlag rdf:type rdf:Property ;
    rdfs:label 'Faa Pma Flag' ;
    rdfs:comment 'Indicates whether this part holds FAA Parts Manufacturer Approval, allowing it to be used as a replacement part on FAA-certified aircraft.' ;
    rdfs:domain ind:PartMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazmatClassification rdf:type rdf:Property ;
    rdfs:label 'Hazmat Classification' ;
    rdfs:comment 'IATA Dangerous Goods Regulation (DGR) class if the part is classified as hazardous material (e.g., Class 3 Flammable Liquids, Class 9 Miscellaneous). Empty if non-hazardous.' ;
    rdfs:domain ind:PartMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icaoPartClassification rdf:type rdf:Property ;
    rdfs:label 'Icao Part Classification' ;
    rdfs:comment 'ICAO classification code for the part type, used for international regulatory compliance and customs documentation.' ;
    rdfs:domain ind:PartMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interchangeablePartGroup rdf:type rdf:Property ;
    rdfs:label 'Interchangeable Part Group' ;
    rdfs:comment 'Identifier for a group of parts that are functionally interchangeable and can substitute for one another in maintenance and inventory management.' ;
    rdfs:domain ind:PartMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastPurchaseDate rdf:type rdf:Property ;
    rdfs:label 'Last Purchase Date' ;
    rdfs:comment 'Date of the most recent purchase order issued for this part, used to track procurement activity and identify slow-moving inventory.' ;
    rdfs:domain ind:PartMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastPurchasePriceAmount rdf:type rdf:Property ;
    rdfs:label 'Last Purchase Price Amount' ;
    rdfs:comment 'Most recent actual purchase price paid per unit of measure for this part, used for cost trending and procurement analytics.' ;
    rdfs:domain ind:PartMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastPurchasePriceCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Last Purchase Price Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the last purchase price amount.' ;
    rdfs:domain ind:PartMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturerCageCode rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Cage Code' ;
    rdfs:comment 'Five-character CAGE code assigned by NATO or US Defense Logistics Agency to identify the manufacturer. Used for traceability and airworthiness compliance.' ;
    rdfs:domain ind:PartMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturerPartNumber rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Part Number' ;
    rdfs:comment 'The original equipment manufacturer (OEM) part number as assigned by the manufacturer. This is the authoritative external identifier for the part.' ;
    rdfs:domain ind:PartMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:obsolescenceDate rdf:type rdf:Property ;
    rdfs:label 'Obsolescence Date' ;
    rdfs:comment 'Date on which the part was marked as obsolete or phased out. Null for active parts.' ;
    rdfs:domain ind:PartMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:partMasterStatus rdf:type rdf:Property ;
    rdfs:label 'Part Master Status' ;
    rdfs:comment 'Current lifecycle status of the part master record: active (available for procurement and use), obsolete (no longer procured or used), phased_out (being replaced), restricted (use limited by policy or regulation), pending_approval (awaiting engineering or quality approval).' ;
    rdfs:domain ind:PartMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partType rdf:type rdf:Property ;
    rdfs:label 'Part Type' ;
    rdfs:comment 'Classification of the part based on its lifecycle and repairability: rotable (repairable high-value component tracked by serial number), repairable (can be repaired but lower value), expendable (discarded after use), consumable (used up in operations), raw material (bulk material).' ;
    rdfs:domain ind:PartMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serializedTrackingFlag rdf:type rdf:Property ;
    rdfs:label 'Serialized Tracking Flag' ;
    rdfs:comment 'Indicates whether this part requires individual serial number tracking for traceability, maintenance history, and airworthiness compliance. Typically true for rotable and high-value repairable parts.' ;
    rdfs:domain ind:PartMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shelfLifeDays rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Days' ;
    rdfs:comment 'Maximum number of days the part can be stored before it must be used, inspected, or discarded. Null for parts with indefinite shelf life.' ;
    rdfs:domain ind:PartMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:standardCostAmount rdf:type rdf:Property ;
    rdfs:label 'Standard Cost Amount' ;
    rdfs:comment 'Standard cost per unit of measure for this part as maintained in the ERP system for inventory valuation and cost accounting purposes.' ;
    rdfs:domain ind:PartMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardCostCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Standard Cost Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the standard cost amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:PartMaster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partsInventoryId rdf:type rdf:Property ;
    rdfs:label 'Parts Inventory Id' ;
    rdfs:comment 'Unique identifier for the parts inventory record. Primary key for this entity.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:abcClassification rdf:type rdf:Property ;
    rdfs:label 'Abc Classification' ;
    rdfs:comment 'Inventory classification based on value and criticality. A items are high-value or critical parts requiring tight control, B items are moderate importance, C items are low-value or non-critical parts.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageWeightedCost rdf:type rdf:Property ;
    rdfs:label 'Average Weighted Cost' ;
    rdfs:comment 'Average unit cost of the part calculated using weighted average costing method, used for inventory valuation and financial reporting.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bondedStoreFlag rdf:type rdf:Property ;
    rdfs:label 'Bonded Store Flag' ;
    rdfs:comment 'Indicates whether the inventory is held in a customs bonded warehouse, allowing duty-free storage until parts are released for domestic use or re-exported.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:criticalityCode rdf:type rdf:Property ;
    rdfs:label 'Criticality Code' ;
    rdfs:comment 'Operational criticality classification indicating the impact of part unavailability. AOG (Aircraft on Ground) critical parts cause immediate aircraft grounding, flight critical parts affect safety, standard parts support routine maintenance, non-critical parts have minimal operational impact.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Flag' ;
    rdfs:comment 'Indicates whether the part is classified as hazardous material requiring special handling, storage, and transportation procedures per IATA Dangerous Goods Regulations.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastIssueDate rdf:type rdf:Property ;
    rdfs:label 'Last Issue Date' ;
    rdfs:comment 'Date when the part was last issued from inventory to a maintenance work order or other consumption activity.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastMovementDate rdf:type rdf:Property ;
    rdfs:label 'Last Movement Date' ;
    rdfs:comment 'Date of the most recent inventory transaction for this part, including receipts, issues, transfers, or adjustments.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastPhysicalCountDate rdf:type rdf:Property ;
    rdfs:label 'Last Physical Count Date' ;
    rdfs:comment 'Date when the last physical inventory count or cycle count was performed for this part at this location to verify system accuracy.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastPurchaseOrderDate rdf:type rdf:Property ;
    rdfs:label 'Last Purchase Order Date' ;
    rdfs:comment 'Date when the most recent purchase order was placed for this part, used for procurement pattern analysis.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:materialNumber rdf:type rdf:Property ;
    rdfs:label 'Material Number' ;
    rdfs:comment 'Unique material identifier assigned by the enterprise resource planning system. Standard part number used across procurement, maintenance, and inventory systems.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumStockLevel rdf:type rdf:Property ;
    rdfs:label 'Maximum Stock Level' ;
    rdfs:comment 'Maximum inventory quantity that should be maintained for this part at this location to avoid overstocking and excess carrying costs.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partCondition rdf:type rdf:Property ;
    rdfs:label 'Part Condition' ;
    rdfs:comment 'Airworthiness condition status of the part. Serviceable parts are certified for installation, unserviceable parts require maintenance, repairable parts can be restored, beyond repair parts must be scrapped, and quarantine parts are under investigation.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityOnHand rdf:type rdf:Property ;
    rdfs:label 'Quantity On Hand' ;
    rdfs:comment 'Current physical quantity of the part available in the storage location, measured in the base unit of measure.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityOnOrder rdf:type rdf:Property ;
    rdfs:label 'Quantity On Order' ;
    rdfs:comment 'Quantity of the part that has been ordered from vendors through purchase orders but not yet received into inventory.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityReserved rdf:type rdf:Property ;
    rdfs:label 'Quantity Reserved' ;
    rdfs:comment 'Quantity of the part that has been reserved or allocated for specific maintenance work orders, Aircraft on Ground (AOG) situations, or scheduled maintenance but not yet physically issued.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reorderPoint rdf:type rdf:Property ;
    rdfs:label 'Reorder Point' ;
    rdfs:comment 'Minimum inventory level threshold that triggers automatic procurement replenishment action. When quantity on hand falls below this level, a purchase requisition should be generated.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyStockLevel rdf:type rdf:Property ;
    rdfs:label 'Safety Stock Level' ;
    rdfs:comment 'Buffer inventory quantity maintained to protect against demand variability and supply chain disruptions, particularly critical for AOG (Aircraft on Ground) prevention.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stationIataCode rdf:type rdf:Property ;
    rdfs:label 'Station Iata Code' ;
    rdfs:comment 'Three-letter IATA airport code identifying the station or airport where the inventory is located.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockStatus rdf:type rdf:Property ;
    rdfs:label 'Stock Status' ;
    rdfs:comment 'Lifecycle status of the inventory item. Active items are currently stocked, inactive items are temporarily not replenished, obsolete items are no longer used, phase-out items are being replaced by newer parts.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stockType rdf:type rdf:Property ;
    rdfs:label 'Stock Type' ;
    rdfs:comment 'Classification of the inventory stock status indicating availability and usage restrictions. Unrestricted stock is available for use, quality inspection stock is under review, blocked stock cannot be used, consignment stock is vendor-owned, in-transit stock is being moved, and reserved stock is allocated to specific work orders.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalStockValue rdf:type rdf:Property ;
    rdfs:label 'Total Stock Value' ;
    rdfs:comment 'Total monetary value of the inventory on hand, calculated as quantity on hand multiplied by average weighted cost.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warehouseZone rdf:type rdf:Property ;
    rdfs:label 'Warehouse Zone' ;
    rdfs:comment 'Physical zone or area within the warehouse facility where the part is stored, used for optimizing picking and storage operations.' ;
    rdfs:domain ind:PartsInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialPartMasterId rdf:type rdf:Property ;
    rdfs:label 'Material Part Master Id' ;
    rdfs:comment 'Foreign key reference to the material master record. Identifies the specific part, component, consumable, or service being procured on this line.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PartMaster .

ind:deletionIndicator rdf:type rdf:Property ;
    rdfs:label 'Deletion Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this purchase order line has been marked for deletion or cancellation. Soft-delete mechanism to preserve audit trail while removing line from active processing.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:deliveryTolerancePercent rdf:type rdf:Property ;
    rdfs:label 'Delivery Tolerance Percent' ;
    rdfs:comment 'The acceptable over-delivery or under-delivery tolerance as a percentage of the ordered quantity. Allows for minor quantity variances without requiring PO amendments.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:finalInvoiceFlag rdf:type rdf:Property ;
    rdfs:label 'Final Invoice Flag' ;
    rdfs:comment 'Boolean indicator that the final invoice has been received and processed for this line, and no further invoices are expected. Signals readiness for line closure.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:goodsReceiptRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Required Flag' ;
    rdfs:comment 'Boolean indicator of whether a goods receipt transaction is required before invoice processing for this line. Enforces three-way matching for physical materials.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:invoiceReceiptRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Invoice Receipt Required Flag' ;
    rdfs:comment 'Boolean indicator of whether invoice verification is required for this line. Controls whether the line participates in invoice matching and payment processing.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineStatus rdf:type rdf:Property ;
    rdfs:label 'Line Status' ;
    rdfs:comment 'Current lifecycle status of the purchase order line. Tracks progression from open through delivery to closure or cancellation.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:longText rdf:type rdf:Property ;
    rdfs:label 'Long Text' ;
    rdfs:comment 'Detailed description of the material or service, including specifications, technical requirements, or special instructions for this procurement line.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netPrice rdf:type rdf:Property ;
    rdfs:label 'Net Price' ;
    rdfs:comment 'The total net value of this line item before taxes and surcharges. Calculated as quantity_ordered multiplied by unit_price, adjusted for any line-level discounts.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:openQuantity rdf:type rdf:Property ;
    rdfs:label 'Open Quantity' ;
    rdfs:comment 'The remaining quantity still to be delivered on this purchase order line. Calculated as quantity_ordered minus quantity_received. Indicates outstanding procurement commitment.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plantCode rdf:type rdf:Property ;
    rdfs:label 'Plant Code' ;
    rdfs:comment 'The plant or facility code where the material will be received or the service will be performed. In aviation context, may represent maintenance base, hub station, or warehouse location.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityInvoiced rdf:type rdf:Property ;
    rdfs:label 'Quantity Invoiced' ;
    rdfs:comment 'The cumulative quantity that has been invoiced by the vendor against this purchase order line. Used for three-way matching and invoice verification.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityOrdered rdf:type rdf:Property ;
    rdfs:label 'Quantity Ordered' ;
    rdfs:comment 'The quantity of material or service units ordered on this purchase order line. Expressed in the unit of measure specified for this line.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityReceived rdf:type rdf:Property ;
    rdfs:label 'Quantity Received' ;
    rdfs:comment 'The cumulative quantity of material that has been received against this purchase order line through goods receipt transactions. Used for three-way matching (PO vs GR vs invoice).' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shortText rdf:type rdf:Property ;
    rdfs:label 'Short Text' ;
    rdfs:comment 'Brief description of the material or service being procured on this line. Provides human-readable context for the line item.' ;
    rdfs:domain ind:PoLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualSpendEstimate rdf:type rdf:Property ;
    rdfs:label 'Annual Spend Estimate' ;
    rdfs:comment 'Estimated total annual spend (in base currency) for this category. Used for category prioritization and strategic sourcing planning.' ;
    rdfs:domain ind:ProcurementCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvalAuthorityLevel rdf:type rdf:Property ;
    rdfs:label 'Approval Authority Level' ;
    rdfs:comment 'Minimum organizational level required to approve purchases in this category based on spend thresholds and strategic importance.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceRequirements rdf:type rdf:Property ;
    rdfs:label 'Compliance Requirements' ;
    rdfs:comment 'Summary of regulatory, safety, or quality compliance requirements applicable to this category (e.g., EASA Part 145 for MRO parts, FAA certification for avionics, ISO 9001 for catering).' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractRenewalCycleMonths rdf:type rdf:Property ;
    rdfs:label 'Contract Renewal Cycle Months' ;
    rdfs:comment 'Typical contract renewal cycle in months for this category. Used for proactive sourcing planning and contract lifecycle management.' ;
    rdfs:domain ind:ProcurementCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:costCenterDefault rdf:type rdf:Property ;
    rdfs:label 'Cost Center Default' ;
    rdfs:comment 'Default cost center code for financial postings related to this category. Can be overridden at transaction level.' ;
    rdfs:domain ind:ProcurementCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccountDefault rdf:type rdf:Property ;
    rdfs:label 'Gl Account Default' ;
    rdfs:comment 'Default general ledger account code for expenses in this category. Supports automated financial posting and spend analytics.' ;
    rdfs:domain ind:ProcurementCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumOrderValue rdf:type rdf:Property ;
    rdfs:label 'Minimum Order Value' ;
    rdfs:comment 'Minimum order value (in base currency) required for purchases in this category. Used to enforce procurement efficiency and reduce transaction costs.' ;
    rdfs:domain ind:ProcurementCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preferredVendorCount rdf:type rdf:Property ;
    rdfs:label 'Preferred Vendor Count' ;
    rdfs:comment 'Target number of preferred or approved vendors for this category. Supports supplier rationalization and risk management.' ;
    rdfs:domain ind:ProcurementCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourcingStrategy rdf:type rdf:Property ;
    rdfs:label 'Sourcing Strategy' ;
    rdfs:comment 'Preferred sourcing approach for this category: single_source (one supplier), dual_source (two suppliers for redundancy), competitive_tender (RFx process), catalogue (pre-negotiated catalog), framework_agreement (call-off contract), spot_buy (ad-hoc purchase).' ;
    rdfs:domain ind:ProcurementCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strategicImportance rdf:type rdf:Property ;
    rdfs:label 'Strategic Importance' ;
    rdfs:comment 'Kraljic matrix classification indicating the strategic importance and supply risk of the category: strategic (high impact, high risk), leverage (high impact, low risk), bottleneck (low impact, high risk), non-critical (low impact, low risk).' ;
    rdfs:domain ind:ProcurementCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Sustainability Flag' ;
    rdfs:comment 'Indicates whether this category has specific sustainability or environmental sourcing requirements (e.g., sustainable aviation fuel, carbon offset programs, eco-friendly catering supplies).' ;
    rdfs:domain ind:ProcurementCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unspscCode rdf:type rdf:Property ;
    rdfs:label 'Unspsc Code' ;
    rdfs:comment 'Eight-digit UNSPSC classification code aligning the category to global commodity taxonomy for cross-industry benchmarking and reporting.' ;
    rdfs:domain ind:ProcurementCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPurchaseEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Purchase Employee Id' ;
    rdfs:comment 'Reference to the procurement buyer or purchasing agent responsible for creating and managing this purchase order.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:sourcingEventId rdf:type rdf:Property ;
    rdfs:label 'Sourcing Event Id' ;
    rdfs:comment 'Foreign key linking to procurement.sourcing_event. Business justification: Purchase orders often result from sourcing events (RFQ/RFP). Currently uses sourcing_event_reference (STRING) which is a denormalized business reference. Adding sourcing_event_id FK normalizes this re' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SourcingEvent .

ind:approvalWorkflowStatus rdf:type rdf:Property ;
    rdfs:label 'Approval Workflow Status' ;
    rdfs:comment 'Current status of the purchase order in the approval workflow. Tracks progression through multi-level approval hierarchy based on purchase order value and authority limits.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Confirmed Delivery Date' ;
    rdfs:comment 'The delivery date confirmed by the vendor in their purchase order acknowledgment. May differ from requested date based on vendor lead times and capacity.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deliveryAddress rdf:type rdf:Property ;
    rdfs:label 'Delivery Address' ;
    rdfs:comment 'Full physical address where the goods or services are to be delivered. Includes street address, city, postal code, and country. Organizational contact data classified as confidential.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryAddressType rdf:type rdf:Property ;
    rdfs:label 'Delivery Address Type' ;
    rdfs:comment 'Classification of the delivery location type. Station for airport locations, base for crew/operational bases, maintenance facility for MRO hangars, warehouse for central stores, headquarters for corporate offices, vendor managed for consignment inventory.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryStationCode rdf:type rdf:Property ;
    rdfs:label 'Delivery Station Code' ;
    rdfs:comment 'Three-letter IATA airport or station code where goods or services are to be delivered. Used for logistics planning and inventory allocation.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poDate rdf:type rdf:Property ;
    rdfs:label 'Po Date' ;
    rdfs:comment 'The date when the purchase order was officially created and issued. This is the principal business event timestamp for the transaction.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:poNumber rdf:type rdf:Property ;
    rdfs:label 'Po Number' ;
    rdfs:comment 'Externally-known business identifier for the purchase order, used across procurement systems and vendor communications. Typically follows airline-specific numbering convention.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poStatus rdf:type rdf:Property ;
    rdfs:label 'Po Status' ;
    rdfs:comment 'Current lifecycle status of the purchase order. Tracks the order from creation through approval, transmission to vendor, receipt of goods/services, and final closure or cancellation. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|sent|acknowledged|partially_received|fully_received|closed|cancelled — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poType rdf:type rdf:Property ;
    rdfs:label 'Po Type' ;
    rdfs:comment 'Classification of the purchase order type. Standard for one-time purchases, blanket for recurring purchases against a contract, framework for multi-release agreements, emergency AOG (Aircraft on Ground) for urgent aircraft parts, contract release for call-offs from master agreements, spot for ad-hoc market purchases.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Requested Delivery Date' ;
    rdfs:comment 'The date by which the airline requests delivery of the goods or completion of services. Used for supply chain planning and vendor performance tracking.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requisitionReference rdf:type rdf:Property ;
    rdfs:label 'Requisition Reference' ;
    rdfs:comment 'Reference to the internal purchase requisition(s) that originated this purchase order. Links operational demand to procurement execution.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sentToVendorTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sent To Vendor Timestamp' ;
    rdfs:comment 'Timestamp when the purchase order was transmitted to the vendor via EDI, email, or vendor portal. Marks the start of vendor fulfillment cycle.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:totalPoValue rdf:type rdf:Property ;
    rdfs:label 'Total Po Value' ;
    rdfs:comment 'The total monetary value of the purchase order, including all line items and charges, before taxes. Represents the committed spend amount.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPoValueIncludingTax rdf:type rdf:Property ;
    rdfs:label 'Total Po Value Including Tax' ;
    rdfs:comment 'The total monetary value of the purchase order including all taxes. This is the final committed amount payable to the vendor.' ;
    rdfs:domain ind:PurchaseOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:primaryRepairRequestorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Repair Requestor Employee Id' ;
    rdfs:comment 'Identifier of the maintenance engineer or planner who initiated the repair order request.' ;
    rdfs:domain ind:RepairOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:removalFlightLegId rdf:type rdf:Property ;
    rdfs:label 'Removal Flight Leg Id' ;
    rdfs:comment 'Foreign key linking to flight.flight_leg. Business justification: Component removals triggering repair orders occur on specific flights where defects are discovered. Airlines track removal events for reliability analysis, warranty claims (proving in-service failure)' ;
    rdfs:domain ind:RepairOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FlightLeg .

ind:airworthinessReleaseDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Airworthiness Release Document Number' ;
    rdfs:comment 'Reference number of the airworthiness release certificate issued by the repair station upon completion of work. May be an FAA Form 8130-3 (Authorized Release Certificate), EASA Form 1 (Authorized Release Certificate), or JAA Form One depending on jurisdiction.' ;
    rdfs:domain ind:RepairOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:berFlag rdf:type rdf:Property ;
    rdfs:label 'Ber Flag' ;
    rdfs:comment 'Indicator that the component was declared beyond economical repair by the vendor, meaning the repair cost exceeds the threshold value or replacement cost.' ;
    rdfs:domain ind:RepairOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:berThresholdValue rdf:type rdf:Property ;
    rdfs:label 'Ber Threshold Value' ;
    rdfs:comment 'Maximum acceptable repair cost threshold for this component. If actual repair cost exceeds this value, the component is declared BER and a replacement is procured instead.' ;
    rdfs:domain ind:RepairOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:faultDescription rdf:type rdf:Property ;
    rdfs:label 'Fault Description' ;
    rdfs:comment 'Detailed description of the defect, malfunction, or reason the component was removed from service and requires repair. Captured from maintenance logs or pilot reports.' ;
    rdfs:domain ind:RepairOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promisedReturnDate rdf:type rdf:Property ;
    rdfs:label 'Promised Return Date' ;
    rdfs:comment 'Date the repair vendor committed to return the serviceable component. Used for planning and vendor performance tracking.' ;
    rdfs:domain ind:RepairOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:repairCostActual rdf:type rdf:Property ;
    rdfs:label 'Repair Cost Actual' ;
    rdfs:comment 'Final invoiced cost for the completed repair work, including any additional charges for findings discovered during teardown or scope changes.' ;
    rdfs:domain ind:RepairOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:repairCostQuoted rdf:type rdf:Property ;
    rdfs:label 'Repair Cost Quoted' ;
    rdfs:comment 'Initial cost estimate provided by the repair vendor for the repair work, before any additional findings or scope changes.' ;
    rdfs:domain ind:RepairOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:repairOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Repair Order Number' ;
    rdfs:comment 'Externally-known unique business identifier for the repair order, used for tracking and communication with repair vendors.' ;
    rdfs:domain ind:RepairOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repairOrderStatus rdf:type rdf:Property ;
    rdfs:label 'Repair Order Status' ;
    rdfs:comment 'Current lifecycle status of the repair order: dispatched (sent to vendor), in-repair (work in progress), awaiting-parts (vendor waiting for spare parts), completed (repair finished and component returned), ber-declared (beyond economical repair), or cancelled (order terminated).' ;
    rdfs:domain ind:RepairOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repairSpecificationReference rdf:type rdf:Property ;
    rdfs:label 'Repair Specification Reference' ;
    rdfs:comment 'Reference to the technical specification, service bulletin, or Component Maintenance Manual (CMM) section governing the repair work to be performed.' ;
    rdfs:domain ind:RepairOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repairStationCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Repair Station Certificate Number' ;
    rdfs:comment 'Regulatory certificate number of the Part-145 repair station performing the work, issued by EASA, FAA, or other civil aviation authority.' ;
    rdfs:domain ind:RepairOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repairType rdf:type rdf:Property ;
    rdfs:label 'Repair Type' ;
    rdfs:comment 'Classification of the maintenance action being performed on the component: overhaul (complete disassembly and rebuild), repair (corrective action), test (functional verification), modification (design change), inspection (scheduled check), or calibration (instrument adjustment).' ;
    rdfs:domain ind:RepairOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replacementPartOrderedFlag rdf:type rdf:Property ;
    rdfs:label 'Replacement Part Ordered Flag' ;
    rdfs:comment 'Indicator that a replacement part has been ordered because the original component was declared BER or the repair was not feasible.' ;
    rdfs:domain ind:RepairOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:warrantyReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Warranty Reference Number' ;
    rdfs:comment 'Warranty claim reference number provided by the manufacturer or vendor when the repair is covered under warranty terms.' ;
    rdfs:domain ind:RepairOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:savingsInitiativeId rdf:type rdf:Property ;
    rdfs:label 'Savings Initiative Id' ;
    rdfs:comment 'Unique identifier for the procurement savings initiative. Primary key.' ;
    rdfs:domain ind:SavingsInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primarySavingsEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Savings Employee Id' ;
    rdfs:comment 'Identifier of the procurement buyer or category manager responsible for leading and delivering this savings initiative.' ;
    rdfs:domain ind:SavingsInitiative ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiarySavingsFinanceValidatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Savings Finance Validator Employee Id' ;
    rdfs:comment 'Identifier of the finance team member who validated the savings, ensuring accountability for the financial audit and confirmation process.' ;
    rdfs:domain ind:SavingsInitiative ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:baselineSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Baseline Spend Amount' ;
    rdfs:comment 'The baseline annual or period spend amount against which savings are measured, representing the pre-initiative cost level.' ;
    rdfs:domain ind:SavingsInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:businessCaseSummary rdf:type rdf:Property ;
    rdfs:label 'Business Case Summary' ;
    rdfs:comment 'A brief summary of the business case and rationale for the savings initiative, explaining the strategic or operational drivers for the cost reduction project.' ;
    rdfs:domain ind:SavingsInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financeValidationDate rdf:type rdf:Property ;
    rdfs:label 'Finance Validation Date' ;
    rdfs:comment 'The date when the finance department validated and confirmed the realized savings, providing independent verification of the cost reduction achievement.' ;
    rdfs:domain ind:SavingsInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:initiativeName rdf:type rdf:Property ;
    rdfs:label 'Initiative Name' ;
    rdfs:comment 'Descriptive name of the savings initiative, summarizing the cost reduction project or strategic sourcing effort.' ;
    rdfs:domain ind:SavingsInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiativeNumber rdf:type rdf:Property ;
    rdfs:label 'Initiative Number' ;
    rdfs:comment 'Business-facing reference number for the savings initiative, used for tracking and reporting to procurement leadership and finance.' ;
    rdfs:domain ind:SavingsInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiativeStatus rdf:type rdf:Property ;
    rdfs:label 'Initiative Status' ;
    rdfs:comment 'Current lifecycle status of the savings initiative: proposed (under evaluation), approved (authorized to proceed), in-progress (execution underway), completed (savings realized), cancelled (discontinued), or on-hold (temporarily paused).' ;
    rdfs:domain ind:SavingsInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiativeType rdf:type rdf:Property ;
    rdfs:label 'Initiative Type' ;
    rdfs:comment 'Classification of the savings initiative approach: negotiation (price reduction), consolidation (vendor or volume consolidation), specification change (material substitution), demand reduction (consumption reduction), process improvement (efficiency gains), or insourcing/outsourcing strategy change.' ;
    rdfs:domain ind:SavingsInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:realizedSavingsAmount rdf:type rdf:Property ;
    rdfs:label 'Realized Savings Amount' ;
    rdfs:comment 'The actual savings amount achieved to date, representing the cumulative financial benefit delivered by the initiative.' ;
    rdfs:domain ind:SavingsInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:riskAssessment rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment' ;
    rdfs:comment 'Assessment of risks associated with the initiative, such as supplier performance risk, operational disruption risk, or quality impact risk, documented for governance and mitigation planning.' ;
    rdfs:domain ind:SavingsInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:savingsValidationStatus rdf:type rdf:Property ;
    rdfs:label 'Savings Validation Status' ;
    rdfs:comment 'The validation stage of the savings: pipeline (forecasted), committed (contractually agreed), realized (operationally achieved), validated by finance (audited and confirmed), or disputed (under review).' ;
    rdfs:domain ind:SavingsInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetSavingsAmount rdf:type rdf:Property ;
    rdfs:label 'Target Savings Amount' ;
    rdfs:comment 'The target absolute savings amount (in currency) that the initiative aims to achieve, representing the financial goal for cost reduction.' ;
    rdfs:domain ind:SavingsInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetSavingsPercentage rdf:type rdf:Property ;
    rdfs:label 'Target Savings Percentage' ;
    rdfs:comment 'The target savings expressed as a percentage of baseline spend, providing a relative measure of the cost reduction goal.' ;
    rdfs:domain ind:SavingsInitiative ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:awardedVendorId rdf:type rdf:Property ;
    rdfs:label 'Awarded Vendor Id' ;
    rdfs:comment 'Reference to the vendor that was awarded the contract or purchase order as a result of this sourcing event. Null if no award has been made or event was cancelled.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Vendor .

ind:primarySourcingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Sourcing Employee Id' ;
    rdfs:comment 'Reference to the procurement buyer or sourcing specialist responsible for issuing and managing this sourcing event.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:awardDate rdf:type rdf:Property ;
    rdfs:label 'Award Date' ;
    rdfs:comment 'Date when the contract or purchase order was formally awarded to the winning vendor.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:awardedCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Awarded Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the awarded contract value (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awardedValueAmount rdf:type rdf:Property ;
    rdfs:label 'Awarded Value Amount' ;
    rdfs:comment 'Total monetary value of the contract or purchase order awarded to the winning vendor. Null if no award has been made.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baselineValueAmount rdf:type rdf:Property ;
    rdfs:label 'Baseline Value Amount' ;
    rdfs:comment 'Baseline or budgeted amount for this sourcing event, used to calculate savings achieved. Typically based on current contract rates or market benchmarks.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractDurationMonths rdf:type rdf:Property ;
    rdfs:label 'Contract Duration Months' ;
    rdfs:comment 'Expected duration of the resulting contract in months. Used for multi-year agreements and framework contracts.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryWeightPercentage rdf:type rdf:Property ;
    rdfs:label 'Delivery Weight Percentage' ;
    rdfs:comment 'Percentage weight assigned to delivery capability, lead time, and logistics in the evaluation criteria (0-100). Used in weighted scoring of vendor proposals.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:evaluationCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Completion Date' ;
    rdfs:comment 'Date when the evaluation of vendor responses was completed and a decision was reached.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluationStartDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Start Date' ;
    rdfs:comment 'Date when the evaluation of vendor responses commenced.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:eventTitle rdf:type rdf:Property ;
    rdfs:label 'Event Title' ;
    rdfs:comment 'Short descriptive title of the sourcing event for identification and reporting purposes.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumQualificationCriteria rdf:type rdf:Property ;
    rdfs:label 'Minimum Qualification Criteria' ;
    rdfs:comment 'Mandatory minimum qualifications vendors must meet to be eligible for award (e.g., years in business, financial stability, certifications, references).' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceWeightPercentage rdf:type rdf:Property ;
    rdfs:label 'Price Weight Percentage' ;
    rdfs:comment 'Percentage weight assigned to price in the evaluation criteria (0-100). Used in weighted scoring of vendor proposals.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityWeightPercentage rdf:type rdf:Property ;
    rdfs:label 'Quality Weight Percentage' ;
    rdfs:comment 'Percentage weight assigned to quality standards, certifications, and compliance in the evaluation criteria (0-100). Used in weighted scoring of vendor proposals.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:responseDeadline rdf:type rdf:Property ;
    rdfs:label 'Response Deadline' ;
    rdfs:comment 'Date and time by which vendors must submit their responses (bids, proposals, quotations) for this sourcing event.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:responsesReceivedCount rdf:type rdf:Property ;
    rdfs:label 'Responses Received Count' ;
    rdfs:comment 'Total number of vendor responses (bids, proposals, quotations) received by the response deadline.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:savingsAchievedAmount rdf:type rdf:Property ;
    rdfs:label 'Savings Achieved Amount' ;
    rdfs:comment 'Total savings achieved versus the baseline value, calculated as baseline minus awarded value. Positive values indicate cost reduction.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:savingsPercentage rdf:type rdf:Property ;
    rdfs:label 'Savings Percentage' ;
    rdfs:comment 'Percentage savings achieved versus baseline, calculated as (savings_achieved_amount / baseline_value_amount) * 100.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:strategicInitiativeReference rdf:type rdf:Property ;
    rdfs:label 'Strategic Initiative Reference' ;
    rdfs:comment 'Reference code or identifier linking this sourcing event to a broader strategic sourcing initiative or cost reduction program.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalWeightPercentage rdf:type rdf:Property ;
    rdfs:label 'Technical Weight Percentage' ;
    rdfs:comment 'Percentage weight assigned to technical capability and quality in the evaluation criteria (0-100). Used in weighted scoring of vendor proposals.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorsInvitedCount rdf:type rdf:Property ;
    rdfs:label 'Vendors Invited Count' ;
    rdfs:comment 'Total number of vendors invited to participate in this sourcing event.' ;
    rdfs:domain ind:SourcingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:spendRecordId rdf:type rdf:Property ;
    rdfs:label 'Spend Record Id' ;
    rdfs:comment 'Unique identifier for the procurement spend record. Primary key for the spend_record product.' ;
    rdfs:domain ind:SpendRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primarySpendRequisitionerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Spend Requisitioner Employee Id' ;
    rdfs:comment 'The employee ID of the person who initiated the procurement requisition. Used for spend authorization audit trails and accountability.' ;
    rdfs:domain ind:SpendRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:vendorInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Vendor Invoice Id' ;
    rdfs:comment 'Foreign key linking to procurement.vendor_invoice. Business justification: Spend records reference vendor invoices for spend classification and payment tracking. Currently uses invoice_number (STRING) which is a denormalized business reference. Adding vendor_invoice_id FK no' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VendorInvoice .

ind:businessUnit rdf:type rdf:Property ;
    rdfs:label 'Business Unit' ;
    rdfs:comment 'The business unit or division within the airline that incurred this spend (e.g., Flight Operations, Maintenance, Catering, Ground Services). Enables business unit spend analysis and chargeback.' ;
    rdfs:domain ind:SpendRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maverickSpendFlag rdf:type rdf:Property ;
    rdfs:label 'Maverick Spend Flag' ;
    rdfs:comment 'Boolean flag indicating whether this spend was executed outside of approved procurement channels or contracts (maverick spend). True indicates non-compliant procurement requiring corrective action.' ;
    rdfs:domain ind:SpendRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Net Spend Amount' ;
    rdfs:comment 'The net spend amount after applying discounts and before tax. Represents the actual cost to the airline for procurement analytics.' ;
    rdfs:domain ind:SpendRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:savingsAmount rdf:type rdf:Property ;
    rdfs:label 'Savings Amount' ;
    rdfs:comment 'The calculated savings amount achieved through strategic sourcing, contract negotiation, or competitive bidding compared to baseline or market rates. Used for procurement performance measurement.' ;
    rdfs:domain ind:SpendRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourcingChannel rdf:type rdf:Property ;
    rdfs:label 'Sourcing Channel' ;
    rdfs:comment 'The sourcing channel through which the procurement was executed (e.g., Contracted, Spot, Catalogue, P-Card, Emergency). Enables analysis of procurement compliance and strategic sourcing effectiveness.' ;
    rdfs:domain ind:SpendRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spendAmount rdf:type rdf:Property ;
    rdfs:label 'Spend Amount' ;
    rdfs:comment 'The monetary value of the spend in the transaction currency. Represents the actual committed or invoiced amount for this procurement transaction.' ;
    rdfs:domain ind:SpendRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:spendDate rdf:type rdf:Property ;
    rdfs:label 'Spend Date' ;
    rdfs:comment 'The date on which the spend was incurred or committed. This is the primary business event timestamp for spend recognition and period allocation.' ;
    rdfs:domain ind:SpendRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractOwnerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Contract Owner Employee Id' ;
    rdfs:comment 'Reference to the procurement or category manager employee responsible for managing this contract and vendor relationship.' ;
    rdfs:domain ind:SupplyContract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:annualCommittedSpend rdf:type rdf:Property ;
    rdfs:label 'Annual Committed Spend' ;
    rdfs:comment 'Minimum or expected annual spend commitment under this contract, used for budget planning and vendor performance tracking.' ;
    rdfs:domain ind:SupplyContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confidentialityClauseFlag rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Clause Flag' ;
    rdfs:comment 'Indicates whether the contract includes a confidentiality or non-disclosure clause restricting the sharing of contract terms or vendor information.' ;
    rdfs:domain ind:SupplyContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractTitle rdf:type rdf:Property ;
    rdfs:label 'Contract Title' ;
    rdfs:comment 'Short descriptive title of the contract for quick identification and reporting purposes.' ;
    rdfs:domain ind:SupplyContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeResolutionMethod rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Method' ;
    rdfs:comment 'Contractually agreed method for resolving disputes: litigation (court proceedings), arbitration (binding third-party decision), mediation (facilitated negotiation), or negotiation (direct party discussions).' ;
    rdfs:domain ind:SupplyContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentRepositoryReference rdf:type rdf:Property ;
    rdfs:label 'Document Repository Reference' ;
    rdfs:comment 'URI, file path, or document management system reference pointing to the signed contract document, amendments, and related legal attachments.' ;
    rdfs:domain ind:SupplyContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceRequirementFlag rdf:type rdf:Property ;
    rdfs:label 'Insurance Requirement Flag' ;
    rdfs:comment 'Indicates whether the vendor is contractually required to maintain specific insurance coverage (e.g., liability, professional indemnity, workers compensation) during the contract term.' ;
    rdfs:domain ind:SupplyContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalEntityCode rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Code' ;
    rdfs:comment 'Code identifying the airline legal entity (subsidiary, operating company, or regional entity) that is the contracting party on behalf of the airline group.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyClauses rdf:type rdf:Property ;
    rdfs:label 'Penalty Clauses' ;
    rdfs:comment 'Description of financial penalties, liquidated damages, or other remedies applicable if the vendor fails to meet contractual obligations or SLA targets.' ;
    rdfs:domain ind:SupplyContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceEscalationClause rdf:type rdf:Property ;
    rdfs:label 'Price Escalation Clause' ;
    rdfs:comment 'Textual description of any contractual provisions allowing price adjustments over time due to inflation, index changes, or other economic factors.' ;
    rdfs:domain ind:SupplyContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalTermMonths rdf:type rdf:Property ;
    rdfs:label 'Renewal Term Months' ;
    rdfs:comment 'Duration in months for each automatic renewal period if auto-renewal is enabled.' ;
    rdfs:domain ind:SupplyContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:signedDate rdf:type rdf:Property ;
    rdfs:label 'Signed Date' ;
    rdfs:comment 'Date when the contract was executed (signed by both airline and vendor parties).' ;
    rdfs:domain ind:SupplyContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:slaTermsSummary rdf:type rdf:Property ;
    rdfs:label 'Sla Terms Summary' ;
    rdfs:comment 'High-level summary of service level commitments, performance targets, response times, and availability guarantees stipulated in the contract.' ;
    rdfs:domain ind:SupplyContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sustainabilityCriteriaFlag rdf:type rdf:Property ;
    rdfs:label 'Sustainability Criteria Flag' ;
    rdfs:comment 'Indicates whether the contract includes environmental, social, or governance (ESG) performance criteria or sustainability commitments aligned with CORSIA or airline sustainability goals.' ;
    rdfs:domain ind:SupplyContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:terminationNoticePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Termination Notice Period Days' ;
    rdfs:comment 'Number of days advance written notice required by either party to terminate the contract before its natural expiration.' ;
    rdfs:domain ind:SupplyContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalContractValue rdf:type rdf:Property ;
    rdfs:label 'Total Contract Value' ;
    rdfs:comment 'Total monetary value committed under this contract over its full term, including all line items and estimated volumes.' ;
    rdfs:domain ind:SupplyContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:as9100Certified rdf:type rdf:Property ;
    rdfs:label 'As9100 Certified' ;
    rdfs:comment 'Indicates whether the vendor holds current AS9100 aerospace quality management system certification, critical for MRO parts suppliers.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bankName rdf:type rdf:Property ;
    rdfs:label 'Bank Name' ;
    rdfs:comment 'Name of the financial institution holding the vendor\'s primary payment account.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankSwiftCode rdf:type rdf:Property ;
    rdfs:label 'Bank Swift Code' ;
    rdfs:comment 'SWIFT/BIC code of the vendor\'s bank for international wire transfers and cross-border payments.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blacklistFlag rdf:type rdf:Property ;
    rdfs:label 'Blacklist Flag' ;
    rdfs:comment 'Indicates whether the vendor is currently blacklisted or suspended from doing business with the airline due to performance, compliance, or ethical violations.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dunsNumber rdf:type rdf:Property ;
    rdfs:label 'Duns Number' ;
    rdfs:comment 'Nine-digit unique identifier assigned by Dun & Bradstreet for business entity identification and credit assessment.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:easaPart145Approved rdf:type rdf:Property ;
    rdfs:label 'Easa Part145 Approved' ;
    rdfs:comment 'Indicates whether the vendor holds EASA Part-145 approval for aircraft maintenance organization, required for MRO service providers operating in EU jurisdictions.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:faaRepairStationCertified rdf:type rdf:Property ;
    rdfs:label 'Faa Repair Station Certified' ;
    rdfs:comment 'Indicates whether the vendor holds FAA repair station certification under 14 CFR Part 145, required for MRO service providers operating in US jurisdictions.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iataVendorCode rdf:type rdf:Property ;
    rdfs:label 'Iata Vendor Code' ;
    rdfs:comment 'IATA-assigned alphanumeric code identifying the vendor within the aviation industry supply chain, used for standardized procurement and settlement.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iso9001Certified rdf:type rdf:Property ;
    rdfs:label 'Iso9001 Certified' ;
    rdfs:comment 'Indicates whether the vendor holds current ISO 9001 quality management system certification.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minorityOwnedFlag rdf:type rdf:Property ;
    rdfs:label 'Minority Owned Flag' ;
    rdfs:comment 'Indicates whether the vendor is certified as a minority-owned business enterprise for diversity and inclusion reporting.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:registeredAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Registered Address Line1' ;
    rdfs:comment 'First line of the vendor\'s official registered business address as recorded with the incorporation authority.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Registered Address Line2' ;
    rdfs:comment 'Second line of the vendor\'s official registered business address, typically containing suite, floor, or building details.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredCity rdf:type rdf:Property ;
    rdfs:label 'Registered City' ;
    rdfs:comment 'City or municipality of the vendor\'s registered business address.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredCountry rdf:type rdf:Property ;
    rdfs:label 'Registered Country' ;
    rdfs:comment 'Three-letter ISO country code of the vendor\'s registered business address.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredPostalCode rdf:type rdf:Property ;
    rdfs:label 'Registered Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the vendor\'s registered business address.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredStateProvince rdf:type rdf:Property ;
    rdfs:label 'Registered State Province' ;
    rdfs:comment 'State, province, or administrative region of the vendor\'s registered business address.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:smallBusinessFlag rdf:type rdf:Property ;
    rdfs:label 'Small Business Flag' ;
    rdfs:comment 'Indicates whether the vendor qualifies as a small business under applicable regulatory definitions for procurement diversity programs.' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vendorStatus rdf:type rdf:Property ;
    rdfs:label 'Vendor Status' ;
    rdfs:comment 'Current lifecycle status of the vendor relationship: active (approved and operational), inactive (no longer doing business), suspended (temporarily blocked), pending_approval (undergoing onboarding review).' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorTier rdf:type rdf:Property ;
    rdfs:label 'Vendor Tier' ;
    rdfs:comment 'Strategic classification of the vendor based on business relationship strength, volume, and criticality: strategic (top-tier partners with long-term agreements), preferred (high-volume reliable suppliers), approved (qualified suppliers meeting minimum standards), conditional (suppliers under probation or limited approval).' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorType rdf:type rdf:Property ;
    rdfs:label 'Vendor Type' ;
    rdfs:comment 'Primary classification of the vendor based on the category of goods or services provided: MRO (Maintenance Repair and Overhaul parts suppliers), fuel (aviation fuel suppliers), catering (inflight and lounge catering providers), ground_services (ground handling and airport service contractors), IT (information technology and software vendors), consumables (general supplies and consumables).' ;
    rdfs:domain ind:Vendor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorAuditId rdf:type rdf:Property ;
    rdfs:label 'Vendor Audit Id' ;
    rdfs:comment 'Unique identifier for the vendor audit record. Primary key.' ;
    rdfs:domain ind:VendorAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditLeadEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Audit Lead Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Vendor audits (EASA Part-145, FAA repair station compliance) require internal audit lead assignment. Quality assurance or procurement employees lead audits. Tracks accountability for audit findings, c' ;
    rdfs:domain ind:VendorAudit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:auditCostAmount rdf:type rdf:Property ;
    rdfs:label 'Audit Cost Amount' ;
    rdfs:comment 'Total cost incurred for conducting the audit, including auditor fees, travel expenses, and third-party certification body charges. Used for procurement budget tracking and vendor management cost analysis.' ;
    rdfs:domain ind:VendorAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:auditCostCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Audit Cost Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the audit cost amount. Examples: USD, EUR, GBP.' ;
    rdfs:domain ind:VendorAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditEndDate rdf:type rdf:Property ;
    rdfs:label 'Audit End Date' ;
    rdfs:comment 'The date on which the audit fieldwork was completed. Nullable for single-day audits. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:VendorAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditLeadOrganization rdf:type rdf:Property ;
    rdfs:label 'Audit Lead Organization' ;
    rdfs:comment 'Name of the organization employing the audit lead. May be the airline\'s internal audit department, a third-party certification body, or a regulatory authority.' ;
    rdfs:domain ind:VendorAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditLocation rdf:type rdf:Property ;
    rdfs:label 'Audit Location' ;
    rdfs:comment 'Physical location where the audit was conducted. May include vendor facility address, city, country, or \'Remote\' for virtual audits conducted via video conference and document review.' ;
    rdfs:domain ind:VendorAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditMethod rdf:type rdf:Property ;
    rdfs:label 'Audit Method' ;
    rdfs:comment 'Method by which the audit was conducted: on-site (physical presence at vendor facility), remote (virtual audit via video and document review), or hybrid (combination of on-site and remote activities).' ;
    rdfs:domain ind:VendorAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Audit Reference Number' ;
    rdfs:comment 'Externally-known unique audit reference number assigned by the auditing organization or system. Used for tracking and reporting purposes.' ;
    rdfs:domain ind:VendorAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditReportDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Audit Report Document Reference' ;
    rdfs:comment 'Reference identifier or file path to the formal audit report document stored in the document management system. Enables retrieval of the full audit report with detailed findings, evidence, and recommendations.' ;
    rdfs:domain ind:Procurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditStatus rdf:type rdf:Property ;
    rdfs:label 'Audit Status' ;
    rdfs:comment 'Current lifecycle status of the audit: scheduled (audit planned but not yet started), in_progress (audit fieldwork underway), completed (audit finished and report issued), cancelled (audit cancelled before completion), or report_pending (fieldwork complete, report being finalized).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionDeadline rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Deadline' ;
    rdfs:comment 'The date by which the vendor must submit and implement corrective actions to address audit findings. Nullable if no corrective actions are required. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:VendorAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:observationsCount rdf:type rdf:Property ;
    rdfs:label 'Observations Count' ;
    rdfs:comment 'Number of observations or opportunities for improvement noted during the audit. Observations are not non-conformities but represent areas where the vendor could enhance processes or practices.' ;
    rdfs:domain ind:VendorAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overallAuditResult rdf:type rdf:Property ;
    rdfs:label 'Overall Audit Result' ;
    rdfs:comment 'Final outcome of the audit: pass (vendor meets all requirements), conditional pass (vendor approved subject to corrective actions within specified timeframe), fail (vendor does not meet requirements and is not approved), or pending (audit report under review, final decision not yet issued).' ;
    rdfs:domain ind:VendorAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reAuditDate rdf:type rdf:Property ;
    rdfs:label 'Re Audit Date' ;
    rdfs:comment 'Scheduled or actual date of the follow-up re-audit to verify corrective action effectiveness. Nullable if no re-audit is required or not yet scheduled. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:VendorAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reAuditRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Re Audit Required Flag' ;
    rdfs:comment 'Boolean flag indicating whether a follow-up re-audit is required to verify closure of findings and effectiveness of corrective actions. True if re-audit is required, False otherwise.' ;
    rdfs:domain ind:VendorAudit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:blockingReasonCode rdf:type rdf:Property ;
    rdfs:label 'Blocking Reason Code' ;
    rdfs:comment 'Code indicating why the invoice is blocked from payment, if applicable (e.g., price variance, quantity mismatch, missing documentation).' ;
    rdfs:domain ind:VendorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyCode rdf:type rdf:Property ;
    rdfs:label 'Company Code' ;
    rdfs:comment 'The airline\'s company code or legal entity to which this invoice is assigned for financial reporting purposes.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Internal Document Number' ;
    rdfs:comment 'The airline\'s internal document number assigned to this invoice in the procurement or ERP system for tracking and reference.' ;
    rdfs:domain ind:VendorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Invoice Received Date' ;
    rdfs:comment 'The date the invoice was physically or electronically received by the airline\'s procurement or accounts payable department.' ;
    rdfs:domain ind:VendorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentRunReference rdf:type rdf:Property ;
    rdfs:label 'Payment Run Reference' ;
    rdfs:comment 'Reference number of the payment run in which this invoice was included for payment processing.' ;
    rdfs:domain ind:VendorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:procurementCategory rdf:type rdf:Property ;
    rdfs:label 'Procurement Category' ;
    rdfs:comment 'The high-level procurement category this invoice belongs to, aligned with airline procurement taxonomy (MRO parts, fuel, catering, ground services, etc.). [ENUM-REF-CANDIDATE: mro_parts|fuel|catering|ground_services|it_services|professional_services|facilities|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:VendorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorInvoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Invoice Number' ;
    rdfs:comment 'The invoice number assigned by the vendor on their invoice document. This is the external identifier from the supplier\'s system.' ;
    rdfs:domain ind:VendorInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorPerformanceId rdf:type rdf:Property ;
    rdfs:label 'Vendor Performance Id' ;
    rdfs:comment 'Unique identifier for the vendor performance evaluation record.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:aogResponseTimeHours rdf:type rdf:Property ;
    rdfs:label 'Aog Response Time Hours' ;
    rdfs:comment 'Average response time in hours for critical AOG parts requests during the evaluation period. Applicable to MRO parts suppliers.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractRenewalEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Contract Renewal Eligible Flag' ;
    rdfs:comment 'Indicates whether the vendor is eligible for contract renewal based on performance tier and evaluation results.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:evaluationDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Date' ;
    rdfs:comment 'The date on which the performance evaluation was completed and recorded.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluationNotes rdf:type rdf:Property ;
    rdfs:label 'Evaluation Notes' ;
    rdfs:comment 'Free-text notes and comments from the evaluating buyer regarding vendor performance, issues, or observations during the evaluation period.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evaluationPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Period End Date' ;
    rdfs:comment 'The end date of the performance evaluation period.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluationPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Period Start Date' ;
    rdfs:comment 'The start date of the performance evaluation period (month, quarter, or custom period).' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:evaluationPeriodType rdf:type rdf:Property ;
    rdfs:label 'Evaluation Period Type' ;
    rdfs:comment 'The type of evaluation period (monthly, quarterly, semi-annual, annual, or custom).' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceAccuracyRatePercent rdf:type rdf:Property ;
    rdfs:label 'Invoice Accuracy Rate Percent' ;
    rdfs:comment 'Percentage of invoices submitted without errors (pricing, quantity, or terms discrepancies) during the evaluation period.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:onTimeDeliveryRatePercent rdf:type rdf:Property ;
    rdfs:label 'On Time Delivery Rate Percent' ;
    rdfs:comment 'Percentage of orders delivered on or before the promised delivery date during the evaluation period.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:orderFillRatePercent rdf:type rdf:Property ;
    rdfs:label 'Order Fill Rate Percent' ;
    rdfs:comment 'Percentage of ordered quantity successfully fulfilled by the vendor during the evaluation period.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overallPerformanceScore rdf:type rdf:Property ;
    rdfs:label 'Overall Performance Score' ;
    rdfs:comment 'Weighted composite performance score calculated from all measured KPIs, typically on a 0-100 scale.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priceComplianceRatePercent rdf:type rdf:Property ;
    rdfs:label 'Price Compliance Rate Percent' ;
    rdfs:comment 'Percentage of invoices that matched contracted pricing terms during the evaluation period.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualityRejectionRatePercent rdf:type rdf:Property ;
    rdfs:label 'Quality Rejection Rate Percent' ;
    rdfs:comment 'Percentage of delivered items rejected due to quality defects or non-conformance during the evaluation period.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaTargetAogResponseHours rdf:type rdf:Property ;
    rdfs:label 'Sla Target Aog Response Hours' ;
    rdfs:comment 'Contracted SLA target (maximum acceptable) for AOG response time in hours for critical parts suppliers.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaTargetOnTimeDeliveryPercent rdf:type rdf:Property ;
    rdfs:label 'Sla Target On Time Delivery Percent' ;
    rdfs:comment 'Contracted SLA target for on-time delivery rate percentage that the vendor is expected to meet.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaTargetQualityRejectionPercent rdf:type rdf:Property ;
    rdfs:label 'Sla Target Quality Rejection Percent' ;
    rdfs:comment 'Contracted SLA target (maximum acceptable) for quality rejection rate percentage.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalOrderValueAmount rdf:type rdf:Property ;
    rdfs:label 'Total Order Value Amount' ;
    rdfs:comment 'Total monetary value of all purchase orders included in this evaluation period.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalOrdersEvaluated rdf:type rdf:Property ;
    rdfs:label 'Total Orders Evaluated' ;
    rdfs:comment 'Total number of purchase orders included in this performance evaluation period.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trendVersusPriorPeriod rdf:type rdf:Property ;
    rdfs:label 'Trend Versus Prior Period' ;
    rdfs:comment 'Performance trend indicator comparing this evaluation period to the previous period (improving, stable, declining, or first evaluation).' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorDevelopmentProgramFlag rdf:type rdf:Property ;
    rdfs:label 'Vendor Development Program Flag' ;
    rdfs:comment 'Indicates whether the vendor has been enrolled in a vendor development program to improve performance.' ;
    rdfs:domain ind:VendorPerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:vendorQuoteId rdf:type rdf:Property ;
    rdfs:label 'Vendor Quote Id' ;
    rdfs:comment 'Unique identifier for the vendor quotation record. Primary key.' ;
    rdfs:domain ind:VendorQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:commercialEvaluationScore rdf:type rdf:Property ;
    rdfs:label 'Commercial Evaluation Score' ;
    rdfs:comment 'Numerical score assigned during commercial evaluation, reflecting price competitiveness, payment terms, and delivery lead time. Typically on a 0-100 scale.' ;
    rdfs:domain ind:VendorQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Delivery Lead Time Days' ;
    rdfs:comment 'Number of days the vendor requires to deliver the goods or services after purchase order issuance.' ;
    rdfs:domain ind:VendorQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:evaluationCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Evaluation Completed Date' ;
    rdfs:comment 'Date when the evaluation of this quotation was completed and scores were finalized.' ;
    rdfs:domain ind:VendorQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exceptionsAndDeviations rdf:type rdf:Property ;
    rdfs:label 'Exceptions And Deviations' ;
    rdfs:comment 'Free-text description of any exceptions, deviations, or clarifications the vendor has noted against the sourcing event requirements.' ;
    rdfs:domain ind:VendorQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incoterms rdf:type rdf:Property ;
    rdfs:label 'Incoterms' ;
    rdfs:comment 'Incoterms rule defining the delivery point, risk transfer, and cost responsibilities between vendor and airline. [ENUM-REF-CANDIDATE: EXW|FCA|CPT|CIP|DAP|DPU|DDP|FAS|FOB|CFR|CIF — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:VendorQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallRanking rdf:type rdf:Property ;
    rdfs:label 'Overall Ranking' ;
    rdfs:comment 'Overall rank of this quotation among all quotes received for the sourcing event, based on combined commercial and technical evaluation. Rank 1 is the best.' ;
    rdfs:domain ind:VendorQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paymentTermsOffered rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Offered' ;
    rdfs:comment 'Payment terms proposed by the vendor (e.g., Net 30, Net 60, 2/10 Net 30, advance payment, letter of credit).' ;
    rdfs:domain ind:VendorQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quoteDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Quote Document Url' ;
    rdfs:comment 'URL or file path to the original quotation document submitted by the vendor (PDF, Excel, etc.).' ;
    rdfs:domain ind:VendorQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quoteReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Quote Reference Number' ;
    rdfs:comment 'Externally-known unique reference number assigned to this vendor quotation, used for tracking and communication with the vendor.' ;
    rdfs:domain ind:VendorQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quoteStatus rdf:type rdf:Property ;
    rdfs:label 'Quote Status' ;
    rdfs:comment 'Current lifecycle status of the vendor quotation in the evaluation and award process. [ENUM-REF-CANDIDATE: received|under_evaluation|shortlisted|awarded|rejected|withdrawn|expired — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:VendorQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quoteType rdf:type rdf:Property ;
    rdfs:label 'Quote Type' ;
    rdfs:comment 'Classification of the quotation based on the sourcing context (formal RFQ/RFP response, ad-hoc price enquiry, spot purchase, or framework agreement quote).' ;
    rdfs:domain ind:VendorQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quotedTotalValue rdf:type rdf:Property ;
    rdfs:label 'Quoted Total Value' ;
    rdfs:comment 'Total value of the quotation across all line items, including all charges but before taxes. Expressed in the quote currency.' ;
    rdfs:domain ind:VendorQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quotedUnitPrice rdf:type rdf:Property ;
    rdfs:label 'Quoted Unit Price' ;
    rdfs:comment 'Unit price quoted by the vendor for the line item or material. Expressed in the quote currency.' ;
    rdfs:domain ind:VendorQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:technicalComplianceNotes rdf:type rdf:Property ;
    rdfs:label 'Technical Compliance Notes' ;
    rdfs:comment 'Free-text notes documenting the vendors technical compliance with specifications, standards, and regulatory requirements (e.g., EASA Part 145, FAA approval, OEM certification).' ;
    rdfs:domain ind:VendorQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalEvaluationScore rdf:type rdf:Property ;
    rdfs:label 'Technical Evaluation Score' ;
    rdfs:comment 'Numerical score assigned during technical evaluation, reflecting compliance with specifications, certifications, and quality standards. Typically on a 0-100 scale.' ;
    rdfs:domain ind:VendorQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorContactEmail rdf:type rdf:Property ;
    rdfs:label 'Vendor Contact Email' ;
    rdfs:comment 'Email address of the vendor representative for communication regarding this quotation.' ;
    rdfs:domain ind:VendorQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorContactName rdf:type rdf:Property ;
    rdfs:label 'Vendor Contact Name' ;
    rdfs:comment 'Name of the vendor representative who submitted or is responsible for this quotation.' ;
    rdfs:domain ind:VendorQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorContactPhone rdf:type rdf:Property ;
    rdfs:label 'Vendor Contact Phone' ;
    rdfs:comment 'Phone number of the vendor representative for communication regarding this quotation.' ;
    rdfs:domain ind:VendorQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:warrantyPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Warranty Period Months' ;
    rdfs:comment 'Duration of warranty coverage offered by the vendor, expressed in months.' ;
    rdfs:domain ind:VendorQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:boardingPassId rdf:type rdf:Property ;
    rdfs:label 'Boarding Pass Id' ;
    rdfs:comment 'Unique identifier for the boarding pass record. Primary key. Inferred role: TRANSACTION_HEADER (discrete check-in event with lifecycle).' ;
    rdfs:domain ind:BoardingPass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryBaggageItemId rdf:type rdf:Property ;
    rdfs:label 'Primary Baggage Item Id' ;
    rdfs:comment 'Foreign key linking to airport.baggage_item. Business justification: Boarding passes are issued to passengers who check baggage. Baggage reconciliation (positive passenger bag match), tracking, and irregularity investigation require this link for operational safety and' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BaggageItem .

ind:primaryBoardingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Boarding Employee Id' ;
    rdfs:comment 'Employee identifier of the gate agent who scanned the boarding pass at boarding. Null if self-scanned or not yet boarded.' ;
    rdfs:domain ind:BoardingPass ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:barcodeData rdf:type rdf:Property ;
    rdfs:label 'Barcode Data' ;
    rdfs:comment 'Encoded barcode data string conforming to IATA BCBP Type M format. Contains passenger name, flight details, seat, boarding pass number, and security data. Confidential due to embedded passenger information.' ;
    rdfs:domain ind:BoardingPass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boardingGroup rdf:type rdf:Property ;
    rdfs:label 'Boarding Group' ;
    rdfs:comment 'Descriptive boarding group name assigned to the passenger (e.g., priority, general, family). Complements boarding_zone with business-friendly label.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boardingPassNumber rdf:type rdf:Property ;
    rdfs:label 'Boarding Pass Number' ;
    rdfs:comment 'Unique boarding pass sequence number issued by the check-in system. Business identifier for the boarding pass. Satisfies TRANSACTION_HEADER minimum requirement for BUSINESS_IDENTIFIER.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boardingPassStatus rdf:type rdf:Property ;
    rdfs:label 'Boarding Pass Status' ;
    rdfs:comment 'Current lifecycle status of the boarding pass. Tracks progression from issuance through boarding gate scan. Satisfies TRANSACTION_HEADER minimum requirement for LIFECYCLE_STATUS.' ;
    rdfs:domain ind:BoardingPass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boardingScanTimestamp rdf:type rdf:Property ;
    rdfs:label 'Boarding Scan Timestamp' ;
    rdfs:comment 'Timestamp when the boarding pass barcode was scanned at the gate, confirming passenger boarded the aircraft. Null if not yet scanned.' ;
    rdfs:domain ind:BoardingPass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:boardingTime rdf:type rdf:Property ;
    rdfs:label 'Boarding Time' ;
    rdfs:comment 'Scheduled boarding commencement time printed on the boarding pass. Advises passengers when to arrive at the gate.' ;
    rdfs:domain ind:BoardingPass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:checkInCounterNumber rdf:type rdf:Property ;
    rdfs:label 'Check In Counter Number' ;
    rdfs:comment 'Counter or kiosk number where the boarding pass was issued. Null for web or mobile check-in.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkInLocationCode rdf:type rdf:Property ;
    rdfs:label 'Check In Location Code' ;
    rdfs:comment 'Three-letter IATA airport code where the boarding pass was issued. May differ from departure airport for interline or codeshare itineraries.' ;
    rdfs:domain ind:BoardingPass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkInMethod rdf:type rdf:Property ;
    rdfs:label 'Check In Method' ;
    rdfs:comment 'Channel through which the passenger completed check-in and received the boarding pass. CUSS = Common Use Self-Service.' ;
    rdfs:domain ind:BoardingPass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkedBagCount rdf:type rdf:Property ;
    rdfs:label 'Checked Bag Count' ;
    rdfs:comment 'Number of checked bags associated with this boarding pass at check-in.' ;
    rdfs:domain ind:BoardingPass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:documentCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Document Check Status' ;
    rdfs:comment 'Status of travel document verification (passport, visa, ID) at check-in. Required for international flights.' ;
    rdfs:domain ind:BoardingPass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fastTrackEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Fast Track Eligible Flag' ;
    rdfs:comment 'Indicates whether the passenger is eligible for fast-track security or priority boarding based on fare class, status, or purchase.' ;
    rdfs:domain ind:BoardingPass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:format rdf:type rdf:Property ;
    rdfs:label 'Format' ;
    rdfs:comment 'Physical or digital format of the boarding pass issued to the passenger. BCBP = Bar Coded Boarding Pass (2D barcode).' ;
    rdfs:domain ind:BoardingPass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReprintTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Reprint Timestamp' ;
    rdfs:comment 'Timestamp of the most recent boarding pass reprint event. Null if never reprinted.' ;
    rdfs:domain ind:BoardingPass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reprintCount rdf:type rdf:Property ;
    rdfs:label 'Reprint Count' ;
    rdfs:comment 'Number of times this boarding pass has been reprinted (e.g., at kiosk, counter, or gate). Zero indicates original issuance.' ;
    rdfs:domain ind:BoardingPass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:securitySelecteeFlag rdf:type rdf:Property ;
    rdfs:label 'Security Selectee Flag' ;
    rdfs:comment 'Indicates whether the passenger has been selected for additional security screening by TSA or equivalent authority. Confidential security data.' ;
    rdfs:domain ind:BoardingPass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specialServiceCodes rdf:type rdf:Property ;
    rdfs:label 'Special Service Codes' ;
    rdfs:comment 'Comma-separated list of IATA SSR codes applicable to this boarding pass (e.g., WCHR for wheelchair, PETC for pet in cabin, UMNR for unaccompanied minor).' ;
    rdfs:domain ind:BoardingPass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apisDataCompleteFlag rdf:type rdf:Property ;
    rdfs:label 'Apis Data Complete Flag' ;
    rdfs:comment 'Indicates whether all required APIS data elements (name, DOB, gender, nationality, passport) have been collected for this passenger. Required for international travel compliance.' ;
    rdfs:domain ind:ReservationBookingPassenger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:associatedInfantIndicator rdf:type rdf:Property ;
    rdfs:label 'Associated Infant Indicator' ;
    rdfs:comment 'Flag indicating whether this adult passenger has an associated infant (lap child) traveling with them. Used for seat assignment and boarding validation.' ;
    rdfs:domain ind:ReservationBookingPassenger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:boardingPassIssuedFlag rdf:type rdf:Property ;
    rdfs:label 'Boarding Pass Issued Flag' ;
    rdfs:comment 'Indicates whether a boarding pass has been issued to this passenger for at least one segment in the itinerary.' ;
    rdfs:domain ind:ReservationBookingPassenger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:checkInStatus rdf:type rdf:Property ;
    rdfs:label 'Check In Status' ;
    rdfs:comment 'Current check-in and boarding status of the passenger. Tracks progression from reservation through boarding.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPhoneNumber rdf:type rdf:Property ;
    rdfs:label 'Contact Phone Number' ;
    rdfs:comment 'Primary contact phone number for this passenger. Used for flight notifications, IROP rebooking, and operational communication.' ;
    rdfs:domain ind:ReservationBookingPassenger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frequentFlyerNumber rdf:type rdf:Property ;
    rdfs:label 'Frequent Flyer Number' ;
    rdfs:comment 'Passenger\'s frequent flyer membership number for the operating carrier or alliance partner. Used for mileage accrual, tier recognition, and SSR processing.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frequentFlyerTierCode rdf:type rdf:Property ;
    rdfs:label 'Frequent Flyer Tier Code' ;
    rdfs:comment 'Current tier or status level of the passenger in the frequent flyer program. Used for priority boarding, lounge access, and upgrade eligibility.' ;
    rdfs:domain ind:ReservationBookingPassenger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nationalityCountryCode rdf:type rdf:Property ;
    rdfs:label 'Nationality Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code representing the passenger\'s nationality. Required for APIS and visa validation.' ;
    rdfs:domain ind:ReservationBookingPassenger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seatPreferenceCode rdf:type rdf:Property ;
    rdfs:label 'Seat Preference Code' ;
    rdfs:comment 'Passenger\'s preferred seat location type. Used by seat assignment algorithms and displayed to agents during check-in.' ;
    rdfs:domain ind:ReservationBookingPassenger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialServiceRequestCount rdf:type rdf:Property ;
    rdfs:label 'Special Service Request Count' ;
    rdfs:comment 'Total number of SSR records associated with this passenger in the PNR. Includes wheelchair assistance, unaccompanied minor service, pet in cabin, extra baggage, etc.' ;
    rdfs:domain ind:ReservationBookingPassenger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ticketIssueDate rdf:type rdf:Property ;
    rdfs:label 'Ticket Issue Date' ;
    rdfs:comment 'Date when the e-ticket was issued to this passenger. Used for fare rule validation and refund calculations.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:unaccompaniedMinorFlag rdf:type rdf:Property ;
    rdfs:label 'Unaccompanied Minor Flag' ;
    rdfs:comment 'Indicates whether this passenger is traveling as an unaccompanied minor and requires special handling, escort service, and guardian handoff procedures.' ;
    rdfs:domain ind:ReservationBookingPassenger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:wheelchairAssistanceCode rdf:type rdf:Property ;
    rdfs:label 'Wheelchair Assistance Code' ;
    rdfs:comment 'IATA SSR code indicating level of wheelchair assistance required. WCHR=Can walk short distances, WCHS=Cannot climb stairs, WCHC=Immobile, requires wheelchair throughout.' ;
    rdfs:domain ind:ReservationBookingPassenger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookingPaymentId rdf:type rdf:Property ;
    rdfs:label 'Booking Payment Id' ;
    rdfs:comment 'Unique identifier for the booking payment record. Primary key for the booking payment entity.' ;
    rdfs:domain ind:BookingPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fareQuoteId rdf:type rdf:Property ;
    rdfs:label 'Fare Quote Id' ;
    rdfs:comment 'Foreign key linking to reservation.fare_quote. Business justification: Payment is made for a specific fare quote within the PNR. Linking to fare_quote enables tracking which pricing the payment was made against and supports payment reconciliation with the priced itinerar' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FareQuote .

ind:agencyIataNumber rdf:type rdf:Property ;
    rdfs:label 'Agency Iata Number' ;
    rdfs:comment 'IATA-assigned numeric identifier for the travel agency that processed the payment. Applicable when payment method is agency account.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizationCode rdf:type rdf:Property ;
    rdfs:label 'Authorization Code' ;
    rdfs:comment 'Authorization code returned by the payment gateway or card issuer upon successful payment authorization. Used for transaction tracking and reconciliation.' ;
    rdfs:domain ind:BookingPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardExpiryMonth rdf:type rdf:Property ;
    rdfs:label 'Card Expiry Month' ;
    rdfs:comment 'Expiration month of the payment card (1-12). Used for payment authorization and validation.' ;
    rdfs:domain ind:BookingPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cardExpiryYear rdf:type rdf:Property ;
    rdfs:label 'Card Expiry Year' ;
    rdfs:comment 'Expiration year of the payment card (four-digit year). Used for payment authorization and validation.' ;
    rdfs:domain ind:BookingPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cardType rdf:type rdf:Property ;
    rdfs:label 'Card Type' ;
    rdfs:comment 'Brand of the payment card used (e.g., Visa, Mastercard, American Express). Applicable only when payment method is credit or debit card. [ENUM-REF-CANDIDATE: visa|mastercard|amex|discover|jcb|diners|unionpay — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BookingPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardholderName rdf:type rdf:Property ;
    rdfs:label 'Cardholder Name' ;
    rdfs:comment 'Name of the cardholder as it appears on the payment card. Used for payment verification and fraud prevention.' ;
    rdfs:domain ind:BookingPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gatewayTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Gateway Transaction Reference' ;
    rdfs:comment 'Unique transaction identifier assigned by the payment gateway or processor. Used for reconciliation, dispute resolution, and gateway-level tracking.' ;
    rdfs:domain ind:BookingPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instalmentCount rdf:type rdf:Property ;
    rdfs:label 'Instalment Count' ;
    rdfs:comment 'Total number of instalments in the payment plan. Null if not an instalment payment.' ;
    rdfs:domain ind:BookingPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:instalmentNumber rdf:type rdf:Property ;
    rdfs:label 'Instalment Number' ;
    rdfs:comment 'Current instalment number in the sequence (e.g., 1 of 3, 2 of 3). Null if not an instalment payment.' ;
    rdfs:domain ind:BookingPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:instalmentPlanFlag rdf:type rdf:Property ;
    rdfs:label 'Instalment Plan Flag' ;
    rdfs:comment 'Indicates whether this payment is part of an instalment plan. True if the payment is structured as multiple instalments, false otherwise.' ;
    rdfs:domain ind:BookingPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maskedCardNumber rdf:type rdf:Property ;
    rdfs:label 'Masked Card Number' ;
    rdfs:comment 'Masked payment card number showing only the last four digits (e.g., ****1234) for identification and customer service purposes while maintaining PCI compliance.' ;
    rdfs:domain ind:BookingPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milesRedeemedQuantity rdf:type rdf:Property ;
    rdfs:label 'Miles Redeemed Quantity' ;
    rdfs:comment 'Number of frequent flyer miles redeemed for this payment. Applicable when payment method is miles redemption.' ;
    rdfs:domain ind:BookingPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paymentAmount rdf:type rdf:Property ;
    rdfs:label 'Payment Amount' ;
    rdfs:comment 'Total monetary amount of the payment transaction in the specified currency. Represents the gross payment value before any adjustments.' ;
    rdfs:domain ind:BookingPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Payment Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the payment amount (e.g., USD, EUR, GBP). Defines the currency in which the payment was processed.' ;
    rdfs:domain ind:BookingPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentMethodType rdf:type rdf:Property ;
    rdfs:label 'Payment Method Type' ;
    rdfs:comment 'Type of payment instrument used for the transaction. Indicates the form of payment selected by the customer or agent. [ENUM-REF-CANDIDATE: credit_card|debit_card|cash|agency_account|voucher|miles_redemption|corporate_account|bank_transfer|digital_wallet — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BookingPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Payment Timestamp' ;
    rdfs:comment 'Date and time when the payment transaction was initiated or authorized. Represents the business event time of the payment in ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX).' ;
    rdfs:domain ind:BookingPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:processorResponseCode rdf:type rdf:Property ;
    rdfs:label 'Processor Response Code' ;
    rdfs:comment 'Response code returned by the payment processor indicating the result of the transaction (e.g., approval, decline reason). Used for troubleshooting and reporting.' ;
    rdfs:domain ind:BookingPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processorResponseMessage rdf:type rdf:Property ;
    rdfs:label 'Processor Response Message' ;
    rdfs:comment 'Human-readable message from the payment processor describing the transaction result or decline reason.' ;
    rdfs:domain ind:BookingPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Settlement Timestamp' ;
    rdfs:comment 'Date and time when the payment was settled and funds were transferred. Null if payment has not yet been settled.' ;
    rdfs:domain ind:BookingPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:threeDsAuthenticationStatus rdf:type rdf:Property ;
    rdfs:label 'Three Ds Authentication Status' ;
    rdfs:comment 'Status of 3D Secure authentication for the card transaction. Indicates whether additional cardholder verification was performed to reduce fraud risk.' ;
    rdfs:domain ind:BookingPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkInEventId rdf:type rdf:Property ;
    rdfs:label 'Check In Event Id' ;
    rdfs:comment 'Unique identifier for the check-in event transaction. Primary key for the check-in event record.' ;
    rdfs:domain ind:CheckInEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:apisSubmissionStatus rdf:type rdf:Property ;
    rdfs:label 'Apis Submission Status' ;
    rdfs:comment 'Status of the APIS data submission to border control authorities. APIS is required for international flights to transmit passenger data to destination countries.' ;
    rdfs:domain ind:CheckInEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkInChannel rdf:type rdf:Property ;
    rdfs:label 'Check In Channel' ;
    rdfs:comment 'The channel or interface through which the passenger performed check-in. CUSS refers to Common Use Self-Service kiosks. [ENUM-REF-CANDIDATE: web|mobile|airport_kiosk|counter|cuss|api|call_center — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CheckInEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkInCloseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Check In Close Timestamp' ;
    rdfs:comment 'The scheduled or actual timestamp when check-in closed for this flight. Used to determine if passenger checked in before the cutoff time.' ;
    rdfs:domain ind:CheckInEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:checkInConfirmationCode rdf:type rdf:Property ;
    rdfs:label 'Check In Confirmation Code' ;
    rdfs:comment 'Unique confirmation code or reference number generated upon successful check-in completion, provided to the passenger.' ;
    rdfs:domain ind:CheckInEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkInRemarks rdf:type rdf:Property ;
    rdfs:label 'Check In Remarks' ;
    rdfs:comment 'Free-text remarks or notes recorded by the agent or system during check-in, capturing special circumstances, passenger requests, or operational notes.' ;
    rdfs:domain ind:CheckInEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkInStationCode rdf:type rdf:Property ;
    rdfs:label 'Check In Station Code' ;
    rdfs:comment 'Three-letter IATA airport code or city code where the check-in transaction was performed.' ;
    rdfs:domain ind:CheckInEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkedBaggageWeightKg rdf:type rdf:Property ;
    rdfs:label 'Checked Baggage Weight Kg' ;
    rdfs:comment 'Total weight in kilograms of all checked baggage for this passenger during check-in.' ;
    rdfs:domain ind:CheckInEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:checkedBagsCount rdf:type rdf:Property ;
    rdfs:label 'Checked Bags Count' ;
    rdfs:comment 'The total number of bags checked by the passenger during this check-in event.' ;
    rdfs:domain ind:CheckInEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:documentVerificationStatus rdf:type rdf:Property ;
    rdfs:label 'Document Verification Status' ;
    rdfs:comment 'Status of travel document verification (passport, visa, ID) performed during check-in to ensure compliance with destination country requirements.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:excessBaggageFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Excess Baggage Fee Amount' ;
    rdfs:comment 'The fee charged for excess baggage beyond the allowed free baggage allowance. Zero if no excess baggage fee was applied.' ;
    rdfs:domain ind:CheckInEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:excessBaggageFeeCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Excess Baggage Fee Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the excess baggage fee amount.' ;
    rdfs:domain ind:CheckInEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minutesBeforeDeparture rdf:type rdf:Property ;
    rdfs:label 'Minutes Before Departure' ;
    rdfs:comment 'The number of minutes before scheduled departure time that the passenger completed check-in. Used for OTP analysis and no-show prediction.' ;
    rdfs:domain ind:CheckInEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mobileBoardingPassIssuedFlag rdf:type rdf:Property ;
    rdfs:label 'Mobile Boarding Pass Issued Flag' ;
    rdfs:comment 'Boolean indicator of whether a mobile boarding pass was issued to the passenger\'s mobile device during check-in.' ;
    rdfs:domain ind:CheckInEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:seatAssignment rdf:type rdf:Property ;
    rdfs:label 'Seat Assignment' ;
    rdfs:comment 'The seat number assigned to the passenger during check-in (e.g., 12A, 23F). May be null if seat assignment is deferred.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upgradeAtCheckInFlag rdf:type rdf:Property ;
    rdfs:label 'Upgrade At Check In Flag' ;
    rdfs:comment 'Boolean indicator of whether the passenger received a cabin class upgrade during the check-in process.' ;
    rdfs:domain ind:CheckInEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:upgradedCabinClass rdf:type rdf:Property ;
    rdfs:label 'Upgraded Cabin Class' ;
    rdfs:comment 'The cabin class to which the passenger was upgraded during check-in (e.g., Business, First). Null if no upgrade occurred.' ;
    rdfs:domain ind:CheckInEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:couponStatusId rdf:type rdf:Property ;
    rdfs:label 'Coupon Status Id' ;
    rdfs:comment 'Unique identifier for the coupon status record. Primary key.' ;
    rdfs:domain ind:CouponStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:baggageAllowance rdf:type rdf:Property ;
    rdfs:label 'Baggage Allowance' ;
    rdfs:comment 'Baggage allowance applicable to this coupon segment (e.g., 2PC, 23KG, 1PC).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkedInTimestamp rdf:type rdf:Property ;
    rdfs:label 'Checked In Timestamp' ;
    rdfs:comment 'Timestamp when the passenger checked in for the flight segment covered by this coupon.' ;
    rdfs:domain ind:CouponStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:couponStatusCode rdf:type rdf:Property ;
    rdfs:label 'Coupon Status Code' ;
    rdfs:comment 'Current lifecycle status of the coupon: O=Open for Use, F=Flown/Used, L=Lifted/Boarded, A=Airport Control, C=Checked In, V=Void, E=Exchanged, R=Refunded, I=Irregular Operations, S=Suspended, U=Unavailable, P=Printed, Z=Archived. [ENUM-REF-CANDIDATE: O|F|L|A|C|V|E|R|I|S|U|P|Z — 13 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CouponStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:couponStatusDescription rdf:type rdf:Property ;
    rdfs:label 'Coupon Status Description' ;
    rdfs:comment 'Human-readable description of the current coupon status.' ;
    rdfs:domain ind:CouponStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeTimestamp rdf:type rdf:Property ;
    rdfs:label 'Exchange Timestamp' ;
    rdfs:comment 'Timestamp when the coupon was exchanged for a new ticket or itinerary.' ;
    rdfs:domain ind:CouponStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:flownDate rdf:type rdf:Property ;
    rdfs:label 'Flown Date' ;
    rdfs:comment 'The actual date the passenger flew on this coupon segment, in yyyy-MM-dd format. Null if not yet flown.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:flownTimestamp rdf:type rdf:Property ;
    rdfs:label 'Flown Timestamp' ;
    rdfs:comment 'The precise timestamp when the coupon was marked as flown/used, typically at gate closure or boarding completion.' ;
    rdfs:domain ind:CouponStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:gdsRecordLocator rdf:type rdf:Property ;
    rdfs:label 'Gds Record Locator' ;
    rdfs:comment 'Six-character alphanumeric GDS (Global Distribution System) record locator associated with this coupon booking.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liftedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Lifted Timestamp' ;
    rdfs:comment 'Timestamp when the coupon was lifted (passenger boarded the aircraft), per IATA coupon lifecycle.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:notValidAfterDate rdf:type rdf:Property ;
    rdfs:label 'Not Valid After Date' ;
    rdfs:comment 'Latest date this coupon is valid for travel, per fare rules, in yyyy-MM-dd format.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:notValidBeforeDate rdf:type rdf:Property ;
    rdfs:label 'Not Valid Before Date' ;
    rdfs:comment 'Earliest date this coupon is valid for travel, per fare rules, in yyyy-MM-dd format.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originalTicketNumber rdf:type rdf:Property ;
    rdfs:label 'Original Ticket Number' ;
    rdfs:comment 'The original ticket number if this coupon was reissued or exchanged from a prior ticket.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousStatusCode rdf:type rdf:Property ;
    rdfs:label 'Previous Status Code' ;
    rdfs:comment 'The coupon status code immediately prior to the current status, enabling status transition tracking.' ;
    rdfs:domain ind:CouponStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reissueIndicator rdf:type rdf:Property ;
    rdfs:label 'Reissue Indicator' ;
    rdfs:comment 'Flag indicating whether this coupon was reissued as part of a ticket exchange or voluntary change.' ;
    rdfs:domain ind:CouponStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:statusChangeReasonCode rdf:type rdf:Property ;
    rdfs:label 'Status Change Reason Code' ;
    rdfs:comment 'Code indicating the reason for the status change (e.g., passenger no-show, voluntary change, involuntary reroute, schedule change).' ;
    rdfs:domain ind:CouponStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusChangeReasonText rdf:type rdf:Property ;
    rdfs:label 'Status Change Reason Text' ;
    rdfs:comment 'Free-text description providing additional context for the status change.' ;
    rdfs:domain ind:CouponStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusChangeTimestamp rdf:type rdf:Property ;
    rdfs:label 'Status Change Timestamp' ;
    rdfs:comment 'Date and time when the coupon status was last changed, in ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX).' ;
    rdfs:domain ind:CouponStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:validatingCarrierCode rdf:type rdf:Property ;
    rdfs:label 'Validating Carrier Code' ;
    rdfs:comment 'IATA two-character code of the airline responsible for validating and settling this coupon.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:voidTimestamp rdf:type rdf:Property ;
    rdfs:label 'Void Timestamp' ;
    rdfs:comment 'Timestamp when the coupon was voided, if applicable.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eTicketId rdf:type rdf:Property ;
    rdfs:label 'E Ticket Id' ;
    rdfs:comment 'Primary key for e_ticket' ;
    rdfs:domain ind:ETicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:baseFareAmount rdf:type rdf:Property ;
    rdfs:label 'Base Fare Amount' ;
    rdfs:comment 'Base fare amount for the ticket before taxes and fees. Represents the airline\'s revenue portion of the ticket price.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conjunctionTicketIndicator rdf:type rdf:Property ;
    rdfs:label 'Conjunction Ticket Indicator' ;
    rdfs:comment 'Flag indicating whether this ticket is part of a conjunction ticket set (multiple tickets issued together for a single journey exceeding 4 flight coupons).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conjunctionTicketNumbers rdf:type rdf:Property ;
    rdfs:label 'Conjunction Ticket Numbers' ;
    rdfs:comment 'Comma-separated list of related conjunction ticket numbers if this ticket is part of a multi-ticket set. Empty if not a conjunction ticket.' ;
    rdfs:domain ind:ETicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equivalentCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Equivalent Currency Code' ;
    rdfs:comment 'ISO 4217 3-letter currency code for the equivalent fare amount. Null if no currency conversion was applied.' ;
    rdfs:domain ind:ETicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equivalentFareAmount rdf:type rdf:Property ;
    rdfs:label 'Equivalent Fare Amount' ;
    rdfs:comment 'Fare amount converted to the currency of the country of commencement of travel, if different from ticket currency. Used for settlement purposes.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exchangeDate rdf:type rdf:Property ;
    rdfs:label 'Exchange Date' ;
    rdfs:comment 'Date when the ticket was exchanged for a new ticket. Null if ticket has not been exchanged.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeTicketIndicator rdf:type rdf:Property ;
    rdfs:label 'Exchange Ticket Indicator' ;
    rdfs:comment 'Flag indicating whether this ticket was issued as an exchange for a previous ticket. True if this is a reissued ticket.' ;
    rdfs:domain ind:ETicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:formOfPaymentDetails rdf:type rdf:Property ;
    rdfs:label 'Form Of Payment Details' ;
    rdfs:comment 'Detailed payment information including masked card number, approval code, or account reference. Sensitive financial data stored according to PCI-DSS requirements.' ;
    rdfs:domain ind:ETicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formOfPaymentType rdf:type rdf:Property ;
    rdfs:label 'Form Of Payment Type' ;
    rdfs:comment 'Primary payment method used to purchase the ticket. Identifies how the passenger paid for the ticket. [ENUM-REF-CANDIDATE: CASH|CREDIT_CARD|DEBIT_CARD|VOUCHER|MILES|CORPORATE_ACCOUNT|INVOICE — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inConnectionWithTicket rdf:type rdf:Property ;
    rdfs:label 'In Connection With Ticket' ;
    rdfs:comment 'Ticket number of a related ticket when this ticket is issued in connection with another (e.g., companion ticket, family booking). Null if standalone.' ;
    rdfs:domain ind:ETicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ticketDesignator rdf:type rdf:Property ;
    rdfs:label 'Ticket Designator' ;
    rdfs:comment 'Special fare qualifier or corporate discount code applied to the ticket. Used for negotiated corporate rates or promotional fares.' ;
    rdfs:domain ind:ETicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ticketStatus rdf:type rdf:Property ;
    rdfs:label 'Ticket Status' ;
    rdfs:comment 'Current lifecycle status of the electronic ticket. OPEN=valid for travel, USED=travel completed, VOID=cancelled before use, REFUNDED=refund processed, EXCHANGED=replaced by new ticket, SUSPENDED=temporarily invalid.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:voidDate rdf:type rdf:Property ;
    rdfs:label 'Void Date' ;
    rdfs:comment 'Date when the ticket was voided. Null if ticket has not been voided. Voiding typically occurs within 24 hours of issuance.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originalFareQuoteId rdf:type rdf:Property ;
    rdfs:label 'Original Fare Quote Id' ;
    rdfs:comment 'Reference to the original fare quote ID if this is a repricing. Null for original quotes.' ;
    rdfs:domain ind:FareQuote ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FareQuote .

ind:endorsementText rdf:type rdf:Property ;
    rdfs:label 'Endorsement Text' ;
    rdfs:comment 'Free-text endorsement or restriction box content printed on the ticket, specifying fare rules, non-refundable conditions, or carrier restrictions.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fareBasisSummary rdf:type rdf:Property ;
    rdfs:label 'Fare Basis Summary' ;
    rdfs:comment 'Concatenated or summarized list of fare basis codes applied across all segments in this quote (e.g., YLOW/YLOW/MLOW). Detailed segment-level fare basis stored in related segment records.' ;
    rdfs:domain ind:FareQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fareCalculationLine rdf:type rdf:Property ;
    rdfs:label 'Fare Calculation Line' ;
    rdfs:comment 'Encoded fare construction string showing city pairs, fare basis codes, and amounts per IATA fare calculation standards. Used for ticket validation and interline proration.' ;
    rdfs:domain ind:FareQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fareQuoteNumber rdf:type rdf:Property ;
    rdfs:label 'Fare Quote Number' ;
    rdfs:comment 'Business identifier for the fare quote, typically assigned by the PSS (Passenger Service System) or GDS (Global Distribution System) at time of pricing.' ;
    rdfs:domain ind:FareQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fareQuoteStatus rdf:type rdf:Property ;
    rdfs:label 'Fare Quote Status' ;
    rdfs:comment 'Current lifecycle status of the fare quote: active (valid for ticketing), ticketed (converted to ticket), expired (past TTL), repriced (superseded by new quote), cancelled, or voided.' ;
    rdfs:domain ind:FareQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:platingCarrierCode rdf:type rdf:Property ;
    rdfs:label 'Plating Carrier Code' ;
    rdfs:comment 'Two-character IATA code of the airline whose ticket stock (plate) will be used to issue the ticket. May differ from validating carrier in interline scenarios.' ;
    rdfs:domain ind:FareQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingCommand rdf:type rdf:Property ;
    rdfs:label 'Pricing Command' ;
    rdfs:comment 'The cryptic command or API call used to generate this fare quote (e.g., FXP, WPNC, pricing modifiers). Used for audit and repricing.' ;
    rdfs:domain ind:FareQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingDate rdf:type rdf:Property ;
    rdfs:label 'Pricing Date' ;
    rdfs:comment 'Date when the fare quote was calculated and stored. Critical for fare validity and repricing scenarios.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pricingSource rdf:type rdf:Property ;
    rdfs:label 'Pricing Source' ;
    rdfs:comment 'Channel or system from which the fare quote was retrieved: GDS (Global Distribution System), NDC (New Distribution Capability), direct airline system, metasearch engine, OTA (Online Travel Agency), or consolidator.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pricing Timestamp' ;
    rdfs:comment 'Precise timestamp when the fare quote was generated, including time zone. Used for ticketing time limit enforcement and audit trails.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:privateFareIndicator rdf:type rdf:Property ;
    rdfs:label 'Private Fare Indicator' ;
    rdfs:comment 'Flag indicating whether this fare quote uses a private or negotiated fare (true) versus a published public fare (false).' ;
    rdfs:domain ind:FareQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:promotionalCode rdf:type rdf:Property ;
    rdfs:label 'Promotional Code' ;
    rdfs:comment 'Promotional or discount code applied at time of pricing to obtain special fare rates.' ;
    rdfs:domain ind:FareQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repricingIndicator rdf:type rdf:Property ;
    rdfs:label 'Repricing Indicator' ;
    rdfs:comment 'Flag indicating whether this fare quote is a repricing of a previous quote (true) or an original pricing (false).' ;
    rdfs:domain ind:FareQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ticketingTimeLimit rdf:type rdf:Property ;
    rdfs:label 'Ticketing Time Limit' ;
    rdfs:comment 'Deadline by which the ticket must be issued to honor this fare quote. After this time, the PNR may be cancelled or repriced.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:totalSurchargeAmount rdf:type rdf:Property ;
    rdfs:label 'Total Surcharge Amount' ;
    rdfs:comment 'Sum of all carrier-imposed surcharges including YQ (fuel surcharge) and YR (carrier surcharge) codes.' ;
    rdfs:domain ind:FareQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Total Tax Amount' ;
    rdfs:comment 'Sum of all government taxes, airport fees, and regulatory charges applicable to this fare quote.' ;
    rdfs:domain ind:FareQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:groupBookingId rdf:type rdf:Property ;
    rdfs:label 'Group Booking Id' ;
    rdfs:comment 'Unique identifier for the group booking record. Primary key for coordinated reservations of 10+ passengers travelling together under a single group contract.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GroupBooking .

ind:depositDueDate rdf:type rdf:Property ;
    rdfs:label 'Deposit Due Date' ;
    rdfs:comment 'Deadline by which the deposit payment must be received to maintain the group booking option or confirmation status.' ;
    rdfs:domain ind:GroupBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:depositReceivedFlag rdf:type rdf:Property ;
    rdfs:label 'Deposit Received Flag' ;
    rdfs:comment 'Indicator of whether the required deposit payment has been received and processed. True indicates deposit obligation fulfilled.' ;
    rdfs:domain ind:GroupBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:groupBookingStatus rdf:type rdf:Property ;
    rdfs:label 'Group Booking Status' ;
    rdfs:comment 'Current lifecycle status of the group booking indicating progression through reservation, confirmation, ticketing, and fulfillment stages.' ;
    rdfs:domain ind:GroupBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupCoordinatorEmail rdf:type rdf:Property ;
    rdfs:label 'Group Coordinator Email' ;
    rdfs:comment 'Primary email address of the group coordinator for all booking communications, updates, and documentation delivery.' ;
    rdfs:domain ind:GroupBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupCoordinatorName rdf:type rdf:Property ;
    rdfs:label 'Group Coordinator Name' ;
    rdfs:comment 'Full name of the primary contact person responsible for coordinating the group booking on behalf of the organizing entity.' ;
    rdfs:domain ind:GroupBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupCoordinatorPhone rdf:type rdf:Property ;
    rdfs:label 'Group Coordinator Phone' ;
    rdfs:comment 'Primary contact phone number for the group coordinator. Used for urgent communications and operational coordination.' ;
    rdfs:domain ind:GroupBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nameListDeadline rdf:type rdf:Property ;
    rdfs:label 'Name List Deadline' ;
    rdfs:comment 'Deadline by which the complete passenger name list must be submitted to the airline. Critical for inventory management and seat release policies.' ;
    rdfs:domain ind:GroupBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:negotiatedFareAmount rdf:type rdf:Property ;
    rdfs:label 'Negotiated Fare Amount' ;
    rdfs:comment 'Contracted fare amount per passenger for the group booking. Represents the negotiated rate agreed between the airline and group organizer.' ;
    rdfs:domain ind:GroupBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pnrLocatorList rdf:type rdf:Property ;
    rdfs:label 'Pnr Locator List' ;
    rdfs:comment 'Comma-separated list of PNR record locators associated with individual passenger bookings within this group. Links group master record to individual reservations.' ;
    rdfs:domain ind:GroupBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seatsNamed rdf:type rdf:Property ;
    rdfs:label 'Seats Named' ;
    rdfs:comment 'Number of seats for which passenger names have been provided and assigned. Tracks name list completion progress against contracted seats.' ;
    rdfs:domain ind:GroupBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:specialServiceRequirements rdf:type rdf:Property ;
    rdfs:label 'Special Service Requirements' ;
    rdfs:comment 'Consolidated list of special service requests applicable to the group, such as meal preferences, accessibility needs, or equipment requirements.' ;
    rdfs:domain ind:GroupBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalSeatsContracted rdf:type rdf:Property ;
    rdfs:label 'Total Seats Contracted' ;
    rdfs:comment 'Total number of seats allocated and contracted for the group booking. Represents the inventory commitment made by the airline to the group organizer.' ;
    rdfs:domain ind:GroupBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actionCode rdf:type rdf:Property ;
    rdfs:label 'Action Code' ;
    rdfs:comment 'Transaction action code representing the booking action taken. NN=Need, HN=Have need, HK=Holding confirmed, KK=Confirmed, UC=Unable to confirm, UN=Unable need, NO=No action, HL=Have waitlist, KL=Confirmed from waitlist, TK=Schedule change confirmed, TL=Schedule change waitlist, HX=Have cancel, XX=Cancel confirmed, WK=Waitlist, RQ=On request. [ENUM-REF-CANDIDATE: NN|HN|HK|KK|UC|UN|NO|HL|KL|TK|TL|HX|XX|WK|RQ — 15 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ItinerarySegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookingChannelCode rdf:type rdf:Property ;
    rdfs:label 'Booking Channel Code' ;
    rdfs:comment 'Channel through which this segment was booked. GDS=Global Distribution System, WEB=Website, MOB=Mobile App, CTO=City Ticket Office, RES=Reservations Call Center, API=Direct API.' ;
    rdfs:domain ind:ItinerarySegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flownIndicator rdf:type rdf:Property ;
    rdfs:label 'Flown Indicator' ;
    rdfs:comment 'Flag indicating whether the passenger has completed travel on this segment. Set to true after departure or boarding confirmation.' ;
    rdfs:domain ind:ItinerarySegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gdsPccCode rdf:type rdf:Property ;
    rdfs:label 'Gds Pcc Code' ;
    rdfs:comment 'GDS Pseudo City Code identifying the travel agency or corporate booking location that created this segment reservation.' ;
    rdfs:domain ind:ItinerarySegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marriageGroupIndicator rdf:type rdf:Property ;
    rdfs:label 'Marriage Group Indicator' ;
    rdfs:comment 'Single-letter code grouping segments that must be priced together as a married segment. Segments with the same indicator are married for fare construction.' ;
    rdfs:domain ind:ItinerarySegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberOfSeats rdf:type rdf:Property ;
    rdfs:label 'Number Of Seats' ;
    rdfs:comment 'Quantity of seats booked on this segment for the associated passengers in the PNR.' ;
    rdfs:domain ind:ItinerarySegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:segmentCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Segment Created Timestamp' ;
    rdfs:comment 'Date and time when this segment was first added to the PNR in the reservation system.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:segmentMileage rdf:type rdf:Property ;
    rdfs:label 'Segment Mileage' ;
    rdfs:comment 'Great circle distance in miles between departure and arrival airports. Used for fare construction and frequent flyer accrual.' ;
    rdfs:domain ind:ItinerarySegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:segmentModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Segment Modified Timestamp' ;
    rdfs:comment 'Date and time when this segment was last modified (status change, schedule change, or other update).' ;
    rdfs:domain ind:ItinerarySegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:segmentSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Segment Sequence Number' ;
    rdfs:comment 'Sequential ordering of this segment within the PNR itinerary. Determines the travel flow from origin to final destination.' ;
    rdfs:domain ind:ItinerarySegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:segmentStatusCode rdf:type rdf:Property ;
    rdfs:label 'Segment Status Code' ;
    rdfs:comment 'Current reservation status of the segment. HK=Confirmed, KK=Confirmed by carrier, KL=Confirmed waitlist cleared, HL=Have requested waitlist, UN=Unable to confirm, UC=Unable to accept, NO=No action taken, WK=Waitlisted, RQ=Requested, TK=Schedule change confirmed, TL=Schedule change waitlist. [ENUM-REF-CANDIDATE: HK|KK|KL|HL|UN|UC|NO|WK|RQ|TK|TL — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ItinerarySegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stopoverIndicator rdf:type rdf:Property ;
    rdfs:label 'Stopover Indicator' ;
    rdfs:comment 'Flag indicating whether this segment represents a stopover (stay exceeding MCT) versus a connection in the passenger journey.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bookingSource rdf:type rdf:Property ;
    rdfs:label 'Booking Source' ;
    rdfs:comment 'Origin system or channel through which the PNR was created. Distinguishes between GDS (Global Distribution System), direct airline channels, NDC (New Distribution Capability), call center, mobile app, web, or airport kiosk. [ENUM-REF-CANDIDATE: gds|direct|ndc|call_center|mobile_app|web|kiosk — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookingType rdf:type rdf:Property ;
    rdfs:label 'Booking Type' ;
    rdfs:comment 'Classification of the booking based on passenger type and commercial arrangement. Distinguishes individual, group, corporate contract, interline, and codeshare bookings.' ;
    rdfs:domain ind:Pnr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:corporateAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Corporate Account Number' ;
    rdfs:comment 'Corporate discount or contract account number associated with the booking. Used for negotiated fare application and corporate reporting.' ;
    rdfs:domain ind:Pnr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creatingAgentSign rdf:type rdf:Property ;
    rdfs:label 'Creating Agent Sign' ;
    rdfs:comment 'Agent sign or user ID of the individual who created the PNR. Used for audit trail and quality control.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Creation Timestamp' ;
    rdfs:comment 'Date and time when the PNR was first created in the reservation system. Represents the initial booking event. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:destinationCityCode rdf:type rdf:Property ;
    rdfs:label 'Destination City Code' ;
    rdfs:comment 'Three-letter IATA city code for the final arrival point in the itinerary. Used for origin-destination (O&D) analysis.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formOfPaymentSummary rdf:type rdf:Property ;
    rdfs:label 'Form Of Payment Summary' ;
    rdfs:comment 'Summary description of the payment method(s) used for this PNR. May include credit card type, cash, voucher, or multiple forms of payment. Detailed payment data stored separately for PCI compliance.' ;
    rdfs:domain ind:Pnr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifyingAgentSign rdf:type rdf:Property ;
    rdfs:label 'Last Modifying Agent Sign' ;
    rdfs:comment 'Agent sign or user ID of the individual who last modified the PNR. Updated with each change for audit trail.' ;
    rdfs:domain ind:Pnr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originCityCode rdf:type rdf:Property ;
    rdfs:label 'Origin City Code' ;
    rdfs:comment 'Three-letter IATA city code for the first departure point in the itinerary. Used for origin-destination (O&D) analysis.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pointOfSaleCity rdf:type rdf:Property ;
    rdfs:label 'Point Of Sale City' ;
    rdfs:comment 'Three-letter IATA city code representing the city where the booking was made. Used for market analysis and revenue management.' ;
    rdfs:domain ind:Pnr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purgeDate rdf:type rdf:Property ;
    rdfs:label 'Purge Date' ;
    rdfs:comment 'Date when the PNR is scheduled to be purged or archived from the active reservation system. Typically set based on last travel date plus retention period. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Pnr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:queueNumber rdf:type rdf:Property ;
    rdfs:label 'Queue Number' ;
    rdfs:comment 'PSS queue number where the PNR is currently placed for agent action. Used for workflow management and ticketing time limit monitoring.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordLocator rdf:type rdf:Property ;
    rdfs:label 'Record Locator' ;
    rdfs:comment 'Six-character alphanumeric code uniquely identifying the PNR across systems. The externally-known business identifier used by agents, passengers, and partner systems. Also known as booking reference or confirmation code.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentCount rdf:type rdf:Property ;
    rdfs:label 'Segment Count' ;
    rdfs:comment 'Total number of flight segments (legs) included in this PNR itinerary. Each flight leg is counted separately.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ticketedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ticketed Timestamp' ;
    rdfs:comment 'Date and time when the PNR was ticketed (e-ticket issued). Null if not yet ticketed. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Pnr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:tripType rdf:type rdf:Property ;
    rdfs:label 'Trip Type' ;
    rdfs:comment 'Type of itinerary structure. One-way (single segment), round-trip (outbound and return), multi-city (multiple destinations), or open-jaw (different origin/destination for outbound and return).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pnrHistoryId rdf:type rdf:Property ;
    rdfs:label 'Pnr History Id' ;
    rdfs:comment 'Unique identifier for each PNR history entry. Primary key. Inferred role: EVENT_LOG.' ;
    rdfs:domain ind:PnrHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:agentSign rdf:type rdf:Property ;
    rdfs:label 'Agent Sign' ;
    rdfs:comment 'Agent sine or user identifier of the person or system that performed the PNR modification. Used for accountability and audit trail.' ;
    rdfs:domain ind:PnrHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeReasonText rdf:type rdf:Property ;
    rdfs:label 'Change Reason Text' ;
    rdfs:comment 'Free-text description providing additional context or explanation for the PNR modification.' ;
    rdfs:domain ind:PnrHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeSource rdf:type rdf:Property ;
    rdfs:label 'Change Source' ;
    rdfs:comment 'Channel or system interface through which the PNR modification was initiated. Identifies the origin of the change for audit and analytics.' ;
    rdfs:domain ind:PnrHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fieldName rdf:type rdf:Property ;
    rdfs:label 'Field Name' ;
    rdfs:comment 'Name of the PNR field or element that was modified. Identifies the specific data element affected by this change.' ;
    rdfs:domain ind:PnrHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:historyEntryType rdf:type rdf:Property ;
    rdfs:label 'History Entry Type' ;
    rdfs:comment 'Type of PNR modification captured in this history entry. Discriminates the nature of the change event. [ENUM-REF-CANDIDATE: segment_add|segment_cancel|segment_modify|name_change|ticket_issuance|ticket_void|remark_add|remark_delete|ssr_add|ssr_cancel|seat_assignment|seat_change|payment_add|payment_modify|contact_change|split_pnr|merge_pnr|queue_placement|queue_removal|fare_quote|price_override|commission_override|endorsement_add|form_of_payment_change|ticketing_time_limit_set|ticketing_time_limit_extend|group_allocation|waitlist_add|waitlist_confirm|upgrade_request|upgrade_confirm — promote to reference product]' ;
    rdfs:domain ind:PnrHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:historySequenceNumber rdf:type rdf:Property ;
    rdfs:label 'History Sequence Number' ;
    rdfs:comment 'Sequential ordering number of this history entry within the PNR lifecycle. Enables chronological reconstruction of all changes.' ;
    rdfs:domain ind:PnrHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isAutomatedChange rdf:type rdf:Property ;
    rdfs:label 'Is Automated Change' ;
    rdfs:comment 'Boolean flag indicating whether this change was performed by an automated system process rather than manual agent action. True=automated, False=manual.' ;
    rdfs:domain ind:PnrHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:officeIataNumber rdf:type rdf:Property ;
    rdfs:label 'Office Iata Number' ;
    rdfs:comment 'IATA-assigned office identification number where the change was made. 9-character alphanumeric code identifying the travel agency or airline office.' ;
    rdfs:domain ind:PnrHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oldValue rdf:type rdf:Property ;
    rdfs:label 'Old Value' ;
    rdfs:comment 'Previous value of the field before the modification. Captures the before-state for audit comparison and rollback capability.' ;
    rdfs:domain ind:PnrHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:passengerNumber rdf:type rdf:Property ;
    rdfs:label 'Passenger Number' ;
    rdfs:comment 'Passenger sequence number within the PNR that was affected by this change. Null if change applies to all passengers.' ;
    rdfs:domain ind:PnrHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:remarkText rdf:type rdf:Property ;
    rdfs:label 'Remark Text' ;
    rdfs:comment 'Free-text remark or note added or modified in this change. Captures agent comments and special instructions.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentNumber rdf:type rdf:Property ;
    rdfs:label 'Segment Number' ;
    rdfs:comment 'Flight segment number within the PNR itinerary that was affected by this change. Null if change applies to entire PNR rather than specific segment.' ;
    rdfs:domain ind:PnrHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pnrRemarkId rdf:type rdf:Property ;
    rdfs:label 'Pnr Remark Id' ;
    rdfs:comment 'Unique identifier for the PNR remark element. Primary key.' ;
    rdfs:domain ind:PnrRemark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:associatedPassengerNumber rdf:type rdf:Property ;
    rdfs:label 'Associated Passenger Number' ;
    rdfs:comment 'Passenger sequence number within the PNR to which this remark applies. Null if the remark applies to all passengers or the booking as a whole.' ;
    rdfs:domain ind:PnrRemark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:associatedSegmentNumber rdf:type rdf:Property ;
    rdfs:label 'Associated Segment Number' ;
    rdfs:comment 'Flight segment number within the PNR to which this remark applies. Null if the remark applies to the entire PNR rather than a specific segment.' ;
    rdfs:domain ind:PnrRemark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:creatingOfficeIataNumber rdf:type rdf:Property ;
    rdfs:label 'Creating Office Iata Number' ;
    rdfs:comment 'Nine-character IATA office identifier (Office ID) of the agency or airline office that created this remark. Format: 4-character city code + 5-character office identifier.' ;
    rdfs:domain ind:PnrRemark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deletingAgentSign rdf:type rdf:Property ;
    rdfs:label 'Deleting Agent Sign' ;
    rdfs:comment 'Agent sign-in code or initials of the individual who deleted this remark element. Null if remark is active.' ;
    rdfs:domain ind:PnrRemark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deletingOfficeIataNumber rdf:type rdf:Property ;
    rdfs:label 'Deleting Office Iata Number' ;
    rdfs:comment 'Nine-character IATA office identifier of the agency or airline office that deleted this remark. Null if remark is active.' ;
    rdfs:domain ind:PnrRemark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Deletion Timestamp' ;
    rdfs:comment 'Date and time when this remark element was deleted or marked inactive. Null for active remarks. Supports audit trail and historical analysis.' ;
    rdfs:domain ind:PnrRemark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isConfidential rdf:type rdf:Property ;
    rdfs:label 'Is Confidential' ;
    rdfs:comment 'Indicates whether this remark is restricted to specific user roles or offices. True for confidential remarks that should not be visible to all agents or external parties.' ;
    rdfs:domain ind:PnrRemark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPrintableOnItinerary rdf:type rdf:Property ;
    rdfs:label 'Is Printable On Itinerary' ;
    rdfs:comment 'Indicates whether this remark should appear on customer-facing itinerary documents. True for itinerary remarks; false for internal operational remarks.' ;
    rdfs:domain ind:PnrRemark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTransmittedToCarrier rdf:type rdf:Property ;
    rdfs:label 'Is Transmitted To Carrier' ;
    rdfs:comment 'Indicates whether this remark is transmitted to the operating carrier(s) via PNR distribution. True for OSI elements and operational remarks requiring carrier visibility.' ;
    rdfs:domain ind:PnrRemark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:modifyingAgentSign rdf:type rdf:Property ;
    rdfs:label 'Modifying Agent Sign' ;
    rdfs:comment 'Agent sign-in code or initials of the individual who last modified this remark element. Null if never modified.' ;
    rdfs:domain ind:PnrRemark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifyingOfficeIataNumber rdf:type rdf:Property ;
    rdfs:label 'Modifying Office Iata Number' ;
    rdfs:comment 'Nine-character IATA office identifier of the agency or airline office that last modified this remark. Null if never modified.' ;
    rdfs:domain ind:PnrRemark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:osiCarrierCode rdf:type rdf:Property ;
    rdfs:label 'Osi Carrier Code' ;
    rdfs:comment 'IATA two-letter or ICAO three-letter airline code identifying the carrier to which this OSI element is directed. Populated only when remark_type is \'osi\'.' ;
    rdfs:domain ind:PnrRemark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remarkCategory rdf:type rdf:Property ;
    rdfs:label 'Remark Category' ;
    rdfs:comment 'Business category or subject area of the remark (e.g., special service request, operational note, customer preference, billing instruction, ground handling instruction).' ;
    rdfs:domain ind:PnrRemark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remarkSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Remark Sequence Number' ;
    rdfs:comment 'Sequential ordering of this remark within the PNR. Used to maintain display order and support remark modification or deletion operations.' ;
    rdfs:domain ind:PnrRemark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:remarkSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Remark Source System' ;
    rdfs:comment 'Identifier of the system or channel that originated this remark (e.g., Amadeus, Sabre, direct entry, web booking, mobile app, GDS interface).' ;
    rdfs:domain ind:PnrRemark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remarkStatus rdf:type rdf:Property ;
    rdfs:label 'Remark Status' ;
    rdfs:comment 'Current lifecycle status of the remark element. Active remarks are visible and operational; deleted remarks are soft-deleted for audit purposes; archived remarks are retained for historical analysis.' ;
    rdfs:domain ind:PnrRemark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remarkType rdf:type rdf:Property ;
    rdfs:label 'Remark Type' ;
    rdfs:comment 'Classification of the remark element. General remarks are visible to all agents; confidential remarks are restricted; invoice remarks support billing; itinerary remarks appear on customer documents; OSI (Other Service Information) elements are directed to carriers; accounting remarks support financial reconciliation.' ;
    rdfs:domain ind:PnrRemark ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundTransactionId rdf:type rdf:Property ;
    rdfs:label 'Refund Transaction Id' ;
    rdfs:comment 'Primary key for refund_transaction' ;
    rdfs:domain ind:RefundTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:arcSettlementId rdf:type rdf:Property ;
    rdfs:label 'Arc Settlement Id' ;
    rdfs:comment 'Reference to the ARC settlement record for this refund transaction, used for financial reconciliation with ARC in the US market.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ArcSettlement .

ind:bspSettlementId rdf:type rdf:Property ;
    rdfs:label 'Bsp Settlement Id' ;
    rdfs:comment 'Reference to the BSP settlement record for this refund transaction, used for financial reconciliation with IATA BSP.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BspSettlement .

ind:feeRefundAmount rdf:type rdf:Property ;
    rdfs:label 'Fee Refund Amount' ;
    rdfs:comment 'The amount of carrier-imposed fees and surcharges being refunded.' ;
    rdfs:domain ind:RefundTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:milesRefunded rdf:type rdf:Property ;
    rdfs:label 'Miles Refunded' ;
    rdfs:comment 'Number of frequent flyer miles refunded to the passenger\'s FFP account, if refund method is miles.' ;
    rdfs:domain ind:RefundTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalEmdNumber rdf:type rdf:Property ;
    rdfs:label 'Original Emd Number' ;
    rdfs:comment 'The 13-digit EMD number of the original Electronic Miscellaneous Document being refunded, if applicable.' ;
    rdfs:domain ind:RefundTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalFareAmount rdf:type rdf:Property ;
    rdfs:label 'Original Fare Amount' ;
    rdfs:comment 'The original base fare amount from the ticket or EMD before any refund calculations.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalFormOfPayment rdf:type rdf:Property ;
    rdfs:label 'Original Form Of Payment' ;
    rdfs:comment 'The original payment method used when the ticket or EMD was purchased. [ENUM-REF-CANDIDATE: credit_card|debit_card|cash|bank_transfer|check|voucher|miles — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RefundTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Refund Approval Date' ;
    rdfs:comment 'Date when the refund was approved by the airline or authorized agent.' ;
    rdfs:domain ind:RefundTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:refundNotes rdf:type rdf:Property ;
    rdfs:label 'Refund Notes' ;
    rdfs:comment 'Free-text notes and comments regarding the refund transaction, including special circumstances or agent remarks.' ;
    rdfs:domain ind:RefundTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundProcessingDate rdf:type rdf:Property ;
    rdfs:label 'Refund Processing Date' ;
    rdfs:comment 'Date when the refund was fully processed and payment was issued or credited.' ;
    rdfs:domain ind:RefundTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:refundProcessingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Refund Processing Timestamp' ;
    rdfs:comment 'Precise timestamp when the refund processing was completed.' ;
    rdfs:domain ind:RefundTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:refundReasonCode rdf:type rdf:Property ;
    rdfs:label 'Refund Reason Code' ;
    rdfs:comment 'Standardized code indicating the business reason for the refund (e.g., schedule change, flight cancellation, passenger no-show, medical emergency, death in family, fare difference).' ;
    rdfs:domain ind:RefundTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Refund Reason Description' ;
    rdfs:comment 'Detailed textual explanation of the refund reason, providing additional context beyond the reason code.' ;
    rdfs:domain ind:RefundTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Refund Reference Number' ;
    rdfs:comment 'Unique business identifier for the refund transaction, used for customer communication and tracking.' ;
    rdfs:domain ind:RefundTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundRequestDate rdf:type rdf:Property ;
    rdfs:label 'Refund Request Date' ;
    rdfs:comment 'Date when the refund was requested by the passenger or initiated by the airline.' ;
    rdfs:domain ind:RefundTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:refundRequestTimestamp rdf:type rdf:Property ;
    rdfs:label 'Refund Request Timestamp' ;
    rdfs:comment 'Precise timestamp when the refund request was submitted or created in the system.' ;
    rdfs:domain ind:RefundTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:refundVoucherNumber rdf:type rdf:Property ;
    rdfs:label 'Refund Voucher Number' ;
    rdfs:comment 'Unique voucher number issued when refund method is voucher or credit shell, used for future travel redemption.' ;
    rdfs:domain ind:RefundTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalRefundAmount rdf:type rdf:Property ;
    rdfs:label 'Total Refund Amount' ;
    rdfs:comment 'The total refund amount including base fare refund, tax refund, and fee refund, after all deductions.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:voucherExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Voucher Expiry Date' ;
    rdfs:comment 'Expiration date of the refund voucher or credit shell, after which it cannot be redeemed.' ;
    rdfs:domain ind:RefundTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:waiverFlag rdf:type rdf:Property ;
    rdfs:label 'Waiver Flag' ;
    rdfs:comment 'Boolean indicator whether penalty waiver was applied to this refund transaction.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduleChangeNotificationId rdf:type rdf:Property ;
    rdfs:label 'Schedule Change Notification Id' ;
    rdfs:comment 'Unique identifier for the schedule change notification record. Primary key.' ;
    rdfs:domain ind:ScheduleChangeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalAircraftTypeId rdf:type rdf:Property ;
    rdfs:label 'Original Aircraft Type Id' ;
    rdfs:comment 'Foreign key linking to fleet.aircraft_type. Business justification: Schedule changes and IROPs often driven by aircraft swaps (gauge changes, maintenance substitutions). Tracking original vs new aircraft type is core to disruption management, passenger re-accommodatio' ;
    rdfs:domain ind:ScheduleChangeNotification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AircraftType .

ind:compensationEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Compensation Eligible Flag' ;
    rdfs:comment 'Indicates whether the schedule change qualifies the passenger for compensation under applicable regulations (true) or not (false).' ;
    rdfs:domain ind:ScheduleChangeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:impactSeverity rdf:type rdf:Property ;
    rdfs:label 'Impact Severity' ;
    rdfs:comment 'Business assessment of the schedule change impact on the passenger: minor (less than 30 minutes), moderate (30 minutes to 2 hours), major (more than 2 hours or missed connection), or cancellation (flight no longer operating).' ;
    rdfs:domain ind:ScheduleChangeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newAircraftTypeCode rdf:type rdf:Property ;
    rdfs:label 'New Aircraft Type Code' ;
    rdfs:comment 'Three-character IATA aircraft type code for the revised equipment after the change. Null if flight is cancelled or equipment unchanged.' ;
    rdfs:domain ind:ScheduleChangeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newArrivalAirportCode rdf:type rdf:Property ;
    rdfs:label 'New Arrival Airport Code' ;
    rdfs:comment 'Three-letter IATA airport code for the revised arrival airport. Null if flight is cancelled.' ;
    rdfs:domain ind:ScheduleChangeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newArrivalDatetime rdf:type rdf:Property ;
    rdfs:label 'New Arrival Datetime' ;
    rdfs:comment 'The revised arrival date and time in local airport time after the schedule change, formatted as yyyy-MM-ddTHH:mm:ss.SSSXXX. Null if flight is cancelled.' ;
    rdfs:domain ind:ScheduleChangeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:newDepartureAirportCode rdf:type rdf:Property ;
    rdfs:label 'New Departure Airport Code' ;
    rdfs:comment 'Three-letter IATA airport code for the revised departure airport. Null if flight is cancelled.' ;
    rdfs:domain ind:ScheduleChangeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newDepartureDatetime rdf:type rdf:Property ;
    rdfs:label 'New Departure Datetime' ;
    rdfs:comment 'The revised departure date and time in local airport time after the schedule change, formatted as yyyy-MM-ddTHH:mm:ss.SSSXXX. Null if flight is cancelled.' ;
    rdfs:domain ind:ScheduleChangeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:newFlightNumber rdf:type rdf:Property ;
    rdfs:label 'New Flight Number' ;
    rdfs:comment 'The revised flight number after the schedule change, formatted as two-character airline code followed by 1-4 digit flight number and optional suffix. Null if flight is cancelled.' ;
    rdfs:domain ind:ScheduleChangeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationChannel rdf:type rdf:Property ;
    rdfs:label 'Notification Channel' ;
    rdfs:comment 'Primary communication channel used to notify the passenger: email, SMS, GDS (Global Distribution System) message, travel agency notification, mobile app push notification, airport counter, or phone call. [ENUM-REF-CANDIDATE: email|sms|gds|travel_agency|mobile_app|airport_counter|phone_call — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ScheduleChangeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationNumber rdf:type rdf:Property ;
    rdfs:label 'Notification Number' ;
    rdfs:comment 'Externally-visible unique business identifier for the schedule change notification, formatted as SCN followed by 10 digits.' ;
    rdfs:domain ind:ScheduleChangeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationStatus rdf:type rdf:Property ;
    rdfs:label 'Notification Status' ;
    rdfs:comment 'Current lifecycle status of the notification: pending (queued for delivery), notified (successfully sent), acknowledged (passenger confirmed receipt), failed (delivery unsuccessful), or cancelled (notification voided).' ;
    rdfs:domain ind:ScheduleChangeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notificationType rdf:type rdf:Property ;
    rdfs:label 'Notification Type' ;
    rdfs:comment 'Category of schedule change that triggered the notification: schedule change (general), flight cancellation, equipment change (aircraft type swap), routing change (different flight path), time change (departure/arrival adjustment), or gate change.' ;
    rdfs:domain ind:ScheduleChangeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalArrivalAirportCode rdf:type rdf:Property ;
    rdfs:label 'Original Arrival Airport Code' ;
    rdfs:comment 'Three-letter IATA airport code for the original scheduled arrival airport.' ;
    rdfs:domain ind:ScheduleChangeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalArrivalDatetime rdf:type rdf:Property ;
    rdfs:label 'Original Arrival Datetime' ;
    rdfs:comment 'The originally scheduled arrival date and time in local airport time, formatted as yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:ScheduleChangeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:originalDepartureAirportCode rdf:type rdf:Property ;
    rdfs:label 'Original Departure Airport Code' ;
    rdfs:comment 'Three-letter IATA airport code for the original scheduled departure airport.' ;
    rdfs:domain ind:ScheduleChangeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalDepartureDatetime rdf:type rdf:Property ;
    rdfs:label 'Original Departure Datetime' ;
    rdfs:comment 'The originally scheduled departure date and time in local airport time, formatted as yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:ScheduleChangeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:originalFlightNumber rdf:type rdf:Property ;
    rdfs:label 'Original Flight Number' ;
    rdfs:comment 'The flight number as originally booked before the schedule change, formatted as two-character airline code followed by 1-4 digit flight number and optional suffix.' ;
    rdfs:domain ind:ScheduleChangeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passengerAcceptanceStatus rdf:type rdf:Property ;
    rdfs:label 'Passenger Acceptance Status' ;
    rdfs:comment 'Passenger response to the schedule change: accepted (passenger confirmed new itinerary), rejected (passenger declined and requested alternative), pending (awaiting passenger response), or auto_accepted (automatically accepted per policy after timeout period).' ;
    rdfs:domain ind:ScheduleChangeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passengerNotificationStatus rdf:type rdf:Property ;
    rdfs:label 'Passenger Notification Status' ;
    rdfs:comment 'Status of passenger notification delivery: notified (successfully delivered to passenger), pending (queued for delivery), failed (delivery attempt unsuccessful), or not_required (notification waived per business rules).' ;
    rdfs:domain ind:ScheduleChangeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reaccommodationAction rdf:type rdf:Property ;
    rdfs:label 'Reaccommodation Action' ;
    rdfs:comment 'Action taken to reaccommodate the passenger: none (no action required), rebooked (moved to different flight), refunded (ticket refunded), voucher_issued (travel credit provided), upgraded (moved to higher cabin class), or alternate_routing (rerouted via different city pair).' ;
    rdfs:domain ind:ScheduleChangeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reaccommodationFlightNumber rdf:type rdf:Property ;
    rdfs:label 'Reaccommodation Flight Number' ;
    rdfs:comment 'Flight number of the alternate flight if passenger was rebooked. Null if no rebooking occurred.' ;
    rdfs:domain ind:ScheduleChangeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeDifferenceMinutes rdf:type rdf:Property ;
    rdfs:label 'Time Difference Minutes' ;
    rdfs:comment 'Net change in departure time expressed in minutes. Positive values indicate delay, negative values indicate earlier departure. Null if flight is cancelled.' ;
    rdfs:domain ind:ScheduleChangeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:travelAgencyIataNumber rdf:type rdf:Property ;
    rdfs:label 'Travel Agency Iata Number' ;
    rdfs:comment 'Eight-digit IATA agency numeric code if the booking was made through a travel agency. Used for agency notification routing.' ;
    rdfs:domain ind:ScheduleChangeNotification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ssrId rdf:type rdf:Property ;
    rdfs:label 'Ssr Id' ;
    rdfs:comment 'Unique identifier for the special service request record. Primary key.' ;
    rdfs:domain ind:Ssr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Action Required Flag' ;
    rdfs:comment 'Indicates whether operational action is required by airline staff to fulfill this SSR (e.g., wheelchair provision, meal loading, document verification).' ;
    rdfs:domain ind:Ssr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:apisRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Apis Required Flag' ;
    rdfs:comment 'Indicates whether this SSR is required for APIS compliance (e.g., DOCS, DOCA, DOCO SSRs for border control and security).' ;
    rdfs:domain ind:Ssr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:chargeApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Charge Applicable Flag' ;
    rdfs:comment 'Indicates whether this SSR incurs a charge to the passenger (e.g., paid meal upgrade, pet in cabin fee). False for complimentary services.' ;
    rdfs:domain ind:Ssr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:freeText rdf:type rdf:Property ;
    rdfs:label 'Free Text' ;
    rdfs:comment 'Free-text field containing additional details or remarks associated with the SSR. May include passenger-specific instructions, medical details, or document numbers.' ;
    rdfs:domain ind:Ssr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interlineAgreementFlag rdf:type rdf:Property ;
    rdfs:label 'Interline Agreement Flag' ;
    rdfs:comment 'Indicates whether this SSR is subject to interline agreement terms between multiple carriers in a multi-carrier itinerary.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responsibleAirlineCode rdf:type rdf:Property ;
    rdfs:label 'Responsible Airline Code' ;
    rdfs:comment 'Two-character IATA airline code of the carrier responsible for fulfilling this SSR. Relevant for codeshare and interline bookings.' ;
    rdfs:domain ind:Ssr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:travelDocumentId rdf:type rdf:Property ;
    rdfs:label 'Travel Document Id' ;
    rdfs:comment 'Primary key for travel_document' ;
    rdfs:domain ind:TravelDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:apisResponseMessage rdf:type rdf:Property ;
    rdfs:label 'Apis Response Message' ;
    rdfs:comment 'Detailed response message received from the border control authority after APIS transmission. Contains error details or acceptance confirmation.' ;
    rdfs:domain ind:TravelDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apisTransmissionStatus rdf:type rdf:Property ;
    rdfs:label 'Apis Transmission Status' ;
    rdfs:comment 'Status of the APIS data transmission to the destination country border control authority. Tracks whether passenger travel document data has been successfully submitted and acknowledged.' ;
    rdfs:domain ind:TravelDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boardingEligibilityStatus rdf:type rdf:Property ;
    rdfs:label 'Boarding Eligibility Status' ;
    rdfs:comment 'Indicates whether the passenger is eligible to board based on travel document validation and APIS clearance. Used by gate agents and automated boarding systems.' ;
    rdfs:domain ind:TravelDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceValidationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Compliance Validation Timestamp' ;
    rdfs:comment 'Date and time when the travel document record was last validated for regulatory compliance.' ;
    rdfs:domain ind:TravelDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:documentIssueDate rdf:type rdf:Property ;
    rdfs:label 'Document Issue Date' ;
    rdfs:comment 'Date on which the travel document was issued by the issuing authority. Used for document validity verification.' ;
    rdfs:domain ind:TravelDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ineligibilityReason rdf:type rdf:Property ;
    rdfs:label 'Ineligibility Reason' ;
    rdfs:comment 'Detailed reason why the passenger is ineligible to board, if boarding_eligibility_status is ineligible. May include expired document, APIS rejection, or missing information.' ;
    rdfs:domain ind:TravelDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ssrDocsElement rdf:type rdf:Property ;
    rdfs:label 'Ssr Docs Element' ;
    rdfs:comment 'Raw SSR DOCS element string as received from the GDS or PSS. Contains structured travel document information in IATA format for APIS transmission.' ;
    rdfs:domain ind:TravelDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:voluntaryChangeId rdf:type rdf:Property ;
    rdfs:label 'Voluntary Change Id' ;
    rdfs:comment 'Unique identifier for the voluntary ticket change transaction. Primary key.' ;
    rdfs:domain ind:VoluntaryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:changeChannel rdf:type rdf:Property ;
    rdfs:label 'Change Channel' ;
    rdfs:comment 'Distribution channel through which the voluntary change was requested: web (airline website), mobile_app (airline mobile application), call_center (phone reservation center), airport_counter (airport ticket counter), travel_agent (travel agency), GDS (Global Distribution System), chatbot (automated chat assistant), or email (email request). [ENUM-REF-CANDIDATE: web|mobile_app|call_center|airport_counter|travel_agent|gds|chatbot|email — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:VoluntaryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeFeeWaiverCode rdf:type rdf:Property ;
    rdfs:label 'Change Fee Waiver Code' ;
    rdfs:comment 'Code indicating the reason for change fee waiver if applicable (e.g., FFP elite status, fare family benefit, promotional waiver, irregular operations). Null if no waiver applied.' ;
    rdfs:domain ind:VoluntaryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeProcessedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Change Processed Timestamp' ;
    rdfs:comment 'Date and time when the voluntary change was successfully processed and the new ticket was issued. Null if not yet completed. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:VoluntaryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:changeRequestTimestamp rdf:type rdf:Property ;
    rdfs:label 'Change Request Timestamp' ;
    rdfs:comment 'Date and time when the passenger initiated the voluntary change request. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:VoluntaryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:changeStatus rdf:type rdf:Property ;
    rdfs:label 'Change Status' ;
    rdfs:comment 'Current status of the voluntary change transaction in its lifecycle: pending (awaiting processing), processing (being handled), completed (successfully processed and new ticket issued), rejected (change request denied), cancelled (passenger cancelled the change request), or refunded (change reversed and fees refunded).' ;
    rdfs:domain ind:VoluntaryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fareDifferenceAmount rdf:type rdf:Property ;
    rdfs:label 'Fare Difference Amount' ;
    rdfs:comment 'Difference between the new fare and the original fare. Positive if new fare is higher (additional collection), negative if new fare is lower (refund due), zero if fares are equal.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fareRuleCategory rdf:type rdf:Property ;
    rdfs:label 'Fare Rule Category' ;
    rdfs:comment 'IATA fare rule category number governing the voluntary change (typically Category 16 for penalties/changes). Format: 1-2 digit number.' ;
    rdfs:domain ind:VoluntaryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formOfPaymentCode rdf:type rdf:Property ;
    rdfs:label 'Form Of Payment Code' ;
    rdfs:comment 'IATA standard form of payment code (e.g., CA for cash, CC for credit card, MS for miles, INV for invoice).' ;
    rdfs:domain ind:VoluntaryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newCabinClass rdf:type rdf:Property ;
    rdfs:label 'New Cabin Class' ;
    rdfs:comment 'Cabin class of the new ticket after the voluntary change. Null if cabin class was not changed.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newDepartureDate rdf:type rdf:Property ;
    rdfs:label 'New Departure Date' ;
    rdfs:comment 'Scheduled departure date of the new itinerary after the voluntary change. Null if departure date was not changed. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:VoluntaryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:newDestinationAirportCode rdf:type rdf:Property ;
    rdfs:label 'New Destination Airport Code' ;
    rdfs:comment 'Three-letter IATA airport code of the destination airport in the new itinerary. Null if routing was not changed.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newFareBasisCode rdf:type rdf:Property ;
    rdfs:label 'New Fare Basis Code' ;
    rdfs:comment 'Fare basis code of the new ticket after the voluntary change.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newOriginAirportCode rdf:type rdf:Property ;
    rdfs:label 'New Origin Airport Code' ;
    rdfs:comment 'Three-letter IATA airport code of the origin airport in the new itinerary. Null if routing was not changed.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newTicketNumber rdf:type rdf:Property ;
    rdfs:label 'New Ticket Number' ;
    rdfs:comment 'The 13-digit ticket number of the newly issued e-ticket after the voluntary change is processed.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalCabinClass rdf:type rdf:Property ;
    rdfs:label 'Original Cabin Class' ;
    rdfs:comment 'Cabin class of the original ticket: first (first class), business (business class), premium_economy (premium economy), or economy (economy class).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalDepartureDate rdf:type rdf:Property ;
    rdfs:label 'Original Departure Date' ;
    rdfs:comment 'Scheduled departure date of the original itinerary before the voluntary change. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originalDestinationAirportCode rdf:type rdf:Property ;
    rdfs:label 'Original Destination Airport Code' ;
    rdfs:comment 'Three-letter IATA airport code of the destination airport in the original itinerary.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalFareBasisCode rdf:type rdf:Property ;
    rdfs:label 'Original Fare Basis Code' ;
    rdfs:comment 'Fare basis code of the original ticket indicating fare type, booking class, and fare rules.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalOriginAirportCode rdf:type rdf:Property ;
    rdfs:label 'Original Origin Airport Code' ;
    rdfs:comment 'Three-letter IATA airport code of the origin airport in the original itinerary.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionReasonText rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason Text' ;
    rdfs:comment 'Free-text explanation of why the voluntary change was rejected. Null if not rejected.' ;
    rdfs:domain ind:VoluntaryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalAmountCollected rdf:type rdf:Property ;
    rdfs:label 'Total Amount Collected' ;
    rdfs:comment 'Total amount collected from the passenger for the voluntary change, including change fee and positive fare difference. Zero if no collection was required.' ;
    rdfs:domain ind:VoluntaryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalAmountRefunded rdf:type rdf:Property ;
    rdfs:label 'Total Amount Refunded' ;
    rdfs:comment 'Total amount refunded to the passenger if the new fare is lower than the original fare (after deducting change fee). Zero if no refund was issued.' ;
    rdfs:domain ind:VoluntaryChange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:admId rdf:type rdf:Property ;
    rdfs:label 'Adm Id' ;
    rdfs:comment 'Unique surrogate identifier for the Agency Debit Memo record in the lakehouse silver layer. Primary key for this entity.' ;
    rdfs:domain ind:Adm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:agencyId rdf:type rdf:Property ;
    rdfs:label 'Agency Id' ;
    rdfs:comment 'Foreign key linking to revenue.agency. Business justification: ADMs are issued to travel agencies. The agent_iata_code and agent_name attributes in adm should reference the authoritative agency master. Standard N:1 relationship. No bidirectional conflict. agent_i' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agency .

ind:admNumber rdf:type rdf:Property ;
    rdfs:label 'Adm Number' ;
    rdfs:comment 'Externally-known, human-readable ADM document number assigned by the issuing airline. Used as the primary reference in BSP/ARC settlement communications and agent correspondence. Typically follows IATA document numbering conventions.' ;
    rdfs:domain ind:Adm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorisedCommissionRate rdf:type rdf:Property ;
    rdfs:label 'Authorised Commission Rate' ;
    rdfs:comment 'The commission rate (decimal fraction) that the airline had authorised for the agent on this transaction. Compared against commission_rate to determine if a commission clawback ADM is warranted.' ;
    rdfs:domain ind:Adm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:collectedFareAmount rdf:type rdf:Property ;
    rdfs:label 'Collected Fare Amount' ;
    rdfs:comment 'The actual fare amount collected by the travel agent on the ticket transaction. The difference between original_fare_amount and collected_fare_amount typically constitutes the fare-difference ADM debit.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:debitAmount rdf:type rdf:Property ;
    rdfs:label 'Debit Amount' ;
    rdfs:comment 'Gross monetary amount being debited from the travel agent by this ADM, expressed in the settlement currency. Represents the principal financial claim before any adjustments or waivers.' ;
    rdfs:domain ind:Adm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Date' ;
    rdfs:comment 'Calendar date on which the travel agent formally submitted a dispute against this ADM. Null if the ADM has not been disputed. Used to verify dispute was raised within the allowable dispute window.' ;
    rdfs:domain ind:Adm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disputeDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Deadline Date' ;
    rdfs:comment 'Last calendar date by which the travel agent may formally dispute this ADM under IATA Resolution 850m or ARC rules. Calculated from the issue date per applicable BSP/ARC market rules. After this date, an undisputed ADM is deemed accepted.' ;
    rdfs:domain ind:Adm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disputeStatus rdf:type rdf:Property ;
    rdfs:label 'Dispute Status' ;
    rdfs:comment 'Current lifecycle status of the ADM dispute workflow: undisputed (agent has not contested), disputed (agent has raised a formal dispute), waived (airline has waived the debit), upheld (dispute rejected, debit stands), reversed (ADM cancelled and debit reversed).' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingOfficeCode rdf:type rdf:Property ;
    rdfs:label 'Issuing Office Code' ;
    rdfs:comment 'Airline office or station code of the revenue accounting unit that issued this ADM. Used for internal routing, accountability tracking, and regional revenue recovery reporting.' ;
    rdfs:domain ind:Adm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netDebitAmount rdf:type rdf:Property ;
    rdfs:label 'Net Debit Amount' ;
    rdfs:comment 'Net amount recoverable from the agent after applying any approved waivers, partial reversals, or adjustments to the gross debit amount. Used for final BSP/ARC settlement processing.' ;
    rdfs:domain ind:Adm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementChannel rdf:type rdf:Property ;
    rdfs:label 'Settlement Channel' ;
    rdfs:comment 'Billing and settlement channel through which this ADM is processed: BSP (IATA Billing and Settlement Plan for international markets), ARC (Airlines Reporting Corporation for US market), or DIRECT (bilateral direct settlement outside BSP/ARC).' ;
    rdfs:domain ind:Adm ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementStationId rdf:type rdf:Property ;
    rdfs:label 'Settlement Station Id' ;
    rdfs:comment 'Foreign key linking to airport.station. Business justification: ARC settlements require station-level tracking for remittance reconciliation, regulatory reporting, station cost center allocation, and audit compliance. Settlement processing occurs at specific stati' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Station .

ind:admAcmReasonCode rdf:type rdf:Property ;
    rdfs:label 'Adm Acm Reason Code' ;
    rdfs:comment 'Standardized reason code for Agency Debit Memo (ADM) or Agency Credit Memo (ACM) transactions, indicating the cause of the debit or credit adjustment (e.g., fare difference, commission clawback, waiver). Null for SALE, REFUND, EXCHANGE, and VOID transaction types. [ENUM-REF-CANDIDATE: FARE_DIFF|COMM_CLAWBACK|WAIVER|TAX_ADJ|SURCHARGE|OTHER — promote to reference product]' ;
    rdfs:domain ind:ArcSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyName rdf:type rdf:Property ;
    rdfs:label 'Agency Name' ;
    rdfs:comment 'Legal or trade name of the travel agency or corporate entity associated with the ARC agency number. Used for reporting, reconciliation, and dispute resolution.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arcAgencyNumber rdf:type rdf:Property ;
    rdfs:label 'Arc Agency Number' ;
    rdfs:comment 'Eight-digit ARC-assigned numeric identifier for the travel agency or corporate location that issued or processed the ticket. Used as the primary agency identifier in ARC settlement reporting and reconciliation.' ;
    rdfs:domain ind:ArcSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arcPeriodNumber rdf:type rdf:Property ;
    rdfs:label 'Arc Period Number' ;
    rdfs:comment 'ARC reporting period identifier in YYYY-WW format representing the calendar year and weekly settlement period (1–52) during which this transaction was reported and settled. ARC operates on a weekly settlement cycle.' ;
    rdfs:domain ind:ArcSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conjunctionTicketNumber rdf:type rdf:Property ;
    rdfs:label 'Conjunction Ticket Number' ;
    rdfs:comment 'Ticket number of the associated conjunction ticket when the itinerary spans more than one ticket document. Null when the transaction involves a single standalone ticket.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endorsementRestriction rdf:type rdf:Property ;
    rdfs:label 'Endorsement Restriction' ;
    rdfs:comment 'Free-text endorsement or restriction box content from the ticket document, indicating fare restrictions, interline endorsements, or special conditions (e.g., NON-ENDORSE, NON-REROUTE, VALID ON XX ONLY). Used for fare audit and refund eligibility determination.' ;
    rdfs:domain ind:ArcSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acmAmount rdf:type rdf:Property ;
    rdfs:label 'Acm Amount' ;
    rdfs:comment 'Total value of Agency Credit Memos (ACMs) issued to the travel agent in this settlement period. ACMs represent credits owed to the agent for airline-initiated corrections, overpayments, or goodwill adjustments. Positive value reduces agent liability.' ;
    rdfs:domain ind:BspSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adjustmentReference rdf:type rdf:Property ;
    rdfs:label 'Adjustment Reference' ;
    rdfs:comment 'Reference number or identifier for any corrective adjustment applied to this BSP settlement. Populated when settlement_status is \'adjusted\'. Links to the originating ADM, ACM, or manual journal entry in the revenue accounting system (SAP S/4HANA).' ;
    rdfs:domain ind:BspSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:admAmount rdf:type rdf:Property ;
    rdfs:label 'Adm Amount' ;
    rdfs:comment 'Total value of Agency Debit Memos (ADMs) raised against the travel agent in this settlement period. ADMs recover amounts owed to the airline due to agent errors, fare violations, or unauthorized discounts. Positive value increases agent liability.' ;
    rdfs:domain ind:BspSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:agentIataCode rdf:type rdf:Property ;
    rdfs:label 'Agent Iata Code' ;
    rdfs:comment 'The 8-digit IATA-assigned numeric code uniquely identifying the travel agency or sales outlet participating in the BSP settlement. Used as the primary agent identifier in IATA BSP transactions and reconciliation.' ;
    rdfs:domain ind:BspSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agentName rdf:type rdf:Property ;
    rdfs:label 'Agent Name' ;
    rdfs:comment 'Legal or trading name of the travel agency or sales outlet as registered with IATA BSP. Used for reporting, dispute resolution, and agent performance analytics.' ;
    rdfs:domain ind:BspSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:airlineNumericCode rdf:type rdf:Property ;
    rdfs:label 'Airline Numeric Code' ;
    rdfs:comment 'Three-digit IATA numeric airline code used in ticket number prefixes and BSP settlement files to identify the validating carrier. Complements the two-letter IATA designator for settlement and ticketing purposes.' ;
    rdfs:domain ind:BspSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arcReportReference rdf:type rdf:Property ;
    rdfs:label 'Arc Report Reference' ;
    rdfs:comment 'Reference identifier linking this BSP settlement to the corresponding ARC (Airlines Reporting Corporation) settlement report for US-market transactions. Populated for settlements processed through ARC rather than IATA BSP. Used for dual-channel reconciliation.' ;
    rdfs:domain ind:BspSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bspFileReference rdf:type rdf:Property ;
    rdfs:label 'Bsp File Reference' ;
    rdfs:comment 'Externally-known IATA BSP file reference number assigned by the BSP clearing system to uniquely identify the settlement file batch. Used for reconciliation with IATA BSP reports and agent remittance matching.' ;
    rdfs:domain ind:BspSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bspMarketCountryCode rdf:type rdf:Property ;
    rdfs:label 'Bsp Market Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-2 country code identifying the BSP market (country or territory) in which this settlement was processed. Determines the applicable BSP rules, currency, and remittance schedule.' ;
    rdfs:domain ind:BspSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenterCode rdf:type rdf:Property ;
    rdfs:label 'Cost Center Code' ;
    rdfs:comment 'SAP S/4HANA cost center code associated with the revenue management or sales function responsible for this BSP settlement. Used for internal financial reporting and P&L attribution by sales region or distribution channel.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeRaisedDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Raised Date' ;
    rdfs:comment 'Date on which the dispute was formally raised against this BSP settlement by either the airline or the travel agent. Populated only when settlement_status is \'disputed\'. Used to track dispute aging and SLA compliance.' ;
    rdfs:domain ind:BspSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:grossSalesAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Sales Amount' ;
    rdfs:comment 'Total gross ticket sales value (fare + taxes + surcharges) billed to the travel agent in this BSP settlement period, before deduction of commissions or adjustments. Expressed in the settlement currency.' ;
    rdfs:domain ind:BspSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ndcIndicator rdf:type rdf:Property ;
    rdfs:label 'Ndc Indicator' ;
    rdfs:comment 'Flag indicating whether the tickets in this BSP settlement were issued via IATA New Distribution Capability (NDC) API channels rather than traditional GDS. True = NDC-sourced settlement; False = traditional GDS/BSP settlement. Used for NDC adoption tracking and distribution analytics.' ;
    rdfs:domain ind:BspSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netRemittanceAmount rdf:type rdf:Property ;
    rdfs:label 'Net Remittance Amount' ;
    rdfs:comment 'Net amount remitted by the travel agent to the airline after deducting commissions and applying any ADM/ACM adjustments from gross sales. This is the actual cash settlement amount transferred through the BSP clearing mechanism.' ;
    rdfs:domain ind:BspSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remittanceDueDate rdf:type rdf:Property ;
    rdfs:label 'Remittance Due Date' ;
    rdfs:comment 'The date by which the travel agent is contractually required to remit the net settlement amount to the BSP clearing house. Determined by the BSP market remittance schedule. Used for cash flow forecasting and overdue tracking.' ;
    rdfs:domain ind:BspSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ticketCount rdf:type rdf:Property ;
    rdfs:label 'Ticket Count' ;
    rdfs:comment 'Total number of individual e-tickets included in this BSP settlement transaction. Used for volume reconciliation and agent productivity reporting.' ;
    rdfs:domain ind:BspSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ticketNumberRangeEnd rdf:type rdf:Property ;
    rdfs:label 'Ticket Number Range End' ;
    rdfs:comment 'The last e-ticket number in the range of tickets covered by this BSP settlement transaction. Together with ticket_number_range_start, defines the complete set of tickets included in this settlement batch.' ;
    rdfs:domain ind:BspSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ticketNumberRangeStart rdf:type rdf:Property ;
    rdfs:label 'Ticket Number Range Start' ;
    rdfs:comment 'The first e-ticket number in the range of tickets covered by this BSP settlement transaction. Follows IATA 13-digit ticket number format (3-digit airline code prefix + 10-digit serial). Used for reconciliation with the Passenger Service System (PSS).' ;
    rdfs:domain ind:BspSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountId rdf:type rdf:Property ;
    rdfs:label 'Account Id' ;
    rdfs:comment 'Reference to the corporate account or Travel Management Company (TMC) that is party to this contract. Links to the corporate account master record.' ;
    rdfs:domain ind:CorporateContract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CorporateAccount .

ind:applicableBookingClasses rdf:type rdf:Property ;
    rdfs:label 'Applicable Booking Classes' ;
    rdfs:comment 'Pipe-delimited list of RBD (Reservation Booking Designator) booking class codes to which this contract\'s fares apply (e.g., \'Y|B|M|K\'). Governs inventory access in the Amadeus Altéa PSS.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableCabinClasses rdf:type rdf:Property ;
    rdfs:label 'Applicable Cabin Classes' ;
    rdfs:comment 'Pipe-delimited list of cabin classes to which the negotiated fares or discounts under this contract apply (e.g., \'Y|C|F\' for Economy, Business, First). Aligns with IATA cabin class designators.' ;
    rdfs:domain ind:CorporateContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoRenewalIndicator rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Indicator' ;
    rdfs:comment 'Indicates whether this corporate contract is set to automatically renew upon reaching the expiry date without requiring a new signed agreement. True = auto-renews; False = requires manual renewal.' ;
    rdfs:domain ind:CorporateContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:carrierCode rdf:type rdf:Property ;
    rdfs:label 'Carrier Code' ;
    rdfs:comment 'IATA two-letter designator of the operating or marketing carrier to which this corporate contract applies. Relevant for codeshare and interline agreements where the contracting carrier may differ from the operating carrier.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeableIndicator rdf:type rdf:Property ;
    rdfs:label 'Changeable Indicator' ;
    rdfs:comment 'Indicates whether tickets issued under this corporate contract permit voluntary changes (rebooking). True = changes permitted; False = no changes allowed. Governs change fee waiver rules.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commissionOverrideRate rdf:type rdf:Property ;
    rdfs:label 'Commission Override Rate' ;
    rdfs:comment 'Negotiated commission rate (as a percentage) paid to the TMC or travel agent above the standard base commission, applicable when contract_type is \'commission_override\'. Expressed as a percentage (e.g., 5.00 = 5%).' ;
    rdfs:domain ind:CorporateContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractName rdf:type rdf:Property ;
    rdfs:label 'Contract Name' ;
    rdfs:comment 'Descriptive name of the corporate contract, typically including the corporate account name and contract year (e.g., \'Acme Corp Global Agreement 2024\'). Used for display and reporting purposes.' ;
    rdfs:domain ind:CorporateContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationAirportCodes rdf:type rdf:Property ;
    rdfs:label 'Destination Airport Codes' ;
    rdfs:comment 'Pipe-delimited list of IATA three-letter airport codes representing the destination points covered by this corporate contract. Null or wildcard indicates all destinations are applicable.' ;
    rdfs:domain ind:CorporateContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdsCorporateCode rdf:type rdf:Property ;
    rdfs:label 'Gds Corporate Code' ;
    rdfs:comment 'Unique corporate code loaded into the Global Distribution System (GDS) — such as Amadeus, Sabre, or Travelport — that travel agents and TMCs use to access the negotiated corporate fares when booking on behalf of the corporate account.' ;
    rdfs:domain ind:CorporateContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minRevenueCommitment rdf:type rdf:Property ;
    rdfs:label 'Min Revenue Commitment' ;
    rdfs:comment 'Minimum annual or contract-period revenue (in contract currency) that the corporate account commits to generate under this agreement. Used for volume-based tier qualification and rebate calculations.' ;
    rdfs:domain ind:CorporateContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minSegmentCommitment rdf:type rdf:Property ;
    rdfs:label 'Min Segment Commitment' ;
    rdfs:comment 'Minimum number of flight segments the corporate account commits to book with the airline during the contract period. Used alongside or as an alternative to min_revenue_commitment for volume qualification.' ;
    rdfs:domain ind:CorporateContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:netFareAmount rdf:type rdf:Property ;
    rdfs:label 'Net Fare Amount' ;
    rdfs:comment 'Fixed negotiated net fare amount agreed under this corporate contract, net of all commissions and agency fees. Applicable when contract_type is \'net_fare\'. Expressed in the contract currency.' ;
    rdfs:domain ind:CorporateContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originAirportCodes rdf:type rdf:Property ;
    rdfs:label 'Origin Airport Codes' ;
    rdfs:comment 'Pipe-delimited list of IATA three-letter airport codes representing the origin points covered by this corporate contract. Null or wildcard indicates all origins are applicable.' ;
    rdfs:domain ind:CorporateContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pnrCorporateCode rdf:type rdf:Property ;
    rdfs:label 'Pnr Corporate Code' ;
    rdfs:comment 'Corporate identifier embedded in the PNR (Passenger Name Record) to associate bookings with this corporate contract for tracking, reporting, and volume measurement purposes within the Amadeus Altéa PSS.' ;
    rdfs:domain ind:CorporateContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rebateRate rdf:type rdf:Property ;
    rdfs:label 'Rebate Rate' ;
    rdfs:comment 'Percentage rebate paid back to the corporate account when volume commitments are met or exceeded. Expressed as a percentage of qualifying revenue (e.g., 3.00 = 3%).' ;
    rdfs:domain ind:CorporateContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rebateThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Rebate Threshold Amount' ;
    rdfs:comment 'Revenue threshold (in contract currency) that the corporate account must exceed to qualify for a volume rebate payment. When actual revenue exceeds this threshold, the rebate_rate applies to the qualifying spend.' ;
    rdfs:domain ind:CorporateContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:refundableIndicator rdf:type rdf:Property ;
    rdfs:label 'Refundable Indicator' ;
    rdfs:comment 'Indicates whether tickets issued under this corporate contract are refundable. True = refundable; False = non-refundable. Governs refund processing in the Amadeus Altéa PSS.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportingRequirement rdf:type rdf:Property ;
    rdfs:label 'Reporting Requirement' ;
    rdfs:comment 'Frequency at which the airline is contractually obligated to provide travel and spend reports to the corporate account or TMC. Drives automated report scheduling in the revenue management system.' ;
    rdfs:domain ind:CorporateContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signingDate rdf:type rdf:Property ;
    rdfs:label 'Signing Date' ;
    rdfs:comment 'Date on which the corporate contract was formally executed and signed by both the airline and the corporate account or TMC. Used for audit and legal compliance tracking.' ;
    rdfs:domain ind:CorporateContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:softDollarCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Soft Dollar Credit Amount' ;
    rdfs:comment 'Total non-cash incentive credit amount committed under this contract for soft dollar arrangements (e.g., upgrades, lounge access, marketing co-op funds). Applicable when contract_type is \'soft_dollar\'. Expressed in contract currency.' ;
    rdfs:domain ind:CorporateContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeMeasurementPeriod rdf:type rdf:Property ;
    rdfs:label 'Volume Measurement Period' ;
    rdfs:comment 'The time period over which minimum volume commitments (revenue or segment) are measured and evaluated for compliance and rebate qualification.' ;
    rdfs:domain ind:CorporateContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingCrewMemberId rdf:type rdf:Property ;
    rdfs:label 'Issuing Crew Member Id' ;
    rdfs:comment 'Foreign key linking to crew.crew_member. Business justification: Tracks cabin crew member who sold ancillary service onboard (baggage upgrade, seat selection, meals). Essential for onboard revenue attribution, crew sales incentive programs, and commission calculati' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Member .

ind:associatedTicketCoupon rdf:type rdf:Property ;
    rdfs:label 'Associated Ticket Coupon' ;
    rdfs:comment 'The coupon number on the associated air ticket (1–4) to which this EMD coupon is linked (EMD-A only). Enables segment-level association between the ancillary service and the specific flight leg it relates to.' ;
    rdfs:domain ind:RevenueEmd ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bspArcReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Bsp Arc Reporting Flag' ;
    rdfs:comment 'Indicates whether this EMD is subject to BSP (Billing and Settlement Plan) or ARC (Airlines Reporting Corporation) settlement reporting (True) or is settled directly outside BSP/ARC (False). Drives inclusion in BSP/ARC billing files and SAP S/4HANA accounts receivable postings.' ;
    rdfs:domain ind:RevenueEmd ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:equivalentAmount rdf:type rdf:Property ;
    rdfs:label 'Equivalent Amount' ;
    rdfs:comment 'Total EMD amount converted to the airline\'s base/reporting currency using the IATA Rate of Exchange (IROE) applicable at time of issuance. Used for consolidated ancillary revenue reporting, RASK/CASK analytics, and SAP S/4HANA FI ledger posting in functional currency.' ;
    rdfs:domain ind:RevenueEmd ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exchangeEmdNumber rdf:type rdf:Property ;
    rdfs:label 'Exchange Emd Number' ;
    rdfs:comment 'The 13-digit EMD number of the original document from which this EMD was exchanged/reissued. Null if this is an original issuance. Used for document lineage tracking, refund difference calculation, and BSP/ARC exchange reporting.' ;
    rdfs:domain ind:RevenueEmd ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formOfPaymentDetail rdf:type rdf:Property ;
    rdfs:label 'Form Of Payment Detail' ;
    rdfs:comment 'Masked payment instrument detail (e.g., last 4 digits of credit card, voucher number, check number). Full card numbers are NEVER stored per PCI DSS. Used for payment reconciliation and dispute resolution.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usedDate rdf:type rdf:Property ;
    rdfs:label 'Used Date' ;
    rdfs:comment 'Calendar date on which the EMD coupon was lifted (service delivered). Null if status is not \'used\'. Used for revenue recognition timing and service delivery confirmation.' ;
    rdfs:domain ind:RevenueEmd ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:atpcoRecordType rdf:type rdf:Property ;
    rdfs:label 'Atpco Record Type' ;
    rdfs:comment 'ATPCO record type number identifying the category of fare data: Record 1=Fare by Rule, Record 2=Fare Amount, Record 3=Fare Rules, Record 4=Footnote, Record 5=Routing, Record 6=Fare Class. Governs how the fare is processed in GDS and PSS systems.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:basisCode rdf:type rdf:Property ;
    rdfs:label 'Basis Code' ;
    rdfs:comment 'ATPCO-standard alphanumeric code uniquely identifying the fare construction rules, booking class, and conditions (e.g., YOW, KLAXOW, B21NR). The atomic pricing identifier used across GDS, PSS, and revenue management systems. Maximum 8 characters per ATPCO convention.' ;
    rdfs:domain ind:Fare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classCode rdf:type rdf:Property ;
    rdfs:label 'Class Code' ;
    rdfs:comment 'One or two-letter code representing the fare class grouping within the cabin (e.g., Y for full economy, B for discounted economy). Used in revenue management for yield optimization and load factor reporting.' ;
    rdfs:domain ind:Fare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:combinabilityCode rdf:type rdf:Property ;
    rdfs:label 'Combinability Code' ;
    rdfs:comment 'ATPCO code governing how this fare may be combined with other fares in a half-round-trip or end-on-end combination. Controls fare construction logic in GDS and PSS pricing engines.' ;
    rdfs:domain ind:Fare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:directionality rdf:type rdf:Property ;
    rdfs:label 'Directionality' ;
    rdfs:comment 'Indicates whether the fare applies to a one-way journey, round-trip, circle trip, or open-jaw itinerary. Determines how the fare is combined in fare construction and pricing calculations.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discontinueDate rdf:type rdf:Property ;
    rdfs:label 'Discontinue Date' ;
    rdfs:comment 'The date after which this fare is no longer valid for ticketing. A null value indicates the fare has no defined expiry. Aligns with ATPCO fare filing discontinue date field.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fareStatus rdf:type rdf:Property ;
    rdfs:label 'Fare Status' ;
    rdfs:comment 'Current lifecycle state of the fare record: active (available for sale), inactive (not currently sellable), pending (filed but not yet effective), withdrawn (removed from filing), superseded (replaced by a newer fare version).' ;
    rdfs:domain ind:Fare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:globalIndicator rdf:type rdf:Property ;
    rdfs:label 'Global Indicator' ;
    rdfs:comment 'IATA-defined two-letter code specifying the geographic routing area applicable to this fare (e.g., AT=Atlantic, PA=Pacific, TS=Trans-Siberian, AP=Asia-Pacific). Governs which routing rules and mileage systems apply for fare construction. [ENUM-REF-CANDIDATE: AT|PA|TS|AP|SA|EH|FE|NA|PO|RU|US — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iataFareFilingRef rdf:type rdf:Property ;
    rdfs:label 'Iata Fare Filing Ref' ;
    rdfs:comment 'IATA-assigned reference number or identifier for the fare filing submission. Used for audit, dispute resolution, and cross-referencing with IATA BSP settlement records.' ;
    rdfs:domain ind:Fare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownership rdf:type rdf:Property ;
    rdfs:label 'Ownership' ;
    rdfs:comment 'Identifies the filing channel through which this fare was submitted and is maintained: ATPCO (Airline Tariff Publishing Company), SITA (Société Internationale de Télécommunications Aéronautiques), or carrier-filed directly into the PSS.' ;
    rdfs:domain ind:Fare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:owrtIndicator rdf:type rdf:Property ;
    rdfs:label 'Owrt Indicator' ;
    rdfs:comment 'ATPCO one-way/round-trip indicator: O=one-way only, R=round-trip only, X=either. Controls how the fare may be combined in half-round-trip pricing and fare construction.' ;
    rdfs:domain ind:Fare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingNumber rdf:type rdf:Property ;
    rdfs:label 'Routing Number' ;
    rdfs:comment 'ATPCO-assigned routing number that specifies the permitted intermediate points and carrier combinations for this fare. A value of \'0\' typically indicates a mileage-based fare with no specific routing restriction.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesRestriction rdf:type rdf:Property ;
    rdfs:label 'Sales Restriction' ;
    rdfs:comment 'Defines geographic or channel restrictions on where this fare may be sold. Controls distribution eligibility across GDS, direct channels, and agency networks. [ENUM-REF-CANDIDATE: no_restriction|country_of_origin|carrier_office|internet_only|agency_only|consolidator_only — promote to reference product]' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tariffCode rdf:type rdf:Property ;
    rdfs:label 'Tariff Code' ;
    rdfs:comment 'Alphanumeric code identifying the specific tariff under which this fare is filed (e.g., PUBL for published, PRIV for private). Determines the visibility and distribution rules in GDS channels.' ;
    rdfs:domain ind:Fare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tariffNumber rdf:type rdf:Property ;
    rdfs:label 'Tariff Number' ;
    rdfs:comment 'ATPCO tariff number identifying the rule set (conditions, restrictions, penalties) associated with this fare. Links the fare amount to its governing fare rules in the ATPCO database.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ticketingCarrierCode rdf:type rdf:Property ;
    rdfs:label 'Ticketing Carrier Code' ;
    rdfs:comment 'IATA two-letter code of the carrier authorized to issue tickets under this fare. May differ from the operating carrier in codeshare and interline arrangements. Used for BSP settlement and ARC reporting.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:travelDiscontinueDate rdf:type rdf:Property ;
    rdfs:label 'Travel Discontinue Date' ;
    rdfs:comment 'The last date on which travel may be completed using this fare. Defines the travel validity window in conjunction with travel_effective_date.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:travelEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Travel Effective Date' ;
    rdfs:comment 'The earliest date on which travel may commence using this fare. Distinct from the ticketing effective date; governs the travel window rather than the sale window.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:awardRedemptionClass rdf:type rdf:Property ;
    rdfs:label 'Award Redemption Class' ;
    rdfs:comment 'Indicates whether this fare class is designated as an FFP (Frequent Flyer Program) award redemption booking class (True), meaning seats in this class are allocated from the award inventory pool and redeemed using loyalty miles/points rather than cash. Award classes are managed separately in Oracle Loyalty Cloud and do not generate direct ticket revenue.' ;
    rdfs:domain ind:FareClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:blackoutApplicable rdf:type rdf:Property ;
    rdfs:label 'Blackout Applicable' ;
    rdfs:comment 'Indicates whether this fare class is subject to blackout date restrictions (True), meaning it cannot be sold or used for travel during defined peak or holiday periods. When True, blackout dates are defined in the associated fare rule or seasonal restriction records. Relevant for both revenue fares and FFP award redemption classes.' ;
    rdfs:domain ind:FareClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:carryOnBagAllowance rdf:type rdf:Property ;
    rdfs:label 'Carry On Bag Allowance' ;
    rdfs:comment 'Number of carry-on baggage items (cabin bags) included at no additional charge for passengers traveling in this fare class. A value of 0 indicates no complimentary carry-on allowance (applicable to ultra-low-cost basic fare products). Feeds ancillary revenue calculation and gate agent enforcement workflows.' ;
    rdfs:domain ind:FareClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:changeable rdf:type rdf:Property ;
    rdfs:label 'Changeable' ;
    rdfs:comment 'Indicates whether the itinerary on a ticket issued in this fare class can be changed after purchase (True) or is a fixed, non-changeable booking (False). When True, change fees and fare difference rules defined in the associated fare rule record apply. Drives Amadeus Altéa PSS voluntary change workflow.' ;
    rdfs:domain ind:FareClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:checkedBagAllowance rdf:type rdf:Property ;
    rdfs:label 'Checked Bag Allowance' ;
    rdfs:comment 'Number of checked baggage pieces included at no additional charge for passengers traveling in this fare class. A value of 0 indicates no complimentary checked baggage (e.g., basic economy). Drives ancillary baggage fee revenue calculation and EMD (Electronic Miscellaneous Document) issuance logic in Amadeus Altéa.' ;
    rdfs:domain ind:FareClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:codeshareEligible rdf:type rdf:Property ;
    rdfs:label 'Codeshare Eligible' ;
    rdfs:comment 'Indicates whether this fare class may be sold on codeshare-operated flights (True) or is restricted to the operating carrier\'s own metal only (False). Codeshare eligibility governs interline proration and revenue sharing agreements between partner airlines under BSP settlement.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:family rdf:type rdf:Property ;
    rdfs:label 'Family' ;
    rdfs:comment 'Grouping label that clusters related RBDs into a commercial fare product family (e.g., FLEX, SEMI-FLEX, SAVER, BASIC, BUSINESS_FLEX, BUSINESS_SAVER). Used by Sabre AirVision Revenue Management for fare family-level yield management, ancillary bundling rules, and customer-facing fare product presentation. [ENUM-REF-CANDIDATE: FLEX|SEMI-FLEX|SAVER|BASIC|BUSINESS_FLEX|BUSINESS_SAVER|LIGHT — promote to reference product]' ;
    rdfs:domain ind:FareClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fareBasisCodePattern rdf:type rdf:Property ;
    rdfs:label 'Fare Basis Code Pattern' ;
    rdfs:comment 'Alphanumeric pattern or prefix associated with fare basis codes that map to this fare class (e.g., \'YOW\', \'BAPOW14\', \'QSAVER21\'). Fare basis codes are the detailed pricing identifiers used in ATPCO (Airline Tariff Publishing Company) fare filings and GDS displays. This field captures the naming convention pattern rather than individual fare basis codes, which are managed in the fare rule product.' ;
    rdfs:domain ind:FareClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fareClassDescription rdf:type rdf:Property ;
    rdfs:label 'Fare Class Description' ;
    rdfs:comment 'Free-text business description of this fare class, capturing its commercial purpose, target customer segment, and key product characteristics (e.g., \'Fully flexible full-fare economy class with unlimited changes and refunds, eligible for all upgrades and lounge access\'). Used in internal revenue management documentation and business reporting.' ;
    rdfs:domain ind:FareClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fareClassStatus rdf:type rdf:Property ;
    rdfs:label 'Fare Class Status' ;
    rdfs:comment 'Current lifecycle status of the fare class record: active = currently in use for booking and inventory control; inactive = suspended from sale but retained for historical reference; deprecated = permanently retired RBD no longer used in any market; seasonal = active only during defined seasonal periods. Governs whether the RBD is available for inventory allocation in the PSS.' ;
    rdfs:domain ind:FareClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loungeAccessIncluded rdf:type rdf:Property ;
    rdfs:label 'Lounge Access Included' ;
    rdfs:comment 'Indicates whether airport lounge access is included as a bundled benefit for passengers traveling in this fare class (True) or is not included (False). Typically True for premium cabin classes (First, Business) and certain elite fare products. Drives lounge access entitlement checks at airport ground operations.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mileageAccrualMultiplier rdf:type rdf:Property ;
    rdfs:label 'Mileage Accrual Multiplier' ;
    rdfs:comment 'Decimal multiplier applied to base flight distance (in miles or kilometers) to calculate Frequent Flyer Program (FFP) miles/points earned when a ticket is issued in this fare class. For example, 1.00 = 100% accrual, 0.50 = 50% accrual, 1.50 = 150% elite bonus accrual. A value of 0.00 indicates no mileage accrual (e.g., deeply discounted or award redemption classes). Feeds Oracle Loyalty Cloud FFP accrual calculation engine.' ;
    rdfs:domain ind:FareClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:noShowFeeApplicable rdf:type rdf:Property ;
    rdfs:label 'No Show Fee Applicable' ;
    rdfs:comment 'Indicates whether a no-show penalty fee is charged when a passenger holding a ticket in this fare class fails to cancel before departure and does not board the flight (True). No-show fees are an ancillary revenue stream tracked in SAP S/4HANA and reported in ARC settlement.' ;
    rdfs:domain ind:FareClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorityBoardingIncluded rdf:type rdf:Property ;
    rdfs:label 'Priority Boarding Included' ;
    rdfs:comment 'Indicates whether priority boarding access is included as a bundled benefit for passengers traveling in this fare class (True) or must be purchased separately as an ancillary service (False). Relevant for fare product differentiation and ancillary revenue attribution in SAP S/4HANA.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:refundable rdf:type rdf:Property ;
    rdfs:label 'Refundable' ;
    rdfs:comment 'Indicates whether tickets issued in this fare class are eligible for a monetary refund upon cancellation (True) or are non-refundable (False). Non-refundable fares may still qualify for travel credit or voucher issuance depending on fare rules. Critical for revenue accounting, BSP (Billing and Settlement Plan) settlement, and ARC reporting.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revenueClassType rdf:type rdf:Property ;
    rdfs:label 'Revenue Class Type' ;
    rdfs:comment 'Categorizes the commercial nature of this fare class for revenue accounting and BSP/ARC settlement purposes: revenue = standard commercial fare generating ticket revenue; award = FFP redemption (no cash revenue); staff = employee/industry discount travel; charter = charter block-seat allocation; group = group booking class; tour_operator = wholesale tour operator allocation. Drives revenue recognition rules in SAP S/4HANA FI/CO.' ;
    rdfs:domain ind:FareClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sameDayChangeEligible rdf:type rdf:Property ;
    rdfs:label 'Same Day Change Eligible' ;
    rdfs:comment 'Indicates whether tickets issued in this fare class qualify for same-day confirmed flight changes (True) or are restricted to the originally booked flight (False). Drives customer service agent workflows in the Amadeus Altéa PSS and is a key commercial differentiator between fare products.' ;
    rdfs:domain ind:FareClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:seatSelectionIncluded rdf:type rdf:Property ;
    rdfs:label 'Seat Selection Included' ;
    rdfs:comment 'Indicates whether advance seat selection is included at no additional charge for passengers booking this fare class (True) or whether seat selection requires an additional ancillary fee (False). Drives ancillary seat revenue calculation and the seat map availability display in the booking engine.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standbyEligible rdf:type rdf:Property ;
    rdfs:label 'Standby Eligible' ;
    rdfs:comment 'Indicates whether passengers holding tickets in this fare class may be placed on the standby list for an earlier or alternative flight at no additional charge (True) or are restricted from standby (False). Relevant for same-day change and irregular operations (IROP) reprotection workflows.' ;
    rdfs:domain ind:FareClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:yieldClassRank rdf:type rdf:Property ;
    rdfs:label 'Yield Class Rank' ;
    rdfs:comment 'Ordinal ranking of this RBD within its cabin by revenue yield, where 1 represents the highest-yielding (most expensive) booking class and higher numbers represent progressively lower-yielding classes. Used by the revenue management system to sequence inventory bucket availability — higher-ranked (lower-yield) classes are closed first as load factor increases, protecting higher-yield inventory. Directly drives RASK (Revenue per Available Seat Kilometer) optimization logic.' ;
    rdfs:domain ind:FareClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ancillaryBundleCode rdf:type rdf:Property ;
    rdfs:label 'Ancillary Bundle Code' ;
    rdfs:comment 'Reference code identifying the ancillary services bundle configuration associated with this fare family in the ancillary revenue management system. Links to the specific set of included and excluded ancillary services (EMD-eligible items) for merchandising.' ;
    rdfs:domain ind:FareFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandName rdf:type rdf:Property ;
    rdfs:label 'Brand Name' ;
    rdfs:comment 'Commercial marketing name of the fare family as displayed to passengers across all sales channels (e.g., \'Basic Economy\', \'Standard\', \'Flex\', \'Business Lite\', \'Business Plus\'). This is the customer-facing label used in GDS displays, NDC offers, and airline.com.' ;
    rdfs:domain ind:FareFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carryOnBagsIncluded rdf:type rdf:Property ;
    rdfs:label 'Carry On Bags Included' ;
    rdfs:comment 'Number of carry-on bags included in the fare family at no additional charge. Zero indicates no carry-on is included (e.g., Basic Economy). Used for ancillary merchandising and EMD issuance logic.' ;
    rdfs:domain ind:FareFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:changePermitted rdf:type rdf:Property ;
    rdfs:label 'Change Permitted' ;
    rdfs:comment 'Indicates whether the passenger is permitted to change the itinerary (date, routing, or flight) on a ticket issued under this fare family. When true, change_fee_amount may apply.' ;
    rdfs:domain ind:FareFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:checkedBagsIncluded rdf:type rdf:Property ;
    rdfs:label 'Checked Bags Included' ;
    rdfs:comment 'Number of checked baggage pieces included in the fare family at no additional charge. Drives ancillary upsell logic and EMD issuance in Amadeus Altéa. Reported per DOT baggage disclosure requirements.' ;
    rdfs:domain ind:FareFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:combinabilityPermitted rdf:type rdf:Property ;
    rdfs:label 'Combinability Permitted' ;
    rdfs:comment 'Indicates whether fares within this fare family may be combined with fares from other fare families or carriers to construct a round-trip or multi-sector itinerary. Aligns with ATPCO Category 10 combinability rules.' ;
    rdfs:domain ind:FareFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:displayPriority rdf:type rdf:Property ;
    rdfs:label 'Display Priority' ;
    rdfs:comment 'Integer ranking that controls the display order of fare families in shopping results across GDS, NDC, and direct channels. Lower values indicate higher display priority (e.g., 1 = displayed first). Used by Sabre AirVision and Amadeus Altéa for branded fare shelf ordering.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:familyStatus rdf:type rdf:Property ;
    rdfs:label 'Family Status' ;
    rdfs:comment 'Current operational status of the fare family in the revenue management and merchandising system. ACTIVE = currently sold; DRAFT = under configuration; RETIRED = no longer sold; SUSPENDED = temporarily withdrawn from sale.' ;
    rdfs:domain ind:FareFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fareClassMapping rdf:type rdf:Property ;
    rdfs:label 'Fare Class Mapping' ;
    rdfs:comment 'Comma-separated list of one-letter IATA booking class codes (RBDs) that are associated with this fare family (e.g., \'Y,B,M,H\'). Defines which inventory buckets in Amadeus Altéa and Sabre AirVision are merchandised under this branded fare.' ;
    rdfs:domain ind:FareFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdsDisplayIndicator rdf:type rdf:Property ;
    rdfs:label 'Gds Display Indicator' ;
    rdfs:comment 'Indicates whether this fare family is visible and bookable through Global Distribution System (GDS) channels (e.g., Amadeus, Sabre, Travelport). When false, the fare family is restricted to direct or NDC channels only.' ;
    rdfs:domain ind:FareFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interlinePermitted rdf:type rdf:Property ;
    rdfs:label 'Interline Permitted' ;
    rdfs:comment 'Indicates whether tickets issued under this fare family may be used on interline partner carrier segments. When false, the fare family is restricted to the issuing carrier\'s own-metal flights only.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:milesAccrualRate rdf:type rdf:Property ;
    rdfs:label 'Miles Accrual Rate' ;
    rdfs:comment 'Percentage of base miles earned per Revenue Passenger Kilometer (RPK) flown under this fare family, expressed as a decimal multiplier (e.g., 0.50 = 50%, 1.00 = 100%, 1.50 = 150%). Feeds Oracle Loyalty Cloud FFP mileage posting logic.' ;
    rdfs:domain ind:FareFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ndcEligible rdf:type rdf:Property ;
    rdfs:label 'Ndc Eligible' ;
    rdfs:comment 'Indicates whether this fare family is available for distribution via IATA New Distribution Capability (NDC) API channels, enabling rich offer and order management with full ancillary bundling.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:refundFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Refund Fee Amount' ;
    rdfs:comment 'Flat fee in the fare family\'s base currency charged to the passenger when processing a refund where refund_permitted is true. Zero indicates a fee-free refund. Null indicates refunds are not permitted.' ;
    rdfs:domain ind:FareFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:refundPermitted rdf:type rdf:Property ;
    rdfs:label 'Refund Permitted' ;
    rdfs:comment 'Indicates whether a refund to the original form of payment is permitted for tickets issued under this fare family. Drives refund eligibility logic in Amadeus Altéa and BSP/ARC settlement processing.' ;
    rdfs:domain ind:FareFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sabreBrandCode rdf:type rdf:Property ;
    rdfs:label 'Sabre Brand Code' ;
    rdfs:comment 'Native brand identifier assigned to this fare family within the Sabre AirVision Revenue Management system. Used for system-of-record traceability and reconciliation between the lakehouse silver layer and the operational Sabre environment.' ;
    rdfs:domain ind:FareFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wifiIncluded rdf:type rdf:Property ;
    rdfs:label 'Wifi Included' ;
    rdfs:comment 'Indicates whether complimentary in-flight Wi-Fi connectivity is included as part of this fare family\'s ancillary service bundle.' ;
    rdfs:domain ind:FareFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fareRuleId rdf:type rdf:Property ;
    rdfs:label 'Fare Rule Id' ;
    rdfs:comment 'Unique surrogate identifier for the fare rule record in the Silver layer lakehouse. Primary key for this entity.' ;
    rdfs:domain ind:FareRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:advancePurchaseHours rdf:type rdf:Property ;
    rdfs:label 'Advance Purchase Hours' ;
    rdfs:comment 'Minimum number of hours before departure by which the ticket must be purchased to qualify for this fare (ATPCO Cat 5). Null if no advance purchase requirement applies. Expressed in hours to accommodate sub-day requirements (e.g., 3-hour, 6-hour, 24-hour, 72-hour, 168-hour/7-day, 336-hour/14-day).' ;
    rdfs:domain ind:FareRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:atpcoCategoryNumber rdf:type rdf:Property ;
    rdfs:label 'Atpco Category Number' ;
    rdfs:comment 'ATPCO rule category number (Cat 1–35) that classifies the type of restriction or condition this rule record governs. Examples: Cat 2 = Day/Time, Cat 3 = Seasonality, Cat 4 = Flight Application, Cat 5 = Advance Purchase, Cat 6 = Min Stay, Cat 7 = Max Stay, Cat 8 = Stopovers, Cat 9 = Transfers, Cat 14 = Travel Restrictions, Cat 15 = Sales Restrictions, Cat 16 = Penalties, Cat 31 = Voluntary Changes, Cat 33 = Voluntary Refunds.' ;
    rdfs:domain ind:FareRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:blackoutEndDate rdf:type rdf:Property ;
    rdfs:label 'Blackout End Date' ;
    rdfs:comment 'End date of a travel blackout period during which this fare is not available for travel (ATPCO Cat 11). Null if no blackout period applies.' ;
    rdfs:domain ind:FareRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:blackoutStartDate rdf:type rdf:Property ;
    rdfs:label 'Blackout Start Date' ;
    rdfs:comment 'Start date of a travel blackout period during which this fare is not available for travel (ATPCO Cat 11 — Blackout Dates). Null if no blackout period applies. Multiple blackout periods should be stored as separate rule records.' ;
    rdfs:domain ind:FareRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:combinabilityType rdf:type rdf:Property ;
    rdfs:label 'Combinability Type' ;
    rdfs:comment 'Specifies how this fare may be combined with other fares to construct a complete itinerary (ATPCO Cat 10). \'end_on_end\' = fares combined sequentially; \'back_to_back\' = two one-way fares used together; \'open_jaw\' = origin or destination differs on outbound/return; \'round_trip\' = must be used as a round trip; \'none\' = no combination permitted.' ;
    rdfs:domain ind:FareRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minStayType rdf:type rdf:Property ;
    rdfs:label 'Min Stay Type' ;
    rdfs:comment 'Qualifier for the minimum stay requirement. \'days\' = calendar day count applies; \'saturday_night\' = passenger must include a Saturday night at destination; \'none\' = no minimum stay restriction.' ;
    rdfs:domain ind:FareRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permittedDaysOfWeek rdf:type rdf:Property ;
    rdfs:label 'Permitted Days Of Week' ;
    rdfs:comment 'Comma-separated list of days of the week on which travel under this fare is permitted (ATPCO Cat 2 — Day/Time). Values: MON, TUE, WED, THU, FRI, SAT, SUN. Null or empty means all days are permitted. Example: \'MON,TUE,WED,THU\' restricts to weekday travel only.' ;
    rdfs:domain ind:FareRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundPenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Refund Penalty Amount' ;
    rdfs:comment 'Monetary penalty deducted from the refund amount when a passenger cancels a refundable ticket under this fare rule (ATPCO Cat 33). Expressed in the currency defined by refund_penalty_currency. Null if the fare is non-refundable or no penalty applies.' ;
    rdfs:domain ind:FareRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:refundPenaltyCurrency rdf:type rdf:Property ;
    rdfs:label 'Refund Penalty Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the refund penalty amount is denominated. Null if no refund penalty applies.' ;
    rdfs:domain ind:FareRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleNumber rdf:type rdf:Property ;
    rdfs:label 'Rule Number' ;
    rdfs:comment 'Carrier-assigned rule number that groups related rule categories under a single tariff filing. Used by pricing engines to retrieve the full rule set for a fare basis. Corresponds to the ATPCO rule number field.' ;
    rdfs:domain ind:FareRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleText rdf:type rdf:Property ;
    rdfs:label 'Rule Text' ;
    rdfs:comment 'Complete free-text narrative of the fare rule as filed with ATPCO or the carrier\'s internal tariff system. Contains the full legal and commercial conditions of use. Used by ticketing agents and displayed in GDS fare displays.' ;
    rdfs:domain ind:FareRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesRestrictionType rdf:type rdf:Property ;
    rdfs:label 'Sales Restriction Type' ;
    rdfs:comment 'Channel restriction governing where this fare may be sold (ATPCO Cat 15 — Sales Restrictions). \'internet_only\' = only available via airline direct web/app; \'agency_only\' = only through accredited travel agents; \'direct_only\' = only via airline direct channels; \'gds_only\' = only through Global Distribution Systems; \'none\' = no channel restriction.' ;
    rdfs:domain ind:FareRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonType rdf:type rdf:Property ;
    rdfs:label 'Season Type' ;
    rdfs:comment 'Seasonal classification applied to this fare rule (ATPCO Cat 3 — Seasonality). Determines the travel season band in which the fare is valid. \'peak\' = high-demand season; \'shoulder\' = transitional season; \'off_peak\' = low-demand season; \'none\' = no seasonal restriction.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stopoversPermitted rdf:type rdf:Property ;
    rdfs:label 'Stopovers Permitted' ;
    rdfs:comment 'Maximum number of stopovers (intentional interruptions of journey exceeding the Minimum Connecting Time) permitted under this fare rule (ATPCO Cat 8). A value of 0 means no stopovers allowed; null means unlimited.' ;
    rdfs:domain ind:FareRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transfersPermitted rdf:type rdf:Property ;
    rdfs:label 'Transfers Permitted' ;
    rdfs:comment 'Maximum number of transfers (connections within Minimum Connecting Time) permitted under this fare rule (ATPCO Cat 9). A value of 0 means no transfers allowed; null means unlimited.' ;
    rdfs:domain ind:FareRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:travelRestrictionType rdf:type rdf:Property ;
    rdfs:label 'Travel Restriction Type' ;
    rdfs:comment 'Directional travel restriction applied to this fare rule (ATPCO Cat 14 — Travel Restrictions). Specifies whether the rule applies to the outbound journey, inbound journey, or both directions of travel.' ;
    rdfs:domain ind:FareRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactingWorkOrderId rdf:type rdf:Property ;
    rdfs:label 'Impacting Work Order Id' ;
    rdfs:comment 'Foreign key linking to maintenance.work_order. Business justification: Flight revenue performance metrics must track maintenance events causing delays/cancellations to calculate true operational RASK, attribute revenue loss to maintenance costs, and support executive rep' ;
    rdfs:domain ind:FlightRevenuePerformance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkOrder .

ind:ancillaryRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Ancillary Revenue Amount' ;
    rdfs:comment 'Total ancillary revenue attributed to this flight, including checked baggage fees, seat selection fees, onboard retail, and other non-fare charges collected from passengers on this specific flight leg.' ;
    rdfs:domain ind:FlightRevenuePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ask rdf:type rdf:Property ;
    rdfs:label 'Ask' ;
    rdfs:comment 'Available Seat Kilometers for this flight, computed as available_seats multiplied by the great-circle distance in kilometers between origin and destination. Represents the capacity deployed and is the denominator for RASK and CASK calculations.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:availableSeats rdf:type rdf:Property ;
    rdfs:label 'Available Seats' ;
    rdfs:comment 'Total number of seats available for sale on this flight across all cabins, as configured in the inventory system at departure. Used as the denominator for load factor and ASK calculations.' ;
    rdfs:domain ind:FlightRevenuePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:averageFareAmount rdf:type rdf:Property ;
    rdfs:label 'Average Fare Amount' ;
    rdfs:comment 'Average base fare revenue per revenue passenger carried on this flight, computed as total_fare_revenue_amount / passengers_carried. Used to benchmark pricing effectiveness against RM forecast and competitor fares.' ;
    rdfs:domain ind:FlightRevenuePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:businessFareRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Business Fare Revenue Amount' ;
    rdfs:comment 'Total base fare revenue collected from business class cabin passengers on this flight. Enables cabin-level revenue contribution and yield analysis to evaluate premium cabin pricing decisions.' ;
    rdfs:domain ind:FlightRevenuePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:businessPassengers rdf:type rdf:Property ;
    rdfs:label 'Business Passengers' ;
    rdfs:comment 'Number of revenue passengers carried in the business class cabin on this flight. Enables cabin-level yield and revenue contribution analysis critical for long-haul RM strategy evaluation.' ;
    rdfs:domain ind:FlightRevenuePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deniedBoardingCount rdf:type rdf:Property ;
    rdfs:label 'Denied Boarding Count' ;
    rdfs:comment 'Number of passengers who were involuntarily denied boarding on this flight due to overbooking. Tracked for DOT consumer protection reporting, compensation cost accounting, and overbooking policy calibration.' ;
    rdfs:domain ind:FlightRevenuePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:departureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Departure Timestamp' ;
    rdfs:comment 'Actual gate-out timestamp (the \'Out\' event in OOOI reporting) recorded at block-off. This is the principal business event timestamp anchoring the revenue performance record to the real-world flight departure.' ;
    rdfs:domain ind:FlightRevenuePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:economyFareRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Economy Fare Revenue Amount' ;
    rdfs:comment 'Total base fare revenue collected from economy cabin passengers on this flight. Enables cabin-level revenue contribution and yield analysis to evaluate economy pricing decisions.' ;
    rdfs:domain ind:FlightRevenuePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:economyPassengers rdf:type rdf:Property ;
    rdfs:label 'Economy Passengers' ;
    rdfs:comment 'Number of revenue passengers carried in the economy cabin (including economy plus/premium economy where applicable) on this flight. Enables cabin-level load factor and revenue mix analysis.' ;
    rdfs:domain ind:FlightRevenuePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:firstClassFareRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'First Class Fare Revenue Amount' ;
    rdfs:comment 'Total base fare revenue collected from first class cabin passengers on this flight. Nullable for routes without a first class product. Enables premium cabin revenue contribution analysis.' ;
    rdfs:domain ind:FlightRevenuePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:firstClassPassengers rdf:type rdf:Property ;
    rdfs:label 'First Class Passengers' ;
    rdfs:comment 'Number of revenue passengers carried in the first class cabin on this flight. Nullable for aircraft types or routes without a first class product. Enables premium cabin revenue contribution analysis.' ;
    rdfs:domain ind:FlightRevenuePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:noShowCount rdf:type rdf:Property ;
    rdfs:label 'No Show Count' ;
    rdfs:comment 'Number of passengers who held confirmed reservations (PNRs) for this flight but did not board. Critical input for overbooking model calibration and RM forecast accuracy assessment.' ;
    rdfs:domain ind:FlightRevenuePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overbookingOutcome rdf:type rdf:Property ;
    rdfs:label 'Overbooking Outcome' ;
    rdfs:comment 'Categorical outcome of the overbooking strategy applied to this flight. \'under_sold\' indicates seats departed empty; \'exact_sell\' indicates full utilization without denied boardings; \'over_sold\' indicates denied boardings occurred; \'cancelled\' indicates the flight was cancelled.' ;
    rdfs:domain ind:FlightRevenuePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passengersCarried rdf:type rdf:Property ;
    rdfs:label 'Passengers Carried' ;
    rdfs:comment 'Total number of revenue passengers who boarded and were carried on this flight across all cabins. Excludes non-revenue passengers (staff travel, deadhead crew). Used as the numerator for load factor and RPK calculations.' ;
    rdfs:domain ind:FlightRevenuePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rask rdf:type rdf:Property ;
    rdfs:label 'Rask' ;
    rdfs:comment 'Total revenue (fare + ancillary + upgrade) divided by Available Seat Kilometers (ASK) for this flight. Primary unit revenue productivity metric used by RM and finance to evaluate pricing effectiveness against capacity deployed.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recordStatus rdf:type rdf:Property ;
    rdfs:label 'Record Status' ;
    rdfs:comment 'Lifecycle status of this revenue performance record. \'provisional\' indicates the record was created at gate departure before full revenue accounting close; \'final\' indicates BSP/ARC settlement is complete; \'adjusted\' indicates a post-close correction has been applied; \'cancelled\' indicates the flight was cancelled after initial record creation.' ;
    rdfs:domain ind:FlightRevenuePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueAccountingPeriod rdf:type rdf:Property ;
    rdfs:label 'Revenue Accounting Period' ;
    rdfs:comment 'The BSP/ARC settlement accounting period (year-month) to which this flight\'s revenue is attributed for financial close and regulatory reporting. Aligns with IATA BSP billing period calendar.' ;
    rdfs:domain ind:FlightRevenuePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rpk rdf:type rdf:Property ;
    rdfs:label 'Rpk' ;
    rdfs:comment 'Revenue Passenger Kilometers for this flight, computed as passengers_carried multiplied by the great-circle distance in kilometers. Measures actual traffic volume and is the denominator for yield calculation.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalFareRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Total Fare Revenue Amount' ;
    rdfs:comment 'Gross base fare revenue collected for all passengers on this flight across all cabins, excluding taxes, fees, and ancillary charges. This is the primary revenue line used for yield and RASK computation. Expressed in the settlement currency.' ;
    rdfs:domain ind:FlightRevenuePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:upgradeCount rdf:type rdf:Property ;
    rdfs:label 'Upgrade Count' ;
    rdfs:comment 'Total number of passengers upgraded to a higher cabin class on this flight, including paid upgrades, complimentary upgrades, and loyalty-tier upgrades. Used to evaluate upgrade revenue opportunity and cabin mix management.' ;
    rdfs:domain ind:FlightRevenuePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:upgradeRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Upgrade Revenue Amount' ;
    rdfs:comment 'Revenue collected from paid cabin upgrades on this flight, including gate upgrades, bid upgrades, and instant upgrade purchases. Tracked separately to evaluate upgrade yield contribution.' ;
    rdfs:domain ind:FlightRevenuePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:voluntaryDeniedBoardingCount rdf:type rdf:Property ;
    rdfs:label 'Voluntary Denied Boarding Count' ;
    rdfs:comment 'Number of passengers who voluntarily accepted compensation and gave up their confirmed seat on this flight. Tracked separately from involuntary denied boarding for DOT reporting and compensation cost management.' ;
    rdfs:domain ind:FlightRevenuePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:yieldPerRpk rdf:type rdf:Property ;
    rdfs:label 'Yield Per Rpk' ;
    rdfs:comment 'Fare revenue divided by Revenue Passenger Kilometers (RPK) for this flight. Measures the average revenue earned per unit of traffic carried, the core yield metric in airline revenue management. Expressed in the settlement currency per kilometer.' ;
    rdfs:domain ind:FlightRevenuePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interlineProrateId rdf:type rdf:Property ;
    rdfs:label 'Interline Prorate Id' ;
    rdfs:comment 'Unique surrogate identifier for each interline prorate agreement or proration transaction record in the silver layer lakehouse.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InterlineProrate .

ind:calculationMethod rdf:type rdf:Property ;
    rdfs:label 'Calculation Method' ;
    rdfs:comment 'Method used to calculate the revenue proration between interline carriers: PROPORTIONAL (based on segment distance), EQUAL_SPLIT (equal share per carrier), MILEAGE_RATIO (IATA mileage-based), AGREED_FACTOR (bilaterally negotiated factor), FIXED (fixed amount per agreement). [ENUM-REF-CANDIDATE: PROPORTIONAL|EQUAL_SPLIT|MILEAGE_RATIO|AGREED_FACTOR|FIXED — promote to reference product]' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iataConferenceArea rdf:type rdf:Property ;
    rdfs:label 'Iata Conference Area' ;
    rdfs:comment 'IATA Traffic Conference area applicable to this prorate agreement: TC1 (Americas), TC2 (Europe, Middle East, Africa), TC3 (Asia-Pacific). Determines the IATA tariff conference jurisdiction governing the agreement.' ;
    rdfs:domain ind:InterlineProrate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumProrateAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Prorate Amount' ;
    rdfs:comment 'Ceiling value for the prorate allocation in the agreement currency. Caps the carrier\'s revenue share to prevent over-recovery on high-yield itineraries under fixed-factor agreements.' ;
    rdfs:domain ind:InterlineProrate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumProrateAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Prorate Amount' ;
    rdfs:comment 'Floor value for the prorate allocation in the agreement currency. Ensures the carrier receives at least this amount regardless of the calculated prorate factor or percentage. Protects against under-recovery on low-yield itineraries.' ;
    rdfs:domain ind:InterlineProrate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ownCarrierCode rdf:type rdf:Property ;
    rdfs:label 'Own Carrier Code' ;
    rdfs:comment 'Two-character IATA airline designator code of the operating airline (the airline owning this record) that is party to the prorate agreement.' ;
    rdfs:domain ind:InterlineProrate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerCarrierCode rdf:type rdf:Property ;
    rdfs:label 'Partner Carrier Code' ;
    rdfs:comment 'Two-character IATA airline designator code of the interline partner carrier participating in the prorate agreement. Identifies the counterparty airline for revenue split purposes.' ;
    rdfs:domain ind:InterlineProrate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prorateAmount rdf:type rdf:Property ;
    rdfs:label 'Prorate Amount' ;
    rdfs:comment 'Fixed monetary amount allocated to this carrier under the prorate agreement, expressed in the agreement currency. Used for FIXED_AMOUNT agreement types where a specific dollar/currency value is agreed rather than a factor or percentage.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prorateBasis rdf:type rdf:Property ;
    rdfs:label 'Prorate Basis' ;
    rdfs:comment 'The underlying basis on which proration is computed: FARE (based on published fare components), MILEAGE (based on IATA TPM/MPM mileage), WEIGHT (cargo weight-based, for cargo interline), or REVENUE (based on actual collected revenue).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prorateFactor rdf:type rdf:Property ;
    rdfs:label 'Prorate Factor' ;
    rdfs:comment 'Numeric prorate factor (ratio) applied to the total fare to determine the revenue share allocated to this carrier\'s segment of the interline journey. Used for IATA_PRF and MILEAGE agreement types. Value between 0 and 1 representing the carrier\'s proportional share.' ;
    rdfs:domain ind:InterlineProrate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proratePercentage rdf:type rdf:Property ;
    rdfs:label 'Prorate Percentage' ;
    rdfs:comment 'Percentage of the total interline fare revenue allocated to this carrier under the prorate agreement. Used for PERCENTAGE agreement types. Value between 0.0000 and 100.0000.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proratedRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Prorated Revenue Amount' ;
    rdfs:comment 'Net revenue amount allocated to the own carrier after applying the prorate factor, percentage, or fixed amount to the collected fare. This is the carrier\'s actual revenue share from the interline itinerary. MONETARY_TRIPLET — net total.' ;
    rdfs:domain ind:InterlineProrate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recordType rdf:type rdf:Property ;
    rdfs:label 'Record Type' ;
    rdfs:comment 'Discriminator indicating whether this record represents a prorate AGREEMENT (the standing agreement defining split rules) or a TRANSACTION (an actual proration event applied to a settled interline billing).' ;
    rdfs:domain ind:InterlineProrate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:viaAirportCode rdf:type rdf:Property ;
    rdfs:label 'Via Airport Code' ;
    rdfs:comment 'Three-letter IATA airport code for an intermediate connecting point that further qualifies the applicable market for this prorate agreement. Null if the agreement applies to all routings between origin and destination.' ;
    rdfs:domain ind:InterlineProrate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ndcOfferOrderId rdf:type rdf:Property ;
    rdfs:label 'Ndc Offer Order Id' ;
    rdfs:comment 'Unique surrogate identifier for the NDC offer order record in the Silver layer lakehouse. Primary key for this entity. TRANSACTION_HEADER role — represents a confirmed booking transacted through an IATA NDC-compliant API channel.' ;
    rdfs:domain ind:NdcOfferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ancillaryAmount rdf:type rdf:Property ;
    rdfs:label 'Ancillary Amount' ;
    rdfs:comment 'Total revenue from ancillary services (e.g., seat upgrades, extra baggage, lounge access, in-flight meals, Wi-Fi) included in this NDC order. Enables ancillary revenue attribution and modern retailing performance measurement separate from base fare revenue.' ;
    rdfs:domain ind:NdcOfferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:buyerType rdf:type rdf:Property ;
    rdfs:label 'Buyer Type' ;
    rdfs:comment 'Classification of the entity that placed the NDC order. DIRECT_TRAVELER = consumer booking directly on airline.com; TRAVEL_AGENT = IATA-accredited travel agency; CORPORATE = corporate self-booking tool; OTA = Online Travel Agency aggregator; TMC = Travel Management Company. Drives NDC channel attribution and distribution cost analysis.' ;
    rdfs:domain ind:NdcOfferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastServicingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Servicing Timestamp' ;
    rdfs:comment 'UTC timestamp of the most recent post-order servicing action (e.g., change, upgrade, ancillary modification) applied to this NDC order. Null if no servicing actions have occurred. Supports IROP (Irregular Operations) reprotection tracking and order change audit.' ;
    rdfs:domain ind:NdcOfferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:loyaltyMilesEarned rdf:type rdf:Property ;
    rdfs:label 'Loyalty Miles Earned' ;
    rdfs:comment 'Number of frequent flyer program (FFP) miles or points accrued by the lead passenger for this NDC order based on the fare family accrual rate and distance flown. Populated upon flight completion. Used for loyalty liability accounting and FFP program performance reporting.' ;
    rdfs:domain ind:NdcOfferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ndcOrderReference rdf:type rdf:Property ;
    rdfs:label 'Ndc Order Reference' ;
    rdfs:comment 'Externally-known alphanumeric order reference assigned by the airline NDC Order Management System at order creation. Communicated to the buyer (traveler, agent, corporate) as the booking confirmation number. Distinct from the PNR locator used in legacy GDS channels. BUSINESS_IDENTIFIER for this TRANSACTION_HEADER.' ;
    rdfs:domain ind:NdcOfferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ndcProviderCode rdf:type rdf:Property ;
    rdfs:label 'Ndc Provider Code' ;
    rdfs:comment 'Identifier of the NDC-certified aggregator, GDS, or direct connect provider through which this order was transacted (e.g., Amadeus NDC, Sabre NDC, Travelport NDC, or airline direct API). Enables distribution cost analysis and provider performance benchmarking.' ;
    rdfs:domain ind:NdcOfferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ndcSchemaVersion rdf:type rdf:Property ;
    rdfs:label 'Ndc Schema Version' ;
    rdfs:comment 'The IATA NDC XML schema version used to create and process this order (e.g., 17.2, 18.1, 19.1, 20.1, 21.3). Critical for API compatibility management, schema migration tracking, and ensuring correct message parsing across NDC schema generations.' ;
    rdfs:domain ind:NdcOfferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Order Created Timestamp' ;
    rdfs:comment 'UTC timestamp when the NDC order was first created in the airline Order Management System following buyer acceptance of the offer. This is the principal real-world business event time (BUSINESS_EVENT_TIMESTAMP) for this transaction — distinct from the ETL audit timestamp.' ;
    rdfs:domain ind:NdcOfferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:originalOfferReference rdf:type rdf:Property ;
    rdfs:label 'Original Offer Reference' ;
    rdfs:comment 'The NDC offer identifier returned by the airline shopping/pricing engine (AirShopping or OfferPrice response) that the buyer accepted and converted into this order. Enables traceability from order back to the original priced offer for revenue attribution and offer conversion analytics.' ;
    rdfs:domain ind:NdcOfferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:servicingActionCount rdf:type rdf:Property ;
    rdfs:label 'Servicing Action Count' ;
    rdfs:comment 'Cumulative count of post-order servicing actions (changes, upgrades, seat modifications, ancillary additions/removals, name corrections) applied to this NDC order since creation. A non-zero value indicates the order has been modified. Used for servicing cost analysis and order complexity measurement.' ;
    rdfs:domain ind:NdcOfferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalOrderAmount rdf:type rdf:Property ;
    rdfs:label 'Total Order Amount' ;
    rdfs:comment 'The gross total amount payable for this NDC order, inclusive of base fare, taxes, carrier surcharges, and ancillary service charges. Net total in the MONETARY_TRIPLET. This is the amount presented to the buyer at order confirmation and used for revenue accounting and BSP settlement.' ;
    rdfs:domain ind:NdcOfferOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gdsQuoteId rdf:type rdf:Property ;
    rdfs:label 'Gds Quote Id' ;
    rdfs:comment 'The native quote or pricing solution identifier assigned by the GDS (e.g., Sabre, Amadeus, Travelport) when the fare was priced through a GDS channel. Null for direct or NDC-sourced pricing. Used for GDS billing reconciliation.' ;
    rdfs:domain ind:PricingRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FareQuote .

ind:carrierSurchargeAmount rdf:type rdf:Property ;
    rdfs:label 'Carrier Surcharge Amount' ;
    rdfs:comment 'Total carrier-imposed surcharges (YQ fuel surcharge and YR carrier-imposed fees) applied to this fare. Distinct from government taxes; retained by the carrier. Critical for revenue accounting and BSP settlement reconciliation.' ;
    rdfs:domain ind:PricingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:formOfPaymentRestriction rdf:type rdf:Property ;
    rdfs:label 'Form Of Payment Restriction' ;
    rdfs:comment 'Any restriction on the form of payment permitted for this fare. NONE = no restriction; CREDIT_CARD_ONLY = must be paid by credit card; CASH_ONLY = cash payment required; SPECIFIC_CARD = restricted to a specific card type or issuer; MILES_ONLY = award redemption only. Impacts checkout and payment processing.' ;
    rdfs:domain ind:PricingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iataRateOfExchange rdf:type rdf:Property ;
    rdfs:label 'Iata Rate Of Exchange' ;
    rdfs:comment 'The IATA-published Rate of Exchange (ROE) used to convert the NUC fare amount to the local pricing currency at the time of pricing. Required for international fare construction and interline proration under IATA Resolution 722.' ;
    rdfs:domain ind:PricingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxStayRequirement rdf:type rdf:Property ;
    rdfs:label 'Max Stay Requirement' ;
    rdfs:comment 'Maximum stay condition attached to the fare rule (e.g., \'1M\' for one month, \'30D\' for 30 days). Null if no maximum stay applies. Constrains the return travel date for round-trip fares.' ;
    rdfs:domain ind:PricingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minStayRequirement rdf:type rdf:Property ;
    rdfs:label 'Min Stay Requirement' ;
    rdfs:comment 'Minimum stay condition attached to the fare rule (e.g., \'SU\' for Sunday night stay, \'3D\' for 3 days). Null if no minimum stay applies. Used for round-trip fare rule validation.' ;
    rdfs:domain ind:PricingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ndcOfferReference rdf:type rdf:Property ;
    rdfs:label 'Ndc Offer Reference' ;
    rdfs:comment 'Unique offer identifier assigned by the airline\'s NDC offer engine when the fare was priced via an IATA NDC-compliant channel. Null for GDS or legacy-sourced pricing. Enables NDC order management and settlement.' ;
    rdfs:domain ind:PricingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingStatus rdf:type rdf:Property ;
    rdfs:label 'Pricing Status' ;
    rdfs:comment 'Current lifecycle state of the pricing record. QUOTED = fare quote generated but not yet ticketed; TICKETED = fare has been issued as an e-ticket; EXPIRED = ticketing time limit passed without issuance; CANCELLED = booking cancelled; REPRICED = superseded by a subsequent pricing event; VOIDED = ticket voided post-issuance.' ;
    rdfs:domain ind:PricingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quoteReference rdf:type rdf:Property ;
    rdfs:label 'Quote Reference' ;
    rdfs:comment 'Externally-known unique identifier assigned by the pricing engine (Sabre AirVision) to this specific fare quote or pricing calculation event. Used for audit trail and repricing reconciliation.' ;
    rdfs:domain ind:PricingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingCode rdf:type rdf:Property ;
    rdfs:label 'Routing Code' ;
    rdfs:comment 'IATA routing code or routing number associated with the fare basis, specifying permitted intermediate points and carrier combinations for the priced itinerary. Governs which connecting points are allowed under the fare rules.' ;
    rdfs:domain ind:PricingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognitionId rdf:type rdf:Property ;
    rdfs:label 'Recognition Id' ;
    rdfs:comment 'Primary key for recognition' ;
    rdfs:domain ind:Recognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountingStatus rdf:type rdf:Property ;
    rdfs:label 'Accounting Status' ;
    rdfs:comment 'Current workflow status of this revenue recognition record: PENDING (awaiting period-close processing), RECOGNIZED (revenue posted to GL), ADJUSTED (corrected after initial recognition), REVERSED (voided/cancelled entry), DISPUTED (under interline billing dispute).' ;
    rdfs:domain ind:Recognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interlineFlag rdf:type rdf:Property ;
    rdfs:label 'Interline Flag' ;
    rdfs:comment 'Indicates whether this coupon is part of an interline itinerary involving two or more carriers under an interline ticketing agreement. When true, prorate_amount and prorate_agreement_reference are applicable.' ;
    rdfs:domain ind:Recognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recognitionMethod rdf:type rdf:Property ;
    rdfs:label 'Recognition Method' ;
    rdfs:comment 'Method by which revenue is recognized for this record: FLOWN (recognized upon flight completion), ACCRUAL (deferred/accrual basis), PRORATE (interline prorate allocation), REDEMPTION (FFP miles redemption), REVERSAL (corrective reversal entry). Aligns with IFRS 15 performance obligation satisfaction.' ;
    rdfs:domain ind:Recognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognitionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Recognition Timestamp' ;
    rdfs:comment 'Timestamp when this revenue recognition entry was processed and posted in the revenue accounting system. Represents the business event time of recognition, distinct from the flight date and the record audit timestamp.' ;
    rdfs:domain ind:Recognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reportingCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Reporting Currency Amount' ;
    rdfs:comment 'Fare amount converted to the airline\'s functional reporting currency (e.g., USD) using the IROE exchange rate. Used for consolidated financial reporting in SAP S/4HANA FI/CO and DOT/IATA statistical submissions.' ;
    rdfs:domain ind:Recognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementCurrency rdf:type rdf:Property ;
    rdfs:label 'Settlement Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code in which the fare and surcharge amounts are denominated for BSP/ARC settlement (e.g., USD, EUR, GBP). Determines the settlement currency for interline billing.' ;
    rdfs:domain ind:Recognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemRecordReference rdf:type rdf:Property ;
    rdfs:label 'Source System Record Reference' ;
    rdfs:comment 'Native record identifier from the originating revenue accounting system (Sabre AirVision Revenue Management or SAP S/4HANA) for traceability and reconciliation between the lakehouse Silver layer and the operational system of record.' ;
    rdfs:domain ind:Recognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRefundId rdf:type rdf:Property ;
    rdfs:label 'Revenue Refund Id' ;
    rdfs:comment 'Primary key for refund' ;
    rdfs:domain ind:RevenueRefund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maintenanceWorkOrderId rdf:type rdf:Property ;
    rdfs:label 'Maintenance Work Order Id' ;
    rdfs:comment 'Foreign key linking to maintenance.work_order. Business justification: Refunds resulting from maintenance-induced cancellations/delays must link to causative work orders for cost recovery from maintenance providers, dispute resolution, and operational impact tracking. Cr' ;
    rdfs:domain ind:RevenueRefund ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkOrder .

ind:bspArcSettlementDate rdf:type rdf:Property ;
    rdfs:label 'Bsp Arc Settlement Date' ;
    rdfs:comment 'The date on which the refund amount was settled through the IATA Billing and Settlement Plan (BSP) or Airlines Reporting Corporation (ARC) settlement cycle. Null for direct refunds or miles refunds not routed through BSP/ARC.' ;
    rdfs:domain ind:RevenueRefund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ffpMilesRefunded rdf:type rdf:Property ;
    rdfs:label 'Ffp Miles Refunded' ;
    rdfs:comment 'Number of Frequent Flyer Program (FFP) miles credited back to the passenger\'s loyalty account as the refund method, or miles reinstated when an award ticket is cancelled. Populated only when refund_method is \'miles\'. Interfaces with Oracle Loyalty Cloud FFP Management.' ;
    rdfs:domain ind:RevenueRefund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:grossFareAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Fare Amount' ;
    rdfs:comment 'The total base fare amount on the original ticket or EMD before any taxes, fees, or surcharges. Represents the revenue component subject to refund calculation and penalty deduction. Expressed in the transaction currency.' ;
    rdfs:domain ind:RevenueRefund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:involuntaryReason rdf:type rdf:Property ;
    rdfs:label 'Involuntary Reason' ;
    rdfs:comment 'For involuntary refunds, the specific airline-caused reason triggering the mandatory refund obligation. \'flight_cancellation\' — flight cancelled by airline; \'significant_delay\' — delay exceeding regulatory threshold; \'denied_boarding\' — involuntary denied boarding (IDB); \'downgrade\' — passenger downgraded to lower cabin; \'schedule_change\' — schedule change beyond passenger tolerance. Null for voluntary refunds.' ;
    rdfs:domain ind:RevenueRefund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalFormOfPaymentCode rdf:type rdf:Property ;
    rdfs:label 'Original Form Of Payment Code' ;
    rdfs:comment 'IATA-standard form of payment code from the original ticket transaction (e.g., CC — credit card, CA — cash, CK — check, MS — miscellaneous, TP — tour order). Required for \'original_form_of_payment\' refund method to route the credit correctly through BSP or ARC settlement.' ;
    rdfs:domain ind:RevenueRefund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pnrCode rdf:type rdf:Property ;
    rdfs:label 'Pnr Code' ;
    rdfs:comment 'Six-character alphanumeric Passenger Name Record (PNR) locator code in the Amadeus Altéa PSS associated with the original booking from which this refund originates. Links the refund to the reservation context.' ;
    rdfs:domain ind:RevenueRefund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxBreakdownJson rdf:type rdf:Property ;
    rdfs:label 'Tax Breakdown Json' ;
    rdfs:comment 'Serialised JSON string containing the itemised breakdown of individual tax and fee components included in the tax_refund_amount (e.g., {"US": 12.50, "XF": 4.50, "AY": 5.60}). Each key is the IATA tax code and the value is the refund amount for that tax. Required for regulatory tax reporting and passenger transparency.' ;
    rdfs:domain ind:RevenueRefund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueSurchargeId rdf:type rdf:Property ;
    rdfs:label 'Revenue Surcharge Id' ;
    rdfs:comment 'Unique system-generated identifier for the carrier-imposed surcharge master record. Primary key for the revenue_surcharge product.' ;
    rdfs:domain ind:RevenueSurcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bookingClassApplicability rdf:type rdf:Property ;
    rdfs:label 'Booking Class Applicability' ;
    rdfs:comment 'Comma-separated list of RBD (Reservation Booking Designator) booking class codes to which this surcharge applies (e.g., \'Y,B,M,H,Q\'). Null or empty indicates applicability to all booking classes. Used in Sabre AirVision pricing rules to restrict surcharge to specific inventory buckets.' ;
    rdfs:domain ind:RevenueSurcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cabinApplicability rdf:type rdf:Property ;
    rdfs:label 'Cabin Applicability' ;
    rdfs:comment 'Cabin class scope for which this surcharge is applicable. All indicates the surcharge applies across all cabins; individual cabin values restrict applicability to specific service classes. Drives differential surcharge pricing by cabin in revenue management.' ;
    rdfs:domain ind:RevenueSurcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingSource rdf:type rdf:Property ;
    rdfs:label 'Filing Source' ;
    rdfs:comment 'Source channel through which this surcharge was filed and distributed. ATPCO (Airline Tariff Publishing Company) is the primary industry filing channel; carrier_direct indicates the surcharge was loaded directly into the carrier\'s PSS without ATPCO filing; GDS indicates direct GDS filing; BSP indicates filing via IATA Billing and Settlement Plan.' ;
    rdfs:domain ind:RevenueSurcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Amount' ;
    rdfs:comment 'Maximum monetary ceiling for the surcharge when using percentage-based calculation. Caps the surcharge on high-fare tickets to maintain competitive pricing. Expressed in the currency defined by currency_code.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Amount' ;
    rdfs:comment 'Minimum monetary floor for the surcharge when using percentage-based calculation. Ensures the surcharge does not fall below a commercially viable threshold on low-fare tickets. Expressed in the currency defined by currency_code.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nucAmount rdf:type rdf:Property ;
    rdfs:label 'Nuc Amount' ;
    rdfs:comment 'Surcharge amount expressed in IATA Neutral Units of Construction (NUC) for international fare construction. NUC amounts are currency-neutral and converted to local currency using IATA-published ROE (Rate of Exchange) at time of ticketing. Required for IATA-compliant international fare construction.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:perCouponIndicator rdf:type rdf:Property ;
    rdfs:label 'Per Coupon Indicator' ;
    rdfs:comment 'Indicates whether the surcharge amount is applied per flight coupon (sector) or per ticket/journey. True = per coupon (each flight segment incurs the surcharge independently); False = per ticket (surcharge applied once per ticket regardless of number of sectors). Critical for multi-sector itinerary pricing.' ;
    rdfs:domain ind:RevenueSurcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:percentageRate rdf:type rdf:Property ;
    rdfs:label 'Percentage Rate' ;
    rdfs:comment 'Percentage of the base fare applied as the surcharge when the calculation method is percentage-based. Expressed as a decimal (e.g., 5.25 = 5.25%). Null when the surcharge is a flat amount. Used in dynamic pricing and revenue management yield calculations.' ;
    rdfs:domain ind:RevenueSurcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:subCode rdf:type rdf:Property ;
    rdfs:label 'Sub Code' ;
    rdfs:comment 'Carrier-defined sub-code qualifying the primary surcharge code (e.g., YQ/F for fuel, YQ/I for infrastructure). Used by ATPCO and GDS systems to distinguish multiple surcharge types filed under the same two-letter code.' ;
    rdfs:domain ind:RevenueSurcharge ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxFeeId rdf:type rdf:Property ;
    rdfs:label 'Tax Fee Id' ;
    rdfs:comment 'Unique surrogate identifier for each tax or fee record in the reference master. Primary key for the tax_fee data product.' ;
    rdfs:domain ind:TaxFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cabinClassApplicability rdf:type rdf:Property ;
    rdfs:label 'Cabin Class Applicability' ;
    rdfs:comment 'Specifies the cabin class to which this tax or fee applies: all (applies regardless of cabin), economy, premium_economy, business, first. Certain taxes (e.g., UK Air Passenger Duty Band B) vary by cabin class.' ;
    rdfs:domain ind:TaxFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectingAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Collecting Authority Name' ;
    rdfs:comment 'Full legal name of the authority or entity to which the collected tax or fee must be remitted (e.g., \'Internal Revenue Service\', \'Heathrow Airport Holdings\', \'EUROCONTROL\'). Used in remittance instructions and regulatory filings.' ;
    rdfs:domain ind:TaxFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectingAuthorityType rdf:type rdf:Property ;
    rdfs:label 'Collecting Authority Type' ;
    rdfs:comment 'Category of the entity legally mandated to collect and remit the tax or fee: government (national or sub-national tax authority), airport_operator (airport authority or concessionaire), carrier (airline collecting on behalf of itself), intergovernmental (body such as EUROCONTROL). Determines remittance workflow and BSP/ARC settlement routing.' ;
    rdfs:domain ind:TaxFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:corsiaApplicable rdf:type rdf:Property ;
    rdfs:label 'Corsia Applicable' ;
    rdfs:comment 'Indicates whether this tax or fee is related to or counts toward CORSIA (Carbon Offsetting and Reduction Scheme for International Aviation) compliance obligations (True) or is unrelated to carbon/environmental compliance (False).' ;
    rdfs:domain ind:TaxFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exemptPassengerTypes rdf:type rdf:Property ;
    rdfs:label 'Exempt Passenger Types' ;
    rdfs:comment 'Comma-separated list of IATA Passenger Type Codes (PTCs) or categories that are legally exempt from this tax or fee (e.g., \'INF,DIP,GOV\' for infants, diplomatic, and government passengers). Null if no exemptions apply. Used by the pricing engine to suppress the tax for qualifying passengers.' ;
    rdfs:domain ind:TaxFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iataTaxCategory rdf:type rdf:Property ;
    rdfs:label 'Iata Tax Category' ;
    rdfs:comment 'IATA-defined category distinguishing the nature of the charge as published in the IATA Tax Code Directory: tax (government-mandated levy), fee (service-based charge), charge (airport or infrastructure charge), surcharge (carrier-imposed additional charge such as fuel surcharge YQ/YR).' ;
    rdfs:domain ind:TaxFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passengerTypeApplicability rdf:type rdf:Property ;
    rdfs:label 'Passenger Type Applicability' ;
    rdfs:comment 'Specifies which IATA passenger type codes (PTCs) are subject to this tax or fee: all (applies to every passenger type), adult, child, infant, unaccompanied_minor. Certain taxes (e.g., UK APD) have reduced or zero rates for infants.' ;
    rdfs:domain ind:TaxFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reference' ;
    rdfs:comment 'Citation of the specific legislation, regulation, or IATA resolution that mandates or authorizes this tax or fee (e.g., \'US Internal Revenue Code Section 4261\', \'UK Finance Act 1994 Section 28\', \'IATA Resolution 728\'). Supports regulatory compliance documentation and audit.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remittanceChannel rdf:type rdf:Property ;
    rdfs:label 'Remittance Channel' ;
    rdfs:comment 'The settlement channel through which collected tax amounts are remitted: bsp (IATA Billing and Settlement Plan), arc (Airlines Reporting Corporation), direct_to_authority (direct payment to government or airport), interline_settlement (via interline billing agreement). Drives the revenue accounting remittance workflow.' ;
    rdfs:domain ind:TaxFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remittanceDestinationCode rdf:type rdf:Property ;
    rdfs:label 'Remittance Destination Code' ;
    rdfs:comment 'Standardized code identifying the remittance destination account or clearing body (e.g., BSP country code, ARC settlement code, or government tax authority reference). Used by revenue accounting to route tax remittance payments correctly.' ;
    rdfs:domain ind:TaxFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeSpecific rdf:type rdf:Property ;
    rdfs:label 'Route Specific' ;
    rdfs:comment 'Indicates whether this tax or fee is applicable only to specific origin-destination route pairs (True) or applies broadly based on country/airport-level rules (False). When True, origin_country_code, destination_country_code, and/or airport_code fields define the specific applicability.' ;
    rdfs:domain ind:TaxFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sapTaxCode rdf:type rdf:Property ;
    rdfs:label 'Sap Tax Code' ;
    rdfs:comment 'The corresponding tax code as configured in SAP S/4HANA FI/CO module for general ledger posting and tax remittance processing. Enables automated mapping between the IATA tax_code and the SAP financial accounting tax configuration for revenue accounting.' ;
    rdfs:domain ind:TaxFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByTaxCode rdf:type rdf:Property ;
    rdfs:label 'Superseded By Tax Code' ;
    rdfs:comment 'The IATA tax code of the successor record when this tax or fee has been superseded (status = superseded). Enables the pricing engine and revenue accounting to trace the lineage of tax code changes and apply the correct current code.' ;
    rdfs:domain ind:TaxFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxBasis rdf:type rdf:Property ;
    rdfs:label 'Tax Basis' ;
    rdfs:comment 'The fare component or amount upon which an ad_valorem_percent tax is calculated: base_fare (net fare excluding taxes), total_fare (gross fare including other charges), fuel_surcharge (applied only to the YQ/YR surcharge component), carrier_imposed_fee, ticket_price. Relevant only for ad_valorem_percent calculation_method.' ;
    rdfs:domain ind:TaxFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxFeeStatus rdf:type rdf:Property ;
    rdfs:label 'Tax Fee Status' ;
    rdfs:comment 'Lifecycle status of the tax or fee record: active (currently in force and applicable), inactive (no longer applicable), superseded (replaced by a newer version of the same tax code), pending (approved but not yet effective). Controls whether the pricing engine includes this record in tax calculations.' ;
    rdfs:domain ind:TaxFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxName rdf:type rdf:Property ;
    rdfs:label 'Tax Name' ;
    rdfs:comment 'Full descriptive name of the tax or fee as published by the collecting authority (e.g., \'US Federal Excise Tax\', \'UK Air Passenger Duty\', \'Airport Passenger Facility Charge\'). Displayed on passenger itineraries and tax remittance reports.' ;
    rdfs:domain ind:TaxFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ticketTypeApplicability rdf:type rdf:Property ;
    rdfs:label 'Ticket Type Applicability' ;
    rdfs:comment 'Specifies the ticket document type to which this tax or fee applies: all, e_ticket (electronic ticket), paper_ticket, emd (Electronic Miscellaneous Document). Most modern taxes apply to all ticket types, but some legacy charges are document-type-specific.' ;
    rdfs:domain ind:TaxFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waivable rdf:type rdf:Property ;
    rdfs:label 'Waivable' ;
    rdfs:comment 'Indicates whether the carrier has authority to waive this tax or fee under specific circumstances (True) or whether collection is legally mandatory and cannot be waived (False). Relevant for IROP (Irregular Operations) handling and diplomatic/government fare exemptions.' ;
    rdfs:domain ind:TaxFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:couponCount rdf:type rdf:Property ;
    rdfs:label 'Coupon Count' ;
    rdfs:comment 'Number of flight coupons (individual flight segments) contained within this ticket document. Standard tickets carry 1–4 coupons. Used for itinerary completeness validation and conjunction ticket detection.' ;
    rdfs:domain ind:Ticket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:endorsementRestrictionText rdf:type rdf:Property ;
    rdfs:label 'Endorsement Restriction Text' ;
    rdfs:comment 'Free-text endorsement and restriction field printed on the ticket indicating fare conditions such as \'NON-ENDORSE/NON-REROUTE\', \'VALID ON XX ONLY\', or interline restrictions. Governs reissue, refund, and exchange eligibility.' ;
    rdfs:domain ind:Ticket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ffpMilesEarned rdf:type rdf:Property ;
    rdfs:label 'Ffp Miles Earned' ;
    rdfs:comment 'Number of frequent flyer miles/points accrued on this ticket based on the fare basis, booking class, and FFP tier. Zero for award tickets (fare_type=FFP) or non-accruing fares. Feeds Oracle Loyalty Cloud for member account crediting.' ;
    rdfs:domain ind:Ticket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:netRemitAmount rdf:type rdf:Property ;
    rdfs:label 'Net Remit Amount' ;
    rdfs:comment 'The net amount remitted to the airline after deducting agency commission and applicable incentives from the total fare. Used in BSP/ARC settlement reconciliation and airline revenue accounting in SAP S/4HANA FI.' ;
    rdfs:domain ind:Ticket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:saleCountryCode rdf:type rdf:Property ;
    rdfs:label 'Sale Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the country in which the ticket was sold. Determines applicable taxes, consumer protection regulations (DOT, EASA), and BSP/ARC settlement jurisdiction.' ;
    rdfs:domain ind:Ticket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxTotalAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Total Amount' ;
    rdfs:comment 'Aggregate of all government taxes, airport fees, and surcharges (e.g., PFC, September 11th Security Fee, fuel surcharge YQ/YR) applied to the ticket. Part of the MONETARY_TRIPLET adjustment component. Detailed tax breakdown is stored at coupon level.' ;
    rdfs:domain ind:Ticket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualDepartureDate rdf:type rdf:Property ;
    rdfs:label 'Actual Departure Date' ;
    rdfs:comment 'Actual calendar date on which the passenger departed on this coupon segment. May differ from scheduled departure date due to IROP (Irregular Operations), reprotection, or voluntary rebooking. Used for revenue recognition and OTP reporting.' ;
    rdfs:domain ind:TicketCoupon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exchangeTicketNumber rdf:type rdf:Property ;
    rdfs:label 'Exchange Ticket Number' ;
    rdfs:comment '13-digit ticket number of the original e-ticket that was exchanged to produce this coupon. Populated when coupon_status is E (Exchanged). Required for BSP/ARC exchange transaction reporting and revenue accounting audit trail.' ;
    rdfs:domain ind:TicketCoupon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fareConstructionIndicator rdf:type rdf:Property ;
    rdfs:label 'Fare Construction Indicator' ;
    rdfs:comment 'Indicates the fare construction method applied to this coupon: NUC=Neutral Unit of Construction (IATA proration), SITI=Sold Inside/Ticketed Inside, SOTO=Sold Outside/Ticketed Outside, SITO=Sold Inside/Ticketed Outside, SOTI=Sold Outside/Ticketed Inside. Governs BSP settlement currency conversion rules.' ;
    rdfs:domain ind:TicketCoupon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingDate rdf:type rdf:Property ;
    rdfs:label 'Issuing Date' ;
    rdfs:comment 'Calendar date on which the e-ticket containing this coupon was issued. Used for revenue period allocation, BSP/ARC reporting cycles, and advance purchase restriction validation.' ;
    rdfs:domain ind:TicketCoupon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:settlementType rdf:type rdf:Property ;
    rdfs:label 'Settlement Type' ;
    rdfs:comment 'Identifies the settlement channel through which this coupon will be or has been financially settled: BSP=IATA Billing and Settlement Plan, ARC=Airlines Reporting Corporation (US domestic), DIRECT=direct airline settlement, INTERLINE=interline billing via IATA Clearing House.' ;
    rdfs:domain ind:TicketCoupon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ticketExchangeId rdf:type rdf:Property ;
    rdfs:label 'Ticket Exchange Id' ;
    rdfs:comment 'Primary key for ticket_exchange' ;
    rdfs:domain ind:TicketExchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalTicketId rdf:type rdf:Property ;
    rdfs:label 'Original Ticket Id' ;
    rdfs:comment 'Foreign key linking to revenue.ticket. Business justification: ticket_exchange captures voluntary or involuntary ticket modifications (reissues). Each exchange references an original ticket being exchanged. The table has original_ticket_number (STRING) as a busin' ;
    rdfs:domain ind:TicketExchange ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Ticket .

ind:exchangeReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Exchange Reference Number' ;
    rdfs:comment 'Externally-known business identifier for the ticket exchange transaction, typically generated by the Passenger Service System (PSS) or GDS at the time of reissue. Used for cross-system reconciliation and customer-facing reference.' ;
    rdfs:domain ind:TicketExchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeStatus rdf:type rdf:Property ;
    rdfs:label 'Exchange Status' ;
    rdfs:comment 'Current lifecycle status of the ticket exchange transaction. Pending indicates initiated but not finalized; completed indicates successfully processed; voided indicates cancelled before settlement; failed indicates processing error; reversed indicates post-completion reversal.' ;
    rdfs:domain ind:TicketExchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeType rdf:type rdf:Property ;
    rdfs:label 'Exchange Type' ;
    rdfs:comment 'Classification of the reason or nature of the ticket exchange. Voluntary indicates passenger-initiated change; involuntary indicates airline-initiated change; upgrade/downgrade reflect cabin class changes; irop_reprotection covers Irregular Operations (IROP) rebooking; schedule_change covers airline schedule modifications. [ENUM-REF-CANDIDATE: voluntary|involuntary|upgrade|downgrade|irop_reprotection|schedule_change — promote to reference product]' ;
    rdfs:domain ind:TicketExchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdsTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Gds Transaction Reference' ;
    rdfs:comment 'Unique transaction identifier assigned by the Global Distribution System (GDS) — such as Amadeus or Sabre — at the time the exchange was processed. Used for cross-system reconciliation between the PSS and GDS settlement records.' ;
    rdfs:domain ind:TicketExchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:involuntaryReasonCode rdf:type rdf:Property ;
    rdfs:label 'Involuntary Reason Code' ;
    rdfs:comment 'Airline-defined reason code specifying the cause of an involuntary ticket exchange (e.g., flight cancellation, significant schedule change, equipment downgrade, denied boarding). Populated only when exchange_type is involuntary or irop_reprotection. Required for DOT and EASA regulatory reporting on involuntary rerouting.' ;
    rdfs:domain ind:TicketExchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingCarrierCode rdf:type rdf:Property ;
    rdfs:label 'Issuing Carrier Code' ;
    rdfs:comment 'IATA two-letter or ICAO three-letter airline designator code of the carrier that issued the new ticket. May differ from the operating carrier in codeshare or interline scenarios.' ;
    rdfs:domain ind:TicketExchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newFareAmount rdf:type rdf:Property ;
    rdfs:label 'New Fare Amount' ;
    rdfs:comment 'Gross base fare amount of the newly issued ticket in the transaction currency, excluding taxes and fees. Used to compute the fare difference and assess revenue uplift or dilution from the exchange.' ;
    rdfs:domain ind:TicketExchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:newTravelDate rdf:type rdf:Property ;
    rdfs:label 'New Travel Date' ;
    rdfs:comment 'Scheduled departure date of the first flight segment on the newly issued ticket itinerary after exchange. Used for demand forecasting, load factor impact assessment, and revenue period reporting.' ;
    rdfs:domain ind:TicketExchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originalTravelDate rdf:type rdf:Property ;
    rdfs:label 'Original Travel Date' ;
    rdfs:comment 'Scheduled departure date of the first flight segment on the original ticket itinerary prior to exchange. Used for seasonality analysis, advance purchase tracking, and revenue accounting period alignment.' ;
    rdfs:domain ind:TicketExchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:settlementPlanType rdf:type rdf:Property ;
    rdfs:label 'Settlement Plan Type' ;
    rdfs:comment 'Identifies the settlement mechanism through which the exchange transaction will be financially settled. BSP (Billing and Settlement Plan) for IATA-member markets; ARC (Airlines Reporting Corporation) for US/Canada markets; direct for airline-direct sales channels.' ;
    rdfs:domain ind:TicketExchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxDifferenceAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Difference Amount' ;
    rdfs:comment 'Net difference in applicable taxes and surcharges between the new ticket and the original ticket. Positive indicates additional tax collection; negative indicates tax credit. Required for accurate BSP settlement and revenue accounting.' ;
    rdfs:domain ind:TicketExchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yieldParameterId rdf:type rdf:Property ;
    rdfs:label 'Yield Parameter Id' ;
    rdfs:comment 'Unique surrogate identifier for the yield management parameter configuration record. Primary key for this entity.' ;
    rdfs:domain ind:YieldParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bidPriceCurveId rdf:type rdf:Property ;
    rdfs:label 'Bid Price Curve Id' ;
    rdfs:comment 'Reference identifier for the bid price curve configuration applied to this yield parameter set. The bid price curve defines the minimum acceptable revenue threshold per seat at each inventory level.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BidPriceCurve .

ind:bookingClassThresholdCount rdf:type rdf:Property ;
    rdfs:label 'Booking Class Threshold Count' ;
    rdfs:comment 'Number of booking class availability thresholds (authorization levels) configured for this yield parameter set. Defines how many fare class buckets are actively managed by the RM optimization engine.' ;
    rdfs:domain ind:YieldParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cancellationRate rdf:type rdf:Property ;
    rdfs:label 'Cancellation Rate' ;
    rdfs:comment 'Historical booking cancellation rate (0.0000–1.0000) for this market or route, used alongside no-show rate to calibrate overbooking levels and availability controls.' ;
    rdfs:domain ind:YieldParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:caskBenchmark rdf:type rdf:Property ;
    rdfs:label 'Cask Benchmark' ;
    rdfs:comment 'Cost per Available Seat Kilometer (CASK) benchmark in the operating currency used as the cost floor reference for yield optimization decisions. Sourced from SAP S/4HANA FI/CO cost accounting.' ;
    rdfs:domain ind:YieldParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dilutionTolerance rdf:type rdf:Property ;
    rdfs:label 'Dilution Tolerance' ;
    rdfs:comment 'Maximum acceptable revenue dilution rate — the percentage of passengers who could have paid a higher fare but were sold a lower fare class. Constrains how aggressively lower booking classes are opened.' ;
    rdfs:domain ind:YieldParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dynamicPricingCeiling rdf:type rdf:Property ;
    rdfs:label 'Dynamic Pricing Ceiling' ;
    rdfs:comment 'Maximum fare amount (in operating currency) above which the dynamic pricing engine is not permitted to set a fare for this market or route. Prevents consumer protection violations and brand damage.' ;
    rdfs:domain ind:YieldParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dynamicPricingEnabled rdf:type rdf:Property ;
    rdfs:label 'Dynamic Pricing Enabled' ;
    rdfs:comment 'Indicates whether dynamic (continuous) pricing is enabled for this yield parameter configuration. When true, the RM engine applies real-time fare adjustments within authorized bounds rather than discrete fare class steps.' ;
    rdfs:domain ind:YieldParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dynamicPricingFloor rdf:type rdf:Property ;
    rdfs:label 'Dynamic Pricing Floor' ;
    rdfs:comment 'Minimum fare amount (in operating currency) below which the dynamic pricing engine is not permitted to set a fare for this market or route. Protects against revenue dilution under automated pricing.' ;
    rdfs:domain ind:YieldParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastHorizonDays rdf:type rdf:Property ;
    rdfs:label 'Forecast Horizon Days' ;
    rdfs:comment 'Number of days ahead for which the demand forecast is generated and applied in yield optimization. Defines the planning window for booking class availability controls.' ;
    rdfs:domain ind:YieldParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:forecastModelType rdf:type rdf:Property ;
    rdfs:label 'Forecast Model Type' ;
    rdfs:comment 'Type of demand forecasting model applied by the RM optimization engine for this parameter set. Determines how historical booking curves and pickup patterns are weighted in availability decisions.' ;
    rdfs:domain ind:YieldParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupBookingThreshold rdf:type rdf:Property ;
    rdfs:label 'Group Booking Threshold' ;
    rdfs:comment 'Minimum number of passengers (Pax) that qualifies a booking as a group booking, triggering separate group inventory controls and pricing rules distinct from individual seat availability management.' ;
    rdfs:domain ind:YieldParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:historicalWeight rdf:type rdf:Property ;
    rdfs:label 'Historical Weight' ;
    rdfs:comment 'Weighting factor (0.0000–1.0000) applied to historical booking data in the blended demand forecast model. Higher values favor historical patterns; lower values favor recent pickup trends. Must sum to 1.0 with pickup_weight.' ;
    rdfs:domain ind:YieldParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastReviewedDate rdf:type rdf:Property ;
    rdfs:label 'Last Reviewed Date' ;
    rdfs:comment 'Date on which this yield parameter configuration was most recently reviewed by the Revenue Management team. Supports governance tracking and parameter staleness detection.' ;
    rdfs:domain ind:YieldParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:loadFactorMinimum rdf:type rdf:Property ;
    rdfs:label 'Load Factor Minimum' ;
    rdfs:comment 'Minimum acceptable load factor threshold below which the RM system triggers promotional availability or fare class opening actions. Expressed as a percentage (0.00–100.00).' ;
    rdfs:domain ind:YieldParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumYieldFloor rdf:type rdf:Property ;
    rdfs:label 'Minimum Yield Floor' ;
    rdfs:comment 'Minimum acceptable yield (revenue per Revenue Passenger Kilometer) below which seat inventory must not be sold. Acts as the absolute revenue protection floor in bid price calculations. Expressed in operating currency per RPK.' ;
    rdfs:domain ind:YieldParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:noShowRate rdf:type rdf:Property ;
    rdfs:label 'No Show Rate' ;
    rdfs:comment 'Historical no-show rate (0.0000–1.0000) for this market or route, used as an input to overbooking authorization calculations. Sourced from Amadeus Altéa PSS departure control data.' ;
    rdfs:domain ind:YieldParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:odControlEnabled rdf:type rdf:Property ;
    rdfs:label 'Od Control Enabled' ;
    rdfs:comment 'Indicates whether origin-destination (O&D) network revenue management control is active for this parameter set. When true, the RM engine optimizes across connecting itineraries rather than leg-by-leg.' ;
    rdfs:domain ind:YieldParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optimizationMethod rdf:type rdf:Property ;
    rdfs:label 'Optimization Method' ;
    rdfs:comment 'Optimization algorithm applied by Sabre AirVision for seat inventory allocation under this parameter set. EMSR-A and EMSR-B are Expected Marginal Seat Revenue variants; LP-based and network bid price methods support O&D (origin-destination) optimization.' ;
    rdfs:domain ind:YieldParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overbookingAuthorizationRate rdf:type rdf:Property ;
    rdfs:label 'Overbooking Authorization Rate' ;
    rdfs:comment 'Authorized overbooking percentage above physical seat capacity for this market or route. Expressed as a percentage above 100% (e.g., 5.00 means 5% above capacity). Governed by DOT consumer protection regulations and airline denied boarding policy.' ;
    rdfs:domain ind:YieldParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parameterCode rdf:type rdf:Property ;
    rdfs:label 'Parameter Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this yield parameter configuration within Sabre AirVision RM. Used for cross-system reference and audit trails.' ;
    rdfs:domain ind:YieldParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parameterDescription rdf:type rdf:Property ;
    rdfs:label 'Parameter Description' ;
    rdfs:comment 'Free-text description providing business context for this yield parameter configuration, including rationale for non-standard settings, market conditions, or special events driving the configuration.' ;
    rdfs:domain ind:YieldParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parameterName rdf:type rdf:Property ;
    rdfs:label 'Parameter Name' ;
    rdfs:comment 'Human-readable name describing the yield parameter configuration, e.g., \'TRANSATLANTIC_PEAK_SUMMER_2025\'. Used for display and reporting in revenue management dashboards.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parameterStatus rdf:type rdf:Property ;
    rdfs:label 'Parameter Status' ;
    rdfs:comment 'Current lifecycle state of the yield parameter configuration record. Active records are applied by the RM optimization engine; draft records are under review; archived records are retained for historical analysis.' ;
    rdfs:domain ind:YieldParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parameterType rdf:type rdf:Property ;
    rdfs:label 'Parameter Type' ;
    rdfs:comment 'Categorizes the scope at which this yield parameter applies: market-level, route-level, flight-group-level, cabin-level, or global default. Determines the optimization hierarchy in Sabre AirVision.' ;
    rdfs:domain ind:YieldParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickupWeight rdf:type rdf:Property ;
    rdfs:label 'Pickup Weight' ;
    rdfs:comment 'Weighting factor (0.0000–1.0000) applied to recent booking pickup trend data in the blended demand forecast model. Complements historical_weight; both must sum to 1.0.' ;
    rdfs:domain ind:YieldParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:raskTarget rdf:type rdf:Property ;
    rdfs:label 'Rask Target' ;
    rdfs:comment 'Target Revenue per Available Seat Kilometer (RASK) in the operating currency for this market or route configuration. Expressed as revenue per ASK. Used as the primary revenue performance benchmark in RM optimization.' ;
    rdfs:domain ind:YieldParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reviewFrequency rdf:type rdf:Property ;
    rdfs:label 'Review Frequency' ;
    rdfs:comment 'Scheduled frequency at which the Revenue Management team reviews and potentially updates this yield parameter configuration. Drives the RM governance and parameter maintenance workflow.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spoilageTolerance rdf:type rdf:Property ;
    rdfs:label 'Spoilage Tolerance' ;
    rdfs:comment 'Maximum acceptable seat spoilage rate (percentage of seats departing empty) tolerated before the RM system adjusts availability controls to open lower fare classes. Expressed as a percentage.' ;
    rdfs:domain ind:YieldParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityPlannerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Capacity Planner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: ASK planning is performed by capacity planning staff who forecast demand, optimize seat allocation, and coordinate with revenue management. Strategic planning function requiring ownership - plan_appro' ;
    rdfs:domain ind:AskPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:bilateralAgreementCode rdf:type rdf:Property ;
    rdfs:label 'Bilateral Agreement Code' ;
    rdfs:comment 'Code identifying the bilateral air service agreement between countries that governs this route. Relevant for international routes subject to traffic rights and capacity restrictions.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hubSpokeClassification rdf:type rdf:Property ;
    rdfs:label 'Hub Spoke Classification' ;
    rdfs:comment 'Classification of the route within the airlines hub-and-spoke network topology. Indicates whether the route connects hubs, connects a hub to a spoke, or is a point-to-point service.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Plan Approval Date' ;
    rdfs:comment 'Date on which this capacity plan was formally approved by network planning or revenue management leadership.' ;
    rdfs:domain ind:AskPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planNotes rdf:type rdf:Property ;
    rdfs:label 'Plan Notes' ;
    rdfs:comment 'Free-text notes or comments regarding this capacity plan. May include rationale for capacity decisions, assumptions, constraints, or special considerations.' ;
    rdfs:domain ind:AskPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedBusinessClassSeats rdf:type rdf:Property ;
    rdfs:label 'Planned Business Class Seats' ;
    rdfs:comment 'Number of business class seats planned per flight on this route. Part of the cabin mix configuration.' ;
    rdfs:domain ind:AskPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedCask rdf:type rdf:Property ;
    rdfs:label 'Planned Cask' ;
    rdfs:comment 'Planned unit cost per Available Seat Kilometer for this route. Used in profitability analysis and route performance evaluation. Business-confidential financial metric.' ;
    rdfs:domain ind:AskPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedEconomySeats rdf:type rdf:Property ;
    rdfs:label 'Planned Economy Seats' ;
    rdfs:comment 'Number of economy class seats planned per flight on this route. Part of the cabin mix configuration.' ;
    rdfs:domain ind:AskPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedFirstClassSeats rdf:type rdf:Property ;
    rdfs:label 'Planned First Class Seats' ;
    rdfs:comment 'Number of first class seats planned per flight on this route. Part of the cabin mix configuration.' ;
    rdfs:domain ind:AskPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedFrequency rdf:type rdf:Property ;
    rdfs:label 'Planned Frequency' ;
    rdfs:comment 'Number of planned flight departures on this route during the season or planning period. Represents service frequency (e.g., daily, 3x weekly).' ;
    rdfs:domain ind:AskPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedPremiumEconomySeats rdf:type rdf:Property ;
    rdfs:label 'Planned Premium Economy Seats' ;
    rdfs:comment 'Number of premium economy seats planned per flight on this route. Part of the cabin mix configuration.' ;
    rdfs:domain ind:AskPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedRask rdf:type rdf:Property ;
    rdfs:label 'Planned Rask' ;
    rdfs:comment 'Planned unit revenue per Available Seat Kilometer for this route. Used in revenue forecasting and route performance evaluation. Business-confidential financial metric.' ;
    rdfs:domain ind:AskPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedTotalSeats rdf:type rdf:Property ;
    rdfs:label 'Planned Total Seats' ;
    rdfs:comment 'Total number of seats planned per flight on this route, summed across all cabin classes. Represents the aircraft gauge capacity.' ;
    rdfs:domain ind:AskPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedYield rdf:type rdf:Property ;
    rdfs:label 'Planned Yield' ;
    rdfs:comment 'Planned yield (revenue per Revenue Passenger Kilometer) for this route. Key revenue management metric used in pricing and capacity optimization. Business-confidential financial metric.' ;
    rdfs:domain ind:AskPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planningPeriodType rdf:type rdf:Property ;
    rdfs:label 'Planning Period Type' ;
    rdfs:comment 'Granularity of the capacity planning period. Indicates whether this plan represents monthly, weekly, seasonal, or annual capacity deployment.' ;
    rdfs:domain ind:AskPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slotAllocationStatus rdf:type rdf:Property ;
    rdfs:label 'Slot Allocation Status' ;
    rdfs:comment 'Status of airport slot allocation for this route at constrained airports. Indicates whether required takeoff and landing slots have been secured.' ;
    rdfs:domain ind:AskPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementName rdf:type rdf:Property ;
    rdfs:label 'Agreement Name' ;
    rdfs:comment 'Official name or title of the bilateral air service agreement, typically referencing the two countries involved.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementNumber rdf:type rdf:Property ;
    rdfs:label 'Agreement Number' ;
    rdfs:comment 'Official reference number or treaty identifier assigned to the bilateral air service agreement by the governing authorities.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:askLimitCountryA rdf:type rdf:Property ;
    rdfs:label 'Ask Limit Country A' ;
    rdfs:comment 'Maximum Available Seat Kilometers permitted per week or month for designated carriers of Country A under the bilateral agreement. Null if unlimited.' ;
    rdfs:domain ind:BilateralAsa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:askLimitCountryB rdf:type rdf:Property ;
    rdfs:label 'Ask Limit Country B' ;
    rdfs:comment 'Maximum Available Seat Kilometers permitted per week or month for designated carriers of Country B under the bilateral agreement. Null if unlimited.' ;
    rdfs:domain ind:BilateralAsa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cabotagePermitted rdf:type rdf:Property ;
    rdfs:label 'Cabotage Permitted' ;
    rdfs:comment 'Indicates whether the agreement permits cabotage (eighth or ninth freedom rights), allowing an airline of one country to carry passengers or cargo between two points within the other country.' ;
    rdfs:domain ind:BilateralAsa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capacityEntitlementType rdf:type rdf:Property ;
    rdfs:label 'Capacity Entitlement Type' ;
    rdfs:comment 'Type of capacity entitlement specified in the agreement. Unlimited allows unrestricted capacity; predetermined sets fixed capacity levels; Bermuda-type links capacity to demand; frequency-limited restricts number of flights; seat-limited restricts number of seats; ASK-limited restricts Available Seat Kilometers.' ;
    rdfs:domain ind:BilateralAsa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeOfGaugePermitted rdf:type rdf:Property ;
    rdfs:label 'Change Of Gauge Permitted' ;
    rdfs:comment 'Indicates whether the agreement permits change of gauge operations, allowing an airline to change aircraft size at an intermediate point on a route.' ;
    rdfs:domain ind:BilateralAsa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:codesharePermitted rdf:type rdf:Property ;
    rdfs:label 'Codeshare Permitted' ;
    rdfs:comment 'Indicates whether the agreement permits codeshare arrangements between designated carriers and other airlines.' ;
    rdfs:domain ind:BilateralAsa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:countryACode rdf:type rdf:Property ;
    rdfs:label 'Country A Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 code for the first country party to the bilateral agreement.' ;
    rdfs:domain ind:BilateralAsa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryBCode rdf:type rdf:Property ;
    rdfs:label 'Country B Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 code for the second country party to the bilateral agreement.' ;
    rdfs:domain ind:BilateralAsa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designatedCarriersCountryA rdf:type rdf:Property ;
    rdfs:label 'Designated Carriers Country A' ;
    rdfs:comment 'List or description of airlines designated by Country A to operate services under the bilateral air service agreement. May specify airline names, IATA codes, or designation criteria.' ;
    rdfs:domain ind:BilateralAsa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:designatedCarriersCountryB rdf:type rdf:Property ;
    rdfs:label 'Designated Carriers Country B' ;
    rdfs:comment 'List or description of airlines designated by Country B to operate services under the bilateral air service agreement. May specify airline names, IATA codes, or designation criteria.' ;
    rdfs:domain ind:BilateralAsa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeResolutionMechanism rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Mechanism' ;
    rdfs:comment 'Description of the dispute resolution mechanism specified in the agreement, such as arbitration, consultation, or referral to ICAO.' ;
    rdfs:domain ind:BilateralAsa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fifthFreedomRights rdf:type rdf:Property ;
    rdfs:label 'Fifth Freedom Rights' ;
    rdfs:comment 'Indicates whether the agreement grants fifth freedom rights, allowing an airline of Country A to carry passengers or cargo between Country B and a third country as part of a service originating or terminating in Country A.' ;
    rdfs:domain ind:BilateralAsa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fourthFreedomRights rdf:type rdf:Property ;
    rdfs:label 'Fourth Freedom Rights' ;
    rdfs:comment 'Indicates whether the agreement grants fourth freedom rights, allowing an airline of Country A to carry passengers or cargo from Country B to Country A.' ;
    rdfs:domain ind:BilateralAsa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:frequencyLimitCountryA rdf:type rdf:Property ;
    rdfs:label 'Frequency Limit Country A' ;
    rdfs:comment 'Maximum number of weekly or monthly flight frequencies permitted for designated carriers of Country A under the bilateral agreement. Null if unlimited.' ;
    rdfs:domain ind:BilateralAsa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:frequencyLimitCountryB rdf:type rdf:Property ;
    rdfs:label 'Frequency Limit Country B' ;
    rdfs:comment 'Maximum number of weekly or monthly flight frequencies permitted for designated carriers of Country B under the bilateral agreement. Null if unlimited.' ;
    rdfs:domain ind:BilateralAsa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:routeScheduleAnnex rdf:type rdf:Property ;
    rdfs:label 'Route Schedule Annex' ;
    rdfs:comment 'Reference to the annex or schedule attached to the bilateral agreement that specifies the authorized routes, intermediate points, and beyond points for designated carriers.' ;
    rdfs:domain ind:BilateralAsa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seatLimitCountryA rdf:type rdf:Property ;
    rdfs:label 'Seat Limit Country A' ;
    rdfs:comment 'Maximum number of seats per week or month permitted for designated carriers of Country A under the bilateral agreement. Null if unlimited.' ;
    rdfs:domain ind:BilateralAsa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seatLimitCountryB rdf:type rdf:Property ;
    rdfs:label 'Seat Limit Country B' ;
    rdfs:comment 'Maximum number of seats per week or month permitted for designated carriers of Country B under the bilateral agreement. Null if unlimited.' ;
    rdfs:domain ind:BilateralAsa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seventhFreedomRights rdf:type rdf:Property ;
    rdfs:label 'Seventh Freedom Rights' ;
    rdfs:comment 'Indicates whether the agreement grants seventh freedom rights, allowing an airline of Country A to operate services entirely outside its home country, between Country B and a third country.' ;
    rdfs:domain ind:BilateralAsa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:signatureDate rdf:type rdf:Property ;
    rdfs:label 'Signature Date' ;
    rdfs:comment 'Date on which the bilateral air service agreement was officially signed by authorized representatives of both countries.' ;
    rdfs:domain ind:BilateralAsa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tariffApprovalMechanism rdf:type rdf:Property ;
    rdfs:label 'Tariff Approval Mechanism' ;
    rdfs:comment 'Mechanism for tariff approval specified in the agreement. Double approval requires both countries to approve; country of origin allows the airline\'s home country to approve; double disapproval means tariffs are approved unless both countries disapprove; free pricing allows airlines to set fares without approval; zone pricing establishes fare zones.' ;
    rdfs:domain ind:BilateralAsa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tariffFilingRequired rdf:type rdf:Property ;
    rdfs:label 'Tariff Filing Required' ;
    rdfs:comment 'Indicates whether designated carriers are required to file tariffs (fares and rates) with the aeronautical authorities of both countries for approval before implementation.' ;
    rdfs:domain ind:BilateralAsa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:thirdFreedomRights rdf:type rdf:Property ;
    rdfs:label 'Third Freedom Rights' ;
    rdfs:comment 'Indicates whether the agreement grants third freedom rights, allowing an airline of Country A to carry passengers or cargo from Country A to Country B.' ;
    rdfs:domain ind:BilateralAsa ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:blockTimeStandardId rdf:type rdf:Property ;
    rdfs:label 'Block Time Standard Id' ;
    rdfs:comment 'Unique identifier for the block time standard record. Primary key.' ;
    rdfs:domain ind:BlockTimeStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:airborneTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Airborne Time Minutes' ;
    rdfs:comment 'Planned airborne time in minutes from takeoff (wheels-up) to landing (wheels-down). Represents the actual flight time in the air, excluding ground operations.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:atcDelayFactorMinutes rdf:type rdf:Property ;
    rdfs:label 'Atc Delay Factor Minutes' ;
    rdfs:comment 'Expected ATC delay factor in minutes based on historical congestion patterns at origin and destination airports, en-route airspace constraints, and time-of-day traffic density.' ;
    rdfs:domain ind:BlockTimeStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:blockTimeStandardStatus rdf:type rdf:Property ;
    rdfs:label 'Block Time Standard Status' ;
    rdfs:comment 'Current lifecycle status of the block time standard. Active standards are used for schedule construction; inactive standards are historical; under_review standards are being validated; superseded standards have been replaced by newer versions.' ;
    rdfs:domain ind:BlockTimeStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contingencyBufferMinutes rdf:type rdf:Property ;
    rdfs:label 'Contingency Buffer Minutes' ;
    rdfs:comment 'Additional buffer time in minutes added to the planned block time to account for operational variability, ATC delays, weather, and other uncertainties. Used to improve schedule reliability and OTP performance.' ;
    rdfs:domain ind:BlockTimeStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:crewDutyTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Crew Duty Time Minutes' ;
    rdfs:comment 'Block time used for crew duty time and flight time limitation calculations. May include additional time for pre-flight briefing, post-flight duties, and regulatory compliance. Foundation for crew pairing and rostering.' ;
    rdfs:domain ind:BlockTimeStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:direction rdf:type rdf:Property ;
    rdfs:label 'Direction' ;
    rdfs:comment 'Direction of flight relative to the airline\'s hub or base. Outbound represents flights departing from hub; inbound represents flights arriving at hub. Block times may differ by direction due to prevailing winds and operational patterns.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:etopsTimeAdjustmentMinutes rdf:type rdf:Property ;
    rdfs:label 'Etops Time Adjustment Minutes' ;
    rdfs:comment 'Additional block time in minutes for ETOPS-certified routes requiring extended-range twin-engine operations. Accounts for required routing to remain within diversion distance of suitable alternate airports.' ;
    rdfs:domain ind:BlockTimeStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fuelPlanningTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Fuel Planning Time Minutes' ;
    rdfs:comment 'Block time used for fuel planning calculations, which may differ from scheduled block time to ensure adequate fuel reserves for contingencies, alternate airports, and regulatory requirements.' ;
    rdfs:domain ind:BlockTimeStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:historicalAverageBlockTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Historical Average Block Time Minutes' ;
    rdfs:comment 'Historical average actual block time in minutes based on past flight performance data. Used for benchmarking and validating planned block time standards against operational reality.' ;
    rdfs:domain ind:BlockTimeStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:percentile85BlockTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Percentile 85 Block Time Minutes' ;
    rdfs:comment '85th percentile of historical actual block times in minutes. Represents the block time that 85% of flights achieve or beat. Used as a reliability target for schedule planning to balance OTP performance with schedule efficiency.' ;
    rdfs:domain ind:BlockTimeStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seasonalAdjustmentType rdf:type rdf:Property ;
    rdfs:label 'Seasonal Adjustment Type' ;
    rdfs:comment 'Indicates whether this block time standard applies to summer season (typically March-October in Northern Hemisphere), winter season (typically October-March), or year-round. Seasonal variations account for prevailing winds, jet stream patterns, and daylight saving time impacts.' ;
    rdfs:domain ind:BlockTimeStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slotConstrainedAdjustmentMinutes rdf:type rdf:Property ;
    rdfs:label 'Slot Constrained Adjustment Minutes' ;
    rdfs:comment 'Additional time in minutes added to block time for slot-constrained airports where departure or arrival slot availability may require schedule padding to ensure slot compliance and reduce IROP risk.' ;
    rdfs:domain ind:BlockTimeStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:standardDeviationMinutes rdf:type rdf:Property ;
    rdfs:label 'Standard Deviation Minutes' ;
    rdfs:comment 'Standard deviation of historical block times in minutes, representing the variability and consistency of actual flight performance. Lower standard deviation indicates more predictable block times.' ;
    rdfs:domain ind:BlockTimeStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxiInTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Taxi In Time Minutes' ;
    rdfs:comment 'Planned taxi-in time in minutes from landing (wheels-down) to gate arrival (on-blocks). Varies by airport layout, gate assignment, and ground traffic.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:taxiOutTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Taxi Out Time Minutes' ;
    rdfs:comment 'Planned taxi-out time in minutes from gate departure (off-blocks) to takeoff (wheels-up). Varies by airport congestion, runway configuration, and time of day.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:windAdjustmentMinutes rdf:type rdf:Property ;
    rdfs:label 'Wind Adjustment Minutes' ;
    rdfs:comment 'Adjustment in minutes to account for prevailing wind patterns, jet stream effects, and seasonal wind variations. Positive values indicate headwind penalties; negative values indicate tailwind benefits.' ;
    rdfs:domain ind:BlockTimeStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cityPairId rdf:type rdf:Property ;
    rdfs:label 'City Pair Id' ;
    rdfs:comment 'Unique identifier for the origin-destination city pair. Primary key for the city pair master entity.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CityPair .

ind:codeshareEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Codeshare Eligible Flag' ;
    rdfs:comment 'Indicates whether this city pair is eligible for codeshare operations under existing alliance agreements and regulatory approvals.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:competitiveIntensity rdf:type rdf:Property ;
    rdfs:label 'Competitive Intensity' ;
    rdfs:comment 'Market competition classification based on number of carriers serving the city pair: monopoly (single carrier), duopoly (two carriers), oligopoly (3-5 carriers), highly_competitive (6+ carriers).' ;
    rdfs:domain ind:CityPair ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationIataRegion rdf:type rdf:Property ;
    rdfs:label 'Destination Iata Region' ;
    rdfs:comment 'IATA Traffic Conference region for the destination (TC1=Americas, TC2=Europe/Africa/Middle East, TC3=Asia/Pacific). Used for fare construction and bilateral agreement classification.' ;
    rdfs:domain ind:CityPair ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distanceBand rdf:type rdf:Property ;
    rdfs:label 'Distance Band' ;
    rdfs:comment 'Categorical classification of route length: short_haul (<1500km), medium_haul (1500-4000km), long_haul (4000-8000km), ultra_long_haul (>8000km). Used for fleet assignment, crew planning, and market segmentation.' ;
    rdfs:domain ind:CityPair ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:etopsRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Etops Required Flag' ;
    rdfs:comment 'Indicates whether ETOPS certification is required for twin-engine aircraft operations on this city pair due to extended overwater or remote routing beyond 60 minutes single-engine diversion time.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:greatCircleDistanceKm rdf:type rdf:Property ;
    rdfs:label 'Great Circle Distance Km' ;
    rdfs:comment 'Shortest distance between origin and destination airports measured along the surface of the Earth (great circle route), expressed in kilometers. Used for ASK and RPK calculations.' ;
    rdfs:domain ind:CityPair ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:greatCircleDistanceMiles rdf:type rdf:Property ;
    rdfs:label 'Great Circle Distance Miles' ;
    rdfs:comment 'Shortest distance between origin and destination airports measured along the surface of the Earth (great circle route), expressed in statute miles. Used for mileage accrual in FFP programs.' ;
    rdfs:domain ind:CityPair ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interlineEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Interline Eligible Flag' ;
    rdfs:comment 'Indicates whether this city pair is eligible for interline ticketing agreements with partner carriers, allowing through-ticketing and baggage transfer.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketClassification rdf:type rdf:Property ;
    rdfs:label 'Market Classification' ;
    rdfs:comment 'Classification of the city pair market type: domestic (within same country), international (between different countries), or transborder (specific cross-border markets with special regulatory treatment, e.g., US-Canada).' ;
    rdfs:domain ind:CityPair ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketMaturity rdf:type rdf:Property ;
    rdfs:label 'Market Maturity' ;
    rdfs:comment 'Lifecycle stage of the city pair market: emerging (new route, low traffic), growth (increasing demand), mature (stable established market), declining (reducing demand).' ;
    rdfs:domain ind:CityPair ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originIataRegion rdf:type rdf:Property ;
    rdfs:label 'Origin Iata Region' ;
    rdfs:comment 'IATA Traffic Conference region for the origin (TC1=Americas, TC2=Europe/Africa/Middle East, TC3=Asia/Pacific). Used for fare construction and bilateral agreement classification.' ;
    rdfs:domain ind:CityPair ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledDistanceKm rdf:type rdf:Property ;
    rdfs:label 'Scheduled Distance Km' ;
    rdfs:comment 'Actual flown distance based on typical flight routing including airways, ATC routing, and operational constraints. May differ from great circle distance due to airspace restrictions, weather routing, or operational procedures.' ;
    rdfs:domain ind:CityPair ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:seasonalPattern rdf:type rdf:Property ;
    rdfs:label 'Seasonal Pattern' ;
    rdfs:comment 'Typical seasonal operating pattern for this city pair: year_round (continuous service), summer_only (IATA summer season), winter_only (IATA winter season), peak_season (high-demand periods), shoulder_season (transitional periods).' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slotConstrainedFlag rdf:type rdf:Property ;
    rdfs:label 'Slot Constrained Flag' ;
    rdfs:comment 'Indicates whether either the origin or destination airport is slot-controlled under IATA Worldwide Slot Guidelines (Level 3 airport), requiring allocated takeoff and landing slots.' ;
    rdfs:domain ind:CityPair ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:timeZoneDifferenceHours rdf:type rdf:Property ;
    rdfs:label 'Time Zone Difference Hours' ;
    rdfs:comment 'Time difference in hours between origin and destination time zones. Positive values indicate destination is ahead; negative values indicate destination is behind. Used for schedule planning and passenger communication.' ;
    rdfs:domain ind:CityPair ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trafficRightsCategory rdf:type rdf:Property ;
    rdfs:label 'Traffic Rights Category' ;
    rdfs:comment 'ICAO freedom of the air classification applicable to this city pair, defining the operational rights granted under bilateral agreements (e.g., third_freedom for outbound, fourth_freedom for inbound, fifth_freedom for beyond rights). [ENUM-REF-CANDIDATE: first_freedom|second_freedom|third_freedom|fourth_freedom|fifth_freedom|sixth_freedom|seventh_freedom|eighth_freedom|ninth_freedom — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:typicalBlockTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Typical Block Time Minutes' ;
    rdfs:comment 'Average scheduled block time (gate-to-gate time) in minutes for flights operating this city pair, including taxi time. Used for crew scheduling, aircraft utilization planning, and schedule design.' ;
    rdfs:domain ind:CityPair ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:typicalFlightTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Typical Flight Time Minutes' ;
    rdfs:comment 'Average airborne flight time in minutes for this city pair, excluding taxi time. Used for fuel planning and flight operations analysis.' ;
    rdfs:domain ind:CityPair ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignedCrewSchedulerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Assigned Crew Scheduler Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Flight numbers are managed by crew scheduling staff who coordinate crew assignments, handle disruptions, and ensure regulatory compliance. Operational necessity for accountability in crew resource man' ;
    rdfs:domain ind:FlightNumber ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:partnershipId rdf:type rdf:Property ;
    rdfs:label 'Partnership Id' ;
    rdfs:comment 'Reference to the codeshare agreement governing this flight number assignment. Null for operating flights. Links to the bilateral codeshare contract between marketing and operating carriers.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partnership .

ind:routeSlotAllocationId rdf:type rdf:Property ;
    rdfs:label 'Route Slot Allocation Id' ;
    rdfs:comment 'Reference to the airport slot allocation record for constrained airports. Links to the assigned takeoff/landing time window granted by the airport coordinator or Air Traffic Control (ATC).' ;
    rdfs:domain ind:Route ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RouteSlotAllocation .

ind:distanceKm rdf:type rdf:Property ;
    rdfs:label 'Distance Km' ;
    rdfs:comment 'Great circle distance in kilometers between origin and destination airports. Used for Revenue Passenger Kilometer (RPK) and Available Seat Kilometer (ASK) calculations.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:etopsCertifiedIndicator rdf:type rdf:Property ;
    rdfs:label 'Etops Certified Indicator' ;
    rdfs:comment 'Flag indicating whether this flight operates under Extended-range Twin-engine Operational Performance Standards (ETOPS) certification for extended overwater or remote area operations (true) or standard operations (false).' ;
    rdfs:domain ind:FlightNumber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:flightNumberStatus rdf:type rdf:Property ;
    rdfs:label 'Flight Number Status' ;
    rdfs:comment 'Current lifecycle status of the flight number: active (in operational use), inactive (temporarily not scheduled), suspended (operationally blocked), pending (approved but not yet active), retired (permanently discontinued).' ;
    rdfs:domain ind:FlightNumber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flightNumberType rdf:type rdf:Property ;
    rdfs:label 'Flight Number Type' ;
    rdfs:comment 'Classification of the flight number based on operational arrangement: operating (airline operates the flight), codeshare (marketing carrier sells seats on another carrier\'s flight), wetlease (aircraft leased with crew), drylease (aircraft leased without crew), blocked (reserved but not in active use).' ;
    rdfs:domain ind:FlightNumber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flightTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Flight Time Minutes' ;
    rdfs:comment 'Scheduled airborne flight time in minutes from wheels-off to wheels-on. Excludes ground taxi time.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:frequencyPattern rdf:type rdf:Property ;
    rdfs:label 'Frequency Pattern' ;
    rdfs:comment 'Seven-character string indicating days of operation (1=operates, 0=does not operate) in sequence Monday through Sunday (e.g., 1111100 = Monday-Friday only, 0000011 = weekends only).' ;
    rdfs:domain ind:FlightNumber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fullFlightNumber rdf:type rdf:Property ;
    rdfs:label 'Full Flight Number' ;
    rdfs:comment 'Complete flight number including carrier code and numeric designator (e.g., AA1234, BA567A). This is the externally-known business identifier displayed to passengers and used in reservations.' ;
    rdfs:domain ind:FlightNumber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdsDistributionIndicator rdf:type rdf:Property ;
    rdfs:label 'Gds Distribution Indicator' ;
    rdfs:comment 'Flag indicating whether this flight number is distributed through Global Distribution Systems (GDS) such as Amadeus, Sabre, Travelport for travel agency bookings (true) or restricted to direct channels (false).' ;
    rdfs:domain ind:FlightNumber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:icaoCarrierCode rdf:type rdf:Property ;
    rdfs:label 'Icao Carrier Code' ;
    rdfs:comment 'Three-character ICAO airline designator code for the carrier (e.g., AAL for American Airlines, BAW for British Airways). Used in flight plans and air traffic control communications.' ;
    rdfs:domain ind:FlightNumber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interlineEligibleIndicator rdf:type rdf:Property ;
    rdfs:label 'Interline Eligible Indicator' ;
    rdfs:comment 'Flag indicating whether this flight number is eligible for interline ticketing agreements with partner carriers (true) or restricted to online bookings only (false).' ;
    rdfs:domain ind:FlightNumber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:networkHubIndicator rdf:type rdf:Property ;
    rdfs:label 'Network Hub Indicator' ;
    rdfs:comment 'Flag indicating whether this flight serves a hub airport in the carrier\'s hub-and-spoke network topology (true) or is a point-to-point spoke route (false).' ;
    rdfs:domain ind:FlightNumber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorityRanking rdf:type rdf:Property ;
    rdfs:label 'Priority Ranking' ;
    rdfs:comment 'Internal priority ranking for this flight number within the carrier\'s network. Lower numbers indicate higher priority for resource allocation, slot protection, and operational recovery during Irregular Operations (IROP).' ;
    rdfs:domain ind:FlightNumber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hubSpokeTopologyId rdf:type rdf:Property ;
    rdfs:label 'Hub Spoke Topology Id' ;
    rdfs:comment 'Unique identifier for the hub-spoke network topology record. Primary key for the hub_spoke_topology data product.' ;
    rdfs:domain ind:HubSpokeTopology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hubStationId rdf:type rdf:Property ;
    rdfs:label 'Hub Station Id' ;
    rdfs:comment 'Foreign key linking to airport.station. Business justification: Hub/spoke topology defines network structure around hub stations. Connection bank planning, MCT validation, gate sequencing, and wave optimization require direct hub station link. Role prefix \'hub_\' d' ;
    rdfs:domain ind:HubSpokeTopology ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Station .

ind:allocatedSlotTime rdf:type rdf:Property ;
    rdfs:label 'Allocated Slot Time' ;
    rdfs:comment 'The specific time slot (HH:MM format) allocated by the airport coordinator for this hub-spoke route at slot-constrained airports. Represents the authorized takeoff or landing time window.' ;
    rdfs:domain ind:HubSpokeTopology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:arrivalWaveEndTime rdf:type rdf:Property ;
    rdfs:label 'Arrival Wave End Time' ;
    rdfs:comment 'Local time (HH:MM format) when the arrival wave ends for this connection bank. Marks the completion of the inbound flight cluster, after which the departure wave begins.' ;
    rdfs:domain ind:HubSpokeTopology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:arrivalWaveStartTime rdf:type rdf:Property ;
    rdfs:label 'Arrival Wave Start Time' ;
    rdfs:comment 'Local time (HH:MM format) when the arrival wave begins for this connection bank. Represents the start of the inbound flight cluster arriving at the hub to feed connecting passengers into the departure wave.' ;
    rdfs:domain ind:HubSpokeTopology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:codesharePartnerIndicator rdf:type rdf:Property ;
    rdfs:label 'Codeshare Partner Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this hub-spoke route includes codeshare agreements with partner airlines. True if codeshare partners place their flight numbers on this route, false if operated solely under the airline\'s own code.' ;
    rdfs:domain ind:HubSpokeTopology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:connectionBankNumber rdf:type rdf:Property ;
    rdfs:label 'Connection Bank Number' ;
    rdfs:comment 'Sequential identifier for the connection bank (wave) within the daily hub operation. Most hubs operate 3-6 connection banks per day, each consisting of an arrival wave followed by a departure wave to maximize connecting passenger flows.' ;
    rdfs:domain ind:HubSpokeTopology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dailyFrequencyCount rdf:type rdf:Property ;
    rdfs:label 'Daily Frequency Count' ;
    rdfs:comment 'Number of daily flights operated on this hub-spoke route pair. Used to calculate spoke thickness and assess market density.' ;
    rdfs:domain ind:HubSpokeTopology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:departureWaveEndTime rdf:type rdf:Property ;
    rdfs:label 'Departure Wave End Time' ;
    rdfs:comment 'Local time (HH:MM format) when the departure wave ends for this connection bank. Marks the completion of the outbound flight cluster for this connection bank.' ;
    rdfs:domain ind:HubSpokeTopology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:departureWaveStartTime rdf:type rdf:Property ;
    rdfs:label 'Departure Wave Start Time' ;
    rdfs:comment 'Local time (HH:MM format) when the departure wave begins for this connection bank. Represents the start of the outbound flight cluster departing from the hub, carrying connecting passengers from the arrival wave.' ;
    rdfs:domain ind:HubSpokeTopology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:hubTierClassification rdf:type rdf:Property ;
    rdfs:label 'Hub Tier Classification' ;
    rdfs:comment 'Strategic classification of the hub airport within the airline\'s network hierarchy. Primary hubs are the largest connecting points with the most extensive spoke networks, secondary hubs serve regional markets, focus cities offer limited connecting service, and regional hubs serve specific geographic areas.' ;
    rdfs:domain ind:HubSpokeTopology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:misconnectRiskScore rdf:type rdf:Property ;
    rdfs:label 'Misconnect Risk Score' ;
    rdfs:comment 'Calculated risk score (0-100) indicating the probability of passenger misconnections on this hub-spoke route based on historical OTP, MCT adequacy, connection bank timing, and operational complexity. Higher scores indicate higher misconnect risk.' ;
    rdfs:domain ind:HubSpokeTopology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:networkOptimizationPriority rdf:type rdf:Property ;
    rdfs:label 'Network Optimization Priority' ;
    rdfs:comment 'Strategic priority level assigned to this hub-spoke route for network optimization initiatives. Critical routes are core to the network and receive highest investment, low priority routes may be candidates for frequency reduction or elimination.' ;
    rdfs:domain ind:HubSpokeTopology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedAskCapacity rdf:type rdf:Property ;
    rdfs:label 'Planned Ask Capacity' ;
    rdfs:comment 'The planned ASK capacity for this hub-spoke route, calculated as available seats multiplied by route distance in kilometers. Key metric for network capacity planning and resource allocation.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planningSystemSource rdf:type rdf:Property ;
    rdfs:label 'Planning System Source' ;
    rdfs:comment 'Identifier of the source planning system that created or manages this hub-spoke topology record (e.g., Jeppesen NetLine/Network, internal network planning tools). Used for data lineage and system integration.' ;
    rdfs:domain ind:HubSpokeTopology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slotConstrainedIndicator rdf:type rdf:Property ;
    rdfs:label 'Slot Constrained Indicator' ;
    rdfs:comment 'Boolean flag indicating whether the hub or spoke airport is slot-constrained, requiring allocated takeoff and landing slots. True for Level 3 coordinated airports (e.g., LHR, JFK, HND), false for non-coordinated airports.' ;
    rdfs:domain ind:HubSpokeTopology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:spokeAirportCode rdf:type rdf:Property ;
    rdfs:label 'Spoke Airport Code' ;
    rdfs:comment 'Three-letter IATA airport code identifying the spoke (destination) airport connected to the hub. Represents the endpoint of a hub-spoke route segment.' ;
    rdfs:domain ind:HubSpokeTopology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spokeThicknessIndicator rdf:type rdf:Property ;
    rdfs:label 'Spoke Thickness Indicator' ;
    rdfs:comment 'Classification of the spoke route based on frequency and capacity. Thin spokes have 1-2 daily flights, thick spokes have 3+ daily flights with larger aircraft, regional spokes serve nearby markets with high frequency, ultra-thin spokes are seasonal or less-than-daily, and mega spokes are high-density trunk routes with multiple widebody flights.' ;
    rdfs:domain ind:HubSpokeTopology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetConnectionWindowMinutes rdf:type rdf:Property ;
    rdfs:label 'Target Connection Window Minutes' ;
    rdfs:comment 'The ideal time window in minutes between arrival and departure for optimal passenger connections within this connection bank. Balances MCT requirements with passenger convenience and operational efficiency. Typically 60-120 minutes for domestic connections, 90-180 minutes for international.' ;
    rdfs:domain ind:HubSpokeTopology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetLoadFactorPercentage rdf:type rdf:Property ;
    rdfs:label 'Target Load Factor Percentage' ;
    rdfs:comment 'The target load factor (percentage of seats filled) for this hub-spoke route, used in network planning and revenue management. Expressed as a percentage (e.g., 82.50 for 82.5%).' ;
    rdfs:domain ind:HubSpokeTopology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetOtpPercentage rdf:type rdf:Property ;
    rdfs:label 'Target Otp Percentage' ;
    rdfs:comment 'The target on-time performance percentage for this hub-spoke route, defined as flights arriving within 15 minutes of scheduled time. Used to set operational performance goals and monitor connection reliability.' ;
    rdfs:domain ind:HubSpokeTopology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:topologyStatus rdf:type rdf:Property ;
    rdfs:label 'Topology Status' ;
    rdfs:comment 'Current lifecycle status of this hub-spoke topology record. Active topologies are in operation, planned topologies are scheduled for future implementation, suspended topologies are temporarily inactive (e.g., due to IROP or seasonal suspension), discontinued topologies have been permanently removed from the network.' ;
    rdfs:domain ind:HubSpokeTopology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weeklyFrequencyCount rdf:type rdf:Property ;
    rdfs:label 'Weekly Frequency Count' ;
    rdfs:comment 'Total number of flights operated per week on this hub-spoke route pair. Accounts for day-of-week variations in schedule.' ;
    rdfs:domain ind:HubSpokeTopology ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:marketAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Market Assessment Id' ;
    rdfs:comment 'Unique identifier for the market assessment record. Primary key.' ;
    rdfs:domain ind:MarketAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assessmentAnalystEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Assessment Analyst Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Market assessments are performed by network planning analysts who evaluate route viability, competitive dynamics, and revenue potential. Already has assessment_analyst_name - clear denormalization req' ;
    rdfs:domain ind:MarketAssessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:airlineMarketSharePercent rdf:type rdf:Property ;
    rdfs:label 'Airline Market Share Percent' ;
    rdfs:comment 'Current market share percentage held by the airline in this O&D market, calculated as airline passengers divided by total market passengers.' ;
    rdfs:domain ind:MarketAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assessmentNotes rdf:type rdf:Property ;
    rdfs:label 'Assessment Notes' ;
    rdfs:comment 'Free-text notes and commentary from the analyst regarding market conditions, competitive dynamics, risks, opportunities, and strategic considerations for this assessment.' ;
    rdfs:domain ind:MarketAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageMarketFareUsd rdf:type rdf:Property ;
    rdfs:label 'Average Market Fare Usd' ;
    rdfs:comment 'Average one-way fare in USD across all carriers in this O&D market, representing market pricing level for revenue opportunity estimation.' ;
    rdfs:domain ind:MarketAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bilateralAgreementStatus rdf:type rdf:Property ;
    rdfs:label 'Bilateral Agreement Status' ;
    rdfs:comment 'Status of bilateral air service agreement between origin and destination countries (open skies, restricted, pending, not applicable), governing traffic rights and capacity.' ;
    rdfs:domain ind:MarketAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessTrafficPercent rdf:type rdf:Property ;
    rdfs:label 'Business Traffic Percent' ;
    rdfs:comment 'Percentage of total market traffic attributed to business travelers, important for cabin mix and fare strategy decisions.' ;
    rdfs:domain ind:MarketAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:codeshareOpportunityFlag rdf:type rdf:Property ;
    rdfs:label 'Codeshare Opportunity Flag' ;
    rdfs:comment 'Boolean flag indicating whether codeshare partnership opportunities exist in this market to enhance network reach without deploying own capacity.' ;
    rdfs:domain ind:MarketAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:competitorCapacityAskAnnual rdf:type rdf:Property ;
    rdfs:label 'Competitor Capacity Ask Annual' ;
    rdfs:comment 'Total annual competitor capacity measured in ASK (Available Seat Kilometers) deployed in this market, used for competitive capacity benchmarking.' ;
    rdfs:domain ind:MarketAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:competitorWeeklyFrequencies rdf:type rdf:Property ;
    rdfs:label 'Competitor Weekly Frequencies' ;
    rdfs:comment 'Total number of weekly flight frequencies operated by all competitors in this O&D market, indicating competitive service intensity.' ;
    rdfs:domain ind:MarketAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:connectingTrafficPercent rdf:type rdf:Property ;
    rdfs:label 'Connecting Traffic Percent' ;
    rdfs:comment 'Percentage of total traffic that is connecting through a hub, complementing O&D traffic to total 100% of market traffic mix.' ;
    rdfs:domain ind:MarketAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:growthTrendPercentYoy rdf:type rdf:Property ;
    rdfs:label 'Growth Trend Percent Yoy' ;
    rdfs:comment 'Year-over-year growth trend percentage for this market, indicating whether demand is growing, stable, or declining. Positive values indicate growth, negative indicate decline.' ;
    rdfs:domain ind:MarketAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interlineOpportunityFlag rdf:type rdf:Property ;
    rdfs:label 'Interline Opportunity Flag' ;
    rdfs:comment 'Boolean flag indicating whether interline ticketing agreements with other carriers could support this market without direct service.' ;
    rdfs:domain ind:MarketAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leisureTrafficPercent rdf:type rdf:Property ;
    rdfs:label 'Leisure Traffic Percent' ;
    rdfs:comment 'Percentage of total market traffic attributed to leisure travelers, complementing business traffic for total passenger segmentation.' ;
    rdfs:domain ind:MarketAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:marketMaturityStage rdf:type rdf:Property ;
    rdfs:label 'Market Maturity Stage' ;
    rdfs:comment 'Lifecycle stage classification of the market (emerging, growth, mature, declining) used for strategic network planning decisions.' ;
    rdfs:domain ind:MarketAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:odTrafficPercent rdf:type rdf:Property ;
    rdfs:label 'Od Traffic Percent' ;
    rdfs:comment 'Percentage of total traffic that is true O&D (Origin-Destination) point-to-point demand, as opposed to connecting traffic through a hub.' ;
    rdfs:domain ind:MarketAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:peakSeasonMonths rdf:type rdf:Property ;
    rdfs:label 'Peak Season Months' ;
    rdfs:comment 'Comma-separated list of month names or numbers representing peak travel demand periods for this market (e.g., \'June,July,August\' or \'December\').' ;
    rdfs:domain ind:MarketAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendedAircraftType rdf:type rdf:Property ;
    rdfs:label 'Recommended Aircraft Type' ;
    rdfs:comment 'Recommended aircraft type or family (e.g., A320, B737, B787) for operating this route based on demand, range, and economics.' ;
    rdfs:domain ind:MarketAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendedWeeklyFrequency rdf:type rdf:Property ;
    rdfs:label 'Recommended Weekly Frequency' ;
    rdfs:comment 'Recommended number of weekly flight frequencies for this route based on the market assessment analysis, supporting schedule planning decisions.' ;
    rdfs:domain ind:MarketAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revenueOpportunityEstimateUsd rdf:type rdf:Property ;
    rdfs:label 'Revenue Opportunity Estimate Usd' ;
    rdfs:comment 'Estimated annual revenue opportunity in USD for the airline in this market, calculated from market size, target share, and average fare assumptions.' ;
    rdfs:domain ind:MarketAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:seasonalityIndex rdf:type rdf:Property ;
    rdfs:label 'Seasonality Index' ;
    rdfs:comment 'Seasonality index representing demand variation across the year, where 1.00 is average, >1.00 is peak season, and <1.00 is off-peak season.' ;
    rdfs:domain ind:MarketAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slotAvailabilityDestination rdf:type rdf:Property ;
    rdfs:label 'Slot Availability Destination' ;
    rdfs:comment 'Slot availability status at the destination airport (available, constrained, unavailable), critical for slot-constrained airports under IATA WSG (Worldwide Slot Guidelines).' ;
    rdfs:domain ind:MarketAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slotAvailabilityOrigin rdf:type rdf:Property ;
    rdfs:label 'Slot Availability Origin' ;
    rdfs:comment 'Slot availability status at the origin airport (available, constrained, unavailable), critical for slot-constrained airports under IATA WSG (Worldwide Slot Guidelines).' ;
    rdfs:domain ind:MarketAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalMarketPassengersAnnual rdf:type rdf:Property ;
    rdfs:label 'Total Market Passengers Annual' ;
    rdfs:comment 'Total annual passenger volume (Pax) in the O&D market across all carriers, representing total market size for demand analysis.' ;
    rdfs:domain ind:MarketAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vfrTrafficPercent rdf:type rdf:Property ;
    rdfs:label 'Vfr Traffic Percent' ;
    rdfs:comment 'Percentage of total market traffic attributed to VFR (Visiting Friends and Relatives) segment, a key demand driver in ethnic and diaspora markets.' ;
    rdfs:domain ind:MarketAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardsEngineerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Standards Engineer Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Operational standards (turnaround times, block times) are developed by operations engineering staff who analyze historical data and set performance targets. Quality management requirement - approved_b' ;
    rdfs:domain ind:OperationalStandard ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:applicableSeasonCode rdf:type rdf:Property ;
    rdfs:label 'Applicable Season Code' ;
    rdfs:comment 'IATA season code for which this operational standard is effective (e.g., S23 for Summer 2023, W23 for Winter 2023/2024).' ;
    rdfs:domain ind:OperationalStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boardingTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Boarding Time Minutes' ;
    rdfs:comment 'Standard time allocated for passenger boarding, varies by aircraft capacity, load factor, and boarding process efficiency.' ;
    rdfs:domain ind:OperationalStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cargoLoadingTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Cargo Loading Time Minutes' ;
    rdfs:comment 'Standard time allocated for cargo and baggage loading during turnaround, varies by cargo volume and ULD (Unit Load Device) count.' ;
    rdfs:domain ind:OperationalStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cargoUnloadingTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Cargo Unloading Time Minutes' ;
    rdfs:comment 'Standard time allocated for cargo and baggage unloading upon arrival, varies by cargo volume and ULD count.' ;
    rdfs:domain ind:OperationalStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cateringTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Catering Time Minutes' ;
    rdfs:comment 'Standard time allocated for catering service during turnaround, including galley restocking and waste removal.' ;
    rdfs:domain ind:OperationalStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cleaningTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Cleaning Time Minutes' ;
    rdfs:comment 'Standard time allocated for cabin cleaning during turnaround, varies by aircraft size and turnaround type.' ;
    rdfs:domain ind:OperationalStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deboardingTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Deboarding Time Minutes' ;
    rdfs:comment 'Standard time allocated for passenger deboarding upon arrival, varies by aircraft capacity and airport gate configuration.' ;
    rdfs:domain ind:OperationalStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fuelingTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Fueling Time Minutes' ;
    rdfs:comment 'Standard time allocated for aircraft refueling during turnaround, varies by fuel uplift volume and airport infrastructure.' ;
    rdfs:domain ind:OperationalStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seasonalAdjustmentMinutes rdf:type rdf:Property ;
    rdfs:label 'Seasonal Adjustment Minutes' ;
    rdfs:comment 'Time adjustment in minutes applied to block time for seasonal wind patterns, weather conditions, and daylight variations. Can be positive or negative.' ;
    rdfs:domain ind:OperationalStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:standardStatus rdf:type rdf:Property ;
    rdfs:label 'Standard Status' ;
    rdfs:comment 'Current lifecycle status of this operational standard. Active standards are used in production schedule planning; draft and under_review are pending approval; superseded indicates replacement by newer standard; archived for historical reference only.' ;
    rdfs:domain ind:OperationalStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:turnaroundTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Turnaround Time Minutes' ;
    rdfs:comment 'Standard ground time in minutes required between arrival and departure for aircraft servicing, including cleaning, catering, fueling, boarding, and maintenance checks.' ;
    rdfs:domain ind:OperationalStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:varianceMinutes rdf:type rdf:Property ;
    rdfs:label 'Variance Minutes' ;
    rdfs:comment 'Statistical variance in minutes observed in historical performance data, indicating operational variability and schedule buffer requirements.' ;
    rdfs:domain ind:OperationalStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:averageLoadFactorPercent rdf:type rdf:Property ;
    rdfs:label 'Average Load Factor Percent' ;
    rdfs:comment 'Historical average load factor (percentage of seats filled) for this route over the trailing 12 months. Key performance indicator for route profitability.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageOtpPercent rdf:type rdf:Property ;
    rdfs:label 'Average Otp Percent' ;
    rdfs:comment 'Historical average on-time performance percentage (flights arriving within 15 minutes of scheduled time) for this route over the trailing 12 months.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:competitiveRouteIndicator rdf:type rdf:Property ;
    rdfs:label 'Competitive Route Indicator' ;
    rdfs:comment 'Flag indicating whether this route faces direct competition from other carriers (true) or is operated exclusively by this airline (false).' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:distanceMiles rdf:type rdf:Property ;
    rdfs:label 'Distance Miles' ;
    rdfs:comment 'Great circle distance between origin and destination airports in statute miles. Used for frequent flyer mileage accrual and US DOT reporting.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:etopsRequired rdf:type rdf:Property ;
    rdfs:label 'Etops Required' ;
    rdfs:comment 'Flag indicating whether this route requires ETOPS certification due to extended overwater or remote area operations beyond 60 minutes single-engine diversion time.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inauguralDate rdf:type rdf:Property ;
    rdfs:label 'Inaugural Date' ;
    rdfs:comment 'Date when the route was first launched and entered commercial service.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:numberOfCompetitors rdf:type rdf:Property ;
    rdfs:label 'Number Of Competitors' ;
    rdfs:comment 'Count of other airlines operating direct service on this origin-destination pair. Zero indicates monopoly route.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operatingSeason rdf:type rdf:Property ;
    rdfs:label 'Operating Season' ;
    rdfs:comment 'Season during which the route operates: year-round (all seasons), summer-only (IATA summer schedule), or winter-only (IATA winter schedule).' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedLaunchDate rdf:type rdf:Property ;
    rdfs:label 'Planned Launch Date' ;
    rdfs:comment 'Expected date for route launch for routes in planned status. Null for active or discontinued routes.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:profitabilityTier rdf:type rdf:Property ;
    rdfs:label 'Profitability Tier' ;
    rdfs:comment 'Internal classification of route profitability: tier_1 (highest margin), tier_2 (above average), tier_3 (break-even), tier_4 (loss-making). Used for strategic network decisions.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeStatus rdf:type rdf:Property ;
    rdfs:label 'Route Status' ;
    rdfs:comment 'Current operational status of the route: active (currently operating), suspended (temporarily halted), planned (approved but not yet launched), or discontinued (permanently ceased).' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slotControlledDestination rdf:type rdf:Property ;
    rdfs:label 'Slot Controlled Destination' ;
    rdfs:comment 'Flag indicating whether the destination airport is slot-controlled (true), requiring allocated takeoff/landing slots, or non-slot-controlled (false).' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slotControlledOrigin rdf:type rdf:Property ;
    rdfs:label 'Slot Controlled Origin' ;
    rdfs:comment 'Flag indicating whether the origin airport is slot-controlled (true), requiring allocated takeoff/landing slots, or non-slot-controlled (false).' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:weeklyFrequency rdf:type rdf:Property ;
    rdfs:label 'Weekly Frequency' ;
    rdfs:comment 'Number of scheduled flights per week on this route. Used for capacity planning and network optimization.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:authorityId rdf:type rdf:Property ;
    rdfs:label 'Authority Id' ;
    rdfs:comment 'Unique identifier for the route authority record. Primary key.' ;
    rdfs:domain ind:Authority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:authorityNumber rdf:type rdf:Property ;
    rdfs:label 'Authority Number' ;
    rdfs:comment 'The official authority number or certificate number issued by the civil aviation authority (e.g., foreign carrier permit number, certificate number).' ;
    rdfs:domain ind:Authority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityAuthorized rdf:type rdf:Property ;
    rdfs:label 'Capacity Authorized' ;
    rdfs:comment 'The authorized capacity for this route, expressed as frequency per week, seats per week, or other capacity measure as specified by the bilateral agreement or authority.' ;
    rdfs:domain ind:Authority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cargoPermittedFlag rdf:type rdf:Property ;
    rdfs:label 'Cargo Permitted Flag' ;
    rdfs:comment 'Indicates whether cargo operations are permitted under this route authority (True/False).' ;
    rdfs:domain ind:Authority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:codesharePermittedFlag rdf:type rdf:Property ;
    rdfs:label 'Codeshare Permitted Flag' ;
    rdfs:comment 'Indicates whether codeshare operations are permitted under this route authority (True/False).' ;
    rdfs:domain ind:Authority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conditionsAndRestrictions rdf:type rdf:Property ;
    rdfs:label 'Conditions And Restrictions' ;
    rdfs:comment 'Free-text description of any conditions, restrictions, or limitations imposed on this route authority (e.g., seasonal restrictions, aircraft type restrictions, cargo-only restrictions, technical stop requirements).' ;
    rdfs:domain ind:Authority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fifthFreedomPermittedFlag rdf:type rdf:Property ;
    rdfs:label 'Fifth Freedom Permitted Flag' ;
    rdfs:comment 'Indicates whether fifth freedom traffic rights (carriage of passengers/cargo between two foreign countries on a flight originating or terminating in the airline\'s home country) are permitted under this authority (True/False).' ;
    rdfs:domain ind:Authority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:passengerPermittedFlag rdf:type rdf:Property ;
    rdfs:label 'Passenger Permitted Flag' ;
    rdfs:comment 'Indicates whether passenger operations are permitted under this route authority (True/False).' ;
    rdfs:domain ind:Authority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trafficRights rdf:type rdf:Property ;
    rdfs:label 'Traffic Rights' ;
    rdfs:comment 'The specific freedoms of the air granted under this authority (e.g., First Freedom, Second Freedom, Third Freedom, Fourth Freedom, Fifth Freedom, Sixth Freedom, Seventh Freedom, Eighth Freedom, Ninth Freedom). May be comma-separated list.' ;
    rdfs:domain ind:Authority ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fleetPlannerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Fleet Planner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Fleet assignments are strategic decisions made by fleet planning analysts who optimize aircraft utilization, match capacity to demand, and coordinate with maintenance. Critical resource allocation req' ;
    rdfs:domain ind:FleetAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assignmentCode rdf:type rdf:Property ;
    rdfs:label 'Assignment Code' ;
    rdfs:comment 'Business identifier code for this fleet assignment, used in operational planning and crew scheduling systems.' ;
    rdfs:domain ind:FleetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentDurationDays rdf:type rdf:Property ;
    rdfs:label 'Assignment Duration Days' ;
    rdfs:comment 'Total number of days this fleet assignment is planned to be in effect, calculated from effective start to end date.' ;
    rdfs:domain ind:FleetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignmentPriority rdf:type rdf:Property ;
    rdfs:label 'Assignment Priority' ;
    rdfs:comment 'Priority ranking of this fleet assignment relative to other assignments, used for conflict resolution and aircraft allocation decisions. Lower numbers indicate higher priority.' ;
    rdfs:domain ind:FleetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignmentRationale rdf:type rdf:Property ;
    rdfs:label 'Assignment Rationale' ;
    rdfs:comment 'Business justification or reasoning for this specific fleet type assignment to the route, capturing strategic considerations such as demand patterns, competitive positioning, or operational constraints.' ;
    rdfs:domain ind:FleetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessClassSeats rdf:type rdf:Property ;
    rdfs:label 'Business Class Seats' ;
    rdfs:comment 'Number of business class seats in the assigned aircraft configuration.' ;
    rdfs:domain ind:FleetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cargoBellyCapacityKg rdf:type rdf:Property ;
    rdfs:label 'Cargo Belly Capacity Kg' ;
    rdfs:comment 'Available cargo capacity in the belly hold of the assigned aircraft, measured in kilograms, used for cargo revenue planning.' ;
    rdfs:domain ind:FleetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cargoBellyCapacityM3 rdf:type rdf:Property ;
    rdfs:label 'Cargo Belly Capacity M3' ;
    rdfs:comment 'Available cargo volume in the belly hold of the assigned aircraft, measured in cubic meters.' ;
    rdfs:domain ind:FleetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:economyClassSeats rdf:type rdf:Property ;
    rdfs:label 'Economy Class Seats' ;
    rdfs:comment 'Number of economy class seats in the assigned aircraft configuration.' ;
    rdfs:domain ind:FleetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:firstClassSeats rdf:type rdf:Property ;
    rdfs:label 'First Class Seats' ;
    rdfs:comment 'Number of first class or premium cabin seats in the assigned aircraft configuration.' ;
    rdfs:domain ind:FleetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:premiumEconomySeats rdf:type rdf:Property ;
    rdfs:label 'Premium Economy Seats' ;
    rdfs:comment 'Number of premium economy seats in the assigned aircraft configuration.' ;
    rdfs:domain ind:FleetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalSeats rdf:type rdf:Property ;
    rdfs:label 'Total Seats' ;
    rdfs:comment 'Total number of passenger seats available on the assigned aircraft configuration, also known as gauge in airline revenue management.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:interlineAgreementId rdf:type rdf:Property ;
    rdfs:label 'Interline Agreement Id' ;
    rdfs:comment 'Unique identifier for the interline ticketing and traffic agreement record. Primary key.' ;
    rdfs:domain ind:InterlineAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:partnerCarrierId rdf:type rdf:Property ;
    rdfs:label 'Partner Carrier Id' ;
    rdfs:comment 'Foreign key linking to route.carrier. Business justification: interline_agreement has partner_carrier_iata_code as STRING. Normalizing to carrier.carrier_id establishes FK to the partner carrier in the interline ticketing agreement. This connects interline_agree' ;
    rdfs:domain ind:Route ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:agreementNotes rdf:type rdf:Property ;
    rdfs:label 'Agreement Notes' ;
    rdfs:comment 'Free-text field for additional notes, special conditions, restrictions, or operational instructions related to the interline agreement.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allianceMembership rdf:type rdf:Property ;
    rdfs:label 'Alliance Membership' ;
    rdfs:comment 'Indicates whether the interline agreement is facilitated by membership in a global airline alliance (Star Alliance, oneworld, SkyTeam, Value Alliance) or is a standalone bilateral agreement (none).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baggageThroughCheckEligible rdf:type rdf:Property ;
    rdfs:label 'Baggage Through Check Eligible' ;
    rdfs:comment 'Boolean flag indicating whether baggage can be checked through to the final destination across both carriers under this interline agreement (True) or must be reclaimed and re-checked (False).' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eTicketInterlineCapable rdf:type rdf:Property ;
    rdfs:label 'E Ticket Interline Capable' ;
    rdfs:comment 'Boolean flag indicating whether electronic ticketing (e-ticket) is supported for interline itineraries under this agreement (True) or paper tickets are required (False).' ;
    rdfs:domain ind:InterlineAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:frequentFlyerAccrualEligible rdf:type rdf:Property ;
    rdfs:label 'Frequent Flyer Accrual Eligible' ;
    rdfs:comment 'Boolean flag indicating whether passengers can accrue frequent flyer miles or points on the partner carrier segments under this interline agreement (True) or not (False).' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gdsDistributionEnabled rdf:type rdf:Property ;
    rdfs:label 'Gds Distribution Enabled' ;
    rdfs:comment 'Boolean flag indicating whether interline itineraries under this agreement are available for booking through Global Distribution Systems (GDS) such as Amadeus, Sabre, and Travelport (True) or restricted to direct channels (False).' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iropReprotectionEligible rdf:type rdf:Property ;
    rdfs:label 'Irop Reprotection Eligible' ;
    rdfs:comment 'Boolean flag indicating whether passengers can be reprotected on the partner carrier in case of irregular operations (IROP) such as delays, cancellations, or missed connections (True) or not (False).' ;
    rdfs:domain ind:InterlineAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:liabilityLimitSdr rdf:type rdf:Property ;
    rdfs:label 'Liability Limit Sdr' ;
    rdfs:comment 'Maximum liability limit per passenger for baggage, delay, or injury claims under the interline agreement, expressed in Special Drawing Rights (SDR) as defined by the Montreal Convention.' ;
    rdfs:domain ind:InterlineAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementBasis rdf:type rdf:Property ;
    rdfs:label 'Settlement Basis' ;
    rdfs:comment 'Financial settlement mechanism for interline revenue: BSP (Billing and Settlement Plan), ARC (Airlines Reporting Corporation), direct billing between carriers, ICH (IATA Clearing House), or bilateral settlement agreement.' ;
    rdfs:domain ind:InterlineAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialProrateAgreementNumber rdf:type rdf:Property ;
    rdfs:label 'Special Prorate Agreement Number' ;
    rdfs:comment 'Unique identifier for a Special Prorate Agreement (SPA) filed with IATA or negotiated bilaterally, if applicable. Nullable for standard interline agreements.' ;
    rdfs:domain ind:InterlineAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ssrHandlingAgreement rdf:type rdf:Property ;
    rdfs:label 'Ssr Handling Agreement' ;
    rdfs:comment 'Defines the level of Special Service Request (SSR) data exchange and handling between carriers: full SSR exchange, limited SSR support, or no SSR exchange.' ;
    rdfs:domain ind:InterlineAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeCodeshareAgreementId rdf:type rdf:Property ;
    rdfs:label 'Route Codeshare Agreement Id' ;
    rdfs:comment 'Unique identifier for the route partnership agreement record. Primary key.' ;
    rdfs:domain ind:Partnership ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CodeshareAgreement .

ind:antitrustImmunityGranted rdf:type rdf:Property ;
    rdfs:label 'Antitrust Immunity Granted' ;
    rdfs:comment 'Indicates whether the partnership (typically joint venture) has been granted antitrust immunity by regulatory authorities, allowing revenue and capacity coordination.' ;
    rdfs:domain ind:Partnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:autoRenewalEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Enabled' ;
    rdfs:comment 'Indicates whether the partnership agreement automatically renews for an additional term upon expiry unless either party provides notice of termination.' ;
    rdfs:domain ind:Partnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:blockSpaceSeatCount rdf:type rdf:Property ;
    rdfs:label 'Block Space Seat Count' ;
    rdfs:comment 'Number of seats purchased by the marketing carrier under a block-space codeshare agreement. Null if not a block-space agreement.' ;
    rdfs:domain ind:Partnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cabinClassAvailability rdf:type rdf:Property ;
    rdfs:label 'Cabin Class Availability' ;
    rdfs:comment 'Comma-separated list of cabin classes (e.g., F, J, W, Y) for which this partnership agreement applies. Null if applies to all classes.' ;
    rdfs:domain ind:Partnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codeshareFlightNumberRangeEnd rdf:type rdf:Property ;
    rdfs:label 'Codeshare Flight Number Range End' ;
    rdfs:comment 'Ending flight number in the range allocated to the marketing carrier for codeshare flights under this agreement. Null if not a codeshare agreement.' ;
    rdfs:domain ind:Partnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:codeshareFlightNumberRangeStart rdf:type rdf:Property ;
    rdfs:label 'Codeshare Flight Number Range Start' ;
    rdfs:comment 'Starting flight number in the range allocated to the marketing carrier for codeshare flights under this agreement. Null if not a codeshare agreement.' ;
    rdfs:domain ind:Partnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eticketInterlineCapable rdf:type rdf:Property ;
    rdfs:label 'Eticket Interline Capable' ;
    rdfs:comment 'Indicates whether electronic ticketing is supported for interline itineraries under this agreement (both carriers must support e-ticket interline).' ;
    rdfs:domain ind:Partnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:frequentFlyerRedemptionEligible rdf:type rdf:Property ;
    rdfs:label 'Frequent Flyer Redemption Eligible' ;
    rdfs:comment 'Indicates whether passengers can redeem frequent flyer miles/points for award travel on the partner carrier under this agreement.' ;
    rdfs:domain ind:Partnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revenueSharingBasis rdf:type rdf:Property ;
    rdfs:label 'Revenue Sharing Basis' ;
    rdfs:comment 'Method by which revenue is allocated between partner carriers: prorate (IATA standard prorate formula based on mileage), block_space (fixed payment for seat block), revenue_share_pool (joint venture pooling), cost_plus (cost reimbursement plus margin), or fixed_fee (flat payment per flight or period).' ;
    rdfs:domain ind:Partnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialServiceRequestPassthrough rdf:type rdf:Property ;
    rdfs:label 'Special Service Request Passthrough' ;
    rdfs:comment 'Indicates whether Special Service Requests (meal preferences, wheelchair assistance, etc.) are passed through between carriers for interline passengers under this agreement.' ;
    rdfs:domain ind:Partnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:routePerformanceId rdf:type rdf:Property ;
    rdfs:label 'Route Performance Id' ;
    rdfs:comment 'Unique identifier for the route performance measurement record. Primary key.' ;
    rdfs:domain ind:RoutePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:analystEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Analyst Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Route performance monitoring requires assigned analysts who track OTP, load factors, and financial metrics, then recommend corrective actions. Standard airline practice - every route cluster has desig' ;
    rdfs:domain ind:RoutePerformance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:availableSeatsTotal rdf:type rdf:Property ;
    rdfs:label 'Available Seats Total' ;
    rdfs:comment 'The total number of seats available for sale on all operated flights on this route during the measurement period. Basis for load factor calculation.' ;
    rdfs:domain ind:RoutePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:averageBlockTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Average Block Time Minutes' ;
    rdfs:comment 'The mean block time (gate-to-gate elapsed time) for all operated flights on this route during the measurement period. Used for schedule planning and crew productivity analysis.' ;
    rdfs:domain ind:RoutePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageDelayMinutes rdf:type rdf:Property ;
    rdfs:label 'Average Delay Minutes' ;
    rdfs:comment 'The mean arrival delay in minutes for all operated flights on this route during the measurement period. Negative values indicate early arrivals.' ;
    rdfs:domain ind:RoutePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cancellationRatePercent rdf:type rdf:Property ;
    rdfs:label 'Cancellation Rate Percent' ;
    rdfs:comment 'The percentage of scheduled flights that were cancelled. Calculated as (flights cancelled / flights scheduled) * 100. Key operational reliability metric.' ;
    rdfs:domain ind:RoutePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cask rdf:type rdf:Property ;
    rdfs:label 'Cask' ;
    rdfs:comment 'Cost per unit of capacity. Calculated as (total cost / ASK). Key unit cost metric for route efficiency analysis. Expressed in cost_currency_code per kilometer.' ;
    rdfs:domain ind:RoutePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:diversionRatePercent rdf:type rdf:Property ;
    rdfs:label 'Diversion Rate Percent' ;
    rdfs:comment 'The percentage of operated flights that were diverted. Calculated as (flights diverted / flights operated) * 100. Indicator of weather, ATC, or operational disruption impact.' ;
    rdfs:domain ind:RoutePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:flightsOperatedCount rdf:type rdf:Property ;
    rdfs:label 'Flights Operated Count' ;
    rdfs:comment 'The total number of flights that actually departed on this route during the measurement period. Excludes cancelled flights.' ;
    rdfs:domain ind:RoutePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:flightsScheduledCount rdf:type rdf:Property ;
    rdfs:label 'Flights Scheduled Count' ;
    rdfs:comment 'The total number of flights scheduled to operate on this route during the measurement period, as published in the airline schedule.' ;
    rdfs:domain ind:RoutePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:grade rdf:type rdf:Property ;
    rdfs:label 'Grade' ;
    rdfs:comment 'Overall qualitative assessment of route performance based on composite scoring of OTP, load factor, yield, and RASK against targets. Used for executive dashboards and network optimization prioritization.' ;
    rdfs:domain ind:RoutePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Measurement Period End Date' ;
    rdfs:comment 'The last date of the performance measurement period. Typically the last day of a calendar month or the end of a seasonal period.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measurementPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Measurement Period Start Date' ;
    rdfs:comment 'The first date of the performance measurement period. Typically the first day of a calendar month or the start of a seasonal period.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measurementPeriodType rdf:type rdf:Property ;
    rdfs:label 'Measurement Period Type' ;
    rdfs:comment 'The granularity of the performance measurement period. Monthly is most common for operational scorecards; seasonal aligns with IATA schedule seasons; custom supports ad-hoc analysis windows.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otpPercent rdf:type rdf:Property ;
    rdfs:label 'Otp Percent' ;
    rdfs:comment 'The percentage of operated flights that arrived within 15 minutes of scheduled arrival time. Industry-standard KPI for route punctuality. Calculated as (on-time arrivals / flights operated) * 100.' ;
    rdfs:domain ind:RoutePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:passengersCarriedCount rdf:type rdf:Property ;
    rdfs:label 'Passengers Carried Count' ;
    rdfs:comment 'The total number of revenue passengers transported on this route during the measurement period. Excludes non-revenue passengers (crew, deadheads, etc.).' ;
    rdfs:domain ind:RoutePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revenueCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Revenue Currency Code' ;
    rdfs:comment 'The three-letter ISO 4217 currency code in which total_revenue_amount is denominated (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:RoutePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yield rdf:type rdf:Property ;
    rdfs:label 'Yield' ;
    rdfs:comment 'Revenue per unit of traffic. Calculated as (total revenue / RPK). Measures pricing power and fare realization. Expressed in revenue_currency_code per kilometer.' ;
    rdfs:domain ind:RoutePerformance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slotCoordinatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Slot Coordinator Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Slot allocations at constrained airports require designated coordinators who negotiate with airport authorities, manage historical rights, and coordinate swaps. Regulatory requirement and operational ' ;
    rdfs:domain ind:RouteSlotAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:environmentalRestrictionFlag rdf:type rdf:Property ;
    rdfs:label 'Environmental Restriction Flag' ;
    rdfs:comment 'Indicates whether this slot is subject to environmental restrictions such as noise abatement procedures, curfew limitations, or emissions-based access rules. True if environmental constraints apply to the slot usage.' ;
    rdfs:domain ind:RouteSlotAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:historicalPrecedenceFlag rdf:type rdf:Property ;
    rdfs:label 'Historical Precedence Flag' ;
    rdfs:comment 'Indicates whether this slot carries historical precedence (grandfather rights) for the airline. True if the airline has operated this slot in previous equivalent seasons and is entitled to priority retention under IATA use-it-or-lose-it rules (80% usage threshold).' ;
    rdfs:domain ind:RouteSlotAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slotAllocationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Slot Allocation Timestamp' ;
    rdfs:comment 'Date and time when the slot coordinator officially allocated this slot to the airline. Marks the transition from requested to allocated status.' ;
    rdfs:domain ind:RouteSlotAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:slotCancellationReason rdf:type rdf:Property ;
    rdfs:label 'Slot Cancellation Reason' ;
    rdfs:comment 'Reason for cancellation of the slot allocation by the coordinator or airline. Populated when slot_status is \'cancelled\'. May include regulatory changes, airport capacity reductions, or airline non-compliance with usage requirements.' ;
    rdfs:domain ind:RouteSlotAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slotConferenceReference rdf:type rdf:Property ;
    rdfs:label 'Slot Conference Reference' ;
    rdfs:comment 'Reference to the IATA slot coordination conference where this slot was discussed or allocated (e.g., IATA Slot Conference Worldwide, Regional Slot Conference). IATA holds biannual slot conferences where airlines and coordinators negotiate slot allocations.' ;
    rdfs:domain ind:RouteSlotAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slotConfirmationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Slot Confirmation Timestamp' ;
    rdfs:comment 'Date and time when the airline confirmed acceptance and intention to use the allocated slot. Required by IATA WSG to retain slot rights for future seasons.' ;
    rdfs:domain ind:RouteSlotAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:slotCoordinationLevel rdf:type rdf:Property ;
    rdfs:label 'Slot Coordination Level' ;
    rdfs:comment 'IATA coordination level of the airport for this slot. Level 1 (non-coordinated): no slot coordination required; Level 2 (schedule-facilitated): voluntary schedule coordination; Level 3 (fully coordinated): mandatory slot allocation by coordinator. Only Level 2 and Level 3 airports issue formal slot allocations.' ;
    rdfs:domain ind:RouteSlotAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slotCoordinatorReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Slot Coordinator Reference Number' ;
    rdfs:comment 'Unique reference number assigned by the airport slot coordinator to this slot allocation. Used for official correspondence and slot coordination activities.' ;
    rdfs:domain ind:RouteSlotAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slotMovementType rdf:type rdf:Property ;
    rdfs:label 'Slot Movement Type' ;
    rdfs:comment 'Indicates whether this slot is for an arrival or departure movement at the coordinated airport.' ;
    rdfs:domain ind:RouteSlotAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slotPriorityScore rdf:type rdf:Property ;
    rdfs:label 'Slot Priority Score' ;
    rdfs:comment 'Numeric score assigned by the slot coordinator to prioritize this slot request relative to competing requests. Higher scores indicate higher priority. Factors include historical precedence, new entrant status, network connectivity, and public interest considerations.' ;
    rdfs:domain ind:RouteSlotAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slotRequestTimestamp rdf:type rdf:Property ;
    rdfs:label 'Slot Request Timestamp' ;
    rdfs:comment 'Date and time when the airline submitted the slot request to the coordinator. Used to establish priority in slot allocation processes where multiple carriers request the same time.' ;
    rdfs:domain ind:RouteSlotAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:slotReturnReason rdf:type rdf:Property ;
    rdfs:label 'Slot Return Reason' ;
    rdfs:comment 'Business reason for returning the slot to the coordinator pool. Populated when slot_status is \'returned\'. Common reasons include route discontinuation, schedule optimization, fleet changes, or commercial underperformance.' ;
    rdfs:domain ind:RouteSlotAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slotSeriesType rdf:type rdf:Property ;
    rdfs:label 'Slot Series Type' ;
    rdfs:comment 'Indicates whether the slot allocation covers the full IATA season, a partial period within the season, or a single date. Full season slots run for the entire summer or winter season; partial season slots cover a subset of dates.' ;
    rdfs:domain ind:RouteSlotAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slotSwapPartnerAirlineCode rdf:type rdf:Property ;
    rdfs:label 'Slot Swap Partner Airline Code' ;
    rdfs:comment 'IATA airline code of the partner airline involved in a slot swap transaction. Populated only when slot_status is \'swapped\'. Slot swaps allow airlines to exchange slots to optimize their network schedules.' ;
    rdfs:domain ind:RouteSlotAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slotSwapReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Slot Swap Reference Number' ;
    rdfs:comment 'Unique reference number for the slot swap transaction, assigned by the slot coordinator. Links this slot allocation to the corresponding swapped slot record.' ;
    rdfs:domain ind:RouteSlotAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slotToleranceMinutes rdf:type rdf:Property ;
    rdfs:label 'Slot Tolerance Minutes' ;
    rdfs:comment 'Number of minutes before or after the allocated time within which the flight operation is considered compliant with the slot. Typically -5 to +10 minutes for departures and -10 to +5 minutes for arrivals, but varies by airport coordinator policy.' ;
    rdfs:domain ind:RouteSlotAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slotUsagePercentage rdf:type rdf:Property ;
    rdfs:label 'Slot Usage Percentage' ;
    rdfs:comment 'Percentage of allocated slot times that were actually used by the airline during the season. IATA WSG requires 80% usage to retain historical rights. Calculated as (flights operated within slot tolerance / total allocated slot occurrences) * 100.' ;
    rdfs:domain ind:RouteSlotAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:terminalRestriction rdf:type rdf:Property ;
    rdfs:label 'Terminal Restriction' ;
    rdfs:comment 'Specific terminal designation at the airport where this slot must be used (e.g., Terminal 1, Terminal 5, Concourse B). Some airports allocate slots with terminal restrictions due to capacity or operational constraints.' ;
    rdfs:domain ind:RouteSlotAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daylightSavingTransitionApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Daylight Saving Transition Applicable Flag' ;
    rdfs:comment 'Indicates whether daylight saving time transitions occur during this scheduling season, requiring schedule adjustments for affected routes and airports. True if DST transitions occur within the season period.' ;
    rdfs:domain ind:ScheduleSeason ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:historicalUseItOrLoseItThresholdPercent rdf:type rdf:Property ;
    rdfs:label 'Historical Use It Or Lose It Threshold Percent' ;
    rdfs:comment 'The minimum slot utilization percentage required during this season to retain grandfather rights for the next equivalent season. Typically 80% per IATA WSG, but may vary by jurisdiction (e.g., EU Regulation 95/93). Expressed as a percentage (e.g., 80.00 for 80%).' ;
    rdfs:domain ind:ScheduleSeason ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:iataSchedulesConferenceEndDate rdf:type rdf:Property ;
    rdfs:label 'Iata Schedules Conference End Date' ;
    rdfs:comment 'The end date of the biannual IATA Schedules Conference. Conferences typically last 3-5 days and occur twice per year (spring for winter season, fall for summer season).' ;
    rdfs:domain ind:ScheduleSeason ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:iataSchedulesConferenceLocation rdf:type rdf:Property ;
    rdfs:label 'Iata Schedules Conference Location' ;
    rdfs:comment 'The city and country where the IATA Schedules Conference for this season is held (e.g., \'Geneva, Switzerland\', \'Singapore\').' ;
    rdfs:domain ind:ScheduleSeason ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iataSchedulesConferenceStartDate rdf:type rdf:Property ;
    rdfs:label 'Iata Schedules Conference Start Date' ;
    rdfs:comment 'The start date of the biannual IATA Schedules Conference where airlines, airports, and slot coordinators meet to coordinate seasonal schedules, negotiate slots, and finalize bilateral agreements.' ;
    rdfs:domain ind:ScheduleSeason ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:iataSeasonYear rdf:type rdf:Property ;
    rdfs:label 'Iata Season Year' ;
    rdfs:comment 'The calendar year in which the season primarily falls or begins, used for grouping and filtering seasons by year (e.g., 2025 for S25 or W25/26).' ;
    rdfs:domain ind:ScheduleSeason ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:initialScheduleSubmissionDeadline rdf:type rdf:Property ;
    rdfs:label 'Initial Schedule Submission Deadline' ;
    rdfs:comment 'The deadline by which airlines must submit their initial seasonal schedule requests to slot coordinators and Global Distribution Systems (GDS). Typically occurs several months before season start per IATA Schedules Information Standards (SIS).' ;
    rdfs:domain ind:ScheduleSeason ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:northernHemisphereDstEndDate rdf:type rdf:Property ;
    rdfs:label 'Northern Hemisphere Dst End Date' ;
    rdfs:comment 'The date when daylight saving time ends in the northern hemisphere during this season (typically first Sunday in November for North America, last Sunday in October for Europe). Null if not applicable to this season.' ;
    rdfs:domain ind:ScheduleSeason ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:northernHemisphereDstStartDate rdf:type rdf:Property ;
    rdfs:label 'Northern Hemisphere Dst Start Date' ;
    rdfs:comment 'The date when daylight saving time begins in the northern hemisphere during this season (typically second Sunday in March for North America, last Sunday in March for Europe). Null if not applicable to this season.' ;
    rdfs:domain ind:ScheduleSeason ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:peakTravelPeriodFlag rdf:type rdf:Property ;
    rdfs:label 'Peak Travel Period Flag' ;
    rdfs:comment 'Indicates whether this season is considered a peak travel period with higher demand and load factors. Summer seasons are typically peak periods for leisure travel in the northern hemisphere.' ;
    rdfs:domain ind:ScheduleSeason ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduleSeasonStatus rdf:type rdf:Property ;
    rdfs:label 'Schedule Season Status' ;
    rdfs:comment 'Current lifecycle status of the scheduling season. Planning: season is being prepared and schedules are being submitted. Active: season is currently in effect. Completed: season has ended but data is still operational. Archived: season is historical and closed for reporting only.' ;
    rdfs:domain ind:ScheduleSeason ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonName rdf:type rdf:Property ;
    rdfs:label 'Season Name' ;
    rdfs:comment 'Human-readable descriptive name for the scheduling season (e.g., \'Summer 2025\', \'Winter 2025/2026\').' ;
    rdfs:domain ind:ScheduleSeason ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slotCoordinationCycle rdf:type rdf:Property ;
    rdfs:label 'Slot Coordination Cycle' ;
    rdfs:comment 'The IATA slot coordination cycle identifier corresponding to this season, used by slot coordinators at Level 2 and Level 3 airports for capacity management and slot allocation.' ;
    rdfs:domain ind:ScheduleSeason ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slotReturnDeadline rdf:type rdf:Property ;
    rdfs:label 'Slot Return Deadline' ;
    rdfs:comment 'The final date by which airlines must return unused or unwanted airport slots to the slot coordinator to avoid use-it-or-lose-it penalties. Critical for slot allocation compliance at Level 3 coordinated airports.' ;
    rdfs:domain ind:ScheduleSeason ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:southernHemisphereDstEndDate rdf:type rdf:Property ;
    rdfs:label 'Southern Hemisphere Dst End Date' ;
    rdfs:comment 'The date when daylight saving time ends in the southern hemisphere during this season (typically first Sunday in April for Australia). Null if not applicable to this season.' ;
    rdfs:domain ind:ScheduleSeason ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:southernHemisphereDstStartDate rdf:type rdf:Property ;
    rdfs:label 'Southern Hemisphere Dst Start Date' ;
    rdfs:comment 'The date when daylight saving time begins in the southern hemisphere during this season (typically first Sunday in October for Australia). Null if not applicable to this season.' ;
    rdfs:domain ind:ScheduleSeason ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:supplementaryScheduleSubmissionDeadline rdf:type rdf:Property ;
    rdfs:label 'Supplementary Schedule Submission Deadline' ;
    rdfs:comment 'The deadline for airlines to submit supplementary or revised schedule changes after the initial submission. Allows for adjustments closer to the season start date.' ;
    rdfs:domain ind:ScheduleSeason ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:schedulePlannerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Schedule Planner Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Seasonal schedules are created by network planning analysts who design frequency patterns, optimize connections, and coordinate with slot coordinators. Clear ownership requirement for schedule quality' ;
    rdfs:domain ind:SeasonalSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:aircraftOwner rdf:type rdf:Property ;
    rdfs:label 'Aircraft Owner' ;
    rdfs:comment 'Indicates the ownership/lease arrangement for the aircraft planned for this schedule. Values: owned (airline-owned), wet_lease (leased with crew), dry_lease (leased without crew), acmi (Aircraft Crew Maintenance Insurance lease), charter (chartered from third party).' ;
    rdfs:domain ind:SeasonalSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arrivalTimeLocal rdf:type rdf:Property ;
    rdfs:label 'Arrival Time Local' ;
    rdfs:comment 'Scheduled arrival time in local time at the destination airport. Format: HH:MM (24-hour). This is the planned gate arrival time (on-blocks time) in the destination airport local timezone. May show next-day arrival if flight crosses midnight.' ;
    rdfs:domain ind:SeasonalSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arrivalTimeUtc rdf:type rdf:Property ;
    rdfs:label 'Arrival Time Utc' ;
    rdfs:comment 'Scheduled arrival time in UTC (Coordinated Universal Time). Format: HH:MM (24-hour). Used for operational planning and coordination across time zones.' ;
    rdfs:domain ind:SeasonalSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:askPlanned rdf:type rdf:Property ;
    rdfs:label 'Ask Planned' ;
    rdfs:comment 'Planned Available Seat Kilometers for this seasonal schedule. Calculated as total seats multiplied by route distance in kilometers. Key capacity metric for network planning and revenue management.' ;
    rdfs:domain ind:SeasonalSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dayChangeIndicator rdf:type rdf:Property ;
    rdfs:label 'Day Change Indicator' ;
    rdfs:comment 'Indicates the number of days difference between departure and arrival dates. Values: 0 (same day), 1 (next day), 2 (two days later), -1 (previous day for flights crossing international date line westbound). Used to calculate actual arrival date from departure date.' ;
    rdfs:domain ind:SeasonalSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:departureTimeLocal rdf:type rdf:Property ;
    rdfs:label 'Departure Time Local' ;
    rdfs:comment 'Scheduled departure time in local time at the origin airport. Format: HH:MM (24-hour). This is the planned gate departure time (off-blocks time) in the origin airport local timezone.' ;
    rdfs:domain ind:SeasonalSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departureTimeUtc rdf:type rdf:Property ;
    rdfs:label 'Departure Time Utc' ;
    rdfs:comment 'Scheduled departure time in UTC (Coordinated Universal Time). Format: HH:MM (24-hour). Used for operational planning and coordination across time zones.' ;
    rdfs:domain ind:SeasonalSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationTerminal rdf:type rdf:Property ;
    rdfs:label 'Destination Terminal' ;
    rdfs:comment 'Terminal identifier at the destination airport where this flight arrives. Used for passenger information and ground operations planning. Format varies by airport (e.g., 1, A, T1, North).' ;
    rdfs:domain ind:SeasonalSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frequencyPerWeek rdf:type rdf:Property ;
    rdfs:label 'Frequency Per Week' ;
    rdfs:comment 'The number of times this flight operates per week during the seasonal schedule period. Derived from the days_of_operation mask. Range: 0-7.' ;
    rdfs:domain ind:SeasonalSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originTerminal rdf:type rdf:Property ;
    rdfs:label 'Origin Terminal' ;
    rdfs:comment 'Terminal identifier at the origin airport from which this flight departs. Used for passenger information and ground operations planning. Format varies by airport (e.g., 1, A, T1, North).' ;
    rdfs:domain ind:SeasonalSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slotTimeDestination rdf:type rdf:Property ;
    rdfs:label 'Slot Time Destination' ;
    rdfs:comment 'Allocated slot time at the destination airport for landing. At slot-coordinated airports, this is the specific time window allocated by the slot coordinator. Format: HH:MM (24-hour local time). May differ slightly from scheduled arrival time.' ;
    rdfs:domain ind:SeasonalSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slotTimeOrigin rdf:type rdf:Property ;
    rdfs:label 'Slot Time Origin' ;
    rdfs:comment 'Allocated slot time at the origin airport for takeoff. At slot-coordinated airports, this is the specific time window allocated by the slot coordinator. Format: HH:MM (24-hour local time). May differ slightly from scheduled departure time.' ;
    rdfs:domain ind:SeasonalSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:occurrenceReportId rdf:type rdf:Property ;
    rdfs:label 'Occurrence Report Id' ;
    rdfs:comment 'Reference to the parent safety occurrence report if this deviation was formally reported as a safety event.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Report .

ind:actualAltitudeFeet rdf:type rdf:Property ;
    rdfs:label 'Actual Altitude Feet' ;
    rdfs:comment 'The actual altitude in feet at which the aircraft was flying at the time of deviation detection. Null if deviation type is not altitude-related.' ;
    rdfs:domain ind:AirspaceDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualRoute rdf:type rdf:Property ;
    rdfs:label 'Actual Route' ;
    rdfs:comment 'The actual route or waypoint sequence flown by the aircraft at the time of deviation. Null if deviation type is not route or lateral-related.' ;
    rdfs:domain ind:AirspaceDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualSpeedKnots rdf:type rdf:Property ;
    rdfs:label 'Actual Speed Knots' ;
    rdfs:comment 'The actual indicated airspeed in knots at the time of deviation detection. Null if deviation type is not speed-related.' ;
    rdfs:domain ind:AirspaceDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:altitudeDeviationFeet rdf:type rdf:Property ;
    rdfs:label 'Altitude Deviation Feet' ;
    rdfs:comment 'The magnitude of altitude deviation in feet (actual minus cleared). Positive indicates above cleared altitude, negative indicates below. Null if deviation type is not altitude-related.' ;
    rdfs:domain ind:AirspaceDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:analystNotes rdf:type rdf:Property ;
    rdfs:label 'Analyst Notes' ;
    rdfs:comment 'Free-text notes and observations recorded by the safety analyst or investigator during review of the deviation event.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:atcClearanceText rdf:type rdf:Property ;
    rdfs:label 'Atc Clearance Text' ;
    rdfs:comment 'The verbatim or summarized text of the ATC clearance or instruction that was deviated from.' ;
    rdfs:domain ind:AirspaceDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:atcFacilityCode rdf:type rdf:Property ;
    rdfs:label 'Atc Facility Code' ;
    rdfs:comment 'The identifier of the ATC facility or control center that had jurisdiction over the airspace at the time of deviation.' ;
    rdfs:domain ind:AirspaceDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:atcSector rdf:type rdf:Property ;
    rdfs:label 'Atc Sector' ;
    rdfs:comment 'The specific ATC sector or control zone within the facility where the deviation occurred.' ;
    rdfs:domain ind:AirspaceDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caaReportDate rdf:type rdf:Property ;
    rdfs:label 'Caa Report Date' ;
    rdfs:comment 'The date on which the deviation was reported to the national civil aviation authority, in yyyy-MM-dd format. Null if not yet reported.' ;
    rdfs:domain ind:AirspaceDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:caaReportReference rdf:type rdf:Property ;
    rdfs:label 'Caa Report Reference' ;
    rdfs:comment 'The reference number or identifier assigned by the national civil aviation authority for this deviation report. Null if not yet reported.' ;
    rdfs:domain ind:AirspaceDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caaReportedFlag rdf:type rdf:Property ;
    rdfs:label 'Caa Reported Flag' ;
    rdfs:comment 'Indicates whether the deviation has been formally reported to the national civil aviation authority. True if reported, False otherwise.' ;
    rdfs:domain ind:AirspaceDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:causeClassification rdf:type rdf:Property ;
    rdfs:label 'Cause Classification' ;
    rdfs:comment 'The primary root cause category for the airspace deviation: crew error, FMS (Flight Management System) error, ATC error, weather, equipment malfunction, communication failure, or other. [ENUM-REF-CANDIDATE: crew_error|fms_error|atc_error|weather|equipment_malfunction|communication_failure|traffic_conflict|navigation_error|procedural_error|other — promote to reference product]' ;
    rdfs:domain ind:AirspaceDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearedAltitudeFeet rdf:type rdf:Property ;
    rdfs:label 'Cleared Altitude Feet' ;
    rdfs:comment 'The altitude in feet that was cleared by ATC for the aircraft at the time of deviation. Null if deviation type is not altitude-related.' ;
    rdfs:domain ind:AirspaceDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clearedRoute rdf:type rdf:Property ;
    rdfs:label 'Cleared Route' ;
    rdfs:comment 'The ATC-cleared route or waypoint sequence that the aircraft was authorized to fly. Null if deviation type is not route or lateral-related.' ;
    rdfs:domain ind:AirspaceDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearedSpeedKnots rdf:type rdf:Property ;
    rdfs:label 'Cleared Speed Knots' ;
    rdfs:comment 'The indicated airspeed in knots that was cleared or assigned by ATC. Null if deviation type is not speed-related.' ;
    rdfs:domain ind:AirspaceDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contributingFactors rdf:type rdf:Property ;
    rdfs:label 'Contributing Factors' ;
    rdfs:comment 'Free-text description of any contributing factors or secondary causes that led to or exacerbated the airspace deviation.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crewNotifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Crew Notified Flag' ;
    rdfs:comment 'Indicates whether the flight crew was notified of the deviation by ATC or onboard systems during the event. True if notified, False otherwise.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:detectionSource rdf:type rdf:Property ;
    rdfs:label 'Detection Source' ;
    rdfs:comment 'The source or system that first detected or reported the airspace deviation: ATC, crew, FMS (Flight Management System), ACARS, FDM (Flight Data Monitoring), ground radar, or other. [ENUM-REF-CANDIDATE: atc|crew|fms|acars|fdm|ground_radar|tcas|egpws|airline_ops|other — promote to reference product]' ;
    rdfs:domain ind:AirspaceDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviationCategory rdf:type rdf:Property ;
    rdfs:label 'Deviation Category' ;
    rdfs:comment 'The severity classification of the deviation based on magnitude and safety impact: minor, moderate, major, or critical.' ;
    rdfs:domain ind:AirspaceDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviationType rdf:type rdf:Property ;
    rdfs:label 'Deviation Type' ;
    rdfs:comment 'The category of airspace deviation: altitude (vertical deviation), lateral (horizontal route deviation), speed (airspeed deviation), clearance (ATC clearance not followed), route (flight plan route deviation), or other.' ;
    rdfs:domain ind:AirspaceDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icaoAdrepReportedFlag rdf:type rdf:Property ;
    rdfs:label 'Icao Adrep Reported Flag' ;
    rdfs:comment 'Indicates whether the deviation has been reported to the ICAO ADREP system for international safety data sharing. True if reported, False otherwise.' ;
    rdfs:domain ind:AirspaceDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:investigationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Investigation Required Flag' ;
    rdfs:comment 'Indicates whether the deviation event requires formal safety investigation per SMS procedures. True if investigation is required, False otherwise.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lateralDeviationNm rdf:type rdf:Property ;
    rdfs:label 'Lateral Deviation Nm' ;
    rdfs:comment 'The magnitude of lateral deviation from the cleared route in nautical miles. Null if deviation type is not lateral or route-related.' ;
    rdfs:domain ind:AirspaceDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumSeparationNm rdf:type rdf:Property ;
    rdfs:label 'Minimum Separation Nm' ;
    rdfs:comment 'The minimum horizontal separation in nautical miles between the deviating aircraft and other traffic during the event. Null if no traffic conflict occurred.' ;
    rdfs:domain ind:AirspaceDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pilotAcknowledgementFlag rdf:type rdf:Property ;
    rdfs:label 'Pilot Acknowledgement Flag' ;
    rdfs:comment 'Indicates whether the flight crew acknowledged the ATC clearance or instruction prior to the deviation. True if acknowledged, False if not acknowledged or unclear.' ;
    rdfs:domain ind:AirspaceDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:riskScore rdf:type rdf:Property ;
    rdfs:label 'Risk Score' ;
    rdfs:comment 'Numerical risk score assigned to the deviation event based on likelihood and consequence, typically on a scale of 1-25 per SMS risk matrix.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:separationLossFlag rdf:type rdf:Property ;
    rdfs:label 'Separation Loss Flag' ;
    rdfs:comment 'Indicates whether the airspace deviation resulted in a loss of required separation from other aircraft or obstacles. True if separation was lost, False otherwise.' ;
    rdfs:domain ind:AirspaceDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:speedDeviationKnots rdf:type rdf:Property ;
    rdfs:label 'Speed Deviation Knots' ;
    rdfs:comment 'The magnitude of speed deviation in knots (actual minus cleared). Positive indicates faster than cleared, negative indicates slower. Null if deviation type is not speed-related.' ;
    rdfs:domain ind:AirspaceDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:weatherConditions rdf:type rdf:Property ;
    rdfs:label 'Weather Conditions' ;
    rdfs:comment 'The meteorological conditions at the time of deviation: VMC (Visual Meteorological Conditions), IMC (Instrument Meteorological Conditions), marginal, or unknown.' ;
    rdfs:domain ind:AirspaceDeviation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendationId rdf:type rdf:Property ;
    rdfs:label 'Recommendation Id' ;
    rdfs:comment 'Foreign key linking to safety.recommendation. Business justification: Alerts can be issued to communicate formal safety recommendations to operational teams. Adding alert.recommendation_id → recommendation.recommendation_id tracks which recommendation the alert communic' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Recommendation .

ind:supersededByAlertId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Alert Id' ;
    rdfs:comment 'Reference to the alert_id of a newer alert that replaces or supersedes this alert. Null if this alert is still current.' ;
    rdfs:domain ind:Alert ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Alert .

ind:acknowledgementCount rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Count' ;
    rdfs:comment 'Number of departments or individuals who have formally acknowledged receipt of this alert.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:acknowledgementDeadline rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Deadline' ;
    rdfs:comment 'Date by which all required departments and personnel must acknowledge receipt of the alert. Null if no acknowledgement is required.' ;
    rdfs:domain ind:Alert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:affectedFleetTailNumbers rdf:type rdf:Property ;
    rdfs:label 'Affected Fleet Tail Numbers' ;
    rdfs:comment 'Comma-separated list of specific aircraft registration numbers (tail numbers) affected by this alert. Empty if alert applies broadly by aircraft type rather than specific airframes.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedOperations rdf:type rdf:Property ;
    rdfs:label 'Affected Operations' ;
    rdfs:comment 'Description of the operational areas, flight phases, or activities impacted by this alert (e.g., ETOPS operations, CAT III approaches, cargo operations, maintenance procedures).' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertDescription rdf:type rdf:Property ;
    rdfs:label 'Alert Description' ;
    rdfs:comment 'Detailed narrative describing the safety issue, hazard, or concern that prompted the alert, including background context and technical details.' ;
    rdfs:domain ind:Alert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertStatus rdf:type rdf:Property ;
    rdfs:label 'Alert Status' ;
    rdfs:comment 'Current lifecycle status of the safety alert: draft (under preparation), issued (distributed to stakeholders), acknowledged (receipt confirmed by departments), complied (required actions completed), closed (alert lifecycle complete), or superseded (replaced by newer alert).' ;
    rdfs:domain ind:Alert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertType rdf:type rdf:Property ;
    rdfs:label 'Alert Type' ;
    rdfs:comment 'Classification of the safety alert by its originating source: internal (airline-issued), EASA SIB (European Union Aviation Safety Agency Safety Information Bulletin), FAA SAFO (Federal Aviation Administration Safety Alert for Operators), manufacturer (OEM safety bulletin), IATA (International Air Transport Association safety alert), or ICAO NOTAM (International Civil Aviation Organization Notice to Air Missions).' ;
    rdfs:domain ind:Alert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceDeadline rdf:type rdf:Property ;
    rdfs:label 'Compliance Deadline' ;
    rdfs:comment 'Date by which the required actions must be completed to maintain regulatory compliance and operational safety. Null if no specific deadline is mandated.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:distributionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Distribution Timestamp' ;
    rdfs:comment 'Date and time when the alert was distributed to internal departments and operational personnel.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:manufacturerBulletinReference rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Bulletin Reference' ;
    rdfs:comment 'Reference number of the original equipment manufacturer (OEM) safety bulletin or service bulletin that this alert is based on or references. Null if not applicable.' ;
    rdfs:domain ind:Alert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredActionDescription rdf:type rdf:Property ;
    rdfs:label 'Required Action Description' ;
    rdfs:comment 'Detailed description of the corrective or preventive actions that must be taken in response to this alert, including specific procedures, inspections, or operational changes.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetRecipientCount rdf:type rdf:Property ;
    rdfs:label 'Target Recipient Count' ;
    rdfs:comment 'Total number of departments or individuals to whom this alert was distributed and from whom acknowledgement is expected.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:urgencyLevel rdf:type rdf:Property ;
    rdfs:label 'Urgency Level' ;
    rdfs:comment 'Priority classification indicating the time-sensitivity and criticality of the alert: critical (immediate action required), high (urgent attention needed), medium (timely response required), low (routine attention), or informational (awareness only).' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditedDepartment rdf:type rdf:Property ;
    rdfs:label 'Audited Department' ;
    rdfs:comment 'Name of the department, division, or functional area being audited (e.g., \'Flight Operations\', \'Ground Handling\', \'Maintenance Engineering\', \'Crew Scheduling\').' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditedFunction rdf:type rdf:Property ;
    rdfs:label 'Audited Function' ;
    rdfs:comment 'Specific operational function or process being audited (e.g., \'Dispatch Release Procedures\', \'Fuel Uplift Operations\', \'Cabin Safety Procedures\', \'MEL Compliance\').' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditedStationCode rdf:type rdf:Property ;
    rdfs:label 'Audited Station Code' ;
    rdfs:comment 'Three-letter IATA airport code of the station being audited, if the audit is station-specific (e.g., \'JFK\', \'LHR\', \'DXB\'). Null for non-station audits.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionPlanDueDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Plan Due Date' ;
    rdfs:comment 'Date by which the corrective action plan must be submitted to the audit authority or safety management team. Null if no CAP required.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionPlanRequired rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Plan Required' ;
    rdfs:comment 'Indicates whether a formal corrective action plan is required based on audit findings. True if findings require documented corrective actions.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:followUpAuditRequired rdf:type rdf:Property ;
    rdfs:label 'Follow Up Audit Required' ;
    rdfs:comment 'Indicates whether a follow-up audit is required to verify implementation of corrective actions. True if findings severity or regulatory requirement mandates follow-up.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:followUpAuditScheduledDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Audit Scheduled Date' ;
    rdfs:comment 'Scheduled date for the follow-up audit to verify corrective action effectiveness. Null if no follow-up required.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:iosaRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Iosa Registration Number' ;
    rdfs:comment 'IATA IOSA registration number if this audit is part of IOSA certification or renewal process (e.g., \'IOSA-123456\'). Null for non-IOSA audits.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadAuditorName rdf:type rdf:Property ;
    rdfs:label 'Lead Auditor Name' ;
    rdfs:comment 'Full name of the lead auditor responsible for conducting and reporting the audit.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallFindingSummary rdf:type rdf:Property ;
    rdfs:label 'Overall Finding Summary' ;
    rdfs:comment 'Executive summary of the audit findings, including overall compliance assessment, number of findings by severity, and key themes identified.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority Name' ;
    rdfs:comment 'Name of the regulatory authority conducting or sponsoring the audit (e.g., \'FAA\', \'EASA\', \'UK CAA\', \'DGCA India\'). Null for internal audits.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAuthorityReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority Reference' ;
    rdfs:comment 'Reference number or identifier assigned by the regulatory authority for this audit. Null for internal audits.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Report Document Reference' ;
    rdfs:comment 'Document management system reference or file path to the formal audit report document.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:smsAccountableExecutiveNotified rdf:type rdf:Property ;
    rdfs:label 'Sms Accountable Executive Notified' ;
    rdfs:comment 'Indicates whether the SMS Accountable Executive has been notified of the audit findings, as required for critical or major findings under ICAO Annex 19.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:standardReference rdf:type rdf:Property ;
    rdfs:label 'Standard Reference' ;
    rdfs:comment 'Reference to the standard, regulation, or framework against which the audit was conducted (e.g., \'IOSA IRM Edition 14\', \'FAA Part 121\', \'ICAO Annex 19\', \'ISO 9001:2015\').' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teamMembers rdf:type rdf:Property ;
    rdfs:label 'Team Members' ;
    rdfs:comment 'Comma-separated list of audit team member names participating in the audit.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditFindingId rdf:type rdf:Property ;
    rdfs:label 'Audit Finding Id' ;
    rdfs:comment 'Unique identifier for the audit finding record. Primary key.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:previousFindingAuditFindingId rdf:type rdf:Property ;
    rdfs:label 'Previous Finding Audit Finding Id' ;
    rdfs:comment 'Reference to the previous audit finding record if this is a recurrence. Links to historical finding for trend analysis and corrective action effectiveness review.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AuditFinding .

ind:auditOrganization rdf:type rdf:Property ;
    rdfs:label 'Audit Organization' ;
    rdfs:comment 'Organization or authority that conducted the audit (e.g., IATA IOSA, FAA, EASA, Internal Audit, National CAA). Identifies the source and authority level of the finding.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditorName rdf:type rdf:Property ;
    rdfs:label 'Auditor Name' ;
    rdfs:comment 'Name of the auditor or inspector who identified and documented the finding. May be internal auditor, IOSA auditor, FAA inspector, or EASA inspector.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingCategory rdf:type rdf:Property ;
    rdfs:label 'Finding Category' ;
    rdfs:comment 'Business or operational category of the finding (e.g., Flight Operations, Maintenance, Ground Operations, Crew Training, Safety Management, Security, Cargo). Aligns with airline operational domains.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingDate rdf:type rdf:Property ;
    rdfs:label 'Finding Date' ;
    rdfs:comment 'Date on which the finding was identified and documented during the audit or inspection activity.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:findingReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Finding Reference Number' ;
    rdfs:comment 'Externally-known unique reference number assigned to this finding for tracking and communication purposes. Used in audit reports and corrective action tracking.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managementResponse rdf:type rdf:Property ;
    rdfs:label 'Management Response' ;
    rdfs:comment 'Formal response from management acknowledging the finding, accepting or disputing it, and committing to corrective actions. Part of the audit finding closure process.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preventiveAction rdf:type rdf:Property ;
    rdfs:label 'Preventive Action' ;
    rdfs:comment 'Description of preventive measures implemented to prevent recurrence of similar findings across the organization. Addresses systemic improvements beyond immediate corrective action.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsiblePersonName rdf:type rdf:Property ;
    rdfs:label 'Responsible Person Name' ;
    rdfs:comment 'Name of the individual assigned accountability for resolving the finding and implementing corrective actions. Business-confidential operational data.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sopReference rdf:type rdf:Property ;
    rdfs:label 'Sop Reference' ;
    rdfs:comment 'Reference to the specific Standard Operating Procedure (SOP) document, version, or section that was not followed or requires revision as a result of this finding.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caseId rdf:type rdf:Property ;
    rdfs:label 'Case Id' ;
    rdfs:comment 'Unique identifier for the safety case record. Primary key.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:caseApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Case Approved By Employee Id' ;
    rdfs:comment 'Employee identifier of the accountable executive or safety manager who approved the safety case for submission to the regulatory authority.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:casePreparedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Case Prepared By Employee Id' ;
    rdfs:comment 'Employee identifier of the safety analyst or engineer who prepared the safety case documentation.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:riskAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Id' ;
    rdfs:comment 'Foreign key linking to safety.risk_assessment. Business justification: Safety cases reference formal risk assessments as evidence. Adding case.risk_assessment_id → risk_assessment.risk_assessment_id links cases to their supporting risk assessments. No redundant columns v' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RiskAssessment .

ind:acceptanceConditions rdf:type rdf:Property ;
    rdfs:label 'Acceptance Conditions' ;
    rdfs:comment 'Specific conditions, limitations, or operational restrictions imposed by the regulatory authority as part of conditional acceptance, such as crew training requirements, route restrictions, weather minima, or periodic reporting obligations.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acceptanceStatus rdf:type rdf:Property ;
    rdfs:label 'Acceptance Status' ;
    rdfs:comment 'Final acceptance status from the regulatory authority: accepted (fully approved), conditionally_accepted (approved with conditions or limitations), rejected (not approved), or pending_clarification (awaiting additional information).' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aircraftTypeCodes rdf:type rdf:Property ;
    rdfs:label 'Aircraft Type Codes' ;
    rdfs:comment 'Comma-separated list of ICAO aircraft type codes (e.g., B789, A359, B77W) to which this safety case applies.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:associatedProjectCode rdf:type rdf:Property ;
    rdfs:label 'Associated Project Code' ;
    rdfs:comment 'Reference code of the operational change project, fleet introduction program, or route expansion initiative that this safety case supports.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assumptions rdf:type rdf:Property ;
    rdfs:label 'Assumptions' ;
    rdfs:comment 'Documented assumptions underpinning the safety case, such as operational environment conditions, crew qualifications, maintenance standards, air traffic control capabilities, and weather minima. Critical for validity and scope boundaries.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentStorageLocation rdf:type rdf:Property ;
    rdfs:label 'Document Storage Location' ;
    rdfs:comment 'File path, URL, or document management system reference where the full safety case documentation is stored for retrieval and audit purposes.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceReferences rdf:type rdf:Property ;
    rdfs:label 'Evidence References' ;
    rdfs:comment 'Comma-separated list or structured references to supporting evidence documents, including risk assessments, hazard analyses, operational data, simulator trials, crew training records, maintenance programs, and third-party certifications.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Internal Approval Date' ;
    rdfs:comment 'Date on which the safety case received internal approval from the accountable executive or SMS committee prior to regulatory submission.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryResponseDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Response Date' ;
    rdfs:comment 'Date on which the regulatory authority provided formal response, feedback, or decision regarding the safety case submission.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryResponseSummary rdf:type rdf:Property ;
    rdfs:label 'Regulatory Response Summary' ;
    rdfs:comment 'Summary of the regulatory authority\'s response, including acceptance decision, conditions, requested clarifications, additional evidence requirements, or reasons for rejection.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryTrackingReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Tracking Reference' ;
    rdfs:comment 'External tracking number or reference code assigned by the regulatory authority for monitoring the safety case submission and approval process.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualRiskStatement rdf:type rdf:Property ;
    rdfs:label 'Residual Risk Statement' ;
    rdfs:comment 'Formal statement of residual risks remaining after all mitigations have been applied, including risk levels, acceptability rationale, and any ongoing monitoring or contingency measures required.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionHistory rdf:type rdf:Property ;
    rdfs:label 'Revision History' ;
    rdfs:comment 'Summary of revisions and updates made to the safety case over its lifecycle, including version numbers, dates, and descriptions of changes.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyArgumentStructure rdf:type rdf:Property ;
    rdfs:label 'Safety Argument Structure' ;
    rdfs:comment 'Structured outline or narrative of the safety argument, including claims, evidence, and reasoning that demonstrate acceptable safety levels for the proposed operation. May reference Goal Structuring Notation (GSN) or Claims-Arguments-Evidence (CAE) frameworks.' ;
    rdfs:domain ind:Case ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:committeeId rdf:type rdf:Property ;
    rdfs:label 'Committee Id' ;
    rdfs:comment 'Unique identifier for the safety committee record. Primary key. Role: MASTER_RESOURCE (safety governance body).' ;
    rdfs:domain ind:Committee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:committeeChairpersonEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Committee Chairperson Employee Id' ;
    rdfs:comment 'Employee identifier for the committee chairperson. Links to workforce master data for role verification and accountability tracking.' ;
    rdfs:domain ind:Committee ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:committeeEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Committee Employee Id' ;
    rdfs:comment 'Identifier of the user who last modified this committee record. Provides accountability for data changes and supports audit trail requirements.' ;
    rdfs:domain ind:Committee ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actionDeadlines rdf:type rdf:Property ;
    rdfs:label 'Action Deadlines' ;
    rdfs:comment 'Target completion dates for assigned action items. May be structured as comma-separated dates or narrative description of multiple deadlines.' ;
    rdfs:domain ind:Committee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionItemCount rdf:type rdf:Property ;
    rdfs:label 'Action Item Count' ;
    rdfs:comment 'Total number of action items assigned during the committee meeting. Used for tracking committee productivity and follow-up workload.' ;
    rdfs:domain ind:Committee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actionItemsAssigned rdf:type rdf:Property ;
    rdfs:label 'Action Items Assigned' ;
    rdfs:comment 'List of corrective actions, safety recommendations, and follow-up tasks assigned during the committee meeting. Includes action item descriptions and assignment details.' ;
    rdfs:domain ind:Committee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionOwners rdf:type rdf:Property ;
    rdfs:label 'Action Owners' ;
    rdfs:comment 'Comma-separated list of individuals or departments assigned responsibility for completing action items. Establishes accountability for safety improvement actions.' ;
    rdfs:domain ind:Committee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agendaItems rdf:type rdf:Property ;
    rdfs:label 'Agenda Items' ;
    rdfs:comment 'Structured list or narrative description of topics and items scheduled for discussion during the committee meeting. Provides context for safety topics reviewed and decisions made.' ;
    rdfs:domain ind:Committee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:attendeeCount rdf:type rdf:Property ;
    rdfs:label 'Attendee Count' ;
    rdfs:comment 'Total number of individuals who attended the committee meeting. Used for quorum verification and meeting effectiveness tracking.' ;
    rdfs:domain ind:Committee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:attendeeList rdf:type rdf:Property ;
    rdfs:label 'Attendee List' ;
    rdfs:comment 'Comma-separated list of names of all individuals who attended the committee meeting. Provides audit trail for management participation and decision-making accountability per ICAO Annex 19 requirements.' ;
    rdfs:domain ind:Committee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chairpersonName rdf:type rdf:Property ;
    rdfs:label 'Chairperson Name' ;
    rdfs:comment 'Full name of the individual who chaired the safety committee meeting. Typically the Accountable Executive for Safety Review Board meetings per ICAO Annex 19 Component 1 requirements.' ;
    rdfs:domain ind:Committee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:committeeStatus rdf:type rdf:Property ;
    rdfs:label 'Committee Status' ;
    rdfs:comment 'Current lifecycle status of the safety committee. Active committees hold regular meetings and exercise governance authority. Inactive committees are temporarily paused. Dissolved committees have been permanently disbanded.' ;
    rdfs:domain ind:Committee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:committeeType rdf:type rdf:Property ;
    rdfs:label 'Committee Type' ;
    rdfs:comment 'Classification of the safety committee within the SMS (Safety Management System) governance structure. Safety Review Board (SRB) is the highest-level management committee responsible for safety policy and risk acceptance decisions. Safety Action Groups are operational-level committees addressing specific safety domains.' ;
    rdfs:domain ind:Committee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationDecisions rdf:type rdf:Property ;
    rdfs:label 'Escalation Decisions' ;
    rdfs:comment 'Summary of decisions made to escalate safety issues to higher management levels or external regulatory authorities. Documents when issues require Accountable Executive attention or regulatory notification.' ;
    rdfs:domain ind:Committee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Escalation Required Flag' ;
    rdfs:comment 'Indicates whether any safety issues discussed in the meeting require escalation to higher management or regulatory authorities. True if escalation is required, False otherwise.' ;
    rdfs:domain ind:Committee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazardsDiscussed rdf:type rdf:Property ;
    rdfs:label 'Hazards Discussed' ;
    rdfs:comment 'List or narrative of specific hazard identifications reviewed by the committee, including hazard numbers and brief descriptions. Links to hazard register for detailed hazard data.' ;
    rdfs:domain ind:Committee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meetingDate rdf:type rdf:Property ;
    rdfs:label 'Meeting Date' ;
    rdfs:comment 'Date on which the safety committee meeting occurred. Principal business event timestamp for this governance record. Used for tracking meeting frequency compliance and audit trail per ICAO Annex 19 requirements.' ;
    rdfs:domain ind:Committee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:meetingEndTime rdf:type rdf:Property ;
    rdfs:label 'Meeting End Time' ;
    rdfs:comment 'Timestamp when the committee meeting concluded. Used for meeting duration tracking and resource planning.' ;
    rdfs:domain ind:Committee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:meetingFrequency rdf:type rdf:Property ;
    rdfs:label 'Meeting Frequency' ;
    rdfs:comment 'Scheduled frequency at which the committee is required to meet per SMS governance framework. Safety Review Boards typically meet quarterly or monthly; operational committees may meet more frequently. [ENUM-REF-CANDIDATE: Weekly|Bi-Weekly|Monthly|Quarterly|Semi-Annual|Annual|Ad-Hoc — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Committee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meetingLocation rdf:type rdf:Property ;
    rdfs:label 'Meeting Location' ;
    rdfs:comment 'Physical or virtual location where the committee meeting was held (e.g., headquarters conference room, station code, or virtual platform identifier).' ;
    rdfs:domain ind:Committee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:meetingStartTime rdf:type rdf:Property ;
    rdfs:label 'Meeting Start Time' ;
    rdfs:comment 'Timestamp when the committee meeting commenced. Used for meeting duration tracking and scheduling compliance.' ;
    rdfs:domain ind:Committee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:minutesApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Minutes Approval Date' ;
    rdfs:comment 'Date on which the committee meeting minutes were formally approved. Required for audit trail and regulatory compliance documentation.' ;
    rdfs:domain ind:Committee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:minutesApprovedFlag rdf:type rdf:Property ;
    rdfs:label 'Minutes Approved Flag' ;
    rdfs:comment 'Indicates whether the meeting minutes have been formally reviewed and approved by the committee. True if approved, False if pending approval.' ;
    rdfs:domain ind:Committee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minutesReference rdf:type rdf:Property ;
    rdfs:label 'Minutes Reference' ;
    rdfs:comment 'Document reference number or storage location for the detailed meeting minutes. Links to full meeting documentation for audit and regulatory review.' ;
    rdfs:domain ind:Committee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextMeetingDate rdf:type rdf:Property ;
    rdfs:label 'Next Meeting Date' ;
    rdfs:comment 'Scheduled date for the next committee meeting. Used for tracking meeting frequency compliance with SMS requirements and regulatory standards.' ;
    rdfs:domain ind:Committee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:quorumMetFlag rdf:type rdf:Property ;
    rdfs:label 'Quorum Met Flag' ;
    rdfs:comment 'Indicates whether the minimum required attendance (quorum) was achieved for the meeting to conduct official business and make binding decisions. True if quorum was met, False otherwise.' ;
    rdfs:domain ind:Committee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryObserverAgency rdf:type rdf:Property ;
    rdfs:label 'Regulatory Observer Agency' ;
    rdfs:comment 'Name of the regulatory authority whose representative attended the meeting as an observer (e.g., FAA, EASA, Transport Canada, national Civil Aviation Authority).' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryObserverPresent rdf:type rdf:Property ;
    rdfs:label 'Regulatory Observer Present' ;
    rdfs:comment 'Indicates whether a representative from a regulatory authority (FAA, EASA, national CAA) attended the meeting as an observer. True if regulatory observer was present, False otherwise.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:riskAcceptanceDecisions rdf:type rdf:Property ;
    rdfs:label 'Risk Acceptance Decisions' ;
    rdfs:comment 'Formal decisions made by the committee regarding acceptance of identified safety risks. Documents which risks were accepted, conditionally accepted, or rejected, along with management rationale. Critical for ICAO Annex 19 Component 1 management accountability requirements.' ;
    rdfs:domain ind:Committee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskAcceptanceRationale rdf:type rdf:Property ;
    rdfs:label 'Risk Acceptance Rationale' ;
    rdfs:comment 'Detailed justification and business reasoning provided by management for accepting specific safety risks. Required documentation for regulatory compliance and audit trail per ICAO Annex 19.' ;
    rdfs:domain ind:Committee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:risksDiscussed rdf:type rdf:Property ;
    rdfs:label 'Risks Discussed' ;
    rdfs:comment 'Summary of safety risk assessments and risk levels reviewed by the committee. Includes discussion of risk mitigation strategies and residual risk evaluations.' ;
    rdfs:domain ind:Committee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyTopicsReviewed rdf:type rdf:Property ;
    rdfs:label 'Safety Topics Reviewed' ;
    rdfs:comment 'Summary of safety management topics, hazards, risks, and safety performance indicators discussed during the meeting. Core content of the committee\'s safety oversight function.' ;
    rdfs:domain ind:Committee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:smsAccountableExecutivePresent rdf:type rdf:Property ;
    rdfs:label 'Sms Accountable Executive Present' ;
    rdfs:comment 'Indicates whether the SMS Accountable Executive (the senior management position with ultimate responsibility for safety performance) attended the meeting. Required for Safety Review Board meetings per ICAO Annex 19 Component 1.' ;
    rdfs:domain ind:Committee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:actionNumber rdf:type rdf:Property ;
    rdfs:label 'Action Number' ;
    rdfs:comment 'Business-facing unique reference number for the corrective action, typically formatted as CA-YYYYNNNNNN for external communication and tracking.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionTitle rdf:type rdf:Property ;
    rdfs:label 'Action Title' ;
    rdfs:comment 'Short descriptive title summarizing the corrective action or recommendation.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionType rdf:type rdf:Property ;
    rdfs:label 'Action Type' ;
    rdfs:comment 'Classification of the action: corrective (addresses existing deficiency), preventive (prevents future occurrence), mitigating (reduces severity), or recommendation (formal safety recommendation from investigation body).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addresseeResponse rdf:type rdf:Property ;
    rdfs:label 'Addressee Response' ;
    rdfs:comment 'Formal response received from the external addressee or AIB regarding acceptance, implementation plan, or rejection of the recommendation.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedDepartment rdf:type rdf:Property ;
    rdfs:label 'Assigned Department' ;
    rdfs:comment 'Internal department or organizational unit responsible for implementing the corrective action.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureStatus rdf:type rdf:Property ;
    rdfs:label 'Closure Status' ;
    rdfs:comment 'Final disposition status indicating whether the corrective action has been formally closed and the reason for closure.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionStatus rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Status' ;
    rdfs:comment 'Current lifecycle status of the corrective action from identification through closure and effectiveness review. [ENUM-REF-CANDIDATE: open|in_progress|pending_verification|verified|closed|overdue|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costEstimate rdf:type rdf:Property ;
    rdfs:label 'Cost Estimate' ;
    rdfs:comment 'Estimated financial cost to implement the corrective action including labor, materials, training, and system modifications.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:effectivenessRating rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Rating' ;
    rdfs:comment 'Assessment of whether the corrective action achieved its intended safety improvement objective after monitoring period.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivenessReviewDate rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Review Date' ;
    rdfs:comment 'Scheduled or actual date for reviewing the long-term effectiveness of the corrective action after a monitoring period.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:externalAddressee rdf:type rdf:Property ;
    rdfs:label 'External Addressee' ;
    rdfs:comment 'Name of external organization or Accident Investigation Body (AIB) to whom this recommendation is addressed, if applicable.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implementationEvidence rdf:type rdf:Property ;
    rdfs:label 'Implementation Evidence' ;
    rdfs:comment 'Description or reference to documentation, records, or artifacts that provide evidence of corrective action implementation.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsiblePersonEmail rdf:type rdf:Property ;
    rdfs:label 'Responsible Person Email' ;
    rdfs:comment 'Email address of the individual accountable for the corrective action implementation.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationNotes rdf:type rdf:Property ;
    rdfs:label 'Verification Notes' ;
    rdfs:comment 'Detailed notes from the verification process including findings, evidence reviewed, and any concerns identified.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caaNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Caa Notification Date' ;
    rdfs:comment 'The date on which the dangerous goods incident was reported to the national civil aviation authority.' ;
    rdfs:domain ind:DangerousGoodsIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:caaNotificationStatus rdf:type rdf:Property ;
    rdfs:label 'Caa Notification Status' ;
    rdfs:comment 'The status of notification to the national civil aviation authority regarding this dangerous goods incident (e.g., not required, pending, submitted, acknowledged).' ;
    rdfs:domain ind:DangerousGoodsIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:damageOccurredFlag rdf:type rdf:Property ;
    rdfs:label 'Damage Occurred Flag' ;
    rdfs:comment 'Indicates whether any damage to aircraft, property, or other goods occurred as a result of the dangerous goods incident.' ;
    rdfs:domain ind:DangerousGoodsIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:detectionMethod rdf:type rdf:Property ;
    rdfs:label 'Detection Method' ;
    rdfs:comment 'The method by which the dangerous goods incident was detected (e.g., visual inspection, X-ray screening, canine detection, crew observation, passenger report).' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectionPoint rdf:type rdf:Property ;
    rdfs:label 'Detection Point' ;
    rdfs:comment 'The point in the handling or flight process where the dangerous goods incident was detected (e.g., check-in, cargo acceptance, screening, loading, in-flight, unloading, post-flight). [ENUM-REF-CANDIDATE: check_in|cargo_acceptance|screening|loading|in_flight|unloading|post_flight — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DangerousGoodsIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icaoNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Icao Notification Date' ;
    rdfs:comment 'The date on which the dangerous goods incident was reported to ICAO.' ;
    rdfs:domain ind:DangerousGoodsIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:icaoNotificationStatus rdf:type rdf:Property ;
    rdfs:label 'Icao Notification Status' ;
    rdfs:comment 'The status of notification to ICAO regarding this dangerous goods incident (e.g., not required, pending, submitted, acknowledged).' ;
    rdfs:domain ind:DangerousGoodsIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentDescription rdf:type rdf:Property ;
    rdfs:label 'Incident Description' ;
    rdfs:comment 'Detailed narrative description of the dangerous goods incident, including circumstances, observations, and actions taken.' ;
    rdfs:domain ind:DangerousGoodsIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentNumber rdf:type rdf:Property ;
    rdfs:label 'Incident Number' ;
    rdfs:comment 'Externally-known unique reference number assigned to this dangerous goods incident for tracking and regulatory reporting purposes.' ;
    rdfs:domain ind:DangerousGoodsIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentStatus rdf:type rdf:Property ;
    rdfs:label 'Incident Status' ;
    rdfs:comment 'Current lifecycle status of the dangerous goods incident (e.g., reported, under investigation, closed, regulatory notified).' ;
    rdfs:domain ind:DangerousGoodsIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incidentType rdf:type rdf:Property ;
    rdfs:label 'Incident Type' ;
    rdfs:comment 'Classification of the dangerous goods incident type (e.g., undeclared dangerous goods, misdeclared dangerous goods, packaging failure, leakage, spillage, fire).' ;
    rdfs:domain ind:DangerousGoodsIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:injuryDescription rdf:type rdf:Property ;
    rdfs:label 'Injury Description' ;
    rdfs:comment 'Description of any injuries sustained by persons as a result of the dangerous goods incident.' ;
    rdfs:domain ind:DangerousGoodsIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:injuryOccurredFlag rdf:type rdf:Property ;
    rdfs:label 'Injury Occurred Flag' ;
    rdfs:comment 'Indicates whether any injury to persons occurred as a result of the dangerous goods incident.' ;
    rdfs:domain ind:DangerousGoodsIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:packagingFailureType rdf:type rdf:Property ;
    rdfs:label 'Packaging Failure Type' ;
    rdfs:comment 'Description of the packaging failure mode if packaging failure contributed to the incident (e.g., seal failure, container rupture, inadequate cushioning).' ;
    rdfs:domain ind:DangerousGoodsIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packagingType rdf:type rdf:Property ;
    rdfs:label 'Packaging Type' ;
    rdfs:comment 'The type of packaging used for the dangerous goods (e.g., drum, cylinder, box, bag).' ;
    rdfs:domain ind:DangerousGoodsIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityInvolved rdf:type rdf:Property ;
    rdfs:label 'Quantity Involved' ;
    rdfs:comment 'The quantity of dangerous goods involved in the incident.' ;
    rdfs:domain ind:DangerousGoodsIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityUnit rdf:type rdf:Property ;
    rdfs:label 'Quantity Unit' ;
    rdfs:comment 'The unit of measure for the quantity of dangerous goods involved (e.g., kg, L, g, mL, pieces).' ;
    rdfs:domain ind:DangerousGoodsIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportedByName rdf:type rdf:Property ;
    rdfs:label 'Reported By Name' ;
    rdfs:comment 'The name of the person who reported the dangerous goods incident.' ;
    rdfs:domain ind:DangerousGoodsIncident ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exerciseControllerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Exercise Controller Employee Id' ;
    rdfs:comment 'Employee identifier of the exercise controller. Links to the workforce or crew management system.' ;
    rdfs:domain ind:EmergencyDrill ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:simulatedAircraftTypeId rdf:type rdf:Property ;
    rdfs:label 'Simulated Aircraft Type Id' ;
    rdfs:comment 'Foreign key linking to fleet.aircraft_type. Business justification: Emergency drills simulate type-specific scenarios (evacuation times vary by aircraft type, door configuration, exit count). Linking drills to aircraft type ensures scenario realism and enables type-sp' ;
    rdfs:domain ind:EmergencyDrill ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AircraftType .

ind:simulatedOccurrenceId rdf:type rdf:Property ;
    rdfs:label 'Simulated Occurrence Id' ;
    rdfs:comment 'Foreign key linking to safety.occurrence. Business justification: Emergency drills simulate response to specific occurrence types. Adding emergency_drill.simulated_occurrence_id → occurrence.occurrence_id links drills to the occurrence scenario they simulate or were' ;
    rdfs:domain ind:EmergencyDrill ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Occurrence .

ind:communicationSystemsTested rdf:type rdf:Property ;
    rdfs:label 'Communication Systems Tested' ;
    rdfs:comment 'List of communication systems and technologies tested during the drill (e.g., emergency hotline, ACARS, satellite phone, radio frequencies, mass notification system, crisis management software).' ;
    rdfs:domain ind:EmergencyDrill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:debriefDate rdf:type rdf:Property ;
    rdfs:label 'Debrief Date' ;
    rdfs:comment 'Date on which the post-drill debrief session was conducted with participants, observers, and stakeholders to review performance and identify lessons learned.' ;
    rdfs:domain ind:EmergencyDrill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:debriefFindings rdf:type rdf:Property ;
    rdfs:label 'Debrief Findings' ;
    rdfs:comment 'Comprehensive summary of observations, strengths, weaknesses, and lessons learned identified during the post-drill debrief. Includes feedback from participants and observers.' ;
    rdfs:domain ind:EmergencyDrill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drillDate rdf:type rdf:Property ;
    rdfs:label 'Drill Date' ;
    rdfs:comment 'The calendar date on which the emergency drill was conducted or is scheduled to be conducted.' ;
    rdfs:domain ind:EmergencyDrill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:drillEndTime rdf:type rdf:Property ;
    rdfs:label 'Drill End Time' ;
    rdfs:comment 'Timestamp marking the official conclusion of the emergency drill exercise, including time zone.' ;
    rdfs:domain ind:EmergencyDrill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:drillReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Drill Reference Number' ;
    rdfs:comment 'Business identifier for the emergency drill, typically formatted as station code, year, and sequence number (e.g., JFK-2024-001).' ;
    rdfs:domain ind:EmergencyDrill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drillStartTime rdf:type rdf:Property ;
    rdfs:label 'Drill Start Time' ;
    rdfs:comment 'Timestamp marking the official commencement of the emergency drill exercise, including time zone.' ;
    rdfs:domain ind:EmergencyDrill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:drillStatus rdf:type rdf:Property ;
    rdfs:label 'Drill Status' ;
    rdfs:comment 'Current lifecycle status of the emergency drill. Tracks progression from planning through execution to completion or cancellation.' ;
    rdfs:domain ind:EmergencyDrill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:drillType rdf:type rdf:Property ;
    rdfs:label 'Drill Type' ;
    rdfs:comment 'Classification of the emergency drill exercise type. Full-scale involves live simulation with all resources; tabletop is discussion-based; functional tests specific functions; communications tests notification systems; evacuation tests passenger/crew egress; medical tests triage and casualty handling.' ;
    rdfs:domain ind:EmergencyDrill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:erpVersionReference rdf:type rdf:Property ;
    rdfs:label 'Erp Version Reference' ;
    rdfs:comment 'Version identifier of the Emergency Response Plan (ERP) document that was being tested and validated by this drill.' ;
    rdfs:domain ind:EmergencyDrill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exerciseControllerName rdf:type rdf:Property ;
    rdfs:label 'Exercise Controller Name' ;
    rdfs:comment 'Full name of the individual responsible for directing and controlling the drill exercise, typically a senior safety or emergency response manager.' ;
    rdfs:domain ind:EmergencyDrill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalAgenciesInvolved rdf:type rdf:Property ;
    rdfs:label 'External Agencies Involved' ;
    rdfs:comment 'Comma-separated list of external organizations and agencies that participated in the drill (e.g., Airport Fire Rescue, Local Police, Emergency Medical Services, Hospital, Red Cross, Airport Authority).' ;
    rdfs:domain ind:EmergencyDrill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:improvementActionCount rdf:type rdf:Property ;
    rdfs:label 'Improvement Action Count' ;
    rdfs:comment 'Total number of improvement actions identified from the drill debrief that require follow-up and implementation.' ;
    rdfs:domain ind:EmergencyDrill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:improvementActionsIdentified rdf:type rdf:Property ;
    rdfs:label 'Improvement Actions Identified' ;
    rdfs:comment 'Detailed list of corrective and preventive actions identified from the drill to enhance emergency response procedures, training, resources, or coordination. Each action should include description and responsible party.' ;
    rdfs:domain ind:EmergencyDrill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextDrillDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Drill Due Date' ;
    rdfs:comment 'Scheduled date for the next emergency drill of this type or at this station, based on regulatory requirements and internal safety management system (SMS) schedules.' ;
    rdfs:domain ind:EmergencyDrill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:objectivesDefined rdf:type rdf:Property ;
    rdfs:label 'Objectives Defined' ;
    rdfs:comment 'Detailed list of specific learning and performance objectives established for the drill, aligned with Emergency Response Plan (ERP) competencies and regulatory requirements.' ;
    rdfs:domain ind:EmergencyDrill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:objectivesMetCount rdf:type rdf:Property ;
    rdfs:label 'Objectives Met Count' ;
    rdfs:comment 'Number of drill objectives that were successfully achieved during the exercise, as assessed by observers and the exercise controller.' ;
    rdfs:domain ind:EmergencyDrill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:objectivesNotMetCount rdf:type rdf:Property ;
    rdfs:label 'Objectives Not Met Count' ;
    rdfs:comment 'Number of drill objectives that were not achieved or only partially achieved during the exercise.' ;
    rdfs:domain ind:EmergencyDrill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:observerList rdf:type rdf:Property ;
    rdfs:label 'Observer List' ;
    rdfs:comment 'Comma-separated list of names and roles of individuals assigned to observe and evaluate the drill performance, including regulatory observers if present.' ;
    rdfs:domain ind:EmergencyDrill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallPerformanceRating rdf:type rdf:Property ;
    rdfs:label 'Overall Performance Rating' ;
    rdfs:comment 'Summary assessment of the drill performance across all objectives and participants. Reflects readiness and effectiveness of emergency response capabilities.' ;
    rdfs:domain ind:EmergencyDrill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:participantCount rdf:type rdf:Property ;
    rdfs:label 'Participant Count' ;
    rdfs:comment 'Total number of personnel actively participating in the drill exercise, including airline staff, contractors, and external agency responders.' ;
    rdfs:domain ind:EmergencyDrill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:participatingDepartments rdf:type rdf:Property ;
    rdfs:label 'Participating Departments' ;
    rdfs:comment 'Comma-separated list of airline departments and external agencies participating in the drill (e.g., Flight Operations, Ground Ops, Maintenance, Airport Authority, Fire Rescue, Medical Services, Local Police).' ;
    rdfs:domain ind:EmergencyDrill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:participatingStations rdf:type rdf:Property ;
    rdfs:label 'Participating Stations' ;
    rdfs:comment 'Comma-separated list of IATA station codes for all airports and facilities participating in the drill, including remote coordination centers.' ;
    rdfs:domain ind:EmergencyDrill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryStationCode rdf:type rdf:Property ;
    rdfs:label 'Primary Station Code' ;
    rdfs:comment 'Three-letter IATA airport code of the primary station where the drill is conducted. The lead location for the exercise.' ;
    rdfs:domain ind:EmergencyDrill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Status' ;
    rdfs:comment 'Assessment of whether the drill met regulatory requirements for emergency preparedness and response as mandated by applicable aviation authorities.' ;
    rdfs:domain ind:EmergencyDrill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Report Completed Date' ;
    rdfs:comment 'Date on which the formal drill report was completed and submitted to management and regulatory authorities as required.' ;
    rdfs:domain ind:EmergencyDrill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportSubmittedTo rdf:type rdf:Property ;
    rdfs:label 'Report Submitted To' ;
    rdfs:comment 'Comma-separated list of internal departments and external agencies to whom the drill report was submitted (e.g., Safety Department, Executive Management, FAA, EASA, Airport Authority).' ;
    rdfs:domain ind:EmergencyDrill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scenarioCategory rdf:type rdf:Property ;
    rdfs:label 'Scenario Category' ;
    rdfs:comment 'High-level classification of the emergency scenario type being exercised. Aligns with Emergency Response Plan (ERP) scenario taxonomy.' ;
    rdfs:domain ind:EmergencyDrill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scenarioDescription rdf:type rdf:Property ;
    rdfs:label 'Scenario Description' ;
    rdfs:comment 'Detailed narrative of the emergency scenario being simulated in the drill, including incident type, location, scale, and key conditions (e.g., aircraft fire on gate, medical emergency in-flight, security threat, hazmat spill).' ;
    rdfs:domain ind:EmergencyDrill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sopReferences rdf:type rdf:Property ;
    rdfs:label 'Sop References' ;
    rdfs:comment 'Comma-separated list of Standard Operating Procedure (SOP) document identifiers and version numbers that were exercised during the drill.' ;
    rdfs:domain ind:EmergencyDrill ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fatigueReportId rdf:type rdf:Property ;
    rdfs:label 'Fatigue Report Id' ;
    rdfs:comment 'Unique identifier for the fatigue report record. Primary key.' ;
    rdfs:domain ind:FatigueReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:linkedSafetyOccurrenceId rdf:type rdf:Property ;
    rdfs:label 'Linked Safety Occurrence Id' ;
    rdfs:comment 'Identifier of the related safety occurrence or incident report if the fatigue report is associated with a documented safety event. Links to safety occurrence records.' ;
    rdfs:domain ind:FatigueReport ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Occurrence .

ind:confidentialReport rdf:type rdf:Property ;
    rdfs:label 'Confidential Report' ;
    rdfs:comment 'Indicates whether the fatigue report was submitted confidentially under the airlines voluntary safety reporting program, protecting the reporters identity from disciplinary action.' ;
    rdfs:domain ind:FatigueReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contributingFactorCircadianDisruption rdf:type rdf:Property ;
    rdfs:label 'Contributing Factor Circadian Disruption' ;
    rdfs:comment 'Indicates whether circadian rhythm disruption (time zone changes, night operations, irregular schedules) was identified as a contributing factor to the reported fatigue.' ;
    rdfs:domain ind:FatigueReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contributingFactorIrop rdf:type rdf:Property ;
    rdfs:label 'Contributing Factor Irop' ;
    rdfs:comment 'Indicates whether irregular operations (delays, diversions, cancellations, weather disruptions, mechanical issues) were identified as a contributing factor to the reported fatigue.' ;
    rdfs:domain ind:FatigueReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contributingFactorOther rdf:type rdf:Property ;
    rdfs:label 'Contributing Factor Other' ;
    rdfs:comment 'Free-text description of other contributing factors to fatigue not captured by standard categories, such as personal health issues, environmental conditions, or operational stressors.' ;
    rdfs:domain ind:FatigueReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contributingFactorSleepDisruption rdf:type rdf:Property ;
    rdfs:label 'Contributing Factor Sleep Disruption' ;
    rdfs:comment 'Indicates whether sleep disruption (insufficient sleep, poor sleep quality, interrupted rest) was identified as a contributing factor to the reported fatigue.' ;
    rdfs:domain ind:FatigueReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contributingFactorWorkload rdf:type rdf:Property ;
    rdfs:label 'Contributing Factor Workload' ;
    rdfs:comment 'Indicates whether excessive workload (high task demands, complex operations, extended duty periods) was identified as a contributing factor to the reported fatigue.' ;
    rdfs:domain ind:FatigueReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:correctiveActionRequired rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Required' ;
    rdfs:comment 'Indicates whether corrective actions (schedule adjustments, rest period modifications, operational changes) are required based on the fatigue report findings.' ;
    rdfs:domain ind:FatigueReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dutyPeriodReference rdf:type rdf:Property ;
    rdfs:label 'Duty Period Reference' ;
    rdfs:comment 'Reference identifier for the duty period during which the fatigue was experienced. Links to crew scheduling duty period records. Format: DP-YYYY-NNNNNN.' ;
    rdfs:domain ind:FatigueReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fatigueScaleType rdf:type rdf:Property ;
    rdfs:label 'Fatigue Scale Type' ;
    rdfs:comment 'Type of fatigue assessment scale used for the reported fatigue level: Samn-Perelli (1-7), Karolinska Sleepiness Scale (1-9), custom airline scale, or other.' ;
    rdfs:domain ind:FatigueReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fatigueSymptomsDescription rdf:type rdf:Property ;
    rdfs:label 'Fatigue Symptoms Description' ;
    rdfs:comment 'Free-text description of fatigue symptoms experienced by the crew member, such as drowsiness, difficulty concentrating, microsleeps, impaired decision-making, or physical exhaustion.' ;
    rdfs:domain ind:FatigueReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flightPhaseExperienced rdf:type rdf:Property ;
    rdfs:label 'Flight Phase Experienced' ;
    rdfs:comment 'Phase of flight or duty period during which the fatigue was most acutely experienced: pre-flight preparation, taxi out, takeoff, climb, cruise, descent, approach, landing, taxi in, post-flight duties, ground duty, or other. [ENUM-REF-CANDIDATE: pre_flight|taxi_out|takeoff|climb|cruise|descent|approach|landing|taxi_in|post_flight|ground_duty|other — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FatigueReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frmsTrendCategory rdf:type rdf:Property ;
    rdfs:label 'Frms Trend Category' ;
    rdfs:comment 'Category assigned for FRMS trend analysis: route-specific (fatigue patterns on specific routes), fleet-specific (aircraft type related), crew base-specific (location related), seasonal (time-of-year patterns), operational pattern (duty structure related), individual (crew member specific), systemic (organization-wide), or other. [ENUM-REF-CANDIDATE: route_specific|fleet_specific|crew_base_specific|seasonal|operational_pattern|individual|systemic|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FatigueReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Report Reference Number' ;
    rdfs:comment 'Externally-known unique reference number assigned to the fatigue report for tracking and audit purposes. Format: FR-YYYY-NNNNNN.' ;
    rdfs:domain ind:FatigueReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportedFatigueLevel rdf:type rdf:Property ;
    rdfs:label 'Reported Fatigue Level' ;
    rdfs:comment 'Numeric fatigue level reported by crew member using standardized scale. Typically Samn-Perelli scale (1-7) or Karolinska Sleepiness Scale (KSS, 1-9). Lower values indicate alertness, higher values indicate severe fatigue.' ;
    rdfs:domain ind:FatigueReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reporterCrewCategory rdf:type rdf:Property ;
    rdfs:label 'Reporter Crew Category' ;
    rdfs:comment 'Category of crew member submitting the fatigue report: flight crew (pilots), cabin crew (flight attendants), ground crew, maintenance crew, dispatch, or other operational staff.' ;
    rdfs:domain ind:FatigueReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Review Completion Timestamp' ;
    rdfs:comment 'Date and time when the fatigue report review was completed by the safety team.' ;
    rdfs:domain ind:FatigueReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:safetyEventOccurred rdf:type rdf:Property ;
    rdfs:label 'Safety Event Occurred' ;
    rdfs:comment 'Indicates whether a safety event (incident, error, deviation, near-miss) occurred as a result of or in conjunction with the reported fatigue.' ;
    rdfs:domain ind:FatigueReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:safetyImpactAssessment rdf:type rdf:Property ;
    rdfs:label 'Safety Impact Assessment' ;
    rdfs:comment 'Assessment of the actual or potential safety impact of the reported fatigue: none (no safety consequence), minor (minimal impact), moderate (noticeable impact on performance), major (significant safety concern), or critical (severe safety risk).' ;
    rdfs:domain ind:FatigueReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:analysisTimestamp rdf:type rdf:Property ;
    rdfs:label 'Analysis Timestamp' ;
    rdfs:comment 'The date and time when the FDR data was analyzed and the event was identified by the FDM system.' ;
    rdfs:domain ind:FdrEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eventCategory rdf:type rdf:Property ;
    rdfs:label 'Event Category' ;
    rdfs:comment 'High-level categorization of the event cause or nature: operational (procedure-related), technical (aircraft system), environmental (weather/terrain), crew_action (pilot input).' ;
    rdfs:domain ind:FdrEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceedanceDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Exceedance Duration Seconds' ;
    rdfs:comment 'The duration in seconds for which the parameter remained outside the threshold limit. Null if the event was instantaneous.' ;
    rdfs:domain ind:FdrEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fdmProgramVersion rdf:type rdf:Property ;
    rdfs:label 'Fdm Program Version' ;
    rdfs:comment 'The version identifier of the FDM/FOQA program rules and thresholds used to detect this event.' ;
    rdfs:domain ind:FdrEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indicatedAirspeedKnots rdf:type rdf:Property ;
    rdfs:label 'Indicated Airspeed Knots' ;
    rdfs:comment 'The indicated airspeed in knots at the time of the event.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recordedValue rdf:type rdf:Property ;
    rdfs:label 'Recorded Value' ;
    rdfs:comment 'The actual value of the flight parameter recorded by the FDR at the time of the event.' ;
    rdfs:domain ind:FdrEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hazardAccountableExecutiveEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Hazard Accountable Executive Employee Id' ;
    rdfs:comment 'Identifier of the accountable executive (typically Director of Safety or VP Operations) who has ultimate accountability for this hazard and its mitigation per ICAO SMS requirements.' ;
    rdfs:domain ind:Hazard ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:hazardEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Hazard Employee Id' ;
    rdfs:comment 'Identifier of the safety officer or safety manager assigned as the owner of this hazard record, responsible for tracking mitigation and closure.' ;
    rdfs:domain ind:Hazard ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:hazardReportedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Hazard Reported By Employee Id' ;
    rdfs:comment 'Identifier of the employee or crew member who reported or identified the hazard. May be anonymized per just culture policy.' ;
    rdfs:domain ind:Hazard ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:affectedOperationsArea rdf:type rdf:Property ;
    rdfs:label 'Affected Operations Area' ;
    rdfs:comment 'Operational domain or business area impacted by the hazard (e.g., flight operations, ground handling, maintenance, cargo, passenger services, crew scheduling).' ;
    rdfs:domain ind:Hazard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedStation rdf:type rdf:Property ;
    rdfs:label 'Affected Station' ;
    rdfs:comment 'IATA three-letter airport or station code where the hazard is localized. Null if hazard is not station-specific.' ;
    rdfs:domain ind:Hazard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentLikelihoodRating rdf:type rdf:Property ;
    rdfs:label 'Current Likelihood Rating' ;
    rdfs:comment 'Current qualitative assessment of the probability that the hazard will result in a safety event, reflecting any mitigations applied since initial identification.' ;
    rdfs:domain ind:Hazard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentRiskIndex rdf:type rdf:Property ;
    rdfs:label 'Current Risk Index' ;
    rdfs:comment 'Current composite risk score derived from current likelihood and severity ratings using the ICAO SMS risk matrix, reflecting residual risk after mitigations. [ENUM-REF-CANDIDATE: 5A|5B|5C|4A|4B|4C|3A|3B|3C|2A|2B|1A — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Hazard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentSeverityRating rdf:type rdf:Property ;
    rdfs:label 'Current Severity Rating' ;
    rdfs:comment 'Current qualitative assessment of the worst credible consequence if the hazard materializes, reflecting any mitigations applied since initial identification.' ;
    rdfs:domain ind:Hazard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardCategory rdf:type rdf:Property ;
    rdfs:label 'Hazard Category' ;
    rdfs:comment 'Primary classification of the hazard type: operational (flight ops, ground ops), technical (aircraft systems, equipment), organizational (procedures, management), environmental (weather, terrain), human_factors (crew performance, fatigue), or external (third-party, regulatory).' ;
    rdfs:domain ind:Hazard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardDescription rdf:type rdf:Property ;
    rdfs:label 'Hazard Description' ;
    rdfs:comment 'Detailed narrative description of the hazard, including conditions, circumstances, and potential consequences that could lead to safety events.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardNumber rdf:type rdf:Property ;
    rdfs:label 'Hazard Number' ;
    rdfs:comment 'Business-facing unique reference number assigned to the hazard for tracking and reporting purposes. Format: HAZ-NNNNNN.' ;
    rdfs:domain ind:Hazard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardStatus rdf:type rdf:Property ;
    rdfs:label 'Hazard Status' ;
    rdfs:comment 'Current lifecycle status of the hazard in the SMS register: open (newly identified), under_review (being assessed), mitigation_in_progress (controls being implemented), mitigated (controls in place, residual risk acceptable), closed (no longer applicable), accepted (risk accepted by accountable executive).' ;
    rdfs:domain ind:Hazard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identificationSource rdf:type rdf:Property ;
    rdfs:label 'Identification Source' ;
    rdfs:comment 'Method or channel through which the hazard was identified: safety audit, incident report, occurrence report, crew observation, maintenance finding, proactive analysis (FMEA, FHA), regulatory inspection, or third-party report. [ENUM-REF-CANDIDATE: safety_audit|incident_report|occurrence_report|crew_observation|maintenance_finding|proactive_analysis|regulatory_inspection|third_party_report — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Hazard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identifiedDate rdf:type rdf:Property ;
    rdfs:label 'Identified Date' ;
    rdfs:comment 'Date on which the hazard was first identified and entered into the SMS hazard register.' ;
    rdfs:domain ind:Hazard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:initialLikelihoodRating rdf:type rdf:Property ;
    rdfs:label 'Initial Likelihood Rating' ;
    rdfs:comment 'Initial qualitative assessment of the probability that the hazard will result in a safety event, using ICAO SMS risk matrix categories: frequent, occasional, remote, improbable, extremely_improbable.' ;
    rdfs:domain ind:Hazard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initialRiskIndex rdf:type rdf:Property ;
    rdfs:label 'Initial Risk Index' ;
    rdfs:comment 'Initial composite risk score derived from likelihood and severity ratings using the ICAO SMS risk matrix (e.g., 5A = frequent/catastrophic, 1A = extremely_improbable/negligible). Format: <likelihood_level><severity_level>. [ENUM-REF-CANDIDATE: 5A|5B|5C|4A|4B|4C|3A|3B|3C|2A|2B|1A — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Hazard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initialSeverityRating rdf:type rdf:Property ;
    rdfs:label 'Initial Severity Rating' ;
    rdfs:comment 'Initial qualitative assessment of the worst credible consequence if the hazard materializes, using ICAO SMS risk matrix categories: catastrophic, hazardous, major, minor, negligible.' ;
    rdfs:domain ind:Hazard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mitigationTargetDate rdf:type rdf:Property ;
    rdfs:label 'Mitigation Target Date' ;
    rdfs:comment 'Target date by which mitigation controls are planned to be fully implemented and effective.' ;
    rdfs:domain ind:Hazard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextReviewDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Review Due Date' ;
    rdfs:comment 'Scheduled date for the next mandatory review of the hazard status and risk assessment, per SMS periodic review requirements.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:notamIssuedFlag rdf:type rdf:Property ;
    rdfs:label 'Notam Issued Flag' ;
    rdfs:comment 'Indicates whether a NOTAM (Notice to Air Missions) was issued to communicate this hazard to flight crews and operational personnel.' ;
    rdfs:domain ind:Hazard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sopRevisionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Sop Revision Required Flag' ;
    rdfs:comment 'Indicates whether this hazard has triggered a requirement to revise or create a Standard Operating Procedure (SOP) as part of mitigation.' ;
    rdfs:domain ind:Hazard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:subcategory rdf:type rdf:Property ;
    rdfs:label 'Subcategory' ;
    rdfs:comment 'Secondary classification providing additional granularity within the primary hazard category (e.g., under technical: avionics, hydraulics, engines).' ;
    rdfs:domain ind:Hazard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Investigation Employee Id' ;
    rdfs:comment 'Reference to the employee or investigator assigned as the lead investigator responsible for coordinating the investigation and producing the final report.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:investigationModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Investigation Modified By User Employee Id' ;
    rdfs:comment 'Reference to the user or system account that last modified this investigation record.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:smsHazardId rdf:type rdf:Property ;
    rdfs:label 'Sms Hazard Id' ;
    rdfs:comment 'Reference to the SMS hazard record that was identified or updated as a result of this investigation. Links investigation findings back to the hazard identification and risk assessment process.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Hazard .

ind:acarsDataReviewed rdf:type rdf:Property ;
    rdfs:label 'Acars Data Reviewed' ;
    rdfs:comment 'Indicates whether ACARS (Aircraft Communications Addressing and Reporting System) messages and data were reviewed as part of the investigation.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:causalFactorsIdentified rdf:type rdf:Property ;
    rdfs:label 'Causal Factors Identified' ;
    rdfs:comment 'Detailed description of the root causal factors identified during the investigation that directly led to the occurrence. May include human factors, technical failures, procedural deficiencies, or organizational factors.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionsRequired rdf:type rdf:Property ;
    rdfs:label 'Corrective Actions Required' ;
    rdfs:comment 'Description of mandatory corrective actions required to address the causal and contributing factors identified in the investigation. Links to corrective action tracking systems.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cvrFdrDataReviewed rdf:type rdf:Property ;
    rdfs:label 'Cvr Fdr Data Reviewed' ;
    rdfs:comment 'Indicates whether CVR (Cockpit Voice Recorder) and FDR (Flight Data Recorder) data were reviewed as part of the investigation. True if recorder data were analyzed, false otherwise.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:externalExpertConsulted rdf:type rdf:Property ;
    rdfs:label 'External Expert Consulted' ;
    rdfs:comment 'Indicates whether external subject matter experts, technical specialists, or consultants were engaged to support the investigation.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:investigationType rdf:type rdf:Property ;
    rdfs:label 'Investigation Type' ;
    rdfs:comment 'Classification of the investigation scope and authority: internal SMS investigation, regulatory authority-led investigation, joint investigation with multiple parties, independent third-party investigation, or preliminary investigation.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAuthorityNotified rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority Notified' ;
    rdfs:comment 'Regulatory or accident investigation authority that was notified of this investigation. NTSB (US National Transportation Safety Board), AAIB (UK Air Accidents Investigation Branch), BEA (French Bureau of Enquiry and Analysis), TSB (Transportation Safety Board of Canada), JTSB (Japan Transport Safety Board), or national AIB. [ENUM-REF-CANDIDATE: NTSB|AAIB|BEA|EASA|FAA|TSB|JTSB|national-AIB|none — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryNotificationStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Status' ;
    rdfs:comment 'Status of regulatory authority notification: not-required (internal investigation only), pending (notification required but not yet sent), notified (authority has been informed), acknowledged (authority confirmed receipt), under-review (authority is actively reviewing).' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportReference rdf:type rdf:Property ;
    rdfs:label 'Report Reference' ;
    rdfs:comment 'Reference identifier or document management system link to the formal investigation report, including preliminary, interim, and final reports.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskAssessmentUpdated rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Updated' ;
    rdfs:comment 'Indicates whether the SMS risk assessment was updated based on the findings of this investigation. True if risk matrices or risk registers were revised.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:safetyRecommendationsIssued rdf:type rdf:Property ;
    rdfs:label 'Safety Recommendations Issued' ;
    rdfs:comment 'Detailed list of safety recommendations issued as a result of the investigation findings. Recommendations may address procedural changes, training enhancements, equipment modifications, or policy updates.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:witnessStatementsCollected rdf:type rdf:Property ;
    rdfs:label 'Witness Statements Collected' ;
    rdfs:comment 'Indicates whether witness statements from crew, passengers, ground personnel, or other parties were collected and documented as part of the investigation.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:actualAltitudeFt rdf:type rdf:Property ;
    rdfs:label 'Actual Altitude Ft' ;
    rdfs:comment 'Actual altitude in feet flown during an airspace deviation occurrence. Populated only for airspace_deviation subtype.' ;
    rdfs:domain ind:Occurrence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:aircraftDamageLevel rdf:type rdf:Property ;
    rdfs:label 'Aircraft Damage Level' ;
    rdfs:comment 'Extent of damage sustained by the aircraft: destroyed (total loss), substantial (major structural damage affecting airworthiness), minor (cosmetic or repairable without affecting airworthiness), or none.' ;
    rdfs:domain ind:Occurrence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classification rdf:type rdf:Property ;
    rdfs:label 'Classification' ;
    rdfs:comment 'Primary classification of the safety event per ICAO Annex 13 definitions: accident (fatal or substantial damage), serious incident (near-accident), incident (safety concern), or occurrence (reportable event).' ;
    rdfs:domain ind:Occurrence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearedAltitudeFt rdf:type rdf:Property ;
    rdfs:label 'Cleared Altitude Ft' ;
    rdfs:comment 'ATC-cleared altitude in feet for an airspace deviation occurrence. Populated only for airspace_deviation subtype.' ;
    rdfs:domain ind:Occurrence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dangerousGoodsUnNumber rdf:type rdf:Property ;
    rdfs:label 'Dangerous Goods Un Number' ;
    rdfs:comment 'United Nations identification number for dangerous goods involved in a dangerous goods incident (e.g., UN1950 for aerosols). Populated only for dangerous_goods_incident subtype.' ;
    rdfs:domain ind:Occurrence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fatalitiesCount rdf:type rdf:Property ;
    rdfs:label 'Fatalities Count' ;
    rdfs:comment 'Total number of fatalities resulting from the occurrence (passengers, crew, and ground personnel).' ;
    rdfs:domain ind:Occurrence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:initialCausalFactors rdf:type rdf:Property ;
    rdfs:label 'Initial Causal Factors' ;
    rdfs:comment 'Preliminary assessment of contributing or causal factors identified during initial occurrence reporting. Subject to revision during formal investigation.' ;
    rdfs:domain ind:Occurrence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:injurySeverity rdf:type rdf:Property ;
    rdfs:label 'Injury Severity' ;
    rdfs:comment 'Highest level of injury sustained by any person involved in the occurrence (fatal, serious, minor, none) per ICAO definitions.' ;
    rdfs:domain ind:Occurrence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:location rdf:type rdf:Property ;
    rdfs:label 'Location' ;
    rdfs:comment 'Textual description of the geographic location where the occurrence took place (airport name, airspace sector, coordinates, or nearest landmark).' ;
    rdfs:domain ind:Occurrence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minorInjuriesCount rdf:type rdf:Property ;
    rdfs:label 'Minor Injuries Count' ;
    rdfs:comment 'Total number of persons who sustained minor injuries not meeting the serious injury threshold.' ;
    rdfs:domain ind:Occurrence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:narrativeDescription rdf:type rdf:Property ;
    rdfs:label 'Narrative Description' ;
    rdfs:comment 'Detailed free-text narrative describing the sequence of events, circumstances, and conditions surrounding the occurrence. Captures initial reporter observations and factual account.' ;
    rdfs:domain ind:Occurrence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:occurrenceDate rdf:type rdf:Property ;
    rdfs:label 'Occurrence Date' ;
    rdfs:comment 'Date on which the safety occurrence took place (UTC).' ;
    rdfs:domain ind:Occurrence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:occurrenceNumber rdf:type rdf:Property ;
    rdfs:label 'Occurrence Number' ;
    rdfs:comment 'Externally-known unique reference number assigned to the occurrence for tracking and regulatory reporting. Format varies by airline SMS system.' ;
    rdfs:domain ind:Occurrence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:occurrenceTimestamp rdf:type rdf:Property ;
    rdfs:label 'Occurrence Timestamp' ;
    rdfs:comment 'Precise date and time (UTC) when the safety occurrence event happened. Principal business event timestamp.' ;
    rdfs:domain ind:Occurrence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:packagingFailureDescription rdf:type rdf:Property ;
    rdfs:label 'Packaging Failure Description' ;
    rdfs:comment 'Description of packaging failure or non-compliance that led to a dangerous goods incident. Populated only for dangerous_goods_incident subtype.' ;
    rdfs:domain ind:Occurrence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reporterName rdf:type rdf:Property ;
    rdfs:label 'Reporter Name' ;
    rdfs:comment 'Name of the individual who reported the occurrence. Confidential to encourage just culture reporting per SMS principles.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingSource rdf:type rdf:Property ;
    rdfs:label 'Reporting Source' ;
    rdfs:comment 'Source or role of the individual or system that initially reported the occurrence (crew, maintenance, ground staff, ATC, passenger, external party, automated system). [ENUM-REF-CANDIDATE: crew|maintenance|ground_staff|atc|passenger|external|automated_system — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Occurrence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runwayDesignator rdf:type rdf:Property ;
    rdfs:label 'Runway Designator' ;
    rdfs:comment 'Runway identifier involved in a runway incursion occurrence (e.g., 27L, 09R, 33). Populated only for runway_incursion subtype.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runwayIncursionSeverity rdf:type rdf:Property ;
    rdfs:label 'Runway Incursion Severity' ;
    rdfs:comment 'FAA/ICAO severity classification for runway incursion: A (extreme risk of collision), B (significant potential for collision), C (ample time to avoid collision), D (little or no chance of collision). Populated only for runway_incursion subtype.' ;
    rdfs:domain ind:Occurrence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seriousInjuriesCount rdf:type rdf:Property ;
    rdfs:label 'Serious Injuries Count' ;
    rdfs:comment 'Total number of persons who sustained serious injuries as defined by ICAO Annex 13 (hospitalization >48 hours, fractures, severe burns, etc.).' ;
    rdfs:domain ind:Occurrence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:subtype rdf:type rdf:Property ;
    rdfs:label 'Subtype' ;
    rdfs:comment 'Detailed subtype classification for the occurrence enabling subtype-specific attribute capture (wildlife strike, runway incursion, airspace deviation, dangerous goods incident, CFIT, loss of control, turbulence encounter, ground collision, fuel emergency, cabin safety, other). [ENUM-REF-CANDIDATE: wildlife_strike|runway_incursion|airspace_deviation|dangerous_goods_incident|cfit|loss_of_control|turbulence_encounter|ground_collision|fuel_emergency|cabin_safety|other — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Occurrence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wildlifeIngestionFlag rdf:type rdf:Property ;
    rdfs:label 'Wildlife Ingestion Flag' ;
    rdfs:comment 'Indicates whether wildlife was ingested into an engine during a wildlife strike. Populated only for wildlife_strike subtype.' ;
    rdfs:domain ind:Occurrence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:wildlifeSpecies rdf:type rdf:Property ;
    rdfs:label 'Wildlife Species' ;
    rdfs:comment 'Species of wildlife involved in a wildlife strike occurrence (bird species, mammal, reptile). Populated only for wildlife_strike subtype.' ;
    rdfs:domain ind:Occurrence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wildlifeStrikeLocation rdf:type rdf:Property ;
    rdfs:label 'Wildlife Strike Location' ;
    rdfs:comment 'Aircraft component or area struck by wildlife (engine, nose, windshield, wing, fuselage, landing gear). Populated only for wildlife_strike subtype.' ;
    rdfs:domain ind:Occurrence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceIndicatorId rdf:type rdf:Property ;
    rdfs:label 'Performance Indicator Id' ;
    rdfs:comment 'Unique identifier for the safety performance indicator definition. Primary key.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PerformanceIndicator .

ind:aggregationMethod rdf:type rdf:Property ;
    rdfs:label 'Aggregation Method' ;
    rdfs:comment 'The statistical method used to aggregate raw data into the indicator value (e.g., sum, average, count, rate, percentage, maximum, minimum). [ENUM-REF-CANDIDATE: sum|average|count|rate|percentage|maximum|minimum — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PerformanceIndicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benchmarkSource rdf:type rdf:Property ;
    rdfs:label 'Benchmark Source' ;
    rdfs:comment 'Identifies the external benchmark or industry standard used for comparison (e.g., IATA Safety Report, peer airline group average, regional safety statistics). Null if no external benchmark is used.' ;
    rdfs:domain ind:PerformanceIndicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:easaAlignmentFlag rdf:type rdf:Property ;
    rdfs:label 'Easa Alignment Flag' ;
    rdfs:comment 'Boolean flag indicating whether this indicator is explicitly aligned with EASA Part-ORO SMS requirements (True) or not (False).' ;
    rdfs:domain ind:PerformanceIndicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:faaAlignmentFlag rdf:type rdf:Property ;
    rdfs:label 'Faa Alignment Flag' ;
    rdfs:comment 'Boolean flag indicating whether this indicator is explicitly aligned with FAA SMS requirements and guidance (True) or not (False).' ;
    rdfs:domain ind:PerformanceIndicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:icaoAlignmentFlag rdf:type rdf:Property ;
    rdfs:label 'Icao Alignment Flag' ;
    rdfs:comment 'Boolean flag indicating whether this indicator is explicitly aligned with ICAO Annex 19 SMS framework requirements (True) or is an airline-specific custom indicator (False).' ;
    rdfs:domain ind:PerformanceIndicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:indicatorCategory rdf:type rdf:Property ;
    rdfs:label 'Indicator Category' ;
    rdfs:comment 'Classification of the indicator as either leading (predictive, proactive measures such as safety audits completed or training compliance) or lagging (reactive, outcome-based measures such as accident rate or incidents reported).' ;
    rdfs:domain ind:PerformanceIndicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indicatorCode rdf:type rdf:Property ;
    rdfs:label 'Indicator Code' ;
    rdfs:comment 'Unique alphanumeric code assigned to the safety performance indicator for reference and reporting purposes. Typically follows organizational coding standards (e.g., SFT-001, OPS-1234).' ;
    rdfs:domain ind:PerformanceIndicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indicatorDescription rdf:type rdf:Property ;
    rdfs:label 'Indicator Description' ;
    rdfs:comment 'Detailed explanation of what the indicator measures, its purpose within the SMS, and how it contributes to safety oversight and risk management.' ;
    rdfs:domain ind:PerformanceIndicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indicatorName rdf:type rdf:Property ;
    rdfs:label 'Indicator Name' ;
    rdfs:comment 'Full descriptive name of the safety performance indicator as used in safety management reporting and dashboards.' ;
    rdfs:domain ind:PerformanceIndicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:indicatorStatus rdf:type rdf:Property ;
    rdfs:label 'Indicator Status' ;
    rdfs:comment 'Current lifecycle status of the indicator definition. Active indicators are in use for monitoring; inactive indicators are temporarily suspended; under_review indicators are being evaluated for changes; retired indicators are no longer used.' ;
    rdfs:domain ind:PerformanceIndicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementFrequency rdf:type rdf:Property ;
    rdfs:label 'Measurement Frequency' ;
    rdfs:comment 'The frequency at which the indicator is measured and reported (e.g., daily, weekly, monthly, quarterly, annually, or real-time for continuous monitoring).' ;
    rdfs:domain ind:PerformanceIndicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementUnit rdf:type rdf:Property ;
    rdfs:label 'Measurement Unit' ;
    rdfs:comment 'Unit of measure for the indicator value (e.g., count, percentage, rate per 100,000 flight hours, days, hours). Defines how the indicator is quantified.' ;
    rdfs:domain ind:PerformanceIndicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingLevel rdf:type rdf:Property ;
    rdfs:label 'Reporting Level' ;
    rdfs:comment 'Classification of the organizational level at which this indicator is primarily reported and monitored (operational for front-line teams, tactical for department managers, strategic for senior leadership, executive for board and accountable executive).' ;
    rdfs:domain ind:PerformanceIndicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetValue rdf:type rdf:Property ;
    rdfs:label 'Target Value' ;
    rdfs:comment 'The target or goal value set for this indicator as part of the Safety Performance Target (SPT) framework. Represents the desired performance level the organization aims to achieve.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trendAnalysisEnabled rdf:type rdf:Property ;
    rdfs:label 'Trend Analysis Enabled' ;
    rdfs:comment 'Boolean flag indicating whether trend analysis and statistical process control are enabled for this indicator (True) or if it is monitored as a point-in-time value only (False).' ;
    rdfs:domain ind:PerformanceIndicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:warningThreshold rdf:type rdf:Property ;
    rdfs:label 'Warning Threshold' ;
    rdfs:comment 'The threshold value at which a warning is issued, indicating that the indicator is approaching an unacceptable level and requires monitoring and potential intervention.' ;
    rdfs:domain ind:PerformanceIndicator ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceAuditId rdf:type rdf:Property ;
    rdfs:label 'Source Audit Id' ;
    rdfs:comment 'Reference to the safety audit or inspection that generated this recommendation, if applicable. Links to audit record in safety management system.' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Audit .

ind:sourceInvestigationId rdf:type rdf:Property ;
    rdfs:label 'Source Investigation Id' ;
    rdfs:comment 'Reference to the accident or incident investigation that generated this recommendation, if applicable. Links to investigation record in safety management system.' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Investigation .

ind:sourceOccurrenceId rdf:type rdf:Property ;
    rdfs:label 'Source Occurrence Id' ;
    rdfs:comment 'Reference to the safety occurrence or event that triggered this recommendation, if applicable. Links to occurrence reporting system.' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Occurrence .

ind:actualImplementationDate rdf:type rdf:Property ;
    rdfs:label 'Actual Implementation Date' ;
    rdfs:comment 'Actual date when the recommended action was fully implemented and verified.' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:addresseeDepartment rdf:type rdf:Property ;
    rdfs:label 'Addressee Department' ;
    rdfs:comment 'Internal department or organizational unit responsible for responding to and implementing the recommendation (e.g., Flight Operations, Maintenance, Training, Ground Operations).' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addresseeExternalOrganization rdf:type rdf:Property ;
    rdfs:label 'Addressee External Organization' ;
    rdfs:comment 'External organization or regulatory authority to whom the recommendation is addressed, if applicable (e.g., FAA, EASA, aircraft manufacturer, airport authority).' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureVerificationMethod rdf:type rdf:Property ;
    rdfs:label 'Closure Verification Method' ;
    rdfs:comment 'Method used to verify that the recommendation has been effectively implemented (e.g., audit, inspection, documentation review, operational monitoring, SMS assessment).' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureVerifiedBy rdf:type rdf:Property ;
    rdfs:label 'Closure Verified By' ;
    rdfs:comment 'Name or role of the individual or body that verified and approved closure of the recommendation (e.g., Safety Manager, SMS Committee, external auditor).' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivenessAssessment rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Assessment' ;
    rdfs:comment 'Narrative assessment of the effectiveness of the implemented recommendation in achieving its intended safety improvement, based on operational data and monitoring.' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedImplementationCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Implementation Cost' ;
    rdfs:comment 'Estimated financial cost to implement the recommendation, including capital expenditure, operational changes, training, and ongoing costs. Used for resource planning and cost-benefit analysis.' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:implementationActionPlan rdf:type rdf:Property ;
    rdfs:label 'Implementation Action Plan' ;
    rdfs:comment 'Detailed description of the corrective actions, procedural changes, or system modifications planned or executed to implement the recommendation.' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingAuthorityCode rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority Code' ;
    rdfs:comment 'Standardized code for the issuing authority (e.g., NTSB for National Transportation Safety Board, AAIB for Air Accidents Investigation Branch, FAA for Federal Aviation Administration, EASA for European Union Aviation Safety Agency).' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendationStatus rdf:type rdf:Property ;
    rdfs:label 'Recommendation Status' ;
    rdfs:comment 'Current lifecycle status of the safety recommendation: open (newly issued), under_review (being evaluated), accepted (approved for action), in_progress (implementation underway), implemented (action completed), closed (verified and closed), rejected (not accepted with justification), or superseded (replaced by newer recommendation). [ENUM-REF-CANDIDATE: open|under_review|accepted|in_progress|implemented|closed|rejected|superseded — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendationText rdf:type rdf:Property ;
    rdfs:label 'Recommendation Text' ;
    rdfs:comment 'Full text of the safety recommendation as issued, describing the specific action or change recommended to improve safety.' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendationType rdf:type rdf:Property ;
    rdfs:label 'Recommendation Type' ;
    rdfs:comment 'Classification of the recommendation based on its origin: internal (generated by airline), external_received (from national AIB or other authority), regulatory_mandate (required by regulator), audit_finding (from safety audit), proactive_study (from safety analysis), or sms_output (from SMS process).' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionJustification rdf:type rdf:Property ;
    rdfs:label 'Rejection Justification' ;
    rdfs:comment 'Detailed justification provided when a recommendation is rejected, including technical, operational, or economic rationale and alternative mitigations if applicable.' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relatedSopReference rdf:type rdf:Property ;
    rdfs:label 'Related Sop Reference' ;
    rdfs:comment 'Reference number or identifier of the SOP that was revised or created as a result of implementing this recommendation.' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseDueDate rdf:type rdf:Property ;
    rdfs:label 'Response Due Date' ;
    rdfs:comment 'Date by which a formal response to the recommendation is required, particularly for external recommendations from regulatory authorities or AIBs.' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responseNarrative rdf:type rdf:Property ;
    rdfs:label 'Response Narrative' ;
    rdfs:comment 'Detailed narrative of the airline\'s response to the recommendation, including acceptance rationale, implementation plan, or justification for rejection.' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseSubmittedDate rdf:type rdf:Property ;
    rdfs:label 'Response Submitted Date' ;
    rdfs:comment 'Date when the formal response to the recommendation was submitted to the issuing authority.' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responsiblePersonRole rdf:type rdf:Property ;
    rdfs:label 'Responsible Person Role' ;
    rdfs:comment 'Job title or role of the individual responsible for the recommendation (e.g., Chief Pilot, Director of Safety, Maintenance Manager, Training Manager).' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyRiskCategory rdf:type rdf:Property ;
    rdfs:label 'Safety Risk Category' ;
    rdfs:comment 'Classification of the safety risk addressed by this recommendation (e.g., flight operations, maintenance, ground handling, crew fatigue, airworthiness, ATC coordination).' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:summary rdf:type rdf:Property ;
    rdfs:label 'Summary' ;
    rdfs:comment 'Brief executive summary or title of the recommendation for quick reference and reporting purposes.' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetImplementationDate rdf:type rdf:Property ;
    rdfs:label 'Target Implementation Date' ;
    rdfs:comment 'Target or required date by which the recommendation should be implemented. May be mandated by regulator or set internally based on risk assessment.' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportId rdf:type rdf:Property ;
    rdfs:label 'Report Id' ;
    rdfs:comment 'Unique identifier for the safety report or alert. Primary key.' ;
    rdfs:domain ind:Report ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reporterEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Reporter Employee Id' ;
    rdfs:comment 'Internal employee identifier of the person who submitted the safety report. May be null for confidential/anonymous reports to support Just Culture principles.' ;
    rdfs:domain ind:Report ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:affectedAircraftTypes rdf:type rdf:Property ;
    rdfs:label 'Affected Aircraft Types' ;
    rdfs:comment 'Comma-separated list of aircraft type codes affected by the safety alert or bulletin.' ;
    rdfs:domain ind:Report ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deIdentificationFlag rdf:type rdf:Property ;
    rdfs:label 'De Identification Flag' ;
    rdfs:comment 'Indicates whether personally identifiable information has been removed from the report to protect reporter identity under Just Culture principles. True/False.' ;
    rdfs:domain ind:Report ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:distributionStatus rdf:type rdf:Property ;
    rdfs:label 'Distribution Status' ;
    rdfs:comment 'Status of distribution of the safety alert or bulletin to relevant personnel and departments.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:narrative rdf:type rdf:Property ;
    rdfs:label 'Narrative' ;
    rdfs:comment 'Detailed free-text narrative describing the safety event, circumstances, and observations. May be de-identified for confidential reports.' ;
    rdfs:domain ind:Report ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryNotificationFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Flag' ;
    rdfs:comment 'Indicates whether the safety event was reported to external regulatory authorities (FAA, EASA, etc.). True/False.' ;
    rdfs:domain ind:Report ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reporterRole rdf:type rdf:Property ;
    rdfs:label 'Reporter Role' ;
    rdfs:comment 'Functional role of the person who submitted the safety report.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryRiskAssessorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Risk Assessor Employee Id' ;
    rdfs:comment 'Reference to the employee who conducted the risk assessment. Must be a qualified safety professional or designated assessor within the SMS organization.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:reviewerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Reviewer Employee Id' ;
    rdfs:comment 'Reference to the employee who reviewed and approved the risk assessment. Typically a senior safety manager or accountable executive. Nullable if assessment not yet reviewed.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assessmentNarrative rdf:type rdf:Property ;
    rdfs:label 'Assessment Narrative' ;
    rdfs:comment 'Detailed textual justification for the likelihood and severity scores assigned, including rationale, assumptions, data sources, and expert judgment applied. Critical for audit trail and knowledge transfer.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentNumber rdf:type rdf:Property ;
    rdfs:label 'Assessment Number' ;
    rdfs:comment 'Business-facing unique identifier for the risk assessment, typically formatted as RA-YYYYNNNNNN for external reference and audit trails.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessorName rdf:type rdf:Property ;
    rdfs:label 'Assessor Name' ;
    rdfs:comment 'Full name of the individual who performed the risk assessment, captured for audit and accountability purposes.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSources rdf:type rdf:Property ;
    rdfs:label 'Data Sources' ;
    rdfs:comment 'List of data sources, evidence, and references used to inform the risk assessment (e.g., FDR/CVR analysis, incident reports, maintenance records, industry safety bulletins, statistical data). Supports traceability and repeatability.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:existingControlsSummary rdf:type rdf:Property ;
    rdfs:label 'Existing Controls Summary' ;
    rdfs:comment 'Summary of current risk mitigation controls, barriers, and defenses already in place at the time of assessment. Used to distinguish initial vs residual risk.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:likelihoodScore rdf:type rdf:Property ;
    rdfs:label 'Likelihood Score' ;
    rdfs:comment 'Probability rating of the hazard occurring, scored on the ICAO 1-5 scale where 1=Extremely Improbable, 2=Improbable, 3=Remote, 4=Occasional, 5=Frequent. Used to calculate risk index.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:notificationReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Notification Reference Number' ;
    rdfs:comment 'Official reference number or tracking identifier assigned by the regulatory authority upon receipt of the risk assessment notification. Used for compliance audit trails.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendedActions rdf:type rdf:Property ;
    rdfs:label 'Recommended Actions' ;
    rdfs:comment 'Proposed corrective actions, additional controls, or risk treatments recommended by the assessor to reduce risk to an acceptable level. May link to formal corrective action plans.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAuthorityNotifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority Notified Flag' ;
    rdfs:comment 'Indicates whether the risk assessment and associated hazard were reported to the national civil aviation authority (e.g., FAA, EASA) as required for high-severity or intolerable risks.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewComments rdf:type rdf:Property ;
    rdfs:label 'Review Comments' ;
    rdfs:comment 'Feedback, observations, or directives provided by the reviewer during the approval process. May include requests for additional analysis or clarification.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskCategory rdf:type rdf:Property ;
    rdfs:label 'Risk Category' ;
    rdfs:comment 'High-level classification of the risk domain. Operational = flight operations and procedures; Technical = aircraft systems and equipment; Organizational = management and processes; Environmental = weather and external conditions; Human Factors = crew performance and fatigue; Security = intentional threats.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskIndex rdf:type rdf:Property ;
    rdfs:label 'Risk Index' ;
    rdfs:comment 'Calculated risk score derived from likelihood and severity scores, typically computed as likelihood × severity. Range 1-25 on ICAO matrix. Determines risk tolerance classification.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:riskMatrixQuadrant rdf:type rdf:Property ;
    rdfs:label 'Risk Matrix Quadrant' ;
    rdfs:comment 'Visual position on the 5×5 ICAO risk matrix, typically expressed as coordinate notation (e.g., L3S4) or color-coded zone (green/yellow/amber/red). Used for dashboard visualization and executive reporting.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskToleranceLevel rdf:type rdf:Property ;
    rdfs:label 'Risk Tolerance Level' ;
    rdfs:comment 'Management decision on acceptability of the assessed risk. Acceptable = no further action required; Tolerable = acceptable with mitigation and monitoring; Intolerable = unacceptable, immediate action required. Aligns with ALARP (As Low As Reasonably Practicable) principle.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severityScore rdf:type rdf:Property ;
    rdfs:label 'Severity Score' ;
    rdfs:comment 'Consequence rating of the hazard if it occurs, scored on the ICAO 1-5 scale where 1=Negligible, 2=Minor, 3=Major, 4=Hazardous, 5=Catastrophic. Used to calculate risk index.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:atcClearanceStatus rdf:type rdf:Property ;
    rdfs:label 'Atc Clearance Status' ;
    rdfs:comment 'Whether the entity involved had proper ATC clearance to enter the runway area at the time of the incursion.' ;
    rdfs:domain ind:RunwayIncursion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:atcInstruction rdf:type rdf:Property ;
    rdfs:label 'Atc Instruction' ;
    rdfs:comment 'The specific ATC instruction or clearance that was active at the time of the incursion, if available from voice recordings or transcripts.' ;
    rdfs:domain ind:RunwayIncursion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collisionAvoidanceAction rdf:type rdf:Property ;
    rdfs:label 'Collision Avoidance Action' ;
    rdfs:comment 'Description of any evasive action taken to avoid collision (e.g., rejected takeoff, go-around, emergency braking, evasive steering).' ;
    rdfs:domain ind:RunwayIncursion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contributingFactorCommunication rdf:type rdf:Property ;
    rdfs:label 'Contributing Factor Communication' ;
    rdfs:comment 'Flag indicating whether communication issues (misunderstood clearance, readback error, language barrier, radio congestion) contributed to the runway incursion.' ;
    rdfs:domain ind:RunwayIncursion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contributingFactorLighting rdf:type rdf:Property ;
    rdfs:label 'Contributing Factor Lighting' ;
    rdfs:comment 'Flag indicating whether inadequate or inoperative runway/taxiway lighting contributed to the runway incursion.' ;
    rdfs:domain ind:RunwayIncursion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contributingFactorProcedures rdf:type rdf:Property ;
    rdfs:label 'Contributing Factor Procedures' ;
    rdfs:comment 'Flag indicating whether inadequate or non-compliance with standard operating procedures contributed to the runway incursion.' ;
    rdfs:domain ind:RunwayIncursion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contributingFactorSignage rdf:type rdf:Property ;
    rdfs:label 'Contributing Factor Signage' ;
    rdfs:comment 'Flag indicating whether inadequate, missing, or confusing airport signage contributed to the runway incursion.' ;
    rdfs:domain ind:RunwayIncursion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contributingFactorSituationalAwareness rdf:type rdf:Property ;
    rdfs:label 'Contributing Factor Situational Awareness' ;
    rdfs:comment 'Flag indicating whether loss of situational awareness (disorientation, confusion about position, distraction) contributed to the runway incursion.' ;
    rdfs:domain ind:RunwayIncursion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contributingFactorTraining rdf:type rdf:Property ;
    rdfs:label 'Contributing Factor Training' ;
    rdfs:comment 'Flag indicating whether inadequate training or lack of familiarity with airport layout contributed to the runway incursion.' ;
    rdfs:domain ind:RunwayIncursion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incursionCategory rdf:type rdf:Property ;
    rdfs:label 'Incursion Category' ;
    rdfs:comment 'ICAO severity classification of the runway incursion: A (serious incident with collision narrowly avoided), B (significant potential for collision), C (ample time/distance to avoid collision), D (little or no chance of collision).' ;
    rdfs:domain ind:RunwayIncursion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incursionType rdf:type rdf:Property ;
    rdfs:label 'Incursion Type' ;
    rdfs:comment 'Type of entity that entered the protected runway area: aircraft, vehicle, pedestrian, or mixed (multiple types).' ;
    rdfs:domain ind:RunwayIncursion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigatorNotes rdf:type rdf:Property ;
    rdfs:label 'Investigator Notes' ;
    rdfs:comment 'Additional notes and observations recorded by the safety investigator during the runway incursion investigation.' ;
    rdfs:domain ind:RunwayIncursion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:separationDistanceMeters rdf:type rdf:Property ;
    rdfs:label 'Separation Distance Meters' ;
    rdfs:comment 'Minimum separation distance in meters between the incurring entity and other aircraft or vehicles on the runway at the closest point of approach.' ;
    rdfs:domain ind:RunwayIncursion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:timeOfDay rdf:type rdf:Property ;
    rdfs:label 'Time Of Day' ;
    rdfs:comment 'Lighting conditions at the time of the incursion: day, night, dawn, or dusk.' ;
    rdfs:domain ind:RunwayIncursion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleOperator rdf:type rdf:Property ;
    rdfs:label 'Vehicle Operator' ;
    rdfs:comment 'Organization or department operating the vehicle involved in the runway incursion (e.g., airline ground handling, airport operations, third-party contractor).' ;
    rdfs:domain ind:RunwayIncursion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vehicleType rdf:type rdf:Property ;
    rdfs:label 'Vehicle Type' ;
    rdfs:comment 'Type of ground vehicle involved in the runway incursion (e.g., fuel truck, catering vehicle, maintenance vehicle, snow removal equipment), if applicable.' ;
    rdfs:domain ind:RunwayIncursion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spiMeasurementId rdf:type rdf:Property ;
    rdfs:label 'Spi Measurement Id' ;
    rdfs:comment 'Unique identifier for the SPI measurement record. Primary key.' ;
    rdfs:domain ind:SpiMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primarySpiEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Spi Employee Id' ;
    rdfs:comment 'Reference to the safety analyst or employee responsible for recording and validating this SPI measurement.' ;
    rdfs:domain ind:SpiMeasurement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:alertThresholdBreachedFlag rdf:type rdf:Property ;
    rdfs:label 'Alert Threshold Breached Flag' ;
    rdfs:comment 'Boolean flag indicating whether the actual value breached the alert threshold for this measurement period. True indicates breach requiring immediate action.' ;
    rdfs:domain ind:SpiMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:alertThresholdValue rdf:type rdf:Property ;
    rdfs:label 'Alert Threshold Value' ;
    rdfs:comment 'The alert threshold value for this SPI. When actual value crosses this threshold, it triggers an alert requiring immediate action.' ;
    rdfs:domain ind:SpiMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementDate rdf:type rdf:Property ;
    rdfs:label 'Measurement Date' ;
    rdfs:comment 'The date when the SPI measurement was recorded or calculated. Represents the business event timestamp for this measurement.' ;
    rdfs:domain ind:SpiMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measurementMethod rdf:type rdf:Property ;
    rdfs:label 'Measurement Method' ;
    rdfs:comment 'The method used to collect or calculate this SPI measurement (automated system, manual data entry, hybrid, calculated from other metrics).' ;
    rdfs:domain ind:SpiMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementNotes rdf:type rdf:Property ;
    rdfs:label 'Measurement Notes' ;
    rdfs:comment 'Free-text notes providing additional context, explanations, or observations about this SPI measurement. May include reasons for anomalies or data quality issues.' ;
    rdfs:domain ind:SpiMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementStatus rdf:type rdf:Property ;
    rdfs:label 'Measurement Status' ;
    rdfs:comment 'The current lifecycle status of this SPI measurement record (draft, submitted for review, reviewed, approved, published).' ;
    rdfs:domain ind:SpiMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportingRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Required Flag' ;
    rdfs:comment 'Boolean flag indicating whether this SPI measurement must be reported to regulatory authorities (FAA, EASA, national CAA).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportingPeriodMonth rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Month' ;
    rdfs:comment 'The calendar month (1-12) of the measurement period. Used for monthly aggregation and trend analysis.' ;
    rdfs:domain ind:SpiMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reportingPeriodQuarter rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Quarter' ;
    rdfs:comment 'The calendar quarter (1-4) of the measurement period. Used for quarterly aggregation and trend analysis.' ;
    rdfs:domain ind:SpiMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reportingPeriodYear rdf:type rdf:Property ;
    rdfs:label 'Reporting Period Year' ;
    rdfs:comment 'The calendar year of the measurement period. Used for annual aggregation and regulatory reporting.' ;
    rdfs:domain ind:SpiMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetMetFlag rdf:type rdf:Property ;
    rdfs:label 'Target Met Flag' ;
    rdfs:comment 'Boolean flag indicating whether the actual value met or exceeded the target value for this measurement period.' ;
    rdfs:domain ind:SpiMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trendDirection rdf:type rdf:Property ;
    rdfs:label 'Trend Direction' ;
    rdfs:comment 'The trend direction of the SPI compared to previous measurement periods (improving, stable, deteriorating, insufficient data).' ;
    rdfs:domain ind:SpiMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:varianceFromTarget rdf:type rdf:Property ;
    rdfs:label 'Variance From Target' ;
    rdfs:comment 'The calculated variance between actual value and target value. Positive indicates performance above target, negative indicates below target.' ;
    rdfs:domain ind:SpiMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:variancePercentage rdf:type rdf:Property ;
    rdfs:label 'Variance Percentage' ;
    rdfs:comment 'The variance from target expressed as a percentage. Calculated as ((actual - target) / target) * 100.' ;
    rdfs:domain ind:SpiMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warningThresholdBreachedFlag rdf:type rdf:Property ;
    rdfs:label 'Warning Threshold Breached Flag' ;
    rdfs:comment 'Boolean flag indicating whether the actual value breached the warning threshold for this measurement period. True indicates breach requiring attention.' ;
    rdfs:domain ind:SpiMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:warningThresholdValue rdf:type rdf:Property ;
    rdfs:label 'Warning Threshold Value' ;
    rdfs:comment 'The warning threshold value for this SPI. When actual value crosses this threshold, it triggers a warning requiring attention.' ;
    rdfs:domain ind:SpiMeasurement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:aircraftOutOfServiceHours rdf:type rdf:Property ;
    rdfs:label 'Aircraft Out Of Service Hours' ;
    rdfs:comment 'The total number of hours the aircraft was out of service due to the wildlife strike, including inspection, repair, and testing time.' ;
    rdfs:domain ind:WildlifeStrike ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:aircraftPartStruck rdf:type rdf:Property ;
    rdfs:label 'Aircraft Part Struck' ;
    rdfs:comment 'The specific part or component of the aircraft that was struck by the wildlife. [ENUM-REF-CANDIDATE: engine|windshield|radome|nose|wing|fuselage|landing_gear|tail|propeller|rotor|other|unknown — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WildlifeStrike ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:damageLevel rdf:type rdf:Property ;
    rdfs:label 'Damage Level' ;
    rdfs:comment 'The severity level of damage sustained by the aircraft as a result of the wildlife strike, following FAA damage classification standards.' ;
    rdfs:domain ind:WildlifeStrike ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectOnFlight rdf:type rdf:Property ;
    rdfs:label 'Effect On Flight' ;
    rdfs:comment 'The operational impact of the wildlife strike on the flight, including any immediate actions taken by the crew.' ;
    rdfs:domain ind:WildlifeStrike ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engineIngestionFlag rdf:type rdf:Property ;
    rdfs:label 'Engine Ingestion Flag' ;
    rdfs:comment 'Indicates whether the wildlife was ingested into one or more aircraft engines. True if ingestion occurred, False otherwise.' ;
    rdfs:domain ind:WildlifeStrike ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:faaReportNumber rdf:type rdf:Property ;
    rdfs:label 'Faa Report Number' ;
    rdfs:comment 'The unique report number assigned by the FAA Wildlife Strike Database upon submission of the strike report.' ;
    rdfs:domain ind:WildlifeStrike ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icaoReportReference rdf:type rdf:Property ;
    rdfs:label 'Icao Report Reference' ;
    rdfs:comment 'The reference number or identifier for the wildlife strike report submitted to ICAO under Circular 107 reporting requirements.' ;
    rdfs:domain ind:WildlifeStrike ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pilotWarnedFlag rdf:type rdf:Property ;
    rdfs:label 'Pilot Warned Flag' ;
    rdfs:comment 'Indicates whether the pilot was warned of wildlife presence prior to the strike. True if warning was issued, False otherwise.' ;
    rdfs:domain ind:WildlifeStrike ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:precipitation rdf:type rdf:Property ;
    rdfs:label 'Precipitation' ;
    rdfs:comment 'The type of precipitation present at the time of the wildlife strike, if any.' ;
    rdfs:domain ind:WildlifeStrike ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remainsCollectedFlag rdf:type rdf:Property ;
    rdfs:label 'Remains Collected Flag' ;
    rdfs:comment 'Indicates whether wildlife remains were collected for species identification or analysis. True if collected, False otherwise.' ;
    rdfs:domain ind:WildlifeStrike ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remainsSentToLabFlag rdf:type rdf:Property ;
    rdfs:label 'Remains Sent To Lab Flag' ;
    rdfs:comment 'Indicates whether collected wildlife remains were sent to a laboratory for identification or forensic analysis. True if sent, False otherwise.' ;
    rdfs:domain ind:WildlifeStrike ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:repairHours rdf:type rdf:Property ;
    rdfs:label 'Repair Hours' ;
    rdfs:comment 'The total number of maintenance labor hours required to repair damage caused by the wildlife strike.' ;
    rdfs:domain ind:WildlifeStrike ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:skyCondition rdf:type rdf:Property ;
    rdfs:label 'Sky Condition' ;
    rdfs:comment 'The weather and sky conditions at the time of the wildlife strike.' ;
    rdfs:domain ind:WildlifeStrike ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:speciesIdentified rdf:type rdf:Property ;
    rdfs:label 'Species Identified' ;
    rdfs:comment 'The common or scientific name of the wildlife species involved in the strike, if identified. May be unknown if species could not be determined.' ;
    rdfs:domain ind:WildlifeStrike ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:speciesQuantity rdf:type rdf:Property ;
    rdfs:label 'Species Quantity' ;
    rdfs:comment 'The estimated number of wildlife individuals involved in the strike event.' ;
    rdfs:domain ind:WildlifeStrike ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:absenceRecordId rdf:type rdf:Property ;
    rdfs:label 'Absence Record Id' ;
    rdfs:comment 'Unique identifier for the absence record. Primary key.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:homeBaseStationId rdf:type rdf:Property ;
    rdfs:label 'Home Base Station Id' ;
    rdfs:comment 'Foreign key linking to airport.station. Business justification: Normalize absence home base location for crew availability analysis by station, replacement crew sourcing, and FDP impact assessment. Essential for operations control.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Station .

ind:primaryAbsenceEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Absence Employee Id' ;
    rdfs:comment 'Reference to the employee who is absent. Links to the employee master record.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryAbsenceReplacementEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Absence Replacement Employee Id' ;
    rdfs:comment 'Reference to the employee assigned to cover duties during this absence period. Nullable if no replacement assigned. Links to employee master record.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:unionAgreementId rdf:type rdf:Property ;
    rdfs:label 'Union Agreement Id' ;
    rdfs:comment 'Foreign key linking to workforce.union_agreement. Business justification: Absence record should reference the union agreement for leave policy compliance. The union_code is an attribute of union_agreement and should be retrieved via JOIN. This ensures absence records are go' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UnionAgreement .

ind:absenceCategory rdf:type rdf:Property ;
    rdfs:label 'Absence Category' ;
    rdfs:comment 'High-level categorization of the absence: planned (scheduled in advance, e.g., annual leave), unplanned (short-notice, e.g., sick leave), or emergency (immediate, e.g., family emergency, AOG crew replacement).' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:absenceReasonNotes rdf:type rdf:Property ;
    rdfs:label 'Absence Reason Notes' ;
    rdfs:comment 'Free-text notes providing additional context or reason for the absence. May contain sensitive information. Access restricted to HR and authorized managers.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:absenceTypeCode rdf:type rdf:Property ;
    rdfs:label 'Absence Type Code' ;
    rdfs:comment 'Code representing the type of absence (e.g., annual leave, sick leave, maternity leave, compassionate leave, training leave, unpaid leave, union leave, jury duty). Aligns with SAP Infotype 2001 absence type catalog.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:absenceTypeDescription rdf:type rdf:Property ;
    rdfs:label 'Absence Type Description' ;
    rdfs:comment 'Human-readable description of the absence type for reporting and display purposes.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crewAvailabilityImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Crew Availability Impact Flag' ;
    rdfs:comment 'Indicates whether this absence affects crew availability for scheduling purposes. True if the employee is unavailable for duty assignment during the absence period.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:durationHours rdf:type rdf:Property ;
    rdfs:label 'Duration Hours' ;
    rdfs:comment 'Total duration of the absence measured in hours. Used for partial-day absences and precise crew scheduling calculations.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fdpImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Fdp Impact Flag' ;
    rdfs:comment 'Indicates whether this absence impacts Flight Duty Period compliance calculations for flight crew. True if FDP-relevant (e.g., sick leave, fatigue-related absence), False otherwise. Critical for FAA/EASA crew rest compliance.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:medicalCertificateReceivedDate rdf:type rdf:Property ;
    rdfs:label 'Medical Certificate Received Date' ;
    rdfs:comment 'The date the medical certificate was received by HR or the relevant authority.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:medicalCertificateReceivedFlag rdf:type rdf:Property ;
    rdfs:label 'Medical Certificate Received Flag' ;
    rdfs:comment 'Indicates whether the required medical certificate has been received and validated. True if received, False otherwise.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:medicalCertificateRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Medical Certificate Required Flag' ;
    rdfs:comment 'Indicates whether a medical certificate is required for this absence (typically for sick leave exceeding a threshold duration). True if required, False otherwise.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:payImpactCode rdf:type rdf:Property ;
    rdfs:label 'Pay Impact Code' ;
    rdfs:comment 'Indicates the impact of the absence on employee pay: paid (full pay maintained), unpaid (no pay during absence), or partial (reduced pay per policy or union agreement).' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payPercentage rdf:type rdf:Property ;
    rdfs:label 'Pay Percentage' ;
    rdfs:comment 'Percentage of regular pay the employee receives during the absence period (0-100). Used for partial pay scenarios such as statutory sick pay or union-negotiated rates.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:returnToWorkConfirmedFlag rdf:type rdf:Property ;
    rdfs:label 'Return To Work Confirmed Flag' ;
    rdfs:comment 'Indicates whether the employees return to work has been confirmed by the manager or HR. True if confirmed, False otherwise.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:returnToWorkDate rdf:type rdf:Property ;
    rdfs:label 'Return To Work Date' ;
    rdfs:comment 'The actual date the employee returned to work following the absence. May differ from planned end date. Critical for crew availability and FDP compliance.' ;
    rdfs:domain ind:AbsenceRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:applicantId rdf:type rdf:Property ;
    rdfs:label 'Applicant Id' ;
    rdfs:comment 'Unique identifier for the applicant record. Primary key.' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicantRecruiterEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Applicant Recruiter Employee Id' ;
    rdfs:comment 'Employee identifier of the recruiter or HR specialist responsible for managing this application.' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:applicantReferralEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Applicant Referral Employee Id' ;
    rdfs:comment 'Employee identifier of the internal employee who referred this applicant, if applicable.' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:recruitmentRequisitionId rdf:type rdf:Property ;
    rdfs:label 'Recruitment Requisition Id' ;
    rdfs:comment 'Reference to the job requisition or vacancy posting that the applicant is applying for.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RecruitmentRequisition .

ind:alternatePhoneNumber rdf:type rdf:Property ;
    rdfs:label 'Alternate Phone Number' ;
    rdfs:comment 'Secondary contact phone number for the applicant, if provided.' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationNumber rdf:type rdf:Property ;
    rdfs:label 'Application Number' ;
    rdfs:comment 'Externally visible unique application reference number assigned when the candidate submits their application.' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aviationLicenceType rdf:type rdf:Property ;
    rdfs:label 'Aviation Licence Type' ;
    rdfs:comment 'Type of aviation licence held by the applicant, if applicable (ATPL - Airline Transport Pilot Licence, CPL - Commercial Pilot Licence, PPL - Private Pilot Licence, cabin crew, AME - Aircraft Maintenance Engineer, none).' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentEmployer rdf:type rdf:Property ;
    rdfs:label 'Current Employer' ;
    rdfs:comment 'Name of the applicant\'s current employer or most recent employer if unemployed.' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentJobTitle rdf:type rdf:Property ;
    rdfs:label 'Current Job Title' ;
    rdfs:comment 'Job title or role of the applicant at their current or most recent employer.' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataRetentionExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Data Retention Expiry Date' ;
    rdfs:comment 'Date when the applicant\'s personal data must be deleted or anonymized per GDPR data retention policies.' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:expectedStartDate rdf:type rdf:Property ;
    rdfs:label 'Expected Start Date' ;
    rdfs:comment 'Expected or agreed date when the applicant will commence employment if hired.' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gdprConsentDate rdf:type rdf:Property ;
    rdfs:label 'Gdpr Consent Date' ;
    rdfs:comment 'Date when the applicant provided GDPR consent for data processing.' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gdprConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Gdpr Consent Flag' ;
    rdfs:comment 'Indicates whether the applicant has provided explicit consent for processing their personal data under GDPR requirements (True/False).' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interviewDate rdf:type rdf:Property ;
    rdfs:label 'Interview Date' ;
    rdfs:comment 'Date of the most recent or scheduled interview with the applicant.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenceIssuingAuthority rdf:type rdf:Property ;
    rdfs:label 'Licence Issuing Authority' ;
    rdfs:comment 'Name of the civil aviation authority that issued the applicant\'s aviation licence (e.g., FAA, EASA, DGCA).' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerAcceptedDate rdf:type rdf:Property ;
    rdfs:label 'Offer Accepted Date' ;
    rdfs:comment 'Date when the applicant accepted the job offer.' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:offerDate rdf:type rdf:Property ;
    rdfs:label 'Offer Date' ;
    rdfs:comment 'Date when a formal job offer was extended to the applicant.' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:picHours rdf:type rdf:Property ;
    rdfs:label 'Pic Hours' ;
    rdfs:comment 'Total flight hours logged as Pilot in Command, if applicable for pilot applicants.' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:positionAppliedFor rdf:type rdf:Property ;
    rdfs:label 'Position Applied For' ;
    rdfs:comment 'Job title or position name that the applicant is applying for.' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningScore rdf:type rdf:Property ;
    rdfs:label 'Screening Score' ;
    rdfs:comment 'Numerical score assigned during initial screening or assessment of the application (0-100 scale).' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:statusReason rdf:type rdf:Property ;
    rdfs:label 'Status Reason' ;
    rdfs:comment 'Reason or notes explaining the current application status, particularly for rejected or withdrawn applications.' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:typeRatingsHeld rdf:type rdf:Property ;
    rdfs:label 'Type Ratings Held' ;
    rdfs:comment 'Comma-separated list of aircraft type ratings held by the applicant (e.g., B737, A320, B777), if applicable for pilot applicants.' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:yearsOfExperience rdf:type rdf:Property ;
    rdfs:label 'Years Of Experience' ;
    rdfs:comment 'Total years of relevant work experience declared by the applicant.' ;
    rdfs:domain ind:Applicant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:benefitEnrolmentId rdf:type rdf:Property ;
    rdfs:label 'Benefit Enrolment Id' ;
    rdfs:comment 'Unique identifier for the benefit enrolment record. Primary key for the benefit enrolment entity.' ;
    rdfs:domain ind:BenefitEnrolment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:benefitPlanId rdf:type rdf:Property ;
    rdfs:label 'Benefit Plan Id' ;
    rdfs:comment 'Identifier of the benefit plan in which the employee is enrolled. Links to the benefit plan catalog.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BenefitPlan .

ind:primaryBenefitEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Benefit Employee Id' ;
    rdfs:comment 'Identifier of the employee enrolled in the benefit plan. Links to the employee master record.' ;
    rdfs:domain ind:BenefitEnrolment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:annualElectionAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Election Amount' ;
    rdfs:comment 'Total annual amount elected by employee for this benefit plan. Applicable for flexible spending accounts (FSA), health savings accounts (HSA), and similar contribution-based benefits.' ;
    rdfs:domain ind:BenefitEnrolment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:beneficiaryDesignation rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Designation' ;
    rdfs:comment 'Identifier or reference to the designated beneficiary for this benefit plan (applicable for life insurance, retirement plans). May reference dependent or external party.' ;
    rdfs:domain ind:BenefitEnrolment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierPolicyNumber rdf:type rdf:Property ;
    rdfs:label 'Carrier Policy Number' ;
    rdfs:comment 'Policy or certificate number assigned by the insurance carrier or benefit provider for this enrolment. Used for claims processing and carrier coordination.' ;
    rdfs:domain ind:BenefitEnrolment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cobraElectionDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Cobra Election Deadline Date' ;
    rdfs:comment 'Deadline date by which terminated employee must elect COBRA continuation coverage. Typically 60 days from termination or notice date. Null if not COBRA eligible.' ;
    rdfs:domain ind:BenefitEnrolment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cobraEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Cobra Eligible Flag' ;
    rdfs:comment 'Indicates whether the employee is eligible for COBRA continuation coverage upon termination of employment. Applicable for US-based health benefit plans.' ;
    rdfs:domain ind:BenefitEnrolment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contributionCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Contribution Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for employee and employer contribution amounts. Supports multi-currency operations for international airline workforce.' ;
    rdfs:domain ind:BenefitEnrolment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contributionFrequency rdf:type rdf:Property ;
    rdfs:label 'Contribution Frequency' ;
    rdfs:comment 'Frequency at which employee and employer contributions are deducted and paid. Aligns with payroll cycle.' ;
    rdfs:domain ind:BenefitEnrolment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coverageEndDate rdf:type rdf:Property ;
    rdfs:label 'Coverage End Date' ;
    rdfs:comment 'Effective end date when benefit coverage terminates for the employee. Null for active ongoing coverage.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:coverageStartDate rdf:type rdf:Property ;
    rdfs:label 'Coverage Start Date' ;
    rdfs:comment 'Effective start date when benefit coverage begins for the employee. May differ from enrolment date due to waiting periods or plan year alignment.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:coverageTier rdf:type rdf:Property ;
    rdfs:label 'Coverage Tier' ;
    rdfs:comment 'Level of coverage selected by the employee. Determines who is covered under the benefit plan (employee only, employee plus spouse, employee plus children, or full family).' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dependentsEnrolledCount rdf:type rdf:Property ;
    rdfs:label 'Dependents Enrolled Count' ;
    rdfs:comment 'Number of dependents (spouse, children, domestic partner) enrolled under this benefit plan coverage. Zero for employee-only coverage.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:employeeContributionAmount rdf:type rdf:Property ;
    rdfs:label 'Employee Contribution Amount' ;
    rdfs:comment 'Monetary amount contributed by the employee per pay period for this benefit plan. Represents the employee\'s share of the benefit cost.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:employerContributionAmount rdf:type rdf:Property ;
    rdfs:label 'Employer Contribution Amount' ;
    rdfs:comment 'Monetary amount contributed by the employer per pay period for this benefit plan. Represents the employer\'s share of the benefit cost.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:enrolmentConfirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Enrolment Confirmation Number' ;
    rdfs:comment 'Confirmation or transaction number generated when the enrolment was processed. Provides audit trail and reference for employee inquiries.' ;
    rdfs:domain ind:BenefitEnrolment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrolmentDate rdf:type rdf:Property ;
    rdfs:label 'Enrolment Date' ;
    rdfs:comment 'Date when the employee enrolled in the benefit plan. Represents the business event timestamp of enrolment action.' ;
    rdfs:domain ind:BenefitEnrolment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enrolmentMethod rdf:type rdf:Property ;
    rdfs:label 'Enrolment Method' ;
    rdfs:comment 'Method or channel through which the employee completed the benefit enrolment. Tracks whether enrolment was done via self-service portal, paper form, phone, HR representative, or automated system.' ;
    rdfs:domain ind:BenefitEnrolment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrolmentSource rdf:type rdf:Property ;
    rdfs:label 'Enrolment Source' ;
    rdfs:comment 'Source or trigger event that initiated this benefit enrolment. Indicates whether enrolment occurred during open enrolment period, new hire onboarding, qualifying life event, annual renewal, or administrative action.' ;
    rdfs:domain ind:BenefitEnrolment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrolmentStatus rdf:type rdf:Property ;
    rdfs:label 'Enrolment Status' ;
    rdfs:comment 'Current lifecycle status of the benefit enrolment. Indicates whether the enrolment is active, terminated, suspended, pending approval, waived by employee, or cancelled.' ;
    rdfs:domain ind:BenefitEnrolment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:evidenceOfInsurabilityRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Evidence Of Insurability Required Flag' ;
    rdfs:comment 'Indicates whether the employee is required to provide evidence of insurability (medical underwriting) for this benefit enrolment. Typically required for late enrolments or coverage above guaranteed issue limits.' ;
    rdfs:domain ind:BenefitEnrolment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:evidenceOfInsurabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Evidence Of Insurability Status' ;
    rdfs:comment 'Status of evidence of insurability review process. Tracks whether medical underwriting has been completed and approved. Not_required if evidence_of_insurability_required_flag is False.' ;
    rdfs:domain ind:BenefitEnrolment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lifeEventDate rdf:type rdf:Property ;
    rdfs:label 'Life Event Date' ;
    rdfs:comment 'Date when the qualifying life event occurred. Used to validate enrolment change eligibility and timing. Null if not applicable.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lifeEventType rdf:type rdf:Property ;
    rdfs:label 'Life Event Type' ;
    rdfs:comment 'Type of qualifying life event that triggered mid-year enrolment change. Applicable when enrolment_source is life_event. Null for standard enrolment periods. [ENUM-REF-CANDIDATE: marriage|birth|adoption|divorce|death|loss_of_coverage|employment_change — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preTaxElectionFlag rdf:type rdf:Property ;
    rdfs:label 'Pre Tax Election Flag' ;
    rdfs:comment 'Indicates whether employee contributions are deducted on a pre-tax basis under Section 125 cafeteria plan. True for pre-tax, False for post-tax contributions.' ;
    rdfs:domain ind:BenefitEnrolment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tobaccoUserFlag rdf:type rdf:Property ;
    rdfs:label 'Tobacco User Flag' ;
    rdfs:comment 'Indicates whether the employee declared tobacco use during enrolment. Affects premium rates for health and life insurance plans. Protected health information.' ;
    rdfs:domain ind:BenefitEnrolment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:coverageTierStructure rdf:type rdf:Property ;
    rdfs:label 'Coverage Tier Structure' ;
    rdfs:comment 'Defines the available coverage tiers for the plan, determining who can be covered (employee only, employee plus dependents, family coverage).' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dependentCoverageAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Dependent Coverage Allowed Flag' ;
    rdfs:comment 'Indicates whether the plan allows employees to enroll eligible dependents (spouse, domestic partner, children).' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eligibilityEmploymentType rdf:type rdf:Property ;
    rdfs:label 'Eligibility Employment Type' ;
    rdfs:comment 'Comma-separated list of employment types eligible for this plan (e.g., full_time, part_time, contract, pilot, cabin_crew, ground_staff). Aligns with workforce employment classifications.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibilityGradeRange rdf:type rdf:Property ;
    rdfs:label 'Eligibility Grade Range' ;
    rdfs:comment 'Employee grade or pay band range eligible for this plan (e.g., G1-G5, Executive, Management). Used to differentiate benefit offerings by organizational level.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibilityMinimumTenureMonths rdf:type rdf:Property ;
    rdfs:label 'Eligibility Minimum Tenure Months' ;
    rdfs:comment 'Minimum number of months an employee must be employed before becoming eligible for this benefit plan. Zero indicates immediate eligibility.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:employeeContributionRate rdf:type rdf:Property ;
    rdfs:label 'Employee Contribution Rate' ;
    rdfs:comment 'Percentage or fixed amount that the employee contributes toward the benefit plan premium or cost. Expressed as a decimal (e.g., 0.2500 for 25%).' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:employerContributionRate rdf:type rdf:Property ;
    rdfs:label 'Employer Contribution Rate' ;
    rdfs:comment 'Percentage or fixed amount that the employer contributes toward the benefit plan premium or cost. Expressed as a decimal (e.g., 0.7500 for 75%).' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:enrollmentWindowEndDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment Window End Date' ;
    rdfs:comment 'Date when the annual open enrollment period ends for this benefit plan. Elections must be submitted before this date.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enrollmentWindowStartDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment Window Start Date' ;
    rdfs:comment 'Date when the annual open enrollment period begins for this benefit plan. Employees can make elections during this window.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maximumDependentAge rdf:type rdf:Property ;
    rdfs:label 'Maximum Dependent Age' ;
    rdfs:comment 'Maximum age for dependent children to remain eligible under the plan. Typically 26 in the US under ACA, varies by jurisdiction.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:monthlyPremiumAmount rdf:type rdf:Property ;
    rdfs:label 'Monthly Premium Amount' ;
    rdfs:comment 'Total monthly premium cost for the benefit plan per coverage tier. Used for payroll deduction calculations and budget planning.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planDescriptionSummary rdf:type rdf:Property ;
    rdfs:label 'Plan Description Summary' ;
    rdfs:comment 'Brief summary of the benefit plan features, coverage highlights, and key terms. Used in employee communications and benefits guides.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Plan Document Url' ;
    rdfs:comment 'URL link to the full plan document, Summary Plan Description (SPD), or benefits handbook stored in the document management system.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Plan Effective Date' ;
    rdfs:comment 'Date when the benefit plan becomes active and coverage begins for enrolled participants. Aligns with plan year start.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Plan Expiration Date' ;
    rdfs:comment 'Date when the benefit plan expires or is scheduled for renewal. Null for evergreen plans without fixed end dates.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:planYear rdf:type rdf:Property ;
    rdfs:label 'Plan Year' ;
    rdfs:comment 'Calendar or fiscal year for which this plan configuration applies. Used for year-over-year plan comparison and historical tracking.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:providerName rdf:type rdf:Property ;
    rdfs:label 'Provider Name' ;
    rdfs:comment 'Name of the external insurance carrier or benefits provider administering the plan (e.g., Aetna, Blue Cross, Fidelity).' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:providerPolicyNumber rdf:type rdf:Property ;
    rdfs:label 'Provider Policy Number' ;
    rdfs:comment 'External policy or contract number assigned by the benefit provider for this plan. Used for claims reconciliation and provider communication.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryComplianceFramework rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Framework' ;
    rdfs:comment 'Comma-separated list of regulatory frameworks this plan must comply with (e.g., ERISA, ACA, HIPAA, GDPR, local labor laws). Determines reporting and governance requirements.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:travelConcessionClassEntitlement rdf:type rdf:Property ;
    rdfs:label 'Travel Concession Class Entitlement' ;
    rdfs:comment 'Highest cabin class the employee is entitled to under travel concession benefits. Varies by employee grade and plan tier.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:travelConcessionEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Travel Concession Eligibility Flag' ;
    rdfs:comment 'Indicates whether this plan includes airline employee travel concession benefits (standby travel, discounted tickets for employee and dependents). Aviation industry-specific benefit.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waitingPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Waiting Period Days' ;
    rdfs:comment 'Number of days an employee must wait after enrollment before coverage becomes effective. Common for health and insurance plans.' ;
    rdfs:domain ind:BenefitPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:jobClassificationId rdf:type rdf:Property ;
    rdfs:label 'Job Classification Id' ;
    rdfs:comment 'Foreign key linking to workforce.job_classification. Business justification: Employee\'s job classification should reference the master job_classification table for grade structure, pay bands, and job family. The STRING job_classification attribute should be replaced by FK to t' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JobClassification .

ind:workforcePositionId rdf:type rdf:Property ;
    rdfs:label 'Workforce Position Id' ;
    rdfs:comment 'Foreign key linking to workforce.position. Business justification: Employee should reference their authorized position in the organizational structure. The job_title is an attribute of position and should be retrieved via JOIN. This links employees to the position ma' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Position .

ind:employeeNumber rdf:type rdf:Property ;
    rdfs:label 'Employee Number' ;
    rdfs:comment 'Externally-known unique employee number assigned by HR system. Business identifier used on badges, payroll, and HR documents.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employmentType rdf:type rdf:Property ;
    rdfs:label 'Employment Type' ;
    rdfs:comment 'Type of employment contract. ACMI indicates crew leased under Aircraft Crew Maintenance Insurance agreements.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hireDate rdf:type rdf:Property ;
    rdfs:label 'Hire Date' ;
    rdfs:comment 'Date the employee was hired or commenced employment with the airline. Used for seniority calculations, benefits eligibility, and tenure reporting.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:homeBaseAirportCode rdf:type rdf:Property ;
    rdfs:label 'Home Base Airport Code' ;
    rdfs:comment 'IATA 3-letter code of the employee\'s home base airport. Critical for crew scheduling, commute planning, and operational assignments.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalCertificateStatus rdf:type rdf:Property ;
    rdfs:label 'Medical Certificate Status' ;
    rdfs:comment 'Current status of the employee\'s aviation medical certificate. Required for pilots and cabin crew per FAA/EASA regulations.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceRating rdf:type rdf:Property ;
    rdfs:label 'Performance Rating' ;
    rdfs:comment 'Most recent performance appraisal rating for the employee. Used for promotion decisions, compensation adjustments, and talent management.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salaryGrade rdf:type rdf:Property ;
    rdfs:label 'Salary Grade' ;
    rdfs:comment 'Salary grade or pay band assigned to the employee. Used for compensation planning and equity analysis.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seniorityDate rdf:type rdf:Property ;
    rdfs:label 'Seniority Date' ;
    rdfs:comment 'Date used to calculate employee seniority for bidding, scheduling, and union contract purposes. May differ from hire date due to transfers or breaks in service.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:workPermitExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Work Permit Expiry Date' ;
    rdfs:comment 'Expiration date of the employee\'s work permit or visa. Monitored to ensure continuous legal employment status.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:workPermitStatus rdf:type rdf:Property ;
    rdfs:label 'Work Permit Status' ;
    rdfs:comment 'Current status of the employee\'s work permit or visa authorization. Critical for legal employment compliance.' ;
    rdfs:domain ind:Employee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeActionId rdf:type rdf:Property ;
    rdfs:label 'Employee Action Id' ;
    rdfs:comment 'Unique identifier for the employee action record. Primary key for the employee action entity.' ;
    rdfs:domain ind:EmployeeAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Employee Id' ;
    rdfs:comment 'Reference to the employee who is the subject of this personnel action.' ;
    rdfs:domain ind:EmployeeAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryEmployeePreviousOrgUnitId rdf:type rdf:Property ;
    rdfs:label 'Primary Employee Previous Org Unit Id' ;
    rdfs:comment 'Reference to the organizational unit the employee belonged to before this action.' ;
    rdfs:domain ind:EmployeeAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:primaryEmployeePreviousPositionId rdf:type rdf:Property ;
    rdfs:label 'Primary Employee Previous Position Id' ;
    rdfs:comment 'Reference to the employee\'s position before this action was executed.' ;
    rdfs:domain ind:EmployeeAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Position .

ind:tertiaryHrApproverEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Hr Approver Employee Id' ;
    rdfs:comment 'Reference to the HR representative who approved this personnel action.' ;
    rdfs:domain ind:EmployeeAction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actionDate rdf:type rdf:Property ;
    rdfs:label 'Action Date' ;
    rdfs:comment 'Date when the personnel action was initiated or recorded in the system.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actionReasonCode rdf:type rdf:Property ;
    rdfs:label 'Action Reason Code' ;
    rdfs:comment 'SAP action reason code providing detailed classification of why the action occurred (e.g., voluntary resignation, retirement, performance-based promotion, operational transfer).' ;
    rdfs:domain ind:EmployeeAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionStatus rdf:type rdf:Property ;
    rdfs:label 'Action Status' ;
    rdfs:comment 'Current workflow status of the personnel action in the approval and execution lifecycle.' ;
    rdfs:domain ind:EmployeeAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newBaseSalary rdf:type rdf:Property ;
    rdfs:label 'New Base Salary' ;
    rdfs:comment 'Annual base salary amount after this personnel action, in the employee\'s local currency.' ;
    rdfs:domain ind:EmployeeAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:newEmploymentStatus rdf:type rdf:Property ;
    rdfs:label 'New Employment Status' ;
    rdfs:comment 'Employment status of the employee after this action.' ;
    rdfs:domain ind:EmployeeAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newEmploymentType rdf:type rdf:Property ;
    rdfs:label 'New Employment Type' ;
    rdfs:comment 'Type of employment contract after this action.' ;
    rdfs:domain ind:EmployeeAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newFteAllocation rdf:type rdf:Property ;
    rdfs:label 'New Fte Allocation' ;
    rdfs:comment 'Full-time equivalent allocation after this action (e.g., 1.00 for full-time, 0.50 for half-time).' ;
    rdfs:domain ind:EmployeeAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:newGradeBand rdf:type rdf:Property ;
    rdfs:label 'New Grade Band' ;
    rdfs:comment 'Salary grade or band the employee is assigned to after this action.' ;
    rdfs:domain ind:EmployeeAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newHomeBaseAirportCode rdf:type rdf:Property ;
    rdfs:label 'New Home Base Airport Code' ;
    rdfs:comment 'Three-letter IATA airport code representing the employee\'s home base after this action. Relevant for crew and operational staff.' ;
    rdfs:domain ind:EmployeeAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newJobTitle rdf:type rdf:Property ;
    rdfs:label 'New Job Title' ;
    rdfs:comment 'Job title assigned to the employee after this personnel action.' ;
    rdfs:domain ind:EmployeeAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousBaseSalary rdf:type rdf:Property ;
    rdfs:label 'Previous Base Salary' ;
    rdfs:comment 'Annual base salary amount before this personnel action, in the employee\'s local currency.' ;
    rdfs:domain ind:EmployeeAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:previousEmploymentStatus rdf:type rdf:Property ;
    rdfs:label 'Previous Employment Status' ;
    rdfs:comment 'Employment status of the employee before this action.' ;
    rdfs:domain ind:EmployeeAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousEmploymentType rdf:type rdf:Property ;
    rdfs:label 'Previous Employment Type' ;
    rdfs:comment 'Type of employment contract before this action.' ;
    rdfs:domain ind:EmployeeAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousFteAllocation rdf:type rdf:Property ;
    rdfs:label 'Previous Fte Allocation' ;
    rdfs:comment 'Full-time equivalent allocation before this action (e.g., 1.00 for full-time, 0.50 for half-time).' ;
    rdfs:domain ind:EmployeeAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:previousGradeBand rdf:type rdf:Property ;
    rdfs:label 'Previous Grade Band' ;
    rdfs:comment 'Salary grade or band the employee was assigned to before this action.' ;
    rdfs:domain ind:EmployeeAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousHomeBaseAirportCode rdf:type rdf:Property ;
    rdfs:label 'Previous Home Base Airport Code' ;
    rdfs:comment 'Three-letter IATA airport code representing the employee\'s home base before this action. Relevant for crew and operational staff.' ;
    rdfs:domain ind:EmployeeAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousJobTitle rdf:type rdf:Property ;
    rdfs:label 'Previous Job Title' ;
    rdfs:comment 'Job title held by the employee before this personnel action.' ;
    rdfs:domain ind:EmployeeAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salaryCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Salary Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for salary amounts.' ;
    rdfs:domain ind:EmployeeAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unionNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Union Notification Date' ;
    rdfs:comment 'Date when the union was notified of this personnel action, if applicable.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:unionNotificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Union Notification Required Flag' ;
    rdfs:comment 'Indicates whether union notification is required for this personnel action per collective bargaining agreements.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:employmentContractId rdf:type rdf:Property ;
    rdfs:label 'Employment Contract Id' ;
    rdfs:comment 'Unique identifier for the employment contract record. Primary key.' ;
    rdfs:domain ind:EmploymentContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:previousContractEmploymentContractId rdf:type rdf:Property ;
    rdfs:label 'Previous Contract Employment Contract Id' ;
    rdfs:comment 'Reference to the previous employment contract record if this contract supersedes or replaces an earlier contract for the same employee. Nullable for initial contracts.' ;
    rdfs:domain ind:EmploymentContract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EmploymentContract .

ind:primaryEmploymentEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Employment Employee Id' ;
    rdfs:comment 'Reference to the employee who is party to this employment contract.' ;
    rdfs:domain ind:EmploymentContract ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:baseSalary rdf:type rdf:Property ;
    rdfs:label 'Base Salary' ;
    rdfs:comment 'The fixed annual or monthly base compensation amount for the employee, excluding bonuses, allowances, and variable pay. For flight crew, this is the guaranteed minimum before flight pay.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:benefitsPackageCode rdf:type rdf:Property ;
    rdfs:label 'Benefits Package Code' ;
    rdfs:comment 'Code or identifier representing the benefits package assigned to this contract, including health insurance, retirement plans, travel privileges, and other perquisites. Different packages may apply to different employee categories.' ;
    rdfs:domain ind:EmploymentContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Contract Document Url' ;
    rdfs:comment 'URL or file path to the digitally stored employment contract document (PDF or electronic signature platform link). Confidential business data.' ;
    rdfs:domain ind:EmploymentContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractVersion rdf:type rdf:Property ;
    rdfs:label 'Contract Version' ;
    rdfs:comment 'Version number of the contract document, incremented when contract terms are amended or renegotiated. Supports contract change history and audit trail.' ;
    rdfs:domain ind:EmploymentContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractedHoursPerWeek rdf:type rdf:Property ;
    rdfs:label 'Contracted Hours Per Week' ;
    rdfs:comment 'Number of hours per week the employee is contracted to work. For flight crew, this may represent block hours or duty hours depending on airline policy. Zero-hours contracts will have 0.00.' ;
    rdfs:domain ind:EmploymentContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:employmentCategory rdf:type rdf:Property ;
    rdfs:label 'Employment Category' ;
    rdfs:comment 'High-level classification of the employee\'s role within the airline. Flight crew includes pilots; cabin crew includes flight attendants; ground staff includes airport and customer service personnel; maintenance includes MRO (Maintenance Repair and Overhaul) technicians; corporate includes office-based roles; management includes leadership positions.' ;
    rdfs:domain ind:EmploymentContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fullTimeEquivalent rdf:type rdf:Property ;
    rdfs:label 'Full Time Equivalent' ;
    rdfs:comment 'Ratio representing the employee\'s contracted hours as a proportion of full-time hours. 1.000 indicates full-time; 0.500 indicates half-time; 0.000 for zero-hours contracts.' ;
    rdfs:domain ind:EmploymentContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:governingJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Governing Jurisdiction' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code representing the legal jurisdiction whose labor laws govern this employment contract (e.g., USA, GBR, DEU).' ;
    rdfs:domain ind:EmploymentContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isUnionMember rdf:type rdf:Property ;
    rdfs:label 'Is Union Member' ;
    rdfs:comment 'Boolean flag indicating whether the employee is a member of a labor union. True if union member; False if not. Relevant for collective bargaining coverage and labor relations.' ;
    rdfs:domain ind:EmploymentContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:payFrequency rdf:type rdf:Property ;
    rdfs:label 'Pay Frequency' ;
    rdfs:comment 'Frequency at which the employee receives salary payments. Monthly is standard for salaried staff; biweekly or weekly may apply to hourly or ground staff.' ;
    rdfs:domain ind:EmploymentContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:probationPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Probation Period Months' ;
    rdfs:comment 'Duration of the probationary period in months during which the employee\'s performance is evaluated before permanent status is confirmed. Nullable if no probation applies.' ;
    rdfs:domain ind:EmploymentContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:salaryCurrency rdf:type rdf:Property ;
    rdfs:label 'Salary Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code in which the base salary is denominated (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:EmploymentContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:travelPrivilegesTier rdf:type rdf:Property ;
    rdfs:label 'Travel Privileges Tier' ;
    rdfs:comment 'Classification tier for employee travel benefits (e.g., standby travel, confirmed seats, companion passes). Higher tiers typically apply to longer-tenured employees and flight crew. Airline-specific tier codes.' ;
    rdfs:domain ind:EmploymentContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grievanceId rdf:type rdf:Property ;
    rdfs:label 'Grievance Id' ;
    rdfs:comment 'Unique identifier for the employee grievance record. Primary key.' ;
    rdfs:domain ind:Grievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:grievanceAssignedInvestigatorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Grievance Assigned Investigator Employee Id' ;
    rdfs:comment 'Reference to the HR or labor relations staff member assigned to investigate the grievance.' ;
    rdfs:domain ind:Grievance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:grievanceEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Grievance Employee Id' ;
    rdfs:comment 'Reference to the employee who filed the grievance. Links to the employee master record in the workforce domain.' ;
    rdfs:domain ind:Grievance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:arbitrationDate rdf:type rdf:Property ;
    rdfs:label 'Arbitration Date' ;
    rdfs:comment 'Date when the arbitration hearing took place, if applicable.' ;
    rdfs:domain ind:Grievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:arbitrationDecision rdf:type rdf:Property ;
    rdfs:label 'Arbitration Decision' ;
    rdfs:comment 'Summary of the arbitrators binding decision, if arbitration occurred.' ;
    rdfs:domain ind:Grievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arbitrationFlag rdf:type rdf:Property ;
    rdfs:label 'Arbitration Flag' ;
    rdfs:comment 'Indicates whether the grievance was escalated to external arbitration. True if arbitration was invoked, False otherwise.' ;
    rdfs:domain ind:Grievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:arbitratorName rdf:type rdf:Property ;
    rdfs:label 'Arbitrator Name' ;
    rdfs:comment 'Name of the neutral third-party arbitrator assigned to the case, if arbitration occurred.' ;
    rdfs:domain ind:Grievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confidentialityFlag rdf:type rdf:Property ;
    rdfs:label 'Confidentiality Flag' ;
    rdfs:comment 'Indicates whether a confidentiality or non-disclosure agreement was executed as part of the resolution. True if confidentiality agreement exists, False otherwise.' ;
    rdfs:domain ind:Grievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:documentationReference rdf:type rdf:Property ;
    rdfs:label 'Documentation Reference' ;
    rdfs:comment 'Reference identifier or file path to supporting documentation, evidence, or investigation reports stored in the document management system.' ;
    rdfs:domain ind:Grievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialSettlementAmount rdf:type rdf:Property ;
    rdfs:label 'Financial Settlement Amount' ;
    rdfs:comment 'Monetary settlement amount paid to the employee as part of the grievance resolution, if applicable. Null if no financial settlement.' ;
    rdfs:domain ind:Grievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grievanceDescription rdf:type rdf:Property ;
    rdfs:label 'Grievance Description' ;
    rdfs:comment 'Detailed narrative description of the grievance as provided by the employee. Contains the facts, circumstances, and specific complaint details.' ;
    rdfs:domain ind:Grievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grievanceNumber rdf:type rdf:Property ;
    rdfs:label 'Grievance Number' ;
    rdfs:comment 'Externally-visible unique case number assigned to the grievance for tracking and reference purposes. Format: GRV-YYYYNNNN.' ;
    rdfs:domain ind:Grievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grievanceType rdf:type rdf:Property ;
    rdfs:label 'Grievance Type' ;
    rdfs:comment 'Classification of the grievance based on the nature of the complaint. CBA = Collective Bargaining Agreement.' ;
    rdfs:domain ind:Grievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Investigation Completion Date' ;
    rdfs:comment 'Date when the investigation was completed and findings were documented.' ;
    rdfs:domain ind:Grievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:investigationStartDate rdf:type rdf:Property ;
    rdfs:label 'Investigation Start Date' ;
    rdfs:comment 'Date when the formal investigation of the grievance commenced.' ;
    rdfs:domain ind:Grievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:legalCounselInvolvedFlag rdf:type rdf:Property ;
    rdfs:label 'Legal Counsel Involved Flag' ;
    rdfs:comment 'Indicates whether external legal counsel was engaged by either party during the grievance process. True if legal counsel was involved, False otherwise.' ;
    rdfs:domain ind:Grievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:relatedPolicyReference rdf:type rdf:Property ;
    rdfs:label 'Related Policy Reference' ;
    rdfs:comment 'Reference to the airline policy, Standard Operating Procedure (SOP), or Collective Bargaining Agreement (CBA) clause cited in the grievance.' ;
    rdfs:domain ind:Grievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedRemedy rdf:type rdf:Property ;
    rdfs:label 'Requested Remedy' ;
    rdfs:comment 'The resolution or corrective action requested by the employee. Examples: reinstatement, back pay, policy change, disciplinary action reversal.' ;
    rdfs:domain ind:Grievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionOutcome rdf:type rdf:Property ;
    rdfs:label 'Resolution Outcome' ;
    rdfs:comment 'Final outcome of the grievance case. Upheld means the grievance was found valid and remedy granted; denied means grievance was not substantiated.' ;
    rdfs:domain ind:Grievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionSummary rdf:type rdf:Property ;
    rdfs:label 'Resolution Summary' ;
    rdfs:comment 'Detailed summary of the resolution, including findings, corrective actions taken, and rationale for the decision.' ;
    rdfs:domain ind:Grievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:respondentDepartment rdf:type rdf:Property ;
    rdfs:label 'Respondent Department' ;
    rdfs:comment 'Organizational department or division of the respondent. Examples: Flight Operations, Cabin Crew, Ground Handling, Maintenance.' ;
    rdfs:domain ind:Grievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:respondentName rdf:type rdf:Property ;
    rdfs:label 'Respondent Name' ;
    rdfs:comment 'Name of the manager, supervisor, or department against whom the grievance is filed.' ;
    rdfs:domain ind:Grievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unionName rdf:type rdf:Property ;
    rdfs:label 'Union Name' ;
    rdfs:comment 'Name of the labor union representing the employee, if applicable. Null if no union representation.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unionRepresentationFlag rdf:type rdf:Property ;
    rdfs:label 'Union Representation Flag' ;
    rdfs:comment 'Indicates whether the employee is represented by a union in this grievance case. True if union representation is involved, False otherwise.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unionRepresentativeName rdf:type rdf:Property ;
    rdfs:label 'Union Representative Name' ;
    rdfs:comment 'Name of the union representative assigned to this case, if applicable.' ;
    rdfs:domain ind:Grievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:witnessCount rdf:type rdf:Property ;
    rdfs:label 'Witness Count' ;
    rdfs:comment 'Number of witnesses interviewed or statements collected during the investigation.' ;
    rdfs:domain ind:Grievance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eligibleForBonus rdf:type rdf:Property ;
    rdfs:label 'Eligible For Bonus' ;
    rdfs:comment 'Indicates whether employees in this job classification are eligible for annual performance bonus or incentive compensation. Used for compensation planning and total rewards calculations.' ;
    rdfs:domain ind:JobClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eligibleForStock rdf:type rdf:Property ;
    rdfs:label 'Eligible For Stock' ;
    rdfs:comment 'Indicates whether employees in this job classification are eligible for equity compensation such as stock options, restricted stock units, or employee stock purchase plans. Typically limited to management and executive positions.' ;
    rdfs:domain ind:JobClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:flsaStatus rdf:type rdf:Property ;
    rdfs:label 'Flsa Status' ;
    rdfs:comment 'Classification under the US Fair Labor Standards Act indicating whether the position is exempt from overtime pay requirements (exempt) or eligible for overtime (non-exempt). Critical for payroll processing and labor law compliance.' ;
    rdfs:domain ind:JobClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iataJobCategory rdf:type rdf:Property ;
    rdfs:label 'Iata Job Category' ;
    rdfs:comment 'IATA standardized job category code used for industry benchmarking, salary surveys, and workforce analytics across airlines. Enables comparison with industry peers.' ;
    rdfs:domain ind:JobClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icaoOccupationalCategory rdf:type rdf:Property ;
    rdfs:label 'Icao Occupational Category' ;
    rdfs:comment 'ICAO standardized occupational category code for aviation-specific roles. Used for international regulatory reporting and workforce statistics submitted to ICAO.' ;
    rdfs:domain ind:JobClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isExecutive rdf:type rdf:Property ;
    rdfs:label 'Is Executive' ;
    rdfs:comment 'Indicates whether this job classification is an executive-level position (C-suite, senior vice president, or equivalent). Used for executive compensation programs, board reporting, and regulatory disclosures.' ;
    rdfs:domain ind:JobClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isManagement rdf:type rdf:Property ;
    rdfs:label 'Is Management' ;
    rdfs:comment 'Indicates whether this job classification is a management or supervisory position with direct reports. Used for leadership development programs, management training, and organizational structure analysis.' ;
    rdfs:domain ind:JobClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobClassificationStatus rdf:type rdf:Property ;
    rdfs:label 'Job Classification Status' ;
    rdfs:comment 'Current lifecycle status of this job classification. Active classifications are available for hiring and assignment. Inactive classifications are temporarily suspended. Obsolete classifications are retired and no longer used. Pending classifications are under review before activation.' ;
    rdfs:domain ind:JobClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobCode rdf:type rdf:Property ;
    rdfs:label 'Job Code' ;
    rdfs:comment 'Unique alphanumeric code identifying the job classification within the airline\'s human resources system. Used for position identification, payroll processing, and workforce planning.' ;
    rdfs:domain ind:JobClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobDescription rdf:type rdf:Property ;
    rdfs:label 'Job Description' ;
    rdfs:comment 'Detailed narrative description of the job responsibilities, duties, and accountabilities. Used for job postings, performance management, and organizational documentation.' ;
    rdfs:domain ind:JobClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobFamily rdf:type rdf:Property ;
    rdfs:label 'Job Family' ;
    rdfs:comment 'High-level grouping of related jobs within the airline. Categories include Flight Deck (pilots), Cabin Crew (flight attendants), Technical/MRO (Maintenance Repair and Overhaul), Ground Operations, Commercial (sales, revenue management), Corporate (finance, HR, IT), Cargo, and Customer Service. [ENUM-REF-CANDIDATE: flight_deck|cabin_crew|technical_mro|ground_operations|commercial|corporate|cargo|customer_service — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:JobClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobSubfamily rdf:type rdf:Property ;
    rdfs:label 'Job Subfamily' ;
    rdfs:comment 'Secondary classification within the job family providing more granular segmentation. For example, within Flight Deck: Captain, First Officer, Second Officer; within Technical/MRO: Line Maintenance, Base Maintenance, Component Repair.' ;
    rdfs:domain ind:JobClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseTypeRequired rdf:type rdf:Property ;
    rdfs:label 'License Type Required' ;
    rdfs:comment 'Specific type of aviation license required for this position if applicable. Examples: ATPL (Airline Transport Pilot License), CPL (Commercial Pilot License), AME (Aircraft Maintenance Engineer), cabin crew attestation. Null if no license required.' ;
    rdfs:domain ind:JobClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalClassRequired rdf:type rdf:Property ;
    rdfs:label 'Medical Class Required' ;
    rdfs:comment 'Class of aviation medical certificate required for this position. Class 1 for airline pilots, Class 2 for commercial pilots, Class 3 for private pilots, Cabin Crew for flight attendants, Not Required for non-safety-sensitive roles.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumEducationLevel rdf:type rdf:Property ;
    rdfs:label 'Minimum Education Level' ;
    rdfs:comment 'Minimum educational qualification required for this job classification. Used for recruitment, job posting, and candidate screening. Examples: high school diploma, bachelor\'s degree, vocational certification. [ENUM-REF-CANDIDATE: high_school|associate|bachelor|master|doctorate|vocational|none — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumExperienceYears rdf:type rdf:Property ;
    rdfs:label 'Minimum Experience Years' ;
    rdfs:comment 'Minimum number of years of relevant work experience required for this job classification. Used for recruitment qualification screening and career progression planning.' ;
    rdfs:domain ind:JobClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:organizationalLevel rdf:type rdf:Property ;
    rdfs:label 'Organizational Level' ;
    rdfs:comment 'Numeric indicator of the position\'s level in the organizational hierarchy. Lower numbers represent higher levels (e.g., 1 = CEO, 2 = Executive VP, 3 = VP, etc.). Used for organizational charting and span-of-control analysis.' ;
    rdfs:domain ind:JobClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:payGrade rdf:type rdf:Property ;
    rdfs:label 'Pay Grade' ;
    rdfs:comment 'Compensation grade or band assigned to this job classification. Used for salary benchmarking, compensation planning, and pay equity analysis. Links to the airline\'s compensation structure.' ;
    rdfs:domain ind:JobClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payGradeMaximum rdf:type rdf:Property ;
    rdfs:label 'Pay Grade Maximum' ;
    rdfs:comment 'Maximum annual base salary for this pay grade. Represents the ceiling for compensation within this classification without promotion.' ;
    rdfs:domain ind:JobClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payGradeMidpoint rdf:type rdf:Property ;
    rdfs:label 'Pay Grade Midpoint' ;
    rdfs:comment 'Midpoint annual base salary for this pay grade representing the target compensation for fully competent performance. Used for market benchmarking and compa-ratio calculations.' ;
    rdfs:domain ind:JobClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payGradeMinimum rdf:type rdf:Property ;
    rdfs:label 'Pay Grade Minimum' ;
    rdfs:comment 'Minimum annual base salary for this pay grade in the airline\'s base currency. Used for compensation planning and offer letter generation.' ;
    rdfs:domain ind:JobClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reportsToJobCode rdf:type rdf:Property ;
    rdfs:label 'Reports To Job Code' ;
    rdfs:comment 'Job code of the supervisory position to which this job classification typically reports. Defines the standard reporting relationship in the organizational hierarchy. Null for executive positions.' ;
    rdfs:domain ind:JobClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresAviationLicense rdf:type rdf:Property ;
    rdfs:label 'Requires Aviation License' ;
    rdfs:comment 'Indicates whether this job classification requires a valid aviation license issued by a civil aviation authority (e.g., pilot license, aircraft maintenance engineer license). True for flight deck crew, licensed aircraft maintenance engineers, and certain technical roles.' ;
    rdfs:domain ind:JobClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresMedicalCertificate rdf:type rdf:Property ;
    rdfs:label 'Requires Medical Certificate' ;
    rdfs:comment 'Indicates whether this job classification requires a valid aviation medical certificate. True for flight deck crew, cabin crew, and certain safety-sensitive positions. Medical certificate class and validity period vary by role.' ;
    rdfs:domain ind:JobClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresSecurityClearance rdf:type rdf:Property ;
    rdfs:label 'Requires Security Clearance' ;
    rdfs:comment 'Indicates whether this job classification requires airport security clearance or background check per TSA or equivalent national aviation security authority. True for roles with access to secure areas, aircraft, or sensitive systems.' ;
    rdfs:domain ind:JobClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresTypeRating rdf:type rdf:Property ;
    rdfs:label 'Requires Type Rating' ;
    rdfs:comment 'Indicates whether this job classification requires aircraft type rating certification. True for pilots and flight engineers who must be certified on specific aircraft types (e.g., B737, A320, B777). Type ratings are aircraft-specific endorsements on pilot licenses.' ;
    rdfs:domain ind:JobClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:safetySensitive rdf:type rdf:Property ;
    rdfs:label 'Safety Sensitive' ;
    rdfs:comment 'Indicates whether this job classification is designated as safety-sensitive under FAA or EASA regulations, requiring compliance with drug and alcohol testing programs, fatigue risk management, and enhanced safety oversight.' ;
    rdfs:domain ind:JobClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:standardHoursPerWeek rdf:type rdf:Property ;
    rdfs:label 'Standard Hours Per Week' ;
    rdfs:comment 'Standard number of work hours per week for this job classification. Used for full-time equivalency (FTE) calculations, workforce planning, and labor cost modeling. May be null for variable schedules.' ;
    rdfs:domain ind:JobClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardWorkSchedule rdf:type rdf:Property ;
    rdfs:label 'Standard Work Schedule' ;
    rdfs:comment 'Typical work schedule pattern for this job classification. Full-time (40 hours/week), part-time, variable (pilots, cabin crew with monthly schedules), shift work (ground operations, maintenance), or on-call (reserve crew).' ;
    rdfs:domain ind:JobClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unionEligible rdf:type rdf:Property ;
    rdfs:label 'Union Eligible' ;
    rdfs:comment 'Indicates whether employees in this job classification are eligible for union membership or collective bargaining representation. Varies by jurisdiction and airline labor agreements.' ;
    rdfs:domain ind:JobClassification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:licenceComplianceId rdf:type rdf:Property ;
    rdfs:label 'Licence Compliance Id' ;
    rdfs:comment 'Unique identifier for the licence compliance record. Primary key for this product.' ;
    rdfs:domain ind:LicenceCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryLicenceEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Licence Employee Id' ;
    rdfs:comment 'Reference to the employee whose licence compliance is being tracked.' ;
    rdfs:domain ind:LicenceCompliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryLicenceModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Licence Modified By User Employee Id' ;
    rdfs:comment 'User ID of the person who last modified this compliance record.' ;
    rdfs:domain ind:LicenceCompliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryLicenceResponsibleHrManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Licence Responsible Hr Manager Employee Id' ;
    rdfs:comment 'Reference to the HR manager responsible for overseeing this compliance record.' ;
    rdfs:domain ind:LicenceCompliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:auditTrailNotes rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Notes' ;
    rdfs:comment 'Free-text notes documenting the compliance verification process, actions taken, and any relevant observations for audit purposes.' ;
    rdfs:domain ind:LicenceCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceActionType rdf:type rdf:Property ;
    rdfs:label 'Compliance Action Type' ;
    rdfs:comment 'Type of administrative compliance action recorded in this entry.' ;
    rdfs:domain ind:LicenceCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceRecordNumber rdf:type rdf:Property ;
    rdfs:label 'Compliance Record Number' ;
    rdfs:comment 'Unique business identifier for the compliance record, formatted as LCR- followed by 8 digits.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crewSchedulingEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Crew Scheduling Eligible Flag' ;
    rdfs:comment 'Indicates whether the employee is eligible for crew scheduling based on current licence compliance status.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:groundingEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Grounding Effective Date' ;
    rdfs:comment 'Date when grounding from flight duties became effective.' ;
    rdfs:domain ind:LicenceCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:groundingFlag rdf:type rdf:Property ;
    rdfs:label 'Grounding Flag' ;
    rdfs:comment 'Indicates whether the employee has been grounded from flight duties due to licence compliance issues.' ;
    rdfs:domain ind:LicenceCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextVerificationDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Verification Due Date' ;
    rdfs:comment 'Date when the next compliance verification is scheduled or required.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryReportDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Date' ;
    rdfs:comment 'Date when the compliance status was reported to the regulatory authority.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryReportReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Reference Number' ;
    rdfs:comment 'Reference number assigned by the regulatory authority for the compliance report submission.' ;
    rdfs:domain ind:LicenceCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Remediation Deadline Date' ;
    rdfs:comment 'Deadline by which remediation actions must be completed.' ;
    rdfs:domain ind:LicenceCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remediationPlan rdf:type rdf:Property ;
    rdfs:label 'Remediation Plan' ;
    rdfs:comment 'Description of the remediation plan or corrective actions required to achieve compliance.' ;
    rdfs:domain ind:LicenceCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remediationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Remediation Required Flag' ;
    rdfs:comment 'Indicates whether remediation actions are required to restore compliance status.' ;
    rdfs:domain ind:LicenceCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalReminderSentDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Reminder Sent Date' ;
    rdfs:comment 'Date when the renewal reminder notification was sent to the employee.' ;
    rdfs:domain ind:LicenceCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalTrackingStatus rdf:type rdf:Property ;
    rdfs:label 'Renewal Tracking Status' ;
    rdfs:comment 'Administrative tracking status for licence renewal process from HR perspective.' ;
    rdfs:domain ind:LicenceCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalComplianceId rdf:type rdf:Property ;
    rdfs:label 'Medical Compliance Id' ;
    rdfs:comment 'Unique identifier for the medical compliance record. Primary key. Role: TRANSACTION_HEADER.' ;
    rdfs:domain ind:MedicalCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryMedicalEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Medical Employee Id' ;
    rdfs:comment 'Reference to the employee whose medical compliance is being tracked. Links to workforce.employee.' ;
    rdfs:domain ind:MedicalCompliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryMedicalModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Medical Modified By User Employee Id' ;
    rdfs:comment 'User ID of the HR system user who last modified this compliance record, providing audit trail for compliance actions and determinations.' ;
    rdfs:domain ind:MedicalCompliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:certificateExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Certificate Expiry Date' ;
    rdfs:comment 'Date when the current medical certificate expires. Denormalized from crew.medical_certificate for HR operational convenience and expiry notification workflows.' ;
    rdfs:domain ind:MedicalCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fitnessDeterminationDate rdf:type rdf:Property ;
    rdfs:label 'Fitness Determination Date' ;
    rdfs:comment 'Date when the fitness-for-duty determination was made by HR or occupational health, establishing the current operational status.' ;
    rdfs:domain ind:MedicalCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fitnessForDutyStatus rdf:type rdf:Property ;
    rdfs:label 'Fitness For Duty Status' ;
    rdfs:comment 'HR administrative determination of the employee\'s fitness to perform safety-critical duties based on medical compliance status. This is an HR operational flag that may trigger crew scheduling restrictions.' ;
    rdfs:domain ind:MedicalCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpActionRequired rdf:type rdf:Property ;
    rdfs:label 'Follow Up Action Required' ;
    rdfs:comment 'HR administrative follow-up action required to maintain or restore medical compliance status. Tracks the next step in the compliance workflow. [ENUM-REF-CANDIDATE: none|renewal_required|medical_exam_scheduled|documentation_submission|fitness_assessment|management_review|grounding_recommended — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MedicalCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:followUpCompletedDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Completed Date' ;
    rdfs:comment 'Date when the required follow-up action was completed by the employee or HR, resolving the compliance issue.' ;
    rdfs:domain ind:MedicalCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:followUpDueDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Due Date' ;
    rdfs:comment 'Date by which the required follow-up action must be completed to maintain compliance status and avoid operational impact (e.g., crew scheduling restrictions).' ;
    rdfs:domain ind:MedicalCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastMedicalExamDate rdf:type rdf:Property ;
    rdfs:label 'Last Medical Exam Date' ;
    rdfs:comment 'Date of the employee\'s most recent aviation medical examination. Denormalized from crew.medical_certificate for HR tracking and scheduling of next exam.' ;
    rdfs:domain ind:MedicalCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextMedicalExamDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Medical Exam Due Date' ;
    rdfs:comment 'Date by which the employee must complete their next aviation medical examination to maintain certificate validity and compliance status.' ;
    rdfs:domain ind:MedicalCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:notificationSentDate rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Date' ;
    rdfs:comment 'Date when HR sent expiry notification or compliance reminder to the employee regarding their medical certificate renewal or compliance action required.' ;
    rdfs:domain ind:MedicalCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:restrictionsDescription rdf:type rdf:Property ;
    rdfs:label 'Restrictions Description' ;
    rdfs:comment 'Description of any operational restrictions or limitations placed on the employee\'s duties due to medical compliance status or fitness-for-duty assessment (e.g., no night flights, no long-haul, ground duties only).' ;
    rdfs:domain ind:MedicalCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schedulingRestrictionEndDate rdf:type rdf:Property ;
    rdfs:label 'Scheduling Restriction End Date' ;
    rdfs:comment 'Date when crew scheduling restrictions are expected to be lifted, subject to compliance restoration and fitness clearance.' ;
    rdfs:domain ind:MedicalCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:schedulingRestrictionStartDate rdf:type rdf:Property ;
    rdfs:label 'Scheduling Restriction Start Date' ;
    rdfs:comment 'Date when crew scheduling restrictions due to medical non-compliance or fitness concerns became effective, preventing assignment to flight duties.' ;
    rdfs:domain ind:MedicalCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:waiverConditions rdf:type rdf:Property ;
    rdfs:label 'Waiver Conditions' ;
    rdfs:comment 'Specific conditions or limitations attached to the medical waiver by the regulatory authority (e.g., periodic monitoring, co-pilot restriction, operational limitations).' ;
    rdfs:domain ind:MedicalCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentOrgUnitId rdf:type rdf:Property ;
    rdfs:label 'Parent Org Unit Id' ;
    rdfs:comment 'Reference to the parent organizational unit in the hierarchy, enabling multi-level organizational structure representation.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrgUnit .

ind:headcountActual rdf:type rdf:Property ;
    rdfs:label 'Headcount Actual' ;
    rdfs:comment 'Current actual full-time equivalent headcount assigned to this organizational unit.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:headcountPlanned rdf:type rdf:Property ;
    rdfs:label 'Headcount Planned' ;
    rdfs:comment 'Planned or budgeted full-time equivalent headcount for this organizational unit.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:iataFunctionalCode rdf:type rdf:Property ;
    rdfs:label 'Iata Functional Code' ;
    rdfs:comment 'IATA standard functional area code for airline organizational classification and industry benchmarking.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isHub rdf:type rdf:Property ;
    rdfs:label 'Is Hub' ;
    rdfs:comment 'Flag indicating whether this organizational unit is located at or supports a hub airport in the airline\'s network.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRevenueGenerating rdf:type rdf:Property ;
    rdfs:label 'Is Revenue Generating' ;
    rdfs:comment 'Flag indicating whether this organizational unit directly generates revenue (e.g., flight operations, cargo) versus support functions.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:locationCode rdf:type rdf:Property ;
    rdfs:label 'Location Code' ;
    rdfs:comment 'IATA three-letter airport or city code representing the primary geographic location of this organizational unit.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orgLevel rdf:type rdf:Property ;
    rdfs:label 'Org Level' ;
    rdfs:comment 'Hierarchical level of the organizational unit within the overall structure (e.g., 1=corporate, 2=division, 3=department, 4=section).' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:orgUnitCode rdf:type rdf:Property ;
    rdfs:label 'Org Unit Code' ;
    rdfs:comment 'Business identifier code for the organizational unit, used across systems and reporting. May align with IATA functional area codes or internal cost center codes.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orgUnitDescription rdf:type rdf:Property ;
    rdfs:label 'Org Unit Description' ;
    rdfs:comment 'Detailed description of the organizational unit\'s purpose, responsibilities, and scope of operations.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orgUnitName rdf:type rdf:Property ;
    rdfs:label 'Org Unit Name' ;
    rdfs:comment 'Full business name of the organizational unit (e.g., Flight Operations Division, Cabin Services Department, MRO Engineering).' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orgUnitStatus rdf:type rdf:Property ;
    rdfs:label 'Org Unit Status' ;
    rdfs:comment 'Current lifecycle status of the organizational unit.' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orgUnitType rdf:type rdf:Property ;
    rdfs:label 'Org Unit Type' ;
    rdfs:comment 'Classification of the organizational unit by structural type within the airline hierarchy. [ENUM-REF-CANDIDATE: division|department|cost_center|functional_unit|station|hub|regional_office|corporate — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryOversightAuthority rdf:type rdf:Property ;
    rdfs:label 'Regulatory Oversight Authority' ;
    rdfs:comment 'Primary regulatory authority with jurisdiction over this organizational unit\'s operations (e.g., FAA, EASA, national CAA).' ;
    rdfs:domain ind:OrgUnit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyCriticalFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Critical Flag' ;
    rdfs:comment 'Indicates whether this organizational unit performs safety-critical functions requiring SMS (Safety Management System) oversight and regulatory compliance.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:payrollRunId rdf:type rdf:Property ;
    rdfs:label 'Payroll Run Id' ;
    rdfs:comment 'Unique identifier for the payroll processing cycle. Primary key for the payroll run entity.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PayrollRun .

ind:primaryPayrollEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Payroll Employee Id' ;
    rdfs:comment 'System user identifier of the payroll manager or authorized approver who approved this payroll run for payment. Required for segregation of duties and audit compliance.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:calculationEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Calculation End Timestamp' ;
    rdfs:comment 'Date and time when payroll calculation processing completed for this run. Used for performance monitoring and audit trail.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:calculationStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Calculation Start Timestamp' ;
    rdfs:comment 'Date and time when payroll calculation processing began for this run. Used for performance monitoring and audit trail.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:coDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Co Document Number' ;
    rdfs:comment 'SAP Controlling document number generated when payroll costs were allocated to cost centers and internal orders. Links payroll run to management accounting for cost analysis.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeCount rdf:type rdf:Property ;
    rdfs:label 'Employee Count' ;
    rdfs:comment 'Total number of employees included in this payroll run. Used for reconciliation and validation of payroll completeness.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fiDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Fi Document Number' ;
    rdfs:comment 'SAP Financial Accounting document number generated when payroll was posted to General Ledger (GL). Links payroll run to accounting entries for reconciliation and audit.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offCycleReason rdf:type rdf:Property ;
    rdfs:label 'Off Cycle Reason' ;
    rdfs:comment 'Business justification for executing an off-cycle payroll run outside the regular payroll schedule. Common reasons include termination settlements, bonus payments, or correction of prior period errors. Populated only when run_type is off_cycle.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payDate rdf:type rdf:Property ;
    rdfs:label 'Pay Date' ;
    rdfs:comment 'Scheduled date when net pay will be disbursed to employees via bank transfer or other payment method. Typically follows payroll approval and posting.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:payPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Pay Period End Date' ;
    rdfs:comment 'Last day of the pay period covered by this payroll run. Defines the end of the earnings and deductions calculation window.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:payPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Pay Period Start Date' ;
    rdfs:comment 'First day of the pay period covered by this payroll run. Defines the beginning of the earnings and deductions calculation window.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:payrollArea rdf:type rdf:Property ;
    rdfs:label 'Payroll Area' ;
    rdfs:comment 'Organizational grouping that defines payroll processing frequency and rules. Typically represents a country, region, or employee group with common payroll characteristics. Maps to SAP HR Payroll Area.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payrollPeriodIdentifier rdf:type rdf:Property ;
    rdfs:label 'Payroll Period Identifier' ;
    rdfs:comment 'Standardized period code in YYYYMM format representing the calendar month and year of the payroll run. Used for period-based reporting and reconciliation.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payrollSchema rdf:type rdf:Property ;
    rdfs:label 'Payroll Schema' ;
    rdfs:comment 'SAP Payroll calculation schema that defines the sequence of payroll rules and wage types processed in this run. Different schemas apply to different employee groups (pilots, cabin crew, ground staff).' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:personnelArea rdf:type rdf:Property ;
    rdfs:label 'Personnel Area' ;
    rdfs:comment 'SAP HR organizational unit representing a geographic or operational division within the company. Typically aligns with airports, hubs, or regional offices for airline workforce segmentation.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:personnelSubarea rdf:type rdf:Property ;
    rdfs:label 'Personnel Subarea' ;
    rdfs:comment 'SAP HR organizational subdivision within a personnel area. Used for more granular workforce segmentation such as terminal, department, or crew base.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Posted Timestamp' ;
    rdfs:comment 'Date and time when payroll financial transactions were posted to SAP FI/CO. Marks the point when payroll costs are recognized in the General Ledger (GL).' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:runType rdf:type rdf:Property ;
    rdfs:label 'Run Type' ;
    rdfs:comment 'Classification of the payroll processing cycle. Regular runs are scheduled periodic payroll; off-cycle runs handle unscheduled payments; correction runs fix prior period errors; advance runs provide early payments; bonus runs process incentive compensation; final runs handle termination settlements.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalEmployeeTax rdf:type rdf:Property ;
    rdfs:label 'Total Employee Tax' ;
    rdfs:comment 'Aggregate employee tax withholdings including income tax, National Insurance (NI) employee portion, and other statutory deductions withheld from employee gross pay.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalEmployerTax rdf:type rdf:Property ;
    rdfs:label 'Total Employer Tax' ;
    rdfs:comment 'Aggregate employer-borne tax obligations including National Insurance (NI), social security contributions, unemployment insurance, and other statutory employer charges for this payroll run.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalGrossPay rdf:type rdf:Property ;
    rdfs:label 'Total Gross Pay' ;
    rdfs:comment 'Aggregate gross earnings for all employees processed in this payroll run before any deductions. Includes base salary, overtime, allowances, bonuses, and other earnings components.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalNetPay rdf:type rdf:Property ;
    rdfs:label 'Total Net Pay' ;
    rdfs:comment 'Aggregate net pay disbursed to all employees in this payroll run after all statutory and voluntary deductions. Represents the actual amount paid to employees.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalVoluntaryDeductions rdf:type rdf:Property ;
    rdfs:label 'Total Voluntary Deductions' ;
    rdfs:comment 'Aggregate voluntary deductions including pension contributions, health insurance premiums, union dues, savings plans, and other employee-elected deductions.' ;
    rdfs:domain ind:PayrollRun ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payslipId rdf:type rdf:Property ;
    rdfs:label 'Payslip Id' ;
    rdfs:comment 'Unique identifier for the payslip record. Primary key for the payslip entity representing a single employee\'s payroll result for a specific pay period.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allowances rdf:type rdf:Property ;
    rdfs:label 'Allowances' ;
    rdfs:comment 'Sum of miscellaneous allowances including housing, transportation, uniform, meal, and other special allowances applicable to the employee.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bankRoutingNumber rdf:type rdf:Property ;
    rdfs:label 'Bank Routing Number' ;
    rdfs:comment 'Bank routing number for direct deposit. Identifies the financial institution receiving the payment.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bonus rdf:type rdf:Property ;
    rdfs:label 'Bonus' ;
    rdfs:comment 'Performance-based or discretionary bonus paid during this pay period. Includes annual bonuses, spot awards, and incentive payments.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commission rdf:type rdf:Property ;
    rdfs:label 'Commission' ;
    rdfs:comment 'Sales commission or variable compensation earned during the pay period. Applicable to sales and revenue-generating roles.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:employeeType rdf:type rdf:Property ;
    rdfs:label 'Employee Type' ;
    rdfs:comment 'Classification of the employee receiving this payslip. Determines applicable pay rules, allowances, and union agreements. [ENUM-REF-CANDIDATE: pilot|cabin_crew|ground_staff|maintenance|corporate|contract|temporary — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employerHealthContribution rdf:type rdf:Property ;
    rdfs:label 'Employer Health Contribution' ;
    rdfs:comment 'Employer portion of health insurance premium. Not deducted from employee pay but recorded for total compensation and benefits cost tracking.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:employerPayrollTax rdf:type rdf:Property ;
    rdfs:label 'Employer Payroll Tax' ;
    rdfs:comment 'Employer portion of payroll taxes including social security, medicare, unemployment insurance, and other statutory employer taxes.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:employerPensionContribution rdf:type rdf:Property ;
    rdfs:label 'Employer Pension Contribution' ;
    rdfs:comment 'Employer matching or non-elective contribution to employee pension plan. Not deducted from employee pay but recorded for total compensation tracking.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:flyingPay rdf:type rdf:Property ;
    rdfs:label 'Flying Pay' ;
    rdfs:comment 'Additional compensation for flight crew based on block hours flown during the pay period. Aviation-specific allowance for pilots and cabin crew.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:garnishments rdf:type rdf:Property ;
    rdfs:label 'Garnishments' ;
    rdfs:comment 'Court-ordered wage garnishments for child support, alimony, tax liens, or other legal obligations deducted from gross pay.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossPay rdf:type rdf:Property ;
    rdfs:label 'Gross Pay' ;
    rdfs:comment 'Total earnings before any deductions. Sum of base salary, flying pay, overtime, allowances, bonuses, and all other earnings components.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:healthInsurancePremium rdf:type rdf:Property ;
    rdfs:label 'Health Insurance Premium' ;
    rdfs:comment 'Employee portion of health insurance premium deducted from gross pay. Covers medical, dental, and vision insurance.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incomeTax rdf:type rdf:Property ;
    rdfs:label 'Income Tax' ;
    rdfs:comment 'Federal, state, and local income tax withheld from gross pay. Statutory deduction remitted to tax authorities on behalf of employee.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:medicareTax rdf:type rdf:Property ;
    rdfs:label 'Medicare Tax' ;
    rdfs:comment 'Medicare tax withheld from gross pay. Statutory payroll tax for healthcare benefits for retirees.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netPay rdf:type rdf:Property ;
    rdfs:label 'Net Pay' ;
    rdfs:comment 'Take-home pay after all deductions. Amount disbursed to employee\'s bank account. Calculated as gross pay minus total deductions.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:otherDeductions rdf:type rdf:Property ;
    rdfs:label 'Other Deductions' ;
    rdfs:comment 'Sum of miscellaneous deductions including life insurance, disability insurance, flexible spending accounts, loan repayments, and other voluntary deductions.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overtimeHours rdf:type rdf:Property ;
    rdfs:label 'Overtime Hours' ;
    rdfs:comment 'Total overtime hours worked during the pay period. Used to calculate overtime pay at applicable premium rates.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overtimePay rdf:type rdf:Property ;
    rdfs:label 'Overtime Pay' ;
    rdfs:comment 'Additional compensation for hours worked beyond standard duty hours. Calculated based on overtime rate and hours worked.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payslipNumber rdf:type rdf:Property ;
    rdfs:label 'Payslip Number' ;
    rdfs:comment 'Human-readable unique payslip number assigned to this payroll result. Used for employee reference and audit trail.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payslipStatus rdf:type rdf:Property ;
    rdfs:label 'Payslip Status' ;
    rdfs:comment 'Current lifecycle status of the payslip. Tracks progression from calculation through approval to payment disbursement.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pensionContribution rdf:type rdf:Property ;
    rdfs:label 'Pension Contribution' ;
    rdfs:comment 'Employee contribution to pension or retirement plan deducted from gross pay. Voluntary or mandatory retirement savings.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:perDiem rdf:type rdf:Property ;
    rdfs:label 'Per Diem' ;
    rdfs:comment 'Daily allowance paid to crew for meals and incidental expenses during layovers and duty periods away from base. Aviation-specific travel allowance.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:shiftDifferential rdf:type rdf:Property ;
    rdfs:label 'Shift Differential' ;
    rdfs:comment 'Additional compensation for working non-standard shifts such as nights, weekends, or holidays. Premium pay for undesirable work hours.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:socialSecurityTax rdf:type rdf:Property ;
    rdfs:label 'Social Security Tax' ;
    rdfs:comment 'Social security or national insurance tax withheld from gross pay. Statutory payroll tax for retirement and disability benefits.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDeductions rdf:type rdf:Property ;
    rdfs:label 'Total Deductions' ;
    rdfs:comment 'Sum of all deductions from gross pay including taxes, pension, insurance premiums, union dues, garnishments, and other deductions.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unionDues rdf:type rdf:Property ;
    rdfs:label 'Union Dues' ;
    rdfs:comment 'Union membership dues deducted from gross pay. Mandatory for unionized employees per collective bargaining agreement.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yearToDateGross rdf:type rdf:Property ;
    rdfs:label 'Year To Date Gross' ;
    rdfs:comment 'Cumulative gross pay from the beginning of the calendar or fiscal year through this pay period. Used for tax reporting and annual compensation tracking.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yearToDateTax rdf:type rdf:Property ;
    rdfs:label 'Year To Date Tax' ;
    rdfs:comment 'Cumulative income tax withheld from the beginning of the calendar or fiscal year through this pay period. Used for tax reporting and reconciliation.' ;
    rdfs:domain ind:Payslip ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceReviewId rdf:type rdf:Property ;
    rdfs:label 'Performance Review Id' ;
    rdfs:comment 'Unique identifier for the performance review record. Primary key.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryPerformanceEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Performance Employee Id' ;
    rdfs:comment 'Identifier of the employee being reviewed. Links to employee master data in SAP S/4HANA HR module.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:attendancePunctualityRating rdf:type rdf:Property ;
    rdfs:label 'Attendance Punctuality Rating' ;
    rdfs:comment 'Rating for attendance, punctuality, and reliability. Critical for crew scheduling and operational reliability. Includes adherence to duty times and rest requirements.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:behavioralCompetencyRating rdf:type rdf:Property ;
    rdfs:label 'Behavioral Competency Rating' ;
    rdfs:comment 'Rating for behavioral competencies including teamwork, communication, customer service, safety culture, and adherence to Standard Operating Procedures (SOP).' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compensationAdjustmentRecommendation rdf:type rdf:Property ;
    rdfs:label 'Compensation Adjustment Recommendation' ;
    rdfs:comment 'Recommendation for compensation adjustment based on performance. Used as input for annual compensation planning cycle.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerServiceRating rdf:type rdf:Property ;
    rdfs:label 'Customer Service Rating' ;
    rdfs:comment 'Rating for customer service quality and passenger satisfaction. Applicable to customer-facing roles including cabin crew, ground staff, and airport operations. Not applicable for non-customer-facing roles.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:developmentAreasSummary rdf:type rdf:Property ;
    rdfs:label 'Development Areas Summary' ;
    rdfs:comment 'Narrative summary of areas identified for improvement and professional development. Includes specific skills, competencies, or behaviors requiring attention.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:developmentPlanActions rdf:type rdf:Property ;
    rdfs:label 'Development Plan Actions' ;
    rdfs:comment 'Specific actions and development activities recommended for the employee. May include training courses, certifications, mentoring, job rotation, or special projects.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:employeeAcknowledgementDate rdf:type rdf:Property ;
    rdfs:label 'Employee Acknowledgement Date' ;
    rdfs:comment 'Date when the employee acknowledged the performance review. Null if not yet acknowledged.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:employeeAcknowledgementFlag rdf:type rdf:Property ;
    rdfs:label 'Employee Acknowledgement Flag' ;
    rdfs:comment 'Indicates whether the employee has acknowledged receipt and review of the performance appraisal. True if acknowledged, False otherwise.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:employeeComments rdf:type rdf:Property ;
    rdfs:label 'Employee Comments' ;
    rdfs:comment 'Comments or feedback provided by the employee in response to the performance review. Allows employee to provide their perspective and input.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadershipCompetencyRating rdf:type rdf:Property ;
    rdfs:label 'Leadership Competency Rating' ;
    rdfs:comment 'Rating for leadership and management competencies. Applicable to supervisory and management roles. Not applicable for non-supervisory positions.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:objectiveAchievementScore rdf:type rdf:Property ;
    rdfs:label 'Objective Achievement Score' ;
    rdfs:comment 'Percentage score representing achievement of individual objectives and key results set at the beginning of the review period. Scale 0.00 to 100.00.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overallRating rdf:type rdf:Property ;
    rdfs:label 'Overall Rating' ;
    rdfs:comment 'Overall performance rating assigned to the employee for the review period. Standard five-point scale used across all staff categories.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overallRatingScore rdf:type rdf:Property ;
    rdfs:label 'Overall Rating Score' ;
    rdfs:comment 'Numeric score corresponding to the overall rating, typically on a scale of 1.00 to 5.00. Used for quantitative analysis and compensation decisions.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceImprovementPlanFlag rdf:type rdf:Property ;
    rdfs:label 'Performance Improvement Plan Flag' ;
    rdfs:comment 'Indicates whether a formal Performance Improvement Plan has been initiated as a result of this review. True if PIP initiated, False otherwise.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:promotionReadinessTimeline rdf:type rdf:Property ;
    rdfs:label 'Promotion Readiness Timeline' ;
    rdfs:comment 'Estimated timeline for promotion readiness if promotion is recommended. Indicates when the employee is expected to be ready for the next level.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionRecommendationFlag rdf:type rdf:Property ;
    rdfs:label 'Promotion Recommendation Flag' ;
    rdfs:comment 'Indicates whether the reviewer recommends the employee for promotion consideration. True if recommended, False otherwise.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewCycleType rdf:type rdf:Property ;
    rdfs:label 'Review Cycle Type' ;
    rdfs:comment 'Type of performance review cycle. Includes annual reviews, mid-year reviews, probation reviews, line checks for flight crew, recurrent training assessments, and special reviews.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Review Period End Date' ;
    rdfs:comment 'End date of the performance period being evaluated.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Review Period Start Date' ;
    rdfs:comment 'Start date of the performance period being evaluated.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reviewStatus rdf:type rdf:Property ;
    rdfs:label 'Review Status' ;
    rdfs:comment 'Current lifecycle status of the performance review. Tracks progression from draft through completion and employee acknowledgement. [ENUM-REF-CANDIDATE: draft|submitted|in_review|approved|completed|acknowledged|disputed — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reviewerComments rdf:type rdf:Property ;
    rdfs:label 'Reviewer Comments' ;
    rdfs:comment 'Detailed comments and observations from the reviewer. Provides context and justification for ratings and recommendations.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyComplianceRating rdf:type rdf:Property ;
    rdfs:label 'Safety Compliance Rating' ;
    rdfs:comment 'Rating for safety compliance and adherence to Safety Management System (SMS) requirements. Critical for all operational roles including flight crew, cabin crew, and ground operations.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secondLevelApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Second Level Approval Date' ;
    rdfs:comment 'Date when the second-level reviewer approved the performance review. Null if not yet approved.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:staffCategory rdf:type rdf:Property ;
    rdfs:label 'Staff Category' ;
    rdfs:comment 'Category of airline staff being reviewed. Different categories may have specialized competency frameworks and rating criteria.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:strengthsSummary rdf:type rdf:Property ;
    rdfs:label 'Strengths Summary' ;
    rdfs:comment 'Narrative summary of the employee\'s key strengths and positive contributions during the review period.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalCompetencyRating rdf:type rdf:Property ;
    rdfs:label 'Technical Competency Rating' ;
    rdfs:comment 'Rating for technical skills and job-specific competencies. For flight crew includes type ratings, procedures knowledge, and technical proficiency. For ground staff includes operational systems proficiency.' ;
    rdfs:domain ind:PerformanceReview ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:positionId rdf:type rdf:Property ;
    rdfs:label 'Position Id' ;
    rdfs:comment 'Primary key for position' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Position .

ind:reportsToPositionId rdf:type rdf:Property ;
    rdfs:label 'Reports To Position Id' ;
    rdfs:comment 'Foreign key reference to the position that this position reports to in the organizational hierarchy. Null for top-level executive positions.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Position .

ind:baseStationCode rdf:type rdf:Property ;
    rdfs:label 'Base Station Code' ;
    rdfs:comment 'IATA three-letter airport code for the crew base or work location assigned to this position. Determines domicile for crew scheduling and commuting eligibility.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exemptStatus rdf:type rdf:Property ;
    rdfs:label 'Exempt Status' ;
    rdfs:comment 'Indicates whether the position is exempt from overtime pay regulations under labor law (True) or non-exempt and eligible for overtime (False).' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fteAllocation rdf:type rdf:Property ;
    rdfs:label 'Fte Allocation' ;
    rdfs:comment 'Full-time equivalent allocation for the position. 1.00 represents a full-time position; fractional values represent part-time or shared positions.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gradeBand rdf:type rdf:Property ;
    rdfs:label 'Grade Band' ;
    rdfs:comment 'Compensation grade or pay band assigned to the position. Determines salary range, benefits eligibility, and career progression path.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icaoLicenceCategory rdf:type rdf:Property ;
    rdfs:label 'Icao Licence Category' ;
    rdfs:comment 'ICAO-defined licence category required for the position (e.g., ATPL, CPL, cabin crew attestation). Applicable to flight crew and safety-critical operational positions.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageRequirements rdf:type rdf:Property ;
    rdfs:label 'Language Requirements' ;
    rdfs:comment 'Language proficiency requirements for the position (e.g., English ICAO Level 4, Mandarin fluent). Critical for flight crew and customer-facing positions.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumFlightHours rdf:type rdf:Property ;
    rdfs:label 'Minimum Flight Hours' ;
    rdfs:comment 'Minimum total flight hours required for the position. Applicable to flight crew positions. Used for recruitment and internal promotion eligibility.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:positionDescription rdf:type rdf:Property ;
    rdfs:label 'Position Description' ;
    rdfs:comment 'Detailed description of the positions responsibilities, duties, and scope of authority. Used for recruitment, performance management, and organizational planning.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredCertifications rdf:type rdf:Property ;
    rdfs:label 'Required Certifications' ;
    rdfs:comment 'Professional certifications or qualifications required for the position (e.g., A&P licence, dispatch licence, safety auditor certification). Multiple certifications separated by semicolon.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityClearanceLevel rdf:type rdf:Property ;
    rdfs:label 'Security Clearance Level' ;
    rdfs:comment 'Security clearance or background check level required for the position. Determines access to secure areas, sensitive information, and critical systems.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seniorityListCode rdf:type rdf:Property ;
    rdfs:label 'Seniority List Code' ;
    rdfs:comment 'Code identifying the seniority list or bidding group for the position. Used in crew scheduling, vacation bidding, and base assignment processes.' ;
    rdfs:domain ind:Position ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:typeRatingRequired rdf:type rdf:Property ;
    rdfs:label 'Type Rating Required' ;
    rdfs:comment 'Aircraft type rating(s) required for the position (e.g., B737, A320, B777). Applicable to pilot and flight engineer positions. Multiple ratings separated by semicolon.' ;
    rdfs:domain ind:Workforce ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryRecruitmentEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Recruitment Employee Id' ;
    rdfs:comment 'Reference to the employee who is the hiring manager responsible for this requisition and will make the final hiring decision.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:quaternaryRecruitmentReplacementEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Quaternary Recruitment Replacement Employee Id' ;
    rdfs:comment 'For backfill or replacement requisitions, reference to the employee who is being replaced (due to departure, promotion, or transfer). Null for new headcount requisitions.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryRecruitmentApprovedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Recruitment Approved By Employee Id' ;
    rdfs:comment 'Reference to the employee (typically senior manager or HR director) who provided final approval for this requisition.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:approvedBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Approved Budget Amount' ;
    rdfs:comment 'Total approved budget allocated for this recruitment requisition, covering salary, benefits, relocation, and recruitment costs. Expressed in the airline\'s reporting currency.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Budget Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the approved budget amount.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diversityInitiativeFlag rdf:type rdf:Property ;
    rdfs:label 'Diversity Initiative Flag' ;
    rdfs:comment 'Indicates whether this requisition is part of a diversity and inclusion hiring initiative or targeted recruitment program.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:externalPostingFlag rdf:type rdf:Property ;
    rdfs:label 'External Posting Flag' ;
    rdfs:comment 'Indicates whether this requisition should be posted to external job boards and public career sites, or restricted to internal candidates only.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jobDescriptionText rdf:type rdf:Property ;
    rdfs:label 'Job Description Text' ;
    rdfs:comment 'Detailed description of the role, responsibilities, qualifications, and requirements for the position.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobPostingTitle rdf:type rdf:Property ;
    rdfs:label 'Job Posting Title' ;
    rdfs:comment 'Public-facing job title to be used in external job postings and advertisements.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberOfVacancies rdf:type rdf:Property ;
    rdfs:label 'Number Of Vacancies' ;
    rdfs:comment 'Total number of open positions to be filled under this requisition.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:postingEndDate rdf:type rdf:Property ;
    rdfs:label 'Posting End Date' ;
    rdfs:comment 'Date when the job posting will be removed from job boards and no longer accept applications.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:postingStartDate rdf:type rdf:Property ;
    rdfs:label 'Posting Start Date' ;
    rdfs:comment 'Date when the job posting becomes visible to candidates on internal and external job boards.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recruitmentChannel rdf:type rdf:Property ;
    rdfs:label 'Recruitment Channel' ;
    rdfs:comment 'Primary channel through which candidates will be sourced: internal (existing employees), external (public job boards), agency (third-party recruiters), employee referral program, campus recruitment, or military transition programs for ex-service personnel.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relocationAssistanceFlag rdf:type rdf:Property ;
    rdfs:label 'Relocation Assistance Flag' ;
    rdfs:comment 'Indicates whether relocation assistance is available for candidates who need to relocate for this position.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:remoteWorkEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Remote Work Eligible Flag' ;
    rdfs:comment 'Indicates whether the position is eligible for remote or hybrid work arrangements.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiredStartDate rdf:type rdf:Property ;
    rdfs:label 'Required Start Date' ;
    rdfs:comment 'Target date by which the hired candidate(s) must commence employment to meet operational needs.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:requisitionApprovedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Requisition Approved Timestamp' ;
    rdfs:comment 'Date and time when the recruitment requisition received final approval and became active for recruiting.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requisitionClosedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Requisition Closed Timestamp' ;
    rdfs:comment 'Date and time when the recruitment requisition was closed (filled, cancelled, or otherwise completed).' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requisitionCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Requisition Created Timestamp' ;
    rdfs:comment 'Date and time when the recruitment requisition was first created in the system.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:requisitionNotes rdf:type rdf:Property ;
    rdfs:label 'Requisition Notes' ;
    rdfs:comment 'Free-text field for additional notes, special instructions, or context about the requisition for recruiters and hiring managers.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requisitionStatus rdf:type rdf:Property ;
    rdfs:label 'Requisition Status' ;
    rdfs:comment 'Current lifecycle status of the recruitment requisition: draft (being prepared), pending approval (awaiting management sign-off), approved (authorized to recruit), active (recruiting in progress), on hold (temporarily paused), filled (all vacancies filled), cancelled (requisition withdrawn), closed (completed and archived). [ENUM-REF-CANDIDATE: draft|pending_approval|approved|active|on_hold|filled|cancelled|closed — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requisitionType rdf:type rdf:Property ;
    rdfs:label 'Requisition Type' ;
    rdfs:comment 'Type of recruitment requisition indicating the business driver: new headcount expansion, backfill for departure, replacement for terminated employee, ACMI (Aircraft Crew Maintenance Insurance) crew intake for wet lease operations, seasonal demand, or project-based temporary hire.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityClearanceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Security Clearance Required Flag' ;
    rdfs:comment 'Indicates whether the position requires aviation security clearance or background checks per TSA or equivalent authority requirements.' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:workScheduleType rdf:type rdf:Property ;
    rdfs:label 'Work Schedule Type' ;
    rdfs:comment 'Expected work schedule pattern for the position: full-time (standard hours), part-time (reduced hours), shift work (rotating shifts), roster-based (crew scheduling), on-call (as-needed availability).' ;
    rdfs:domain ind:RecruitmentRequisition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:staffTravelEntitlementId rdf:type rdf:Property ;
    rdfs:label 'Staff Travel Entitlement Id' ;
    rdfs:comment 'Unique identifier for the staff travel entitlement record. Primary key.' ;
    rdfs:domain ind:StaffTravelEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:advanceBookingDaysMaximum rdf:type rdf:Property ;
    rdfs:label 'Advance Booking Days Maximum' ;
    rdfs:comment 'Maximum number of days in advance that staff travel can be booked under this entitlement. Null if no maximum advance booking restriction applies.' ;
    rdfs:domain ind:StaffTravelEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:advanceBookingDaysMinimum rdf:type rdf:Property ;
    rdfs:label 'Advance Booking Days Minimum' ;
    rdfs:comment 'Minimum number of days in advance that staff travel must be booked under this entitlement. Null if no minimum advance booking requirement applies.' ;
    rdfs:domain ind:StaffTravelEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:annualAllocationSectors rdf:type rdf:Property ;
    rdfs:label 'Annual Allocation Sectors' ;
    rdfs:comment 'Number of flight sectors (individual flight segments) allocated to the employee per calendar year under this entitlement. Null if allocation is measured in trips instead of sectors.' ;
    rdfs:domain ind:StaffTravelEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:annualAllocationTrips rdf:type rdf:Property ;
    rdfs:label 'Annual Allocation Trips' ;
    rdfs:comment 'Number of round trips or one-way trips allocated to the employee per calendar year under this entitlement. Null if allocation is measured in sectors instead of trips.' ;
    rdfs:domain ind:StaffTravelEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:blackoutDatesApplyFlag rdf:type rdf:Property ;
    rdfs:label 'Blackout Dates Apply Flag' ;
    rdfs:comment 'Indicates whether blackout dates (peak travel periods where staff travel is restricted) apply to this entitlement. True if blackout restrictions apply, false if entitlement is exempt from blackout dates.' ;
    rdfs:domain ind:StaffTravelEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:carryForwardAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Carry Forward Allowed Flag' ;
    rdfs:comment 'Indicates whether unused allocation from the current year can be carried forward to the next calendar year. True if carry-forward is permitted, false otherwise.' ;
    rdfs:domain ind:StaffTravelEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:carryForwardLimitSectors rdf:type rdf:Property ;
    rdfs:label 'Carry Forward Limit Sectors' ;
    rdfs:comment 'Maximum number of unused sectors that can be carried forward to the next calendar year. Null if no carry-forward is allowed or if measured in trips.' ;
    rdfs:domain ind:StaffTravelEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:carryForwardLimitTrips rdf:type rdf:Property ;
    rdfs:label 'Carry Forward Limit Trips' ;
    rdfs:comment 'Maximum number of unused trips that can be carried forward to the next calendar year. Null if no carry-forward is allowed or if measured in sectors.' ;
    rdfs:domain ind:StaffTravelEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eligibilityTier rdf:type rdf:Property ;
    rdfs:label 'Eligibility Tier' ;
    rdfs:comment 'Tier classification determining the level of travel benefits based on employee grade, tenure, and position. Higher tiers receive more generous allocations and priority. [ENUM-REF-CANDIDATE: tier_1|tier_2|tier_3|tier_4|executive|management|operational|probationary — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:StaffTravelEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entitlementCode rdf:type rdf:Property ;
    rdfs:label 'Entitlement Code' ;
    rdfs:comment 'Unique business identifier for this entitlement record, used for operational reference and tracking.' ;
    rdfs:domain ind:StaffTravelEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entitlementType rdf:type rdf:Property ;
    rdfs:label 'Entitlement Type' ;
    rdfs:comment 'Type of staff travel concession granted. ID90 standby (90% discount standby), ID50 confirmed (50% discount confirmed), ID75 standby (75% discount standby), ZED interline (Zonal Employee Discount for interline travel), rebate coupon (fixed rebate voucher), positive space (confirmed seat), staff leisure (personal travel), staff business (official business travel). [ENUM-REF-CANDIDATE: ID90_standby|ID50_confirmed|ID75_standby|ZED_interline|rebate_coupon|positive_space|staff_leisure|staff_business — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:StaffTravelEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interlinePartnerAgreements rdf:type rdf:Property ;
    rdfs:label 'Interline Partner Agreements' ;
    rdfs:comment 'Comma-separated list of IATA airline codes representing interline partner airlines where this entitlement can be used for ZED or reciprocal staff travel. Example: BA,LH,AF,QF. Null if entitlement is restricted to own airline only.' ;
    rdfs:domain ind:StaffTravelEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumNomineesCount rdf:type rdf:Property ;
    rdfs:label 'Maximum Nominees Count' ;
    rdfs:comment 'Maximum number of eligible nominees (spouse, dependants, parents) who can be registered under this entitlement. Null if no limit applies.' ;
    rdfs:domain ind:StaffTravelEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nomineeDependantsEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Nominee Dependants Eligible Flag' ;
    rdfs:comment 'Indicates whether the employees dependent children are eligible to use this travel entitlement as nominees. True if dependants are eligible, false otherwise.' ;
    rdfs:domain ind:StaffTravelEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nomineeParentsEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Nominee Parents Eligible Flag' ;
    rdfs:comment 'Indicates whether the employees parents are eligible to use this travel entitlement as nominees. True if parents are eligible, false otherwise.' ;
    rdfs:domain ind:StaffTravelEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nomineeSpouseEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Nominee Spouse Eligible Flag' ;
    rdfs:comment 'Indicates whether the employees spouse or domestic partner is eligible to use this travel entitlement as a nominee. True if spouse is eligible, false otherwise.' ;
    rdfs:domain ind:StaffTravelEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:policyVersion rdf:type rdf:Property ;
    rdfs:label 'Policy Version' ;
    rdfs:comment 'Version number of the staff travel policy under which this entitlement was granted. Used for tracking policy changes over time and ensuring compliance with the applicable policy version.' ;
    rdfs:domain ind:StaffTravelEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remainingAllocationSectors rdf:type rdf:Property ;
    rdfs:label 'Remaining Allocation Sectors' ;
    rdfs:comment 'Number of sectors remaining in the annual allocation available for future bookings. Calculated as annual_allocation_sectors minus used_allocation_sectors.' ;
    rdfs:domain ind:StaffTravelEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:remainingAllocationTrips rdf:type rdf:Property ;
    rdfs:label 'Remaining Allocation Trips' ;
    rdfs:comment 'Number of trips remaining in the annual allocation available for future bookings. Calculated as annual_allocation_trips minus used_allocation_trips.' ;
    rdfs:domain ind:StaffTravelEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceChargeCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Service Charge Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the service charge amount. Example: USD, EUR, GBP. Null if no service charge applies.' ;
    rdfs:domain ind:StaffTravelEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:staffTravelEntitlementStatus rdf:type rdf:Property ;
    rdfs:label 'Staff Travel Entitlement Status' ;
    rdfs:comment 'Current lifecycle status of the travel entitlement. Active entitlements can be used for booking; suspended entitlements are temporarily blocked; expired entitlements have passed their validity period; revoked entitlements are permanently cancelled.' ;
    rdfs:domain ind:StaffTravelEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxesFeesWaivedFlag rdf:type rdf:Property ;
    rdfs:label 'Taxes Fees Waived Flag' ;
    rdfs:comment 'Indicates whether airport taxes, fuel surcharges, and government fees are waived for staff travel bookings under this entitlement. True if taxes and fees are waived, false if employee must pay taxes and fees.' ;
    rdfs:domain ind:StaffTravelEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:unionAgreementCode rdf:type rdf:Property ;
    rdfs:label 'Union Agreement Code' ;
    rdfs:comment 'Code identifying the collective bargaining agreement or union contract that governs this travel entitlement. Null if entitlement is not governed by a union agreement.' ;
    rdfs:domain ind:StaffTravelEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usedAllocationSectors rdf:type rdf:Property ;
    rdfs:label 'Used Allocation Sectors' ;
    rdfs:comment 'Number of sectors from the annual allocation that have been consumed year-to-date. Updated after each completed staff travel booking.' ;
    rdfs:domain ind:StaffTravelEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:usedAllocationTrips rdf:type rdf:Property ;
    rdfs:label 'Used Allocation Trips' ;
    rdfs:comment 'Number of trips from the annual allocation that have been consumed year-to-date. Updated after each completed staff travel booking.' ;
    rdfs:domain ind:StaffTravelEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedTrainingOrganisation rdf:type rdf:Property ;
    rdfs:label 'Approved Training Organisation' ;
    rdfs:comment 'Name of the EASA/FAA/ICAO-approved training organisation or internal training department authorized to deliver this course.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:atoApprovalNumber rdf:type rdf:Property ;
    rdfs:label 'Ato Approval Number' ;
    rdfs:comment 'Regulatory approval or certification number issued by the civil aviation authority to the training organisation for this course.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationIssuedFlag rdf:type rdf:Property ;
    rdfs:label 'Certification Issued Flag' ;
    rdfs:comment 'Indicates whether successful completion of this course results in a formal certification, license endorsement, or type rating. True if certification is issued, False if course is for awareness or development only.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificationType rdf:type rdf:Property ;
    rdfs:label 'Certification Type' ;
    rdfs:comment 'Type of certification or credential awarded upon successful completion. Examples: Type Rating A320, Dangerous Goods Certification, CRM Certificate, Safety Management System Certification. Null if no certification is issued.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costPerParticipant rdf:type rdf:Property ;
    rdfs:label 'Cost Per Participant' ;
    rdfs:comment 'Standard cost to deliver the training course per participant, including instructor fees, materials, simulator time, and facility costs. Used for training budget planning and cost allocation.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:courseCategory rdf:type rdf:Property ;
    rdfs:label 'Course Category' ;
    rdfs:comment 'Classification of the training course by functional area. Type rating refers to aircraft-specific pilot certification, recurrent refers to periodic refresher training, regulatory refers to mandated compliance training. [ENUM-REF-CANDIDATE: type_rating|recurrent|regulatory|leadership|safety|ground_ops|cabin_crew|technical|customer_service|security — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courseCode rdf:type rdf:Property ;
    rdfs:label 'Course Code' ;
    rdfs:comment 'Unique alphanumeric code identifying the training course in the airline\'s training management system. Used for scheduling and compliance tracking.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courseDescription rdf:type rdf:Property ;
    rdfs:label 'Course Description' ;
    rdfs:comment 'Detailed narrative description of the course content, learning objectives, and outcomes. Used for course catalogue and employee self-service portals.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courseName rdf:type rdf:Property ;
    rdfs:label 'Course Name' ;
    rdfs:comment 'Full descriptive name of the training course or programme.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courseStatus rdf:type rdf:Property ;
    rdfs:label 'Course Status' ;
    rdfs:comment 'Current lifecycle status of the training course. Active courses are available for scheduling. Retired courses are no longer offered but retained for historical compliance records.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:courseVersion rdf:type rdf:Property ;
    rdfs:label 'Course Version' ;
    rdfs:comment 'Version number of the course curriculum. Incremented when course content, duration, or regulatory requirements change. Format: major.minor (e.g., 2.1).' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageOfInstruction rdf:type rdf:Property ;
    rdfs:label 'Language Of Instruction' ;
    rdfs:comment 'Two-letter ISO 639-1 language code for the primary language in which the course is delivered. Examples: EN (English), FR (French), DE (German).' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumParticipants rdf:type rdf:Property ;
    rdfs:label 'Maximum Participants' ;
    rdfs:comment 'Maximum number of participants allowed per training session. Driven by classroom capacity, simulator availability, or instructor-to-student ratio requirements.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumPassScore rdf:type rdf:Property ;
    rdfs:label 'Minimum Pass Score' ;
    rdfs:comment 'Minimum score or percentage required to successfully complete the course. Typically expressed as a percentage (e.g., 80.00 for 80%).' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prerequisiteCourses rdf:type rdf:Property ;
    rdfs:label 'Prerequisite Courses' ;
    rdfs:comment 'Comma-separated list of course codes that must be completed before enrolling in this course. Null if no prerequisites exist.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recurrenceIntervalMonths rdf:type rdf:Property ;
    rdfs:label 'Recurrence Interval Months' ;
    rdfs:comment 'Number of months between required recurrent training sessions. Null if the course is not recurrent. Common values: 12 (annual), 24 (biennial), 6 (semi-annual).' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulationReference rdf:type rdf:Property ;
    rdfs:label 'Regulation Reference' ;
    rdfs:comment 'Citation of the specific ICAO, EASA, FAA, or national civil aviation authority regulation that mandates this training course. Examples: ICAO Annex 6, EASA Part-ORO, FAA 14 CFR Part 121.427.' ;
    rdfs:domain ind:TrainingCourse ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingRecordId rdf:type rdf:Property ;
    rdfs:label 'Training Record Id' ;
    rdfs:comment 'Primary key for training_record' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryTrainingEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Training Employee Id' ;
    rdfs:comment 'Reference to the employee who completed this training event. Links to the employee master record in the workforce domain.' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:trainingCentreStationId rdf:type rdf:Property ;
    rdfs:label 'Training Centre Station Id' ;
    rdfs:comment 'Foreign key linking to airport.station. Business justification: Training centers are airport stations. Normalize code to FK for training logistics, travel cost allocation, simulator facility management, and training capacity planning.' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Station .

ind:approvalAuthorityCode rdf:type rdf:Property ;
    rdfs:label 'Approval Authority Code' ;
    rdfs:comment 'Code identifying the regulatory authority or internal approval body that approved or certified this training event. Used for compliance tracking and audit trails.' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateIssuedDate rdf:type rdf:Property ;
    rdfs:label 'Certificate Issued Date' ;
    rdfs:comment 'Date when the training certificate or qualification was officially issued by the regulatory authority or training organization.' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:externalProviderFlag rdf:type rdf:Property ;
    rdfs:label 'External Provider Flag' ;
    rdfs:comment 'Indicates whether the training was conducted by an external training provider or approved training organization (ATO) rather than internal airline training resources. True for external providers, false for internal training.' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:externalProviderName rdf:type rdf:Property ;
    rdfs:label 'External Provider Name' ;
    rdfs:comment 'Name of the external training organization or approved training organization (ATO) that conducted the training. Null for internal training events.' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mandatoryFlag rdf:type rdf:Property ;
    rdfs:label 'Mandatory Flag' ;
    rdfs:comment 'Indicates whether this training is mandatory for regulatory compliance or operational qualification. True for required training such as proficiency checks, dangerous goods, security, and type ratings. False for optional or developmental training.' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:passingScoreThreshold rdf:type rdf:Property ;
    rdfs:label 'Passing Score Threshold' ;
    rdfs:comment 'Minimum score required to pass the training event, expressed as a percentage (0.00 to 100.00). Defines the pass/fail boundary for graded assessments.' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recurrencyIntervalMonths rdf:type rdf:Property ;
    rdfs:label 'Recurrency Interval Months' ;
    rdfs:comment 'Number of months between required recurrent training events. Common values: 12 months for proficiency checks, 24 months for dangerous goods training, 36 months for security training. Null for non-recurrent training.' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recurrentFlag rdf:type rdf:Property ;
    rdfs:label 'Recurrent Flag' ;
    rdfs:comment 'Indicates whether this training is recurrent (requires periodic renewal) or one-time. True for recurrent training such as annual proficiency checks, biennial dangerous goods training, and periodic emergency procedures training.' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recurrentTrainingDueDate rdf:type rdf:Property ;
    rdfs:label 'Recurrent Training Due Date' ;
    rdfs:comment 'Date by which the employee must complete mandatory recurrent training (e.g., annual safety training, CRM, emergency procedures). Critical for regulatory compliance. [Moved from employee: This attribute represents the next due date for recurrent training, which is specific to each employee-course combination, not to the employee globally. Different courses have different recurrence intervals, so this belongs in the training_record association as next_due_date.]' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledStartDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Date' ;
    rdfs:comment 'Planned start date for the training event. Used for training scheduling and resource planning.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:score rdf:type rdf:Property ;
    rdfs:label 'Score' ;
    rdfs:comment 'Numerical score or grade achieved in the training event, expressed as a percentage (0.00 to 100.00). Applicable for assessments and examinations. Null for non-graded training such as briefings or awareness sessions.' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingResult rdf:type rdf:Property ;
    rdfs:label 'Training Result' ;
    rdfs:comment 'Outcome of the training event. Indicates whether the employee successfully passed, failed, did not complete, or withdrew from the training.' ;
    rdfs:domain ind:TrainingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkrideDate rdf:type rdf:Property ;
    rdfs:label 'Checkride Date' ;
    rdfs:comment 'The date when the practical test or skill test (checkride) for the type rating was successfully completed.' ;
    rdfs:domain ind:TypeRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:currentValidityStartDate rdf:type rdf:Property ;
    rdfs:label 'Current Validity Start Date' ;
    rdfs:comment 'The start date of the current validity period for this type rating, typically following the most recent revalidation or renewal.' ;
    rdfs:domain ind:TypeRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:endorsements rdf:type rdf:Property ;
    rdfs:label 'Endorsements' ;
    rdfs:comment 'Additional endorsements or authorizations associated with the type rating (e.g., ETOPS, CAT II/III, RVSM, RNP).' ;
    rdfs:domain ind:TypeRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:examinerName rdf:type rdf:Property ;
    rdfs:label 'Examiner Name' ;
    rdfs:comment 'Name of the designated pilot examiner (DPE) or type rating examiner (TRE) who conducted the checkride.' ;
    rdfs:domain ind:TypeRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fleetTransitionSourceType rdf:type rdf:Property ;
    rdfs:label 'Fleet Transition Source Type' ;
    rdfs:comment 'The aircraft type from which the employee transitioned when obtaining this type rating, if applicable (used for fleet transition planning).' ;
    rdfs:domain ind:TypeRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initialIssueDate rdf:type rdf:Property ;
    rdfs:label 'Initial Issue Date' ;
    rdfs:comment 'The date when the type rating was first issued to the employee.' ;
    rdfs:domain ind:TypeRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastRevalidationDate rdf:type rdf:Property ;
    rdfs:label 'Last Revalidation Date' ;
    rdfs:comment 'The date of the most recent revalidation or proficiency check that extended the validity of this type rating.' ;
    rdfs:domain ind:TypeRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lineCheckDate rdf:type rdf:Property ;
    rdfs:label 'Line Check Date' ;
    rdfs:comment 'Date of the most recent line check or line operational evaluation conducted on this aircraft type.' ;
    rdfs:domain ind:TypeRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextRevalidationDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Revalidation Due Date' ;
    rdfs:comment 'The date by which the next revalidation or proficiency check must be completed to maintain currency.' ;
    rdfs:domain ind:TypeRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:picHoursOnType rdf:type rdf:Property ;
    rdfs:label 'Pic Hours On Type' ;
    rdfs:comment 'Total flight hours logged as Pilot in Command on this specific aircraft type.' ;
    rdfs:domain ind:TypeRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proficiencyCheckDate rdf:type rdf:Property ;
    rdfs:label 'Proficiency Check Date' ;
    rdfs:comment 'Date of the most recent operator proficiency check (OPC) or competency check for this type rating.' ;
    rdfs:domain ind:TypeRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ratingCategory rdf:type rdf:Property ;
    rdfs:label 'Rating Category' ;
    rdfs:comment 'Category of type rating qualification: PIC (Pilot in Command), SIC (Second in Command), TRI (Type Rating Instructor), TRE (Type Rating Examiner), FE (Flight Engineer), AME (Aircraft Maintenance Engineer).' ;
    rdfs:domain ind:TypeRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recencyCheckDate rdf:type rdf:Property ;
    rdfs:label 'Recency Check Date' ;
    rdfs:comment 'Date of the most recent recency or currency check (e.g., three takeoffs and landings within 90 days) for this type rating.' ;
    rdfs:domain ind:TypeRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:simulatorQualificationLevel rdf:type rdf:Property ;
    rdfs:label 'Simulator Qualification Level' ;
    rdfs:comment 'The qualification level of the flight simulator used for type rating training and testing (Level A/B/C/D, FTD - Flight Training Device, FFS - Full Flight Simulator).' ;
    rdfs:domain ind:TypeRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalFlightHoursOnType rdf:type rdf:Property ;
    rdfs:label 'Total Flight Hours On Type' ;
    rdfs:comment 'Cumulative total flight hours logged by the employee on this specific aircraft type since initial type rating.' ;
    rdfs:domain ind:TypeRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingOrganizationCode rdf:type rdf:Property ;
    rdfs:label 'Training Organization Code' ;
    rdfs:comment 'Code or identifier of the approved training organization (ATO) where the initial type rating training was completed.' ;
    rdfs:domain ind:TypeRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transitionTrainingHours rdf:type rdf:Property ;
    rdfs:label 'Transition Training Hours' ;
    rdfs:comment 'Total training hours required or completed for transition to this aircraft type from a previous type rating.' ;
    rdfs:domain ind:TypeRating ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:arbitrationClause rdf:type rdf:Property ;
    rdfs:label 'Arbitration Clause' ;
    rdfs:comment 'Terms and conditions for binding arbitration of unresolved disputes under this collective bargaining agreement.' ;
    rdfs:domain ind:UnionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bargainingUnit rdf:type rdf:Property ;
    rdfs:label 'Bargaining Unit' ;
    rdfs:comment 'Category of employees covered by this agreement (e.g., pilots, cabin crew, ground staff, mechanics, dispatchers, corporate employees). [ENUM-REF-CANDIDATE: pilots|cabin_crew|ground_staff|mechanics|dispatchers|corporate|other — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:UnionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coveredEmployeeCount rdf:type rdf:Property ;
    rdfs:label 'Covered Employee Count' ;
    rdfs:comment 'Total number of employees covered under this collective bargaining agreement at the time of ratification.' ;
    rdfs:domain ind:UnionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:durationMonths rdf:type rdf:Property ;
    rdfs:label 'Duration Months' ;
    rdfs:comment 'Total duration of the collective bargaining agreement in months from effective date to expiry date.' ;
    rdfs:domain ind:UnionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dutyHourLimitMonthly rdf:type rdf:Property ;
    rdfs:label 'Duty Hour Limit Monthly' ;
    rdfs:comment 'Maximum number of duty hours per month allowed under this agreement for covered employees.' ;
    rdfs:domain ind:UnionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:flightHourLimitMonthly rdf:type rdf:Property ;
    rdfs:label 'Flight Hour Limit Monthly' ;
    rdfs:comment 'Maximum number of flight hours per month allowed under this agreement for flight crew members.' ;
    rdfs:domain ind:UnionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:furloughRecallProvisions rdf:type rdf:Property ;
    rdfs:label 'Furlough Recall Provisions' ;
    rdfs:comment 'Terms governing employee furloughs (temporary layoffs) and recall procedures, including seniority order and notification requirements.' ;
    rdfs:domain ind:UnionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grievanceProcedure rdf:type rdf:Property ;
    rdfs:label 'Grievance Procedure' ;
    rdfs:comment 'Formal process for resolving disputes and grievances between employees and management as outlined in the agreement.' ;
    rdfs:domain ind:UnionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:healthBenefitsSummary rdf:type rdf:Property ;
    rdfs:label 'Health Benefits Summary' ;
    rdfs:comment 'Summary of health insurance and medical benefits provisions negotiated in the agreement.' ;
    rdfs:domain ind:UnionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jobSecurityProvisions rdf:type rdf:Property ;
    rdfs:label 'Job Security Provisions' ;
    rdfs:comment 'Terms protecting employee job security, including no-furlough clauses, minimum fleet size commitments, and outsourcing restrictions.' ;
    rdfs:domain ind:UnionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managementSignatory rdf:type rdf:Property ;
    rdfs:label 'Management Signatory' ;
    rdfs:comment 'Name and title of the airline management representative who signed the collective bargaining agreement on behalf of the company.' ;
    rdfs:domain ind:UnionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumRestHours rdf:type rdf:Property ;
    rdfs:label 'Minimum Rest Hours' ;
    rdfs:comment 'Minimum consecutive rest hours required between duty periods as specified in the agreement.' ;
    rdfs:domain ind:UnionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:negotiatingCommitteeLead rdf:type rdf:Property ;
    rdfs:label 'Negotiating Committee Lead' ;
    rdfs:comment 'Name of the lead negotiator or committee chair representing the union during agreement negotiations.' ;
    rdfs:domain ind:UnionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:negotiationEndDate rdf:type rdf:Property ;
    rdfs:label 'Negotiation End Date' ;
    rdfs:comment 'Date when formal negotiations for this collective bargaining agreement concluded.' ;
    rdfs:domain ind:UnionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:negotiationStartDate rdf:type rdf:Property ;
    rdfs:label 'Negotiation Start Date' ;
    rdfs:comment 'Date when formal negotiations for this collective bargaining agreement commenced.' ;
    rdfs:domain ind:UnionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:payScaleStructure rdf:type rdf:Property ;
    rdfs:label 'Pay Scale Structure' ;
    rdfs:comment 'Description of the compensation structure defined in the agreement, including base pay scales, step progressions, and longevity increases.' ;
    rdfs:domain ind:UnionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratificationDate rdf:type rdf:Property ;
    rdfs:label 'Ratification Date' ;
    rdfs:comment 'Date when the union membership voted to approve and ratify the collective bargaining agreement.' ;
    rdfs:domain ind:UnionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:retirementBenefitsSummary rdf:type rdf:Property ;
    rdfs:label 'Retirement Benefits Summary' ;
    rdfs:comment 'Summary of pension, 401(k), and other retirement benefit provisions negotiated in the agreement.' ;
    rdfs:domain ind:UnionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scopeClause rdf:type rdf:Property ;
    rdfs:label 'Scope Clause' ;
    rdfs:comment 'Provisions defining the scope of work that must be performed by union members versus contractors or other carriers (critical for protecting union jobs).' ;
    rdfs:domain ind:UnionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seniorityBiddingRules rdf:type rdf:Property ;
    rdfs:label 'Seniority Bidding Rules' ;
    rdfs:comment 'Description of seniority-based bidding procedures for schedules, routes, bases, and equipment assignments as defined in the agreement.' ;
    rdfs:domain ind:UnionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unionAgreementStatus rdf:type rdf:Property ;
    rdfs:label 'Union Agreement Status' ;
    rdfs:comment 'Current lifecycle status of the collective bargaining agreement (draft, negotiation, ratification, active, expired, terminated, suspended). [ENUM-REF-CANDIDATE: draft|negotiation|ratification|active|expired|terminated|suspended — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:UnionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unionCode rdf:type rdf:Property ;
    rdfs:label 'Union Code' ;
    rdfs:comment 'Standardized abbreviation or code for the union (e.g., ALPA for Air Line Pilots Association, AFA for Association of Flight Attendants, IAM for International Association of Machinists, AMFA for Aircraft Mechanics Fraternal Association).' ;
    rdfs:domain ind:UnionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unionSignatory rdf:type rdf:Property ;
    rdfs:label 'Union Signatory' ;
    rdfs:comment 'Name and title of the union representative who signed the collective bargaining agreement on behalf of the union membership.' ;
    rdfs:domain ind:UnionAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentId rdf:type rdf:Property ;
    rdfs:label 'Enrollment Id' ;
    rdfs:comment 'Unique identifier for this benefit enrollment record. Primary key.' ;
    rdfs:domain ind:Enrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bookingSegmentId rdf:type rdf:Property ;
    rdfs:label 'Booking Segment Id' ;
    rdfs:comment 'Primary key uniquely identifying this passenger-flight booking segment' ;
    rdfs:domain ind:BookingSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:boardingSequence rdf:type rdf:Property ;
    rdfs:label 'Boarding Sequence' ;
    rdfs:comment 'Numeric boarding priority assigned to this passenger for this flight, determining boarding group and order. Lower numbers board first.' ;
    rdfs:domain ind:BookingSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fareBasis rdf:type rdf:Property ;
    rdfs:label 'Fare Basis' ;
    rdfs:comment 'The fare basis code indicating the specific fare rules, restrictions, and conditions applied to this passenger\'s ticket for this segment.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Segment Updated Timestamp' ;
    rdfs:comment 'Date and time when this booking segment was last modified. Updated on any change to segment details. UTC timestamp.' ;
    rdfs:domain ind:BookingSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:standbyPriority rdf:type rdf:Property ;
    rdfs:label 'Standby Priority' ;
    rdfs:comment 'Priority ranking for standby passengers on this flight segment. Lower numbers have higher priority for available seats. Null if passenger is confirmed.' ;
    rdfs:domain ind:BookingSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vendorCategoryQualificationId rdf:type rdf:Property ;
    rdfs:label 'Vendor Category Qualification Id' ;
    rdfs:comment 'Unique identifier for this vendor-category qualification record. Primary key.' ;
    rdfs:domain ind:VendorCategoryQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:categoryProcurementCategoryId rdf:type rdf:Property ;
    rdfs:label 'Category Procurement Category Id' ;
    rdfs:comment 'Foreign key linking to the procurement category for which the vendor is qualified' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProcurementCategory .

ind:categorySpecificLeadTimeDays rdf:type rdf:Property ;
    rdfs:label 'Category Specific Lead Time Days' ;
    rdfs:comment 'Average lead time in days from purchase order to delivery for this vendor supplying items in this category. May differ from vendor-level or category-level defaults. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:VendorCategoryQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:categorySpecificPaymentTerms rdf:type rdf:Property ;
    rdfs:label 'Category Specific Payment Terms' ;
    rdfs:comment 'Payment terms negotiated specifically for this vendor-category combination (e.g., Net 30, Net 60, 2/10 Net 30). May differ from the vendor\'s standard payment terms. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:VendorCategoryQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationLevel rdf:type rdf:Property ;
    rdfs:label 'Certification Level' ;
    rdfs:comment 'Tier or certification level assigned to this vendor for this specific category based on performance, capabilities, and compliance: gold (top tier), silver (preferred), bronze (approved), standard (qualified), conditional (approved with restrictions). Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceTierForCategory rdf:type rdf:Property ;
    rdfs:label 'Performance Tier For Category' ;
    rdfs:comment 'Performance rating assigned to this vendor for this specific category based on quality, delivery, cost, and service metrics: excellent (top performer), good (meets expectations), satisfactory (acceptable), needs_improvement (below target), poor (unacceptable). Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:VendorCategoryQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationDate rdf:type rdf:Property ;
    rdfs:label 'Qualification Date' ;
    rdfs:comment 'Date when the vendor was officially qualified or approved to supply goods/services in this category. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Qualification Expiry Date' ;
    rdfs:comment 'Date when this qualification expires and requires renewal or re-evaluation. Null for qualifications without expiry. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:VendorCategoryQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualificationNotes rdf:type rdf:Property ;
    rdfs:label 'Qualification Notes' ;
    rdfs:comment 'Free-text notes capturing special conditions, restrictions, or comments related to this vendor-category qualification (e.g., approved for emergency purchases only, requires dual approval above $50K).' ;
    rdfs:domain ind:VendorCategoryQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spendLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Spend Limit Amount' ;
    rdfs:comment 'Maximum spend amount (in base currency) allowed for this vendor within this category during the qualification period. Used for spend control and vendor diversification. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:VendorCategoryQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:passengerBookingPassengerId rdf:type rdf:Property ;
    rdfs:label 'Passenger Booking Passenger Id' ;
    rdfs:comment 'Primary key for passenger_booking_passenger' ;
    rdfs:domain ind:PassengerBookingPassenger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bookingPassengerId rdf:type rdf:Property ;
    rdfs:label 'Booking Passenger Id' ;
    rdfs:comment 'Unique identifier for this booking-passenger link record. Primary key.' ;
    rdfs:domain ind:PassengerBookingPassenger ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ReservationBookingPassenger .

ind:forwarderRouteAgreementId rdf:type rdf:Property ;
    rdfs:label 'Forwarder Route Agreement Id' ;
    rdfs:comment 'Unique identifier for this freight forwarder route agreement record. Primary key.' ;
    rdfs:domain ind:ForwarderRouteAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualVolumeShippedKg rdf:type rdf:Property ;
    rdfs:label 'Actual Volume Shipped Kg' ;
    rdfs:comment 'Cumulative cargo volume in kilograms shipped by this forwarder on this route during the current contract period. Used to track performance against minimum volume commitments.' ;
    rdfs:domain ind:ForwarderRouteAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumVolumeCommitmentKg rdf:type rdf:Property ;
    rdfs:label 'Minimum Volume Commitment Kg' ;
    rdfs:comment 'Minimum cargo volume in kilograms that the freight forwarder has committed to ship on this route within the contract period. Used for capacity planning and commercial performance tracking.' ;
    rdfs:domain ind:ForwarderRouteAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentTermsOverride rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Override' ;
    rdfs:comment 'Route-specific payment terms that override the forwarder\'s global payment terms. Captures negotiated terms such as \'Net 15\', \'Net 45\', or \'Prepaid\' that apply only to cargo shipments on this route.' ;
    rdfs:domain ind:ForwarderRouteAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredPartnerStatus rdf:type rdf:Property ;
    rdfs:label 'Preferred Partner Status' ;
    rdfs:comment 'Commercial status of the forwarder on this specific route: preferred (priority access and preferential rates), standard (normal commercial terms), restricted (limited capacity allocation). This status is route-specific and may vary across the forwarder\'s route portfolio.' ;
    rdfs:domain ind:ForwarderRouteAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityBookingFlag rdf:type rdf:Property ;
    rdfs:label 'Priority Booking Flag' ;
    rdfs:comment 'Indicates whether this freight forwarder has priority booking access on this route, allowing preferential space allocation during high-demand periods. Typically granted to preferred partners or high-volume forwarders.' ;
    rdfs:domain ind:ForwarderRouteAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:routeSpecificDiscountPercent rdf:type rdf:Property ;
    rdfs:label 'Route Specific Discount Percent' ;
    rdfs:comment 'Percentage discount applied to standard cargo rates for this forwarder on this specific route. Negotiated as part of route-level commercial agreements and may differ from the forwarder\'s global discount structure.' ;
    rdfs:domain ind:ForwarderRouteAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:routePromotionId rdf:type rdf:Property ;
    rdfs:label 'Route Promotion Id' ;
    rdfs:comment 'Primary key for route_promotion' ;
    rdfs:domain ind:RoutePromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualBookingCount rdf:type rdf:Property ;
    rdfs:label 'Actual Booking Count' ;
    rdfs:comment 'Actual number of bookings recorded for this route during the promotion period where the promotion was applied. Updated in real-time or batch. Used for performance tracking and ROI analysis. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:RoutePromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:competitiveImpactScore rdf:type rdf:Property ;
    rdfs:label 'Competitive Impact Score' ;
    rdfs:comment 'Quantitative score (0-100) measuring the competitive impact of this promotion on this specific route, considering market share changes, competitor response, and load factor improvements.' ;
    rdfs:domain ind:RoutePromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eligibleRoutes rdf:type rdf:Property ;
    rdfs:label 'Eligible Routes' ;
    rdfs:comment 'Comma-separated list of route codes or origin-destination pairs eligible for the promotion (e.g., \'JFK-LHR,LAX-NRT\'). Empty or \'ALL\' indicates no route restriction. Used for route-specific bonus campaigns. [Moved from loyalty_promotion: This is a denormalized comma-separated list of route codes that should be normalized into the route_promotion association table. Each route should be a separate association record rather than a text list. The detection reasoning explicitly states \'The eligible_routes field on loyalty_promotion is a denormalized list that should be normalized into a proper association table.\']' ;
    rdfs:domain ind:RoutePromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incrementalRevenue rdf:type rdf:Property ;
    rdfs:label 'Incremental Revenue' ;
    rdfs:comment 'Estimated incremental revenue generated by this route-promotion combination, calculated as the difference between actual revenue and baseline revenue projections. Used for promotion effectiveness analysis.' ;
    rdfs:domain ind:RoutePromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:routePromotionStatus rdf:type rdf:Property ;
    rdfs:label 'Route Promotion Status' ;
    rdfs:comment 'Current status of this route within the promotion: active (currently earning bonus miles), suspended (temporarily paused for this route), completed (promotion period ended for this route), cancelled (route removed from promotion). Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:RoutePromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeSpecificBonusMultiplier rdf:type rdf:Property ;
    rdfs:label 'Route Specific Bonus Multiplier' ;
    rdfs:comment 'Bonus miles multiplier specific to this route within the promotion (e.g., 2.5x for premium routes, 2.0x for standard routes). Overrides or refines the promotion-level bonus_miles_formula for this specific route. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:RoutePromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetBookingCount rdf:type rdf:Property ;
    rdfs:label 'Target Booking Count' ;
    rdfs:comment 'Target number of bookings expected for this route during the promotion period. Used for performance tracking and ROI analysis. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:RoutePromotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:passengerBookingId rdf:type rdf:Property ;
    rdfs:label 'Passenger Booking Id' ;
    rdfs:comment 'Primary key for passenger_booking' ;
    rdfs:domain ind:PassengerBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fareCurrency rdf:type rdf:Property ;
    rdfs:label 'Fare Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the fare amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:PassengerBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upgradeIndicator rdf:type rdf:Property ;
    rdfs:label 'Upgrade Indicator' ;
    rdfs:comment 'Flag indicating whether this booking was upgraded from the original booking class (e.g., operational upgrade, loyalty upgrade, paid upgrade).' ;
    rdfs:domain ind:PassengerBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:flightAllotmentId rdf:type rdf:Property ;
    rdfs:label 'Flight Allotment Id' ;
    rdfs:comment 'Primary key for flight_allotment' ;
    rdfs:domain ind:FlightAllotment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allotmentId rdf:type rdf:Property ;
    rdfs:label 'Allotment Id' ;
    rdfs:comment 'Unique identifier for this flight allotment record. Primary key.' ;
    rdfs:domain ind:FlightAllotment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CargoAllotment .

ind:createdDate rdf:type rdf:Property ;
    rdfs:label 'Created Date' ;
    rdfs:comment 'Timestamp when this allotment record was created in the system.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:productRouteAvailabilityId rdf:type rdf:Property ;
    rdfs:label 'Product Route Availability Id' ;
    rdfs:comment 'Unique identifier for this product-route availability configuration record. Primary key.' ;
    rdfs:domain ind:ProductRouteAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:acceptanceCutoffHoursOverride rdf:type rdf:Property ;
    rdfs:label 'Acceptance Cutoff Hours Override' ;
    rdfs:comment 'Number of hours before scheduled departure by which cargo must be accepted for this product on this route. Overrides the product\'s global cutoff when route-specific operational requirements apply (e.g., customs processing, security screening, connection timing).' ;
    rdfs:domain ind:ProductRouteAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bookingChannelRestrictions rdf:type rdf:Property ;
    rdfs:label 'Booking Channel Restrictions' ;
    rdfs:comment 'Comma-separated list of booking channels through which this product-route combination can be booked (e.g., direct, gsa, freight_forwarder, online). Used to control distribution and manage channel conflicts.' ;
    rdfs:domain ind:ProductRouteAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capacityAllocationKg rdf:type rdf:Property ;
    rdfs:label 'Capacity Allocation Kg' ;
    rdfs:comment 'Allocated cargo capacity in kilograms reserved for this product on this route per flight. Used for capacity management and revenue optimization. Null indicates no specific allocation (first-come-first-served).' ;
    rdfs:domain ind:ProductRouteAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumWeightKg rdf:type rdf:Property ;
    rdfs:label 'Maximum Weight Kg' ;
    rdfs:comment 'Maximum shipment weight in kilograms accepted for this product on this specific route. May differ from the product\'s global maximum due to aircraft type, route distance, or operational limitations.' ;
    rdfs:domain ind:ProductRouteAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumWeightKg rdf:type rdf:Property ;
    rdfs:label 'Minimum Weight Kg' ;
    rdfs:comment 'Minimum shipment weight in kilograms required for this product on this specific route. May differ from the product\'s global minimum due to route economics, aircraft capacity, or operational constraints.' ;
    rdfs:domain ind:ProductRouteAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operationalNotes rdf:type rdf:Property ;
    rdfs:label 'Operational Notes' ;
    rdfs:comment 'Free-text field capturing route-specific operational considerations, restrictions, or special handling requirements for this product on this route (e.g., \'Requires customs pre-clearance\', \'Limited to freighter flights only\', \'Subject to seasonal capacity constraints\').' ;
    rdfs:domain ind:ProductRouteAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateClassOverride rdf:type rdf:Property ;
    rdfs:label 'Rate Class Override' ;
    rdfs:comment 'Optional rate class code that overrides the product\'s default rate class for this specific route. Used when route-specific pricing structures apply due to competitive dynamics, bilateral agreements, or market conditions.' ;
    rdfs:domain ind:ProductRouteAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceAvailabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Service Availability Status' ;
    rdfs:comment 'Current operational status of this product on this route: active (currently bookable), suspended (temporarily unavailable), planned (future availability), discontinued (permanently removed). Controls booking system availability.' ;
    rdfs:domain ind:ProductRouteAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transitTimeHoursOverride rdf:type rdf:Property ;
    rdfs:label 'Transit Time Hours Override' ;
    rdfs:comment 'Committed transit time in hours for this product on this specific route. Overrides the product\'s global transit time commitment when route distance, connection patterns, or operational realities require different service level commitments.' ;
    rdfs:domain ind:ProductRouteAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:aircraftSponsorshipActivationId rdf:type rdf:Property ;
    rdfs:label 'Aircraft Sponsorship Activation Id' ;
    rdfs:comment 'Primary key for aircraft_sponsorship_activation' ;
    rdfs:domain ind:AircraftSponsorshipActivation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:activationId rdf:type rdf:Property ;
    rdfs:label 'Activation Id' ;
    rdfs:comment 'Unique system identifier for this specific aircraft-sponsorship activation record. Primary key.' ;
    rdfs:domain ind:AircraftSponsorshipActivation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SponsorshipActivation .

ind:activationEndDate rdf:type rdf:Property ;
    rdfs:label 'Activation End Date' ;
    rdfs:comment 'The date when the sponsorship branding was removed from the aircraft or the activation period concluded. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:AircraftSponsorshipActivation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:activationStartDate rdf:type rdf:Property ;
    rdfs:label 'Activation Start Date' ;
    rdfs:comment 'The date when the sponsorship branding was applied to the aircraft and became visible in operations. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:AircraftSponsorshipActivation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualFlightHours rdf:type rdf:Property ;
    rdfs:label 'Actual Flight Hours' ;
    rdfs:comment 'The actual number of flight hours accumulated by this aircraft while carrying this sponsorship branding, tracked for sponsor reporting and contract compliance. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:AircraftSponsorshipActivation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brandingType rdf:type rdf:Property ;
    rdfs:label 'Branding Type' ;
    rdfs:comment 'Classification of how the sponsorship is visually represented on this aircraft (e.g., full special livery, logo placement only, tail branding). Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:AircraftSponsorshipActivation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractualFlightHours rdf:type rdf:Property ;
    rdfs:label 'Contractual Flight Hours' ;
    rdfs:comment 'The minimum number of flight hours committed in the sponsorship contract for this specific aircraft activation, used to measure contractual delivery obligations. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:AircraftSponsorshipActivation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:liveryDesignReference rdf:type rdf:Property ;
    rdfs:label 'Livery Design Reference' ;
    rdfs:comment 'Reference code or identifier for the specific livery design applied to this aircraft for this sponsorship, linking to design documentation or paint shop specifications. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:AircraftSponsorshipActivation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paintApplicationDate rdf:type rdf:Property ;
    rdfs:label 'Paint Application Date' ;
    rdfs:comment 'The date when the sponsorship livery or branding was physically applied to the aircraft in the paint shop or maintenance facility.' ;
    rdfs:domain ind:AircraftSponsorshipActivation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paintRemovalDate rdf:type rdf:Property ;
    rdfs:label 'Paint Removal Date' ;
    rdfs:comment 'The date when the sponsorship livery or branding was physically removed from the aircraft.' ;
    rdfs:domain ind:AircraftSponsorshipActivation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:primaryRouteAssignment rdf:type rdf:Property ;
    rdfs:label 'Primary Route Assignment' ;
    rdfs:comment 'The primary route or geographic region where this branded aircraft is preferentially deployed to maximize sponsor visibility in target markets (e.g., \'North America\', \'Asia-Pacific routes\', \'European network\').' ;
    rdfs:domain ind:AircraftSponsorshipActivation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sponsorApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Sponsor Approval Date' ;
    rdfs:comment 'The date when the sponsor formally approved the livery design and activation plan for this specific aircraft.' ;
    rdfs:domain ind:AircraftSponsorshipActivation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:typeQualificationId rdf:type rdf:Property ;
    rdfs:label 'Type Qualification Id' ;
    rdfs:comment 'Unique identifier for this type qualification record. Primary key.' ;
    rdfs:domain ind:TypeQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:examinerQualifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Examiner Qualified Flag' ;
    rdfs:comment 'Indicates whether the employee holds examiner/check airman authorization for this aircraft type, enabling them to conduct proficiency checks, line checks, and certification evaluations. Required for regulatory compliance with FAA Part 121.411 and EASA OPS.' ;
    rdfs:domain ind:TypeQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:instructorQualifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Instructor Qualified Flag' ;
    rdfs:comment 'Indicates whether the employee holds instructor authorization for this aircraft type, enabling them to conduct training flights, simulator sessions, and ground school instruction. Critical for training program staffing and instructor scheduling.' ;
    rdfs:domain ind:TypeQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastProficiencyCheckDate rdf:type rdf:Property ;
    rdfs:label 'Last Proficiency Check Date' ;
    rdfs:comment 'Date of the most recent proficiency check (PC) or operator proficiency check (OPC) completed for this type qualification. Used to calculate next due date per regulatory recurrent training cycles (typically 6 or 12 months).' ;
    rdfs:domain ind:TypeQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextProficiencyCheckDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Proficiency Check Due Date' ;
    rdfs:comment 'Date by which the next proficiency check must be completed to maintain qualification currency. Monitored by crew scheduling and training departments to prevent qualification lapses.' ;
    rdfs:domain ind:TypeQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalHoursOnType rdf:type rdf:Property ;
    rdfs:label 'Total Hours On Type' ;
    rdfs:comment 'Cumulative flight hours or maintenance hours the employee has logged on this specific aircraft type. Used for experience-based crew pairing, insurance requirements, and proficiency assessment. Updated from flight operations or maintenance tracking systems.' ;
    rdfs:domain ind:TypeQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:typeQualificationDate rdf:type rdf:Property ;
    rdfs:label 'Type Qualification Date' ;
    rdfs:comment 'Date when the employee successfully completed initial type rating training and certification for this aircraft type. Used for seniority calculations and qualification history tracking.' ;
    rdfs:domain ind:TypeQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:typeQualificationStatus rdf:type rdf:Property ;
    rdfs:label 'Type Qualification Status' ;
    rdfs:comment 'Current lifecycle status of this type qualification. ACTIVE = current and valid for operations; EXPIRED = requires recurrent check; SUSPENDED = temporarily invalid due to medical/regulatory hold; IN_TRAINING = initial or upgrade training in progress; LAPSED = not maintained, requires full requalification.' ;
    rdfs:domain ind:TypeQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:typeRatingCodes rdf:type rdf:Property ;
    rdfs:label 'Type Rating Codes' ;
    rdfs:comment 'Comma-separated list of aircraft type rating codes the employee is certified to operate (e.g., B737, A320, B777). Applicable to pilots. [Moved from employee: The type_rating_codes attribute in employee is a comma-separated list attempting to denormalize the M:N relationship. This violates 1NF and prevents proper tracking of qualification-specific attributes (dates, status, hours, instructor flags) for each type. Each type rating should be a separate record in the type_qualification association with its own lifecycle data.]' ;
    rdfs:domain ind:TypeQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorContractId rdf:type rdf:Property ;
    rdfs:label 'Vendor Contract Id' ;
    rdfs:comment 'Unique identifier for this maintenance vendor contract record. Primary key.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:capabilityScope rdf:type rdf:Property ;
    rdfs:label 'Capability Scope' ;
    rdfs:comment 'Textual description of the specific maintenance capabilities, part categories, or service types covered under this contract (e.g., engine components, avionics repair, AOG support). Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCard rdf:type rdf:Property ;
    rdfs:label 'Rate Card' ;
    rdfs:comment 'Reference identifier or document number for the pricing schedule, labor rates, or unit costs applicable to this maintenance org-vendor contract. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:VendorContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stationMroContractId rdf:type rdf:Property ;
    rdfs:label 'Station Mro Contract Id' ;
    rdfs:comment 'Unique identifier for the station MRO contract record. Primary key.' ;
    rdfs:domain ind:StationMroContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextPerformanceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Performance Review Date' ;
    rdfs:comment 'Scheduled date for the next performance review or contract evaluation for this station-provider relationship.' ;
    rdfs:domain ind:StationMroContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:serviceScope rdf:type rdf:Property ;
    rdfs:label 'Service Scope' ;
    rdfs:comment 'Detailed description of the maintenance services covered under this contract at this station (e.g., line maintenance, overnight checks, component replacement, AOG support, scheduled inspections).' ;
    rdfs:domain ind:StationMroContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaTerms rdf:type rdf:Property ;
    rdfs:label 'Sla Terms' ;
    rdfs:comment 'Service Level Agreement terms and commitments for this station-provider contract, including response times, turnaround times, availability guarantees, and quality standards.' ;
    rdfs:domain ind:StationMroContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:twentyFourSevenCoverageFlag rdf:type rdf:Property ;
    rdfs:label 'Twenty Four Seven Coverage Flag' ;
    rdfs:comment 'Indicates whether the MRO provider offers 24/7 maintenance coverage at this station under this contract.' ;
    rdfs:domain ind:StationMroContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractInventoryAllocationId rdf:type rdf:Property ;
    rdfs:label 'Contract Inventory Allocation Id' ;
    rdfs:comment 'Unique surrogate identifier for this contract-flight allocation record' ;
    rdfs:domain ind:ContractInventoryAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocatedSeats rdf:type rdf:Property ;
    rdfs:label 'Allocated Seats' ;
    rdfs:comment 'Number of seats on this flight-date allocated or reserved for this corporate contract. May be soft allocation (priority access) or hard block (guaranteed availability).' ;
    rdfs:domain ind:ContractInventoryAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revenueGenerated rdf:type rdf:Property ;
    rdfs:label 'Revenue Generated' ;
    rdfs:comment 'Total revenue generated from bookings under this corporate contract on this specific flight-date. Used for contract performance tracking and volume commitment measurement.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:seatsUsed rdf:type rdf:Property ;
    rdfs:label 'Seats Used' ;
    rdfs:comment 'Number of seats actually booked and consumed under this corporate contract on this specific flight-date. Used to track contract utilization and volume commitment progress.' ;
    rdfs:domain ind:ContractInventoryAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fareApplicabilityId rdf:type rdf:Property ;
    rdfs:label 'Fare Applicability Id' ;
    rdfs:comment 'Unique surrogate identifier for this fare-inventory applicability record.' ;
    rdfs:domain ind:FareApplicability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fareApplicabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Fare Applicability Status' ;
    rdfs:comment 'Lifecycle status of this fare-inventory applicability record. ACTIVE=currently in effect, SUSPENDED=temporarily disabled by revenue management, EXPIRED=past discontinue_date, WITHDRAWN=removed from sale by carrier decision.' ;
    rdfs:domain ind:FareApplicability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastBookingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Booking Timestamp' ;
    rdfs:comment 'Timestamp of the most recent booking made using this fare on this flight inventory. Used for booking curve analysis and revenue management forecasting.' ;
    rdfs:domain ind:FareApplicability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:seatsSoldUnderFare rdf:type rdf:Property ;
    rdfs:label 'Seats Sold Under Fare' ;
    rdfs:comment 'Current count of confirmed bookings made using this specific fare on this flight-date. Tracked separately from flight inventory total seats_sold to enable fare-level revenue analysis and yield management decisions.' ;
    rdfs:domain ind:FareApplicability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cargoSegmentId rdf:type rdf:Property ;
    rdfs:label 'Cargo Segment Id' ;
    rdfs:comment 'Unique identifier for this cargo segment record. Primary key.' ;
    rdfs:domain ind:CargoSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:compartmentCode rdf:type rdf:Property ;
    rdfs:label 'Compartment Code' ;
    rdfs:comment 'Code identifying the specific cargo compartment or hold position where this AWB was loaded on this flight leg (e.g., FWD, AFT, BULK). Used for weight and balance calculations.' ;
    rdfs:domain ind:CargoSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handlingStationCode rdf:type rdf:Property ;
    rdfs:label 'Handling Station Code' ;
    rdfs:comment 'Three-letter IATA airport code for the station where this cargo was handled for this segment (loading, transfer, or offloading). May differ from flight origin/destination for transfer cargo.' ;
    rdfs:domain ind:CargoSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Loaded Timestamp' ;
    rdfs:comment 'Date and time when this AWB was physically loaded onto the aircraft for this flight leg. Used for operational performance tracking and load reconciliation.' ;
    rdfs:domain ind:CargoSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:loadingPriority rdf:type rdf:Property ;
    rdfs:label 'Loading Priority' ;
    rdfs:comment 'Priority level for loading this AWB on this specific flight leg, which may differ from overall AWB priority based on connection times, special handling requirements, or operational constraints.' ;
    rdfs:domain ind:CargoSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manifestedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Manifested Timestamp' ;
    rdfs:comment 'Date and time when this AWB was added to the cargo manifest for this specific flight leg. Used for operational cutoff tracking and regulatory compliance.' ;
    rdfs:domain ind:CargoSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:offloadedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Offloaded Timestamp' ;
    rdfs:comment 'Date and time when this AWB was physically offloaded from the aircraft after this flight leg. Used for transfer coordination and delivery tracking.' ;
    rdfs:domain ind:CargoSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:segmentSequence rdf:type rdf:Property ;
    rdfs:label 'Segment Sequence' ;
    rdfs:comment 'Sequential order of this flight leg within the AWB\'s complete routing (1 for first leg, 2 for second leg, etc.). Critical for multi-leg shipment tracking and transfer coordination.' ;
    rdfs:domain ind:CargoSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:segmentMileageAccrualId rdf:type rdf:Property ;
    rdfs:label 'Segment Mileage Accrual Id' ;
    rdfs:comment 'Unique identifier for this segment-to-accrual linkage record. Primary key for the association.' ;
    rdfs:domain ind:SegmentMileageAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualifyingIndicator rdf:type rdf:Property ;
    rdfs:label 'Qualifying Indicator' ;
    rdfs:comment 'Flag indicating whether this segment qualifies for elite status qualification (EQM/EQS) in addition to redeemable miles. False for deeply discounted fares, award tickets, or partner segments with restricted earning.' ;
    rdfs:domain ind:SegmentMileageAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:segmentBaseMiles rdf:type rdf:Property ;
    rdfs:label 'Segment Base Miles' ;
    rdfs:comment 'Base miles earned specifically from this segment, calculated from segment distance and fare class. When a journey-based accrual spans multiple segments, this attribute allocates the portion of base miles attributable to this specific segment.' ;
    rdfs:domain ind:SegmentMileageAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:segmentContributionDate rdf:type rdf:Property ;
    rdfs:label 'Segment Contribution Date' ;
    rdfs:comment 'Date when this segment\'s contribution to the accrual was calculated. Typically the segment departure date for standard accruals, or the claim date for retroactive accruals.' ;
    rdfs:domain ind:SegmentMileageAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:segmentEliteBonusMiles rdf:type rdf:Property ;
    rdfs:label 'Segment Elite Bonus Miles' ;
    rdfs:comment 'Elite tier bonus miles earned specifically from this segment. Calculated by applying the member\'s elite multiplier to this segment\'s base miles.' ;
    rdfs:domain ind:SegmentMileageAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:segmentPostingStatus rdf:type rdf:Property ;
    rdfs:label 'Segment Posting Status' ;
    rdfs:comment 'Status of this segment\'s contribution to the accrual. Pending indicates awaiting flight completion or ticket validation. Posted indicates miles credited. Reversed indicates miles clawed back. Excluded indicates segment did not qualify for miles (award ticket, non-qualifying fare class).' ;
    rdfs:domain ind:SegmentMileageAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentPromotionalBonusMiles rdf:type rdf:Property ;
    rdfs:label 'Segment Promotional Bonus Miles' ;
    rdfs:comment 'Promotional bonus miles earned specifically from this segment. Captures route-specific promotions, cabin-specific bonuses, or segment-level campaign credits.' ;
    rdfs:domain ind:SegmentMileageAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:travelHistoryId rdf:type rdf:Property ;
    rdfs:label 'Travel History Id' ;
    rdfs:comment 'Unique identifier for this passenger-route travel history record. Primary key.' ;
    rdfs:domain ind:TravelHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:averageFarePaid rdf:type rdf:Property ;
    rdfs:label 'Average Fare Paid' ;
    rdfs:comment 'Average fare amount paid by this passenger for this route across all historical bookings. Used for price sensitivity analysis and personalized pricing strategies.' ;
    rdfs:domain ind:TravelHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:firstTravelDate rdf:type rdf:Property ;
    rdfs:label 'First Travel Date' ;
    rdfs:comment 'Date of the passenger\'s first travel on this route. Used for customer tenure analysis and lifecycle marketing.' ;
    rdfs:domain ind:TravelHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastTravelDate rdf:type rdf:Property ;
    rdfs:label 'Last Travel Date' ;
    rdfs:comment 'Most recent date when this passenger traveled on this route. Used for recency analysis in customer segmentation and reactivation campaigns.' ;
    rdfs:domain ind:TravelHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:routeAffinityScore rdf:type rdf:Property ;
    rdfs:label 'Route Affinity Score' ;
    rdfs:comment 'Calculated score (0.00 to 100.00) representing the strength of this passenger\'s preference for this route based on frequency, recency, fare paid, and booking behavior. Used for route-specific marketing and personalization.' ;
    rdfs:domain ind:TravelHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:travelFrequencyOnRoute rdf:type rdf:Property ;
    rdfs:label 'Travel Frequency On Route' ;
    rdfs:comment 'Total number of times this passenger has traveled on this specific route. Used for route affinity scoring and frequent traveler identification.' ;
    rdfs:domain ind:TravelHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:channelVendorAgreementId rdf:type rdf:Property ;
    rdfs:label 'Channel Vendor Agreement Id' ;
    rdfs:comment 'Unique identifier for this channel-vendor distribution agreement record. Primary key.' ;
    rdfs:domain ind:ChannelVendorAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maintenanceServiceAgreementId rdf:type rdf:Property ;
    rdfs:label 'Maintenance Service Agreement Id' ;
    rdfs:comment 'Unique system identifier for this maintenance service agreement record. Primary key.' ;
    rdfs:domain ind:MaintenanceServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contractValue rdf:type rdf:Property ;
    rdfs:label 'Contract Value' ;
    rdfs:comment 'Total contracted value or estimated annual spend for maintenance services provided by this MRO for this aircraft under this agreement. Currency assumed to be airline\'s reporting currency. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:MaintenanceServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastServiceDate rdf:type rdf:Property ;
    rdfs:label 'Last Service Date' ;
    rdfs:comment 'Date when this MRO most recently completed maintenance work on this aircraft under this agreement. Used for service history tracking and performance monitoring.' ;
    rdfs:domain ind:MaintenanceServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextScheduledServiceDate rdf:type rdf:Property ;
    rdfs:label 'Next Scheduled Service Date' ;
    rdfs:comment 'Planned date for the next scheduled maintenance event for this aircraft at this MRO facility under this agreement (e.g., next C-Check slot).' ;
    rdfs:domain ind:MaintenanceServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scopeOfWork rdf:type rdf:Property ;
    rdfs:label 'Scope Of Work' ;
    rdfs:comment 'Textual description of the maintenance services covered under this agreement for this aircraft (e.g., \'C-Check heavy maintenance\', \'Line maintenance at hub stations\', \'Engine shop visits\', \'Component repair and overhaul\'). Scope varies by aircraft-MRO combination. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:MaintenanceServiceAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aircraftApprovalId rdf:type rdf:Property ;
    rdfs:label 'Aircraft Approval Id' ;
    rdfs:comment 'Primary key for the aircraft_approval association' ;
    rdfs:domain ind:AircraftApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certificationDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Certification Document Reference' ;
    rdfs:comment 'Reference number or file path to the official certification document proving this aircraft holds this operational approval.' ;
    rdfs:domain ind:AircraftApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Compliance Verification Date' ;
    rdfs:comment 'The date of the most recent compliance verification or audit confirming this aircraft meets the requirements for this operational approval.' ;
    rdfs:domain ind:AircraftApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:typeRecommendationApplicabilityId rdf:type rdf:Property ;
    rdfs:label 'Type Recommendation Applicability Id' ;
    rdfs:comment 'Primary key for the type_recommendation_applicability association' ;
    rdfs:domain ind:TypeRecommendationApplicability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicabilityDeterminationDate rdf:type rdf:Property ;
    rdfs:label 'Applicability Determination Date' ;
    rdfs:comment 'Date when the applicability of this recommendation to this aircraft type was formally determined by engineering or safety review.' ;
    rdfs:domain ind:TypeRecommendationApplicability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exemptionReference rdf:type rdf:Property ;
    rdfs:label 'Exemption Reference' ;
    rdfs:comment 'Reference to regulatory exemption or alternative means of compliance if this aircraft type is exempted from this recommendation. Null if no exemption applies.' ;
    rdfs:domain ind:TypeRecommendationApplicability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fleetCountAffected rdf:type rdf:Property ;
    rdfs:label 'Fleet Count Affected' ;
    rdfs:comment 'Number of individual aircraft of this type in the fleet affected by this recommendation at the time of applicability determination.' ;
    rdfs:domain ind:TypeRecommendationApplicability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:implementationCost rdf:type rdf:Property ;
    rdfs:label 'Implementation Cost' ;
    rdfs:comment 'Actual or estimated cost to implement this recommendation for this aircraft type. Costs vary significantly by type due to differences in fleet size, modification complexity, and parts requirements.' ;
    rdfs:domain ind:TypeRecommendationApplicability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:implementationDate rdf:type rdf:Property ;
    rdfs:label 'Implementation Date' ;
    rdfs:comment 'Actual date when this recommendation was implemented for this specific aircraft type. Implementation dates vary by type due to maintenance schedules, parts availability, and engineering complexity.' ;
    rdfs:domain ind:TypeRecommendationApplicability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:implementationPriority rdf:type rdf:Property ;
    rdfs:label 'Implementation Priority' ;
    rdfs:comment 'Priority level for implementing this recommendation on this aircraft type, which may differ from the recommendation\'s overall priority based on type-specific risk factors, fleet utilization, or operational considerations.' ;
    rdfs:domain ind:TypeRecommendationApplicability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modificationReference rdf:type rdf:Property ;
    rdfs:label 'Modification Reference' ;
    rdfs:comment 'Reference number for the engineering modification, service bulletin, or airworthiness directive that implements this recommendation for this aircraft type. Links to engineering change management systems.' ;
    rdfs:domain ind:TypeRecommendationApplicability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aircraftTypeVendorApprovalId rdf:type rdf:Property ;
    rdfs:label 'Aircraft Type Vendor Approval Id' ;
    rdfs:comment 'Primary key for the aircraft_type_vendor_approval association' ;
    rdfs:domain ind:AircraftTypeVendorApproval ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:alertDistributionId rdf:type rdf:Property ;
    rdfs:label 'Alert Distribution Id' ;
    rdfs:comment 'Unique identifier for this alert distribution record. Primary key.' ;
    rdfs:domain ind:AlertDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:channelEffectivenessScore rdf:type rdf:Property ;
    rdfs:label 'Channel Effectiveness Score' ;
    rdfs:comment 'Calculated effectiveness score for this alert-channel combination based on delivery rate and acknowledgement rate' ;
    rdfs:domain ind:AlertDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryAttemptCount rdf:type rdf:Property ;
    rdfs:label 'Delivery Attempt Count' ;
    rdfs:comment 'Number of delivery attempts made for this alert through this channel' ;
    rdfs:domain ind:AlertDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastDeliveryAttemptTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Delivery Attempt Timestamp' ;
    rdfs:comment 'Timestamp of the most recent delivery attempt for this alert through this channel' ;
    rdfs:domain ind:AlertDistribution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:channelAuditAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Channel Audit Assessment Id' ;
    rdfs:comment 'Unique identifier for this channel-specific audit assessment record. Primary key.' ;
    rdfs:domain ind:ChannelAuditAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditorAssigned rdf:type rdf:Property ;
    rdfs:label 'Auditor Assigned' ;
    rdfs:comment 'Name or identifier of the specific auditor or audit team member who assessed this channel within the broader audit event.' ;
    rdfs:domain ind:ChannelAuditAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelAuditDate rdf:type rdf:Property ;
    rdfs:label 'Channel Audit Date' ;
    rdfs:comment 'Specific date this channel was assessed within the broader audit event. For multi-day audits covering multiple channels, each channel may be audited on different days within the audit_event.actual_start_date to audit_event.actual_end_date window.' ;
    rdfs:domain ind:ChannelAuditAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:channelAuditNotes rdf:type rdf:Property ;
    rdfs:label 'Channel Audit Notes' ;
    rdfs:comment 'Free-text notes and observations specific to this channel\'s audit assessment, including context for findings, mitigating factors, or areas of excellence.' ;
    rdfs:domain ind:ChannelAuditAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelAuditScope rdf:type rdf:Property ;
    rdfs:label 'Channel Audit Scope' ;
    rdfs:comment 'Detailed description of the audit scope specific to this channel, including which ancillary products, pricing rules, disclosure requirements, refund processes, and merchandising practices were assessed. This is channel-specific and more granular than the overall audit_event.audit_scope.' ;
    rdfs:domain ind:ChannelAuditAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelComplianceRating rdf:type rdf:Property ;
    rdfs:label 'Channel Compliance Rating' ;
    rdfs:comment 'Compliance rating assigned specifically to this channel\'s performance in the audit. May differ from the overall audit_event.assessment_rating as different channels may have different compliance levels within the same audit event.' ;
    rdfs:domain ind:ChannelAuditAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelCorrectiveActionDueDate rdf:type rdf:Property ;
    rdfs:label 'Channel Corrective Action Due Date' ;
    rdfs:comment 'Deadline by which corrective actions for this channel must be completed and verified.' ;
    rdfs:domain ind:ChannelAuditAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:channelCorrectiveActionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Channel Corrective Action Required Flag' ;
    rdfs:comment 'Indicates whether formal corrective action is required for this channel based on audit findings.' ;
    rdfs:domain ind:ChannelAuditAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:channelCorrectiveActionStatus rdf:type rdf:Property ;
    rdfs:label 'Channel Corrective Action Status' ;
    rdfs:comment 'Current status of corrective action implementation for this channel.' ;
    rdfs:domain ind:ChannelAuditAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelCriticalFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Channel Critical Findings Count' ;
    rdfs:comment 'Number of critical findings identified for this channel, requiring immediate corrective action.' ;
    rdfs:domain ind:ChannelAuditAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:channelFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Channel Findings Count' ;
    rdfs:comment 'Total number of findings, observations, or non-conformances identified for this specific channel during the audit event. Channel-level count that rolls up to audit_event.total_findings_count.' ;
    rdfs:domain ind:ChannelAuditAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:channelMajorFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Channel Major Findings Count' ;
    rdfs:comment 'Number of major findings identified for this channel, requiring corrective action within a defined timeframe.' ;
    rdfs:domain ind:ChannelAuditAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:channelMinorFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Channel Minor Findings Count' ;
    rdfs:comment 'Number of minor findings or observations identified for this channel.' ;
    rdfs:domain ind:ChannelAuditAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextChannelAuditDue rdf:type rdf:Property ;
    rdfs:label 'Next Channel Audit Due' ;
    rdfs:comment 'Scheduled date for the next audit assessment of this specific channel. May differ from audit_event.next_scheduled_audit_date if channels have different audit frequencies based on risk profile or prior findings.' ;
    rdfs:domain ind:ChannelAuditAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditCostAllocationId rdf:type rdf:Property ;
    rdfs:label 'Audit Cost Allocation Id' ;
    rdfs:comment 'Unique surrogate identifier for this audit cost allocation record. Primary key.' ;
    rdfs:domain ind:AuditCostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:responsibleManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Responsible Manager Employee Id' ;
    rdfs:comment 'Foreign key to workforce.employee identifying the manager accountable for this cost allocation, typically the cost centre manager or audit program coordinator.' ;
    rdfs:domain ind:AuditCostAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:actualCostToDate rdf:type rdf:Property ;
    rdfs:label 'Actual Cost To Date' ;
    rdfs:comment 'The cumulative actual costs incurred by this cost centre for this audit program as of the current reporting date. Enables budget vs actual variance analysis.' ;
    rdfs:domain ind:AuditCostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocatedBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Allocated Budget Amount' ;
    rdfs:comment 'The budget amount allocated to this cost centre for participation in this specific audit program for the fiscal period. Represents planned expenditure.' ;
    rdfs:domain ind:AuditCostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationEndDate rdf:type rdf:Property ;
    rdfs:label 'Allocation End Date' ;
    rdfs:comment 'The date on which this cost allocation ends, typically aligned with audit program completion or fiscal year end.' ;
    rdfs:domain ind:AuditCostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:budgetVarianceAmount rdf:type rdf:Property ;
    rdfs:label 'Budget Variance Amount' ;
    rdfs:comment 'Calculated variance between allocated budget and actual costs (actual_cost_to_date - allocated_budget_amount). Positive values indicate over-budget, negative indicate under-budget.' ;
    rdfs:domain ind:AuditCostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costAllocationPercentage rdf:type rdf:Property ;
    rdfs:label 'Cost Allocation Percentage' ;
    rdfs:comment 'The percentage of the total audit program cost allocated to this cost centre, reflecting the proportional responsibility or scope coverage. Sum across all cost centres for a program should equal 100%.' ;
    rdfs:domain ind:AuditCostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:vendorAuditScheduleId rdf:type rdf:Property ;
    rdfs:label 'Vendor Audit Schedule Id' ;
    rdfs:comment 'Unique identifier for this vendor audit schedule record. Primary key.' ;
    rdfs:domain ind:VendorAuditSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignedAuditorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Assigned Auditor Employee Id' ;
    rdfs:comment 'Foreign key to workforce.employee identifying the lead auditor assigned to conduct this vendor audit under this program' ;
    rdfs:domain ind:VendorAuditSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:auditExemptionFlag rdf:type rdf:Property ;
    rdfs:label 'Audit Exemption Flag' ;
    rdfs:comment 'Indicates whether this vendor has been granted an exemption from this audit program based on alternative certifications or low-risk classification' ;
    rdfs:domain ind:VendorAuditSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:auditFrequency rdf:type rdf:Property ;
    rdfs:label 'Audit Frequency' ;
    rdfs:comment 'The specific frequency at which this vendor must be audited under this program, which may differ from the program\'s default cycle based on vendor tier, risk profile, or contractual requirements' ;
    rdfs:domain ind:VendorAuditSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditResult rdf:type rdf:Property ;
    rdfs:label 'Audit Result' ;
    rdfs:comment 'The outcome or status of the most recent audit of this vendor under this program' ;
    rdfs:domain ind:VendorAuditSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionPlanStatus rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Plan Status' ;
    rdfs:comment 'Current status of the corrective action plan for this vendor-audit combination' ;
    rdfs:domain ind:VendorAuditSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exemptionExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Exemption Expiry Date' ;
    rdfs:comment 'The date on which the audit exemption expires and the vendor becomes subject to the audit program again' ;
    rdfs:domain ind:VendorAuditSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:findingsCount rdf:type rdf:Property ;
    rdfs:label 'Findings Count' ;
    rdfs:comment 'Total number of audit findings identified during the most recent audit of this vendor under this program' ;
    rdfs:domain ind:VendorAuditSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:positionBudgetId rdf:type rdf:Property ;
    rdfs:label 'Position Budget Id' ;
    rdfs:comment 'Unique surrogate identifier for the position budget allocation record. Primary key for the association.' ;
    rdfs:domain ind:PositionBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:budgetNotes rdf:type rdf:Property ;
    rdfs:label 'Budget Notes' ;
    rdfs:comment 'Free-text notes or assumptions specific to this position budget allocation (e.g., \'assumes 3-month vacancy\', \'includes type rating training cost\', \'contingent on fleet expansion approval\'). Provides context for budget reviewers and variance analysis.' ;
    rdfs:domain ind:PositionBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:budgetedFte rdf:type rdf:Property ;
    rdfs:label 'Budgeted Fte' ;
    rdfs:comment 'The planned FTE allocation for this position within this budget plan. May differ from the position\'s base FTE allocation to reflect hiring plans, vacancy assumptions, or scenario planning (e.g., 0.50 FTE budgeted for a 1.00 FTE position due to expected vacancy).' ;
    rdfs:domain ind:PositionBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetedSalaryAmount rdf:type rdf:Property ;
    rdfs:label 'Budgeted Salary Amount' ;
    rdfs:comment 'The total salary cost budgeted for this position within this budget plan, including base salary, allowances, and statutory benefits. Denominated in the budget plan\'s currency. Used for labor cost forecasting and OPEX planning.' ;
    rdfs:domain ind:PositionBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceThreshold rdf:type rdf:Property ;
    rdfs:label 'Variance Threshold' ;
    rdfs:comment 'The maximum allowable absolute monetary deviation between budgeted and actual salary costs for this position within this plan before triggering management review. May differ from the plan-level variance threshold to reflect position criticality or cost materiality.' ;
    rdfs:domain ind:PositionBudget ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:stationAuthorizationId rdf:type rdf:Property ;
    rdfs:label 'Station Authorization Id' ;
    rdfs:comment 'Unique identifier for this station authorization record. Primary key.' ;
    rdfs:domain ind:StationAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:onCallStatus rdf:type rdf:Property ;
    rdfs:label 'On Call Status' ;
    rdfs:comment 'Indicates whether the certifying staff member is on primary on-call, backup on-call, or not on-call for AOG situations at this station. Station-specific on-call responsibility.' ;
    rdfs:domain ind:StationAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shiftAssignment rdf:type rdf:Property ;
    rdfs:label 'Shift Assignment' ;
    rdfs:comment 'The shift pattern assigned to the certifying staff member at this specific station (e.g., day shift, night shift, rotating). Station-specific work schedule.' ;
    rdfs:domain ind:StationAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stationQualificationDate rdf:type rdf:Property ;
    rdfs:label 'Station Qualification Date' ;
    rdfs:comment 'The date on which the certifying staff member completed station-specific qualification training and familiarization for this station\'s facilities, equipment, and procedures.' ;
    rdfs:domain ind:StationAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:corporateAncillaryEntitlementId rdf:type rdf:Property ;
    rdfs:label 'Corporate Ancillary Entitlement Id' ;
    rdfs:comment 'Unique surrogate identifier for this corporate ancillary entitlement record' ;
    rdfs:domain ind:CorporateAncillaryEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:autoApplyFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Apply Flag' ;
    rdfs:comment 'Indicates whether this ancillary entitlement should be automatically applied to eligible bookings under this corporate contract or requires manual selection' ;
    rdfs:domain ind:CorporateAncillaryEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:entitlementStatus rdf:type rdf:Property ;
    rdfs:label 'Entitlement Status' ;
    rdfs:comment 'Current status of this specific ancillary entitlement within the corporate contract (active, suspended, expired, pending)' ;
    rdfs:domain ind:CorporateAncillaryEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:includedQuantity rdf:type rdf:Property ;
    rdfs:label 'Included Quantity' ;
    rdfs:comment 'Number of units of this ancillary product included free or bundled per passenger or per booking under this corporate contract (e.g., 2 free checked bags, 1 lounge access per trip)' ;
    rdfs:domain ind:CorporateAncillaryEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:negotiatedPrice rdf:type rdf:Property ;
    rdfs:label 'Negotiated Price' ;
    rdfs:comment 'Fixed negotiated price for this ancillary product under this corporate contract, overriding the standard catalog price' ;
    rdfs:domain ind:CorporateAncillaryEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:usageLimitPerBooking rdf:type rdf:Property ;
    rdfs:label 'Usage Limit Per Booking' ;
    rdfs:comment 'Maximum number of times this ancillary entitlement can be used per booking under the corporate contract terms' ;
    rdfs:domain ind:CorporateAncillaryEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:usageLimitPerPassenger rdf:type rdf:Property ;
    rdfs:label 'Usage Limit Per Passenger' ;
    rdfs:comment 'Maximum number of times this ancillary entitlement can be used per passenger per trip under the corporate contract terms' ;
    rdfs:domain ind:CorporateAncillaryEntitlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maintenanceAuthorizationId rdf:type rdf:Property ;
    rdfs:label 'Maintenance Authorization Id' ;
    rdfs:comment 'Unique identifier for this crew maintenance authorization record. Primary key.' ;
    rdfs:domain ind:MaintenanceAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:authorizationScope rdf:type rdf:Property ;
    rdfs:label 'Authorization Scope' ;
    rdfs:comment 'Textual description of the specific maintenance activities, aircraft types, or component categories the crew member is authorized to work on at this organisation (e.g., \'B737 line maintenance\', \'engine borescope inspection\', \'avionics troubleshooting\'). Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:MaintenanceAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationalQualificationId rdf:type rdf:Property ;
    rdfs:label 'Operational Qualification Id' ;
    rdfs:comment 'Unique identifier for this crew operational qualification record. Primary key.' ;
    rdfs:domain ind:OperationalQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:instructorEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Instructor Employee Id' ;
    rdfs:comment 'Foreign key to workforce.employee representing the instructor or check airman who conducted the qualifying training or check for this operational approval.' ;
    rdfs:domain ind:OperationalQualification ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:checkDate rdf:type rdf:Property ;
    rdfs:label 'Check Date' ;
    rdfs:comment 'Date of the most recent proficiency check or line check conducted to validate the crew member\'s competency for operations under this approval.' ;
    rdfs:domain ind:OperationalQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trainingDeviceUsed rdf:type rdf:Property ;
    rdfs:label 'Training Device Used' ;
    rdfs:comment 'Identifier of the simulator or training device used for qualification training (e.g., SIM-001, FTD-B737-02), if applicable to this operational approval.' ;
    rdfs:domain ind:OperationalQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatchExemptionInvocationId rdf:type rdf:Property ;
    rdfs:label 'Dispatch Exemption Invocation Id' ;
    rdfs:comment 'Unique identifier for this specific invocation of an exemption within a dispatch release. Primary key.' ;
    rdfs:domain ind:DispatchExemptionInvocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicabilityJustification rdf:type rdf:Property ;
    rdfs:label 'Applicability Justification' ;
    rdfs:comment 'Dispatcher\'s explanation of why this specific exemption is applicable to this flight (e.g., \'ETOPS diversion time waiver applies due to North Atlantic routing with limited alternate airports\'). Required for regulatory audit defense.' ;
    rdfs:domain ind:DispatchExemptionInvocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Application Timestamp' ;
    rdfs:comment 'Date and time when the dispatcher applied this exemption to the dispatch release during the authorization workflow. Captures the operational moment of invocation.' ;
    rdfs:domain ind:DispatchExemptionInvocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:conditionComplianceNotes rdf:type rdf:Property ;
    rdfs:label 'Condition Compliance Notes' ;
    rdfs:comment 'Detailed notes documenting how the flight meets all conditions attached to the exemption (e.g., \'Aircraft equipped with required ETOPS equipment per exemption condition 3a; crew ETOPS-qualified per condition 2b\').' ;
    rdfs:domain ind:DispatchExemptionInvocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionsAcceptedFlag rdf:type rdf:Property ;
    rdfs:label 'Conditions Accepted Flag' ;
    rdfs:comment 'Indicates whether the dispatcher explicitly acknowledged and accepted all conditions attached to this exemption as applicable to this specific flight. Required for regulatory compliance attestation.' ;
    rdfs:domain ind:DispatchExemptionInvocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dispatcherAcknowledgment rdf:type rdf:Property ;
    rdfs:label 'Dispatcher Acknowledgment' ;
    rdfs:comment 'Textual acknowledgment or attestation statement by the dispatcher confirming understanding of the exemption\'s conditions and applicability to this flight. May include dispatcher comments on specific condition compliance.' ;
    rdfs:domain ind:DispatchExemptionInvocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expiryVerificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Expiry Verification Timestamp' ;
    rdfs:comment 'Timestamp when the dispatcher verified that the exemption was still valid (not expired) at the time of dispatch release issuance. Critical for audit trail demonstrating due diligence.' ;
    rdfs:domain ind:DispatchExemptionInvocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:invocationSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Invocation Sequence Number' ;
    rdfs:comment 'Sequential order in which this exemption was applied within the dispatch release workflow. Useful for understanding dispatcher decision-making sequence during release preparation.' ;
    rdfs:domain ind:DispatchExemptionInvocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vendorAuthorizationId rdf:type rdf:Property ;
    rdfs:label 'Vendor Authorization Id' ;
    rdfs:comment 'Unique identifier for this vendor authorization record. Primary key.' ;
    rdfs:domain ind:VendorAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvalLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Approval Limit Amount' ;
    rdfs:comment 'The maximum monetary value that the employee is authorized to approve for transactions with this vendor. Enforces spending controls and segregation of duties.' ;
    rdfs:domain ind:VendorAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvalLimitCurrency rdf:type rdf:Property ;
    rdfs:label 'Approval Limit Currency' ;
    rdfs:comment 'Three-letter ISO currency code for the approval limit amount.' ;
    rdfs:domain ind:VendorAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizationLevel rdf:type rdf:Property ;
    rdfs:label 'Authorization Level' ;
    rdfs:comment 'The hierarchical level of authorization granted to the employee for this vendor. Higher levels permit larger transaction values and more critical procurement actions.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryResponsibilityId rdf:type rdf:Property ;
    rdfs:label 'Category Responsibility Id' ;
    rdfs:comment 'Unique identifier for this category responsibility assignment record. Primary key.' ;
    rdfs:domain ind:CategoryResponsibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Assigned By Employee Id' ;
    rdfs:comment 'Foreign key to workforce.employee identifying the manager or procurement director who made this assignment. Supports audit trail and accountability.' ;
    rdfs:domain ind:CategoryResponsibility ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:assignmentNotes rdf:type rdf:Property ;
    rdfs:label 'Assignment Notes' ;
    rdfs:comment 'Free-text notes about this assignment, including special conditions, coverage arrangements, or transition plans.' ;
    rdfs:domain ind:CategoryResponsibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backupFlag rdf:type rdf:Property ;
    rdfs:label 'Backup Flag' ;
    rdfs:comment 'Indicates whether this is a backup assignment (true) or primary assignment (false). Critical for vacation coverage and workload distribution. Explicitly identified in detection reasoning.' ;
    rdfs:domain ind:CategoryResponsibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:categoryManagerEmail rdf:type rdf:Property ;
    rdfs:label 'Category Manager Email' ;
    rdfs:comment 'Email address of the category manager or lead buyer responsible for this category. Used for escalations and strategic sourcing inquiries. [Moved from procurement_category: The category_manager_email attribute in procurement_category stores a single manager\'s email, but the business reality requires tracking multiple employees with different roles per category. This attribute should be deprecated in favor of joining to workforce.employee through the category_responsibility association to retrieve email addresses for all assigned employees based on their roles.]' ;
    rdfs:domain ind:CategoryResponsibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryOwner rdf:type rdf:Property ;
    rdfs:label 'Category Owner' ;
    rdfs:comment 'Name or identifier of the lead buyer or procurement manager responsible for strategic sourcing and supplier management within this category. [Moved from procurement_category: The category_owner attribute in procurement_category currently stores a single owner name/identifier, but the business reality is that multiple employees have different roles for each category (primary manager, backup, technical specialist, finance controller). This attribute should be deprecated in favor of querying the category_responsibility association to determine the current primary_manager for each category. The association provides richer role-based assignment tracking.]' ;
    rdfs:domain ind:CategoryResponsibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:roleType rdf:type rdf:Property ;
    rdfs:label 'Role Type' ;
    rdfs:comment 'The specific role this employee performs for this category. Values: primary_manager (lead category manager), backup_manager (coverage during absence), technical_specialist (technical expertise for specifications), finance_controller (financial oversight), approver (approval authority), technical_advisor (advisory role). Explicitly identified in detection reasoning.' ;
    rdfs:domain ind:CategoryResponsibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workloadPercentage rdf:type rdf:Property ;
    rdfs:label 'Workload Percentage' ;
    rdfs:comment 'Percentage of the employee\'s time allocated to this category (0.00 to 100.00). Used for workload balancing and capacity planning when employees manage multiple categories.' ;
    rdfs:domain ind:CategoryResponsibility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueBundleComponentId rdf:type rdf:Property ;
    rdfs:label 'Revenue Bundle Component Id' ;
    rdfs:comment 'Primary key for revenue_bundle_component' ;
    rdfs:domain ind:RevenueBundleComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bundleComponentId rdf:type rdf:Property ;
    rdfs:label 'Bundle Component Id' ;
    rdfs:comment 'Unique surrogate identifier for this fare family ancillary inclusion record. Primary key for the association.' ;
    rdfs:domain ind:RevenueBundleComponent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AncillaryBundleComponent .

ind:channelOverride rdf:type rdf:Property ;
    rdfs:label 'Channel Override' ;
    rdfs:comment 'Comma-separated list of sales channels where this specific fare family-ancillary inclusion configuration applies differently than the default. Used for channel-specific bundling strategies (e.g., GDS vs. direct web). Null indicates no channel-specific override. This override is specific to the fare family-ancillary pairing.' ;
    rdfs:domain ind:RevenueBundleComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingHighlightFlag rdf:type rdf:Property ;
    rdfs:label 'Marketing Highlight Flag' ;
    rdfs:comment 'Indicates whether this ancillary inclusion should be prominently featured in fare family marketing materials and comparison charts. True for key differentiators (e.g., Premium Economy highlighting extra legroom and priority boarding). This marketing emphasis is specific to the fare family-ancillary relationship.' ;
    rdfs:domain ind:RevenueBundleComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:memberAuditSampleId rdf:type rdf:Property ;
    rdfs:label 'Member Audit Sample Id' ;
    rdfs:comment 'Unique identifier for this member audit sample record. Primary key.' ;
    rdfs:domain ind:MemberAuditSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:documentationProvided rdf:type rdf:Property ;
    rdfs:label 'Documentation Provided' ;
    rdfs:comment 'List or description of documentation provided or reviewed for this member during the audit (e.g., transaction history, redemption records, tier qualification evidence, complaint correspondence).' ;
    rdfs:domain ind:MemberAuditSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:examinationStatus rdf:type rdf:Property ;
    rdfs:label 'Examination Status' ;
    rdfs:comment 'Current status of the examination of this member within this audit event. Pending=selected but not yet examined, In Progress=examination underway, Completed=examination finished, Deferred=postponed to follow-up, Excluded=removed from sample.' ;
    rdfs:domain ind:MemberAuditSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingCount rdf:type rdf:Property ;
    rdfs:label 'Finding Count' ;
    rdfs:comment 'Number of audit findings, discrepancies, or non-conformances identified specifically related to this member account during this audit event. Zero indicates clean examination.' ;
    rdfs:domain ind:MemberAuditSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:interviewNotes rdf:type rdf:Property ;
    rdfs:label 'Interview Notes' ;
    rdfs:comment 'Auditor notes from member interview or account examination. May contain sensitive information about member behavior, complaints, or account irregularities discovered during audit.' ;
    rdfs:domain ind:MemberAuditSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sampleSelectionDate rdf:type rdf:Property ;
    rdfs:label 'Sample Selection Date' ;
    rdfs:comment 'Date when this member was selected for inclusion in the audit sample. Used to track audit planning timeline and sample frame timing.' ;
    rdfs:domain ind:MemberAuditSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sampleSelectionFlag rdf:type rdf:Property ;
    rdfs:label 'Sample Selection Flag' ;
    rdfs:comment 'Indicates whether this member was formally selected as part of the audit sample (true) or examined opportunistically (false). Tracks audit methodology compliance.' ;
    rdfs:domain ind:MemberAuditSample ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:campaignExposureId rdf:type rdf:Property ;
    rdfs:label 'Campaign Exposure Id' ;
    rdfs:comment 'Unique identifier for this campaign exposure record. Primary key.' ;
    rdfs:domain ind:CampaignExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:attributedRevenue rdf:type rdf:Property ;
    rdfs:label 'Attributed Revenue' ;
    rdfs:comment 'Revenue amount attributed to this specific campaign exposure, used for ROI calculation and campaign performance measurement. Explicitly identified in detection phase as relationship data.' ;
    rdfs:domain ind:CampaignExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:attributionModel rdf:type rdf:Property ;
    rdfs:label 'Attribution Model' ;
    rdfs:comment 'Attribution model used to calculate attributed revenue for this exposure (first-touch, last-touch, linear, time-decay, position-based).' ;
    rdfs:domain ind:CampaignExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Conversion Timestamp' ;
    rdfs:comment 'Date and time when the member converted as a result of the campaign, if conversion_flag is true.' ;
    rdfs:domain ind:CampaignExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:creativeVariant rdf:type rdf:Property ;
    rdfs:label 'Creative Variant' ;
    rdfs:comment 'Specific creative variant or A/B test version shown to this member during this exposure.' ;
    rdfs:domain ind:CampaignExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exposureChannel rdf:type rdf:Property ;
    rdfs:label 'Exposure Channel' ;
    rdfs:comment 'Channel through which the member was exposed to the campaign (email, SMS, digital ad, social media, etc.). Explicitly identified in detection phase as relationship data.' ;
    rdfs:domain ind:CampaignExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exposureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Exposure Timestamp' ;
    rdfs:comment 'Date and time when the member was exposed to the campaign. Explicitly identified in detection phase as relationship data.' ;
    rdfs:domain ind:CampaignExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:impressionCount rdf:type rdf:Property ;
    rdfs:label 'Impression Count' ;
    rdfs:comment 'Number of times this member was exposed to this campaign (for frequency capping and saturation analysis).' ;
    rdfs:domain ind:CampaignExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:memberSegmentAtExposure rdf:type rdf:Property ;
    rdfs:label 'Member Segment At Exposure' ;
    rdfs:comment 'Member segment classification at the time of exposure, captured for campaign effectiveness analysis by segment.' ;
    rdfs:domain ind:CampaignExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseFlag rdf:type rdf:Property ;
    rdfs:label 'Response Flag' ;
    rdfs:comment 'Indicates whether the member responded to the campaign exposure (clicked, opened, engaged). Explicitly identified in detection phase as relationship data.' ;
    rdfs:domain ind:CampaignExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tierLevelAtExposure rdf:type rdf:Property ;
    rdfs:label 'Tier Level At Exposure' ;
    rdfs:comment 'FFP tier level of the member at the time of exposure, captured for tier-specific campaign performance analysis.' ;
    rdfs:domain ind:CampaignExposure ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaseCostAllocationId rdf:type rdf:Property ;
    rdfs:label 'Lease Cost Allocation Id' ;
    rdfs:comment 'Unique surrogate identifier for the lease cost allocation record' ;
    rdfs:domain ind:LeaseCostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:glJournalEntryId rdf:type rdf:Property ;
    rdfs:label 'Gl Journal Entry Id' ;
    rdfs:comment 'Reference to the SAP S/4HANA general ledger journal entry document generated from this allocation record. Supports audit trail and reconciliation between cost allocation system and financial ledger.' ;
    rdfs:domain ind:LeaseCostAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JournalEntry .

ind:allocationMethod rdf:type rdf:Property ;
    rdfs:label 'Allocation Method' ;
    rdfs:comment 'Methodology used to allocate lease costs to this flight. FLIGHT_HOURS: proportional to block hours; CYCLE_COUNT: proportional to takeoff/landing cycles; REVENUE_SHARE: proportional to revenue generated; SEAT_MILES: proportional to available seat miles; MANUAL: finance-approved override allocation.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationPercentage rdf:type rdf:Property ;
    rdfs:label 'Allocation Percentage' ;
    rdfs:comment 'Percentage of the lease contract\'s periodic cost allocated to this specific flight inventory record, expressed as a decimal (e.g., 0.0125 = 1.25%). Sum of allocation percentages across all flights for a given lease-period should equal 1.0.' ;
    rdfs:domain ind:LeaseCostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allocationPeriod rdf:type rdf:Property ;
    rdfs:label 'Allocation Period' ;
    rdfs:comment 'Accounting period (YYYY-MM format) for which this lease cost allocation applies. Supports monthly close processes and period-over-period cost variance analysis.' ;
    rdfs:domain ind:LeaseCostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flightHoursAttributed rdf:type rdf:Property ;
    rdfs:label 'Flight Hours Attributed' ;
    rdfs:comment 'Block hours (departure gate to arrival gate) attributed to this flight for the purpose of lease cost allocation. Used in utilization-based allocation methods where lease cost is distributed proportionally to flight hours operated.' ;
    rdfs:domain ind:LeaseCostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:codeshareFlightExecutionId rdf:type rdf:Property ;
    rdfs:label 'Codeshare Flight Execution Id' ;
    rdfs:comment 'Unique identifier for this codeshare flight execution record. Primary key.' ;
    rdfs:domain ind:CodeshareFlightExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:codeshareFlightNumberUsed rdf:type rdf:Property ;
    rdfs:label 'Codeshare Flight Number Used' ;
    rdfs:comment 'The specific marketing carrier flight number assigned and used for this codeshare execution, including carrier code and numeric identifier. This is the flight number passengers see on their tickets.' ;
    rdfs:domain ind:CodeshareFlightExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerNotificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Partner Notification Timestamp' ;
    rdfs:comment 'UTC timestamp when the partner carrier was notified of operational details for this codeshare flight execution (schedule changes, delays, cancellations). Critical for partner carrier customer service operations.' ;
    rdfs:domain ind:CodeshareFlightExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:prorateCalculationBasis rdf:type rdf:Property ;
    rdfs:label 'Prorate Calculation Basis' ;
    rdfs:comment 'The method or formula used to calculate revenue allocation for this specific flight execution (e.g., IATA standard prorate, special prorate agreement percentage, block-space fixed amount). Documents how revenue_share_amount was derived.' ;
    rdfs:domain ind:CodeshareFlightExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueShareAmount rdf:type rdf:Property ;
    rdfs:label 'Revenue Share Amount' ;
    rdfs:comment 'The calculated revenue amount allocated to the partner carrier for this specific flight leg execution under the partnership agreement terms. Used for settlement reconciliation.' ;
    rdfs:domain ind:CodeshareFlightExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:seatAllocationCount rdf:type rdf:Property ;
    rdfs:label 'Seat Allocation Count' ;
    rdfs:comment 'Number of seats allocated to the marketing carrier for this specific flight execution under block-space agreements. Null for free-flow codeshare arrangements.' ;
    rdfs:domain ind:CodeshareFlightExecution ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:segmentAncillaryPurchaseId rdf:type rdf:Property ;
    rdfs:label 'Segment Ancillary Purchase Id' ;
    rdfs:comment 'Unique identifier for this segment-level ancillary purchase transaction. Primary key for the association.' ;
    rdfs:domain ind:SegmentAncillaryPurchase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pricePaid rdf:type rdf:Property ;
    rdfs:label 'Price Paid' ;
    rdfs:comment 'Actual price paid for this ancillary purchase on this segment. May differ from catalog base price due to dynamic pricing, promotions, bundling, or passenger-specific discounts.' ;
    rdfs:domain ind:SegmentAncillaryPurchase ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:passengerPromotionEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Passenger Promotion Enrollment Id' ;
    rdfs:comment 'Primary key for passenger_promotion_enrollment' ;
    rdfs:domain ind:PassengerPromotionEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:promotionEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Promotion Enrollment Id' ;
    rdfs:comment 'Unique identifier for this promotion enrollment record. Primary key.' ;
    rdfs:domain ind:PassengerPromotionEnrollment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LoyaltyPromotionEnrollment .

ind:promotionLoyaltyPromotionId rdf:type rdf:Property ;
    rdfs:label 'Promotion Loyalty Promotion Id' ;
    rdfs:comment 'Foreign key linking to the loyalty promotion campaign' ;
    rdfs:domain ind:PassengerPromotionEnrollment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LoyaltyPromotion .

ind:enrollmentCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Enrollment Created Timestamp' ;
    rdfs:comment 'Timestamp when this enrollment record was first created in the system. Immutable audit field.' ;
    rdfs:domain ind:PassengerPromotionEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:enrollmentUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Enrollment Updated Timestamp' ;
    rdfs:comment 'Timestamp when this enrollment record was last modified. Updated when status changes or bonus miles are awarded.' ;
    rdfs:domain ind:PassengerPromotionEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:qualificationProgress rdf:type rdf:Property ;
    rdfs:label 'Qualification Progress' ;
    rdfs:comment 'Percentage progress (0.00 to 100.00) toward meeting the promotion qualification requirements. Calculated based on flights taken, miles earned, or other promotion-specific criteria. Explicitly identified in detection phase relationship data.' ;
    rdfs:domain ind:PassengerPromotionEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costAllocationId rdf:type rdf:Property ;
    rdfs:label 'Cost Allocation Id' ;
    rdfs:comment 'Unique surrogate identifier for this compliance cost allocation record. Primary key.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allocationDriverValue rdf:type rdf:Property ;
    rdfs:label 'Allocation Driver Value' ;
    rdfs:comment 'Quantitative value of the allocation driver used for this cost centre (e.g., 12500 flight hours, 450 employees, 2.5M ASK) that determines the cost_sharing_ratio' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annualComplianceCost rdf:type rdf:Property ;
    rdfs:label 'Annual Compliance Cost' ;
    rdfs:comment 'Total annual cost amount allocated to this cost centre for compliance with this specific regulatory requirement, in the cost centre\'s controlling currency' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetAllocationPercentage rdf:type rdf:Property ;
    rdfs:label 'Budget Allocation Percentage' ;
    rdfs:comment 'Percentage of the total compliance cost for this regulatory requirement allocated to this cost centre (0.00 to 100.00). Sum across all cost centres for a requirement should equal 100%.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costSharingRatio rdf:type rdf:Property ;
    rdfs:label 'Cost Sharing Ratio' ;
    rdfs:comment 'Proportional cost sharing ratio used to distribute compliance costs to this cost centre based on activity drivers (e.g., flight hours, ASK, headcount). Used for dynamic cost allocation calculations.' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastUpdatedDate rdf:type rdf:Property ;
    rdfs:label 'Last Updated Date' ;
    rdfs:comment 'Timestamp when this allocation record was last modified' ;
    rdfs:domain ind:CostAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:airportSlotAllocationId rdf:type rdf:Property ;
    rdfs:label 'Airport Slot Allocation Id' ;
    rdfs:comment 'Primary key for airport_slot_allocation' ;
    rdfs:domain ind:AirportSlotAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slotAllocationSlotId rdf:type rdf:Property ;
    rdfs:label 'Slot Allocation Slot Id' ;
    rdfs:comment 'Unique identifier for this slot allocation record. Primary key.' ;
    rdfs:domain ind:AirportSlotAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Slot .

ind:slotTimeArrival rdf:type rdf:Property ;
    rdfs:label 'Slot Time Arrival' ;
    rdfs:comment 'Allocated landing slot time at the arrival airport as assigned by Air Traffic Control (ATC) or airport slot coordinator. Critical for slot-controlled airports. [Moved from scheduled_flight: This attribute represents the allocated landing slot time for a specific scheduled flight at a specific airport, which is relationship-specific data. A scheduled flight may have different arrival slot times across different seasons or when slots are reallocated, making this an attribute of the allocation relationship rather than an intrinsic property of the scheduled flight itself.]' ;
    rdfs:domain ind:AirportSlotAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:slotTimeDeparture rdf:type rdf:Property ;
    rdfs:label 'Slot Time Departure' ;
    rdfs:comment 'Allocated takeoff slot time at the departure airport as assigned by Air Traffic Control (ATC) or airport slot coordinator. Critical for slot-controlled airports. [Moved from scheduled_flight: This attribute represents the allocated takeoff slot time for a specific scheduled flight at a specific airport, which is relationship-specific data. A scheduled flight may have different slot times across different seasons or when slots are reallocated, making this an attribute of the allocation relationship rather than an intrinsic property of the scheduled flight itself.]' ;
    rdfs:domain ind:AirportSlotAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:aircraftTypeQualified rdf:type rdf:Property ;
    rdfs:label 'Aircraft Type Qualified' ;
    rdfs:comment 'Comma-separated list of aircraft types this crew is qualified to service (e.g., \'B737, A320, B777, A350\').' ;
    rdfs:domain ind:DeicingCrew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageTurnaroundTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Average Turnaround Time Minutes' ;
    rdfs:comment 'Historical average time in minutes this crew takes to complete a standard deicing operation.' ;
    rdfs:domain ind:DeicingCrew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cdmParticipant rdf:type rdf:Property ;
    rdfs:label 'Cdm Participant' ;
    rdfs:comment 'Indicates whether this crew participates in Airport Collaborative Decision Making (A-CDM) processes for coordinated deicing operations.' ;
    rdfs:domain ind:DeicingCrew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractorCompanyName rdf:type rdf:Property ;
    rdfs:label 'Contractor Company Name' ;
    rdfs:comment 'Name of the third-party contractor company providing this deicing crew, if applicable (null for internal crews).' ;
    rdfs:domain ind:DeicingCrew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costPerHour rdf:type rdf:Property ;
    rdfs:label 'Cost Per Hour' ;
    rdfs:comment 'Hourly cost rate for deploying this deicing crew, including labor, equipment, and overhead (in base currency).' ;
    rdfs:domain ind:DeicingCrew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:crewCode rdf:type rdf:Property ;
    rdfs:label 'Crew Code' ;
    rdfs:comment 'Externally-known unique alphanumeric code identifying the deicing crew for operational reference and scheduling systems.' ;
    rdfs:domain ind:DeicingCrew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crewName rdf:type rdf:Property ;
    rdfs:label 'Crew Name' ;
    rdfs:comment 'Human-readable name or designation of the deicing crew (e.g., \'Alpha Deicing Team\', \'Night Shift Crew 3\').' ;
    rdfs:domain ind:DeicingCrew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crewSize rdf:type rdf:Property ;
    rdfs:label 'Crew Size' ;
    rdfs:comment 'Number of personnel assigned to this deicing crew.' ;
    rdfs:domain ind:DeicingCrew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:crewStatus rdf:type rdf:Property ;
    rdfs:label 'Crew Status' ;
    rdfs:comment 'Current operational status of the deicing crew indicating availability and lifecycle state.' ;
    rdfs:domain ind:DeicingCrew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crewType rdf:type rdf:Property ;
    rdfs:label 'Crew Type' ;
    rdfs:comment 'Classification of the deicing crew based on employment and operational model (internal airline staff, third-party contractor, hybrid, seasonal, emergency response, or standby).' ;
    rdfs:domain ind:DeicingCrew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyResponseCapable rdf:type rdf:Property ;
    rdfs:label 'Emergency Response Capable' ;
    rdfs:comment 'Indicates whether this crew is trained and equipped for emergency deicing operations during severe weather events.' ;
    rdfs:domain ind:DeicingCrew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:equipmentAssigned rdf:type rdf:Property ;
    rdfs:label 'Equipment Assigned' ;
    rdfs:comment 'Comma-separated list or description of ground support equipment (GSE) and deicing vehicles assigned to this crew (e.g., \'Type I truck, Type IV truck, bucket lift\').' ;
    rdfs:domain ind:DeicingCrew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fluidTypeAuthorized rdf:type rdf:Property ;
    rdfs:label 'Fluid Type Authorized' ;
    rdfs:comment 'Types of deicing and anti-icing fluids this crew is certified to apply (e.g., \'Type I, Type II, Type IV\' per AMS 1424/1428 standards).' ;
    rdfs:domain ind:DeicingCrew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageProficiency rdf:type rdf:Property ;
    rdfs:label 'Language Proficiency' ;
    rdfs:comment 'Languages spoken by crew members for communication with flight crew and ground operations (e.g., \'English, French, Spanish\').' ;
    rdfs:domain ind:DeicingCrew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastTrainingDate rdf:type rdf:Property ;
    rdfs:label 'Last Training Date' ;
    rdfs:comment 'Date of the most recent training session completed by this deicing crew.' ;
    rdfs:domain ind:DeicingCrew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextTrainingDate rdf:type rdf:Property ;
    rdfs:label 'Next Training Date' ;
    rdfs:comment 'Scheduled date for the next mandatory training or recertification session.' ;
    rdfs:domain ind:DeicingCrew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operationalHoursCapacity rdf:type rdf:Property ;
    rdfs:label 'Operational Hours Capacity' ;
    rdfs:comment 'Maximum number of operational hours this crew can work per shift or per day, based on regulatory and safety limits.' ;
    rdfs:domain ind:DeicingCrew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safetyIncidentCount rdf:type rdf:Property ;
    rdfs:label 'Safety Incident Count' ;
    rdfs:comment 'Cumulative count of safety incidents or violations recorded for this crew since activation.' ;
    rdfs:domain ind:DeicingCrew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supervisorName rdf:type rdf:Property ;
    rdfs:label 'Supervisor Name' ;
    rdfs:comment 'Full name of the supervisor or crew lead responsible for this deicing crew.' ;
    rdfs:domain ind:DeicingCrew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestingCrewMemberId rdf:type rdf:Property ;
    rdfs:label 'Requesting Crew Member Id' ;
    rdfs:comment 'Identifier of the crew member initiating the swap request.' ;
    rdfs:domain ind:SwapRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Member .

ind:requestingPairingId rdf:type rdf:Property ;
    rdfs:label 'Requesting Pairing Id' ;
    rdfs:comment 'Identifier of the pairing that the requesting crew member wants to swap away from.' ;
    rdfs:domain ind:SwapRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Pairing .

ind:targetCrewMemberId rdf:type rdf:Property ;
    rdfs:label 'Target Crew Member Id' ;
    rdfs:comment 'Identifier of the crew member being asked to swap assignments.' ;
    rdfs:domain ind:SwapRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Member .

ind:targetPairingId rdf:type rdf:Property ;
    rdfs:label 'Target Pairing Id' ;
    rdfs:comment 'Identifier of the pairing that the requesting crew member wants to swap into.' ;
    rdfs:domain ind:SwapRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Pairing .

ind:expirationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Expiration Timestamp' ;
    rdfs:comment 'Date and time after which the swap request is no longer valid if not acted upon.' ;
    rdfs:domain ind:SwapRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:legalityViolationDetails rdf:type rdf:Property ;
    rdfs:label 'Legality Violation Details' ;
    rdfs:comment 'Detailed description of any legality violations or warnings identified during the check.' ;
    rdfs:domain ind:SwapRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mutualSwapFlag rdf:type rdf:Property ;
    rdfs:label 'Mutual Swap Flag' ;
    rdfs:comment 'Indicates whether this is a mutual swap where both crew members exchange assignments (true) or a one-way swap (false).' ;
    rdfs:domain ind:SwapRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualificationViolationDetails rdf:type rdf:Property ;
    rdfs:label 'Qualification Violation Details' ;
    rdfs:comment 'Details of any qualification, type rating, or recency violations identified.' ;
    rdfs:domain ind:SwapRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestingCrewBaseCode rdf:type rdf:Property ;
    rdfs:label 'Requesting Crew Base Code' ;
    rdfs:comment 'Three-letter IATA code of the crew base for the requesting crew member.' ;
    rdfs:domain ind:SwapRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresQualificationCheck rdf:type rdf:Property ;
    rdfs:label 'Requires Qualification Check' ;
    rdfs:comment 'Indicates whether the swap requires validation of crew qualifications, type ratings, and recency requirements.' ;
    rdfs:domain ind:SwapRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:swapType rdf:type rdf:Property ;
    rdfs:label 'Swap Type' ;
    rdfs:comment 'Type of swap being requested: pairing (full sequence), trip, duty period, single leg, reserve day, or day off.' ;
    rdfs:domain ind:SwapRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:systemGeneratedFlag rdf:type rdf:Property ;
    rdfs:label 'System Generated Flag' ;
    rdfs:comment 'Indicates whether the swap request was automatically generated by the system (true) or manually created by a crew member (false).' ;
    rdfs:domain ind:SwapRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:targetCrewBaseCode rdf:type rdf:Property ;
    rdfs:label 'Target Crew Base Code' ;
    rdfs:comment 'Three-letter IATA code of the crew base for the target crew member.' ;
    rdfs:domain ind:SwapRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetResponse rdf:type rdf:Property ;
    rdfs:label 'Target Response' ;
    rdfs:comment 'Response from the target crew member regarding the swap request.' ;
    rdfs:domain ind:SwapRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetResponseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Target Response Timestamp' ;
    rdfs:comment 'Date and time when the target crew member responded to the swap request.' ;
    rdfs:domain ind:SwapRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:bankId rdf:type rdf:Property ;
    rdfs:label 'Bank Id' ;
    rdfs:comment 'Reference to the financial institution providing the cash pooling service and managing the pool accounts.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Bank .

ind:treasuryManagerEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Treasury Manager Employee Id' ;
    rdfs:comment 'Reference to the employee responsible for managing and monitoring this cash pool arrangement.' ;
    rdfs:domain ind:CashPool ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:autoSweepEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Sweep Enabled Flag' ;
    rdfs:comment 'Indicates whether automatic cash sweeping is enabled to transfer excess balances from participant accounts to the master account.' ;
    rdfs:domain ind:CashPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:baseInterestRate rdf:type rdf:Property ;
    rdfs:label 'Base Interest Rate' ;
    rdfs:comment 'Reference interest rate (in decimal form, e.g., 0.0525 for 5.25%) used as the foundation for pool interest calculations, typically linked to a benchmark rate such as LIBOR, SOFR, or EURIBOR.' ;
    rdfs:domain ind:CashPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:createdByUserCode rdf:type rdf:Property ;
    rdfs:label 'Created By User Code' ;
    rdfs:comment 'User identifier of the person who created this cash pool record.' ;
    rdfs:domain ind:CashPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ifrs16ApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Ifrs 16 Applicable Flag' ;
    rdfs:comment 'Indicates whether IFRS 16 lease accounting considerations apply to this cash pool, relevant when pool is linked to lease liability financing arrangements.' ;
    rdfs:domain ind:CashPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interestCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Interest Calculation Method' ;
    rdfs:comment 'Day count convention used for calculating interest on pooled balances and compensating participating accounts.' ;
    rdfs:domain ind:CashPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interestSpreadBps rdf:type rdf:Property ;
    rdfs:label 'Interest Spread Bps' ;
    rdfs:comment 'Spread in basis points (1 bp = 0.01%) added to or subtracted from the base rate for credit or debit positions within the pool.' ;
    rdfs:domain ind:CashPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:masterAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Master Account Number' ;
    rdfs:comment 'The primary bank account number serving as the header or concentration account for the cash pool structure.' ;
    rdfs:domain ind:CashPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumPoolLimit rdf:type rdf:Property ;
    rdfs:label 'Maximum Pool Limit' ;
    rdfs:comment 'Maximum aggregate exposure or balance limit for the cash pool arrangement, set by the bank or internal treasury policy.' ;
    rdfs:domain ind:CashPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumBalanceThreshold rdf:type rdf:Property ;
    rdfs:label 'Minimum Balance Threshold' ;
    rdfs:comment 'Minimum aggregate balance required to be maintained in the cash pool to avoid penalties or maintain favorable interest terms.' ;
    rdfs:domain ind:CashPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:modifiedByUserCode rdf:type rdf:Property ;
    rdfs:label 'Modified By User Code' ;
    rdfs:comment 'User identifier of the person who last modified this cash pool record.' ;
    rdfs:domain ind:CashPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nettingEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Netting Enabled Flag' ;
    rdfs:comment 'Indicates whether intercompany netting is enabled within the cash pool to offset payables and receivables among participating entities.' ;
    rdfs:domain ind:CashPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overdraftFacilityFlag rdf:type rdf:Property ;
    rdfs:label 'Overdraft Facility Flag' ;
    rdfs:comment 'Indicates whether the cash pool includes an overdraft facility allowing negative aggregate balances up to an approved limit.' ;
    rdfs:domain ind:CashPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overdraftLimit rdf:type rdf:Property ;
    rdfs:label 'Overdraft Limit' ;
    rdfs:comment 'Maximum overdraft amount permitted for the cash pool when overdraft facility is enabled. Nullable if no overdraft facility exists.' ;
    rdfs:domain ind:CashPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:poolCode rdf:type rdf:Property ;
    rdfs:label 'Pool Code' ;
    rdfs:comment 'Externally-known unique business identifier for the cash pool arrangement, used in treasury operations and intercompany settlements.' ;
    rdfs:domain ind:CashPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poolName rdf:type rdf:Property ;
    rdfs:label 'Pool Name' ;
    rdfs:comment 'Human-readable name of the cash pool arrangement, typically reflecting the participating entities or geographic scope.' ;
    rdfs:domain ind:CashPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poolStatus rdf:type rdf:Property ;
    rdfs:label 'Pool Status' ;
    rdfs:comment 'Current lifecycle status of the cash pool arrangement indicating operational state and availability for treasury operations.' ;
    rdfs:domain ind:CashPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poolType rdf:type rdf:Property ;
    rdfs:label 'Pool Type' ;
    rdfs:comment 'Classification of the cash pooling structure: notional (interest compensation without physical transfer), physical (actual fund transfers), hybrid (combination), zero balancing (daily sweep to zero), target balancing (sweep to target level), or header structure (master account with sub-accounts).' ;
    rdfs:domain ind:CashPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poolingFrequency rdf:type rdf:Property ;
    rdfs:label 'Pooling Frequency' ;
    rdfs:comment 'Frequency at which cash concentration or interest calculation occurs within the pool structure.' ;
    rdfs:domain ind:CashPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryApprovalNumber rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Number' ;
    rdfs:comment 'Reference number for regulatory approval or notification required for cross-border or multi-jurisdictional cash pooling arrangements.' ;
    rdfs:domain ind:CashPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sweepThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Sweep Threshold Amount' ;
    rdfs:comment 'Minimum balance threshold that triggers an automatic sweep transaction from a participant account to the master account.' ;
    rdfs:domain ind:CashPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetBalanceAmount rdf:type rdf:Property ;
    rdfs:label 'Target Balance Amount' ;
    rdfs:comment 'Target balance to be maintained in participant accounts after sweep operations in target balancing pool structures.' ;
    rdfs:domain ind:CashPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:withholdingTaxRate rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Rate' ;
    rdfs:comment 'Applicable withholding tax rate (in decimal form, e.g., 0.15 for 15%) on interest income generated within the cash pool, based on tax jurisdiction.' ;
    rdfs:domain ind:CashPool ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:legalEntityId rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Id' ;
    rdfs:comment 'Primary key for legal_entity' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentEntityId rdf:type rdf:Property ;
    rdfs:label 'Parent Entity Id' ;
    rdfs:comment 'Reference to the immediate parent legal entity in the corporate ownership hierarchy. Null if this is the ultimate parent.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:ultimateParentEntityId rdf:type rdf:Property ;
    rdfs:label 'Ultimate Parent Entity Id' ;
    rdfs:comment 'Reference to the top-level parent legal entity in the corporate ownership hierarchy. Null if this is the ultimate parent.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:accountingStandard rdf:type rdf:Property ;
    rdfs:label 'Accounting Standard' ;
    rdfs:comment 'Primary accounting framework used by the entity for financial reporting (IFRS, US GAAP, or local GAAP).' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:airOperatorCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Air Operator Certificate Number' ;
    rdfs:comment 'Certificate number issued by the civil aviation authority authorizing the entity to conduct commercial air transport operations.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aocEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Aoc Effective Date' ;
    rdfs:comment 'Date on which the Air Operator Certificate became effective and the entity was authorized to commence operations.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:aocExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Aoc Expiry Date' ;
    rdfs:comment 'Date on which the Air Operator Certificate expires and must be renewed. Null if certificate has no expiry.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:aocIssuingAuthority rdf:type rdf:Property ;
    rdfs:label 'Aoc Issuing Authority' ;
    rdfs:comment 'Name of the civil aviation authority that issued the Air Operator Certificate (e.g., FAA, EASA, CAAC).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationMethod rdf:type rdf:Property ;
    rdfs:label 'Consolidation Method' ;
    rdfs:comment 'Accounting method used to consolidate this entity\'s financial results into group reporting.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalYearEndDay rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year End Day' ;
    rdfs:comment 'Day of month (1-31) representing the end of the entity\'s fiscal year.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fiscalYearEndMonth rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year End Month' ;
    rdfs:comment 'Month number (1-12) representing the end of the entity\'s fiscal year for financial reporting purposes.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:incorporationCountryCode rdf:type rdf:Property ;
    rdfs:label 'Incorporation Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the jurisdiction where the entity is incorporated.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incorporationJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Incorporation Jurisdiction' ;
    rdfs:comment 'State, province, or sub-national jurisdiction within the incorporation country (e.g., Delaware, Ontario).' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalEntityName rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Name' ;
    rdfs:comment 'Full registered legal name of the entity as it appears in incorporation documents and regulatory filings.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalForm rdf:type rdf:Property ;
    rdfs:label 'Legal Form' ;
    rdfs:comment 'Type of legal structure of the entity (e.g., corporation, LLC, partnership, branch).' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leiCode rdf:type rdf:Property ;
    rdfs:label 'Lei Code' ;
    rdfs:comment 'ISO 17442 Legal Entity Identifier, a 20-character alphanumeric code for unique identification in financial transactions and regulatory reporting.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Operating Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the primary country where the entity conducts business operations.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredCountryCode rdf:type rdf:Property ;
    rdfs:label 'Registered Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the registered address.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Status' ;
    rdfs:comment 'Current regulatory standing of the legal entity with the corporate registry or governing authority.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Reporting Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code used for financial reporting and consolidation purposes.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aircraftLeasedToAirlineCount rdf:type rdf:Property ;
    rdfs:label 'Aircraft Leased To Airline Count' ;
    rdfs:comment 'Number of aircraft currently leased from this lessor to Airlines.' ;
    rdfs:domain ind:Lessor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:businessAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Business Address Line1' ;
    rdfs:comment 'First line of the lessor\'s registered business address (street number and name).' ;
    rdfs:domain ind:Lessor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Business Address Line2' ;
    rdfs:comment 'Second line of the lessor\'s registered business address (suite, floor, building name).' ;
    rdfs:domain ind:Lessor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessCity rdf:type rdf:Property ;
    rdfs:label 'Business City' ;
    rdfs:comment 'City of the lessor\'s registered business address.' ;
    rdfs:domain ind:Lessor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessCountryCode rdf:type rdf:Property ;
    rdfs:label 'Business Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code for the lessor\'s registered business address.' ;
    rdfs:domain ind:Lessor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessPostalCode rdf:type rdf:Property ;
    rdfs:label 'Business Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the lessor\'s registered business address.' ;
    rdfs:domain ind:Lessor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessStateProvince rdf:type rdf:Property ;
    rdfs:label 'Business State Province' ;
    rdfs:comment 'State, province, or administrative region of the lessor\'s registered business address.' ;
    rdfs:domain ind:Lessor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditRating rdf:type rdf:Property ;
    rdfs:label 'Credit Rating' ;
    rdfs:comment 'Current credit rating assigned to the lessor by recognized rating agencies (e.g., Moody\'s, S&P, Fitch).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditRatingAgency rdf:type rdf:Property ;
    rdfs:label 'Credit Rating Agency' ;
    rdfs:comment 'Name of the credit rating agency that issued the credit rating.' ;
    rdfs:domain ind:Lessor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditRatingDate rdf:type rdf:Property ;
    rdfs:label 'Credit Rating Date' ;
    rdfs:comment 'Date when the current credit rating was issued or last updated.' ;
    rdfs:domain ind:Lessor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fleetSize rdf:type rdf:Property ;
    rdfs:label 'Fleet Size' ;
    rdfs:comment 'Total number of aircraft owned by the lessor across all customers and aircraft types.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:headquartersCity rdf:type rdf:Property ;
    rdfs:label 'Headquarters City' ;
    rdfs:comment 'City where the lessor\'s primary headquarters office is located.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersCountryCode rdf:type rdf:Property ;
    rdfs:label 'Headquarters Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code representing the country where the lessor\'s headquarters is located.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Insurance Certificate Number' ;
    rdfs:comment 'Reference number of the lessor\'s liability insurance certificate on file with Airlines.' ;
    rdfs:domain ind:Lessor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lessorCode rdf:type rdf:Property ;
    rdfs:label 'Lessor Code' ;
    rdfs:comment 'Unique alphanumeric code assigned to the lessor for operational reference and system integration.' ;
    rdfs:domain ind:Lessor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lessorType rdf:type rdf:Property ;
    rdfs:label 'Lessor Type' ;
    rdfs:comment 'Classification of the lessor based on their business model and lease structure (operating lease, finance lease, sale-leaseback, manufacturer-backed, bank-owned, or private equity).' ;
    rdfs:domain ind:Lessor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextAuditDate rdf:type rdf:Property ;
    rdfs:label 'Next Audit Date' ;
    rdfs:comment 'Scheduled date for the next financial or operational audit of the lessor.' ;
    rdfs:domain ind:Lessor ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:status rdf:type rdf:Property ;
    rdfs:label 'Status' ;
    rdfs:comment 'Current operational status of the lessor relationship in the fleet management system.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierId rdf:type rdf:Property ;
    rdfs:label 'Carrier Id' ;
    rdfs:comment 'Primary key for carrier' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountingCode rdf:type rdf:Property ;
    rdfs:label 'Accounting Code' ;
    rdfs:comment 'Three-digit numeric code assigned by IATA for financial settlement, ticketing, and interline accounting purposes.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aocIssueDate rdf:type rdf:Property ;
    rdfs:label 'Aoc Issue Date' ;
    rdfs:comment 'Date when the carrier\'s current Air Operator Certificate was issued.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:callsign rdf:type rdf:Property ;
    rdfs:label 'Callsign' ;
    rdfs:comment 'Unique radio telephony callsign used by pilots and air traffic control for voice communications during flight operations.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cargoOperationsFlag rdf:type rdf:Property ;
    rdfs:label 'Cargo Operations Flag' ;
    rdfs:comment 'Indicates whether the carrier operates dedicated cargo or freight services.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:carrierName rdf:type rdf:Property ;
    rdfs:label 'Carrier Name' ;
    rdfs:comment 'Full legal name of the airline carrier as registered with aviation authorities.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierType rdf:type rdf:Property ;
    rdfs:label 'Carrier Type' ;
    rdfs:comment 'Classification of the carrier based on primary business model and service offering.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ceasedOperationsDate rdf:type rdf:Property ;
    rdfs:label 'Ceased Operations Date' ;
    rdfs:comment 'Date when the carrier permanently ceased flight operations, if applicable.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:codeshareParticipantFlag rdf:type rdf:Property ;
    rdfs:label 'Codeshare Participant Flag' ;
    rdfs:comment 'Indicates whether the carrier participates in codeshare agreements with other carriers.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commencedOperationsDate rdf:type rdf:Property ;
    rdfs:label 'Commenced Operations Date' ;
    rdfs:comment 'Date when the carrier began commercial flight operations.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:foundedDate rdf:type rdf:Property ;
    rdfs:label 'Founded Date' ;
    rdfs:comment 'Date when the carrier was originally established or incorporated.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:hubAirportCodes rdf:type rdf:Property ;
    rdfs:label 'Hub Airport Codes' ;
    rdfs:comment 'Comma-separated list of IATA airport codes representing the carrier\'s primary hub airports for network operations.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iataCode rdf:type rdf:Property ;
    rdfs:label 'Iata Code' ;
    rdfs:comment 'Two-character IATA airline designator code uniquely identifying the carrier in global distribution systems, reservations, and ticketing.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iataMemberFlag rdf:type rdf:Property ;
    rdfs:label 'Iata Member Flag' ;
    rdfs:comment 'Indicates whether the carrier is a member of the International Air Transport Association (IATA).' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iosaCertificationDate rdf:type rdf:Property ;
    rdfs:label 'Iosa Certification Date' ;
    rdfs:comment 'Date when the carrier received or last renewed its IOSA certification.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:iosaCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Iosa Certified Flag' ;
    rdfs:comment 'Indicates whether the carrier holds current IATA Operational Safety Audit (IOSA) certification.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iosaExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Iosa Expiry Date' ;
    rdfs:comment 'Date when the carrier\'s current IOSA certification expires and requires renewal.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lowCostCarrierFlag rdf:type rdf:Property ;
    rdfs:label 'Low Cost Carrier Flag' ;
    rdfs:comment 'Indicates whether the carrier operates under a low-cost carrier business model.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentCompanyName rdf:type rdf:Property ;
    rdfs:label 'Parent Company Name' ;
    rdfs:comment 'Name of the parent company or holding group that owns or controls the carrier.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regionalCarrierFlag rdf:type rdf:Property ;
    rdfs:label 'Regional Carrier Flag' ;
    rdfs:comment 'Indicates whether the carrier primarily operates regional or short-haul routes.' ;
    rdfs:domain ind:Carrier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:predecessorCycleId rdf:type rdf:Property ;
    rdfs:label 'Predecessor Cycle Id' ;
    rdfs:comment 'Reference to the previous qualification cycle that immediately preceded this one in the program timeline.' ;
    rdfs:domain ind:QualificationCycle ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QualificationCycle .

ind:successorCycleId rdf:type rdf:Property ;
    rdfs:label 'Successor Cycle Id' ;
    rdfs:comment 'Reference to the next qualification cycle that immediately follows this one in the program timeline.' ;
    rdfs:domain ind:QualificationCycle ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:QualificationCycle .

ind:benefitEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Benefit Effective Date' ;
    rdfs:comment 'The date when newly qualified tier benefits become active for members who qualified in this cycle.' ;
    rdfs:domain ind:QualificationCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:benefitExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Benefit Expiry Date' ;
    rdfs:comment 'The date when tier benefits earned through this qualification cycle expire.' ;
    rdfs:domain ind:QualificationCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:communicationSentDate rdf:type rdf:Property ;
    rdfs:label 'Communication Sent Date' ;
    rdfs:comment 'Date when members were notified about this qualification cycle (e.g., cycle start announcement, rule changes).' ;
    rdfs:domain ind:QualificationCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cycleCode rdf:type rdf:Property ;
    rdfs:label 'Cycle Code' ;
    rdfs:comment 'Business identifier code for the qualification cycle, used for external reference and reporting.' ;
    rdfs:domain ind:QualificationCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleName rdf:type rdf:Property ;
    rdfs:label 'Cycle Name' ;
    rdfs:comment 'Human-readable name of the qualification cycle (e.g., \'Calendar Year 2024\', \'Q1 2024 Elite Qualification\').' ;
    rdfs:domain ind:QualificationCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleType rdf:type rdf:Property ;
    rdfs:label 'Cycle Type' ;
    rdfs:comment 'Classification of the qualification cycle period structure (annual, semi-annual, quarterly, rolling 12-month, or custom).' ;
    rdfs:domain ind:QualificationCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:description rdf:type rdf:Property ;
    rdfs:label 'Description' ;
    rdfs:comment 'Detailed description of the qualification cycle, including any special rules, promotions, or conditions applicable to this cycle.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gracePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Grace Period Days' ;
    rdfs:comment 'Number of days after cycle end date during which late-posted qualifying activity may still be credited to the cycle.' ;
    rdfs:domain ind:QualificationCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isLifetimeEligible rdf:type rdf:Property ;
    rdfs:label 'Is Lifetime Eligible' ;
    rdfs:comment 'Indicates whether qualifying activity in this cycle counts toward lifetime status achievement.' ;
    rdfs:domain ind:QualificationCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:partnerActivityEligible rdf:type rdf:Property ;
    rdfs:label 'Partner Activity Eligible' ;
    rdfs:comment 'Indicates whether qualifying activity earned through partner airlines and coalition partners counts toward qualification in this cycle.' ;
    rdfs:domain ind:QualificationCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:promotionMultiplier rdf:type rdf:Property ;
    rdfs:label 'Promotion Multiplier' ;
    rdfs:comment 'Default promotional multiplier applied to qualifying activity during this cycle (e.g., 1.50 for 50% bonus).' ;
    rdfs:domain ind:QualificationCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualificationMetric rdf:type rdf:Property ;
    rdfs:label 'Qualification Metric' ;
    rdfs:comment 'The primary metric used to measure member qualification progress during this cycle (e.g., qualifying miles, qualifying points, qualifying segments, qualifying dollars, or hybrid combination).' ;
    rdfs:domain ind:QualificationCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rolloverAllowed rdf:type rdf:Property ;
    rdfs:label 'Rollover Allowed' ;
    rdfs:comment 'Indicates whether excess qualifying activity beyond the highest tier threshold can roll over to the next qualification cycle.' ;
    rdfs:domain ind:QualificationCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rolloverPercentage rdf:type rdf:Property ;
    rdfs:label 'Rollover Percentage' ;
    rdfs:comment 'Percentage of excess qualifying activity that rolls over to the next cycle if rollover is allowed (e.g., 50.00 for 50%).' ;
    rdfs:domain ind:QualificationCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:softLandingTiers rdf:type rdf:Property ;
    rdfs:label 'Soft Landing Tiers' ;
    rdfs:comment 'Number of tier levels a member drops if soft landing rule applies (e.g., 1 means drop one tier level).' ;
    rdfs:domain ind:QualificationCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tierRetentionRule rdf:type rdf:Property ;
    rdfs:label 'Tier Retention Rule' ;
    rdfs:comment 'Rule governing how members retain or lose tier status if they do not requalify (requalify from scratch, soft landing to lower tier, guaranteed period retention, or no retention).' ;
    rdfs:domain ind:QualificationCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualRevenueContribution rdf:type rdf:Property ;
    rdfs:label 'Annual Revenue Contribution' ;
    rdfs:comment 'Estimated or actual annual revenue contribution from this partnership in the airline\'s reporting currency.' ;
    rdfs:domain ind:PartnerOrganization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:brandVisibilityLevel rdf:type rdf:Property ;
    rdfs:label 'Brand Visibility Level' ;
    rdfs:comment 'Level of brand visibility and co-branding prominence granted to the partner in marketing materials.' ;
    rdfs:domain ind:PartnerOrganization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codeshareEnabled rdf:type rdf:Property ;
    rdfs:label 'Codeshare Enabled' ;
    rdfs:comment 'Indicates whether codeshare flight arrangements are enabled with this airline partner.' ;
    rdfs:domain ind:PartnerOrganization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:commissionRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Commission Rate Percentage' ;
    rdfs:comment 'Standard commission rate percentage paid to or received from the partner organization.' ;
    rdfs:domain ind:PartnerOrganization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractRenewalDate rdf:type rdf:Property ;
    rdfs:label 'Contract Renewal Date' ;
    rdfs:comment 'Next scheduled date for partnership contract renewal or review.' ;
    rdfs:domain ind:PartnerOrganization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dataSharingAgreement rdf:type rdf:Property ;
    rdfs:label 'Data Sharing Agreement' ;
    rdfs:comment 'Indicates whether a formal data sharing agreement exists with the partner organization.' ;
    rdfs:domain ind:PartnerOrganization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gdprCompliant rdf:type rdf:Property ;
    rdfs:label 'Gdpr Compliant' ;
    rdfs:comment 'Indicates whether the partner organization has been verified as GDPR compliant for data processing activities.' ;
    rdfs:domain ind:PartnerOrganization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interlineAgreement rdf:type rdf:Property ;
    rdfs:label 'Interline Agreement' ;
    rdfs:comment 'Indicates whether an interline ticketing agreement exists with this airline partner.' ;
    rdfs:domain ind:PartnerOrganization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalEntityIdentifier rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Identifier' ;
    rdfs:comment 'ISO 17442 compliant Legal Entity Identifier for the partner organization.' ;
    rdfs:domain ind:PartnerOrganization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loyaltyProgramIntegration rdf:type rdf:Property ;
    rdfs:label 'Loyalty Program Integration' ;
    rdfs:comment 'Indicates whether the partner organization is integrated with the airline\'s loyalty program for points earning and redemption.' ;
    rdfs:domain ind:PartnerOrganization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketingCampaignParticipation rdf:type rdf:Property ;
    rdfs:label 'Marketing Campaign Participation' ;
    rdfs:comment 'Indicates whether the partner organization actively participates in co-branded marketing campaigns.' ;
    rdfs:domain ind:PartnerOrganization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netPromoterScore rdf:type rdf:Property ;
    rdfs:label 'Net Promoter Score' ;
    rdfs:comment 'Net Promoter Score measuring the partner organization\'s likelihood to recommend the airline to other potential partners, ranging from -100 to +100.' ;
    rdfs:domain ind:PartnerOrganization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:partnerSatisfactionScore rdf:type rdf:Property ;
    rdfs:label 'Partner Satisfaction Score' ;
    rdfs:comment 'Satisfaction score from partner relationship surveys, typically on a scale of 0 to 10.' ;
    rdfs:domain ind:PartnerOrganization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partnershipEndDate rdf:type rdf:Property ;
    rdfs:label 'Partnership End Date' ;
    rdfs:comment 'Date when the partnership relationship ended or is scheduled to end. Null for active ongoing partnerships.' ;
    rdfs:domain ind:PartnerOrganization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:partnershipStartDate rdf:type rdf:Property ;
    rdfs:label 'Partnership Start Date' ;
    rdfs:comment 'Date when the partnership relationship officially commenced.' ;
    rdfs:domain ind:PartnerOrganization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:partnershipStatus rdf:type rdf:Property ;
    rdfs:label 'Partnership Status' ;
    rdfs:comment 'Current lifecycle status of the partnership relationship.' ;
    rdfs:domain ind:PartnerOrganization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnershipTier rdf:type rdf:Property ;
    rdfs:label 'Partnership Tier' ;
    rdfs:comment 'Strategic classification indicating the level of partnership engagement and benefits.' ;
    rdfs:domain ind:PartnerOrganization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredCommunicationLanguage rdf:type rdf:Property ;
    rdfs:label 'Preferred Communication Language' ;
    rdfs:comment 'ISO 639-1 two-letter language code for the partner organization\'s preferred communication language.' ;
    rdfs:domain ind:PartnerOrganization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:callToActionUrl rdf:type rdf:Property ;
    rdfs:label 'Call To Action Url' ;
    rdfs:comment 'Destination URL for the call-to-action link, including tracking parameters for attribution.' ;
    rdfs:domain ind:AbTestVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionCount rdf:type rdf:Property ;
    rdfs:label 'Conversion Count' ;
    rdfs:comment 'Total number of conversions (desired actions) achieved by this variant during the test.' ;
    rdfs:domain ind:AbTestVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:creativeAssetUrl rdf:type rdf:Property ;
    rdfs:label 'Creative Asset Url' ;
    rdfs:comment 'URL or file path to the creative asset (image, video, HTML template) used in this variant.' ;
    rdfs:domain ind:AbTestVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expectedLiftPercentage rdf:type rdf:Property ;
    rdfs:label 'Expected Lift Percentage' ;
    rdfs:comment 'Anticipated percentage improvement in the primary success metric compared to control variant.' ;
    rdfs:domain ind:AbTestVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isWinner rdf:type rdf:Property ;
    rdfs:label 'Is Winner' ;
    rdfs:comment 'Boolean flag indicating whether this variant was declared the winner of the A/B test based on statistical significance and business criteria.' ;
    rdfs:domain ind:AbTestVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:messagingContent rdf:type rdf:Property ;
    rdfs:label 'Messaging Content' ;
    rdfs:comment 'Text content or copy used in the variant, including headlines, body text, and call-to-action messaging.' ;
    rdfs:domain ind:AbTestVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Offer Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for monetary offers (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:AbTestVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerValue rdf:type rdf:Property ;
    rdfs:label 'Offer Value' ;
    rdfs:comment 'Monetary value or quantity of the offer (e.g., discount amount in currency, number of bonus miles, upgrade value).' ;
    rdfs:domain ind:AbTestVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:personalizationRules rdf:type rdf:Property ;
    rdfs:label 'Personalization Rules' ;
    rdfs:comment 'JSON or text description of dynamic personalization rules applied to this variant based on customer attributes or behavior.' ;
    rdfs:domain ind:AbTestVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statisticalSignificanceLevel rdf:type rdf:Property ;
    rdfs:label 'Statistical Significance Level' ;
    rdfs:comment 'P-value or confidence level achieved by this variant in the test results (e.g., 0.9500 for 95% confidence).' ;
    rdfs:domain ind:AbTestVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trafficAllocationPercentage rdf:type rdf:Property ;
    rdfs:label 'Traffic Allocation Percentage' ;
    rdfs:comment 'Percentage of total test traffic allocated to this variant (0.00 to 100.00). Sum across all variants in a test should equal 100.' ;
    rdfs:domain ind:AbTestVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:variantCode rdf:type rdf:Property ;
    rdfs:label 'Variant Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the variant within the test (e.g., CONTROL, VAR_A, VAR_B).' ;
    rdfs:domain ind:AbTestVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variantName rdf:type rdf:Property ;
    rdfs:label 'Variant Name' ;
    rdfs:comment 'Human-readable name describing the variant (e.g., Control Group, Discount Offer 20%, Premium Messaging).' ;
    rdfs:domain ind:AbTestVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:variantType rdf:type rdf:Property ;
    rdfs:label 'Variant Type' ;
    rdfs:comment 'Classification of the variant role in the experiment: control (baseline), treatment (experimental), or holdout (excluded from test).' ;
    rdfs:domain ind:AbTestVariant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acceptanceCriteria rdf:type rdf:Property ;
    rdfs:label 'Acceptance Criteria' ;
    rdfs:comment 'Defined criteria or conditions that must be met for this deliverable to be considered complete and accepted.' ;
    rdfs:domain ind:ContractDeliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acceptedBy rdf:type rdf:Property ;
    rdfs:label 'Accepted By' ;
    rdfs:comment 'Name or identifier of the individual who formally accepted the deliverable.' ;
    rdfs:domain ind:ContractDeliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualMetricValue rdf:type rdf:Property ;
    rdfs:label 'Actual Metric Value' ;
    rdfs:comment 'Actual achieved value for the performance metric after deliverable execution.' ;
    rdfs:domain ind:ContractDeliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:completionPercentage rdf:type rdf:Property ;
    rdfs:label 'Completion Percentage' ;
    rdfs:comment 'Percentage of work completed for this deliverable, ranging from 0.00 to 100.00.' ;
    rdfs:domain ind:ContractDeliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliverableCategory rdf:type rdf:Property ;
    rdfs:label 'Deliverable Category' ;
    rdfs:comment 'Broader classification or grouping of the deliverable for organizational and reporting purposes.' ;
    rdfs:domain ind:ContractDeliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverableCode rdf:type rdf:Property ;
    rdfs:label 'Deliverable Code' ;
    rdfs:comment 'Unique business identifier or code assigned to this contract deliverable for external reference and tracking.' ;
    rdfs:domain ind:ContractDeliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverableName rdf:type rdf:Property ;
    rdfs:label 'Deliverable Name' ;
    rdfs:comment 'Human-readable name or title of the contract deliverable.' ;
    rdfs:domain ind:ContractDeliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverableStatus rdf:type rdf:Property ;
    rdfs:label 'Deliverable Status' ;
    rdfs:comment 'Current lifecycle status of the contract deliverable indicating its progress and state.' ;
    rdfs:domain ind:ContractDeliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverableType rdf:type rdf:Property ;
    rdfs:label 'Deliverable Type' ;
    rdfs:comment 'Classification of the deliverable by its nature or category within the marketing contract.' ;
    rdfs:domain ind:ContractDeliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliverableValueAmount rdf:type rdf:Property ;
    rdfs:label 'Deliverable Value Amount' ;
    rdfs:comment 'Monetary value or contract price allocated to this specific deliverable.' ;
    rdfs:domain ind:ContractDeliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dependencies rdf:type rdf:Property ;
    rdfs:label 'Dependencies' ;
    rdfs:comment 'Description of other deliverables or tasks that this deliverable depends on or is blocked by.' ;
    rdfs:domain ind:ContractDeliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isMilestone rdf:type rdf:Property ;
    rdfs:label 'Is Milestone' ;
    rdfs:comment 'Flag indicating whether this deliverable represents a major milestone within the contract.' ;
    rdfs:domain ind:ContractDeliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduledEndDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Date' ;
    rdfs:comment 'Planned date by which this deliverable is scheduled to be completed.' ;
    rdfs:domain ind:ContractDeliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetMetricValue rdf:type rdf:Property ;
    rdfs:label 'Target Metric Value' ;
    rdfs:comment 'Target or goal value for the performance metric associated with this deliverable.' ;
    rdfs:domain ind:ContractDeliverable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:appealFiled rdf:type rdf:Property ;
    rdfs:label 'Appeal Filed' ;
    rdfs:comment 'Indicates whether the data subject filed an appeal or complaint with a supervisory authority regarding the handling of their request.' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:appealReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Appeal Reference Number' ;
    rdfs:comment 'Reference number assigned by the supervisory authority or internal appeals process for tracking the appeal.' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assigned Timestamp' ;
    rdfs:comment 'Date and time when the request was assigned to a data protection officer or staff member for processing.' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dataSystemsSearched rdf:type rdf:Property ;
    rdfs:label 'Data Systems Searched' ;
    rdfs:comment 'Comma-separated list of internal systems and databases searched to fulfill the data subject request (e.g., Amadeus Altéa PSS, loyalty system, CRM, ancillary booking system).' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:extendedDueDate rdf:type rdf:Property ;
    rdfs:label 'Extended Due Date' ;
    rdfs:comment 'New deadline if an extension was granted. GDPR allows up to 2 additional months; CCPA allows up to 45 additional days.' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:extensionGranted rdf:type rdf:Property ;
    rdfs:label 'Extension Granted' ;
    rdfs:comment 'Indicates whether an extension to the response deadline was granted due to complexity or volume of the request.' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:identityVerificationMethod rdf:type rdf:Property ;
    rdfs:label 'Identity Verification Method' ;
    rdfs:comment 'Method used to verify the identity of the requestor: document_upload (ID document scan), knowledge_based (security questions), biometric (fingerprint/facial recognition), email_confirmation, phone_verification, or in_person verification.' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identityVerificationStatus rdf:type rdf:Property ;
    rdfs:label 'Identity Verification Status' ;
    rdfs:comment 'Status of identity verification process for the requestor: pending (awaiting verification), verified (identity confirmed), failed (verification unsuccessful), not_required (verification waived).' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identityVerifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Identity Verified Timestamp' ;
    rdfs:comment 'Date and time when the requestor\'s identity was successfully verified.' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:internalNotes rdf:type rdf:Property ;
    rdfs:label 'Internal Notes' ;
    rdfs:comment 'Internal working notes and comments recorded by data protection officers during the processing of the request. Not shared with the data subject.' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAuthorizedRepresentative rdf:type rdf:Property ;
    rdfs:label 'Is Authorized Representative' ;
    rdfs:comment 'Indicates whether the request was submitted by an authorized representative on behalf of the data subject (true) or by the data subject themselves (false).' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recordsFoundCount rdf:type rdf:Property ;
    rdfs:label 'Records Found Count' ;
    rdfs:comment 'Total number of records or data items identified across all systems that pertain to the data subject.' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rejectionLegalBasis rdf:type rdf:Property ;
    rdfs:label 'Rejection Legal Basis' ;
    rdfs:comment 'Specific legal provision or regulation cited as the basis for rejecting the data subject request (e.g., GDPR Article 17(3) exception).' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:representativeAuthorizationDocument rdf:type rdf:Property ;
    rdfs:label 'Representative Authorization Document' ;
    rdfs:comment 'Reference to the document or proof of authorization provided by the representative to act on behalf of the data subject.' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestDescription rdf:type rdf:Property ;
    rdfs:label 'Request Description' ;
    rdfs:comment 'Detailed description or notes provided by the requestor explaining the nature and scope of their data subject request.' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Request Reference Number' ;
    rdfs:comment 'Externally-visible unique reference number assigned to the data subject request for tracking and communication purposes.' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestorEmail rdf:type rdf:Property ;
    rdfs:label 'Requestor Email' ;
    rdfs:comment 'Email address of the individual submitting the data subject request for correspondence and notification purposes.' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestorName rdf:type rdf:Property ;
    rdfs:label 'Requestor Name' ;
    rdfs:comment 'Full name of the individual submitting the data subject request. May differ from passenger name if submitted by authorized representative.' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestorPhone rdf:type rdf:Property ;
    rdfs:label 'Requestor Phone' ;
    rdfs:comment 'Contact phone number of the individual submitting the data subject request.' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseFormat rdf:type rdf:Property ;
    rdfs:label 'Response Format' ;
    rdfs:comment 'Format in which the data was provided to the data subject for access or portability requests: PDF, CSV, JSON, XML, or paper.' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseMethod rdf:type rdf:Property ;
    rdfs:label 'Response Method' ;
    rdfs:comment 'Method used to deliver the response to the data subject: email, postal_mail, secure_portal, in_person, or phone.' ;
    rdfs:domain ind:DataSubjectRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentAgencyId rdf:type rdf:Property ;
    rdfs:label 'Parent Agency Id' ;
    rdfs:comment 'Reference to the parent or host agency if this agency operates as a branch or sub-agency within a larger agency network. Null for independent agencies.' ;
    rdfs:domain ind:Agency ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agency .

ind:agencyStatus rdf:type rdf:Property ;
    rdfs:label 'Agency Status' ;
    rdfs:comment 'Current operational status of the agency in the airline\'s distribution network. Active agencies can issue tickets and receive commissions.' ;
    rdfs:domain ind:Agency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agencyType rdf:type rdf:Property ;
    rdfs:label 'Agency Type' ;
    rdfs:comment 'Classification of the agency based on its primary business model and customer segment served.' ;
    rdfs:domain ind:Agency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualSalesVolume rdf:type rdf:Property ;
    rdfs:label 'Annual Sales Volume' ;
    rdfs:comment 'Total ticket sales revenue generated by the agency in the most recent fiscal year, used for performance segmentation and commission tier determination.' ;
    rdfs:domain ind:Agency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:arcNumber rdf:type rdf:Property ;
    rdfs:label 'Arc Number' ;
    rdfs:comment 'Seven-digit numeric identifier assigned by ARC to agencies operating in the United States for ticket settlement and reporting purposes.' ;
    rdfs:domain ind:Agency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bspCountryCode rdf:type rdf:Property ;
    rdfs:label 'Bsp Country Code' ;
    rdfs:comment 'Three-letter ISO country code identifying the BSP jurisdiction under which the agency operates and settles transactions.' ;
    rdfs:domain ind:Agency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Contract Effective Date' ;
    rdfs:comment 'The date when the agency\'s distribution agreement with the airline became effective, establishing the commercial relationship.' ;
    rdfs:domain ind:Agency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Contract Expiration Date' ;
    rdfs:comment 'The date when the current agency distribution agreement expires. Null for evergreen or indefinite agreements.' ;
    rdfs:domain ind:Agency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:iataNumber rdf:type rdf:Property ;
    rdfs:label 'Iata Number' ;
    rdfs:comment 'Eight-digit numeric code assigned by IATA to identify accredited travel agencies globally. This is the primary business identifier used in BSP settlements and ARC reporting.' ;
    rdfs:domain ind:Agency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideCommissionRate rdf:type rdf:Property ;
    rdfs:label 'Override Commission Rate' ;
    rdfs:comment 'Additional commission percentage awarded to high-performing agencies based on volume or strategic partnership agreements. Null if no override applies.' ;
    rdfs:domain ind:Agency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preferredAgencyFlag rdf:type rdf:Property ;
    rdfs:label 'Preferred Agency Flag' ;
    rdfs:comment 'Indicates whether this agency has been designated as a preferred or strategic partner receiving enhanced support, priority service, or special incentives.' ;
    rdfs:domain ind:Agency ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:corporateAccountId rdf:type rdf:Property ;
    rdfs:label 'Corporate Account Id' ;
    rdfs:comment 'Primary key for corporate_account' ;
    rdfs:domain ind:CorporateAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountName rdf:type rdf:Property ;
    rdfs:label 'Account Name' ;
    rdfs:comment 'Legal or trading name of the corporate entity holding this account.' ;
    rdfs:domain ind:CorporateAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountNumber rdf:type rdf:Property ;
    rdfs:label 'Account Number' ;
    rdfs:comment 'Externally-visible unique account number assigned to the corporate customer for billing and reference purposes.' ;
    rdfs:domain ind:CorporateAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualRevenueCommitmentAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Revenue Commitment Amount' ;
    rdfs:comment 'Minimum annual revenue the corporate customer has committed to generate under the agreement.' ;
    rdfs:domain ind:CorporateAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annualRevenueCommitmentCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Annual Revenue Commitment Currency Code' ;
    rdfs:comment 'Three-letter ISO currency code for the annual revenue commitment amount.' ;
    rdfs:domain ind:CorporateAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoTicketingEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Ticketing Enabled' ;
    rdfs:comment 'Indicates whether automatic ticket issuance is enabled for bookings made under this corporate account.' ;
    rdfs:domain ind:CorporateAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:billingCycleDay rdf:type rdf:Property ;
    rdfs:label 'Billing Cycle Day' ;
    rdfs:comment 'Day of the month on which invoices are generated for this corporate account (1-31).' ;
    rdfs:domain ind:CorporateAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:industrySector rdf:type rdf:Property ;
    rdfs:label 'Industry Sector' ;
    rdfs:comment 'Primary industry sector of the corporate customer for segmentation and analytics purposes.' ;
    rdfs:domain ind:CorporateAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loyaltyProgramIntegrationEnabled rdf:type rdf:Property ;
    rdfs:label 'Loyalty Program Integration Enabled' ;
    rdfs:comment 'Indicates whether travelers under this corporate account can earn and redeem loyalty points.' ;
    rdfs:domain ind:CorporateAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revenueTier rdf:type rdf:Property ;
    rdfs:label 'Revenue Tier' ;
    rdfs:comment 'Tier classification based on annual revenue contribution used for prioritization and service levels.' ;
    rdfs:domain ind:CorporateAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxIdentifier rdf:type rdf:Property ;
    rdfs:label 'Tax Identifier' ;
    rdfs:comment 'Tax identification number or VAT registration number of the corporate entity for invoicing and compliance.' ;
    rdfs:domain ind:CorporateAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:travelPolicyUrl rdf:type rdf:Property ;
    rdfs:label 'Travel Policy Url' ;
    rdfs:comment 'Web address linking to the corporate customers internal travel policy document for reference.' ;
    rdfs:domain ind:CorporateAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flightId rdf:type rdf:Property ;
    rdfs:label 'Flight Id' ;
    rdfs:comment 'Reference to the specific flight this bid price curve applies to.' ;
    rdfs:domain ind:BidPriceCurve ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ScheduledFlight .

ind:baseBidPriceAmount rdf:type rdf:Property ;
    rdfs:label 'Base Bid Price Amount' ;
    rdfs:comment 'The baseline bid price value representing the minimum acceptable revenue per seat for this curve segment.' ;
    rdfs:domain ind:BidPriceCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityAvailableUnits rdf:type rdf:Property ;
    rdfs:label 'Capacity Available Units' ;
    rdfs:comment 'The total number of seats available for sale in the booking class this bid price curve applies to.' ;
    rdfs:domain ind:BidPriceCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:curveCode rdf:type rdf:Property ;
    rdfs:label 'Curve Code' ;
    rdfs:comment 'Externally-known unique business identifier for the bid price curve, used in revenue management systems and operational references.' ;
    rdfs:domain ind:BidPriceCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:curveGenerationMethod rdf:type rdf:Property ;
    rdfs:label 'Curve Generation Method' ;
    rdfs:comment 'The method used to generate this bid price curve: automated (system-generated), manual (analyst-created), hybrid (combination), or machine learning based.' ;
    rdfs:domain ind:BidPriceCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:curveName rdf:type rdf:Property ;
    rdfs:label 'Curve Name' ;
    rdfs:comment 'Human-readable descriptive name for the bid price curve, typically indicating the route, season, or market segment it applies to.' ;
    rdfs:domain ind:BidPriceCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:curveType rdf:type rdf:Property ;
    rdfs:label 'Curve Type' ;
    rdfs:comment 'Classification of the bid price curve methodology: static (fixed), dynamic (real-time adjusted), hybrid (combination), forecast-based (demand forecast driven), or historical (based on past performance).' ;
    rdfs:domain ind:BidPriceCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daysBeforeDepartureEnd rdf:type rdf:Property ;
    rdfs:label 'Days Before Departure End' ;
    rdfs:comment 'The ending point in the booking window (days before departure) for which this bid price curve is applicable.' ;
    rdfs:domain ind:BidPriceCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:daysBeforeDepartureStart rdf:type rdf:Property ;
    rdfs:label 'Days Before Departure Start' ;
    rdfs:comment 'The starting point in the booking window (days before departure) for which this bid price curve is applicable.' ;
    rdfs:domain ind:BidPriceCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:demandForecastUnits rdf:type rdf:Property ;
    rdfs:label 'Demand Forecast Units' ;
    rdfs:comment 'The forecasted demand in number of seats or passengers for the flight leg and booking class this curve applies to.' ;
    rdfs:domain ind:BidPriceCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:displacementCostAmount rdf:type rdf:Property ;
    rdfs:label 'Displacement Cost Amount' ;
    rdfs:comment 'The estimated revenue loss from displacing a higher-value passenger by accepting a lower-value booking.' ;
    rdfs:domain ind:BidPriceCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastOptimizationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Optimization Timestamp' ;
    rdfs:comment 'The date and time when this bid price curve was last recalculated or optimized by the revenue management system.' ;
    rdfs:domain ind:BidPriceCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:optimizationModel rdf:type rdf:Property ;
    rdfs:label 'Optimization Model' ;
    rdfs:comment 'The revenue optimization model used to generate this bid price curve. EMSR (Expected Marginal Seat Revenue) variants, network optimization, leg-based, or Origin and Destination (O&D) based models.' ;
    rdfs:domain ind:BidPriceCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spillCostAmount rdf:type rdf:Property ;
    rdfs:label 'Spill Cost Amount' ;
    rdfs:comment 'The estimated revenue loss from turning away demand due to inventory restrictions or overbooking limits.' ;
    rdfs:domain ind:BidPriceCurve ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:codeshareAgreementId rdf:type rdf:Property ;
    rdfs:label 'Codeshare Agreement Id' ;
    rdfs:comment 'Primary key for codeshare_agreement' ;
    rdfs:domain ind:CodeshareAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:agreementCode rdf:type rdf:Property ;
    rdfs:label 'Agreement Code' ;
    rdfs:comment 'Externally-known unique business identifier for the codeshare agreement, used in operational systems and partner communications.' ;
    rdfs:domain ind:CodeshareAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baggageAllowanceHarmonization rdf:type rdf:Property ;
    rdfs:label 'Baggage Allowance Harmonization' ;
    rdfs:comment 'Indicates whether baggage policies are harmonized between operating and marketing carriers for codeshare flights.' ;
    rdfs:domain ind:CodeshareAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:blockSpaceSeats rdf:type rdf:Property ;
    rdfs:label 'Block Space Seats' ;
    rdfs:comment 'Number of seats allocated to the marketing carrier under block space codeshare arrangements.' ;
    rdfs:domain ind:CodeshareAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fareBasisCodeSharingAllowed rdf:type rdf:Property ;
    rdfs:label 'Fare Basis Code Sharing Allowed' ;
    rdfs:comment 'Indicates whether fare basis codes can be shared between operating and marketing carriers under this agreement.' ;
    rdfs:domain ind:CodeshareAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:frequentFlyerAccrualAllowed rdf:type rdf:Property ;
    rdfs:label 'Frequent Flyer Accrual Allowed' ;
    rdfs:comment 'Indicates whether passengers can earn frequent flyer miles on the marketing carriers program for codeshare flights.' ;
    rdfs:domain ind:CodeshareAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interlineTicketingAllowed rdf:type rdf:Property ;
    rdfs:label 'Interline Ticketing Allowed' ;
    rdfs:comment 'Indicates whether interline ticketing is permitted under this codeshare agreement for multi-carrier itineraries.' ;
    rdfs:domain ind:CodeshareAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inventoryControlParty rdf:type rdf:Property ;
    rdfs:label 'Inventory Control Party' ;
    rdfs:comment 'Designates which carrier has authority over seat inventory management and availability control.' ;
    rdfs:domain ind:CodeshareAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liabilityAllocationModel rdf:type rdf:Property ;
    rdfs:label 'Liability Allocation Model' ;
    rdfs:comment 'Defines which carrier bears primary liability for passenger claims and operational issues under this codeshare.' ;
    rdfs:domain ind:CodeshareAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loungeAccessReciprocity rdf:type rdf:Property ;
    rdfs:label 'Lounge Access Reciprocity' ;
    rdfs:comment 'Indicates whether marketing carrier passengers have access to operating carrier lounges under this agreement.' ;
    rdfs:domain ind:CodeshareAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketingCarrierSharePercentage rdf:type rdf:Property ;
    rdfs:label 'Marketing Carrier Share Percentage' ;
    rdfs:comment 'Percentage of revenue allocated to the marketing carrier when percentage-split revenue model is used.' ;
    rdfs:domain ind:CodeshareAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatingCarrierSharePercentage rdf:type rdf:Property ;
    rdfs:label 'Operating Carrier Share Percentage' ;
    rdfs:comment 'Percentage of revenue allocated to the operating carrier when percentage-split revenue model is used.' ;
    rdfs:domain ind:CodeshareAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prorateMethod rdf:type rdf:Property ;
    rdfs:label 'Prorate Method' ;
    rdfs:comment 'Calculation methodology for revenue proration when prorate revenue share model is applied.' ;
    rdfs:domain ind:CodeshareAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Date' ;
    rdfs:comment 'Date when regulatory authorities approved this codeshare agreement for commercial operation.' ;
    rdfs:domain ind:CodeshareAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Notice Days' ;
    rdfs:comment 'Number of days advance notice required before expiration to trigger renewal or termination of the agreement.' ;
    rdfs:domain ind:CodeshareAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revenueShareModel rdf:type rdf:Property ;
    rdfs:label 'Revenue Share Model' ;
    rdfs:comment 'Method used to allocate revenue between operating and marketing carriers under this codeshare agreement.' ;
    rdfs:domain ind:CodeshareAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleCoordinationRequired rdf:type rdf:Property ;
    rdfs:label 'Schedule Coordination Required' ;
    rdfs:comment 'Indicates whether flight schedules must be coordinated between operating and marketing carriers under this agreement.' ;
    rdfs:domain ind:CodeshareAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:accountOpeningDate rdf:type rdf:Property ;
    rdfs:label 'Account Opening Date' ;
    rdfs:comment 'Date when the airline first established a banking relationship with this bank.' ;
    rdfs:domain ind:Bank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bankCode rdf:type rdf:Property ;
    rdfs:label 'Bank Code' ;
    rdfs:comment 'Unique bank identification code assigned by the national banking authority or central bank. Used for domestic payment routing and interbank settlements.' ;
    rdfs:domain ind:Bank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankStatus rdf:type rdf:Property ;
    rdfs:label 'Bank Status' ;
    rdfs:comment 'Current operational status of the bank in the airline\'s treasury and payment systems.' ;
    rdfs:domain ind:Bank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankType rdf:type rdf:Property ;
    rdfs:label 'Bank Type' ;
    rdfs:comment 'Classification of the bank based on its primary business function and regulatory category.' ;
    rdfs:domain ind:Bank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ibanPrefix rdf:type rdf:Property ;
    rdfs:label 'Iban Prefix' ;
    rdfs:comment 'Country-specific IBAN prefix used for international account number validation. Consists of 2-letter country code and 2-digit check digits.' ;
    rdfs:domain ind:Bank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPreferredVendor rdf:type rdf:Property ;
    rdfs:label 'Is Preferred Vendor' ;
    rdfs:comment 'Indicates whether this bank is designated as a preferred banking partner for the airline\'s treasury operations, offering negotiated rates and priority service.' ;
    rdfs:domain ind:Bank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSanctionsCompliant rdf:type rdf:Property ;
    rdfs:label 'Is Sanctions Compliant' ;
    rdfs:comment 'Indicates whether the bank has been verified as compliant with international sanctions regulations (OFAC, UN, EU) and is approved for airline treasury operations.' ;
    rdfs:domain ind:Bank ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:relationshipManagerEmail rdf:type rdf:Property ;
    rdfs:label 'Relationship Manager Email' ;
    rdfs:comment 'Email address of the bank\'s relationship manager for treasury correspondence and payment instructions.' ;
