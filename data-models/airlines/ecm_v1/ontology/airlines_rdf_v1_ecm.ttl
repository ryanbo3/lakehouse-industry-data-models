ind:Agency rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Revenue ;
    rdfs:label 'Agency' ;
    rdfs:comment 'Master reference table for agency. Referenced by agency_id.' .

ind:CorporateAccount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Revenue ;
    rdfs:label 'Corporate Account' ;
    rdfs:comment 'Master reference table for corporate_account. Referenced by account_id.' .

ind:BidPriceCurve rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Revenue ;
    rdfs:label 'Bid Price Curve' ;
    rdfs:comment 'Master reference table for bid_price_curve. Referenced by bid_price_curve_id.' .

ind:CodeshareAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Route ;
    rdfs:label 'Codeshare Agreement' ;
    rdfs:comment 'Master reference table for codeshare_agreement. Referenced by route_codeshare_agreement_id.' .

ind:Bank rdf:type rdfs:Class ;
