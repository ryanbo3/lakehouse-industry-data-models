    rdfs:comment 'Master reference table for qualification_cycle. Referenced by qualification_cycle_id.' .

ind:PartnerOrganization rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Marketing ;
    rdfs:label 'Partner Organization' ;
    rdfs:comment 'Master reference table for partner_organization. Referenced by partner_organization_id.' .

ind:AbTestVariant rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Marketing ;
    rdfs:label 'Ab Test Variant' ;
    rdfs:comment 'Master reference table for ab_test_variant. Referenced by ab_test_variant_id.' .

ind:ContractDeliverable rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Marketing ;
    rdfs:label 'Contract Deliverable' ;
    rdfs:comment 'Master reference table for contract_deliverable. Referenced by contract_deliverable_id.' .

ind:DataSubjectRequest rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Passenger ;
    rdfs:label 'Data Subject Request' ;
