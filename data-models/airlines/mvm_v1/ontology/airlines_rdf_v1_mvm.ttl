# RDFS Schema for Business: Airlines

@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix ind: <http://datamodel.lakehouse.org/business/airlines#> .

# --- Root Business Class ---
ind:Business rdf:type rdfs:Class ;
    rdfs:label 'Business' ;
    rdfs:comment 'Root class for all business entities' .

# --- Specific Business: Airlines ---
ind:Airlines rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Business ;
    rdfs:label 'Airlines' ;
    rdfs:comment 'Airlines is a global industry operating passenger and cargo flights across extensive route networks, offering premium travel experiences, loyalty programs, and hub-and-spoke connectivity linking cities worldwide.' .

# --- Domain Classes ---
ind:Flight rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Airlines ;
    rdfs:label 'Flight' ;
    rdfs:comment 'Core flight operations data covering flight planning, dispatch releases, OOOI events (Out-Off-On-In gate times), block hours, fuel uplift, ACARS messaging, FMS data, operational control, flight schedules, actual departures and arrivals, delays, diversions, IROP handling, and real-time flight status. SSOT for all flight execution data. Aligns with Lufthansa Systems NetLine/Ops and Jeppesen Flight Planning System.' .

ind:Passenger rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Airlines ;
    rdfs:label 'Passenger' ;
    rdfs:comment 'Single source of truth for all passenger identity and profile data — the WHO the airline serves. Owns PNR-linked passenger profiles, identity documents, contact details, travel preferences, accessibility and SSR (Special Service Request) preferences, loyalty tier linkage, and segmentation attributes. Serves as the authoritative customer identity hub referenced by reservation, loyalty, and ancillary domains. Aligns with Amadeus Altéa PSS.' .

ind:Reservation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Airlines ;
    rdfs:label 'Reservation' ;
    rdfs:comment 'Manages PNR (Passenger Name Record) creation, booking records, itineraries, seat assignments, check-in, boarding passes, e-ticket issuance, EMD (Electronic Miscellaneous Document), reservation modifications, GDS distribution, interline agreements, codeshare bookings, and MCT (Minimum Connecting Time) validation. SSOT for all booking and ticketing transaction lifecycle data. Aligns with Amadeus Altéa Reservation and Inventory.' .

ind:Revenue rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Airlines ;
    rdfs:label 'Revenue' ;
    rdfs:comment 'Revenue management and pricing SSOT — HOW the airline prices and captures revenue. Owns fare structures, pricing rules, yield management parameters, fare classes, dynamic pricing, RASK/CASK/RPK/ASK performance metrics, revenue accounting records, BSP (Billing and Settlement Plan) settlements, ARC reporting, and ancillary revenue aggregation. Aligns with Sabre AirVision Revenue Management.' .

ind:Crew rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Airlines ;
    rdfs:label 'Crew' ;
    rdfs:comment 'Crew scheduling, rostering, pairings, duty periods, rest requirements, crew qualifications, type ratings, recency, crew bases, deadhead positioning, crew legality checks, fatigue risk management, and crew-to-flight leg assignments. Manages flight crew, cabin crew, and crew resource allocation per FAR Part 117 and EASA FTL. Aligns with AIMS Crew Management System.' .

ind:Fleet rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Airlines ;
    rdfs:label 'Fleet' ;
    rdfs:comment 'Single source of truth for aircraft and fleet asset master data including aircraft registration, tail numbers, ICAO/IATA type designators, configuration (cabin layout, seat maps), seating capacity, ownership (owned, wet lease, dry lease, ACMI), APU details, ETOPS certification status, MEL applicability, utilization, block hours, cycles, and fleet planning. Owns the physical asset registry referenced by all other operational domains.' .

ind:Maintenance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Airlines ;
    rdfs:label 'Maintenance' ;
    rdfs:comment 'Aircraft MRO (Maintenance Repair and Overhaul) lifecycle management including scheduled and unscheduled maintenance, work orders, airworthiness directives (ADs), component life-limited parts tracking, MEL (Minimum Equipment List) deferrals, AOG (Aircraft on Ground) events, APU maintenance, Part-145 approved maintenance organisation records, and defect tracking. Aligns with AMOS Aircraft Maintenance and Engineering System.' .

ind:Cargo rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Airlines ;
    rdfs:label 'Cargo' ;
    rdfs:comment 'Air freight and cargo commercial and operational data including AWB (Air Waybill) lifecycle, ULD (Unit Load Device) management, cargo bookings, shipment tracking, cargo capacity allocation, weight and balance, dangerous goods (DG) declarations, freight rates, cargo revenue accounting, and shipper/consignee relationships. Manages both belly cargo and dedicated freighter operations. Aligns with Mercator Cargo Management System.' .

ind:Loyalty rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Airlines ;
    rdfs:label 'Loyalty' ;
    rdfs:comment 'FFP (Frequent Flyer Program) management including member enrollment, tier status (elite levels), mileage accrual and redemption transactions, award bookings, partner airline earn/burn agreements, coalition programs, loyalty promotions, member benefits, upgrades, and lifetime status tracking. Aligns with Oracle Loyalty Cloud FFP Management.' .

ind:Airport rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Airlines ;
    rdfs:label 'Airport' ;
    rdfs:comment 'Ground handling and airport operations data including gate assignments, turnaround operations, baggage handling and tracing, ramp services, aircraft servicing, ground support equipment (GSE) scheduling, slot management, CDM (Collaborative Decision Making) messages, PFC (Passenger Facility Charge) records, check-in and boarding process events, and airport facility coordination. Manages hub operations and spoke station activities. Aligns with SITA Airport Management Platform.' .

ind:Route rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Airlines ;
    rdfs:label 'Route' ;
    rdfs:comment 'Route network planning and schedule design data including origin-destination (O&D) route definitions, hub-and-spoke network topology, city pairs, frequencies, flight numbers, seasonal schedules, slot allocations at constrained airports, bilateral agreements, codeshare route agreements, ASK (Available Seat Kilometer) capacity planning, and network performance KPIs (OTP, load factor by route). Aligns with Jeppesen scheduling.' .

ind:Safety rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Airlines ;
    rdfs:label 'Safety' ;
    rdfs:comment 'Aviation safety management including SMS (Safety Management System), incident and occurrence reporting, accident investigation, CVR (Cockpit Voice Recorder) and FDR (Flight Data Recorder) event analysis, NOTAM (Notice to Air Missions) tracking, hazard identification, risk assessment, safety audits, corrective action plans, SOP version control, and fatigue risk management. SSOT for all safety occurrence and risk data. Aligns with ICAO Annex 19 SMS framework.' .

ind:Ancillary rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Airlines ;
    rdfs:label 'Ancillary' ;
    rdfs:comment 'Ancillary services and revenue products sold beyond the base fare including baggage fees, seat selection and upgrades, priority boarding, lounge access, in-flight meals and retail, Wi-Fi, travel insurance, car rentals, hotel bookings, bundled fare products, and EMD-linked ancillary charge records. Manages ancillary product catalog, pricing, and unbundled fare strategy.' .

ind:Inventory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Airlines ;
    rdfs:label 'Inventory' ;
    rdfs:comment 'Flight inventory and seat capacity availability management — the airline\'s sellable stock. Owns fare class buckets, seat availability by cabin, overbooking controls, codeshare inventory allocations, and real-time availability snapshots consumed by GDS and direct channels. Directly feeds revenue management yield optimization. Aligns with Amadeus Altéa Inventory.' .

ind:Finance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Airlines ;
    rdfs:label 'Finance' ;
    rdfs:comment 'Corporate financial management SSOT covering general ledger, accounts payable/receivable, cost centre accounting, budget planning, financial consolidation, CASK (Cost per Available Seat Kilometer) reporting, fuel cost accounting, lease liability (IFRS 16), interline billing settlements, treasury operations, and regulatory financial reporting. Aligns with SAP S/4HANA FI/CO modules.' .

# --- Data Product Classes (Tables) ---
ind:FlightInventory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Flight Inventory' ;
    rdfs:comment 'Core master entity representing the sellable seat inventory for a specific flight-date combination. Owns the authoritative record of total capacity, cabin breakdown, fare class bucket configuration, and overall availability status for each flight leg in the Amadeus Altéa Inventory system. This is the primary inventory control record consumed by GDS, direct channels, and revenue management yield optimization.' .

ind:CabinClass rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Cabin Class' ;
    rdfs:comment 'Reference master defining the physical and commercial cabin classes operated by the airline (e.g., First, Business, Premium Economy, Economy). Captures IATA cabin designator codes, seat configuration standards, service level definitions, and applicable aircraft type associations. Used as the classification backbone for inventory segmentation and revenue management.' .

ind:FareClassBucket rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Fare Class Bucket' ;
    rdfs:comment 'Master entity defining individual booking class (RBD — Reservation Booking Designator) buckets within a cabin for a flight inventory record. Captures the single-letter IATA booking class code (e.g., Y, B, M, Q, V), the hierarchical nesting within the cabin, authorized capacity (AU), booking limit (BL), overbooking factor, and current availability status. The atomic unit of inventory control in Altéa Inventory and the direct input to Sabre AirVision yield optimization.' .

ind:SeatAvailability rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Seat Availability' ;
    rdfs:comment 'Real-time and historical transactional record of seat availability by fare class bucket for a flight-date, as broadcast to distribution channels and captured at scheduled intervals for audit and analytics. Captures available seat count, status code (Open/Closed/Waitlist), last update timestamp, channel context (GDS, NDC, direct), snapshot trigger reason, and load factor at capture time. Serves as both the live availability signal consumed by Amadeus, Sabre, and Travelport systems and the historical availability audit trail for revenue management model training and GDS broadcast verification.' .

ind:OverbookingControl rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Overbooking Control' ;
    rdfs:comment 'Master entity storing the overbooking authorization parameters for a flight inventory record by cabin class. Captures the authorized overbooking percentage, maximum oversale seats, historical no-show rate inputs, spoilage risk threshold, and the revenue management system override flag. Directly managed by revenue management analysts and consumed by Altéa Inventory to set booking limits above physical capacity.' .

ind:CodeshareAllocation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Codeshare Allocation' ;
    rdfs:comment 'Master entity governing the seat block or free-flow inventory allocation granted to a codeshare or interline partner airline on a specific flight-date and cabin. Captures the operating carrier flight, the marketing carrier code, allocation type (block space vs. free-flow), authorized seat count, minimum/maximum thresholds, and the bilateral agreement reference. Ensures partner inventory is correctly ring-fenced within the host carrier\'s Altéa Inventory.' .

ind:InventoryLeg rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Inventory Leg' ;
    rdfs:comment 'Master entity representing a single physical flight leg as the unit of inventory management, distinct from the commercial flight segment. Captures origin and destination airport IATA codes, scheduled departure and arrival datetimes, operating carrier, flight number, service type, and the link to the parent flight inventory record. Supports multi-leg itinerary inventory nesting and through-availability calculations.' .

ind:Segment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Segment' ;
    rdfs:comment 'Master entity representing a commercial O&D (origin-destination) segment as sold to passengers, which may span one or more physical inventory legs. Captures the marketed flight number, O&D city pair, cabin, fare basis, and the through-availability nesting rules that govern how segment availability is derived from underlying leg buckets. Critical for connecting-itinerary inventory control and MCT (Minimum Connecting Time) enforcement.' .

ind:GroupBlock rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Group Block' ;
    rdfs:comment 'Master entity representing a reserved seat block allocated to a group booking request on a specific flight-date and cabin. Captures the group name, number of seats blocked, option date (deadline for confirmation), ticketing deadline, applicable fare class, deposit status, and the linked PNR reference. Group blocks reduce available inventory for individual sale and must be tracked separately from regular fare class bucket availability.' .

ind:WaitlistEntry rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Inventory ;
    rdfs:label 'Waitlist Entry' ;
    rdfs:comment 'Transactional record of a passenger or booking placed on the waitlist for a specific fare class bucket when availability is closed. Captures the PNR reference, requested cabin and fare class, waitlist priority rank, waitlist reason (sold-out, upgrade request, group overflow), creation timestamp, and clearance status. Managed by Altéa Inventory\'s waitlist processing engine and cleared automatically when bucket availability opens.' .

ind:Fare rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Revenue ;
    rdfs:label 'Fare' ;
    rdfs:comment 'Master fare definition record representing a published or private fare basis — the atomic pricing unit in the airline revenue management system. Owns fare basis code, fare amount, currency, cabin class, booking class (RBD), fare type (published/negotiated/private/web), one-way or round-trip indicator, directionality, origin-destination city pair, carrier designator, ticketing carrier, global indicator, routing number, fare tariff number, IATA fare filing reference, effective date, discontinue date, and fare ownership (ATPCO/SITA/carrier-filed). Aligns with Sabre AirVision fare filing and ATPCO Fare Filing standards.' .

ind:FareRule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Revenue ;
    rdfs:label 'Fare Rule' ;
    rdfs:comment 'Business rules governing the conditions of use for a fare basis — the regulatory and commercial constraints attached to a fare. Captures rule category (advance purchase, minimum/maximum stay, stopovers, transfers, combinability, blackout dates, seasonality, day-of-week restrictions, tour code requirements, penalties, refundability, endorsement/restriction text). References the parent fare and ATPCO rule category numbers (Cat 1–35). Owns the full rule text and structured rule parameters used by pricing engines and ticketing systems.' .

ind:FareClass rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Revenue ;
    rdfs:label 'Fare Class' ;
    rdfs:comment 'Reference master for Reservation Booking Designators (RBDs) defining the booking class hierarchy — the inventory bucket alphabet that maps sellable seats to fare products. Each record defines a single RBD: cabin assignment (First/Business/Premium Economy/Economy), booking class letter code (Y, B, M, Q, etc.), fare class family grouping, yield class ranking within cabin, upgrade eligibility flag, mileage accrual multiplier, and revenue management bucket assignment. Serves as the bridge between inventory availability (how many seats to sell at each price point) and revenue accounting (what was actually sold and at what yield).' .

ind:PricingRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Revenue ;
    rdfs:label 'Pricing Record' ;
    rdfs:comment 'Transactional record of a fare quote or pricing calculation event generated by the pricing engine for a specific itinerary and passenger type combination. Captures the priced itinerary (origin, destination, routing, flight segments), total fare amount, tax breakdown, surcharges (YQ/YR fuel surcharge, carrier-imposed fees), passenger type code (ADT/CHD/INF), fare basis codes applied per segment, pricing date, ticketing time limit, form of payment restrictions, and pricing source (GDS, direct, NDC). Represents the SSOT for how a specific booking was priced before ticketing.' .

ind:TaxFee rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Revenue ;
    rdfs:label 'Tax Fee' ;
    rdfs:comment 'Reference master for all government-mandated taxes, carrier-imposed fees, and airport charges applicable to air tickets. Defines tax/fee code (IATA standard tax codes), tax name, collecting authority (government, airport, carrier), tax type (ad valorem percentage, flat amount, per-segment), currency, applicability rules (domestic/international, route-specific, passenger type), effective and expiry dates, and remittance destination. Used by pricing engines to construct the full ticket price breakdown and by revenue accounting for tax remittance.' .

ind:YieldParameter rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Revenue ;
    rdfs:label 'Yield Parameter' ;
    rdfs:comment 'Revenue management configuration record defining yield management parameters and optimization settings for a specific market, route, or flight group. Stores bid price curves, booking class availability thresholds, load factor targets, revenue per available seat kilometer (RASK) targets, cost per available seat kilometer (CASK) benchmarks, minimum acceptable yield floors, overbooking authorization levels, spoilage and dilution tolerance settings, and forecast model weights. Owned by the Revenue Management team and aligned with Sabre AirVision RM optimization modules.' .

ind:Ticket rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Revenue ;
    rdfs:label 'Ticket' ;
    rdfs:comment 'Electronic ticket (e-ticket) master record representing the issued travel document for a passenger. Stores ticket number (13-digit IATA format), issuing carrier code, issuing office/IATA location identifier, ticket issue date and time, passenger name, passenger type code, form of payment, total fare amount, tax total, net remit amount, ticket status (open/used/refunded/voided/exchanged/lifted), conjunction ticket indicator, tour code, endorsement/restriction text, original ticket number (for exchanges), and BSP/ARC reporting indicator. SSOT for issued ticket lifecycle.' .

ind:TicketCoupon rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Revenue ;
    rdfs:label 'Ticket Coupon' ;
    rdfs:comment 'Individual flight coupon record within an e-ticket, representing one segment of travel. Each e-ticket may contain up to four flight coupons. Captures coupon number, flight number, origin and destination, departure date, cabin class, booking class (RBD), fare basis code, not-valid-before/after dates, baggage allowance, coupon status (open/used/lifted/flown/refunded/voided/suspended/exchanged), stopover indicator, and actual flight date used. SSOT for coupon-level revenue recognition and BSP/ARC coupon reporting.' .

ind:RevenueEmd rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Revenue ;
    rdfs:label 'Revenue Emd' ;
    rdfs:comment 'Electronic Miscellaneous Document (EMD) record for ancillary services sold in conjunction with or independently of an air ticket. Captures EMD number, EMD type (EMD-A associated / EMD-S standalone), service type code (IATA RFIC/RFISC), service description (excess baggage, seat upgrade, lounge access, priority boarding, etc.), associated ticket number, coupon reference, amount, currency, form of payment, issue date, issuing office, EMD status (open/used/refunded/voided), and BSP/ARC reporting flag. SSOT for ancillary revenue document lifecycle.' .

ind:BspSettlement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Revenue ;
    rdfs:label 'Bsp Settlement' ;
    rdfs:comment 'BSP (Billing and Settlement Plan) settlement transaction record representing the financial settlement between the airline and travel agents through the IATA BSP clearing mechanism. Captures BSP billing period, agent IATA code, agent name, country/BSP market, transaction type (sale/refund/ADM/ACM), ticket number range, gross sales amount, commission amount, net remittance amount, currency, settlement date, BSP file reference, and settlement status (pending/settled/disputed/adjusted). SSOT for BSP-channel revenue collection and agent settlement.' .

ind:Recognition rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Revenue ;
    rdfs:label 'Recognition' ;
    rdfs:comment 'Revenue accounting transaction record representing the recognized revenue entry for a flown or used ticket coupon or EMD. Captures the accounting period, ticket/coupon reference, flight date, origin-destination, cabin, booking class, fare amount recognized, prorate share (for interline), tax amounts, surcharges, form of payment, passenger type, revenue recognition method (flown/accrual), interline prorate agreement reference, and accounting status (pending/recognized/adjusted/reversed). SSOT for passenger revenue recognition aligned with IATA revenue accounting standards and airline financial reporting.' .

ind:InterlineProrate rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Revenue ;
    rdfs:label 'Interline Prorate' ;
    rdfs:comment 'Interline prorate agreement and proration record defining how revenue from a multi-carrier itinerary is split between participating airlines. Captures prorate agreement type (IATA pro-rate factor/mileage/specific prorate agreement), partner carrier code, applicable route/market, prorate factor or amount, currency, effective and expiry dates, agreement reference number, and proration calculation method. Also stores actual proration transaction records for settled interline billing. Aligns with IATA interline billing and settlement standards.' .

ind:FareFamily rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Revenue ;
    rdfs:label 'Fare Family' ;
    rdfs:comment 'Fare family (branded fare) master record defining a named bundle of fare conditions and ancillary inclusions marketed under a commercial brand name (e.g., Basic Economy, Standard, Flex, Business Lite, Business Plus). Captures fare family code, commercial brand name, cabin applicability, included services (carry-on baggage, checked baggage, seat selection, lounge access, miles accrual rate, change/refund conditions), fare class mapping, display priority, and marketing description. Enables branded fare merchandising across GDS, NDC, and direct channels.' .

ind:CorporateContract rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Revenue ;
    rdfs:label 'Corporate Contract' ;
    rdfs:comment 'Corporate travel contract record defining negotiated fare agreements between the airline and corporate accounts or travel management companies (TMCs). Captures contract reference number, corporate account name and ID, contract type (net fare/discount/commission override/soft dollar), applicable markets and routes, discount percentage or net fare amounts, minimum volume commitment (revenue or segment targets), contract period, blackout dates, reporting requirements, account manager, and contract status (draft/active/expired/suspended). SSOT for corporate pricing and B2B revenue agreements.' .

ind:Refund rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Revenue ;
    rdfs:label 'Refund' ;
    rdfs:comment 'Refund transaction record capturing the processing of a ticket or EMD refund to a passenger or agent. Stores refund reference number, original ticket/EMD number, refund type (voluntary/involuntary/IROP/schedule change), refund amount, penalty amount deducted, tax refund breakdown, refund method (original form of payment/voucher/miles), refund request date, processing date, refund status (requested/approved/processed/rejected/pending), approving agent or system, and BSP/ARC refund indicator. SSOT for refund liability management and revenue reversal accounting.' .

ind:TicketExchange rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Revenue ;
    rdfs:label 'Ticket Exchange' ;
    rdfs:comment 'Ticket exchange (reissue) transaction record capturing the voluntary or involuntary modification of an existing ticket to a new itinerary or fare. Stores exchange reference number, original ticket number, new ticket number, exchange type (voluntary/involuntary/upgrade/downgrade/IROP reprotection), fare difference amount (additional collection or residual value), penalty amount, exchange date, exchanging office, original fare basis, new fare basis, and exchange status. SSOT for ticket reissue lifecycle and associated revenue impact tracking.' .

ind:GeneralLedger rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'General Ledger' ;
    rdfs:comment 'SAP S/4HANA FI-GL SSOT for all accounting entries across the airlines chart of accounts. Each record represents a journal entry document (posting) with header attributes (document number, posting date, fiscal period, document type, company code, reference, reversal indicator, posting user) and line items (debit/credit amounts, GL account, cost centre, profit centre, functional area, cost element, currency, exchange rate). Supports IFRS and local GAAP dual reporting, period-end close, intercompany postings, accruals, provisions, and financial consolidation across all legal entities. Serves as the immutable audit trail for regulatory financial reporting and the single authoritative source for all financial postings.' .

ind:JournalEntry rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Journal Entry' ;
    rdfs:comment 'Individual accounting posting records in the general ledger representing debits and credits for every financial transaction across the airline. Captures document type, posting date, fiscal period, currency, exchange rate, reference document, reversal indicators, and posting user. Aligns with SAP FI document posting model and supports audit trail for regulatory financial reporting.' .

ind:CostCentre rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Cost Centre' ;
    rdfs:comment 'SAP CO organisational unit master representing cost-incurring and profit-bearing responsibility centres within the airline — e.g., flight operations, cabin crew, MRO line/base stations, ground handling, airport lounges, cargo division, route groups (by hub, region), and corporate functions. Stores centre type (cost/profit), hierarchy level and parent, responsible manager, controlling area, validity periods, budget allocation references, revenue attribution rules, CASK/RASK allocation keys, and internal activity rates. Enables departmental P&L reporting, CASK component attribution, route profitability analysis, and management accounting by business segment.' .

ind:AccountsPayable rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Accounts Payable' ;
    rdfs:comment 'SAP FI-AP vendor invoice and payment obligation records for the airline covering MRO suppliers, fuel vendors, airport authorities, GDS providers, catering contractors, and ground handling agents. Each record represents a vendor invoice document with invoice number, vendor ID, invoice date, line items, tax amounts, purchase order reference, goods receipt reference, three-way match status, payment terms, due dates, withholding tax, approval workflow status, payment execution details (method, bank, value date, clearing document), and BSP/ARC settlement obligations. Supports procure-to-pay lifecycle, cash flow forecasting, and supplier payment runs.' .

ind:AccountsReceivable rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Accounts Receivable' ;
    rdfs:comment 'SAP FI-AR customer receivable and collection records for the airline covering travel agency BSP/ARC settlements, corporate account billings, interline receivables, cargo AWB collections, ancillary service charges, and incoming payment receipts. Tracks invoice issuance, payment receipt (method, bank, value date, clearing reference), dunning status, credit limits, ageing buckets, and reconciliation status. Supports revenue recognition, working capital management, and customer credit risk monitoring.' .

ind:BudgetPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Budget Plan' ;
    rdfs:comment 'Annual and multi-year financial budget plans for the airline covering operating expenditure (OPEX), capital expenditure (CAPEX), and revenue budgets by cost centre, profit centre, and GL account. Stores budget version, planning horizon, approval status, budget owner, and variance thresholds. Supports rolling forecast cycles and board-level financial planning aligned with SAP CO-PA and BPC modules.' .

ind:FuelCostTransaction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Fuel Cost Transaction' ;
    rdfs:comment 'Granular fuel uplift cost records linking each physical fuel uplift event (from flight operations) to its financial accounting entry. Captures fuel quantity (litres/kg), unit price, total cost, currency, fuel supplier, into-plane agent, airport IATA code, fuel type (Jet-A1, SAF), hedging contract reference, and cost centre allocation. Critical for CASK fuel component reporting and fuel hedge effectiveness measurement.' .

ind:LeaseContract rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Lease Contract' ;
    rdfs:comment 'IFRS 16 lease contract master and full amortisation schedule for aircraft dry leases, wet leases (ACMI), engine leases, spare part pool access agreements, and property leases (airport lounges, hangars, office space). Stores lessor details, lease commencement and expiry dates, lease term, right-of-use asset value, lease liability opening balance, discount rate (incremental borrowing rate), variable lease payment terms, renewal/termination options, modification history, and complete period-by-period liability amortisation schedule (opening balance, interest expense, lease payment, principal repayment, closing balance). Supports automated GL journal entry generation, IFRS 16 disclosure notes, lease vs buy analysis, fleet planning integration, and auditor reconciliation.' .

ind:LeaseLiabilitySchedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Lease Liability Schedule' ;
    rdfs:comment 'IFRS 16 lease liability amortisation schedule records for each lease contract, detailing period-by-period opening balance, interest expense, lease payment, principal repayment, and closing balance. Supports automated journal entry generation for right-of-use asset depreciation and interest accrual. Enables IFRS 16 disclosure notes and auditor reconciliation for aircraft and property leases.' .

ind:InterlineBilling rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Interline Billing' ;
    rdfs:comment 'Interline billing and settlement records for revenue and cost flows between the airline and partner carriers under interline ticketing agreements. Captures IATA billing and settlement plan (BSP) transactions, interline proration amounts, debit memos, credit memos, billing period, partner airline IATA code, and settlement currency. Supports IATA CASS (Cargo Accounts Settlement System) and passenger interline reconciliation.' .

ind:TaxTransaction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Tax Transaction' ;
    rdfs:comment 'Tax posting and compliance records for all applicable taxes including VAT/GST on ancillary services, passenger facility charges (PFC), airport taxes, withholding tax on vendor payments, and corporate income tax provisions. Captures tax code, tax jurisdiction, taxable base amount, tax amount, tax period, filing reference, and tax authority. Supports multi-jurisdiction tax compliance and DOT/EASA regulatory financial reporting.' .

ind:FixedAsset rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Fixed Asset' ;
    rdfs:comment 'SAP FI-AA fixed asset master for the airline\'s capitalised assets including owned aircraft, engines, simulators, ground support equipment, IT infrastructure, and leasehold improvements. Stores asset class, acquisition date, acquisition cost, useful life, depreciation method, accumulated depreciation, net book value, asset location, and disposal date. Supports CAPEX tracking, insurance valuation, and IFRS 16 right-of-use asset management.' .

ind:CompanyCode rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Company Code' ;
    rdfs:comment 'Legal entity and company code master representing the airline\'s individual legal entities, subsidiaries, and joint ventures registered in SAP FI. Stores company code, legal entity name, country of incorporation, local currency, chart of accounts, fiscal year variant, and consolidation group. Supports multi-entity financial consolidation, intercompany eliminations, and statutory reporting per jurisdiction.' .

ind:ScheduledFlight rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Flight ;
    rdfs:label 'Scheduled Flight' ;
    rdfs:comment 'Master record for a planned flight operation as published in the airline\'s schedule. Represents the canonical scheduled flight leg with planned route, aircraft type, departure/arrival airports, scheduled times (STD/STA), flight number, codeshare indicators, operating carrier, service type (passenger/cargo/ferry), day-of-week frequency pattern, season validity (IATA summer/winter), and schedule status (active/suspended/cancelled). SSOT for all planned flight operations prior to day-of-operations. Each operated flight_leg references exactly one scheduled_flight as its planned baseline.' .

ind:FlightLeg rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Flight ;
    rdfs:label 'Flight Leg' ;
    rdfs:comment 'Operational instance of a single flight leg actually operated or planned to be operated on a specific date. The atomic unit of flight execution and the central hub entity of the flight domain. Contains actual flight number, operating date, origin/destination airport pair, aircraft registration (tail number), cabin configuration, full flight status lifecycle with history (scheduled → boarding → departed → airborne → landed → arrived, or cancelled/diverted), status change timestamps with source attribution (ACARS, ATC feed, airport FIDS, manual OCC update), all OOOI timestamps (Out-Off-On-In), computed block hours and airborne time, estimated and actual departure/arrival times (ETD/ETA/ATD/ATA), gate/stand information, and public-facing status message. Links to scheduled_flight for planned baseline comparison. All operational flight records (dispatch, fuel, delays, performance) reference this entity. Supports real-time passenger notifications, airport FIDS integration, and OCC monitoring via NetLine/Ops.' .

ind:DispatchRelease rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Flight ;
    rdfs:label 'Dispatch Release' ;
    rdfs:comment 'Official dispatch release document authorizing a specific flight leg to depart. Contains dispatcher authorization, MEL (Minimum Equipment List) items accepted, fuel release quantities (planned uplift, minimum fuel, contingency, alternate, final reserve), alternate airports, NOTAM briefing package (relevant NOTAMs for departure/en-route/destination/alternate with operational significance flags), weather briefing package (METARs, TAFs, SIGMETs, PIREPs, winds-aloft for all relevant stations), ETOPS authorization if applicable, and dispatcher/captain sign-off timestamps. Mandatory regulatory document required by FAA 14 CFR Part 121.687 / EASA OPS for each commercial flight departure.' .

ind:Plan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Flight ;
    rdfs:label 'Plan' ;
    rdfs:comment 'Computerized flight plan for a specific flight leg, managed as a versioned document through its full lifecycle from initial filing to final crew-accepted Operational Flight Plan (OFP) loaded into the FMS. Contains route of flight (RNAV waypoints, airways, SIDs/STARs), planned altitude profile and step-climb schedule, estimated en-route time, fuel burn calculations by segment, alternate airports, wind and temperature data used, cost index, planned block hours, zero fuel weight, takeoff weight, landing weight, and performance data. Version status tracks progression: filed (submitted to ATC/ICAO), amended (re-cleared/updated), operational (final crew-accepted OFP loaded into FMS for execution). The operational version represents the definitive flight plan used by the crew and is the SSOT for planned route, fuel, and performance targets against which actuals are compared. Generated by Jeppesen Flight Planning System or equivalent.' .

ind:OooiEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Flight ;
    rdfs:label 'Oooi Event' ;
    rdfs:comment 'Captures the four key gate/runway timestamps for each flight leg: Out (pushback/gate departure), Off (wheels-off/takeoff), On (wheels-on/landing), and In (gate arrival/chocks-in). Each event record includes the event type, actual timestamp, source system (ACARS, manual entry, ADS-B), airport and runway/gate reference, and data quality flag. Foundation for block hours calculation, OTP (On-Time Performance) reporting, and DOT/IATA punctuality statistics.' .

ind:FuelUplift rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Flight ;
    rdfs:label 'Fuel Uplift' ;
    rdfs:comment 'Records actual fuel loaded onto an aircraft for a specific flight leg at a specific station. Contains fuel quantity uplift (kg/lbs and litres), fuel density, fuel type (Jet-A, Jet-A1, JP-8), fuelling company, into-plane agent, fuel ticket number, fuel price per unit, total fuel cost, pre-fuelling quantity on board, post-fuelling quantity on board, and fuelling timestamp. Critical for fuel cost accounting, fuel efficiency analysis, and CORSIA carbon reporting.' .

ind:DelayRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Flight ;
    rdfs:label 'Delay Record' ;
    rdfs:comment 'Captures delay events associated with a flight leg including primary and secondary IATA delay codes (AHM 730 standard), delay duration in minutes, responsible department/station, delay description narrative, delay category (airline, ATC, airport, weather, pax-related), and whether the delay was reactionary (caused by late inbound aircraft). Supports OTP reporting, DOT delay reporting, root cause analysis, and operational performance management.' .

ind:Diversion rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Flight ;
    rdfs:label 'Diversion' ;
    rdfs:comment 'Records flight diversions where an aircraft lands at an airport other than the planned destination. Contains diversion reason (weather, medical, mechanical, ATC, security), diversion airport, time of diversion decision, actual landing time at diversion airport, subsequent disposition (continued to destination, returned to origin, cancelled), passenger handling actions taken, and estimated cost impact. Supports IROP management, regulatory reporting, and passenger care obligations.' .

ind:IropEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Flight ;
    rdfs:label 'Irop Event' ;
    rdfs:comment 'Irregular Operations (IROP) event master record capturing disruptions that affect multiple flights or require operational recovery actions. Covers event type (weather, ATC ground stop, airport closure, aircraft AOG, crew shortage, security), affected station(s), event start/end times, severity level, CDM (Collaborative Decision Making) session reference, recovery plan status, and estimated total delay minutes and passengers affected. Distinct from individual delay_record or diversion — represents the root cause event driving multiple disruptions.' .

ind:Cancellation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Flight ;
    rdfs:label 'Cancellation' ;
    rdfs:comment 'Records flight cancellations including cancellation reason code (IATA AHM 730), cancellation decision timestamp, cancellation authority (OCC, station, crew), whether cancellation was proactive or reactive, passenger rebooking status, estimated revenue impact, and whether the cancellation was DOT-reportable. Distinct from delay_record (flight operated late) and diversion (flight landed elsewhere). Supports DOT 14 CFR Part 234 reporting and passenger care compliance.' .

ind:WeightBalance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Flight ;
    rdfs:label 'Weight Balance' ;
    rdfs:comment 'Weight and balance (W&B) loadsheet for each flight leg. Contains zero fuel weight (ZFW), takeoff weight (TOW), landing weight (LW), maximum structural weights, centre of gravity (CG) position at takeoff and landing, trim setting, load distribution by zone, passenger count by cabin class, cargo/baggage weight by hold, and loadmaster/dispatcher sign-off. Mandatory regulatory document for every commercial flight per FAA/EASA airworthiness requirements.' .

ind:Status rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Flight ;
    rdfs:label 'Status' ;
    rdfs:comment 'Real-time and historical flight status records providing the current operational state of a flight leg at any point in time. Contains status code (scheduled, boarding, departed, airborne, landed, arrived, cancelled, diverted, delayed), status timestamp, source system (ACARS, ATC feed, airport FIDS, manual OCC update), estimated departure/arrival times (ETD/ETA), gate information, and public-facing status message. Supports real-time passenger notifications, airport FIDS, and OCC monitoring via NetLine/Ops.' .

ind:Pnr rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Reservation ;
    rdfs:label 'Pnr' ;
    rdfs:comment 'Passenger Name Record (PNR) — the master booking record and SSOT for all reservation data within the airline. Captures the full PNR lifecycle from creation through ticketing, modification, and archival/purge. Stores PNR record locator (6-character alphanumeric), booking source (GDS/direct/NDC), distribution channel, booking date, ticketing time limit (TTL), booking status (confirmed/waitlisted/cancelled/archived), currency, total fare amount, form of payment summary, agency IATA number, responsible office ID, creating agent sign, creation timestamp, last modification timestamp, number of passengers, number of segments, and PNR purge date. Central hub entity to which all other reservation products relate. Aligns with Amadeus Altéa Reservation and IATA RP 1745 PNR standards.' .

ind:ItinerarySegment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Reservation ;
    rdfs:label 'Itinerary Segment' ;
    rdfs:comment 'Individual flight segment within a PNR itinerary. Represents a single booked flight leg including operating carrier code, flight number, departure airport IATA code, arrival airport IATA code, scheduled departure date and time, scheduled arrival date and time, booking class (RBD), cabin class, fare basis code, segment status code (HK/KL/UN/NO), number of seats, codeshare indicator, operating carrier flight number, marketing carrier code, equipment type, and segment sequence number. Core operational unit of the itinerary.' .

ind:ETicket rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Reservation ;
    rdfs:label 'E Ticket' ;
    rdfs:comment 'Electronic ticket (e-ticket) record representing the contractual document of carriage issued to a passenger. Stores ticket number (13-digit IATA format), conjunction ticket numbers, issuing airline code, issuing office IATA number, ticket issue date and time, ticket status (OPEN/USED/VOID/REFUNDED/EXCHANGED), fare amount, tax breakdown, total amount, form of payment, fare calculation string, endorsement/restriction text, tour code, commission amount, and original ticket number for exchanges. SSOT for ticketing lifecycle. Aligns with Amadeus Altéa ticketing module.' .

ind:BookingPassenger rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Reservation ;
    rdfs:label 'Booking Passenger' ;
    rdfs:comment 'Passenger name element (PNE) within a PNR — the reservation-context association of a traveller to a booking. Stores passenger title, first name, last name, suffix, passenger type code (ADT/CHD/INF/INS/YTH/UNN), date of birth, gender, nationality, associated infant indicator, frequent flyer number and tier (for display/SSR purposes), known traveller number (KTN), redress number, APIS data completeness flag, seat preference (window/aisle/none), meal preference code, SSR count, and passenger sequence number within the PNR. This is the booking-scoped passenger reference; the canonical passenger identity master is owned by the passenger domain.' .

ind:Ssr rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Reservation ;
    rdfs:label 'Ssr' ;
    rdfs:comment 'Special Service Request (SSR) record attached to a PNR or specific segment/passenger combination. Captures SSR code (WCHR/VGML/UMNR/DOCS/DOCA/DOCO/FQTV etc.), SSR status (HK/KK/UN/NO/NN), free-text SSR remark, airline responsible for action, segment applicability, passenger applicability, SSR category (meal/wheelchair/document/loyalty/security), creation source, and action required flag. Supports operational fulfilment of passenger special needs and regulatory APIS/DOCA/DOCO document collection.' .

ind:BoardingPass rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Reservation ;
    rdfs:label 'Boarding Pass' ;
    rdfs:comment 'Boarding pass record issued to a passenger for a specific flight segment at check-in. Stores boarding pass sequence number, check-in method (web/mobile/kiosk/counter/CUSS), boarding pass format (BCBP/paper/mobile), barcode data (IATA BCBP Type M), gate number, boarding time, seat number at issuance, boarding zone/group, baggage tag numbers, security selectee flag, document check status, boarding pass issue timestamp, and boarding pass reprint count. SSOT for check-in and boarding event data.' .

ind:CheckInEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Reservation ;
    rdfs:label 'Check In Event' ;
    rdfs:comment 'Check-in transaction record capturing the act of a passenger checking in for a flight. Stores check-in timestamp, check-in channel (web/mobile/airport kiosk/counter/CUSS/API), check-in agent ID, check-in station (airport/city), check-in status (completed/cancelled/no-show), number of bags checked, total checked baggage weight, excess baggage fee amount, upgrade at check-in flag, APIS submission status, document verification status, and check-in close time. Enables OTP analysis, no-show tracking, and ground operations coordination.' .

ind:FareQuote rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Reservation ;
    rdfs:label 'Fare Quote' ;
    rdfs:comment 'Stored fare quote (pricing record) within a PNR capturing the fare calculation at time of booking or repricing. Stores fare quote number, pricing date, fare basis code per segment, published fare amount, applicable discount, total fare, tax itemisation, surcharges (YQ/YR fuel surcharge), pricing command used, validating carrier, ticketing time limit, fare type (published/negotiated/private/award), tour code, endorsement text, and pricing source (GDS/NDC/direct). Supports ticketing, repricing, and revenue accounting.' .

ind:BookingPayment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Reservation ;
    rdfs:label 'Booking Payment' ;
    rdfs:comment 'Payment record associated with a PNR capturing the form of payment and transaction details for ticket and ancillary purchases. Stores payment method type (credit card/debit card/cash/agency account/voucher/miles redemption/corporate account), card type, masked card number, card expiry, cardholder name, payment amount, currency, payment status (authorised/settled/declined/refunded/chargeback), payment gateway transaction ID, 3DS authentication status, payment timestamp, and instalment plan details. SSOT for reservation-level payment capture.' .

ind:RefundTransaction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Reservation ;
    rdfs:label 'Refund Transaction' ;
    rdfs:comment 'Refund transaction record for voided, cancelled, or partially refunded tickets and EMDs. Stores refund type (full/partial/involuntary/voluntary), original ticket or EMD number, refund amount, penalty amount deducted, tax refund amount, refund method (original form of payment/voucher/miles), refund request date, refund processing date, refund status (requested/approved/processed/rejected), refund reason code, waiver code (for penalty waivers), processing agent ID, and refund reference number. Supports revenue accounting and BSP/ARC settlement.' .

ind:TravelDocument rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Reservation ;
    rdfs:label 'Travel Document' ;
    rdfs:comment 'Passenger travel document record collected for APIS (Advance Passenger Information System) and border control compliance. Stores document type (passport/national ID/visa/resident permit/travel permit), document number, issuing country ISO code, nationality, document expiry date, document issue date, surname as on document, given names as on document, gender, date of birth, place of birth, and document verification status. Collected via SSR DOCS/DOCA/DOCO elements. Required for international travel regulatory compliance with TSA, CBP, and national border agencies.' .

ind:GroupBooking rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Reservation ;
    rdfs:label 'Group Booking' ;
    rdfs:comment 'Group booking master record for coordinated reservations of 10+ passengers travelling together under a single group contract. Stores group name, group type (leisure/corporate/incentive/tour operator/sports team/military/government), total seats contracted, seats named (passengers assigned), seats confirmed, group fare basis code, negotiated fare amount per passenger, deposit amount and due date, final payment due date, name list completion deadline, ticketing deadline, group booking status (option/tentative/confirmed/partially-ticketed/fully-ticketed/cancelled), group coordinator name and contact, sales owner, and associated PNR locator list. Supports group desk operations, bulk inventory allocation, deposit tracking, and name list management workflows.' .

ind:WorkOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Maintenance ;
    rdfs:label 'Work Order' ;
    rdfs:comment 'Core MRO work order entity representing a discrete maintenance task or package issued against an aircraft, component, or system. Captures work order number, type (scheduled/unscheduled/AOG/modification), status lifecycle (open/in-progress/deferred/closed), originating source (AD, SB, MEL, defect, interval), estimated and actual man-hours, labour cost, material cost, station, start and completion timestamps, sign-off authority, Part-145 approval reference, and associated AMO. SSOT for all maintenance execution records. Links upward to maintenance program/check and downward to tasks, material requests, and component removals.' .

ind:WorkOrderTask rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Maintenance ;
    rdfs:label 'Work Order Task' ;
    rdfs:comment 'Individual task line within a work order, representing a discrete maintenance action, inspection step, or job card instruction. Tracks task card reference, ATA chapter/section, skill trade required (avionics, airframe, powerplant), estimated hours, actual hours, technician sign-off, inspector sign-off, status, and any deferred or carry-forward flags. Enables granular tracking of multi-task work packages.' .

ind:Program rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Maintenance ;
    rdfs:label 'Program' ;
    rdfs:comment 'Approved aircraft maintenance program (AMP) master record defining the scheduled maintenance framework for an aircraft type or individual registration. Captures program revision, EASA/FAA approval reference, maintenance planning document (MPD) baseline, interval structure (flight hours, flight cycles, calendar days), escalation approvals, and effectivity. SSOT for what maintenance is required and at what intervals per regulatory approval.' .

ind:Check rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Maintenance ;
    rdfs:label 'Check' ;
    rdfs:comment 'Scheduled maintenance check event (A-check, B-check, C-check, D-check, line check, transit check) planned or executed against a specific aircraft registration. Records check type, due date, due flight hours, due cycles, actual induction date, release date, station/MRO facility, man-hours consumed, downtime days, and next-due projections. Bridges the maintenance program to actual execution events.' .

ind:AirworthinessDirective rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Maintenance ;
    rdfs:label 'Airworthiness Directive' ;
    rdfs:comment 'Airworthiness Directive (AD) master record issued by FAA, EASA, or national CAA mandating corrective action on aircraft, engines, or components. Captures AD number, issuing authority, effective date, compliance method (one-time/repetitive), threshold (FH/FC/calendar), interval, applicability (aircraft type, serial number range), superseded AD references, and compliance status per tail number. SSOT for regulatory AD tracking.' .

ind:AdCompliance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Maintenance ;
    rdfs:label 'Ad Compliance' ;
    rdfs:comment 'Compliance record tracking the status of each Airworthiness Directive against each applicable aircraft or component. Records compliance method selected, accomplishment date, flight hours at accomplishment, cycles at accomplishment, next-due date/hours/cycles for repetitive ADs, work order reference, certifying staff sign-off, and open/closed/deferred status. Enables airworthiness compliance reporting to FAA/EASA/CAA.' .

ind:ServiceBulletin rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Maintenance ;
    rdfs:label 'Service Bulletin' ;
    rdfs:comment 'Manufacturer Service Bulletin (SB) and Service Letter (SL) master record issued by OEM (Airbus, Boeing, CFM, etc.) recommending or mandating modifications, inspections, or part replacements. Captures SB number, revision, OEM, ATA chapter, category (mandatory/recommended/optional), effectivity, compliance threshold, and cross-reference to any associated AD. SSOT for OEM technical communication tracking.' .

ind:DefectReport rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Maintenance ;
    rdfs:label 'Defect Report' ;
    rdfs:comment 'Aircraft defect and discrepancy record raised by flight crew (via technical log), cabin crew, or maintenance technicians. Captures ATA chapter, defect description, discovery phase (pre-flight/in-flight/post-flight/hangar), MEL/CDL applicability, deferral category (A/B/C/D), deferral expiry, rectification work order reference, station, and open/deferred/closed status. SSOT for unscheduled maintenance demand origination.' .

ind:MelItem rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Maintenance ;
    rdfs:label 'Mel Item' ;
    rdfs:comment 'Minimum Equipment List (MEL) item master defining approved deferral conditions for inoperative aircraft systems or components. Captures ATA chapter, MEL item number, revision, deferral category (A/B/C/D), maximum deferral period, operational/maintenance procedures required, placard requirements, dispatch conditions, and MMEL (Master MEL) reference. SSOT for MEL configuration per aircraft type.' .

ind:MelDeferral rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Maintenance ;
    rdfs:label 'Mel Deferral' ;
    rdfs:comment 'Active MEL deferral instance recording a specific inoperative item deferred on a tail number under an approved MEL category. Captures tail number, MEL item reference, deferral open date, deferral expiry date, flight hours/cycles at deferral, station, authorising certifying staff, associated defect report, rectification work order, and closure details. Enables AOG risk monitoring and deferral expiry alerting.' .

ind:Component rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Maintenance ;
    rdfs:label 'Component' ;
    rdfs:comment 'Aircraft component and rotable part master record tracking individual serialised and batch-tracked parts across the fleet. Captures part number (P/N), serial number (S/N), ATA chapter, component description, manufacturer, life-limited part (LLP) flag, total time since new (TTSN), total cycles since new (TCSN), time since overhaul (TSO), cycles since overhaul (CSO), current location (aircraft/shop/store), airworthiness release certificate (CRS/Form 1/8130-3) reference, and serviceable/unserviceable status.' .

ind:TechnicalLog rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Maintenance ;
    rdfs:label 'Technical Log' ;
    rdfs:comment 'Aircraft technical log (ATL) sector page record capturing the official per-flight airworthiness and maintenance record as required by EASA Part-M / FAA 14 CFR 91.417. Records flight sector (departure/arrival), commander acceptance, pre-flight inspection status, fuel/oil state, defects raised by crew, MEL items active, deferred defects carried forward, CRS (Certificate of Release to Service) issued for rectification work, certifying staff licence number, and aircraft total hours/cycles at sector end. The legal airworthiness continuity document — must be retained for the life of the aircraft.' .

ind:Release rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Maintenance ;
    rdfs:label 'Release' ;
    rdfs:comment 'Certificate of Release to Service (CRS) record issued by Part-145 certifying staff confirming that maintenance work has been completed satisfactorily and the aircraft or component is airworthy for return to service. Captures CRS number, work order reference, certifying staff name and licence number, approval organisation (Part-145 AMO), scope of work, date/time of release, aircraft hours/cycles at release, and any open items or limitations. Legally mandated airworthiness release document.' .

ind:ApprovedMaintenanceOrg rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Maintenance ;
    rdfs:label 'Approved Maintenance Org' ;
    rdfs:comment 'Part-145 Approved Maintenance Organisation (AMO) master record for internal base/line maintenance and contracted third-party MRO providers. Captures organisation name, ICAO/IATA station code, approval number, issuing authority (EASA Part-145, FAA Part-145 Repair Station, CAAC CCAR-145), approval scope (airframe rating, engine rating, component rating, avionics rating), capability list reference, approval expiry date, audit history, and commercial contract status. SSOT for MRO vendor qualification, regulatory approval tracking, and outsourced maintenance governance.' .

ind:FfpMember rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Loyalty ;
    rdfs:label 'Ffp Member' ;
    rdfs:comment 'Master record for Frequent Flyer Program (FFP) members. Captures member enrollment identity, FFP number, membership status, tier level (e.g., Silver, Gold, Platinum, Executive), tier qualification dates, lifetime miles balance, home airport, preferred language, communication preferences, enrollment channel, program join date, and member travel/service preferences (seat, meal, cabin, marketing consent). This is the SSOT for loyalty member identity and preferences within the loyalty domain — distinct from the passenger master in the passenger domain, which owns travel identity. Aligns with Oracle Loyalty Cloud member master.' .

ind:TierStatus rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Loyalty ;
    rdfs:label 'Tier Status' ;
    rdfs:comment 'Defines the elite tier levels within the FFP (e.g., Silver, Gold, Platinum, Executive Platinum). Captures tier name, tier code, qualification thresholds (miles, segments, spend), tier benefits summary, tier validity period rules, upgrade eligibility, lounge access entitlement, bonus mile multiplier, and priority service flags. Reference entity governing tier qualification logic across the program.' .

ind:TierQualification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Loyalty ;
    rdfs:label 'Tier Qualification' ;
    rdfs:comment 'Tracks each member\'s active and historical tier qualification periods, including standard annual qualification cycles and special qualification events (status matches, tier challenges). Records qualification year/cycle, qualifying miles (QM), qualifying segments (QS), qualifying spend (QSP), tier achieved, tier effective date, tier expiry date, rollover miles, tier extension events, qualification source breakdown, and for status match/challenge cases: competing airline, competing tier held, proof of status reference, challenge conditions, challenge activity required/achieved, and match outcome. Enables year-end tier review processing, proactive tier challenge management, and competitive status match adjudication. Aligns with Oracle Loyalty Cloud tier qualification module.' .

ind:MileageAccrual rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Loyalty ;
    rdfs:label 'Mileage Accrual' ;
    rdfs:comment 'Transactional record of every mile-crediting event for an FFP member, including flight earnings, partner earnings, credit card accruals, miles purchases, manual adjustments (goodwill credits, retro-claims, error corrections, fraud reversals), and reinstatements. Captures accrual source (flight, partner, credit card, hotel, car rental, retail, purchase, adjustment), flight details (PNR, flight number, origin, destination, cabin class, fare class), partner transaction reference, base miles, bonus miles, elite bonus multiplier, promotional bonus, total miles credited, accrual date, posting date, accrual status (pending, posted, reversed), expiry date of earned miles, adjustment reason code, authorizing agent ID, and approval reference. Core SSOT ledger for all credit-side loyalty currency movements.' .

ind:MileageRedemption rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Loyalty ;
    rdfs:label 'Mileage Redemption' ;
    rdfs:comment 'Transactional record of every mile-debiting event for an FFP member, including award flights, upgrades, partner rewards, merchandise, charity donations, miles transfers (peer-to-peer gifting, family pooling), and purchase-based transfers. Captures redemption type, award booking reference, redemption miles deducted, co-pay cash amount, redemption date, redemption channel, redemption status (requested, confirmed, ticketed, cancelled, refunded), refund miles on cancellation, processing fees, transfer recipient FFP number (for transfers), transfer fee, and transfer type (gift, family pool, purchase). Core SSOT ledger for all debit-side loyalty currency movements.' .

ind:MilesBalance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Loyalty ;
    rdfs:label 'Miles Balance' ;
    rdfs:comment 'Current and historical miles balance ledger for each FFP member. Maintains total miles balance, redeemable miles, qualifying miles (QM) year-to-date, qualifying segments (QS) year-to-date, qualifying spend (QSP) year-to-date, lifetime miles earned, lifetime miles redeemed, miles expiring in next 90/180 days, last transaction date, and balance as-of timestamp. Serves as the authoritative running balance for member account statements and real-time eligibility checks.' .

ind:AwardBooking rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Loyalty ;
    rdfs:label 'Award Booking' ;
    rdfs:comment 'Master record for award flight bookings made using FFP miles. Captures award PNR, award type (saver, standard, upgrade, companion), origin, destination, travel dates, cabin class, number of passengers, total miles cost, co-pay amount, ticketing status, award ticket number, booking channel, waitlist status, award inventory bucket used, partner airline involvement, and cancellation/refund details. Links to mileage_redemption for the miles debit event.' .

ind:PartnerProgram rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Loyalty ;
    rdfs:label 'Partner Program' ;
    rdfs:comment 'Master record for FFP earn/burn partner agreements. Captures partner name, partner type (airline codeshare, hotel, car rental, credit card, retail, telecom), partner IATA/ICAO code where applicable, earn rate (miles per dollar/unit), burn rate (miles per reward unit), partner tier recognition flag, partner bonus mile eligibility, agreement effective date, agreement expiry date, settlement currency, settlement frequency, and partner contact details. SSOT for all loyalty partner configurations.' .

ind:PartnerTransaction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Loyalty ;
    rdfs:label 'Partner Transaction' ;
    rdfs:comment 'Transactional record of miles earned or redeemed through non-airline FFP partners (hotels, car rentals, credit cards, retail). Captures partner program ID, member FFP number, partner transaction reference, transaction date, transaction amount, transaction currency, miles awarded or redeemed, bonus miles, partner location/property, transaction type (earn/burn), posting status, and dispute flag. Feeds into mileage_accrual and mileage_redemption for consolidated member ledger.' .

ind:Promotion rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Loyalty ;
    rdfs:label 'Promotion' ;
    rdfs:comment 'Master record for FFP promotional campaigns offering bonus miles, tier accelerators, or special rewards. Captures promotion code, promotion name, promotion type (double miles, tier challenge, status match, bonus on route, partner bonus), target segment, eligible member tiers, eligible routes or partners, promotion start date, promotion end date, bonus miles formula, maximum bonus cap, opt-in requirement flag, opt-in count, redemption count, and promotion status. Aligns with Oracle Loyalty Cloud promotions module.' .

ind:PromotionEnrollment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Loyalty ;
    rdfs:label 'Promotion Enrollment' ;
    rdfs:comment 'Tracks individual member opt-ins and participation in loyalty promotions. Records member FFP number, promotion ID, enrollment date, enrollment channel, qualification progress (e.g., flights completed vs. required), bonus miles awarded, promotion completion date, and promotion outcome status (enrolled, in-progress, completed, expired, cancelled). Enables targeted promotion tracking and bonus posting automation.' .

ind:MemberBenefit rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Loyalty ;
    rdfs:label 'Member Benefit' ;
    rdfs:comment 'Defines the specific benefit entitlements associated with each FFP tier or membership type and tracks their consumption. Captures benefit type (lounge access, priority check-in, extra baggage allowance, seat upgrade priority, companion ticket, bonus mile multiplier, dedicated phone line), benefit tier applicability, benefit quantity/limit, benefit validity period, benefit delivery channel, benefit terms, usage count, last usage date, remaining balance, and usage history summary. Reference entity linking tier levels to their operational benefit entitlements with consumption tracking for benefit cap enforcement and utilization reporting.' .

ind:UpgradeRequest rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Loyalty ;
    rdfs:label 'Upgrade Request' ;
    rdfs:comment 'Tracks member requests for complimentary or miles-based cabin upgrades. Captures request type (complimentary elite upgrade, miles upgrade, co-pay upgrade), member FFP number, PNR reference, flight number, travel date, origin, destination, requested cabin, current cabin, upgrade priority score, waitlist position, upgrade status (requested, waitlisted, confirmed, cleared, denied, expired), upgrade clearing timestamp, miles deducted if applicable, and upgrade source channel.' .

ind:MilesTransfer rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Loyalty ;
    rdfs:label 'Miles Transfer' ;
    rdfs:comment 'Records peer-to-peer miles transfer transactions between FFP members (gifting, pooling, family sharing). Captures sender FFP number, recipient FFP number, miles transferred, transfer fee charged, transfer date, transfer type (gift, family pool contribution, purchase), transfer status, and applicable transfer limits consumed. Distinct from partner_transaction as it represents member-to-member movement of loyalty currency.' .

ind:AwardInventory rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Loyalty ;
    rdfs:label 'Award Inventory' ;
    rdfs:comment 'Manages the availability of award seats allocated for FFP redemption across flights and cabin classes. Captures flight number, travel date, origin, destination, cabin class, award bucket code (saver/standard/premium), total award seats allocated, seats available, seats held, seats redeemed, blackout date flag, partner award availability flag, and last updated timestamp. Distinct from the revenue inventory domain — this is the loyalty-specific award seat pool managed by the FFP program.' .

ind:Profile rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Passenger ;
    rdfs:label 'Profile' ;
    rdfs:comment 'Core master record for every individual passenger served by the airline — the authoritative identity hub (SSOT) for the passenger domain. Stores full legal name, date of birth, gender, nationality, preferred language, passenger type (adult, child, infant, unaccompanied minor), profile creation source (Altéa PSS, web, mobile, GDS), profile status, and data consent flags. Holds a summary primary contact reference (single email, single phone) for display purposes only — the authoritative multi-valued contact store is the contact_detail product. Referenced by reservation, loyalty, and ancillary domains via passenger_id. Aligns with Amadeus Altéa passenger profile entity.' .

ind:TravelIdentityDocument rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Passenger ;
    rdfs:label 'Travel Identity Document' ;
    rdfs:comment 'Stores all identity and travel documents associated with a passenger — passports, national ID cards, visas, residence permits, and known traveller numbers (e.g., TSA PreCheck, Global Entry, NEXUS). Captures document number, issuing country (ICAO alpha-2), document type, issue date, expiry date, machine-readable zone (MRZ) data, and document verification status. Supports APIS (Advance Passenger Information System) regulatory reporting and border control compliance. A passenger may hold multiple documents across multiple nationalities.' .

ind:ContactDetail rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Passenger ;
    rdfs:label 'Contact Detail' ;
    rdfs:comment 'All contact channels for a passenger — email addresses, phone numbers (mobile, home, work), postal addresses, and emergency contacts. Captures contact type, channel, preferred contact flag, opt-in/opt-out status for marketing and operational communications, verification status, and effective date range. Supports IROP proactive notification and DOT consumer communication requirements. A passenger may have multiple active contact records across channels. Distinct from pax_profile (which holds a summary contact reference) — this is the detailed, multi-valued contact store.' .

ind:SsrRecord rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Passenger ;
    rdfs:label 'Ssr Record' ;
    rdfs:comment 'Special Service Request (SSR) records linked to a passenger profile — capturing per-flight or per-booking service instances for accessibility needs (WCHR, WCHC, BLND, DEAF), medical requirements (MEDA, OXYG), dietary meal requests (SPML codes instantiated from travel_preference standing preferences or ad-hoc), unaccompanied minor (UMNR) service, and other service codes defined by IATA SSR taxonomy. Each SSR record carries the IATA SSR code, free-text description, service status (requested, confirmed, cancelled), applicable flight scope, and handling instructions for ground and cabin crew. Distinct from travel_preference (standing preferences) and accessibility_profile (persistent PRM master) — this is the per-flight service instance.' .

ind:LoyaltyLinkage rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Passenger ;
    rdfs:label 'Loyalty Linkage' ;
    rdfs:comment 'Association entity linking a passenger profile to one or more Frequent Flyer Program (FFP) memberships — both the airlines own programme and partner airline programmes (Star Alliance, oneworld, SkyTeam). Stores FFP number, programme code (IATA carrier code), tier status at linkage time, tier expiry, linkage status (active, suspended, unlinked), and source system. This is a reference pointer only — loyalty master data (accrual, redemption, tier calculation) lives in the loyalty domain. Enables tier recognition at check-in and boarding without SSOT duplication.' .

ind:TravellerSegment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Passenger ;
    rdfs:label 'Traveller Segment' ;
    rdfs:comment 'Passenger segmentation and marketing classification records — assigns passengers to analytically derived or rule-based segments such as high-value traveller, corporate frequent flyer, leisure traveller, price-sensitive, premium loyalist, or lapsed traveller. Captures segment code, segment name, segment source (rules engine, ML model, manual), assignment date, expiry date, and confidence score where applicable. Used by revenue management for personalised pricing, by loyalty for targeted offers, and by ancillary for upsell propensity. Distinct from loyalty tier — this is a commercial segmentation layer.' .

ind:Consent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Passenger ;
    rdfs:label 'Consent' ;
    rdfs:comment 'Manages passenger data privacy and consent records in compliance with GDPR, CCPA, PDPA, and other applicable data protection regulations. Captures consent type (marketing email, SMS, data sharing with partners, profiling, personalisation), consent status (granted, withdrawn, pending), consent channel (web, mobile app, call centre, airport kiosk), consent timestamp, consent version (policy version at time of grant), and jurisdiction. Provides the legal basis for data processing activities and supports right-to-erasure and data portability requests. Mandatory for DOT and EASA consumer protection compliance.' .

ind:MinorGuardian rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Passenger ;
    rdfs:label 'Minor Guardian' ;
    rdfs:comment 'Manages the relationship between unaccompanied minor (UMNR) passengers and their authorised guardians or escorts. Captures guardian full name, relationship to minor (parent, legal guardian, authorised adult), contact phone numbers, government-issued ID reference, authorisation document reference, pickup authorisation at destination, and the effective date range of the guardianship record. Required for UMNR service fulfilment, ground handling handover procedures, and liability compliance. Distinct from contact_detail — this entity carries legal authorisation and handover workflow data specific to minors.' .

ind:WatchlistCheck rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Passenger ;
    rdfs:label 'Watchlist Check' ;
    rdfs:comment 'Records the results of security watchlist screening checks performed against a passenger profile — covering TSA Secure Flight, OFAC sanctions screening, Interpol notices, and national no-fly list checks. Captures check timestamp, screening programme (Secure Flight, OFAC, EU PNR Directive, etc.), match status (clear, potential match, confirmed match, resolved), resolution action, resolving officer ID, and regulatory submission reference. Mandatory for TSA Secure Flight compliance on US-bound flights and EU PNR Directive compliance on EU-bound flights. Distinct from redress_record — this captures the screening event, not the resolution credential.' .

ind:ApisSubmission rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Passenger ;
    rdfs:label 'Apis Submission' ;
    rdfs:comment 'Transactional records of Advance Passenger Information System (APIS) data submissions to border control authorities — capturing the submission timestamp, destination country authority (CBP, UK Border Force, EU Entry/Exit System, etc.), submission status (pending, accepted, rejected, error), passenger travel document data snapshot at time of submission, flight reference, and authority response code. Required for regulatory compliance on international routes under ICAO Annex 9, US CBP APIS, and EU Entry/Exit System mandates. Distinct from travel_document (the master record) — this captures the regulatory submission event.' .

ind:AccessibilityProfile rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Passenger ;
    rdfs:label 'Accessibility Profile' ;
    rdfs:comment 'Dedicated master record for passengers with disabilities or reduced mobility (PRM — Passengers with Reduced Mobility) — capturing mobility aid type (manual wheelchair, electric wheelchair, mobility scooter), dimensions and weight of mobility aid, battery type (lithium-ion, dry cell) for cargo hold compliance, ambulatory status, visual impairment level, hearing impairment level, cognitive assistance requirements, medical equipment carried (CPAP, oxygen concentrator), and preferred assistance workflow at each journey touchpoint (check-in, security, gate, boarding, deplaning). Aligns with IATA PRM Handling Guidelines and EU Regulation 1107/2006. Distinct from ssr_record — this is the persistent profile, not the per-flight SSR instance.' .

ind:ProductCatalog rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ancillary ;
    rdfs:label 'Product Catalog' ;
    rdfs:comment 'Master catalog of all ancillary products and services offered by the airline beyond the base fare, including baggage fees, seat upgrades, priority boarding, lounge access, in-flight meals, Wi-Fi, travel insurance, car rentals, hotel bookings, and bundled fare add-ons. Defines the product identity, category, IATA SSIM/EMD service type codes, channel availability, and lifecycle status for each ancillary offering.' .

ind:Category rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ancillary ;
    rdfs:label 'Category' ;
    rdfs:comment 'Reference taxonomy classifying ancillary products into standardized categories aligned with IATA PADIS and ATPCO Optional Services standards — e.g., baggage, seat, boarding, lounge, catering, connectivity, ground transport, accommodation, insurance, bundles. Drives merchandising logic, reporting hierarchies, and EMD issuance rules.' .

ind:Price rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ancillary ;
    rdfs:label 'Price' ;
    rdfs:comment 'Pricing records for ancillary products defining the fare amount, currency, applicable route or market, cabin class, passenger type code (PTC), booking class, sales channel, and effective date range. Supports dynamic and static ancillary pricing strategies including yield-linked and flat-fee models. Source of truth for ancillary price points used in offer generation.' .

ind:Bundle rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ancillary ;
    rdfs:label 'Bundle' ;
    rdfs:comment 'Defines bundled ancillary fare products (e.g., Basic, Standard, Flex, Premium bundles) that package multiple ancillary services into a single purchasable offer. Captures bundle composition rules, included service entitlements, pricing tiers, and unbundling eligibility. Supports the airline\'s unbundled fare strategy and branded fare merchandising.' .

ind:BundleComponent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ancillary ;
    rdfs:label 'Bundle Component' ;
    rdfs:comment 'Junction entity linking bundles to their constituent ancillary products, defining the specific services included in each bundle with quantity entitlements (e.g., 1x checked bag, 1x seat selection), inclusion type (mandatory/optional/upgradeable), and merchandising display sequence. Resolves the many-to-many relationship between bundles and products. Enables flexible bundle composition, entitlement validation at service delivery, and branded fare comparison displays.' .

ind:AncillaryOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ancillary ;
    rdfs:label 'Ancillary Order' ;
    rdfs:comment 'Transactional record of a passenger\'s purchase of one or more ancillary services, linked to a PNR and e-ticket. Captures order date, sales channel (GDS, NDC, direct, airport), total amount, currency, payment reference, order status, and the originating booking context. Acts as the commercial anchor for ancillary revenue recognition and EMD issuance.' .

ind:OrderItem rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ancillary ;
    rdfs:label 'Order Item' ;
    rdfs:comment 'Line-item detail of each ancillary service within an ancillary order. Captures the specific ancillary product purchased, quantity, unit price, total amount, applicable flight segment, passenger association, SSR code, service status (confirmed, waitlisted, cancelled), and fulfilment reference. Enables per-service revenue tracking and operational delivery coordination.' .

ind:AncillaryEmd rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ancillary ;
    rdfs:label 'Ancillary Emd' ;
    rdfs:comment 'Electronic Miscellaneous Document (EMD) master record issued for ancillary services sold separately from the base e-ticket. Captures EMD number (13-digit IATA format), EMD type (EMD-S standalone or EMD-A associated), issuing airline, issuing office/GDS, associated ticket number, passenger name, total face value, currency, issuance date, validity period, and current coupon status. SSOT for EMD lifecycle management.' .

ind:SeatProduct rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ancillary ;
    rdfs:label 'Seat Product' ;
    rdfs:comment 'Commercial seat product definitions available for ancillary purchase or upgrade, defining seat types (standard, preferred, extra legroom, exit row, bulkhead), zone classifications, pitch/width specifications, applicable aircraft types, cabin class associations, and pricing tier references. This is the sellable seat product catalog — distinct from the physical seat map (fleet domain) and operational seat assignment (reservation domain). Drives seat merchandising offers and revenue attribution by seat tier.' .

ind:SeatAssignment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ancillary ;
    rdfs:label 'Seat Assignment' ;
    rdfs:comment 'Transactional record of a paid or complimentary seat assignment made for a passenger on a specific flight segment. Captures seat number, deck, cabin, seat product type, assignment method (self-select, agent-assigned, auto-assigned), assignment timestamp, associated ancillary order item reference, upgrade type if applicable, and current assignment status. Enables seat revenue tracking and operational manifest generation.' .

ind:BaggageAllowance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ancillary ;
    rdfs:label 'Baggage Allowance' ;
    rdfs:comment 'Defines the baggage entitlement rules associated with a fare product, frequent flyer tier, or ancillary purchase — including number of pieces, weight limits (kg/lbs), size restrictions, and applicable route/cabin/PTC combinations. Supports both piece concept and weight concept allowance models per IATA Resolution 302. Used for entitlement validation at check-in and ancillary upsell logic.' .

ind:UpgradeOffer rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ancillary ;
    rdfs:label 'Upgrade Offer' ;
    rdfs:comment 'Defines commercial upgrade offers presented to passengers for cabin upgrades (e.g., Economy to Business) via bid, fixed-price, or miles-based mechanisms. Captures offer type (bid upgrade, instant upgrade, miles upgrade, operational upgrade), eligible fare classes, minimum and maximum bid amounts, offer window (hours before departure), target cabin, and channel availability. Supports revenue-optimized upgrade merchandising programs.' .

ind:UpgradeTransaction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ancillary ;
    rdfs:label 'Upgrade Transaction' ;
    rdfs:comment 'Transactional record of a passenger cabin upgrade event, whether purchased, bid-won, miles-redeemed, or operationally assigned. Captures upgrade type, origin cabin, destination cabin, amount paid or miles consumed, bid submission and acceptance timestamps, flight segment, passenger reference, and upgrade status (pending, confirmed, waitlisted, cleared, denied). Enables upgrade revenue tracking and yield impact analysis.' .

ind:EligibilityRule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Ancillary ;
    rdfs:label 'Eligibility Rule' ;
    rdfs:comment 'Business rules defining which passengers, fare classes, routes, cabin types, booking windows, and FFP tiers are eligible to purchase specific ancillary products. Captures rule type (fare-class restriction, route restriction, tier-based entitlement, advance-purchase window, passenger-type restriction), effective date range, priority order, and override flags. Drives real-time ancillary offer eligibility checks across all sales channels.' .

ind:CityPair rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Route ;
    rdfs:label 'City Pair' ;
    rdfs:comment 'Master definition of an origin-destination (O&D) city pair — the fundamental commercial unit of the airline route network. Captures origin and destination airport/city codes, directionality (one-way vs bidirectional), great circle distance, scheduled distance, IATA region pairing (e.g., TC1-TC2), and market classification (domestic, international, transborder). Serves as the SSOT for all O&D-level demand analysis, RPK aggregation, yield reporting, and market sizing. Referenced by route, market_assessment, and interline agreements.' .

ind:Route rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Route ;
    rdfs:label 'Route' ;
    rdfs:comment 'Master record for a defined airline route between an origin and destination airport pair, representing the authoritative network topology entity. Captures route code, origin and destination IATA airport codes, route type (hub-to-hub, hub-to-spoke, spoke-to-spoke, point-to-point), service type (passenger, cargo, mixed), route status (active, suspended, planned, discontinued), inaugural date, suspension date, and applicable bilateral air service agreement reference. Aligns with Jeppesen NetLine/Sched route master.' .

ind:FlightNumber rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Route ;
    rdfs:label 'Flight Number' ;
    rdfs:comment 'Master record for airline flight number designators assigned to routes, capturing the IATA/ICAO carrier code prefix, numeric flight number, suffix (if applicable), direction (outbound/inbound), operating carrier, marketing carrier (for codeshare), flight number type (operating, codeshare, wetlease), effective date range, and associated route. Serves as the SSOT for flight number lifecycle management and codeshare number assignment. Aligns with Jeppesen scheduling and Amadeus Altéa inventory.' .

ind:ScheduleSeason rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Route ;
    rdfs:label 'Schedule Season' ;
    rdfs:comment 'Reference master for IATA scheduling seasons defining the temporal boundaries for all schedule planning, slot coordination, and capacity deployment activities. Captures season code (e.g., S25, W25/26), season type (summer/winter), start and end dates per IATA calendar, schedule submission deadlines (initial, supplementary), slot return deadlines, and IATA Schedules Conference dates. Serves as the mandatory temporal anchor referenced by seasonal_schedule, route_slot_allocation, ask_plan, and route_fleet_assignment.' .

ind:SeasonalSchedule rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Route ;
    rdfs:label 'Seasonal Schedule' ;
    rdfs:comment 'Operational schedule plan for a specific route during an IATA season, defining the planned service pattern including days of operation (DOW mask), departure and arrival times (local and UTC), frequency per week, cabin configuration, planned aircraft type, block time, and schedule status (planned, filed, approved, active, cancelled). Represents the filed schedule submitted to IATA and slot coordinators. Aligns with Jeppesen Flight Planning System seasonal schedule module.' .

ind:SlotAllocation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Route ;
    rdfs:label 'Slot Allocation' ;
    rdfs:comment 'Airport slot allocation record for a specific route and season at a slot-coordinated (Level 2 or Level 3) airport. Captures slot coordinator reference number, allocated departure or arrival time, slot type (historical grandfather, new entrant, pool), slot series (full season or partial), days of operation, aircraft type restriction, slot status (requested, allocated, confirmed, returned, swapped), and IATA slot coordination conference reference. Critical for constrained airports (LHR, JFK, CDG, NRT). Aligns with IATA Worldwide Slot Guidelines (WSG).' .

ind:Partnership rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Route ;
    rdfs:label 'Partnership' ;
    rdfs:comment 'Master record for all carrier-to-carrier commercial partnership arrangements at the route level, encompassing codeshare agreements, interline ticketing agreements, special prorate agreements (SPAs), and joint venture arrangements. Captures partner carrier IATA code, agreement type (codeshare free-flow, codeshare block-space, standard interline, SPA, through-check-in, joint venture), applicable routes or O&D pairs, revenue sharing basis (prorate, block-space, revenue-share pool), cabin class availability, baggage through-check eligibility, e-ticket interline capability, effective date, expiry date, and agreement status. Serves as the SSOT for all route-level partnership data enabling multi-carrier itinerary construction, codeshare flight number assignment, and interline revenue settlement.' .

ind:InterlineAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Route ;
    rdfs:label 'Interline Agreement' ;
    rdfs:comment 'Master record for interline ticketing and traffic agreements between the airline and partner carriers at the route or network level. Captures partner carrier IATA code, agreement type (standard interline, special prorate agreement, through-check-in), applicable O&D pairs, prorate basis (IATA prorate factor, mileage, negotiated), baggage through-check eligibility, e-ticket interline capability, BSP/ARC settlement basis, effective date, and agreement status. Enables multi-carrier itinerary construction and revenue settlement.' .

ind:Performance rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Route ;
    rdfs:label 'Performance' ;
    rdfs:comment 'Operational performance record for a route over a defined measurement period (monthly or seasonal), capturing actual vs planned KPIs including OTP (On-Time Performance percentage), load factor (actual passengers / available seats), RPK (Revenue Passenger Kilometers), ASK (Available Seat Kilometers), RASK (Revenue per ASK), CASK (Cost per ASK), yield (revenue per RPK), cancellation rate, diversion rate, and average block time variance. Serves as the route-level operational scorecard. Distinct from flight-level OOOI data owned by the flight domain.' .

ind:BlockTimeStandard rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Route ;
    rdfs:label 'Block Time Standard' ;
    rdfs:comment 'Reference master for planned block time standards by route and aircraft type, representing the scheduled gate-to-gate flight time used in schedule construction and crew pairing. Captures route, aircraft type, direction (outbound/inbound), planned block time (minutes), taxi-out time, taxi-in time, airborne time, seasonal adjustment (summer/winter winds), and last review date. Block time standards are the foundation of crew duty time calculations, fuel planning, and OTP measurement.' .

ind:FleetAssignment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Route ;
    rdfs:label 'Fleet Assignment' ;
    rdfs:comment 'Transactional record of fleet type assignment to a route for a specific season or schedule period, capturing the planned aircraft type, sub-fleet variant, seat configuration, cabin class mix, gauge (total seats), cargo belly capacity, ETOPS requirement (for long-haul over-water routes), and assignment effective date range. Represents the planned fleet deployment decision linking network planning to fleet management. Aligns with Jeppesen NetLine/Fleet assignment module.' .

ind:Occurrence rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Safety ;
    rdfs:label 'Occurrence' ;
    rdfs:comment 'Master record for all aviation safety occurrences including incidents, accidents, serious incidents, near-misses, and all occurrence subtypes (wildlife strikes, runway incursions, airspace deviations, dangerous goods incidents, CFIT events, loss of control, turbulence encounters) as defined under ICAO Annex 13 and Annex 19 SMS framework. Captures occurrence classification (accident/serious incident/incident/occurrence), ICAO occurrence category (CICTT taxonomy), occurrence subtype with subtype-specific extended attributes, date/time/location, aircraft registration, flight phase, injury severity, damage level, narrative description, initial causal factors, reporting source, and regulatory notification status. Subtype-specific fields accommodate wildlife strike details (species, aircraft part struck, ingestion), runway incursion details (runway designator, severity category A-D), airspace deviation details (cleared vs actual values), and dangerous goods details (UN number, DG class, packaging failure). SSOT for all safety occurrence data across the airline.' .

ind:Hazard rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Safety ;
    rdfs:label 'Hazard' ;
    rdfs:comment 'Master record for identified safety hazards within the SMS (Safety Management System) hazard register. Captures hazard title, description, hazard category (operational/technical/organizational/environmental), source of identification (audit/report/observation/proactive analysis), affected operations area, initial likelihood rating, initial severity rating, initial risk index, current status (open/mitigated/closed/accepted), date identified, and responsible safety officer. Core to ICAO Annex 19 proactive safety management.' .

ind:RiskAssessment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Safety ;
    rdfs:label 'Risk Assessment' ;
    rdfs:comment 'Formal risk assessment record linked to a hazard or occurrence within the SMS risk management process. Captures assessment date, assessor identity, risk type (initial/residual/reviewed), likelihood score (1-5 ICAO scale), severity score (1-5 ICAO scale), risk index, risk tolerance level (acceptable/tolerable/intolerable), risk matrix quadrant, assessment methodology, and narrative justification. Tracks the evolution of risk ratings over time as controls are applied. Aligns with ICAO Annex 19 risk management requirements.' .

ind:CorrectiveAction rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Safety ;
    rdfs:label 'Corrective Action' ;
    rdfs:comment 'Corrective actions, preventive actions, mitigating actions, and formal safety recommendations raised against occurrences, hazards, audit findings, risk assessments, or investigations within the SMS. Captures action/recommendation title, description, action type (corrective/preventive/mitigating/recommendation), priority level, assigned department or external addressee (including national AIBs), responsible person, target completion date, actual completion date, verification method, verification status, effectiveness review date, closure status, source reference (investigation/audit/hazard/occurrence), and recommendation-specific fields (addressee response, implementation evidence, regulatory tracking reference). Tracks the full lifecycle from identification through closure and effectiveness review. Encompasses both internally generated recommendations and those received from Accident Investigation Bodies requiring airline response and tracking.' .

ind:Audit rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Safety ;
    rdfs:label 'Audit' ;
    rdfs:comment 'Safety audit and inspection programme records covering internal SMS audits, IOSA (IATA Operational Safety Audit) preparation audits, regulatory authority audits (FAA, EASA, national CAA), and line operations safety audits (LOSA). Captures audit reference number, audit type, audit scope, audited department/station/function, lead auditor, audit team members, planned date, actual date, audit status (planned/in-progress/completed/closed), overall finding summary, and regulatory authority reference where applicable.' .

ind:AuditFinding rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Safety ;
    rdfs:label 'Audit Finding' ;
    rdfs:comment 'Individual findings raised during safety audits, inspections, or surveillance activities. Captures finding reference number, parent audit reference, finding type (non-conformance/observation/opportunity for improvement), finding category, regulatory reference breached (if applicable), finding description, root cause analysis, risk level assigned to finding, responsible department for resolution, and linkage to corrective actions. Supports IOSA, FAA, EASA, and national CAA audit finding management.' .

ind:Report rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Safety ;
    rdfs:label 'Report' ;
    rdfs:comment 'Voluntary and mandatory safety reports, safety alerts, safety information bulletins, and urgent safety communications submitted by crew/staff or received from external authorities through the airlines safety reporting and communication system. Captures report/alert reference number, report type (voluntary/mandatory/confidential/safety_alert/SIB/SAFO/manufacturer_bulletin), reporter or issuing authority, submission/issue date, event date, event location, flight phase, narrative/subject, initial classification, affected aircraft types, urgency level, required action description, compliance deadline, acknowledgement tracking, de-identification status, distribution status, and processing status. Supports Just Culture principles, ICAO Annex 19 safety reporting requirements, and timely dissemination of safety-critical information.' .

ind:Investigation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Safety ;
    rdfs:label 'Investigation' ;
    rdfs:comment 'Safety investigation records for occurrences requiring formal investigation under ICAO Annex 13 or internal SMS investigation procedures. Captures investigation reference number, linked occurrence, investigation type (internal/regulatory/joint), lead investigator, investigation team, investigation start date, target completion date, actual completion date, investigation status (open/in-progress/draft-report/final/closed), causal factors identified, contributing factors, safety recommendations issued, and regulatory authority notification status (NTSB/AAIB/BEA/national AIB).' .

ind:Recommendation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Safety ;
    rdfs:label 'Recommendation' ;
    rdfs:comment 'Formal safety recommendations issued as outputs of investigations, audits, or proactive safety studies. Captures recommendation reference number, source investigation or audit, recommendation text, addressee (internal department or external authority), priority level, target implementation date, implementation status, response narrative, and closure verification. Tracks both internally generated recommendations and those received from national Accident Investigation Bodies (AIBs) requiring airline response.' .

ind:Alert rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Safety ;
    rdfs:label 'Alert' ;
    rdfs:comment 'Safety alerts, safety information bulletins, and urgent safety communications issued internally or received from external sources (EASA Safety Information Bulletins, FAA SAFOs, manufacturer safety bulletins, IATA safety alerts). Captures alert reference number, alert type (internal/EASA SIB/FAA SAFO/manufacturer/IATA), issuing authority, issue date, subject, affected aircraft types, affected operations, urgency level, required action description, compliance deadline, acknowledgement tracking by department, and distribution status. Ensures timely dissemination and tracking of safety-critical information across all operational departments.' .

ind:TerminalFacility rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Airport ;
    rdfs:label 'Terminal Facility' ;
    rdfs:comment 'Master record for airport terminal facilities including terminal buildings, concourses, piers, satellite structures, and check-in counter/kiosk assets. Captures IATA/ICAO airport codes, terminal identifiers, facility type, total gate count, check-in counter inventory (counter zones, types including full-service/self-service/CUSS/bag-drop, airline assignments, accessibility compliance, biometric capability), lounge count, capacity (PAX per hour), operational status, hub classification (hub vs spoke station), and owning airline or joint-use designation. SSOT for physical airport facility assets and check-in infrastructure managed by the airline.' .

ind:Gate rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Airport ;
    rdfs:label 'Gate' ;
    rdfs:comment 'Master record for individual aircraft gates within a terminal facility. Captures gate identifier, terminal reference, concourse, gate type (contact/remote/hardstand), compatible aircraft categories (ICAO size codes A–F), jetbridge availability, ground power unit (GPU) availability, potable water availability, operational status, and maximum wingspan clearance. Serves as the SSOT for gate asset definitions used in gate assignment and turnaround planning.' .

ind:GateAssignment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Airport ;
    rdfs:label 'Gate Assignment' ;
    rdfs:comment 'Transactional record linking a specific flight leg to a gate for a defined time window. Captures flight identifier, tail number, scheduled and actual gate-in/gate-out timestamps (OOOI-aligned), gate identifier, assignment source (CDM/manual/auto-assign), conflict flag, priority override reason, and assignment status (planned/confirmed/released). Supports turnaround sequencing, CDM messaging, and OTP reporting.' .

ind:Turnaround rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Airport ;
    rdfs:label 'Turnaround' ;
    rdfs:comment 'Master operational record for an aircraft turnaround event at a gate, representing the full ground servicing cycle between inbound and outbound flight legs. Captures inbound and outbound flight references, tail number, gate assignment, scheduled and actual block-in/block-out times, turnaround type (standard/quick/overnight/transit), target turnaround time (TTT), actual turnaround time, overall status, responsible ground handler, ramp service order details (ordered services, service window, handler instructions, completion status, deviation notes), and OTP contribution metrics. Central entity for ground operations coordination, handler SLA measurement, and OTP root-cause analysis.' .

ind:TurnaroundTask rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Airport ;
    rdfs:label 'Turnaround Task' ;
    rdfs:comment 'Individual ground servicing task within a turnaround event, including GSE deployment details. Captures task type (fueling, catering, cleaning, water service, lavatory service, de-icing, cargo loading, PAX boarding, pushback), planned and actual start/end times, responsible service provider, task status (pending/in-progress/complete/skipped), delay reason code, sequence order, assigned GSE asset(s), GSE operator, GSE deployment start/end times, fuel consumed by GSE, and any equipment defect noted. Enables milestone tracking, SLA compliance measurement, and GSE utilization optimization for each turnaround service element.' .

ind:Slot rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Airport ;
    rdfs:label 'Slot' ;
    rdfs:comment 'Airport slot record representing an allocated takeoff or landing time at a capacity-constrained airport, including utilization tracking. Captures IATA season, slot type (arrival/departure), allocated time, slot coordinator reference, airport ICAO code, airline designator, aircraft type, slot series (regular/ad-hoc), slot status (allocated/confirmed/returned/swapped), historic slot precedence flag, and per-operating-date utilization data including actual flight reference, compliance status (used/missed/cancelled/swapped), variance in minutes, reason for non-compliance, and regulatory reporting flag. Aligns with IATA Worldwide Slot Guidelines (WSG) and supports slot compliance monitoring and slot pool management.' .

ind:SlotUtilization rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Airport ;
    rdfs:label 'Slot Utilization' ;
    rdfs:comment 'Transactional record tracking actual use of an allocated slot against its planned parameters. Captures slot reference, associated flight, operated date, planned vs actual departure/arrival time, slot compliance status (used/missed/cancelled/swapped), variance in minutes, reason for non-compliance, and regulatory reporting flag for slot return obligations. Supports IATA slot compliance monitoring and slot pool management.' .

ind:CheckinSession rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Airport ;
    rdfs:label 'Checkin Session' ;
    rdfs:comment 'Transactional record representing a passenger check-in interaction at an airport station. Captures PNR reference, passenger reference, flight reference, check-in channel (counter/kiosk/CUSS/web-drop), check-in agent or kiosk identifier, check-in start and end timestamps, seat assigned at check-in, number of bags checked, excess baggage flag, SSR (Special Service Request) items processed, boarding pass issuance method, and check-in status. Supports OTP, passenger flow, and ground operations analytics.' .

ind:BoardingEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Airport ;
    rdfs:label 'Boarding Event' ;
    rdfs:comment 'Transactional record capturing each passenger boarding scan event at the gate. Captures flight reference, gate assignment reference, passenger reference, PNR, boarding pass barcode, scan timestamp, boarding sequence number, boarding zone, scan result (accepted/rejected/duplicate/offload), agent or automated gate reader identifier, and any irregular boarding action taken. Enables final PAX count reconciliation, no-show tracking, and security compliance.' .

ind:BaggageItem rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Airport ;
    rdfs:label 'Baggage Item' ;
    rdfs:comment 'Master record for an individual checked baggage item from acceptance through delivery. Captures IATA 10-digit bag tag number, PNR reference, passenger reference, flight routing, bag type (standard/oversized/fragile/sports/live-animal), weight, dimensions, declared value, acceptance station, acceptance timestamp, final destination station, current location status, and last scan event reference. SSOT for baggage identity and routing within the airport domain.' .

ind:BaggageScan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Airport ;
    rdfs:label 'Baggage Scan' ;
    rdfs:comment 'Transactional record for each baggage scan event in the baggage handling system (BHS). Captures bag tag number, baggage item reference, scan location (check-in/BHS sortation/make-up area/aircraft hold/reclaim belt/transfer), scan device identifier, scan timestamp, flight reference, sortation decision, and scan result (read/no-read/manual-entry). Provides full baggage tracing chain from acceptance to delivery and supports IATA Resolution 753 baggage tracking compliance.' .

ind:BaggageIrregularity rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Airport ;
    rdfs:label 'Baggage Irregularity' ;
    rdfs:comment 'Transactional record for a baggage irregularity event including mishandled, delayed, damaged, or pilfered baggage. Captures PIR (Property Irregularity Report) number, bag tag reference, passenger reference, flight reference, irregularity type (misrouted/offloaded/damaged/pilfered/lost), report station, report timestamp, last known location, forwarding instructions, recovery status, and WorldTracer reference number. Supports IATA WorldTracer integration and DOT/IATA mishandled baggage reporting.' .

ind:DeicingEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Airport ;
    rdfs:label 'Deicing Event' ;
    rdfs:comment 'Transactional record for an aircraft de-icing or anti-icing treatment event. Captures flight reference, tail number, de-icing pad or gate location, treatment type (Type I/II/III/IV fluid), fluid volume applied per treatment step, holdover time issued, treatment start and end timestamps, outside air temperature, precipitation type, de-icing crew identifier, and post-treatment inspection result. Supports safety compliance, fluid cost tracking, and environmental reporting (CORSIA/ISO 14001).' .

ind:GroundHandler rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Airport ;
    rdfs:label 'Ground Handler' ;
    rdfs:comment 'Master record for ground handling service providers contracted to deliver ramp, passenger, and cargo handling services at specific stations, including performance measurement history. Captures handler name, IATA ground handler code, handling categories (ramp/passenger/cargo/fuel/catering), contracted stations, SGHA agreement reference, license and permit details, insurance expiry, performance tier, operational contact details, and periodic performance KPIs (on-time departure contribution, baggage delivery time, damage rate, SLA breach flags, penalty triggers, performance scores). SSOT for ground handler identity and SLA governance within the airport domain.' .

ind:Station rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Airport ;
    rdfs:label 'Station' ;
    rdfs:comment 'Master record for an airline operating station at an airport. Captures IATA airport code, ICAO airport code, station name, city, country, hub classification (hub/focus-city/spoke/outstations), time zone, DST observance, station manager, operational hours, customs and immigration availability, overnight parking capability, maintenance capability level, and active status. SSOT for airline station definitions within the airport domain; complements the route domain\'s network topology.' .

ind:Member rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Crew ;
    rdfs:label 'Member' ;
    rdfs:comment 'Master record for all crew personnel — flight crew (pilots, first officers) and cabin crew (flight attendants, pursers). Owns the authoritative identity, employment status, crew base assignment, crew category (flight deck vs cabin), seniority number, date of hire, AIMS crew ID, and current operational status. This is the SSOT for crew identity within the crew domain, distinct from the workforce domain employee record which owns HR/payroll data.' .

ind:Qualification rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Crew ;
    rdfs:label 'Qualification' ;
    rdfs:comment 'Crew qualification and type rating master records. Captures aircraft type ratings (e.g., B737, A320), position authorizations (Captain, First Officer, Purser), ICAO/FAA licence endorsements, simulator check currency, and qualification expiry dates. Tracks both flight deck type ratings and cabin crew aircraft-specific qualifications. Aligns with AIMS qualification module and FAR/EASA regulatory requirements.' .

ind:Base rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Crew ;
    rdfs:label 'Base' ;
    rdfs:comment 'Reference master for crew domicile bases — the home airports from which crew are assigned, rostered, and begin/end pairings. Captures IATA/ICAO airport code, base name, crew categories served (flight deck, cabin, or both), base capacity (authorized headcount by category), base manager, operational timezone, and associated rest facilities. Used as the anchor point for pairing construction (pairings start/end at base), deadhead planning, reserve pool sizing, and crew positioning decisions. The SSOT for crew base definitions within the crew domain. Aligns with AIMS base management module.' .

ind:Pairing rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Crew ;
    rdfs:label 'Pairing' ;
    rdfs:comment 'A crew pairing (also called a trip or rotation) is the core operational scheduling unit — a sequence of duty periods and rest periods starting and ending at the same crew base, built during the schedule construction phase. Captures pairing code, base, effective date range, total block hours, total duty time, total credit hours, number of legs, overnight stations, and pairing cost. Pairings are the output of the crew pairing optimizer and the input to rostering. Aligns with AIMS pairing module.' .

ind:DutyPeriod rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Crew ;
    rdfs:label 'Duty Period' ;
    rdfs:comment 'A duty period is a continuous block of time during which a crew member is on duty, bounded by report time and release time. Belongs to a pairing. Captures report time, release time, total duty elapsed time (TDT), flight duty period (FDP) start/end, rest period before and after, duty type (flight duty, ground duty, deadhead, training), and FAR Part 117 / EASA FTL legality status. The atomic unit for fatigue risk and FTL compliance calculations.' .

ind:Roster rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Crew ;
    rdfs:label 'Roster' ;
    rdfs:comment 'The published monthly crew roster — the assignment of pairings, training events, days off, standby duties, and leave to individual crew members for a bid period. Captures crew member, bid period (month/year), roster publication date, roster version, total credited block hours, total duty days, days off count, reserve days count, roster status (draft, published, revised, frozen), and PBS award reference (if applicable). The SSOT for what each crew member is scheduled to do in a given month. Supports roster comparison (planned vs actual), crew pay calculation inputs, and union compliance verification. Aligns with AIMS rostering module.' .

ind:RosterActivity rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Crew ;
    rdfs:label 'Roster Activity' ;
    rdfs:comment 'Individual activity line items within a crew roster — each row represents one scheduled activity assigned to a crew member within a bid period. Activity types include: pairing, training, standby (airport or home reserve), day off, deadhead, leave, and ground duty. Captures activity type, start/end datetime, station, pairing reference (if applicable), activity status (scheduled, completed, cancelled, swapped), credit hours, and swap metadata (requesting/receiving crew, approval status) for traded activities. For standby-type activities: additionally captures standby type (airport/home), contact window, activation status, activation time, and triggered flight assignment. Enables day-by-day crew schedule visibility, reserve pool management, roster change audit trail, and IROP crew recovery tracking.' .

ind:FlightLegAssignment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Crew ;
    rdfs:label 'Flight Leg Assignment' ;
    rdfs:comment 'The operational assignment of a specific crew member to a specific flight leg — both operating crew and deadhead (positioning) movements. For operating crew: captures assigned position (Captain, FO, Purser, FA), check-in time, actual report time, augmented crew flag, relief crew flag, and assignment source (rostered, reserve, swap, IROP recovery). For deadhead crew: captures deadhead reason (pairing start, pairing end, IROP recovery, training), booking class, and own-metal/interline indicator. The deadhead_flag discriminates between operating and positioning assignments. The SSOT for who flew (or repositioned on) which leg in what capacity. Links crew domain to flight domain.' .

ind:FtlLegalityCheck rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Crew ;
    rdfs:label 'Ftl Legality Check' ;
    rdfs:comment 'Unified crew fitness-to-operate assessment records encompassing both regulatory FTL/FDP legality checks (FAR Part 117, EASA FTL) and biomathematical fatigue risk model assessments (SAFE, FAID, FRMS). Each record captures: check timestamp, crew member, duty period or pairing evaluated, assessment method (regulatory_rule or biomathematical_model), regulation/model applied, check trigger (pre-assignment, pre-departure, post-duty, IROP extension), cumulative flight time windows (28-day, 365-day), FDP limit and actual FDP, rest compliance status, fatigue score and risk band (for model-based), mitigations applied, approving authority, and overall fitness result (legal/illegal/waiver/elevated-risk). The SSOT for crew legality and fatigue risk audit trail. Supports SMS, FRMS (ICAO Doc 9966), and regulatory compliance.' .

ind:TrainingEvent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Crew ;
    rdfs:label 'Training Event' ;
    rdfs:comment 'Records of crew training events including simulator checks (PC — Proficiency Check, OPC — Operator Proficiency Check, LOE — Line Operational Evaluation), line checks, emergency procedures training (EPT), CRM (Crew Resource Management), ETOPS training, dangerous goods, and security training. Captures training type, aircraft type, training date, training centre, instructor, result (pass/fail/incomplete), and next due date. The SSOT for crew training history and upcoming training requirements. Aligns with AIMS training module.' .

ind:MedicalCertificate rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Crew ;
    rdfs:label 'Medical Certificate' ;
    rdfs:comment 'Crew medical certificate records tracking ICAO Class 1 (flight crew) and Class 2 (cabin crew) medical certificates. Captures certificate class, issuing authority (AME/DAME), issue date, expiry date, certificate number, any limitations or waivers, and current validity status. Critical for crew legality — a crew member cannot operate without a valid medical certificate. Aligns with FAA/EASA medical certification requirements.' .

ind:Licence rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Crew ;
    rdfs:label 'Licence' ;
    rdfs:comment 'Crew aviation licence master records — ATPL (Airline Transport Pilot Licence), CPL (Commercial Pilot Licence), MPL (Multi-crew Pilot Licence), and cabin crew attestation/licence. Captures licence number, issuing authority (FAA, EASA, national CAA), licence type, issue date, ratings held, language proficiency endorsement (ICAO level), and current validity. Distinct from qualification (which tracks type ratings and currency) — this is the base legal authorisation to act as crew.' .

ind:Absence rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Crew ;
    rdfs:label 'Absence' ;
    rdfs:comment 'Records of crew absences from scheduled duty — sick leave, maternity/paternity leave, compassionate leave, suspension, administrative leave, and unplanned absences. Captures absence type, start date, end date, duration, notification method, medical certificate reference (if sick), and impact on roster (replacement required flag). Used for crew availability planning, absence pattern monitoring, and collective agreement compliance.' .

ind:Awb rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Cargo ;
    rdfs:label 'Awb' ;
    rdfs:comment 'Air Waybill (AWB) master record — the primary contractual and operational document governing a cargo shipment. Captures AWB number (IATA 8-digit format), origin and destination airports, shipper and consignee details, commodity description, declared value, number of pieces, gross weight, chargeable weight, volume, nature of goods, special handling codes, freight charges, prepaid/collect indicator, routing instructions, and AWB status lifecycle (booked, accepted, manifested, departed, arrived, delivered). SSOT for all AWB-level cargo data. Aligns with Mercator Cargo Management System AWB module.' .

ind:Booking rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Cargo ;
    rdfs:label 'Booking' ;
    rdfs:comment 'Cargo space reservation record created prior to AWB issuance. Captures booking reference number, booking channel (GDS, direct, agent), requested flight(s), commodity type, requested weight and volume, special handling requirements (DG, perishable, live animals, valuables), booking status (tentative, confirmed, waitlisted, cancelled), rate quote reference, booking agent/forwarder, acceptance deadline, and allotment reference. Represents the commercial commitment before physical acceptance. Aligns with Mercator Cargo booking module.' .

ind:Shipment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Cargo ;
    rdfs:label 'Shipment' ;
    rdfs:comment 'Physical shipment record tracking the end-to-end movement of cargo from acceptance to delivery, including granular milestone events. Captures shipment status (received, built-up, loaded, in-transit, arrived, delivered, on-hold), actual pieces and weight at acceptance, volume, commodity code (IATA/HS), special handling codes (SHC), temperature range for perishables, routing segments, current location, estimated and actual arrival times, proof of delivery, exception flags, and milestone event history (event code per IATA Cargo-XML: RCS, DEP, ARR, NFD, DLV, DIS with timestamps, station, flight, and responsible party). Links AWB to physical ULD build-up and flight manifest. SSOT for shipment lifecycle tracking and real-time shipment visibility.' .

ind:Uld rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Cargo ;
    rdfs:label 'Uld' ;
    rdfs:comment 'Unit Load Device (ULD) master record — the authoritative asset register for all ULD containers and pallets. Captures ULD serial number (IATA format: type code + serial + owner code), ULD type (LD3, LD7, LD11, PMC, PAG, etc.), tare weight, maximum gross weight, maximum volume, material, owner airline code, serviceable status, current location (airport/station), last inspection date, next inspection due date, damage status, and lease/ownership indicator. SSOT for ULD asset identity. Aligns with Mercator ULD management module.' .

ind:UldMovement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Cargo ;
    rdfs:label 'Uld Movement' ;
    rdfs:comment 'Transactional record of every ULD movement and condition event — build-up, breakdown, transfer, loading, offloading, repositioning, and discrepancy/damage incidents. Captures ULD serial number, event type (including damage, missing, overweight, contamination, seal broken), event timestamp, origin station, destination station, flight number, position in aircraft (hold/position code), gross weight at loading, seal numbers, handling agent, discrepancy flags, damage description, repair required indicator, and resolution status. Enables full ULD traceability, supports weight and balance calculations, and provides ULD asset integrity management. Aligns with Mercator ULD tracking module and IATA ULD Regulations damage reporting.' .

ind:Manifest rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Cargo ;
    rdfs:label 'Manifest' ;
    rdfs:comment 'Flight cargo manifest record consolidating all AWBs and ULDs loaded on a specific flight. Captures flight number, flight date, origin and destination airports, total pieces, total weight (actual and chargeable), total volume, list of AWBs carried, ULD positions, belly vs freighter indicator, manifest status (preliminary, final, amended), customs declaration reference, and regulatory submission timestamps. Required for customs clearance and regulatory compliance. Aligns with Mercator manifest module.' .

ind:DangerousGoods rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Cargo ;
    rdfs:label 'Dangerous Goods' ;
    rdfs:comment 'Dangerous Goods (DG) declaration record associated with a specific AWB shipment. Captures IATA DG class and division, UN number, proper shipping name, packing group, net and gross quantity per package, number of packages, packing instruction code, shipper declaration text, emergency contact, radioactive index (if applicable), acceptance check results, DG acceptance certificate reference, and regulatory compliance flags per IATA DGR (Dangerous Goods Regulations). Mandatory for all DG shipments. Aligns with Mercator DG module.' .

ind:FreightRate rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Cargo ;
    rdfs:label 'Freight Rate' ;
    rdfs:comment 'Cargo freight rate and pricing master record defining all pricing structures for cargo transportation including base rates, surcharges, and interline proration. Captures rate type (general cargo rate GCR, specific commodity rate SCR, class rate, ULD rate, IATA tariff rate, surcharge, interline prorate), origin and destination airport pair, commodity code, weight break thresholds, rate per kg, minimum charge, currency, validity period, rate class, routing restrictions, rate source (TACT, bilateral agreement, spot rate, interline), surcharge details (fuel FSC, security SSC, handling, DG, oversize, remote area, CAF with calculation basis), interline partner code, proration method, and settlement references. SSOT for all cargo pricing and revenue sharing. Aligns with Mercator rating and interline modules.' .

ind:Capacity rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Cargo ;
    rdfs:label 'Capacity' ;
    rdfs:comment 'Cargo capacity allocation record per flight segment defining available belly and freighter capacity. Captures flight number, flight date, aircraft registration, aircraft type, total belly cargo capacity (weight and volume), freighter main deck capacity, booked weight, booked volume, available weight, available volume, allotment blocks by product type (general, express, perishable, DG), overbooking factor, embargo flags, and capacity status. Enables revenue management and capacity control for cargo. Aligns with Mercator capacity module.' .

ind:FreightForwarder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Cargo ;
    rdfs:label 'Freight Forwarder' ;
    rdfs:comment 'Freight forwarder and cargo agent master record — the commercial intermediary between shippers and the airline. Captures IATA cargo agent code, company name, CASS (Cargo Accounts Settlement System) number, IATA accreditation status, primary contact details, billing address, credit limit, payment terms, BSP/CASS participation flag, approved commodity types, DG handling certification, station coverage, account manager, and account status. SSOT for cargo commercial partner identity within the cargo domain.' .

ind:Shipper rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Cargo ;
    rdfs:label 'Shipper' ;
    rdfs:comment 'Shipper master record representing the entity tendering cargo for transport. Captures shipper name, address, country, contact details, known shipper status (IATA/ICAO security designation), shipper type (individual, corporate, regulated agent), commodity specializations, DG shipper certification, customs registration number, EORI number, credit status, and relationship to freight forwarder. Distinct from freight forwarder — the shipper is the cargo originator. SSOT for shipper identity in cargo operations.' .

ind:Invoice rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Cargo ;
    rdfs:label 'Invoice' ;
    rdfs:comment 'Cargo revenue invoice record issued to freight forwarders or shippers for transportation charges. Captures invoice number, AWB reference(s), billing party (forwarder/shipper), invoice date, due date, freight charges (prepaid and collect), surcharges (fuel surcharge, security surcharge, handling fees, DG surcharge, oversize surcharge), taxes, total amount, currency, payment status, CASS settlement reference, and invoice type (standard, credit note, debit note). SSOT for cargo billing. Aligns with Mercator revenue accounting module.' .

ind:Claim rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Cargo ;
    rdfs:label 'Claim' ;
    rdfs:comment 'Cargo claim record for loss, damage, or delay incidents. Captures claim reference number, AWB number, claimant details, claim type (loss, damage, delay, pilferage), date of discovery, date of claim filing, claimed amount, currency, damage description, supporting documents list, investigation status, liability determination, settlement amount, settlement date, and claim outcome. Supports cargo liability management and insurance recovery. Aligns with Mercator claims module.' .

ind:LoadPlan rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Cargo ;
    rdfs:label 'Load Plan' ;
    rdfs:comment 'Weight and balance calculation record per flight capturing cargo contribution to aircraft loading. Captures flight number, flight date, aircraft registration, total cargo weight loaded, cargo weight by hold position (forward hold, aft hold, bulk), ULD positions and weights, cargo centre of gravity contribution, trim adjustment required, load sheet reference, loadmaster sign-off, and regulatory compliance flag. Critical for flight safety and dispatch. Links cargo domain to flight operations.' .

ind:Embargo rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Cargo ;
    rdfs:label 'Embargo' ;
    rdfs:comment 'Cargo embargo record defining restrictions on cargo acceptance for specific routes, stations, or commodity types. Captures embargo reference, embargo type (station closure, commodity restriction, weight restriction, DG restriction, seasonal embargo), affected origin/destination airports, affected flight numbers or route, commodity codes affected, embargo start and end dates, reason code, issuing authority, and override approval process. Supports capacity and safety management.' .

ind:CustomsEntry rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Cargo ;
    rdfs:label 'Customs Entry' ;
    rdfs:comment 'Customs declaration and clearance record for cargo crossing international borders. Captures customs entry number, AWB reference, entry type (import, export, transit, transshipment), commodity HS code, declared value, country of origin, country of destination, customs broker details, duty and tax amounts, customs status (filed, under examination, released, held, seized), examination type, release timestamp, and regulatory authority reference. Supports import/export compliance and customs clearance workflows.' .

ind:Aircraft rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fleet ;
    rdfs:label 'Aircraft' ;
    rdfs:comment 'Core master record for every physical aircraft asset in the airline\'s fleet — the Single Source of Truth for aircraft identity referenced by all operational domains. Captures tail number (registration mark), ICAO/IATA type designator, MSN (Manufacturer Serial Number), line number, aircraft family and variant, current operational status (active, stored, parked, retired, wet-lease-out), ownership category (owned, finance-lease, dry-lease, wet-lease-in, ACMI), lessor/owner reference, delivery date, retirement date, country of registration, certificate of registration number, certificate of airworthiness number, airworthiness category, noise chapter classification, ETOPS certification status and minutes rating, RVSM approval, CAT III ILS approval, and current base station. Following merge of aircraft_registration, also holds regulatory registration details including registering authority, registration date/expiry, and registered owner/operator.' .

ind:AircraftType rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fleet ;
    rdfs:label 'Aircraft Type' ;
    rdfs:comment 'Reference master for ICAO/IATA aircraft type designators covering all aircraft families and variants operated or planned. Stores ICAO type code, IATA type code, manufacturer name, aircraft family (e.g. B737, A320), variant (e.g. B737-800, A320neo), engine count, engine type (turbofan, turboprop), wake turbulence category (L/M/H/J), maximum certified passenger capacity, maximum structural payload (kg), maximum takeoff weight (MTOW), maximum landing weight (MLW), maximum zero-fuel weight (MZFW), typical range (nm), typical cruise speed (Mach), wingspan (m), fuselage width category (narrowbody/widebody), ETOPS baseline capability, and whether the type is currently in the airline\'s fleet.' .

ind:CabinConfiguration rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fleet ;
    rdfs:label 'Cabin Configuration' ;
    rdfs:comment 'Defines the cabin layout and seating configuration installed on a specific aircraft. Each record represents a named configuration version (e.g. \'B738-CFG-A\') linked to an aircraft or aircraft type. Captures total seat count, number of cabin classes (e.g. First, Business, Premium Economy, Economy), seat pitch by class, seat width by class, lie-flat availability, in-flight entertainment (IFE) system type, Wi-Fi availability, galley count, lavatory count, door count, overwing exit count, configuration effective date, and configuration retirement date. Supports revenue management seat inventory and passenger service.' .

ind:SeatMap rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fleet ;
    rdfs:label 'Seat Map' ;
    rdfs:comment 'Seat-level detail for a cabin configuration — each row represents one physical seat position. This is the granular seat inventory that passenger service systems, revenue management, and check-in reference for seat assignment, blocking, and special service request (SSR) fulfillment. Captures seat designator (e.g. 12A), deck (main/upper), cabin class assignment, row number, column letter, seat type (window/middle/aisle), location attributes (exit-row, bulkhead, overwing, last-row, bassinet-capable), physical dimensions (pitch inches, width inches), recline capability (standard/limited/lie-flat/angle-flat), blocking flags (is_blocked, block_reason), crew rest indicator, IFE availability, power outlet type (none/AC/USB/both), and premium attributes relevant to ancillary seat selection revenue.' .

ind:FleetOrder rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fleet ;
    rdfs:label 'Fleet Order' ;
    rdfs:comment 'Records aircraft purchase orders and lease commitments placed with OEMs (Boeing, Airbus, Embraer) or lessors for fleet growth, replacement, or renewal. Each record represents a firm order, option, or letter of intent. Captures order reference number, aircraft type ordered, quantity (firm/option/LoI), deliveries completed, cancellations, order date, contractual delivery window (start/end), list price per unit (USD), negotiated price per unit where available, total order value, order status (firm/option/LoI/cancelled/converted), financing structure (cash/debt/sale-leaseback/operating-lease), counterparty (OEM or lessor), and associated fleet plan scenario reference. Supports fleet planning, capital expenditure forecasting, and delivery pipeline management.' .

ind:AircraftDelivery rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fleet ;
    rdfs:label 'Aircraft Delivery' ;
    rdfs:comment 'Transactional record of each aircraft delivery event — when a new or leased aircraft is formally accepted into the airline\'s fleet from a manufacturer or lessor. Captures delivery date, delivery location (airport ICAO), aircraft MSN, tail number assigned at delivery, aircraft type, delivery flight number (ferry flight), acceptance certificate reference, technical acceptance inspection outcome, delivery condition (new/used), hours at delivery, cycles at delivery, engine serial numbers at delivery, APU serial number at delivery, and delivery team sign-off. Triggers aircraft registration and initial airworthiness documentation.' .

ind:AircraftLease rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fleet ;
    rdfs:label 'Aircraft Lease' ;
    rdfs:comment 'Master record for each aircraft lease agreement covering dry-lease, wet-lease, and ACMI arrangements. Captures lease agreement number, lessor name, lessee entity, aircraft tail number, aircraft type, lease type (dry/wet/ACMI), lease start date, lease end date, monthly rental rate (USD), security deposit amount, return conditions (hours/cycles limits), maintenance reserve rate per flight hour, redelivery location, extension options, early termination clause flag, governing law jurisdiction, and current lease status (active/expired/terminated/extended). SSOT for fleet ownership and cost allocation.' .

ind:Engine rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fleet ;
    rdfs:label 'Engine' ;
    rdfs:comment 'Master record for each aircraft engine tracked as an independent serialized asset. Engines move between aircraft (on-wing swaps), go to MRO shops, and serve as spares — requiring independent lifecycle tracking separate from the airframe. Captures engine serial number (ESN), manufacturer (CFM International, GE Aviation, Rolls-Royce, Pratt & Whitney), engine model/variant (e.g. CFM56-7B27, LEAP-1A26), current position on aircraft (1/2/3/4 or spare/shop), current installed aircraft reference, installation date, last removal date, total flight hours since new (TSN), total cycles since new (CSN), hours since last shop visit (TSLSV), cycles since last shop visit (CSLSV), engine status (installed/spare/QEC/shop/beyond-repair/retired), thrust rating (lbf/kN), ETOPS eligibility flag, and life-limited parts (LLP) remaining cycles summary. Critical for engine shop visit planning and lease return.' .

ind:AircraftUtilization rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fleet ;
    rdfs:label 'Aircraft Utilization' ;
    rdfs:comment 'Daily utilization ledger for each aircraft capturing actual operational activity — the authoritative source for airframe time and cycles used by maintenance planning, lease return monitoring, and fleet economics. Each record is keyed to aircraft + date. Stores daily block hours flown, flight hours (airborne), flight cycles completed, number of sectors, number of landings, fuel burn (kg), APU hours, and revenue vs. non-revenue (ferry/positioning) breakdown. Maintains running cumulative totals: total airframe hours since new (TSN), total cycles since new (CSN). Feeds maintenance interval calculations, CASK/RASK analytics, lease return condition tracking, and regulatory utilization reporting.' .

ind:EtopsAuthorization rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fleet ;
    rdfs:label 'Etops Authorization' ;
    rdfs:comment 'Records ETOPS (Extended-range Twin-engine Operational Performance Standards) authorization for each aircraft, specifying the approved diversion time (e.g. 120, 180, 240 minutes), the authorizing regulatory body (FAA, EASA, national CAA), authorization certificate number, effective date, expiry date, applicable route pairs or geographic areas, required maintenance program compliance references, and current authorization status (active/suspended/expired). Each aircraft may have multiple ETOPS authorizations from different regulators. Critical for long-haul twin-engine route dispatch.' .

ind:AircraftRegistration rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fleet ;
    rdfs:label 'Aircraft Registration' ;
    rdfs:comment 'Official regulatory registration record for each aircraft with the national civil aviation authority. Captures registration mark (tail number), registering country (ICAO country prefix), national civil aviation authority (CAA) name, certificate of registration number, registration date, registration expiry date, registered owner name, registered operator name, aircraft category (transport/general aviation), certificate of airworthiness number, airworthiness category, noise certificate number, and registration status (current/expired/cancelled/transferred). This is the regulatory identity record for the aircraft asset.' .

ind:CouponStatus rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Reservation ;
    rdfs:label 'Coupon Status' ;
    rdfs:comment 'Tracks the booking-context lifecycle status of each ticket coupon (open, used, exchanged, refunded, void) as managed within the reservation system, referencing revenue.ticket_coupon as the SSOT for the coupon financial document.' .

ind:BookingSegment rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Flight ;
    rdfs:label 'Booking Segment' ;
    rdfs:comment 'This association product represents the operational booking/reservation segment linking a passenger to a specific flight leg. It captures the passenger\'s journey on a single flight, including seat assignment, boarding details, check-in status, fare information, and service entitlements. Each record represents one passenger\'s travel on one flight leg. This is the core operational entity referenced by check-in systems, boarding gate systems, departure control, and in-flight service systems. Aligns with Amadeus Altéa PNR segment concept.. Existence Justification: In airline operations, the relationship between flight legs and passenger profiles is a canonical many-to-many: each flight leg carries many passengers (typically 100-400 depending on aircraft), and each passenger travels on many flight legs over their lifetime and even within a single journey (multi-leg itineraries). This relationship is operationally managed as booking segments or PNR segments in reservation systems like Amadeus Altéa, with rich attributes including seat assignments, check-in/boarding timestamps, fare details, and service entitlements that belong to neither the flight nor the passenger alone.' .

ind:LegalEntity rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Finance ;
    rdfs:label 'Legal Entity' ;
    rdfs:comment 'Master reference table for legal_entity. Referenced by lessee_entity_id.' .

ind:Lessor rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Fleet ;
    rdfs:label 'Lessor' ;
    rdfs:comment 'Master reference table for lessor. Referenced by lessor_id.' .

ind:Carrier rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Route ;
    rdfs:label 'Carrier' ;
    rdfs:comment 'Master reference table for carrier. Referenced by operating_carrier_id.' .

ind:Agency rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Revenue ;
    rdfs:label 'Agency' ;
    rdfs:comment 'Master reference table for agency. Referenced by agency_id.' .

ind:CorporateAccount rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Revenue ;
    rdfs:label 'Corporate Account' ;
    rdfs:comment 'Master reference table for corporate_account. Referenced by account_id.' .

ind:CodeshareAgreement rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Route ;
    rdfs:label 'Codeshare Agreement' ;
    rdfs:comment 'Master reference table for codeshare_agreement. Referenced by route_codeshare_agreement_id.' .

ind:IropFlightImpact rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Flight ;
    rdfs:label 'Irop Flight Impact' ;
    rdfs:comment 'This association product represents the operational impact event between a declared irregular operations event and a specific flight leg. It captures the per-flight impact record that OCC dispatchers and recovery planners actively manage during IROP recovery workflows. Each record links one flight_irop_event to one flight_leg and carries attributes that exist only in the context of this specific event-flight pairing — including the type of impact, recovery action taken, delay minutes attributable to this event, and the flight\'s position in the recovery sequence. Recognized as a core operational concept in airline OCC systems such as Lufthansa Systems NetLine/Ops.. Existence Justification: In airline operations, a single IROP event (e.g., a weather ground stop at a hub) simultaneously affects dozens of flight legs, and a single flight leg can be impacted by multiple IROP events (e.g., a crew shortage compounded by an ATC ground stop on the same day). The Operations Control Center actively manages which specific flights are impacted by each declared IROP, tracking per-flight impact type, recovery actions taken, and delay minutes attributed to that specific event — data that belongs neither to the IROP event record nor to the flight leg record alone. This relationship is a recognized operational concept in airline OCC systems (e.g., NetLine/Ops \'irop_flight_impact\') that dispatchers and recovery planners create, update, and close as part of the IROP recovery workflow.' .

ind:UldContent rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Cargo ;
    rdfs:label 'Uld Content' ;
    rdfs:comment 'This association product represents the ULD Build-Up Event between uld_movement and shipment. It captures the operational record of which shipments were loaded into a specific ULD for a specific movement event, including the piece count, weight contribution, hold position, seal, and special handling codes applicable to that shipment within that ULD movement. Each record links one uld_movement to one shipment and carries attributes that exist only in the context of that specific build-up assignment. Aligns with IATA ULD Regulations and Cargo-XML messaging standards for ULD content manifesting.. Existence Justification: In air cargo operations, the ULD build-up process is a distinct, actively managed business activity where multiple shipments are physically loaded into a ULD for a specific movement event, and a single shipment may traverse multiple ULD movement events across its routing legs (e.g., built into ULD-A at origin, transferred to ULD-B at a hub). This relationship — known in the industry as a \'ULD Content Record\' or \'ULD Shipment Assignment\' — is operationally created, updated, and deleted by cargo handlers and is the authoritative record of which shipments were in which ULD at each movement event. The existing shipment.uld_id FK points only to the ULD asset (cargo.uld), not to a specific movement event, meaning it cannot represent the temporal/event-level assignment that cargo operations actually require.' .

ind:AdIncorporation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Maintenance ;
    rdfs:label 'Ad Incorporation' ;
    rdfs:comment 'This association product represents the formal incorporation of an Airworthiness Directive into a specific Maintenance Program (AMP). It captures the regulatory compliance contract between a program and an AD — tracking incorporation status, compliance method selected for this program, effective date of incorporation, the program revision at which the AD was incorporated, and any operator-specific applicability overrides. Each record is a live regulatory obligation managed by the CAMO and subject to airworthiness authority audit.. Existence Justification: In aviation MRO operations, a Maintenance Program (AMP) formally incorporates multiple Airworthiness Directives, and a single AD applies to multiple maintenance programs (e.g., across different aircraft types or operator AMPs). Airlines and CAMOs actively manage an \'AD Incorporation\' or \'Program AD Compliance Matrix\' as a regulatory obligation — tracking which ADs are incorporated into which programs, at what revision, with what compliance method and status. This is not an analytical correlation; it is a live, audited, regulatory record that engineers create, update, and present to airworthiness authorities.' .

ind:SbIncorporation rdf:type rdfs:Class ;
    rdfs:subClassOf ind:Maintenance ;
    rdfs:label 'Sb Incorporation' ;
    rdfs:comment 'This association product represents the formal SB Incorporation contract between a maintenance program and a service bulletin. It captures the CAMO\'s official evaluation and embodiment decision for each Service Bulletin within a specific Approved Aircraft Maintenance Program (AMP), including incorporation status, decision date, revision level incorporated, and program-level cost estimate. Each record links one program to one service_bulletin and holds attributes that exist only in the context of this program-SB combination, supporting EASA Part-M/Part-CAMO regulatory compliance reporting and lessor SB status reporting.. Existence Justification: In MRO aviation operations, airlines formally manage an \'SB Incorporation Matrix\' — a structured record of which Service Bulletins have been evaluated, incorporated, deferred, or rejected for each Approved Aircraft Maintenance Program (AMP). This is an actively managed operational concept: maintenance planners create, update, and close these records as SBs are issued by OEMs and evaluated against each program\'s scope, configuration, and regulatory requirements. A single AMP covers multiple SBs (e.g., all applicable Airbus SBs for an A320 fleet program), and a single SB may be evaluated against multiple AMPs (e.g., an Airbus SB applicable to both narrow-body and wide-body programs operated by the same airline). The relationship carries its own data — incorporation status, decision date, revision incorporated, and cost estimate — that belongs to neither the program nor the SB alone.' .

# --- Attribute Properties ---
ind:flightInventoryId rdf:type rdf:Property ;
    rdfs:label 'Flight Inventory Id' ;
    rdfs:comment 'Unique surrogate identifier for the flight inventory record representing the sellable seat inventory for a specific flight-date combination in the Amadeus Altéa Inventory system.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FlightInventory .

ind:aircraftId rdf:type rdf:Property ;
    rdfs:label 'Aircraft Id' ;
    rdfs:comment 'Foreign key linking to fleet.aircraft. Business justification: Flight inventory is opened on a specific tail number for each departure. Operations Control Center assigns aircraft to flights; inventory management needs tail number for MEL item applicability, actua' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Aircraft .

ind:cabinConfigurationId rdf:type rdf:Property ;
    rdfs:label 'Cabin Configuration Id' ;
    rdfs:comment 'Foreign key linking to fleet.cabin_configuration. Business justification: When equipment changes occur (equipment_change_indicator on flight_inventory), the inventory system must reference the active cabin configuration to recompute class capacities (business_class_capacity' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CabinConfiguration .

ind:costCentreId rdf:type rdf:Property ;
    rdfs:label 'Cost Centre Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_centre. Business justification: Flight operations are cost centers in airline accounting. CASK (Cost per Available Seat Kilometer) calculations require linking flight inventory to cost centers for profitability analysis and manageme' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCentre .

ind:fleetAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Fleet Assignment Id' ;
    rdfs:comment 'Foreign key linking to route.route_fleet_assignment. Business justification: Fleet assignment determines aircraft type, seat configuration, and cabin class capacity that inventory must control. Revenue management bucket authorization, overbooking limits, and codeshare allocati' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FleetAssignment .

ind:flightNumberId rdf:type rdf:Property ;
    rdfs:label 'Flight Number Id' ;
    rdfs:comment 'Foreign key linking to route.flight_number. Business justification: Flight inventory controls real-time seat availability for specific flight numbers defined in route planning. Revenue management, codeshare allocation, and GDS distribution all require linking daily in' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FlightNumber .

ind:originStationId rdf:type rdf:Property ;
    rdfs:label 'Origin Station Id' ;
    rdfs:comment 'Foreign key linking to airport.station. Business justification: Flight inventory capacity records must link to origin station for slot-coordinated market compliance reporting, station-level load factor dashboards, and hub capacity planning. Aviation revenue manage' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Station .

ind:routeId rdf:type rdf:Property ;
    rdfs:label 'Route Id' ;
    rdfs:comment 'FK to route.route.route_id — Flight inventory must reference the route for network-level availability queries, codeshare allocation management, and seasonal capacity planning.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Route .

ind:scheduledFlightId rdf:type rdf:Property ;
    rdfs:label 'Scheduled Flight Id' ;
    rdfs:comment 'Reference to the scheduled flight leg for which this inventory record is maintained. Links to the flight master entity in the flight operations domain.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ScheduledFlight .

ind:seasonalScheduleId rdf:type rdf:Property ;
    rdfs:label 'Seasonal Schedule Id' ;
    rdfs:comment 'Foreign key linking to route.seasonal_schedule. Business justification: Flight inventory operationalizes a specific seasonal schedule template. Linking inventory to seasonal_schedule enables variance analysis (planned vs actual capacity), schedule change impact assessment' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SeasonalSchedule .

ind:alteaInventoryKey rdf:type rdf:Property ;
    rdfs:label 'Altea Inventory Key' ;
    rdfs:comment 'Native primary key or reference identifier assigned by the Amadeus Altéa Inventory system to this flight inventory record. Used for system-of-record traceability and reconciliation between the lakehouse Silver layer and the operational PSS.' ;
    rdfs:domain ind:FlightInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedCapacity rdf:type rdf:Property ;
    rdfs:label 'Authorized Capacity' ;
    rdfs:comment 'Revenue management-approved seat count authorized for sale on this flight-date, which may differ from total physical capacity due to operational holds, crew seat requirements, or regulatory restrictions. This is the effective inventory ceiling used by Sabre AirVision Revenue Management.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:availabilitySnapshotTimestamp rdf:type rdf:Property ;
    rdfs:label 'Availability Snapshot Timestamp' ;
    rdfs:comment 'Timestamp of the most recent real-time availability snapshot broadcast to GDS and direct booking channels. Reflects the point-in-time at which seats_available and fare class bucket statuses were last synchronized with Amadeus Altéa.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:bookingCurveDay rdf:type rdf:Property ;
    rdfs:label 'Booking Curve Day' ;
    rdfs:comment 'Number of days prior to departure at which this inventory snapshot was captured, representing the position on the booking curve (e.g., 90, 60, 30, 14, 7, 1). Used by Sabre AirVision Revenue Management for demand forecasting and fare class optimization.' ;
    rdfs:domain ind:FlightInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:businessClassCapacity rdf:type rdf:Property ;
    rdfs:label 'Business Class Capacity' ;
    rdfs:comment 'Total number of seats allocated to the Business Class cabin on this flight-date. Reflects the aircraft configuration and any cabin reconfiguration applied for this specific flight.' ;
    rdfs:domain ind:FlightInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:channelRestrictionCode rdf:type rdf:Property ;
    rdfs:label 'Channel Restriction Code' ;
    rdfs:comment 'Code indicating any channel-specific sales restrictions applied to this flight inventory (e.g., \'DIRECT_ONLY\' for web/app exclusive fares, \'GDS_BLOCKED\' for GDS channel closure, \'NDC_ONLY\' for IATA NDC channel exclusivity). Controls distribution channel access to inventory.' ;
    rdfs:domain ind:FlightInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codeshareIndicator rdf:type rdf:Property ;
    rdfs:label 'Codeshare Indicator' ;
    rdfs:comment 'Flag indicating whether this flight inventory record includes codeshare seat allocations from partner airlines. When true, a portion of the authorized capacity is reserved for codeshare partner bookings under interline ticketing agreements.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:codeshareSeatsAllocated rdf:type rdf:Property ;
    rdfs:label 'Codeshare Seats Allocated' ;
    rdfs:comment 'Number of seats within the authorized capacity ring-fenced for codeshare partner airline bookings on this flight-date. Managed under bilateral codeshare agreements and tracked separately from own-metal inventory for revenue accounting and BSP settlement.' ;
    rdfs:domain ind:FlightInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:createdTimestamp rdf:type rdf:Property ;
    rdfs:label 'Created Timestamp' ;
    rdfs:comment 'Timestamp when this flight inventory record was first created in the Amadeus Altéa Inventory system, typically at the time of schedule publication or inventory initialization for the flight-date.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:departureDate rdf:type rdf:Property ;
    rdfs:label 'Departure Date' ;
    rdfs:comment 'Scheduled local departure date of the flight leg at the origin station. Together with flight_number, forms the primary business key for inventory lookup by GDS and booking channels.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:destinationAirportCode rdf:type rdf:Property ;
    rdfs:label 'Destination Airport Code' ;
    rdfs:comment 'Three-letter IATA airport code for the arrival station of this flight leg (e.g., LAX, CDG). Used to identify the inventory leg destination in route network and GDS availability queries.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:economyCapacity rdf:type rdf:Property ;
    rdfs:label 'Economy Capacity' ;
    rdfs:comment 'Total number of seats allocated to the Economy Class cabin on this flight-date. Typically the largest cabin and primary driver of load factor and revenue management decisions.' ;
    rdfs:domain ind:FlightInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:equipmentChangeIndicator rdf:type rdf:Property ;
    rdfs:label 'Equipment Change Indicator' ;
    rdfs:comment 'Flag indicating whether the aircraft type assigned to this flight-date has been changed from the originally scheduled equipment. Equipment changes may alter cabin configuration, total capacity, and fare class bucket allocations requiring inventory rebalancing.' ;
    rdfs:domain ind:FlightInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fareClassBucketConfig rdf:type rdf:Property ;
    rdfs:label 'Fare Class Bucket Config' ;
    rdfs:comment 'Serialized representation of the active fare class bucket (booking class) configuration for this flight-date, listing each IATA booking class code and its authorized seat allocation (e.g., \'Y:20,B:15,M:10,Q:5\'). Managed by Sabre AirVision Revenue Management and consumed by Amadeus Altéa for availability control.' ;
    rdfs:domain ind:FlightInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstClassCapacity rdf:type rdf:Property ;
    rdfs:label 'First Class Capacity' ;
    rdfs:comment 'Total number of seats allocated to the First Class cabin on this flight-date. Reflects the aircraft configuration and any cabin reconfiguration applied for this specific flight.' ;
    rdfs:domain ind:FlightInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:flightNumber rdf:type rdf:Property ;
    rdfs:label 'Flight Number' ;
    rdfs:comment 'IATA-format airline designator and numeric flight number (e.g., AA101) identifying the marketed flight for which inventory is being managed. Used by GDS and direct channels to query availability.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdsAvailabilityCode rdf:type rdf:Property ;
    rdfs:label 'Gds Availability Code' ;
    rdfs:comment 'Single-letter availability status code broadcast to Global Distribution Systems (GDS) representing the highest open booking class on this flight-date (e.g., \'Y\' for full availability, \'L\' for restricted availability). Conforms to IATA availability message standards.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupSeatsHeld rdf:type rdf:Property ;
    rdfs:label 'Group Seats Held' ;
    rdfs:comment 'Number of seats currently held under group booking reservations (typically 10+ passengers under a single PNR group) on this flight-date. Group holds reduce available inventory for individual bookings and are subject to group ticketing deadlines.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:interlineSeatsAllocated rdf:type rdf:Property ;
    rdfs:label 'Interline Seats Allocated' ;
    rdfs:comment 'Number of seats allocated for interline ticketing partner bookings on this flight-date under IATA interline agreements. Distinct from codeshare allocations and tracked for ARC/BSP proration and revenue accounting.' ;
    rdfs:domain ind:FlightInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inventoryControlMode rdf:type rdf:Property ;
    rdfs:label 'Inventory Control Mode' ;
    rdfs:comment 'Indicates whether inventory management for this flight-date is operating under MANUAL (revenue analyst override), AUTOMATED (Sabre AirVision algorithmic control), or HYBRID (automated with manual overrides) mode. Affects how fare class bucket changes are applied.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryStatus rdf:type rdf:Property ;
    rdfs:label 'Inventory Status' ;
    rdfs:comment 'Current operational status of the flight inventory record in Amadeus Altéa. OPEN indicates seats are available for sale; CLOSED indicates no further sales permitted; WAITLIST indicates demand exceeds supply and waitlist is active; SUSPENDED indicates temporary hold on sales; CANCELLED indicates the flight has been cancelled and inventory is frozen.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastSeatAvailabilityDate rdf:type rdf:Property ;
    rdfs:label 'Last Seat Availability Date' ;
    rdfs:comment 'Date on which the last available seat on this flight-date was sold or the inventory was closed. Used for post-departure revenue analysis and booking curve benchmarking.' ;
    rdfs:domain ind:FlightInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent modification to this flight inventory record, including any changes to seat counts, fare class buckets, overbooking parameters, or inventory status. Critical for real-time availability synchronization with GDS.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:loadFactorPct rdf:type rdf:Property ;
    rdfs:label 'Load Factor Pct' ;
    rdfs:comment 'Current load factor expressed as a percentage, calculated as seats_sold divided by authorized_capacity multiplied by 100. A key revenue management KPI representing the proportion of available seat capacity that has been sold. Used by Sabre AirVision for yield optimization decisions.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operationalSeatsHeld rdf:type rdf:Property ;
    rdfs:label 'Operational Seats Held' ;
    rdfs:comment 'Number of seats withheld from sale for operational purposes including deadhead crew positioning, airline staff travel, and aircraft ferry requirements. These seats are excluded from the sellable inventory pool.' ;
    rdfs:domain ind:FlightInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overbookingFactor rdf:type rdf:Property ;
    rdfs:label 'Overbooking Factor' ;
    rdfs:comment 'Revenue management-approved overbooking multiplier expressed as a percentage above physical capacity (e.g., 105.00 means 5% overbooking allowed). Set by Sabre AirVision Revenue Management based on historical no-show and cancellation rates to maximize load factor while managing denied boarding risk.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overbookingLimit rdf:type rdf:Property ;
    rdfs:label 'Overbooking Limit' ;
    rdfs:comment 'Absolute maximum number of bookings permitted on this flight-date including the overbooking allowance. Computed from authorized_capacity multiplied by overbooking_factor and used as the hard ceiling in the Amadeus Altéa booking engine.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:premiumEconomyCapacity rdf:type rdf:Property ;
    rdfs:label 'Premium Economy Capacity' ;
    rdfs:comment 'Total number of seats allocated to the Premium Economy cabin on this flight-date. Nullable for aircraft configurations that do not include a Premium Economy cabin.' ;
    rdfs:domain ind:FlightInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revenueManagementClass rdf:type rdf:Property ;
    rdfs:label 'Revenue Management Class' ;
    rdfs:comment 'Revenue management classification assigned by Sabre AirVision to this flight-date based on demand forecast, booking curve position, and competitive pricing environment. Drives automated fare class bucket opening and closing decisions for yield optimization.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleChangeIndicator rdf:type rdf:Property ;
    rdfs:label 'Schedule Change Indicator' ;
    rdfs:comment 'Flag indicating whether this flight-date has undergone a schedule change (time, equipment, or routing modification) since the original inventory record was created. Schedule changes may trigger IROP (Irregular Operations) rebooking workflows and inventory reallocation.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:seatsAvailable rdf:type rdf:Property ;
    rdfs:label 'Seats Available' ;
    rdfs:comment 'Current number of seats available for sale across all cabins on this flight-date, calculated as authorized_capacity minus seats_sold minus overbooking_buffer. This is the real-time availability figure broadcast to GDS and direct booking channels.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seatsSold rdf:type rdf:Property ;
    rdfs:label 'Seats Sold' ;
    rdfs:comment 'Total number of confirmed seat bookings (Pax) across all cabins and fare classes on this flight-date. Updated in real-time as reservations are created, modified, or cancelled in the Amadeus Altéa Reservation system.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalCapacity rdf:type rdf:Property ;
    rdfs:label 'Total Capacity' ;
    rdfs:comment 'Total number of physical seats available on the aircraft for this flight-date combination across all cabins. Derived from the aircraft configuration assigned to the flight and represents the maximum sellable inventory ceiling.' ;
    rdfs:domain ind:FlightInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:waitlistCount rdf:type rdf:Property ;
    rdfs:label 'Waitlist Count' ;
    rdfs:comment 'Current number of passengers on the waitlist for this flight-date when inventory_status is WAITLIST or when specific fare classes are closed. Waitlisted passengers are cleared in priority order as cancellations occur.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cabinClassId rdf:type rdf:Property ;
    rdfs:label 'Cabin Class Id' ;
    rdfs:comment 'Unique surrogate identifier for the cabin class record within the airline\'s inventory system. Primary key for this reference master entity.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CabinClass .

ind:generalLedgerId rdf:type rdf:Property ;
    rdfs:label 'General Ledger Id' ;
    rdfs:comment 'Foreign key linking to finance.general_ledger. Business justification: Airlines maintain separate GL revenue accounts by cabin class (first, business, premium economy, economy) for P&L reporting and RASK analysis. Revenue accounting systems post cabin-level revenue to di' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GeneralLedger .

ind:applicableFlightRange rdf:type rdf:Property ;
    rdfs:label 'Applicable Flight Range' ;
    rdfs:comment 'Flight range category for which this cabin class configuration is applicable: \'short_haul\' (under 3 hours), \'medium_haul\' (3–6 hours), \'long_haul\' (6–12 hours), \'ultra_long_haul\' (over 12 hours), or \'all\'. Drives route-specific product deployment and inventory segmentation.' ;
    rdfs:domain ind:CabinClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baggageAllowanceKg rdf:type rdf:Property ;
    rdfs:label 'Baggage Allowance Kg' ;
    rdfs:comment 'Standard checked baggage allowance in kilograms included with the base fare for this cabin class. Drives ancillary revenue calculations, passenger service standards, and GDS fare display. Governed by IATA Resolution 302 weight concept.' ;
    rdfs:domain ind:CabinClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baggagePiecesAllowed rdf:type rdf:Property ;
    rdfs:label 'Baggage Pieces Allowed' ;
    rdfs:comment 'Number of checked baggage pieces included in the standard allowance for this cabin class under the piece concept. Applicable for routes governed by IATA piece concept (primarily transatlantic and transpacific). Complements baggage_allowance_kg for weight-concept routes.' ;
    rdfs:domain ind:CabinClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cabinClassStatus rdf:type rdf:Property ;
    rdfs:label 'Cabin Class Status' ;
    rdfs:comment 'Current lifecycle status of the cabin class record. \'active\' indicates the cabin is currently offered and sellable; \'inactive\' indicates temporarily suspended; \'retired\' indicates permanently discontinued; \'pending\' indicates configured but not yet activated for sale.' ;
    rdfs:domain ind:CabinClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cabinCode rdf:type rdf:Property ;
    rdfs:label 'Cabin Code' ;
    rdfs:comment 'Airline-internal alphanumeric code uniquely identifying the cabin class within the carrier\'s Passenger Service System (PSS). Used in Amadeus Altéa Inventory for cabin-level availability and inventory management. May differ from the IATA designator when the airline operates sub-cabin variants.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cabinName rdf:type rdf:Property ;
    rdfs:label 'Cabin Name' ;
    rdfs:comment 'Commercial marketing name of the cabin class as presented to passengers and travel agents (e.g., \'First Class\', \'Business Class\', \'Premium Economy\', \'Economy\'). Used in passenger-facing communications, booking flows, and GDS displays.' ;
    rdfs:domain ind:CabinClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cabinType rdf:type rdf:Property ;
    rdfs:label 'Cabin Type' ;
    rdfs:comment 'Standardized classification of the cabin into one of the four IATA-recognized commercial cabin tiers: first, business, premium_economy, or economy. Drives revenue management segmentation, yield optimization in Sabre AirVision, and inventory bucket hierarchy.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carryOnAllowanceKg rdf:type rdf:Property ;
    rdfs:label 'Carry On Allowance Kg' ;
    rdfs:comment 'Maximum weight in kilograms permitted for carry-on baggage in the cabin for this cabin class. Used in ground handling operations, security screening coordination with TSA/EASA, and passenger service standards.' ;
    rdfs:domain ind:CabinClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:codeshareSellable rdf:type rdf:Property ;
    rdfs:label 'Codeshare Sellable' ;
    rdfs:comment 'Indicates whether this cabin class can be sold on codeshare flights operated by partner airlines. When true, inventory allocations for this cabin are made available to codeshare partners through interline agreements. Drives GDS availability display for codeshare itineraries.' ;
    rdfs:domain ind:CabinClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discontinuationDate rdf:type rdf:Property ;
    rdfs:label 'Discontinuation Date' ;
    rdfs:comment 'Date on which this cabin class definition is retired and no longer available for new bookings. Null for currently active cabin classes. Supports historical inventory analysis and regulatory record retention requirements.' ;
    rdfs:domain ind:CabinClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveDate rdf:type rdf:Property ;
    rdfs:label 'Effective Date' ;
    rdfs:comment 'Date from which this cabin class definition becomes commercially active and available for sale. Used for seasonal product changes, new aircraft type introductions, and cabin reconfiguration projects. Aligns with IATA Season scheduling conventions.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fareBasisPrefix rdf:type rdf:Property ;
    rdfs:label 'Fare Basis Prefix' ;
    rdfs:comment 'Standard alphabetic prefix used in fare basis codes for this cabin class (e.g., \'Y\' for Economy, \'C\' for Business, \'F\' for First). Aligns fare construction with IATA fare basis code conventions and drives revenue management fare class bucket assignment in Sabre AirVision.' ;
    rdfs:domain ind:CabinClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ffpAccrualMultiplier rdf:type rdf:Property ;
    rdfs:label 'Ffp Accrual Multiplier' ;
    rdfs:comment 'Multiplier applied to base miles flown to calculate Frequent Flyer Program (FFP) miles or points accrued for travel in this cabin class. For example, a value of 2.0 means passengers earn double miles. Feeds Oracle Loyalty Cloud FFP accrual engine.' ;
    rdfs:domain ind:CabinClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gdsDisplayCode rdf:type rdf:Property ;
    rdfs:label 'Gds Display Code' ;
    rdfs:comment 'Code used to represent this cabin class in Global Distribution System (GDS) availability displays (e.g., Amadeus, Sabre, Travelport). May differ from the internal cabin_code for legacy GDS compatibility. Ensures correct cabin identification in travel agent booking workflows.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iataCabinDesignator rdf:type rdf:Property ;
    rdfs:label 'Iata Cabin Designator' ;
    rdfs:comment 'Single-letter IATA standard cabin designator code identifying the commercial cabin class (e.g., F = First, C = Business, W = Premium Economy, Y = Economy). Used as the industry-standard booking class grouping code across Global Distribution Systems (GDS) and interline agreements.' ;
    rdfs:domain ind:CabinClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ifeType rdf:type rdf:Property ;
    rdfs:label 'Ife Type' ;
    rdfs:comment 'Type of In-Flight Entertainment (IFE) system available in this cabin class: \'seatback_screen\' = personal seatback display, \'overhead_screen\' = shared overhead monitors, \'personal_device\' = bring-your-own-device streaming, \'none\' = no IFE. Used in product definition and passenger experience standards.' ;
    rdfs:domain ind:CabinClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isLieFlat rdf:type rdf:Property ;
    rdfs:label 'Is Lie Flat' ;
    rdfs:comment 'Indicates whether the seats in this cabin class convert to a fully flat sleeping surface (180-degree recline). True for premium long-haul First and Business class products. Critical for product differentiation, revenue management premium pricing, and GDS display.' ;
    rdfs:domain ind:CabinClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loungeAccessEntitlement rdf:type rdf:Property ;
    rdfs:label 'Lounge Access Entitlement' ;
    rdfs:comment 'Level of airport lounge access included with this cabin class: \'none\' = no lounge access, \'home_carrier\' = access to the airline\'s own lounges only, \'partner\' = access to partner airline lounges, \'all_alliance\' = full alliance lounge network access. Drives ground handling instructions and passenger service delivery.' ;
    rdfs:domain ind:CabinClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxOverbookingPct rdf:type rdf:Property ;
    rdfs:label 'Max Overbooking Pct' ;
    rdfs:comment 'Maximum percentage above physical seat capacity that bookings may be accepted for this cabin class under the airline\'s overbooking policy. For example, 10.00 means up to 110% of seats may be sold. Null when overbooking_allowed is false. Governed by DOT regulations.' ;
    rdfs:domain ind:CabinClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mealServiceType rdf:type rdf:Property ;
    rdfs:label 'Meal Service Type' ;
    rdfs:comment 'Standard meal service type provided in this cabin class: \'full_meal\' = multi-course meal service, \'light_meal\' = single-course meal, \'snack\' = snack and beverage only, \'buy_on_board\' = no complimentary meal, \'none\' = no food service. Drives catering uplift planning and galley configuration.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overbookingAllowed rdf:type rdf:Property ;
    rdfs:label 'Overbooking Allowed' ;
    rdfs:comment 'Indicates whether overbooking is permitted for this cabin class. When true, the inventory system may accept bookings beyond physical seat capacity based on no-show forecasting models. Governed by DOT overbooking regulations and airline revenue management policy.' ;
    rdfs:domain ind:CabinClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:powerOutletType rdf:type rdf:Property ;
    rdfs:label 'Power Outlet Type' ;
    rdfs:comment 'Type of in-seat power outlet available in this cabin class: \'ac_110v\', \'ac_220v\', \'usb_a\', \'usb_c\', or \'none\'. Used in product specification, passenger communication, and aircraft configuration management in AMOS.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityBoarding rdf:type rdf:Property ;
    rdfs:label 'Priority Boarding' ;
    rdfs:comment 'Indicates whether passengers in this cabin class receive priority boarding privileges ahead of general boarding groups. Drives boarding sequence configuration in SITA Airport Management Platform and ground handling SOPs.' ;
    rdfs:domain ind:CabinClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorityCheckIn rdf:type rdf:Property ;
    rdfs:label 'Priority Check In' ;
    rdfs:comment 'Indicates whether passengers in this cabin class are entitled to dedicated priority check-in counters or lanes. Drives airport operations configuration in SITA Airport Management Platform and ground handling service level agreements.' ;
    rdfs:domain ind:CabinClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revenueClassHierarchy rdf:type rdf:Property ;
    rdfs:label 'Revenue Class Hierarchy' ;
    rdfs:comment 'Numeric rank defining the commercial hierarchy of this cabin class relative to others (1 = highest/First, 4 = lowest/Economy). Used by Sabre AirVision Revenue Management for yield optimization, upgrade logic, and inventory nesting rules. Lower number = higher revenue class.' ;
    rdfs:domain ind:CabinClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seatConfigurationCode rdf:type rdf:Property ;
    rdfs:label 'Seat Configuration Code' ;
    rdfs:comment 'Standard seat layout configuration code for this cabin class expressed as a row-abreast pattern (e.g., \'2-2-2\' for Business, \'3-3-3\' for Economy). Reflects the physical seat arrangement across the aircraft cross-section. Sourced from aircraft type configuration in AMOS.' ;
    rdfs:domain ind:CabinClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seatPitchInches rdf:type rdf:Property ;
    rdfs:label 'Seat Pitch Inches' ;
    rdfs:comment 'Distance in inches between a point on one seat and the same point on the seat directly in front, representing legroom standard for this cabin class. Key product differentiation metric used in marketing, regulatory DOT reporting, and passenger experience benchmarking.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:seatReclineInches rdf:type rdf:Property ;
    rdfs:label 'Seat Recline Inches' ;
    rdfs:comment 'Maximum recline distance in inches for seats in this cabin class. Distinguishes flat-bed (Business/First) from recliner (Premium Economy) and standard recline (Economy) product tiers. Used in product definition and passenger experience standards.' ;
    rdfs:domain ind:CabinClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:seatWidthInches rdf:type rdf:Property ;
    rdfs:label 'Seat Width Inches' ;
    rdfs:comment 'Width of the seat in inches for this cabin class, measured at the widest point of the seat cushion. Used in product specification, passenger comfort benchmarking, and marketing collateral.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceLevelDescription rdf:type rdf:Property ;
    rdfs:label 'Service Level Description' ;
    rdfs:comment 'Narrative description of the service standards, amenities, and passenger experience associated with this cabin class. Includes details such as meal service type, lounge access entitlement, priority boarding, and onboard entertainment offerings. Used for product definition and customer communication.' ;
    rdfs:domain ind:CabinClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemCode rdf:type rdf:Property ;
    rdfs:label 'Source System Code' ;
    rdfs:comment 'Code identifying the operational system of record from which this cabin class definition originates (e.g., \'ALTEA_INV\' for Amadeus Altéa Inventory, \'SABRE_RM\' for Sabre AirVision). Supports data lineage tracking in the Databricks Silver Layer lakehouse.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent modification to this cabin class record. Used for change tracking, data synchronization with downstream systems (GDS, Revenue Management), and audit compliance. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:upgradeEligible rdf:type rdf:Property ;
    rdfs:label 'Upgrade Eligible' ;
    rdfs:comment 'Indicates whether passengers booked in this cabin class are eligible to receive complimentary or paid upgrades to a higher cabin class. Drives upgrade logic in Amadeus Altéa Inventory and Oracle Loyalty Cloud FFP upgrade award processing.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:wifiAvailable rdf:type rdf:Property ;
    rdfs:label 'Wifi Available' ;
    rdfs:comment 'Indicates whether in-flight Wi-Fi connectivity is available in this cabin class. Drives ancillary service offerings, passenger communication, and product marketing. Complements IFE type for digital connectivity product definition.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fareClassBucketId rdf:type rdf:Property ;
    rdfs:label 'Fare Class Bucket Id' ;
    rdfs:comment 'Unique surrogate identifier for the fare class bucket record in the Silver layer. Primary key for this entity.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FareClassBucket .

ind:fareId rdf:type rdf:Property ;
    rdfs:label 'Fare Id' ;
    rdfs:comment 'Foreign key linking to revenue.fare. Business justification: Each fare class bucket controls availability for specific filed fares at that RBD level. fare_class_bucket has fare_basis_code (plain) but no fare_id FK. RM yield analysis and revenue dilution reporti' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fare .

ind:inventoryLegId rdf:type rdf:Property ;
    rdfs:label 'Inventory Leg Id' ;
    rdfs:comment 'Reference to the flight inventory leg record to which this fare class bucket belongs. Links the bucket to a specific flight-date-leg combination managed in Altéa Inventory.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InventoryLeg .

ind:scheduleSeasonId rdf:type rdf:Property ;
    rdfs:label 'Schedule Season Id' ;
    rdfs:comment 'Foreign key linking to route.schedule_season. Business justification: Fare class bucket configurations are season-specific; RM systems open new bucket sets each IATA season. Season-level bucket reporting and historical yield analysis require this FK to identify which se' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ScheduleSeason .

ind:advancePurchaseDays rdf:type rdf:Property ;
    rdfs:label 'Advance Purchase Days' ;
    rdfs:comment 'Minimum number of days before departure that a ticket must be purchased to qualify for fares in this booking class (e.g., 7, 14, 21). A value of 0 indicates no advance purchase requirement. Governs ticketing time limit enforcement in Altéa.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allotmentType rdf:type rdf:Property ;
    rdfs:label 'Allotment Type' ;
    rdfs:comment 'Classification of the inventory allocation type for this bucket: own (operating carrier direct sale), codeshare (partner airline marketing), interline (interline ticketing agreement), group (group booking block), charter (charter operator block), blocked (operationally blocked seats). Drives revenue accounting and settlement routing.' ;
    rdfs:domain ind:FareClassBucket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedUnits rdf:type rdf:Property ;
    rdfs:label 'Authorized Units' ;
    rdfs:comment 'Authorized capacity (AU) — the maximum number of seats the revenue management system has authorized for sale in this booking class bucket for the flight leg. Set by Sabre AirVision yield optimization and loaded into Altéa Inventory. Core inventory control parameter.' ;
    rdfs:domain ind:FareClassBucket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:availabilityCode rdf:type rdf:Property ;
    rdfs:label 'Availability Code' ;
    rdfs:comment 'IATA standard availability status code transmitted to GDS systems (e.g., A = available, L = waitlist, R = request, C = closed). Distinct from bucket_status in that this is the externally-broadcast GDS code per IATA PADIS standards, while bucket_status is the internal operational state.' ;
    rdfs:domain ind:FareClassBucket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookingLimit rdf:type rdf:Property ;
    rdfs:label 'Booking Limit' ;
    rdfs:comment 'Booking limit (BL) — the maximum cumulative number of bookings permitted across this bucket and all lower-yield buckets nested beneath it. Enforced in real time by Altéa Inventory to prevent overselling beyond the authorized level.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bucketRank rdf:type rdf:Property ;
    rdfs:label 'Bucket Rank' ;
    rdfs:comment 'Ordinal position of this RBD bucket within its cabin hierarchy, from highest-yield (rank 1) to lowest-yield. Used by Sabre AirVision and Altéa Inventory to determine availability cascade — a lower-ranked (higher-yield) bucket must be open before a higher-ranked (lower-yield) bucket can sell.' ;
    rdfs:domain ind:FareClassBucket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bucketStatus rdf:type rdf:Property ;
    rdfs:label 'Bucket Status' ;
    rdfs:comment 'Current availability status of the fare class bucket as broadcast to GDS and direct channels: open (seats available for sale), closed (no availability — bucket is shut by RM or capacity), waitlist (no confirmed seats but waitlist accepted), request_only (requires manual approval), suspended (temporarily removed from sale by operations).' ;
    rdfs:domain ind:FareClassBucket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Change Fee Amount' ;
    rdfs:comment 'Monetary penalty charged to the passenger for a voluntary itinerary change on a ticket issued under this booking class, expressed in the filing currency. A value of 0.00 indicates no change fee. Commercially sensitive pricing parameter.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:changeFeeCurrency rdf:type rdf:Property ;
    rdfs:label 'Change Fee Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the change fee amount is denominated (e.g., USD, EUR, GBP). Required for multi-currency fare filing and BSP/ARC settlement.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codesharePartnerCode rdf:type rdf:Property ;
    rdfs:label 'Codeshare Partner Code' ;
    rdfs:comment 'IATA two-letter airline designator of the codeshare marketing partner for whom this bucket allocation is reserved (e.g., LH, BA, AA). Null for own-carrier inventory. Used for interline settlement and codeshare capacity reporting.' ;
    rdfs:domain ind:FareClassBucket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentBookings rdf:type rdf:Property ;
    rdfs:label 'Current Bookings' ;
    rdfs:comment 'Number of confirmed bookings currently held against this fare class bucket. Updated in near-real-time from Altéa Inventory as PNRs are created, modified, or cancelled. Used to compute remaining availability.' ;
    rdfs:domain ind:FareClassBucket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:effectiveFrom rdf:type rdf:Property ;
    rdfs:label 'Effective From' ;
    rdfs:comment 'Calendar date from which this fare class bucket configuration becomes active for sale. Used for seasonal inventory planning and schedule-period bucket management in Altéa Inventory.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveUntil rdf:type rdf:Property ;
    rdfs:label 'Effective Until' ;
    rdfs:comment 'Calendar date after which this fare class bucket configuration is no longer active. Null indicates the bucket remains open-ended until explicitly closed. Supports seasonal and schedule-period inventory lifecycle management.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fareBasisCode rdf:type rdf:Property ;
    rdfs:label 'Fare Basis Code' ;
    rdfs:comment 'IATA fare basis code associated with the primary fare filed under this booking class bucket (e.g., YOWUS, BAPUS21). Links the inventory bucket to the fare tariff filed with ATPCO. Used for ticketing, interline proration, and BSP/ARC settlement.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fareFamilyCode rdf:type rdf:Property ;
    rdfs:label 'Fare Family Code' ;
    rdfs:comment 'Branded fare family or product bundle code associated with this booking class (e.g., BASIC, STANDARD, FLEX, BUSINESS_PLUS). Aligns the RBD bucket with the airline\'s branded fare product hierarchy for ancillary bundling and NDC offer construction.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupBlockSeats rdf:type rdf:Property ;
    rdfs:label 'Group Block Seats' ;
    rdfs:comment 'Number of seats within this bucket reserved as a group block allocation. A value of 0 indicates no group block. Group blocks are managed separately from individual seat availability and are subject to group contract terms.' ;
    rdfs:domain ind:FareClassBucket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isChangeable rdf:type rdf:Property ;
    rdfs:label 'Is Changeable' ;
    rdfs:comment 'Indicates whether the itinerary booked under this fare class may be voluntarily changed (True) or is a fixed non-changeable ticket (False). Relevant for IROP handling, voluntary rebooking, and ancillary change-fee revenue.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRefundable rdf:type rdf:Property ;
    rdfs:label 'Is Refundable' ;
    rdfs:comment 'Indicates whether tickets issued under this booking class are eligible for a full or partial refund (True) or are non-refundable (False). Drives customer service handling, involuntary rerouting compensation, and DOT consumer protection compliance.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastRmUpdateTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Rm Update Timestamp' ;
    rdfs:comment 'Timestamp of the most recent authorized unit or booking limit update pushed from Sabre AirVision to Altéa Inventory. Enables audit of RM optimization cycle frequency and latency monitoring between the two systems.' ;
    rdfs:domain ind:FareClassBucket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:maxStayDays rdf:type rdf:Property ;
    rdfs:label 'Max Stay Days' ;
    rdfs:comment 'Maximum number of days the passenger may remain at the destination before return travel must commence for fares in this booking class. A null value indicates no maximum stay restriction. Standard fare restriction filed with ATPCO.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minStayDays rdf:type rdf:Property ;
    rdfs:label 'Min Stay Days' ;
    rdfs:comment 'Minimum number of days the passenger must remain at the destination before return travel is permitted for fares in this booking class. A value of 0 indicates no minimum stay restriction. Standard fare restriction filed with ATPCO.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:protectionLevel rdf:type rdf:Property ;
    rdfs:label 'Protection Level' ;
    rdfs:comment 'Number of seats protected (reserved) for higher-yield demand in this bucket, as computed by the EMSR (Expected Marginal Seat Revenue) optimization in Sabre AirVision. Prevents lower-yield bookings from displacing higher-yield passengers. Core RM optimization output.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rbdCode rdf:type rdf:Property ;
    rdfs:label 'Rbd Code' ;
    rdfs:comment 'Single uppercase IATA letter identifying the booking class (e.g., Y, B, M, Q, V, H, K, L, S, N, O, G). The RBD is the atomic unit of inventory control in Altéa Inventory and the direct input to Sabre AirVision yield optimization. Governed by IATA Resolution 728.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Created Timestamp' ;
    rdfs:comment 'Timestamp when this fare class bucket record was first created in the Silver layer data product. Supports data lineage, audit trail, and SLA compliance tracking per enterprise data governance standards.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:recordUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent update to this fare class bucket record in the Silver layer. Used for incremental load detection, change data capture, and audit compliance.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:yieldClass rdf:type rdf:Property ;
    rdfs:label 'Yield Class' ;
    rdfs:comment 'Revenue management yield classification assigned to this bucket by Sabre AirVision, grouping RBDs into broad yield tiers for reporting and optimization. Commercially sensitive as it reveals pricing strategy segmentation.' ;
    rdfs:domain ind:FareClassBucket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seatAvailabilityId rdf:type rdf:Property ;
    rdfs:label 'Seat Availability Id' ;
    rdfs:comment 'Unique surrogate identifier for each seat availability snapshot record in the inventory system. Primary key for this data product.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SeatAvailability .

ind:flightLegId rdf:type rdf:Property ;
    rdfs:label 'Flight Leg Id' ;
    rdfs:comment 'Reference to the operating flight record for which seat availability is being tracked. Links to the flight master entity.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FlightLeg .

ind:availabilityStatus rdf:type rdf:Property ;
    rdfs:label 'Availability Status' ;
    rdfs:comment 'Current booking status of the fare class bucket as broadcast to distribution channels. Open = seats available for sale; Closed = bucket closed by revenue management; Waitlist = waitlist accepted; Request = booking requires airline confirmation; Sold Out = no seats remain. Core inventory control signal consumed by GDS, NDC, and direct channels.' ;
    rdfs:domain ind:SeatAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availabilityVersion rdf:type rdf:Property ;
    rdfs:label 'Availability Version' ;
    rdfs:comment 'Monotonically increasing version counter for this flight-date-fare-class availability record. Enables ordering of multiple snapshots for the same key and supports optimistic concurrency control in the Silver layer.' ;
    rdfs:domain ind:SeatAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bookingClassAvailabilityMap rdf:type rdf:Property ;
    rdfs:label 'Booking Class Availability Map' ;
    rdfs:comment 'Availability status string (AVS) representing the full cabin availability across all booking classes at the time of snapshot, as broadcast in GDS availability responses (e.g., \'Y9B9M9Q4V0\'). Enables reconstruction of the complete availability display seen by travel agents.' ;
    rdfs:domain ind:SeatAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:broadcastTimestamp rdf:type rdf:Property ;
    rdfs:label 'Broadcast Timestamp' ;
    rdfs:comment 'Date and time when this availability update was broadcast to GDS and distribution channels. Distinct from snapshot_timestamp (capture time) and last_updated_timestamp (system update time). Used for GDS broadcast latency measurement and SLA verification.' ;
    rdfs:domain ind:SeatAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:codeshareAllotment rdf:type rdf:Property ;
    rdfs:label 'Codeshare Allotment' ;
    rdfs:comment 'Number of seats allocated to the codeshare marketing partner within this fare class bucket. Null when codeshare_indicator is false. Used to track partner inventory consumption against agreed allotment caps.' ;
    rdfs:domain ind:SeatAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:daysToDeparture rdf:type rdf:Property ;
    rdfs:label 'Days To Departure' ;
    rdfs:comment 'Number of calendar days between the snapshot_timestamp date and the flight_date. Critical dimension for revenue management booking curve analysis and yield optimization model training.' ;
    rdfs:domain ind:SeatAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:distributionChannel rdf:type rdf:Property ;
    rdfs:label 'Distribution Channel' ;
    rdfs:comment 'Channel context for which this availability snapshot was generated or broadcast. GDS = Global Distribution System (Amadeus, Sabre, Travelport); NDC = IATA New Distribution Capability; Direct = airline.com or mobile app; API = B2B direct connect; Interline = partner carrier ticketing; Codeshare = shared flight operation partner.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastDemand rdf:type rdf:Property ;
    rdfs:label 'Forecast Demand' ;
    rdfs:comment 'Revenue management system\'s demand forecast for this fare class bucket at the time of the snapshot, expressed as expected number of bookings. Captured alongside actual availability for model accuracy tracking and yield optimization.' ;
    rdfs:domain ind:SeatAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gdsProviderCode rdf:type rdf:Property ;
    rdfs:label 'Gds Provider Code' ;
    rdfs:comment 'IATA-assigned GDS provider code identifying the specific GDS to which this availability was broadcast: 1A = Amadeus, 1S = Sabre, 1G = Galileo (Travelport), 1P = Worldspan (Travelport). Null when distribution_channel is not GDS.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCurrentSnapshot rdf:type rdf:Property ;
    rdfs:label 'Is Current Snapshot' ;
    rdfs:comment 'Flag indicating whether this record represents the most recent (current) availability snapshot for the flight-date-fare-class combination. Enables efficient point-in-time queries without full history scan. Set to false when superseded by a newer snapshot.' ;
    rdfs:domain ind:SeatAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isInterlineEligible rdf:type rdf:Property ;
    rdfs:label 'Is Interline Eligible' ;
    rdfs:comment 'Flag indicating whether this fare class bucket is open for interline ticketing by partner carriers under bilateral interline agreements. Governs availability visibility in interline booking flows.' ;
    rdfs:domain ind:SeatAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketingCarrierCode rdf:type rdf:Property ;
    rdfs:label 'Marketing Carrier Code' ;
    rdfs:comment 'Two-character IATA airline designator of the carrier under whose flight number the seat is sold to passengers. On non-codeshare flights this equals the operating carrier code.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nestingLevel rdf:type rdf:Property ;
    rdfs:label 'Nesting Level' ;
    rdfs:comment 'Hierarchical nesting position of this fare class bucket within the cabin\'s virtual nesting structure used by the revenue management system. Lower values indicate higher-yield buckets. Governs availability inheritance between fare classes.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operatingCarrierCode rdf:type rdf:Property ;
    rdfs:label 'Operating Carrier Code' ;
    rdfs:comment 'Two-character IATA airline designator of the carrier physically operating the flight. Differs from the marketing carrier on codeshare flights. Required for interline and codeshare inventory allocation tracking.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:physicalCapacity rdf:type rdf:Property ;
    rdfs:label 'Physical Capacity' ;
    rdfs:comment 'Total number of physical seats configured in the cabin for this flight-date, before overbooking authorization. Provides the denominator for cabin-level load factor calculations and capacity planning.' ;
    rdfs:domain ind:SeatAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rmDecisionCode rdf:type rdf:Property ;
    rdfs:label 'Rm Decision Code' ;
    rdfs:comment 'Code identifying the revenue management optimization decision or rule that triggered the current availability status or booking limit for this fare class bucket (e.g., FCST_CLOSE, MANUAL_OVERRIDE, AUTO_OPEN). Supports RM model audit and performance attribution.' ;
    rdfs:domain ind:SeatAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seatsAuthorized rdf:type rdf:Property ;
    rdfs:label 'Seats Authorized' ;
    rdfs:comment 'Maximum number of bookings authorized for this fare class bucket as set by the revenue management system. Represents the booking limit or allotment cap controlling inventory exposure for this RBD.' ;
    rdfs:domain ind:SeatAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seatsHeld rdf:type rdf:Property ;
    rdfs:label 'Seats Held' ;
    rdfs:comment 'Number of seats temporarily held under option, group block, or tour operator allotment that are not yet confirmed bookings but reduce net availability. Distinct from seats_sold as these may be released.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:snapshotTimestamp rdf:type rdf:Property ;
    rdfs:label 'Snapshot Timestamp' ;
    rdfs:comment 'Exact date and time (ISO 8601 with timezone offset) at which this availability record was captured or broadcast. The principal business event timestamp for this EVENT_LOG record. Used for GDS broadcast verification and revenue management time-series analysis.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:snapshotTrigger rdf:type rdf:Property ;
    rdfs:label 'Snapshot Trigger' ;
    rdfs:comment 'Business event or system action that caused this availability snapshot to be generated and broadcast. Enables audit of why availability changed at a given point in time. [ENUM-REF-CANDIDATE: Booking|Cancellation|Schedule Change|RM Override|GDS Poll|NDC Request|Overbooking Adjustment|Batch Interval — promote to reference product]' ;
    rdfs:domain ind:SeatAvailability ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overbookingControlId rdf:type rdf:Property ;
    rdfs:label 'Overbooking Control Id' ;
    rdfs:comment 'Unique surrogate identifier for the overbooking control record. Primary key for this entity.' ;
    rdfs:domain ind:OverbookingControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:yieldParameterId rdf:type rdf:Property ;
    rdfs:label 'Yield Parameter Id' ;
    rdfs:comment 'Foreign key linking to revenue.yield_parameter. Business justification: Overbooking authorization rates are derived from yield parameters (no_show_rate, spoilage_tolerance, overbooking_authorization_rate). The RM system applies yield_parameter settings when computing over' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:YieldParameter .

ind:authorizedOverbookingPct rdf:type rdf:Property ;
    rdfs:label 'Authorized Overbooking Pct' ;
    rdfs:comment 'The approved percentage above physical cabin seat capacity that the revenue management system is authorized to sell. For example, a value of 10.00 means up to 10% more seats than physically available may be booked. Derived from historical no-show rates and spoilage risk models in Sabre AirVision Revenue Management.' ;
    rdfs:domain ind:OverbookingControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:avgFareValueUsd rdf:type rdf:Property ;
    rdfs:label 'Avg Fare Value Usd' ;
    rdfs:comment 'The average fare value in USD for bookings in this cabin on this flight, used as an input to the overbooking revenue optimization model. Enables the model to weigh the revenue benefit of additional bookings against the cost of denied boarding compensation.' ;
    rdfs:domain ind:OverbookingControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cancellationRateInput rdf:type rdf:Property ;
    rdfs:label 'Cancellation Rate Input' ;
    rdfs:comment 'Historical cancellation rate (expressed as a decimal proportion) for this route, cabin, and season used as an actuarial input alongside the no-show rate in the overbooking model. Distinct from no-show rate as it captures pre-departure cancellations.' ;
    rdfs:domain ind:OverbookingControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:codeshareInventoryFlag rdf:type rdf:Property ;
    rdfs:label 'Codeshare Inventory Flag' ;
    rdfs:comment 'Indicates whether this overbooking control applies to a codeshare inventory allocation rather than the operating carrier\'s own inventory. Codeshare overbooking controls may differ from mainline controls due to interline agreements and partner airline seat block commitments.' ;
    rdfs:domain ind:OverbookingControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:controlStatus rdf:type rdf:Property ;
    rdfs:label 'Control Status' ;
    rdfs:comment 'Current lifecycle status of this overbooking control record. Active indicates the parameters are live and being applied by Altéa Inventory booking limit calculations. Suspended means overbooking is temporarily halted for this cabin. Overridden indicates a manual revenue management analyst override is in effect.' ;
    rdfs:domain ind:OverbookingControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentBookingCount rdf:type rdf:Property ;
    rdfs:label 'Current Booking Count' ;
    rdfs:comment 'The real-time count of confirmed bookings (PNRs) held against this cabin at the time of the last availability snapshot. Used to compute remaining availability and monitor oversale exposure.' ;
    rdfs:domain ind:OverbookingControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dayOfWeekPattern rdf:type rdf:Property ;
    rdfs:label 'Day Of Week Pattern' ;
    rdfs:comment 'Bitmask or string pattern (e.g., \'1234567\' where each digit represents Mon–Sun) indicating which days of the week this overbooking control applies to. Allows differentiated overbooking levels for weekday versus weekend departures.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deniedBoardingRiskThreshold rdf:type rdf:Property ;
    rdfs:label 'Denied Boarding Risk Threshold' ;
    rdfs:comment 'The maximum acceptable probability (expressed as a decimal, e.g., 0.0200 = 2%) that at least one passenger will be involuntarily denied boarding due to oversale. Balances revenue optimization against regulatory denied boarding compensation exposure under DOT 14 CFR Part 250 and IATA Resolution 830d.' ;
    rdfs:domain ind:OverbookingControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:goShowRateInput rdf:type rdf:Property ;
    rdfs:label 'Go Show Rate Input' ;
    rdfs:comment 'Historical rate of passengers who arrive at the gate without a prior reservation (go-shows) for this route and cabin, expressed as a decimal proportion. Used in the overbooking model to account for demand that materialises at departure.' ;
    rdfs:domain ind:OverbookingControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:groupBookingSeatsReserved rdf:type rdf:Property ;
    rdfs:label 'Group Booking Seats Reserved' ;
    rdfs:comment 'Number of seats within the cabin that are reserved for confirmed group bookings and excluded from the overbooking calculation. Group bookings typically have lower no-show rates and are treated separately in the overbooking model.' ;
    rdfs:domain ind:OverbookingControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:historicalNoShowRate rdf:type rdf:Property ;
    rdfs:label 'Historical No Show Rate' ;
    rdfs:comment 'The input no-show rate (expressed as a decimal proportion, e.g., 0.0850 = 8.50%) derived from historical passenger behaviour for this route, cabin, and season. Used as the primary actuarial input to the overbooking authorization model in Sabre AirVision.' ;
    rdfs:domain ind:OverbookingControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:idbCompensationExposureUsd rdf:type rdf:Property ;
    rdfs:label 'Idb Compensation Exposure Usd' ;
    rdfs:comment 'Estimated maximum financial exposure in USD for involuntary denied boarding (IDB) compensation if all oversold seats result in IDB events. Calculated based on max_oversale_seats and applicable DOT/IATA compensation rates. Used in revenue management risk assessment.' ;
    rdfs:domain ind:OverbookingControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastReviewedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Reviewed Timestamp' ;
    rdfs:comment 'The date and time when a revenue management analyst last reviewed and confirmed or adjusted this overbooking control record. Supports governance workflows requiring periodic review of overbooking authorizations.' ;
    rdfs:domain ind:OverbookingControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:loadFactorForecast rdf:type rdf:Property ;
    rdfs:label 'Load Factor Forecast' ;
    rdfs:comment 'The forecasted load factor (proportion of physical seats expected to be occupied at departure, expressed as a decimal e.g., 0.9200 = 92%) for this cabin on this flight. Input from Sabre AirVision demand forecasting, used to calibrate the overbooking level.' ;
    rdfs:domain ind:OverbookingControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxOversaleSeats rdf:type rdf:Property ;
    rdfs:label 'Max Oversale Seats' ;
    rdfs:comment 'The absolute maximum number of seats above physical cabin capacity that may be sold, regardless of the authorized overbooking percentage. Acts as a hard cap to limit denied boarding exposure. Set by revenue management analysts in Altéa Inventory.' ;
    rdfs:domain ind:OverbookingControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Review Date' ;
    rdfs:comment 'The scheduled date by which this overbooking control record must be reviewed by a revenue management analyst. Drives workflow queuing in Sabre AirVision to ensure timely recalibration before departure.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:notes rdf:type rdf:Property ;
    rdfs:label 'Notes' ;
    rdfs:comment 'Free-text field for additional operational notes or context related to this overbooking control record, such as special event considerations, IROP recovery instructions, or coordination notes with ground handling teams.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overbookingModelVersion rdf:type rdf:Property ;
    rdfs:label 'Overbooking Model Version' ;
    rdfs:comment 'Version identifier of the statistical overbooking model used to compute the authorized overbooking percentage for this record. Enables reproducibility, model governance, and comparison of model performance across versions in Sabre AirVision.' ;
    rdfs:domain ind:OverbookingControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideReason rdf:type rdf:Property ;
    rdfs:label 'Override Reason' ;
    rdfs:comment 'Free-text justification provided by the revenue management analyst when rm_system_override_flag is True. Documents the business rationale for departing from the system-recommended overbooking level (e.g., special event, group booking, IROP recovery).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryMarketCode rdf:type rdf:Property ;
    rdfs:label 'Regulatory Market Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code or regulatory jurisdiction code (e.g., USA, EU) identifying the regulatory regime governing denied boarding compensation obligations for this flight. Determines applicable DOT, EASA EC 261/2004, or national civil aviation authority rules.' ;
    rdfs:domain ind:OverbookingControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rmSystemOverrideFlag rdf:type rdf:Property ;
    rdfs:label 'Rm System Override Flag' ;
    rdfs:comment 'Indicates whether a revenue management analyst has manually overridden the system-calculated overbooking parameters. When True, the authorized_overbooking_pct and max_oversale_seats reflect analyst-entered values rather than the automated Sabre AirVision model output.' ;
    rdfs:domain ind:OverbookingControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:spoilageRiskThreshold rdf:type rdf:Property ;
    rdfs:label 'Spoilage Risk Threshold' ;
    rdfs:comment 'The maximum acceptable probability (expressed as a decimal, e.g., 0.0500 = 5%) that the flight departs with empty seats due to under-booking. Revenue management uses this threshold to calibrate the overbooking level against the risk of seat spoilage versus denied boarding.' ;
    rdfs:domain ind:OverbookingControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:upgradeBufferSeats rdf:type rdf:Property ;
    rdfs:label 'Upgrade Buffer Seats' ;
    rdfs:comment 'Number of seats held back from the overbooking pool to accommodate anticipated operational upgrades (e.g., elite frequent flyer upgrades, compensation upgrades). Reduces the effective booking limit to preserve upgrade capacity.' ;
    rdfs:domain ind:OverbookingControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:voluntaryDeniedBoardingTarget rdf:type rdf:Property ;
    rdfs:label 'Voluntary Denied Boarding Target' ;
    rdfs:comment 'The target number of passengers expected to accept voluntary denied boarding (VDB) compensation offers at the gate in the event of an oversale. Used in the overbooking model to offset the involuntary denied boarding risk.' ;
    rdfs:domain ind:OverbookingControl ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:codeshareAllocationId rdf:type rdf:Property ;
    rdfs:label 'Codeshare Allocation Id' ;
    rdfs:comment 'Unique surrogate identifier for the codeshare or interline inventory allocation record within the Amadeus Altéa Inventory system. Primary key for this entity.' ;
    rdfs:domain ind:CodeshareAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:codeshareAgreementId rdf:type rdf:Property ;
    rdfs:label 'Codeshare Agreement Id' ;
    rdfs:comment 'Foreign key linking to route.codeshare_agreement. Business justification: Codeshare seat allocations are governed by a codeshare agreement. Agreement compliance audits, revenue-share settlement, and regulatory approval tracking require linking each allocation to its governi' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CodeshareAgreement .

ind:interlineBillingId rdf:type rdf:Property ;
    rdfs:label 'Interline Billing Id' ;
    rdfs:comment 'Foreign key linking to finance.interline_billing. Business justification: Codeshare seat allocations with revenue_share_percentage and prorate_agreement_code directly generate interline billing settlements between operating and marketing carriers. IATA interline settlement ' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InterlineBilling .

ind:operatingCarrierId rdf:type rdf:Property ;
    rdfs:label 'Operating Carrier Id' ;
    rdfs:comment 'Reference to the airline that physically operates the flight on which this inventory allocation is granted. The operating carrier owns the aircraft and crew.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:operatingFlightNumberId rdf:type rdf:Property ;
    rdfs:label 'Operating Flight Number Id' ;
    rdfs:comment 'Foreign key linking to route.flight_number. Business justification: Codeshare inventory control requires linking each allocation to the operating carrier\'s authoritative flight number for GDS availability broadcasting and schedule-inventory reconciliation. operating_f' ;
    rdfs:domain ind:CodeshareAllocation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FlightNumber .

ind:partnershipId rdf:type rdf:Property ;
    rdfs:label 'Partnership Id' ;
    rdfs:comment 'Foreign key linking to route.partnership. Business justification: Codeshare allocations execute the commercial terms of a partnership agreement. Partnership-level inventory reporting, prorate settlement, and block-space compliance require linking allocations directl' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Partnership .

ind:allocationStatus rdf:type rdf:Property ;
    rdfs:label 'Allocation Status' ;
    rdfs:comment 'Current lifecycle state of the codeshare allocation record within Altéa Inventory. \'active\' means the allocation is live and available for booking; \'suspended\' means temporarily halted; \'cancelled\' means permanently withdrawn; \'pending\' means awaiting activation; \'expired\' means the flight date has passed.' ;
    rdfs:domain ind:CodeshareAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationType rdf:type rdf:Property ;
    rdfs:label 'Allocation Type' ;
    rdfs:comment 'Defines the inventory control mechanism governing this codeshare allocation. \'block_space\' means a fixed seat block is ring-fenced for the marketing carrier regardless of overall availability; \'free_flow\' means the marketing carrier draws from the operating carrier\'s shared availability pool without a hard block; \'hybrid\' combines a guaranteed minimum block with free-flow access above it.' ;
    rdfs:domain ind:CodeshareAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alteaAllocationReference rdf:type rdf:Property ;
    rdfs:label 'Altea Allocation Reference' ;
    rdfs:comment 'Native allocation reference identifier assigned by the Amadeus Altéa Inventory system for this codeshare block. Used for reconciliation and traceability back to the operational PSS source record.' ;
    rdfs:domain ind:CodeshareAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizedSeatCount rdf:type rdf:Property ;
    rdfs:label 'Authorized Seat Count' ;
    rdfs:comment 'Maximum number of seats the marketing carrier is authorised to sell on this flight-date and cabin under this allocation. For block-space agreements this is the contracted block size; for free-flow it represents the cap agreed in the bilateral.' ;
    rdfs:domain ind:CodeshareAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bilateralAgreementReference rdf:type rdf:Property ;
    rdfs:label 'Bilateral Agreement Reference' ;
    rdfs:comment 'Human-readable external reference number or code of the bilateral codeshare/interline agreement (e.g., contract number from the commercial agreement). Stored for operational traceability; the full agreement detail is held in the bilateral_agreement master.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daysOfOperation rdf:type rdf:Property ;
    rdfs:label 'Days Of Operation' ;
    rdfs:comment 'IATA-standard days-of-week string indicating on which days of the week this allocation applies within the effective date range (e.g., \'1234567\' = daily, \'135\' = Mon/Wed/Fri). Encoded as ISO weekday numbers 1=Monday through 7=Sunday.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationIataCode rdf:type rdf:Property ;
    rdfs:label 'Destination Iata Code' ;
    rdfs:comment 'Three-letter IATA airport code for the arrival airport of the operating flight segment covered by this allocation (e.g., CDG, SIN, ORD).' ;
    rdfs:domain ind:CodeshareAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flightDate rdf:type rdf:Property ;
    rdfs:label 'Flight Date' ;
    rdfs:comment 'Scheduled departure date of the operating flight for which this codeshare allocation applies. Combined with the operating flight number, uniquely identifies the flight-date instance.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:gdsAvailabilityIndicator rdf:type rdf:Property ;
    rdfs:label 'Gds Availability Indicator' ;
    rdfs:comment 'Flag indicating whether the marketing carrier\'s availability under this allocation is published and visible in Global Distribution Systems (GDS) such as Amadeus, Sabre, and Travelport. When False, the allocation is restricted to direct or NDC channels only.' ;
    rdfs:domain ind:CodeshareAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interlineIndicator rdf:type rdf:Property ;
    rdfs:label 'Interline Indicator' ;
    rdfs:comment 'Flag indicating whether this allocation is governed by an interline ticketing agreement (True) rather than a pure codeshare arrangement (False). Interline allocations follow IATA BSP/ARC settlement rules.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Modified Timestamp' ;
    rdfs:comment 'Timestamp of the most recent modification to this codeshare allocation record, such as a change to seat counts, thresholds, or status. Supports audit trail and change tracking in the Silver layer.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastSeatDate rdf:type rdf:Property ;
    rdfs:label 'Last Seat Date' ;
    rdfs:comment 'Latest date on which the marketing carrier may sell the last available seat under this allocation before the booking window closes. May differ from the flight date due to advance purchase restrictions in the bilateral.' ;
    rdfs:domain ind:CodeshareAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:marketingFlightNumber rdf:type rdf:Property ;
    rdfs:label 'Marketing Flight Number' ;
    rdfs:comment 'IATA-format flight designator under which the marketing carrier sells the codeshare seats (e.g., BA5678). This is the flight number visible to passengers booking through the marketing carrier.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumSeatThreshold rdf:type rdf:Property ;
    rdfs:label 'Maximum Seat Threshold' ;
    rdfs:comment 'Hard upper limit on the number of seats the marketing carrier may sell on this flight-date and cabin, enforced by Altéa Inventory to prevent over-allocation beyond the bilateral agreement cap.' ;
    rdfs:domain ind:CodeshareAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumSeatThreshold rdf:type rdf:Property ;
    rdfs:label 'Minimum Seat Threshold' ;
    rdfs:comment 'Minimum number of seats guaranteed to the marketing carrier that the operating carrier must hold available regardless of overall flight demand. Relevant for block-space and hybrid allocation types. Null for pure free-flow allocations.' ;
    rdfs:domain ind:CodeshareAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originIataCode rdf:type rdf:Property ;
    rdfs:label 'Origin Iata Code' ;
    rdfs:comment 'Three-letter IATA airport code for the departure airport of the operating flight segment covered by this allocation (e.g., LHR, JFK, DXB).' ;
    rdfs:domain ind:CodeshareAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prorateAgreementCode rdf:type rdf:Property ;
    rdfs:label 'Prorate Agreement Code' ;
    rdfs:comment 'Code referencing the revenue proration agreement between the operating and marketing carriers that governs how ticket revenue is split for seats sold under this codeshare allocation. Aligns with IATA BSP prorate rules.' ;
    rdfs:domain ind:CodeshareAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseDate rdf:type rdf:Property ;
    rdfs:label 'Release Date' ;
    rdfs:comment 'Date on which any unsold seats in a block-space allocation are automatically released back to the operating carrier\'s general inventory pool for unrestricted sale. Null for free-flow allocations where no block is held.' ;
    rdfs:domain ind:CodeshareAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:releaseDaysPrior rdf:type rdf:Property ;
    rdfs:label 'Release Days Prior' ;
    rdfs:comment 'Number of days before scheduled departure at which unsold block-space seats are automatically released to the operating carrier\'s open inventory. Derived from the bilateral agreement terms and used to compute release_date.' ;
    rdfs:domain ind:CodeshareAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:remarks rdf:type rdf:Property ;
    rdfs:label 'Remarks' ;
    rdfs:comment 'Free-text operational notes or remarks associated with this codeshare allocation, such as special handling instructions, commercial exceptions, or temporary override justifications entered by inventory controllers.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueSharePercentage rdf:type rdf:Property ;
    rdfs:label 'Revenue Share Percentage' ;
    rdfs:comment 'Percentage of ticket revenue attributable to the operating carrier for seats sold by the marketing carrier under this allocation, as stipulated in the bilateral prorate agreement. Commercially sensitive.' ;
    rdfs:domain ind:CodeshareAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:aircraftTypeId rdf:type rdf:Property ;
    rdfs:label 'Aircraft Type Id' ;
    rdfs:comment 'Foreign key linking to fleet.aircraft_type. Business justification: Revenue management systems configure fare class bucket authorization limits based on aircraft type\'s physical capacity, cabin configuration, and range. Inventory leg planning requires structured refer' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AircraftType .

ind:blockTimeStandardId rdf:type rdf:Property ;
    rdfs:label 'Block Time Standard Id' ;
    rdfs:comment 'Foreign key linking to route.block_time_standard. Business justification: Block time variance analysis and crew duty time compliance require linking each inventory leg to its applicable block time standard. Aviation operations teams use this to flag legs where scheduled_blo' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BlockTimeStandard .

ind:departureTerminalFacilityId rdf:type rdf:Property ;
    rdfs:label 'Departure Terminal Facility Id' ;
    rdfs:comment 'Foreign key linking to airport.terminal_facility. Business justification: Terminal facility planners use inventory leg booked counts to forecast check-in counter demand, lounge occupancy, and gate capacity per terminal. Linking departure terminal normalizes the denormalized' ;
    rdfs:domain ind:InventoryLeg ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TerminalFacility .

ind:maintenanceReleaseId rdf:type rdf:Property ;
    rdfs:label 'Maintenance Release Id' ;
    rdfs:comment 'Foreign key linking to maintenance.release. Business justification: Regulatory requirement (EASA Part-M / FAA 14 CFR 43): no flight leg may depart without a valid Certificate of Release to Service. Linking inventory_leg to maintenance.release enables dispatch systems ' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Release .

ind:arrivalTerminal rdf:type rdf:Property ;
    rdfs:label 'Arrival Terminal' ;
    rdfs:comment 'Terminal identifier at the destination airport where this leg arrives (e.g., \'T2\', \'T4\', \'C\'). Used for connecting passenger MCT validation and ground handling coordination.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availabilitySnapshotDatetime rdf:type rdf:Property ;
    rdfs:label 'Availability Snapshot Datetime' ;
    rdfs:comment 'UTC timestamp of the most recent real-time availability snapshot for this leg as published to GDS and direct booking channels. Supports audit of availability state at a point in time and feeds through-availability calculations.' ;
    rdfs:domain ind:InventoryLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:bookedCount rdf:type rdf:Property ;
    rdfs:label 'Booked Count' ;
    rdfs:comment 'Current total number of confirmed bookings (Pax) held against this leg across all fare classes and cabins. Updated in real time by the Amadeus Altéa PSS as reservations are created, modified, or cancelled.' ;
    rdfs:domain ind:InventoryLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:codeshareBlockedCount rdf:type rdf:Property ;
    rdfs:label 'Codeshare Blocked Count' ;
    rdfs:comment 'Number of seats allocated to codeshare partner airlines on this operating leg. Represents inventory carved out for marketing carrier partners under codeshare agreements, reducing net availability for the operating carrier.' ;
    rdfs:domain ind:InventoryLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:departureSlotTime rdf:type rdf:Property ;
    rdfs:label 'Departure Slot Time' ;
    rdfs:comment 'Allocated airport departure slot time (UTC) assigned by the slot coordinator for this leg at the origin airport. May differ from scheduled departure time. Null for airports without slot coordination (non-Level 2/3 airports).' ;
    rdfs:domain ind:InventoryLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:groupBlockedCount rdf:type rdf:Property ;
    rdfs:label 'Group Blocked Count' ;
    rdfs:comment 'Number of seats currently blocked and held for group bookings on this leg. Reduces the net availability exposed to individual GDS and direct channel requests.' ;
    rdfs:domain ind:InventoryLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inventoryCloseDatetime rdf:type rdf:Property ;
    rdfs:label 'Inventory Close Datetime' ;
    rdfs:comment 'Date and time (UTC) when inventory for this leg was closed to new bookings. Typically triggered at departure or by revenue management closure rules. Null if inventory is still open.' ;
    rdfs:domain ind:InventoryLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:inventoryOpenDatetime rdf:type rdf:Property ;
    rdfs:label 'Inventory Open Datetime' ;
    rdfs:comment 'Date and time (UTC) when inventory for this leg was first opened for sale across GDS and direct channels. Marks the start of the revenue management availability window.' ;
    rdfs:domain ind:InventoryLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:iropIndicator rdf:type rdf:Property ;
    rdfs:label 'Irop Indicator' ;
    rdfs:comment 'Flag indicating whether this leg is currently subject to an Irregular Operations (IROP) event such as a delay, cancellation, diversion, or equipment swap. True = IROP condition active. Triggers passenger re-accommodation workflows in Amadeus Altéa.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legStatus rdf:type rdf:Property ;
    rdfs:label 'Leg Status' ;
    rdfs:comment 'Current operational and inventory lifecycle status of this leg. \'active\' — open for sale; \'cancelled\' — flight cancelled, inventory closed; \'diverted\' — flight diverted to alternate airport; \'suspended\' — temporarily removed from sale; \'closed\' — inventory closed post-departure.' ;
    rdfs:domain ind:InventoryLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadFactor rdf:type rdf:Property ;
    rdfs:label 'Load Factor' ;
    rdfs:comment 'Current load factor for this leg expressed as a percentage: (booked_count / total_seat_capacity) × 100. Key revenue management KPI representing the percentage of available seats filled. Updated in real time as bookings change.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatingDayOfWeek rdf:type rdf:Property ;
    rdfs:label 'Operating Day Of Week' ;
    rdfs:comment 'IATA day-of-week code on which this leg operates, where 1=Monday through 7=Sunday per IATA SSIM convention. Used for schedule frequency analysis and inventory pattern matching. [ENUM-REF-CANDIDATE: 1|2|3|4|5|6|7 — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:InventoryLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledArrivalDatetime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Arrival Datetime' ;
    rdfs:comment 'Scheduled gate arrival date and time for this leg in UTC (ISO 8601 format). Represents the planned OOOI \'In\' time used for connection logic, MCT calculations, and inventory closure triggers.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledBlockHours rdf:type rdf:Property ;
    rdfs:label 'Scheduled Block Hours' ;
    rdfs:comment 'Planned block time for this leg in decimal hours, measured from scheduled gate departure (Out) to scheduled gate arrival (In). Block hours are the primary unit for aircraft utilization, crew duty time, and cost accounting (CASK calculations).' ;
    rdfs:domain ind:InventoryLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduledDepartureDatetime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Departure Datetime' ;
    rdfs:comment 'Scheduled gate departure date and time for this leg in UTC (ISO 8601 format). Represents the planned OOOI \'Out\' time used for inventory availability windows, GDS display, and OTP measurement.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledFlightDistanceKm rdf:type rdf:Property ;
    rdfs:label 'Scheduled Flight Distance Km' ;
    rdfs:comment 'Great-circle distance of this leg in kilometres between origin and destination airports. Used in RPK (Revenue Passenger Kilometre) and ASK (Available Seat Kilometre) calculations, yield analysis, and CORSIA carbon emissions reporting.' ;
    rdfs:domain ind:InventoryLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Sequence Number' ;
    rdfs:comment 'Ordinal position of this physical leg within the parent flight inventory record (e.g., 1 for the first leg, 2 for the second leg of a multi-leg service). Used to reconstruct itinerary order and support through-availability logic.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceTypeCode rdf:type rdf:Property ;
    rdfs:label 'Service Type Code' ;
    rdfs:comment 'IATA single-character service type code indicating the nature of the flight service (e.g., \'J\' for scheduled passenger, \'F\' for scheduled freight, \'C\' for charter). Drives inventory partitioning between passenger and cargo domains.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:throughAvailabilityIndicator rdf:type rdf:Property ;
    rdfs:label 'Through Availability Indicator' ;
    rdfs:comment 'Flag indicating whether this leg participates in through-availability calculations, allowing connecting itinerary availability to be computed across multiple legs without individual leg-level availability checks. True = through-availability enabled.' ;
    rdfs:domain ind:InventoryLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalSeatCapacity rdf:type rdf:Property ;
    rdfs:label 'Total Seat Capacity' ;
    rdfs:comment 'Total number of sellable passenger seats on this leg across all cabins, as configured in the inventory system for the assigned aircraft type. This is the gross capacity before overbooking authorization is applied.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:waitlistedCount rdf:type rdf:Property ;
    rdfs:label 'Waitlisted Count' ;
    rdfs:comment 'Number of passengers currently on the waitlist for this leg, pending availability opening due to cancellations or capacity adjustments. Managed within Amadeus Altéa Inventory waitlist queues.' ;
    rdfs:domain ind:InventoryLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wetLeaseIndicator rdf:type rdf:Property ;
    rdfs:label 'Wet Lease Indicator' ;
    rdfs:comment 'Flag indicating whether this leg is operated under a wet lease (ACMI) arrangement, where the aircraft, crew, maintenance, and insurance are provided by a lessor airline. Affects operating carrier attribution and regulatory reporting.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:segmentId rdf:type rdf:Property ;
    rdfs:label 'Segment Id' ;
    rdfs:comment 'Unique surrogate identifier for the commercial Origin-Destination (O&D) inventory segment record in the Amadeus Altéa Inventory system. Primary key for this entity.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Segment .

ind:fareClassId rdf:type rdf:Property ;
    rdfs:label 'Fare Class Id' ;
    rdfs:comment 'Foreign key linking to revenue.fare_class. Business justification: Inventory segments are controlled by fare class rules (availability_control_method, booking_class). segment has booking_class and fare_basis_code as plain attributes but no fare_class_id FK. Availabil' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FareClass .

ind:availabilityControlMethod rdf:type rdf:Property ;
    rdfs:label 'Availability Control Method' ;
    rdfs:comment 'Method used to control seat availability for this segment: \'leg_based\' = availability derived from individual leg bucket counts; \'od_based\' = availability controlled at the O&D segment level using virtual nesting; \'hybrid\' = combination of leg and O&D controls.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:availabilitySnapshotTime rdf:type rdf:Property ;
    rdfs:label 'Availability Snapshot Time' ;
    rdfs:comment 'Timestamp (UTC) at which the current availability figures (seats_sold, seats_available, load_factor) were last refreshed from the Amadeus Altéa Inventory system. Critical for GDS cache synchronization and real-time availability accuracy.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:bookingClass rdf:type rdf:Property ;
    rdfs:label 'Booking Class' ;
    rdfs:comment 'Single-letter IATA Reservation Booking Designator (RBD) representing the fare class bucket for this segment (e.g., Y, B, M, Q, V, W). Directly controls availability nesting and revenue management yield optimization in Sabre AirVision and Amadeus Altéa.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codeshareSeatAllocation rdf:type rdf:Property ;
    rdfs:label 'Codeshare Seat Allocation' ;
    rdfs:comment 'Number of seats allocated to the marketing carrier under a block-space codeshare agreement for this segment. Applicable only when codeshare_type = \'block_space\'. Null for free-flow or non-codeshare segments.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:codeshareType rdf:type rdf:Property ;
    rdfs:label 'Codeshare Type' ;
    rdfs:comment 'Type of codeshare arrangement governing inventory allocation for this segment: \'free_flow\' = marketing carrier draws from operating carrier\'s open inventory; \'block_space\' = a fixed seat block is allocated to the marketing carrier; \'none\' = not a codeshare segment.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interlineEligible rdf:type rdf:Property ;
    rdfs:label 'Interline Eligible' ;
    rdfs:comment 'Indicates whether this inventory segment is eligible for interline ticketing agreements, allowing passengers to book connecting itineraries across multiple carriers on a single ticket. Governed by bilateral interline agreements and IATA BSP/ARC settlement rules.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:minConnectingTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Min Connecting Time Minutes' ;
    rdfs:comment 'Minimum Connecting Time (MCT) in minutes required at the connecting airport for this segment to be valid in a connecting itinerary. Enforced during availability display and booking to prevent infeasible connections. Sourced from IATA SSIM MCT tables.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originAirportCode rdf:type rdf:Property ;
    rdfs:label 'Origin Airport Code' ;
    rdfs:comment 'Three-letter IATA airport code for the origin station of this commercial O&D segment as sold to the passenger. Defines the departure point of the sellable unit.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overbookingRate rdf:type rdf:Property ;
    rdfs:label 'Overbooking Rate' ;
    rdfs:comment 'Overbooking authorization expressed as a percentage above physical cabin capacity (e.g., 5.00 = 5% overbooking). Used by revenue management to calibrate no-show risk models and optimize load factor.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:saleCloseDate rdf:type rdf:Property ;
    rdfs:label 'Sale Close Date' ;
    rdfs:comment 'Date after which this inventory segment is no longer available for new bookings. Typically set to the departure date or earlier based on advance purchase restrictions and revenue management close-out rules.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:saleOpenDate rdf:type rdf:Property ;
    rdfs:label 'Sale Open Date' ;
    rdfs:comment 'Date from which this inventory segment is open for sale in GDS and direct booking channels. Defines the advance purchase window start for revenue management and distribution control.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledArrivalTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Arrival Time' ;
    rdfs:comment 'Scheduled arrival date and time of the segment at the destination airport in UTC (yyyy-MM-ddTHH:mm:ss.SSSXXX). Used for MCT enforcement and connecting itinerary feasibility validation.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledDepartureTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Departure Time' ;
    rdfs:comment 'Scheduled departure date and time of the segment at the origin airport in UTC (yyyy-MM-ddTHH:mm:ss.SSSXXX). Used for precise GDS availability display and MCT (Minimum Connecting Time) enforcement calculations.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:seatsBlocked rdf:type rdf:Property ;
    rdfs:label 'Seats Blocked' ;
    rdfs:comment 'Number of seats held back from general sale for operational purposes such as crew positioning, group holds, codeshare allocations, or special service requests (SSR). Reduces net available inventory without being sold.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:segmentStatus rdf:type rdf:Property ;
    rdfs:label 'Segment Status' ;
    rdfs:comment 'Current availability status of this inventory segment as published to GDS and direct booking channels. \'open\' = seats available for sale; \'closed\' = no availability; \'waitlisted\' = demand exceeds supply, waitlist active; \'cancelled\' = flight/segment cancelled; \'suspended\' = temporarily removed from sale.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentType rdf:type rdf:Property ;
    rdfs:label 'Segment Type' ;
    rdfs:comment 'Classification of the commercial segment by its operational and commercial structure: \'direct\' = single leg O&D; \'connecting\' = multi-leg through-availability segment; \'codeshare\' = marketed by partner airline; \'interline\' = cross-carrier ticketing agreement; \'virtual\' = constructed availability for display purposes.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:throughAvailabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Through Availability Flag' ;
    rdfs:comment 'Indicates whether this segment participates in through-availability nesting, meaning its availability is derived from the aggregated availability of underlying leg buckets rather than being independently controlled. True = through-availability applies.' ;
    rdfs:domain ind:Segment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:groupBlockId rdf:type rdf:Property ;
    rdfs:label 'Group Block Id' ;
    rdfs:comment 'Unique surrogate identifier for the group block record in the inventory system. Primary key for this entity.' ;
    rdfs:domain ind:Inventory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GroupBlock .

ind:accountsReceivableId rdf:type rdf:Property ;
    rdfs:label 'Accounts Receivable Id' ;
    rdfs:comment 'Foreign key linking to finance.accounts_receivable. Business justification: Group blocks carry deposit_amount, deposit_paid, deposit_paid_date, and final_payment_due_date — all generating AR records. Finance tracks group booking deposits and final payments as receivables. Rev' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccountsReceivable .

ind:pnrId rdf:type rdf:Property ;
    rdfs:label 'Pnr Id' ;
    rdfs:comment 'Reference to the master Passenger Name Record (PNR) associated with this group block. A group block is linked to a single group PNR in the Passenger Service System (PSS).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Pnr .

ind:blockStatus rdf:type rdf:Property ;
    rdfs:label 'Block Status' ;
    rdfs:comment 'Current lifecycle status of the group block. \'tentative\' = seats held pending confirmation; \'confirmed\' = group has committed; \'ticketed\' = tickets issued; \'cancelled\' = block released back to inventory; \'expired\' = option date passed without confirmation; \'waitlisted\' = requested but not yet allocated. [ENUM-REF-CANDIDATE: tentative|confirmed|ticketed|cancelled|expired|waitlisted — promote to reference product]' ;
    rdfs:domain ind:GroupBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depositAmount rdf:type rdf:Property ;
    rdfs:label 'Deposit Amount' ;
    rdfs:comment 'The monetary deposit amount required or received for this group block, expressed in fare_currency_code. Null if deposit_required is False.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:depositPaid rdf:type rdf:Property ;
    rdfs:label 'Deposit Paid' ;
    rdfs:comment 'Indicates whether the required deposit has been received from the group organizer. True = deposit received; False = deposit outstanding. Drives follow-up and cancellation workflows.' ;
    rdfs:domain ind:GroupBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:depositPaidDate rdf:type rdf:Property ;
    rdfs:label 'Deposit Paid Date' ;
    rdfs:comment 'The date on which the deposit payment was received from the group organizer. Null if deposit has not been paid.' ;
    rdfs:domain ind:GroupBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:depositRequired rdf:type rdf:Property ;
    rdfs:label 'Deposit Required' ;
    rdfs:comment 'Indicates whether a deposit payment is required from the group organizer to hold or confirm this group block. True = deposit required; False = no deposit required.' ;
    rdfs:domain ind:GroupBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fareCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Fare Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the group_fare_amount is denominated (e.g., \'USD\', \'EUR\', \'GBP\').' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finalPaymentDueDate rdf:type rdf:Property ;
    rdfs:label 'Final Payment Due Date' ;
    rdfs:comment 'The date by which the full fare payment for all ticketed seats in the group block must be settled. Distinct from the deposit due date and ticketing deadline.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:freeSeatRatio rdf:type rdf:Property ;
    rdfs:label 'Free Seat Ratio' ;
    rdfs:comment 'The ratio of complimentary (free) seats granted to the group organizer relative to the total seats purchased, expressed as a decimal (e.g., 0.1000 = 1 free seat per 10 paid). Drives revenue accounting and yield calculations.' ;
    rdfs:domain ind:GroupBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freeSeatsAllocated rdf:type rdf:Property ;
    rdfs:label 'Free Seats Allocated' ;
    rdfs:comment 'The actual number of complimentary (free) seats allocated to the group organizer based on the free_seat_ratio and confirmed group size. Impacts revenue accounting and load factor reporting.' ;
    rdfs:domain ind:GroupBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:groupFareAmount rdf:type rdf:Property ;
    rdfs:label 'Group Fare Amount' ;
    rdfs:comment 'Negotiated per-seat fare amount agreed for this group block, expressed in the currency specified by fare_currency_code. Represents the contracted price per passenger for revenue accounting and settlement.' ;
    rdfs:domain ind:GroupBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:groupFareBasis rdf:type rdf:Property ;
    rdfs:label 'Group Fare Basis' ;
    rdfs:comment 'The fare basis code applicable to the group block, defining the fare rules, restrictions, and pricing conditions under which the group seats are sold (e.g., \'GEXCAP\', \'YGROUP\'). Aligns with IATA fare construction rules.' ;
    rdfs:domain ind:GroupBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupName rdf:type rdf:Property ;
    rdfs:label 'Group Name' ;
    rdfs:comment 'The commercial or organizational name of the group for whom the seat block is reserved (e.g., \'Smith Wedding Party\', \'ACME Corp Sales Conference\'). Used for identification and communication with the group organizer.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupType rdf:type rdf:Property ;
    rdfs:label 'Group Type' ;
    rdfs:comment 'Classification of the group by purpose or segment. Used for revenue management analysis, pricing strategy, and reporting. [ENUM-REF-CANDIDATE: leisure|corporate|incentive|military|religious|sports|charter — promote to reference product]' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumGroupSize rdf:type rdf:Property ;
    rdfs:label 'Minimum Group Size' ;
    rdfs:comment 'The minimum number of passengers required to qualify for group fare pricing on this block, as defined by the applicable fare rules. Typically 10 passengers per IATA group fare conventions.' ;
    rdfs:domain ind:GroupBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:namesDueDate rdf:type rdf:Property ;
    rdfs:label 'Names Due Date' ;
    rdfs:comment 'The date by which the group organizer must submit individual passenger names (Pax names) for all seats in the confirmed block. Required for check-in, security compliance, and advance passenger information (API) submission.' ;
    rdfs:domain ind:GroupBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:optionDate rdf:type rdf:Property ;
    rdfs:label 'Option Date' ;
    rdfs:comment 'The deadline date by which the group organizer must confirm the number of seats and provide passenger names. If not confirmed by this date, the block may be automatically released back to inventory. Critical for inventory management and revenue optimization.' ;
    rdfs:domain ind:GroupBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:overbookingEligible rdf:type rdf:Property ;
    rdfs:label 'Overbooking Eligible' ;
    rdfs:comment 'Indicates whether this group block is subject to overbooking controls. True = the block counts against overbooking limits; False = the block is protected from overbooking displacement (e.g., guaranteed allocation). Feeds revenue management overbooking models.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reference rdf:type rdf:Property ;
    rdfs:label 'Reference' ;
    rdfs:comment 'Externally-known alphanumeric reference code assigned to this group block by the Passenger Service System (PSS) or reservations team. Used by travel agents and group coordinators to identify and manage the block.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesChannel rdf:type rdf:Property ;
    rdfs:label 'Sales Channel' ;
    rdfs:comment 'The distribution channel through which the group block was requested and booked. \'direct\' = airline reservations team; \'gds\' = Global Distribution System (GDS) such as Amadeus or Sabre; \'online_travel_agency\' = OTA; \'corporate\' = corporate travel desk; \'charter\' = charter operator.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seatsConfirmed rdf:type rdf:Property ;
    rdfs:label 'Seats Confirmed' ;
    rdfs:comment 'Number of seats within the block that have been formally confirmed by the group organizer. May be less than seats_blocked during the tentative phase. Drives revenue recognition and ticketing obligations.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seatsReleased rdf:type rdf:Property ;
    rdfs:label 'Seats Released' ;
    rdfs:comment 'Number of seats that have been released back to general inventory from this group block, either due to partial cancellation, reduction, or expiry of the option. Supports inventory reconciliation.' ;
    rdfs:domain ind:GroupBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seatsRequested rdf:type rdf:Property ;
    rdfs:label 'Seats Requested' ;
    rdfs:comment 'Total number of seats originally requested by the group organizer at the time of the initial group block request. Baseline for tracking changes to the block size.' ;
    rdfs:domain ind:GroupBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seatsTicketed rdf:type rdf:Property ;
    rdfs:label 'Seats Ticketed' ;
    rdfs:comment 'Number of seats within the confirmed block for which electronic tickets (e-tickets) have been issued. Used to track ticketing progress against the ticketing deadline.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ticketingDeadline rdf:type rdf:Property ;
    rdfs:label 'Ticketing Deadline' ;
    rdfs:comment 'The final date by which all confirmed seats in the group block must be ticketed (e-tickets issued). Failure to ticket by this date may result in automatic cancellation of unticketed seats and release to general inventory.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waitlistEntryId rdf:type rdf:Property ;
    rdfs:label 'Waitlist Entry Id' ;
    rdfs:comment 'Unique surrogate identifier for each waitlist entry record in the Altéa Inventory waitlist processing engine. Primary key for this data product.' ;
    rdfs:domain ind:WaitlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bookingPassengerId rdf:type rdf:Property ;
    rdfs:label 'Booking Passenger Id' ;
    rdfs:comment 'Foreign key linking to reservation.reservation_booking_passenger. Business justification: Waitlist clearance workflow requires identifying the specific passenger (not just PNR) to notify, upgrade, and trigger boarding pass issuance. A PNR can have multiple passengers; without this FK, the ' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BookingPassenger .

ind:paxProfileId rdf:type rdf:Property ;
    rdfs:label 'Pax Profile Id' ;
    rdfs:comment 'Reference to the individual passenger profile associated with this waitlist entry. A single PNR may contain multiple passengers, each generating a separate waitlist entry.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Profile .

ind:alteaWaitlistSequence rdf:type rdf:Property ;
    rdfs:label 'Altea Waitlist Sequence' ;
    rdfs:comment 'Native waitlist sequence number assigned by the Amadeus Altéa Inventory waitlist processing engine. Serves as the business identifier for this waitlist entry within the Altéa system, used for reconciliation between the lakehouse Silver layer and the source PSS.' ;
    rdfs:domain ind:WaitlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelCode rdf:type rdf:Property ;
    rdfs:label 'Channel Code' ;
    rdfs:comment 'Distribution channel through which the waitlist entry was created. GDS: Global Distribution System (e.g., Amadeus, Sabre, Travelport); NDC: IATA New Distribution Capability channel; DIRECT_WEB: airline direct website; MOBILE: airline mobile application; AIRPORT: airport check-in or gate agent; CALL_CENTER: reservations call center; INTERLINE: interline partner booking. [ENUM-REF-CANDIDATE: GDS|NDC|DIRECT_WEB|MOBILE|AIRPORT|CALL_CENTER|INTERLINE — promote to reference product]' ;
    rdfs:domain ind:WaitlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearanceBookingClass rdf:type rdf:Property ;
    rdfs:label 'Clearance Booking Class' ;
    rdfs:comment 'The actual booking class in which the waitlist entry was cleared and confirmed, which may differ from the originally requested booking class if the revenue management system cleared the passenger into a higher-availability bucket. Null until clearance occurs.' ;
    rdfs:domain ind:WaitlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearanceMethod rdf:type rdf:Property ;
    rdfs:label 'Clearance Method' ;
    rdfs:comment 'Method by which the waitlist entry was cleared. AUTOMATIC: Altéa Inventory engine cleared automatically when bucket availability opened; MANUAL: airport or reservations agent manually cleared the entry; UPGRADE_PROCESSING: cleared as part of an upgrade processing run; IROP_REACCOMMODATION: cleared during Irregular Operations (IROP) reaccommodation workflow.' ;
    rdfs:domain ind:WaitlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearanceTimestamp rdf:type rdf:Property ;
    rdfs:label 'Clearance Timestamp' ;
    rdfs:comment 'Date and time (UTC) when the waitlist entry was successfully cleared and the seat confirmed. Null if the entry has not yet been cleared. Used to measure waitlist clearance latency and revenue recovery timing. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:WaitlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:expiryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Expiry Timestamp' ;
    rdfs:comment 'Date and time (UTC) at which the waitlist entry will automatically expire if not cleared, typically aligned with the flight departure time or a configurable pre-departure deadline set by revenue management policy. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ffpMemberNumber rdf:type rdf:Property ;
    rdfs:label 'Ffp Member Number' ;
    rdfs:comment 'Frequent Flyer Program (FFP) membership number of the waitlisted passenger. Used to apply loyalty-based priority rules and to credit miles upon clearance and travel. Classified as confidential PII as it is a unique personal identifier.' ;
    rdfs:domain ind:WaitlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ffpTier rdf:type rdf:Property ;
    rdfs:label 'Ffp Tier' ;
    rdfs:comment 'Frequent Flyer Program (FFP) membership tier of the waitlisted passenger at the time of waitlist entry creation (e.g., NONE, SILVER, GOLD, PLATINUM, ELITE). Higher tiers receive elevated priority rank in the waitlist queue per revenue management policy.' ;
    rdfs:domain ind:WaitlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdsQueueNumber rdf:type rdf:Property ;
    rdfs:label 'Gds Queue Number' ;
    rdfs:comment 'Queue number assigned by the Global Distribution System (GDS) for this waitlist entry, used to route clearance notifications back to the originating travel agent or booking system. Null for direct-channel bookings.' ;
    rdfs:domain ind:WaitlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCodeshare rdf:type rdf:Property ;
    rdfs:label 'Is Codeshare' ;
    rdfs:comment 'Indicates whether the waitlist entry is associated with a codeshare flight operation where the marketing carrier differs from the operating carrier. True: codeshare booking; False: own-metal operation. Affects inventory allotment rules and clearance authority.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationSent rdf:type rdf:Property ;
    rdfs:label 'Notification Sent' ;
    rdfs:comment 'Indicates whether a clearance or status-change notification has been dispatched to the passenger or booking agent following a waitlist status transition. True: notification sent; False: notification pending or not applicable. Supports DOT consumer notification compliance.' ;
    rdfs:domain ind:WaitlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Notification Timestamp' ;
    rdfs:comment 'Date and time (UTC) when the clearance or status-change notification was dispatched to the passenger or booking agent. Null if no notification has been sent. Used for DOT consumer protection compliance reporting. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:priorityRank rdf:type rdf:Property ;
    rdfs:label 'Priority Rank' ;
    rdfs:comment 'Numeric rank of this waitlist entry within the queue for the same flight, cabin, and fare class bucket. Lower values indicate higher priority for clearance. Determined by Altéa Inventory based on booking time, fare paid, and frequent flyer tier.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revenueManagementOverride rdf:type rdf:Property ;
    rdfs:label 'Revenue Management Override' ;
    rdfs:comment 'Indicates whether a revenue management analyst manually overrode the standard Altéa Inventory waitlist clearance rules for this entry (e.g., to prioritise a high-value passenger or honour a corporate contract). True: manual override applied; False: standard automated rules applied.' ;
    rdfs:domain ind:WaitlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:seatCountRequested rdf:type rdf:Property ;
    rdfs:label 'Seat Count Requested' ;
    rdfs:comment 'Number of seats requested on the waitlist for this entry. For individual bookings this is typically 1; for group bookings this may be greater than 1. Determines the inventory units required for clearance.' ;
    rdfs:domain ind:WaitlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ssrCodes rdf:type rdf:Property ;
    rdfs:label 'Ssr Codes' ;
    rdfs:comment 'Comma-separated list of IATA Special Service Request (SSR) codes associated with the waitlisted passenger (e.g., WCHR, VGML, UMNR). These SSRs must be honoured upon clearance and seat assignment. Stored as a denormalized string for operational reference.' ;
    rdfs:domain ind:WaitlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ticketNumber rdf:type rdf:Property ;
    rdfs:label 'Ticket Number' ;
    rdfs:comment '13-digit IATA electronic ticket (e-ticket) number associated with the waitlisted booking segment. Follows the IATA 13-digit format (3-digit airline code + 10-digit serial). May be null if the ticket has not yet been issued at the time of waitlist creation.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upgradeFromCabinCode rdf:type rdf:Property ;
    rdfs:label 'Upgrade From Cabin Code' ;
    rdfs:comment 'For upgrade-request waitlist entries, the cabin code of the originally booked cabin from which the passenger is requesting an upgrade (e.g., Y for Economy). Null for sold-out or group overflow waitlist reasons. Used by upgrade processing logic in Altéa Inventory.' ;
    rdfs:domain ind:WaitlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waitlistReason rdf:type rdf:Property ;
    rdfs:label 'Waitlist Reason' ;
    rdfs:comment 'Business reason why the passenger or booking was placed on the waitlist rather than confirmed. SOLD_OUT: requested fare class bucket was closed; UPGRADE_REQUEST: passenger requested cabin upgrade pending availability; GROUP_OVERFLOW: group booking exceeded available allotment; OVERBOOKING_CONTROL: revenue management overbooking limit reached; CODESHARE_ALLOTMENT: codeshare partner inventory allocation exhausted.' ;
    rdfs:domain ind:WaitlistEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waitlistStatus rdf:type rdf:Property ;
    rdfs:label 'Waitlist Status' ;
    rdfs:comment 'Current lifecycle status of the waitlist entry as managed by the Altéa Inventory waitlist processing engine. OPEN: actively queued awaiting availability; CLEARED: bucket opened and seat confirmed; CANCELLED: passenger or agent cancelled the waitlist request; EXPIRED: flight departed or deadline passed without clearance; REJECTED: system or revenue management rule prevented clearance.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carrierId rdf:type rdf:Property ;
    rdfs:label 'Carrier Id' ;
    rdfs:comment 'Foreign key linking to route.carrier. Business justification: Fares are filed by a specific carrier (ATPCO filing carrier). Carrier-level fare management, competitive fare analysis, and regulatory filing audits require linking fares to the authoritative carrier ' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:fareFamilyId rdf:type rdf:Property ;
    rdfs:label 'Fare Family Id' ;
    rdfs:comment 'Foreign key linking to revenue.fare_family. Business justification: Individual fares are grouped into fare families (branded fares). A fare belongs to one fare family. This is the authoritative link between the atomic fare definition and its branded fare grouping. Sta' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FareFamily .

ind:amount rdf:type rdf:Property ;
    rdfs:label 'Amount' ;
    rdfs:comment 'Published or filed fare amount in the specified currency, representing the one-way or round-trip base fare before taxes and surcharges. This is the principal monetary value of the fare record as filed with ATPCO or SITA.' ;
    rdfs:domain ind:Fare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:atpcoRecordType rdf:type rdf:Property ;
    rdfs:label 'Atpco Record Type' ;
    rdfs:comment 'ATPCO record type number identifying the category of fare data: Record 1=Fare by Rule, Record 2=Fare Amount, Record 3=Fare Rules, Record 4=Footnote, Record 5=Routing, Record 6=Fare Class. Governs how the fare is processed in GDS and PSS systems.' ;
    rdfs:domain ind:Fare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:basisCode rdf:type rdf:Property ;
    rdfs:label 'Basis Code' ;
    rdfs:comment 'ATPCO-standard alphanumeric code uniquely identifying the fare construction rules, booking class, and conditions (e.g., YOW, KLAXOW, B21NR). The atomic pricing identifier used across GDS, PSS, and revenue management systems. Maximum 8 characters per ATPCO convention.' ;
    rdfs:domain ind:Fare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cabinClass rdf:type rdf:Property ;
    rdfs:label 'Cabin Class' ;
    rdfs:comment 'Physical cabin of service associated with this fare (e.g., first, business, premium_economy, economy). Determines the onboard product and service level entitlement for the passenger.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeableIndicator rdf:type rdf:Property ;
    rdfs:label 'Changeable Indicator' ;
    rdfs:comment 'Indicates whether the itinerary or date may be changed after ticketing (True) or is a fixed non-changeable fare (False). May be subject to a change fee defined in the associated fare rule.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:classCode rdf:type rdf:Property ;
    rdfs:label 'Class Code' ;
    rdfs:comment 'One or two-letter code representing the fare class grouping within the cabin (e.g., Y for full economy, B for discounted economy). Used in revenue management for yield optimization and load factor reporting.' ;
    rdfs:domain ind:Fare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:combinabilityCode rdf:type rdf:Property ;
    rdfs:label 'Combinability Code' ;
    rdfs:comment 'ATPCO code governing how this fare may be combined with other fares in a half-round-trip or end-on-end combination. Controls fare construction logic in GDS and PSS pricing engines.' ;
    rdfs:domain ind:Fare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currencyCode rdf:type rdf:Property ;
    rdfs:label 'Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the fare amount is denominated (e.g., USD, EUR, GBP). Determines the settlement currency for BSP and ARC reporting.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationCountryCode rdf:type rdf:Property ;
    rdfs:label 'Destination Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the fare destination point. Used for international fare applicability, bilateral air service agreement compliance, and CORSIA carbon reporting.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:directionality rdf:type rdf:Property ;
    rdfs:label 'Directionality' ;
    rdfs:comment 'Indicates whether the fare applies to a one-way journey, round-trip, circle trip, or open-jaw itinerary. Determines how the fare is combined in fare construction and pricing calculations.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discontinueDate rdf:type rdf:Property ;
    rdfs:label 'Discontinue Date' ;
    rdfs:comment 'The date after which this fare is no longer valid for ticketing. A null value indicates the fare has no defined expiry. Aligns with ATPCO fare filing discontinue date field.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fareStatus rdf:type rdf:Property ;
    rdfs:label 'Fare Status' ;
    rdfs:comment 'Current lifecycle state of the fare record: active (available for sale), inactive (not currently sellable), pending (filed but not yet effective), withdrawn (removed from filing), superseded (replaced by a newer fare version).' ;
    rdfs:domain ind:Fare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fareType rdf:type rdf:Property ;
    rdfs:label 'Fare Type' ;
    rdfs:comment 'Classification of the fare by its distribution and ownership model. Published fares are filed publicly via ATPCO/SITA; negotiated fares are corporate or agency-specific; private fares are not publicly visible in GDS; web fares are exclusive to direct channels; net fares are wholesale fares for consolidators. [ENUM-REF-CANDIDATE: published|negotiated|private|web|net|consolidator — promote to reference product]' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingDate rdf:type rdf:Property ;
    rdfs:label 'Filing Date' ;
    rdfs:comment 'The date on which this fare was originally filed with ATPCO, SITA, or the carrier\'s own system. Used for audit trails, regulatory compliance, and fare history analysis.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:globalIndicator rdf:type rdf:Property ;
    rdfs:label 'Global Indicator' ;
    rdfs:comment 'IATA-defined two-letter code specifying the geographic routing area applicable to this fare (e.g., AT=Atlantic, PA=Pacific, TS=Trans-Siberian, AP=Asia-Pacific). Governs which routing rules and mileage systems apply for fare construction. [ENUM-REF-CANDIDATE: AT|PA|TS|AP|SA|EH|FE|NA|PO|RU|US — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iataFareFilingRef rdf:type rdf:Property ;
    rdfs:label 'Iata Fare Filing Ref' ;
    rdfs:comment 'IATA-assigned reference number or identifier for the fare filing submission. Used for audit, dispute resolution, and cross-referencing with IATA BSP settlement records.' ;
    rdfs:domain ind:Fare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumStayDays rdf:type rdf:Property ;
    rdfs:label 'Maximum Stay Days' ;
    rdfs:comment 'Maximum number of days the passenger may remain at the destination before the return journey must commence. A null value indicates no maximum stay restriction.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumStayDays rdf:type rdf:Property ;
    rdfs:label 'Minimum Stay Days' ;
    rdfs:comment 'Minimum number of days the passenger must remain at the destination before returning, as required by this fare\'s conditions. Commonly used for round-trip leisure fares to prevent business travelers from using discounted fares.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originCountryCode rdf:type rdf:Property ;
    rdfs:label 'Origin Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the fare origin point. Used for regulatory compliance, DOT reporting, and country-of-sale restrictions.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownership rdf:type rdf:Property ;
    rdfs:label 'Ownership' ;
    rdfs:comment 'Identifies the filing channel through which this fare was submitted and is maintained: ATPCO (Airline Tariff Publishing Company), SITA (Société Internationale de Télécommunications Aéronautiques), or carrier-filed directly into the PSS.' ;
    rdfs:domain ind:Fare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:owrtIndicator rdf:type rdf:Property ;
    rdfs:label 'Owrt Indicator' ;
    rdfs:comment 'ATPCO one-way/round-trip indicator: O=one-way only, R=round-trip only, X=either. Controls how the fare may be combined in half-round-trip pricing and fare construction.' ;
    rdfs:domain ind:Fare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passengerTypeCode rdf:type rdf:Property ;
    rdfs:label 'Passenger Type Code' ;
    rdfs:comment 'IATA three-letter Passenger Type Code specifying the eligible passenger category for this fare (e.g., ADT=Adult, CHD=Child, INF=Infant, SRC=Senior, MIL=Military, STU=Student). Restricts fare applicability to qualifying passengers.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundableIndicator rdf:type rdf:Property ;
    rdfs:label 'Refundable Indicator' ;
    rdfs:comment 'Indicates whether this fare is eligible for a cash refund upon cancellation (True) or is non-refundable (False). Critical for passenger service, revenue accounting, and DOT consumer protection compliance.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:routingNumber rdf:type rdf:Property ;
    rdfs:label 'Routing Number' ;
    rdfs:comment 'ATPCO-assigned routing number that specifies the permitted intermediate points and carrier combinations for this fare. A value of \'0\' typically indicates a mileage-based fare with no specific routing restriction.' ;
    rdfs:domain ind:Fare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesRestriction rdf:type rdf:Property ;
    rdfs:label 'Sales Restriction' ;
    rdfs:comment 'Defines geographic or channel restrictions on where this fare may be sold. Controls distribution eligibility across GDS, direct channels, and agency networks. [ENUM-REF-CANDIDATE: no_restriction|country_of_origin|carrier_office|internet_only|agency_only|consolidator_only — promote to reference product]' ;
    rdfs:domain ind:Fare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tariffCode rdf:type rdf:Property ;
    rdfs:label 'Tariff Code' ;
    rdfs:comment 'Alphanumeric code identifying the specific tariff under which this fare is filed (e.g., PUBL for published, PRIV for private). Determines the visibility and distribution rules in GDS channels.' ;
    rdfs:domain ind:Fare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tariffNumber rdf:type rdf:Property ;
    rdfs:label 'Tariff Number' ;
    rdfs:comment 'ATPCO tariff number identifying the rule set (conditions, restrictions, penalties) associated with this fare. Links the fare amount to its governing fare rules in the ATPCO database.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ticketingCarrierCode rdf:type rdf:Property ;
    rdfs:label 'Ticketing Carrier Code' ;
    rdfs:comment 'IATA two-letter code of the carrier authorized to issue tickets under this fare. May differ from the operating carrier in codeshare and interline arrangements. Used for BSP settlement and ARC reporting.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:travelDiscontinueDate rdf:type rdf:Property ;
    rdfs:label 'Travel Discontinue Date' ;
    rdfs:comment 'The last date on which travel may be completed using this fare. Defines the travel validity window in conjunction with travel_effective_date.' ;
    rdfs:domain ind:Fare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:travelEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Travel Effective Date' ;
    rdfs:comment 'The earliest date on which travel may commence using this fare. Distinct from the ticketing effective date; governs the travel window rather than the sale window.' ;
    rdfs:domain ind:Fare ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fareRuleId rdf:type rdf:Property ;
    rdfs:label 'Fare Rule Id' ;
    rdfs:comment 'Unique surrogate identifier for the fare rule record in the Silver layer lakehouse. Primary key for this entity.' ;
    rdfs:domain ind:FareRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:advancePurchaseHours rdf:type rdf:Property ;
    rdfs:label 'Advance Purchase Hours' ;
    rdfs:comment 'Minimum number of hours before departure by which the ticket must be purchased to qualify for this fare (ATPCO Cat 5). Null if no advance purchase requirement applies. Expressed in hours to accommodate sub-day requirements (e.g., 3-hour, 6-hour, 24-hour, 72-hour, 168-hour/7-day, 336-hour/14-day).' ;
    rdfs:domain ind:FareRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:atpcoCategoryNumber rdf:type rdf:Property ;
    rdfs:label 'Atpco Category Number' ;
    rdfs:comment 'ATPCO rule category number (Cat 1–35) that classifies the type of restriction or condition this rule record governs. Examples: Cat 2 = Day/Time, Cat 3 = Seasonality, Cat 4 = Flight Application, Cat 5 = Advance Purchase, Cat 6 = Min Stay, Cat 7 = Max Stay, Cat 8 = Stopovers, Cat 9 = Transfers, Cat 14 = Travel Restrictions, Cat 15 = Sales Restrictions, Cat 16 = Penalties, Cat 31 = Voluntary Changes, Cat 33 = Voluntary Refunds.' ;
    rdfs:domain ind:FareRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:blackoutEndDate rdf:type rdf:Property ;
    rdfs:label 'Blackout End Date' ;
    rdfs:comment 'End date of a travel blackout period during which this fare is not available for travel (ATPCO Cat 11). Null if no blackout period applies.' ;
    rdfs:domain ind:FareRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:blackoutStartDate rdf:type rdf:Property ;
    rdfs:label 'Blackout Start Date' ;
    rdfs:comment 'Start date of a travel blackout period during which this fare is not available for travel (ATPCO Cat 11 — Blackout Dates). Null if no blackout period applies. Multiple blackout periods should be stored as separate rule records.' ;
    rdfs:domain ind:FareRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:carrierCode rdf:type rdf:Property ;
    rdfs:label 'Carrier Code' ;
    rdfs:comment 'IATA two-letter airline designator code of the validating carrier that owns and filed this fare rule. Identifies the airline responsible for the tariff.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryName rdf:type rdf:Property ;
    rdfs:label 'Category Name' ;
    rdfs:comment 'Human-readable name of the ATPCO rule category (e.g., \'Advance Purchase\', \'Minimum Stay\', \'Maximum Stay\', \'Stopovers\', \'Transfers\', \'Penalties\', \'Combinability\', \'Blackout Dates\', \'Seasonality\', \'Day/Time Restrictions\'). Derived from the ATPCO category number for display and reporting purposes.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:combinabilityType rdf:type rdf:Property ;
    rdfs:label 'Combinability Type' ;
    rdfs:comment 'Specifies how this fare may be combined with other fares to construct a complete itinerary (ATPCO Cat 10). \'end_on_end\' = fares combined sequentially; \'back_to_back\' = two one-way fares used together; \'open_jaw\' = origin or destination differs on outbound/return; \'round_trip\' = must be used as a round trip; \'none\' = no combination permitted.' ;
    rdfs:domain ind:FareRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endorsementText rdf:type rdf:Property ;
    rdfs:label 'Endorsement Text' ;
    rdfs:comment 'Free-text endorsement or restriction box content that must be printed on the ticket (ATPCO Cat 20 — Endorsements). Contains regulatory or commercial restrictions such as \'NON-ENDORSE/NON-REROUTE\', \'VALID ON XX ONLY\', or \'NO REFUND AFTER DEPARTURE\'. Required by IATA ticketing standards.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minStayType rdf:type rdf:Property ;
    rdfs:label 'Min Stay Type' ;
    rdfs:comment 'Qualifier for the minimum stay requirement. \'days\' = calendar day count applies; \'saturday_night\' = passenger must include a Saturday night at destination; \'none\' = no minimum stay restriction.' ;
    rdfs:domain ind:FareRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:permittedDaysOfWeek rdf:type rdf:Property ;
    rdfs:label 'Permitted Days Of Week' ;
    rdfs:comment 'Comma-separated list of days of the week on which travel under this fare is permitted (ATPCO Cat 2 — Day/Time). Values: MON, TUE, WED, THU, FRI, SAT, SUN. Null or empty means all days are permitted. Example: \'MON,TUE,WED,THU\' restricts to weekday travel only.' ;
    rdfs:domain ind:FareRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundPenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Refund Penalty Amount' ;
    rdfs:comment 'Monetary penalty deducted from the refund amount when a passenger cancels a refundable ticket under this fare rule (ATPCO Cat 33). Expressed in the currency defined by refund_penalty_currency. Null if the fare is non-refundable or no penalty applies.' ;
    rdfs:domain ind:FareRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:refundPenaltyCurrency rdf:type rdf:Property ;
    rdfs:label 'Refund Penalty Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the refund penalty amount is denominated. Null if no refund penalty applies.' ;
    rdfs:domain ind:FareRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleNumber rdf:type rdf:Property ;
    rdfs:label 'Rule Number' ;
    rdfs:comment 'Carrier-assigned rule number that groups related rule categories under a single tariff filing. Used by pricing engines to retrieve the full rule set for a fare basis. Corresponds to the ATPCO rule number field.' ;
    rdfs:domain ind:FareRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleStatus rdf:type rdf:Property ;
    rdfs:label 'Rule Status' ;
    rdfs:comment 'Current lifecycle status of the fare rule record. \'active\' = currently in force and applied by pricing engines; \'inactive\' = suspended or withdrawn; \'superseded\' = replaced by a newer rule version; \'pending\' = filed but not yet effective.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleText rdf:type rdf:Property ;
    rdfs:label 'Rule Text' ;
    rdfs:comment 'Complete free-text narrative of the fare rule as filed with ATPCO or the carrier\'s internal tariff system. Contains the full legal and commercial conditions of use. Used by ticketing agents and displayed in GDS fare displays.' ;
    rdfs:domain ind:FareRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesRestrictionType rdf:type rdf:Property ;
    rdfs:label 'Sales Restriction Type' ;
    rdfs:comment 'Channel restriction governing where this fare may be sold (ATPCO Cat 15 — Sales Restrictions). \'internet_only\' = only available via airline direct web/app; \'agency_only\' = only through accredited travel agents; \'direct_only\' = only via airline direct channels; \'gds_only\' = only through Global Distribution Systems; \'none\' = no channel restriction.' ;
    rdfs:domain ind:FareRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonType rdf:type rdf:Property ;
    rdfs:label 'Season Type' ;
    rdfs:comment 'Seasonal classification applied to this fare rule (ATPCO Cat 3 — Seasonality). Determines the travel season band in which the fare is valid. \'peak\' = high-demand season; \'shoulder\' = transitional season; \'off_peak\' = low-demand season; \'none\' = no seasonal restriction.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stopoversPermitted rdf:type rdf:Property ;
    rdfs:label 'Stopovers Permitted' ;
    rdfs:comment 'Maximum number of stopovers (intentional interruptions of journey exceeding the Minimum Connecting Time) permitted under this fare rule (ATPCO Cat 8). A value of 0 means no stopovers allowed; null means unlimited.' ;
    rdfs:domain ind:FareRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tourCode rdf:type rdf:Property ;
    rdfs:label 'Tour Code' ;
    rdfs:comment 'Tour operator or inclusive tour code required to be present on the ticket for this fare to be valid (ATPCO Cat 27 — Tour Conductor Discounts / inclusive tour requirements). Null if no tour code is required. Used for IT (Inclusive Tour) and BT (Bulk Tour) fares.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transfersPermitted rdf:type rdf:Property ;
    rdfs:label 'Transfers Permitted' ;
    rdfs:comment 'Maximum number of transfers (connections within Minimum Connecting Time) permitted under this fare rule (ATPCO Cat 9). A value of 0 means no transfers allowed; null means unlimited.' ;
    rdfs:domain ind:FareRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:travelRestrictionType rdf:type rdf:Property ;
    rdfs:label 'Travel Restriction Type' ;
    rdfs:comment 'Directional travel restriction applied to this fare rule (ATPCO Cat 14 — Travel Restrictions). Specifies whether the rule applies to the outbound journey, inbound journey, or both directions of travel.' ;
    rdfs:domain ind:FareRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baggageAllowanceId rdf:type rdf:Property ;
    rdfs:label 'Baggage Allowance Id' ;
    rdfs:comment 'Foreign key linking to ancillary.baggage_allowance. Business justification: Fare classes define included baggage allowances — a fundamental airline product design relationship. This drives ancillary upsell logic (what is chargeable vs. included), GDS display, and IATA ATPCO b' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BaggageAllowance .

ind:awardRedemptionClass rdf:type rdf:Property ;
    rdfs:label 'Award Redemption Class' ;
    rdfs:comment 'Indicates whether this fare class is designated as an FFP (Frequent Flyer Program) award redemption booking class (True), meaning seats in this class are allocated from the award inventory pool and redeemed using loyalty miles/points rather than cash. Award classes are managed separately in Oracle Loyalty Cloud and do not generate direct ticket revenue.' ;
    rdfs:domain ind:FareClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:blackoutApplicable rdf:type rdf:Property ;
    rdfs:label 'Blackout Applicable' ;
    rdfs:comment 'Indicates whether this fare class is subject to blackout date restrictions (True), meaning it cannot be sold or used for travel during defined peak or holiday periods. When True, blackout dates are defined in the associated fare rule or seasonal restriction records. Relevant for both revenue fares and FFP award redemption classes.' ;
    rdfs:domain ind:FareClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:carryOnBagAllowance rdf:type rdf:Property ;
    rdfs:label 'Carry On Bag Allowance' ;
    rdfs:comment 'Number of carry-on baggage items (cabin bags) included at no additional charge for passengers traveling in this fare class. A value of 0 indicates no complimentary carry-on allowance (applicable to ultra-low-cost basic fare products). Feeds ancillary revenue calculation and gate agent enforcement workflows.' ;
    rdfs:domain ind:FareClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:changeable rdf:type rdf:Property ;
    rdfs:label 'Changeable' ;
    rdfs:comment 'Indicates whether the itinerary on a ticket issued in this fare class can be changed after purchase (True) or is a fixed, non-changeable booking (False). When True, change fees and fare difference rules defined in the associated fare rule record apply. Drives Amadeus Altéa PSS voluntary change workflow.' ;
    rdfs:domain ind:FareClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:checkedBagAllowance rdf:type rdf:Property ;
    rdfs:label 'Checked Bag Allowance' ;
    rdfs:comment 'Number of checked baggage pieces included at no additional charge for passengers traveling in this fare class. A value of 0 indicates no complimentary checked baggage (e.g., basic economy). Drives ancillary baggage fee revenue calculation and EMD (Electronic Miscellaneous Document) issuance logic in Amadeus Altéa.' ;
    rdfs:domain ind:FareClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:codeshareEligible rdf:type rdf:Property ;
    rdfs:label 'Codeshare Eligible' ;
    rdfs:comment 'Indicates whether this fare class may be sold on codeshare-operated flights (True) or is restricted to the operating carrier\'s own metal only (False). Codeshare eligibility governs interline proration and revenue sharing agreements between partner airlines under BSP settlement.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:expiryDate rdf:type rdf:Property ;
    rdfs:label 'Expiry Date' ;
    rdfs:comment 'Calendar date after which this fare class definition is no longer active for new bookings. A null value indicates the fare class has no defined expiry and remains active indefinitely. Used to manage seasonal fare class retirement and product sunset timelines.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:family rdf:type rdf:Property ;
    rdfs:label 'Family' ;
    rdfs:comment 'Grouping label that clusters related RBDs into a commercial fare product family (e.g., FLEX, SEMI-FLEX, SAVER, BASIC, BUSINESS_FLEX, BUSINESS_SAVER). Used by Sabre AirVision Revenue Management for fare family-level yield management, ancillary bundling rules, and customer-facing fare product presentation. [ENUM-REF-CANDIDATE: FLEX|SEMI-FLEX|SAVER|BASIC|BUSINESS_FLEX|BUSINESS_SAVER|LIGHT — promote to reference product]' ;
    rdfs:domain ind:FareClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fareBasisCodePattern rdf:type rdf:Property ;
    rdfs:label 'Fare Basis Code Pattern' ;
    rdfs:comment 'Alphanumeric pattern or prefix associated with fare basis codes that map to this fare class (e.g., \'YOW\', \'BAPOW14\', \'QSAVER21\'). Fare basis codes are the detailed pricing identifiers used in ATPCO (Airline Tariff Publishing Company) fare filings and GDS displays. This field captures the naming convention pattern rather than individual fare basis codes, which are managed in the fare rule product.' ;
    rdfs:domain ind:FareClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fareClassDescription rdf:type rdf:Property ;
    rdfs:label 'Fare Class Description' ;
    rdfs:comment 'Free-text business description of this fare class, capturing its commercial purpose, target customer segment, and key product characteristics (e.g., \'Fully flexible full-fare economy class with unlimited changes and refunds, eligible for all upgrades and lounge access\'). Used in internal revenue management documentation and business reporting.' ;
    rdfs:domain ind:FareClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fareClassStatus rdf:type rdf:Property ;
    rdfs:label 'Fare Class Status' ;
    rdfs:comment 'Current lifecycle status of the fare class record: active = currently in use for booking and inventory control; inactive = suspended from sale but retained for historical reference; deprecated = permanently retired RBD no longer used in any market; seasonal = active only during defined seasonal periods. Governs whether the RBD is available for inventory allocation in the PSS.' ;
    rdfs:domain ind:FareClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loungeAccessIncluded rdf:type rdf:Property ;
    rdfs:label 'Lounge Access Included' ;
    rdfs:comment 'Indicates whether airport lounge access is included as a bundled benefit for passengers traveling in this fare class (True) or is not included (False). Typically True for premium cabin classes (First, Business) and certain elite fare products. Drives lounge access entitlement checks at airport ground operations.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mileageAccrualMultiplier rdf:type rdf:Property ;
    rdfs:label 'Mileage Accrual Multiplier' ;
    rdfs:comment 'Decimal multiplier applied to base flight distance (in miles or kilometers) to calculate Frequent Flyer Program (FFP) miles/points earned when a ticket is issued in this fare class. For example, 1.00 = 100% accrual, 0.50 = 50% accrual, 1.50 = 150% elite bonus accrual. A value of 0.00 indicates no mileage accrual (e.g., deeply discounted or award redemption classes). Feeds Oracle Loyalty Cloud FFP accrual calculation engine.' ;
    rdfs:domain ind:FareClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:noShowFeeApplicable rdf:type rdf:Property ;
    rdfs:label 'No Show Fee Applicable' ;
    rdfs:comment 'Indicates whether a no-show penalty fee is charged when a passenger holding a ticket in this fare class fails to cancel before departure and does not board the flight (True). No-show fees are an ancillary revenue stream tracked in SAP S/4HANA and reported in ARC settlement.' ;
    rdfs:domain ind:FareClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorityBoardingIncluded rdf:type rdf:Property ;
    rdfs:label 'Priority Boarding Included' ;
    rdfs:comment 'Indicates whether priority boarding access is included as a bundled benefit for passengers traveling in this fare class (True) or must be purchased separately as an ancillary service (False). Relevant for fare product differentiation and ancillary revenue attribution in SAP S/4HANA.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:refundable rdf:type rdf:Property ;
    rdfs:label 'Refundable' ;
    rdfs:comment 'Indicates whether tickets issued in this fare class are eligible for a monetary refund upon cancellation (True) or are non-refundable (False). Non-refundable fares may still qualify for travel credit or voucher issuance depending on fare rules. Critical for revenue accounting, BSP (Billing and Settlement Plan) settlement, and ARC reporting.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revenueClassType rdf:type rdf:Property ;
    rdfs:label 'Revenue Class Type' ;
    rdfs:comment 'Categorizes the commercial nature of this fare class for revenue accounting and BSP/ARC settlement purposes: revenue = standard commercial fare generating ticket revenue; award = FFP redemption (no cash revenue); staff = employee/industry discount travel; charter = charter block-seat allocation; group = group booking class; tour_operator = wholesale tour operator allocation. Drives revenue recognition rules in SAP S/4HANA FI/CO.' ;
    rdfs:domain ind:FareClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sameDayChangeEligible rdf:type rdf:Property ;
    rdfs:label 'Same Day Change Eligible' ;
    rdfs:comment 'Indicates whether tickets issued in this fare class qualify for same-day confirmed flight changes (True) or are restricted to the originally booked flight (False). Drives customer service agent workflows in the Amadeus Altéa PSS and is a key commercial differentiator between fare products.' ;
    rdfs:domain ind:FareClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:seatSelectionIncluded rdf:type rdf:Property ;
    rdfs:label 'Seat Selection Included' ;
    rdfs:comment 'Indicates whether advance seat selection is included at no additional charge for passengers booking this fare class (True) or whether seat selection requires an additional ancillary fee (False). Drives ancillary seat revenue calculation and the seat map availability display in the booking engine.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standbyEligible rdf:type rdf:Property ;
    rdfs:label 'Standby Eligible' ;
    rdfs:comment 'Indicates whether passengers holding tickets in this fare class may be placed on the standby list for an earlier or alternative flight at no additional charge (True) or are restricted from standby (False). Relevant for same-day change and irregular operations (IROP) reprotection workflows.' ;
    rdfs:domain ind:FareClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:yieldClassRank rdf:type rdf:Property ;
    rdfs:label 'Yield Class Rank' ;
    rdfs:comment 'Ordinal ranking of this RBD within its cabin by revenue yield, where 1 represents the highest-yielding (most expensive) booking class and higher numbers represent progressively lower-yielding classes. Used by the revenue management system to sequence inventory bucket availability — higher-ranked (lower-yield) classes are closed first as load factor increases, protecting higher-yield inventory. Directly drives RASK (Revenue per Available Seat Kilometer) optimization logic.' ;
    rdfs:domain ind:FareClass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pricingRecordId rdf:type rdf:Property ;
    rdfs:label 'Pricing Record Id' ;
    rdfs:comment 'Unique surrogate identifier for each pricing calculation event generated by the pricing engine. Primary key of this table.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PricingRecord .

ind:agencyId rdf:type rdf:Property ;
    rdfs:label 'Agency Id' ;
    rdfs:comment 'Foreign key linking to revenue.agency. Business justification: Pricing quotes generated for travel agencies should reference the agency master. This enables agency-specific pricing and commission tracking. Standard N:1 relationship. No bidirectional conflict.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Agency .

ind:ancillaryBundleId rdf:type rdf:Property ;
    rdfs:label 'Ancillary Bundle Id' ;
    rdfs:comment 'Foreign key linking to ancillary.bundle. Business justification: Pricing quotes in airline reservation systems must track which fare family/ancillary bundle was selected during shopping. Revenue management and offer construction depend on this link to calculate tot' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Bundle .

ind:corporateContractId rdf:type rdf:Property ;
    rdfs:label 'Corporate Contract Id' ;
    rdfs:comment 'Foreign key linking to revenue.corporate_contract. Business justification: Pricing calculations can apply corporate contract discounts. This links the pricing event to the contract being applied. Standard N:1 relationship. No bidirectional conflict.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CorporateContract .

ind:fareQuoteId rdf:type rdf:Property ;
    rdfs:label 'Fare Quote Id' ;
    rdfs:comment 'The native quote or pricing solution identifier assigned by the GDS (e.g., Sabre, Amadeus, Travelport) when the fare was priced through a GDS channel. Null for direct or NDC-sourced pricing. Used for GDS billing reconciliation.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FareQuote .

ind:taxFeeId rdf:type rdf:Property ;
    rdfs:label 'Tax Fee Id' ;
    rdfs:comment 'Foreign key linking to the tax/fee reference master record that defines the tax type, rate, and remittance rules.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TaxFee .

ind:validatingCarrierId rdf:type rdf:Property ;
    rdfs:label 'Validating Carrier Id' ;
    rdfs:comment 'Foreign key linking to route.carrier. Business justification: The validating carrier on a pricing record is the BSP settlement party. Carrier-level pricing analytics, NDC offer management, and BSP remittance reconciliation require linking pricing records to the ' ;
    rdfs:domain ind:PricingRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:appliedAmount rdf:type rdf:Property ;
    rdfs:label 'Applied Amount' ;
    rdfs:comment 'The actual monetary amount of this tax or fee applied to this specific pricing record. May differ from the reference rate_amount on tax_fee due to proration across segments, minimum/maximum caps, or passenger-type exemptions. This is the amount that appears on the ticket and is remitted to the collecting authority.' ;
    rdfs:domain ind:PricingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseFareAmount rdf:type rdf:Property ;
    rdfs:label 'Base Fare Amount' ;
    rdfs:comment 'The net fare amount before taxes, fees, and surcharges, expressed in the pricing currency. Represents the airline\'s revenue component used for yield and RASK calculations. Part of the MONETARY_TRIPLET.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:calculationBasis rdf:type rdf:Property ;
    rdfs:label 'Calculation Basis' ;
    rdfs:comment 'The monetary or numeric value against which the tax rate was applied to derive the applied_amount. For ad valorem taxes, this is the base fare amount; for per-segment taxes, this is the segment count; for flat taxes, this is 1. Enables audit and reconciliation of the tax calculation.' ;
    rdfs:domain ind:PricingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:carrierSurchargeAmount rdf:type rdf:Property ;
    rdfs:label 'Carrier Surcharge Amount' ;
    rdfs:comment 'Total carrier-imposed surcharges (YQ fuel surcharge and YR carrier-imposed fees) applied to this fare. Distinct from government taxes; retained by the carrier. Critical for revenue accounting and BSP settlement reconciliation.' ;
    rdfs:domain ind:PricingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:changeableFlag rdf:type rdf:Property ;
    rdfs:label 'Changeable Flag' ;
    rdfs:comment 'Indicates whether the priced fare permits voluntary changes (True) or is a no-change fare (False). If True, change fees and fare difference rules from the fare basis apply.' ;
    rdfs:domain ind:PricingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:equivalentFareAmount rdf:type rdf:Property ;
    rdfs:label 'Equivalent Fare Amount' ;
    rdfs:comment 'Base fare amount converted to IATA Neutral Units of Construction (NUC) or the airline\'s reporting currency equivalent. Used for international fare construction, proration, and interline settlement where fares are built in NUC and converted via IATA Rate of Exchange (ROE).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exemptFlag rdf:type rdf:Property ;
    rdfs:label 'Exempt Flag' ;
    rdfs:comment 'Indicates whether the passenger was exempt from this tax on this specific pricing record (e.g., diplomatic exemption, infant exemption, government traveller exemption). When true, the applied_amount is zero but the tax line is retained for audit and regulatory reporting purposes.' ;
    rdfs:domain ind:PricingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:formOfPaymentRestriction rdf:type rdf:Property ;
    rdfs:label 'Form Of Payment Restriction' ;
    rdfs:comment 'Any restriction on the form of payment permitted for this fare. NONE = no restriction; CREDIT_CARD_ONLY = must be paid by credit card; CASH_ONLY = cash payment required; SPECIFIC_CARD = restricted to a specific card type or issuer; MILES_ONLY = award redemption only. Impacts checkout and payment processing.' ;
    rdfs:domain ind:PricingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iataRateOfExchange rdf:type rdf:Property ;
    rdfs:label 'Iata Rate Of Exchange' ;
    rdfs:comment 'The IATA-published Rate of Exchange (ROE) used to convert the NUC fare amount to the local pricing currency at the time of pricing. Required for international fare construction and interline proration under IATA Resolution 722.' ;
    rdfs:domain ind:PricingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxStayRequirement rdf:type rdf:Property ;
    rdfs:label 'Max Stay Requirement' ;
    rdfs:comment 'Maximum stay condition attached to the fare rule (e.g., \'1M\' for one month, \'30D\' for 30 days). Null if no maximum stay applies. Constrains the return travel date for round-trip fares.' ;
    rdfs:domain ind:PricingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minStayRequirement rdf:type rdf:Property ;
    rdfs:label 'Min Stay Requirement' ;
    rdfs:comment 'Minimum stay condition attached to the fare rule (e.g., \'SU\' for Sunday night stay, \'3D\' for 3 days). Null if no minimum stay applies. Used for round-trip fare rule validation.' ;
    rdfs:domain ind:PricingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ndcOfferReference rdf:type rdf:Property ;
    rdfs:label 'Ndc Offer Reference' ;
    rdfs:comment 'Unique offer identifier assigned by the airline\'s NDC offer engine when the fare was priced via an IATA NDC-compliant channel. Null for GDS or legacy-sourced pricing. Enables NDC order management and settlement.' ;
    rdfs:domain ind:PricingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pnrLocator rdf:type rdf:Property ;
    rdfs:label 'Pnr Locator' ;
    rdfs:comment 'Six-character alphanumeric booking reference (PNR locator) in the Passenger Service System (PSS) to which this pricing record is associated. Links the fare quote to the reservation context.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingDate rdf:type rdf:Property ;
    rdfs:label 'Pricing Date' ;
    rdfs:comment 'The calendar date on which the fare was priced. Used to determine applicable fare rules, advance purchase requirements, and seasonality. Distinct from the ticketing date and travel date.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pricingSource rdf:type rdf:Property ;
    rdfs:label 'Pricing Source' ;
    rdfs:comment 'The distribution channel or system through which this fare was priced. GDS = Global Distribution System (e.g., Amadeus, Sabre, Travelport); DIRECT = airline direct website/app; NDC = IATA New Distribution Capability; API = third-party API; INTERLINE = interline agreement pricing; CODESHARE = codeshare partner pricing.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingStatus rdf:type rdf:Property ;
    rdfs:label 'Pricing Status' ;
    rdfs:comment 'Current lifecycle state of the pricing record. QUOTED = fare quote generated but not yet ticketed; TICKETED = fare has been issued as an e-ticket; EXPIRED = ticketing time limit passed without issuance; CANCELLED = booking cancelled; REPRICED = superseded by a subsequent pricing event; VOIDED = ticket voided post-issuance.' ;
    rdfs:domain ind:PricingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Pricing Timestamp' ;
    rdfs:comment 'The exact date and time (UTC) when the pricing engine generated this fare quote or pricing calculation. Represents the principal business event time for this transaction. Conforms to yyyy-MM-ddTHH:mm:ss.SSSXXX format.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:quoteReference rdf:type rdf:Property ;
    rdfs:label 'Quote Reference' ;
    rdfs:comment 'Externally-known unique identifier assigned by the pricing engine (Sabre AirVision) to this specific fare quote or pricing calculation event. Used for audit trail and repricing reconciliation.' ;
    rdfs:domain ind:PricingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundableFlag rdf:type rdf:Property ;
    rdfs:label 'Refundable Flag' ;
    rdfs:comment 'Indicates whether the priced fare is refundable (True) or non-refundable (False) per the applicable fare rules. Critical for customer service, revenue protection, and DOT consumer protection compliance.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:returnDate rdf:type rdf:Property ;
    rdfs:label 'Return Date' ;
    rdfs:comment 'The scheduled departure date of the return journey for round-trip fares. Null for one-way fares. Used for minimum/maximum stay rule validation in fare construction.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:routingCode rdf:type rdf:Property ;
    rdfs:label 'Routing Code' ;
    rdfs:comment 'IATA routing code or routing number associated with the fare basis, specifying permitted intermediate points and carrier combinations for the priced itinerary. Governs which connecting points are allowed under the fare rules.' ;
    rdfs:domain ind:PricingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentCount rdf:type rdf:Property ;
    rdfs:label 'Segment Count' ;
    rdfs:comment 'Total number of flight segments (individual flight legs) included in the priced itinerary. Used to identify direct vs. connecting itineraries and for proration calculations on multi-segment fares.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:taxAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Amount' ;
    rdfs:comment 'Aggregate of all government-imposed taxes applied to this fare (e.g., US Federal Excise Tax, PFC, international departure/arrival taxes). Collected on behalf of taxing authorities and remitted via BSP/ARC. Part of the MONETARY_TRIPLET.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Sequence Number' ;
    rdfs:comment 'The IATA-mandated display order of this tax line within the full tax breakdown for the pricing record. Determines the order in which taxes appear on the ticket and in BSP/ARC settlement files. Sequence is specific to this pricing record\'s tax manifest.' ;
    rdfs:domain ind:PricingRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ticketingTimeLimit rdf:type rdf:Property ;
    rdfs:label 'Ticketing Time Limit' ;
    rdfs:comment 'The deadline by which the e-ticket must be issued to honour this fare quote. After this timestamp, the fare quote expires and the booking must be repriced. Critical for revenue management and seat inventory control.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:totalFareAmount rdf:type rdf:Property ;
    rdfs:label 'Total Fare Amount' ;
    rdfs:comment 'Total amount payable by the passenger: base fare + taxes + carrier surcharges. This is the amount displayed to the customer and collected at ticketing. Represents the net total in the MONETARY_TRIPLET. Compliant with DOT full-fare advertising rules.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:travelDate rdf:type rdf:Property ;
    rdfs:label 'Travel Date' ;
    rdfs:comment 'The scheduled departure date of the first flight segment in the priced itinerary. Used for advance purchase rule validation, seasonality determination, and revenue period attribution.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tripType rdf:type rdf:Property ;
    rdfs:label 'Trip Type' ;
    rdfs:comment 'Classification of the itinerary structure. OW = One-Way; RT = Round-Trip; OJ = Open-Jaw; CT = Circle Trip. Determines fare construction method and applicable fare rules under IATA Resolution 722.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stationId rdf:type rdf:Property ;
    rdfs:label 'Station Id' ;
    rdfs:comment 'Foreign key linking to airport.station. Business justification: Airport-specific taxes and fees (Passenger Facility Charges, airport improvement fees, departure taxes) are directly tied to a specific station. The station FK enables tax applicability validation, PF' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Station .

ind:applicabilityScope rdf:type rdf:Property ;
    rdfs:label 'Applicability Scope' ;
    rdfs:comment 'Indicates whether the tax or fee applies to domestic itineraries, international itineraries, or both. A key filter used by the pricing engine when constructing the tax breakdown for a ticket.' ;
    rdfs:domain ind:TaxFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cabinClassApplicability rdf:type rdf:Property ;
    rdfs:label 'Cabin Class Applicability' ;
    rdfs:comment 'Specifies the cabin class to which this tax or fee applies: all (applies regardless of cabin), economy, premium_economy, business, first. Certain taxes (e.g., UK Air Passenger Duty Band B) vary by cabin class.' ;
    rdfs:domain ind:TaxFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:calculationMethod rdf:type rdf:Property ;
    rdfs:label 'Calculation Method' ;
    rdfs:comment 'Defines how the tax or fee amount is computed: flat_amount (fixed monetary amount per occurrence), ad_valorem_percent (percentage of the applicable fare or charge base), per_segment (charged once per flight segment), per_coupon (charged per ticket coupon), per_pax_per_direction (charged per passenger per direction of travel). Drives the pricing engine calculation logic.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectingAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Collecting Authority Name' ;
    rdfs:comment 'Full legal name of the authority or entity to which the collected tax or fee must be remitted (e.g., \'Internal Revenue Service\', \'Heathrow Airport Holdings\', \'EUROCONTROL\'). Used in remittance instructions and regulatory filings.' ;
    rdfs:domain ind:TaxFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectingAuthorityType rdf:type rdf:Property ;
    rdfs:label 'Collecting Authority Type' ;
    rdfs:comment 'Category of the entity legally mandated to collect and remit the tax or fee: government (national or sub-national tax authority), airport_operator (airport authority or concessionaire), carrier (airline collecting on behalf of itself), intergovernmental (body such as EUROCONTROL). Determines remittance workflow and BSP/ARC settlement routing.' ;
    rdfs:domain ind:TaxFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:corsiaApplicable rdf:type rdf:Property ;
    rdfs:label 'Corsia Applicable' ;
    rdfs:comment 'Indicates whether this tax or fee is related to or counts toward CORSIA (Carbon Offsetting and Reduction Scheme for International Aviation) compliance obligations (True) or is unrelated to carbon/environmental compliance (False).' ;
    rdfs:domain ind:TaxFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exemptPassengerTypes rdf:type rdf:Property ;
    rdfs:label 'Exempt Passenger Types' ;
    rdfs:comment 'Comma-separated list of IATA Passenger Type Codes (PTCs) or categories that are legally exempt from this tax or fee (e.g., \'INF,DIP,GOV\' for infants, diplomatic, and government passengers). Null if no exemptions apply. Used by the pricing engine to suppress the tax for qualifying passengers.' ;
    rdfs:domain ind:TaxFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccountCode rdf:type rdf:Property ;
    rdfs:label 'Gl Account Code' ;
    rdfs:comment 'The SAP S/4HANA general ledger account code to which collected amounts for this tax or fee are posted in the revenue accounting system. Ensures correct financial reporting and tax liability tracking on the balance sheet.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iataTaxCategory rdf:type rdf:Property ;
    rdfs:label 'Iata Tax Category' ;
    rdfs:comment 'IATA-defined category distinguishing the nature of the charge as published in the IATA Tax Code Directory: tax (government-mandated levy), fee (service-based charge), charge (airport or infrastructure charge), surcharge (carrier-imposed additional charge such as fuel surcharge YQ/YR).' ;
    rdfs:domain ind:TaxFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Amount' ;
    rdfs:comment 'The maximum monetary amount of the tax or fee that may be collected, capping the calculated value. Applicable to ad_valorem_percent taxes with a legislated ceiling. Denominated in currency_code. Null if no cap applies.' ;
    rdfs:domain ind:TaxFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Amount' ;
    rdfs:comment 'The minimum monetary amount of the tax or fee that must be collected, regardless of the calculated value. Applicable primarily to ad_valorem_percent taxes where the computed amount could fall below a legislated floor. Denominated in currency_code.' ;
    rdfs:domain ind:TaxFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:passengerTypeApplicability rdf:type rdf:Property ;
    rdfs:label 'Passenger Type Applicability' ;
    rdfs:comment 'Specifies which IATA passenger type codes (PTCs) are subject to this tax or fee: all (applies to every passenger type), adult, child, infant, unaccompanied_minor. Certain taxes (e.g., UK APD) have reduced or zero rates for infants.' ;
    rdfs:domain ind:TaxFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publishedDate rdf:type rdf:Property ;
    rdfs:label 'Published Date' ;
    rdfs:comment 'The date on which the collecting authority officially published or announced this tax or fee rate or rule change. Distinct from effective_date; used for advance notice compliance tracking and pricing team workflow management.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rateAmount rdf:type rdf:Property ;
    rdfs:label 'Rate Amount' ;
    rdfs:comment 'The monetary amount or percentage rate of the tax or fee. For flat_amount and per-segment/per-coupon types, this is the fixed charge value. For ad_valorem_percent, this is the percentage rate (e.g., 7.5 for 7.5%). Interpreted in conjunction with calculation_method.' ;
    rdfs:domain ind:TaxFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reference' ;
    rdfs:comment 'Citation of the specific legislation, regulation, or IATA resolution that mandates or authorizes this tax or fee (e.g., \'US Internal Revenue Code Section 4261\', \'UK Finance Act 1994 Section 28\', \'IATA Resolution 728\'). Supports regulatory compliance documentation and audit.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remittanceChannel rdf:type rdf:Property ;
    rdfs:label 'Remittance Channel' ;
    rdfs:comment 'The settlement channel through which collected tax amounts are remitted: bsp (IATA Billing and Settlement Plan), arc (Airlines Reporting Corporation), direct_to_authority (direct payment to government or airport), interline_settlement (via interline billing agreement). Drives the revenue accounting remittance workflow.' ;
    rdfs:domain ind:TaxFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:remittanceDestinationCode rdf:type rdf:Property ;
    rdfs:label 'Remittance Destination Code' ;
    rdfs:comment 'Standardized code identifying the remittance destination account or clearing body (e.g., BSP country code, ARC settlement code, or government tax authority reference). Used by revenue accounting to route tax remittance payments correctly.' ;
    rdfs:domain ind:TaxFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeSpecific rdf:type rdf:Property ;
    rdfs:label 'Route Specific' ;
    rdfs:comment 'Indicates whether this tax or fee is applicable only to specific origin-destination route pairs (True) or applies broadly based on country/airport-level rules (False). When True, origin_country_code, destination_country_code, and/or airport_code fields define the specific applicability.' ;
    rdfs:domain ind:TaxFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sapTaxCode rdf:type rdf:Property ;
    rdfs:label 'Sap Tax Code' ;
    rdfs:comment 'The corresponding tax code as configured in SAP S/4HANA FI/CO module for general ledger posting and tax remittance processing. Enables automated mapping between the IATA tax_code and the SAP financial accounting tax configuration for revenue accounting.' ;
    rdfs:domain ind:TaxFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByTaxCode rdf:type rdf:Property ;
    rdfs:label 'Superseded By Tax Code' ;
    rdfs:comment 'The IATA tax code of the successor record when this tax or fee has been superseded (status = superseded). Enables the pricing engine and revenue accounting to trace the lineage of tax code changes and apply the correct current code.' ;
    rdfs:domain ind:TaxFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxBasis rdf:type rdf:Property ;
    rdfs:label 'Tax Basis' ;
    rdfs:comment 'The fare component or amount upon which an ad_valorem_percent tax is calculated: base_fare (net fare excluding taxes), total_fare (gross fare including other charges), fuel_surcharge (applied only to the YQ/YR surcharge component), carrier_imposed_fee, ticket_price. Relevant only for ad_valorem_percent calculation_method.' ;
    rdfs:domain ind:TaxFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCode rdf:type rdf:Property ;
    rdfs:label 'Tax Code' ;
    rdfs:comment 'IATA-standard two-to-four character alphanumeric code uniquely identifying the tax or fee (e.g., US, YQ, YR, GB, DE). Used by pricing engines, GDS, and BSP settlement to identify and apply the correct charge on a ticket.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxFeeStatus rdf:type rdf:Property ;
    rdfs:label 'Tax Fee Status' ;
    rdfs:comment 'Lifecycle status of the tax or fee record: active (currently in force and applicable), inactive (no longer applicable), superseded (replaced by a newer version of the same tax code), pending (approved but not yet effective). Controls whether the pricing engine includes this record in tax calculations.' ;
    rdfs:domain ind:TaxFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxName rdf:type rdf:Property ;
    rdfs:label 'Tax Name' ;
    rdfs:comment 'Full descriptive name of the tax or fee as published by the collecting authority (e.g., \'US Federal Excise Tax\', \'UK Air Passenger Duty\', \'Airport Passenger Facility Charge\'). Displayed on passenger itineraries and tax remittance reports.' ;
    rdfs:domain ind:TaxFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxType rdf:type rdf:Property ;
    rdfs:label 'Tax Type' ;
    rdfs:comment 'High-level classification of the charge: government_tax (legislated by a national or regional authority), airport_charge (levied by an airport operator), carrier_surcharge (carrier-imposed fee such as fuel or insurance surcharge), security_fee (security-related government levy), passenger_facility_charge (PFC levied by US airports under FAA authority), environmental_levy (carbon or environmental charge such as CORSIA). [ENUM-REF-CANDIDATE: government_tax|airport_charge|carrier_surcharge|security_fee|passenger_facility_charge|environmental_levy|other — promote to reference product]' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ticketTypeApplicability rdf:type rdf:Property ;
    rdfs:label 'Ticket Type Applicability' ;
    rdfs:comment 'Specifies the ticket document type to which this tax or fee applies: all, e_ticket (electronic ticket), paper_ticket, emd (Electronic Miscellaneous Document). Most modern taxes apply to all ticket types, but some legacy charges are document-type-specific.' ;
    rdfs:domain ind:TaxFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionNumber rdf:type rdf:Property ;
    rdfs:label 'Version Number' ;
    rdfs:comment 'Sequential version number of this tax or fee record, incremented each time the rate, rules, or applicability conditions are updated by the collecting authority. Enables historical rate tracking and audit trail for tax remittance reconciliation.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:waivable rdf:type rdf:Property ;
    rdfs:label 'Waivable' ;
    rdfs:comment 'Indicates whether the carrier has authority to waive this tax or fee under specific circumstances (True) or whether collection is legally mandatory and cannot be waived (False). Relevant for IROP (Irregular Operations) handling and diplomatic/government fare exemptions.' ;
    rdfs:domain ind:TaxFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvedBy rdf:type rdf:Property ;
    rdfs:label 'Approved By' ;
    rdfs:comment 'Name or employee identifier of the Revenue Manager who authorized this yield parameter configuration for production use. Supports audit trail and governance accountability.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookingClassThresholdCount rdf:type rdf:Property ;
    rdfs:label 'Booking Class Threshold Count' ;
    rdfs:comment 'Number of booking class availability thresholds (authorization levels) configured for this yield parameter set. Defines how many fare class buckets are actively managed by the RM optimization engine.' ;
    rdfs:domain ind:YieldParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cancellationRate rdf:type rdf:Property ;
    rdfs:label 'Cancellation Rate' ;
    rdfs:comment 'Historical booking cancellation rate (0.0000–1.0000) for this market or route, used alongside no-show rate to calibrate overbooking levels and availability controls.' ;
    rdfs:domain ind:YieldParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:caskBenchmark rdf:type rdf:Property ;
    rdfs:label 'Cask Benchmark' ;
    rdfs:comment 'Cost per Available Seat Kilometer (CASK) benchmark in the operating currency used as the cost floor reference for yield optimization decisions. Sourced from SAP S/4HANA FI/CO cost accounting.' ;
    rdfs:domain ind:YieldParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dilutionTolerance rdf:type rdf:Property ;
    rdfs:label 'Dilution Tolerance' ;
    rdfs:comment 'Maximum acceptable revenue dilution rate — the percentage of passengers who could have paid a higher fare but were sold a lower fare class. Constrains how aggressively lower booking classes are opened.' ;
    rdfs:domain ind:YieldParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dynamicPricingCeiling rdf:type rdf:Property ;
    rdfs:label 'Dynamic Pricing Ceiling' ;
    rdfs:comment 'Maximum fare amount (in operating currency) above which the dynamic pricing engine is not permitted to set a fare for this market or route. Prevents consumer protection violations and brand damage.' ;
    rdfs:domain ind:YieldParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dynamicPricingEnabled rdf:type rdf:Property ;
    rdfs:label 'Dynamic Pricing Enabled' ;
    rdfs:comment 'Indicates whether dynamic (continuous) pricing is enabled for this yield parameter configuration. When true, the RM engine applies real-time fare adjustments within authorized bounds rather than discrete fare class steps.' ;
    rdfs:domain ind:YieldParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dynamicPricingFloor rdf:type rdf:Property ;
    rdfs:label 'Dynamic Pricing Floor' ;
    rdfs:comment 'Minimum fare amount (in operating currency) below which the dynamic pricing engine is not permitted to set a fare for this market or route. Protects against revenue dilution under automated pricing.' ;
    rdfs:domain ind:YieldParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:forecastHorizonDays rdf:type rdf:Property ;
    rdfs:label 'Forecast Horizon Days' ;
    rdfs:comment 'Number of days ahead for which the demand forecast is generated and applied in yield optimization. Defines the planning window for booking class availability controls.' ;
    rdfs:domain ind:YieldParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:forecastModelType rdf:type rdf:Property ;
    rdfs:label 'Forecast Model Type' ;
    rdfs:comment 'Type of demand forecasting model applied by the RM optimization engine for this parameter set. Determines how historical booking curves and pickup patterns are weighted in availability decisions.' ;
    rdfs:domain ind:YieldParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupBookingThreshold rdf:type rdf:Property ;
    rdfs:label 'Group Booking Threshold' ;
    rdfs:comment 'Minimum number of passengers (Pax) that qualifies a booking as a group booking, triggering separate group inventory controls and pricing rules distinct from individual seat availability management.' ;
    rdfs:domain ind:YieldParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:historicalWeight rdf:type rdf:Property ;
    rdfs:label 'Historical Weight' ;
    rdfs:comment 'Weighting factor (0.0000–1.0000) applied to historical booking data in the blended demand forecast model. Higher values favor historical patterns; lower values favor recent pickup trends. Must sum to 1.0 with pickup_weight.' ;
    rdfs:domain ind:YieldParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastReviewedDate rdf:type rdf:Property ;
    rdfs:label 'Last Reviewed Date' ;
    rdfs:comment 'Date on which this yield parameter configuration was most recently reviewed by the Revenue Management team. Supports governance tracking and parameter staleness detection.' ;
    rdfs:domain ind:YieldParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:loadFactorMinimum rdf:type rdf:Property ;
    rdfs:label 'Load Factor Minimum' ;
    rdfs:comment 'Minimum acceptable load factor threshold below which the RM system triggers promotional availability or fare class opening actions. Expressed as a percentage (0.00–100.00).' ;
    rdfs:domain ind:YieldParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:loadFactorTarget rdf:type rdf:Property ;
    rdfs:label 'Load Factor Target' ;
    rdfs:comment 'Target load factor (percentage of available seats filled with revenue passengers) for this market or route configuration. Expressed as a percentage (0.00–100.00). Balances spoilage risk against dilution risk in RM optimization.' ;
    rdfs:domain ind:YieldParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumYieldFloor rdf:type rdf:Property ;
    rdfs:label 'Minimum Yield Floor' ;
    rdfs:comment 'Minimum acceptable yield (revenue per Revenue Passenger Kilometer) below which seat inventory must not be sold. Acts as the absolute revenue protection floor in bid price calculations. Expressed in operating currency per RPK.' ;
    rdfs:domain ind:YieldParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:noShowRate rdf:type rdf:Property ;
    rdfs:label 'No Show Rate' ;
    rdfs:comment 'Historical no-show rate (0.0000–1.0000) for this market or route, used as an input to overbooking authorization calculations. Sourced from Amadeus Altéa PSS departure control data.' ;
    rdfs:domain ind:YieldParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:odControlEnabled rdf:type rdf:Property ;
    rdfs:label 'Od Control Enabled' ;
    rdfs:comment 'Indicates whether origin-destination (O&D) network revenue management control is active for this parameter set. When true, the RM engine optimizes across connecting itineraries rather than leg-by-leg.' ;
    rdfs:domain ind:YieldParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optimizationMethod rdf:type rdf:Property ;
    rdfs:label 'Optimization Method' ;
    rdfs:comment 'Optimization algorithm applied by Sabre AirVision for seat inventory allocation under this parameter set. EMSR-A and EMSR-B are Expected Marginal Seat Revenue variants; LP-based and network bid price methods support O&D (origin-destination) optimization.' ;
    rdfs:domain ind:YieldParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overbookingAuthorizationRate rdf:type rdf:Property ;
    rdfs:label 'Overbooking Authorization Rate' ;
    rdfs:comment 'Authorized overbooking percentage above physical seat capacity for this market or route. Expressed as a percentage above 100% (e.g., 5.00 means 5% above capacity). Governed by DOT consumer protection regulations and airline denied boarding policy.' ;
    rdfs:domain ind:YieldParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:parameterCode rdf:type rdf:Property ;
    rdfs:label 'Parameter Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this yield parameter configuration within Sabre AirVision RM. Used for cross-system reference and audit trails.' ;
    rdfs:domain ind:YieldParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parameterDescription rdf:type rdf:Property ;
    rdfs:label 'Parameter Description' ;
    rdfs:comment 'Free-text description providing business context for this yield parameter configuration, including rationale for non-standard settings, market conditions, or special events driving the configuration.' ;
    rdfs:domain ind:YieldParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parameterName rdf:type rdf:Property ;
    rdfs:label 'Parameter Name' ;
    rdfs:comment 'Human-readable name describing the yield parameter configuration, e.g., \'TRANSATLANTIC_PEAK_SUMMER_2025\'. Used for display and reporting in revenue management dashboards.' ;
    rdfs:domain ind:YieldParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parameterStatus rdf:type rdf:Property ;
    rdfs:label 'Parameter Status' ;
    rdfs:comment 'Current lifecycle state of the yield parameter configuration record. Active records are applied by the RM optimization engine; draft records are under review; archived records are retained for historical analysis.' ;
    rdfs:domain ind:YieldParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parameterType rdf:type rdf:Property ;
    rdfs:label 'Parameter Type' ;
    rdfs:comment 'Categorizes the scope at which this yield parameter applies: market-level, route-level, flight-group-level, cabin-level, or global default. Determines the optimization hierarchy in Sabre AirVision.' ;
    rdfs:domain ind:YieldParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickupWeight rdf:type rdf:Property ;
    rdfs:label 'Pickup Weight' ;
    rdfs:comment 'Weighting factor (0.0000–1.0000) applied to recent booking pickup trend data in the blended demand forecast model. Complements historical_weight; both must sum to 1.0.' ;
    rdfs:domain ind:YieldParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:raskTarget rdf:type rdf:Property ;
    rdfs:label 'Rask Target' ;
    rdfs:comment 'Target Revenue per Available Seat Kilometer (RASK) in the operating currency for this market or route configuration. Expressed as revenue per ASK. Used as the primary revenue performance benchmark in RM optimization.' ;
    rdfs:domain ind:YieldParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reviewFrequency rdf:type rdf:Property ;
    rdfs:label 'Review Frequency' ;
    rdfs:comment 'Scheduled frequency at which the Revenue Management team reviews and potentially updates this yield parameter configuration. Drives the RM governance and parameter maintenance workflow.' ;
    rdfs:domain ind:YieldParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:spoilageTolerance rdf:type rdf:Property ;
    rdfs:label 'Spoilage Tolerance' ;
    rdfs:comment 'Maximum acceptable seat spoilage rate (percentage of seats departing empty) tolerated before the RM system adjusts availability controls to open lower fare classes. Expressed as a percentage.' ;
    rdfs:domain ind:YieldParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ticketId rdf:type rdf:Property ;
    rdfs:label 'Ticket Id' ;
    rdfs:comment 'Primary key for ticket' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Ticket .

ind:bspSettlementId rdf:type rdf:Property ;
    rdfs:label 'Bsp Settlement Id' ;
    rdfs:comment 'Foreign key linking to revenue.bsp_settlement. Business justification: Tickets sold through BSP channels are included in BSP settlement batches. The ticket should reference which BSP settlement batch it was included in. This is a temporal FK (populated during billing cyc' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BspSettlement .

ind:companyCodeId rdf:type rdf:Property ;
    rdfs:label 'Company Code Id' ;
    rdfs:comment 'Foreign key linking to finance.company_code. Business justification: Every ticket is issued by a legal entity (company code) for IFRS 15 revenue recognition, consolidated financial reporting, and regulatory compliance. Essential for multi-entity airline groups.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CompanyCode .

ind:ffpMemberId rdf:type rdf:Property ;
    rdfs:label 'Ffp Member Id' ;
    rdfs:comment 'Foreign key linking to loyalty.ffp_member. Business justification: Tickets must track FFP member for mileage accrual posting, tier recognition, and revenue attribution. Core operational link between revenue capture and loyalty program. Replaces denormalized ffp_membe' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FfpMember .

ind:issuingCrewMemberId rdf:type rdf:Property ;
    rdfs:label 'Issuing Crew Member Id' ;
    rdfs:comment 'Foreign key linking to crew.crew_member. Business justification: Tracks crew member who manually issued ticket at airport counter/service desk. Required for crew sales performance tracking, commission calculation for crew-issued tickets, and audit trail. Existing i' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Member .

ind:ticketingCarrierId rdf:type rdf:Property ;
    rdfs:label 'Ticketing Carrier Id' ;
    rdfs:comment 'Foreign key linking to route.carrier. Business justification: The ticketing carrier is the BSP settlement party responsible for the ticket. Carrier-level revenue accounting, BSP remittance reconciliation, and IATA billing require linking tickets to the authorita' ;
    rdfs:domain ind:Ticket ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:travelIdentityDocumentId rdf:type rdf:Property ;
    rdfs:label 'Travel Identity Document Id' ;
    rdfs:comment 'Foreign key linking to passenger.travel_identity_document. Business justification: APIS/Secure Flight compliance requires airlines to link each issued ticket to the specific identity document verified at ticketing. Regulators (TSA, ICAO) mandate this audit trail. Aviation compliance' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TravelIdentityDocument .

ind:conjunctionTicketIndicator rdf:type rdf:Property ;
    rdfs:label 'Conjunction Ticket Indicator' ;
    rdfs:comment 'Flag indicating whether this ticket is part of a conjunction ticket set (multiple ticket documents covering a single itinerary exceeding 4 coupons). True = conjunction ticket; False = standalone ticket. Required for correct coupon sequencing and BSP settlement.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conjunctionTicketNumber rdf:type rdf:Property ;
    rdfs:label 'Conjunction Ticket Number' ;
    rdfs:comment 'The 13-digit ticket number of the related conjunction ticket document in the same set. Populated only when conjunction_ticket_indicator is True. Enables full itinerary reconstruction across multiple ticket documents.' ;
    rdfs:domain ind:Ticket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:couponCount rdf:type rdf:Property ;
    rdfs:label 'Coupon Count' ;
    rdfs:comment 'Number of flight coupons (individual flight segments) contained within this ticket document. Standard tickets carry 1–4 coupons. Used for itinerary completeness validation and conjunction ticket detection.' ;
    rdfs:domain ind:Ticket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:endorsementRestrictionText rdf:type rdf:Property ;
    rdfs:label 'Endorsement Restriction Text' ;
    rdfs:comment 'Free-text endorsement and restriction field printed on the ticket indicating fare conditions such as \'NON-ENDORSE/NON-REROUTE\', \'VALID ON XX ONLY\', or interline restrictions. Governs reissue, refund, and exchange eligibility.' ;
    rdfs:domain ind:Ticket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ffpMilesEarned rdf:type rdf:Property ;
    rdfs:label 'Ffp Miles Earned' ;
    rdfs:comment 'Number of frequent flyer miles/points accrued on this ticket based on the fare basis, booking class, and FFP tier. Zero for award tickets (fare_type=FFP) or non-accruing fares. Feeds Oracle Loyalty Cloud for member account crediting.' ;
    rdfs:domain ind:Ticket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:formOfPaymentDetail rdf:type rdf:Property ;
    rdfs:label 'Form Of Payment Detail' ;
    rdfs:comment 'Masked payment instrument detail, e.g., last 4 digits of credit card number with card type prefix (VISA****1234) or bank reference. Stored in masked/tokenised form per PCI DSS. Used for settlement reconciliation and chargeback management.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formOfPaymentType rdf:type rdf:Property ;
    rdfs:label 'Form Of Payment Type' ;
    rdfs:comment 'Code indicating the payment instrument used to purchase the ticket. CC=Credit Card, CA=Cash, CK=Check, TP=Tour Order/Prepaid, MS=Miscellaneous, EP=Electronic Payment/EMD. Drives BSP/ARC settlement routing and fraud monitoring. [ENUM-REF-CANDIDATE: CC|CA|CK|TP|MS|EP|GV|LO — promote to reference product]' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issueTimestamp rdf:type rdf:Property ;
    rdfs:label 'Issue Timestamp' ;
    rdfs:comment 'The exact date and time (UTC) at which the e-ticket was issued by the ticketing system. Serves as the principal business event timestamp for the ticket transaction lifecycle. Used in BSP/ARC reporting periods and revenue recognition. BUSINESS_EVENT_TIMESTAMP category.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:netRemitAmount rdf:type rdf:Property ;
    rdfs:label 'Net Remit Amount' ;
    rdfs:comment 'The net amount remitted to the airline after deducting agency commission and applicable incentives from the total fare. Used in BSP/ARC settlement reconciliation and airline revenue accounting in SAP S/4HANA FI.' ;
    rdfs:domain ind:Ticket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalTicketNumber rdf:type rdf:Property ;
    rdfs:label 'Original Ticket Number' ;
    rdfs:comment 'The 13-digit IATA ticket number of the original ticket when this record represents a reissued or exchanged ticket. Null for original issuances. Enables exchange chain tracing for revenue accounting and DOT consumer protection reporting.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passengerName rdf:type rdf:Property ;
    rdfs:label 'Passenger Name' ;
    rdfs:comment 'Full name of the ticketed passenger as printed on the ticket, in IATA PNR name format (SURNAME/FIRSTNAME TITLE). Stored on the ticket for check-in, boarding, and regulatory compliance. PII — restricted.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundAmount rdf:type rdf:Property ;
    rdfs:label 'Refund Amount' ;
    rdfs:comment 'The monetary amount refunded to the passenger when ticket_status is \'refunded\'. May be less than total_fare_amount due to cancellation penalties or non-refundable fare components. Used for revenue accounting and DOT refund compliance reporting.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:refundTimestamp rdf:type rdf:Property ;
    rdfs:label 'Refund Timestamp' ;
    rdfs:comment 'Date and time when a refund was processed for this ticket. Null for non-refunded tickets. Used for DOT consumer protection reporting (14 CFR Part 250), revenue reversal accounting, and refund SLA monitoring.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:saleCountryCode rdf:type rdf:Property ;
    rdfs:label 'Sale Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the country in which the ticket was sold. Determines applicable taxes, consumer protection regulations (DOT, EASA), and BSP/ARC settlement jurisdiction.' ;
    rdfs:domain ind:Ticket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxTotalAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Total Amount' ;
    rdfs:comment 'Aggregate of all government taxes, airport fees, and surcharges (e.g., PFC, September 11th Security Fee, fuel surcharge YQ/YR) applied to the ticket. Part of the MONETARY_TRIPLET adjustment component. Detailed tax breakdown is stored at coupon level.' ;
    rdfs:domain ind:Ticket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ticketStatus rdf:type rdf:Property ;
    rdfs:label 'Ticket Status' ;
    rdfs:comment 'Current state of the e-ticket in its lifecycle. \'open\' = issued and valid for travel; \'used\' = all coupons flown; \'refunded\' = fare returned to passenger; \'voided\' = cancelled within BSP/ARC void window; \'exchanged\' = reissued against a new ticket; \'lifted\' = coupon checked in and boarded. LIFECYCLE_STATUS category.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:voidTimestamp rdf:type rdf:Property ;
    rdfs:label 'Void Timestamp' ;
    rdfs:comment 'Date and time when the ticket was voided within the BSP/ARC void window (typically same-day or T+1). Null for non-voided tickets. Required for BSP/ARC void transaction reporting and revenue reversal in SAP S/4HANA.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ticketCouponId rdf:type rdf:Property ;
    rdfs:label 'Ticket Coupon Id' ;
    rdfs:comment 'Primary key for ticket_coupon' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TicketCoupon .

ind:marketingCarrierId rdf:type rdf:Property ;
    rdfs:label 'Marketing Carrier Id' ;
    rdfs:comment 'Foreign key linking to route.carrier. Business justification: Codeshare revenue accounting requires distinguishing the marketing carrier (sells the seat) from the operating carrier. Marketing carrier revenue share calculations and GDS distribution reporting depe' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:technicalLogId rdf:type rdf:Property ;
    rdfs:label 'Technical Log Id' ;
    rdfs:comment 'Foreign key linking to maintenance.technical_log. Business justification: Each ticket coupon represents a flown sector; the technical log records airworthiness state for that exact sector. Aviation operations link coupon-level flight data to the technical log for AOG impact' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TechnicalLog .

ind:workOrderId rdf:type rdf:Property ;
    rdfs:label 'Work Order Id' ;
    rdfs:comment 'Foreign key linking to maintenance.work_order. Business justification: Airlines track which maintenance work orders caused flight disruptions affecting specific ticket coupons for passenger compensation claims, revenue impact analysis, and operational performance reporti' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkOrder .

ind:actualDepartureDate rdf:type rdf:Property ;
    rdfs:label 'Actual Departure Date' ;
    rdfs:comment 'Actual calendar date on which the passenger departed on this coupon segment. May differ from scheduled departure date due to IROP (Irregular Operations), reprotection, or voluntary rebooking. Used for revenue recognition and OTP reporting.' ;
    rdfs:domain ind:TicketCoupon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:baggageAllowance rdf:type rdf:Property ;
    rdfs:label 'Baggage Allowance' ;
    rdfs:comment 'Free checked baggage allowance associated with this coupon, expressed either as piece concept (e.g., 2PC) or weight concept (e.g., 23KG) per IATA Resolution 302. Drives ancillary revenue opportunity identification and customer service.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:couponNumber rdf:type rdf:Property ;
    rdfs:label 'Coupon Number' ;
    rdfs:comment 'Sequential coupon number within the e-ticket (1 through 4), indicating the position of this flight segment in the itinerary. IATA mandates a maximum of four coupons per ticket.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:couponStatus rdf:type rdf:Property ;
    rdfs:label 'Coupon Status' ;
    rdfs:comment 'Current lifecycle status of the flight coupon per IATA coupon status codes: O=Open for use, A=Airport control (lifted), F=Flown/used, R=Refunded, V=Voided, S=Suspended, E=Exchanged, L=Lifted/boarded. SSOT for coupon-level revenue recognition and BSP/ARC coupon reporting. [ENUM-REF-CANDIDATE: O|A|F|R|V|S|E|L — promote to reference product]' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeTicketNumber rdf:type rdf:Property ;
    rdfs:label 'Exchange Ticket Number' ;
    rdfs:comment '13-digit ticket number of the original e-ticket that was exchanged to produce this coupon. Populated when coupon_status is E (Exchanged). Required for BSP/ARC exchange transaction reporting and revenue accounting audit trail.' ;
    rdfs:domain ind:TicketCoupon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fareAmount rdf:type rdf:Property ;
    rdfs:label 'Fare Amount' ;
    rdfs:comment 'Base fare amount allocated to this individual coupon segment in the ticket currency, before taxes and surcharges. Used for coupon-level revenue recognition, BSP/ARC settlement, and yield (revenue per RPK) calculation.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fareConstructionIndicator rdf:type rdf:Property ;
    rdfs:label 'Fare Construction Indicator' ;
    rdfs:comment 'Indicates the fare construction method applied to this coupon: NUC=Neutral Unit of Construction (IATA proration), SITI=Sold Inside/Ticketed Inside, SOTO=Sold Outside/Ticketed Outside, SITO=Sold Inside/Ticketed Outside, SOTI=Sold Outside/Ticketed Inside. Governs BSP settlement currency conversion rules.' ;
    rdfs:domain ind:TicketCoupon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flownDate rdf:type rdf:Property ;
    rdfs:label 'Flown Date' ;
    rdfs:comment 'Calendar date on which the passenger actually flew this coupon segment, as recorded by the departure control system at boarding. Populated when coupon_status is F (Flown). Triggers revenue recognition under IFRS 15.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:issuingDate rdf:type rdf:Property ;
    rdfs:label 'Issuing Date' ;
    rdfs:comment 'Calendar date on which the e-ticket containing this coupon was issued. Used for revenue period allocation, BSP/ARC reporting cycles, and advance purchase restriction validation.' ;
    rdfs:domain ind:TicketCoupon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:liftedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Lifted Timestamp' ;
    rdfs:comment 'Precise date and time (ISO 8601 with timezone offset) at which the coupon was lifted (scanned/validated) at the boarding gate. Captured by the Amadeus Altéa Departure Control System (DCS). Used for OOOI event correlation and OTP measurement.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:notValidAfterDate rdf:type rdf:Property ;
    rdfs:label 'Not Valid After Date' ;
    rdfs:comment 'Latest date on which this coupon may be used for travel, as specified by the fare rule. Enforced at check-in and boarding. Null indicates no upper validity restriction (open-dated coupon).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:notValidBeforeDate rdf:type rdf:Property ;
    rdfs:label 'Not Valid Before Date' ;
    rdfs:comment 'Earliest date on which this coupon may be used for travel, as specified by the fare rule. Enforced at check-in and boarding. Null indicates no lower validity restriction.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nucAmount rdf:type rdf:Property ;
    rdfs:label 'Nuc Amount' ;
    rdfs:comment 'Fare amount expressed in IATA Neutral Units of Construction (NUC), the currency-neutral unit used for international fare proration and interline revenue accounting. Converted to local currency using IATA Rate of Exchange (ROE).' ;
    rdfs:domain ind:TicketCoupon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:refundDate rdf:type rdf:Property ;
    rdfs:label 'Refund Date' ;
    rdfs:comment 'Calendar date on which the refund for this coupon was processed. Populated when coupon_status is R (Refunded). Used for revenue reversal period allocation and BSP/ARC refund cycle reporting.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementType rdf:type rdf:Property ;
    rdfs:label 'Settlement Type' ;
    rdfs:comment 'Identifies the settlement channel through which this coupon will be or has been financially settled: BSP=IATA Billing and Settlement Plan, ARC=Airlines Reporting Corporation (US domestic), DIRECT=direct airline settlement, INTERLINE=interline billing via IATA Clearing House.' ;
    rdfs:domain ind:TicketCoupon ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stopoverIndicator rdf:type rdf:Property ;
    rdfs:label 'Stopover Indicator' ;
    rdfs:comment 'Indicates whether this coupon point constitutes a stopover (True) or a connection (False) per IATA fare construction rules. A stopover is a deliberate break in journey exceeding 24 hours domestically or 24 hours internationally. Affects fare construction and through-fare applicability.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalAmount rdf:type rdf:Property ;
    rdfs:label 'Total Amount' ;
    rdfs:comment 'Total amount for this coupon segment (fare_amount + tax_amount) in the ticket currency. Used as the gross revenue figure for coupon-level BSP/ARC settlement and revenue accounting.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:voidDate rdf:type rdf:Property ;
    rdfs:label 'Void Date' ;
    rdfs:comment 'Calendar date on which this coupon was voided. Populated when coupon_status is V (Voided). Voiding is only permitted on the date of issuance per BSP/ARC rules. Used for revenue accounting and settlement reconciliation.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revenueEmdId rdf:type rdf:Property ;
    rdfs:label 'Revenue Emd Id' ;
    rdfs:comment 'Unique surrogate identifier for the Electronic Miscellaneous Document (EMD) record in the lakehouse silver layer. Primary key for this entity.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RevenueEmd .

ind:itinerarySegmentId rdf:type rdf:Property ;
    rdfs:label 'Itinerary Segment Id' ;
    rdfs:comment 'Foreign key linking to reservation.itinerary_segment. Business justification: EMDs for segment-specific ancillaries (seat upgrades, excess baggage on a specific leg) must reference the itinerary segment. Segment-level ancillary revenue reporting and EMD coupon reconciliation re' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ItinerarySegment .

ind:productCatalogId rdf:type rdf:Property ;
    rdfs:label 'Product Catalog Id' ;
    rdfs:comment 'Foreign key linking to ancillary.product_catalog. Business justification: Revenue EMDs represent sold ancillary services. Linking to the ancillary product catalog enables revenue-by-product reporting, IFRS 15 performance obligation identification, and ancillary revenue acco' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ProductCatalog .

ind:baseAmount rdf:type rdf:Property ;
    rdfs:label 'Base Amount' ;
    rdfs:comment 'The base fare component of the EMD before taxes and fees, in the transaction currency. Used for yield analysis, RASK computation, and ancillary revenue decomposition in Sabre AirVision Revenue Management.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emdNumber rdf:type rdf:Property ;
    rdfs:label 'Emd Number' ;
    rdfs:comment 'The 13-digit IATA-standard EMD document number, structured as airline code (3 digits) + form code (1 digit) + serial number (6 digits) + check digit (1 digit) + coupon count (2 digits). This is the externally-known business identifier used in BSP/ARC settlement and passenger-facing communications.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emdStatus rdf:type rdf:Property ;
    rdfs:label 'Emd Status' ;
    rdfs:comment 'Current lifecycle status of the EMD coupon: open (issued, not yet used), used (service delivered), refunded (amount returned to passenger), voided (cancelled same-day before BSP/ARC lift), exchanged (reissued as new EMD), suspended (temporarily held). Drives revenue recognition and BSP/ARC settlement eligibility. [ENUM-REF-CANDIDATE: open|used|refunded|voided|exchanged|suspended — promote to reference product if additional statuses are required]' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emdType rdf:type rdf:Property ;
    rdfs:label 'Emd Type' ;
    rdfs:comment 'Indicates whether the EMD is an EMD-A (Associated — linked to an air ticket coupon) or EMD-S (Standalone — issued independently of a ticket, e.g., lounge access, excess baggage sold separately). Drives BSP/ARC settlement routing and revenue accounting treatment.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equivalentAmount rdf:type rdf:Property ;
    rdfs:label 'Equivalent Amount' ;
    rdfs:comment 'Total EMD amount converted to the airline\'s base/reporting currency using the IATA Rate of Exchange (IROE) applicable at time of issuance. Used for consolidated ancillary revenue reporting, RASK/CASK analytics, and SAP S/4HANA FI ledger posting in functional currency.' ;
    rdfs:domain ind:RevenueEmd ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exchangeEmdNumber rdf:type rdf:Property ;
    rdfs:label 'Exchange Emd Number' ;
    rdfs:comment 'The 13-digit EMD number of the original document from which this EMD was exchanged/reissued. Null if this is an original issuance. Used for document lineage tracking, refund difference calculation, and BSP/ARC exchange reporting.' ;
    rdfs:domain ind:RevenueEmd ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdsCode rdf:type rdf:Property ;
    rdfs:label 'Gds Code' ;
    rdfs:comment 'Two-character code identifying the Global Distribution System (GDS) through which the EMD was issued (e.g., 1A=Amadeus, 1S=Sabre, 1G=Galileo/Travelport, 1V=Worldspan). Null for direct channel sales. Used for GDS incentive reconciliation and distribution cost analytics.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issueDate rdf:type rdf:Property ;
    rdfs:label 'Issue Date' ;
    rdfs:comment 'Calendar date on which the EMD was issued to the passenger. The principal business event date for revenue recognition, BSP/ARC billing period assignment, and ancillary revenue reporting.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rfic rdf:type rdf:Property ;
    rdfs:label 'Rfic' ;
    rdfs:comment 'Single-character IATA Reason for Issuance Code (RFIC) classifying the broad category of ancillary service (e.g., A=Air Transportation, B=Surface Transportation, C=Baggage, D=Financial Impact, E=Airport Services, F=Merchandise, G=In-flight Services, I=Individual Airline Use). Used for BSP/ARC reporting and revenue categorisation.' ;
    rdfs:domain ind:RevenueEmd ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfisc rdf:type rdf:Property ;
    rdfs:label 'Rfisc' ;
    rdfs:comment 'Three-character IATA Reason for Issuance Sub-Code (RFISC) providing granular classification of the ancillary service within the RFIC category (e.g., 0B5=Checked Baggage 1st Piece, 0CC=Seat Selection, 0B1=Priority Boarding). Used for ancillary revenue analytics, yield management, and regulatory reporting.' ;
    rdfs:domain ind:RevenueEmd ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceDate rdf:type rdf:Property ;
    rdfs:label 'Service Date' ;
    rdfs:comment 'The scheduled date on which the ancillary service is to be delivered or consumed (e.g., flight date for excess baggage, lounge access date). May differ from issue_date for advance purchases. Used for revenue recognition scheduling and service fulfilment tracking.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:serviceDescription rdf:type rdf:Property ;
    rdfs:label 'Service Description' ;
    rdfs:comment 'Human-readable description of the ancillary service covered by this EMD (e.g., \'Excess Baggage 23kg\', \'Seat Upgrade to Business Class\', \'Airport Lounge Access\', \'Priority Boarding\', \'Pet in Cabin\'). Sourced from the Sabre AirVision / Amadeus Altéa service catalogue.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usedDate rdf:type rdf:Property ;
    rdfs:label 'Used Date' ;
    rdfs:comment 'Calendar date on which the EMD coupon was lifted (service delivered). Null if status is not \'used\'. Used for revenue recognition timing and service delivery confirmation.' ;
    rdfs:domain ind:RevenueEmd ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accountsPayableId rdf:type rdf:Property ;
    rdfs:label 'Accounts Payable Id' ;
    rdfs:comment 'Foreign key linking to finance.accounts_payable. Business justification: BSP net remittance payments (airline paying net settlement to BSP or receiving from agents) generate AP entries for cash management and payment processing. IATA BSP reconciliation requires AP traceabi' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccountsPayable .

ind:settlementStationId rdf:type rdf:Property ;
    rdfs:label 'Settlement Station Id' ;
    rdfs:comment 'Foreign key linking to airport.station. Business justification: BSP settlements are processed and reconciled at specific stations; station FK enables settlement audit trails, station-level remittance tracking, and cost center allocation for settlement processing.' ;
    rdfs:domain ind:BspSettlement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Station .

ind:acmAmount rdf:type rdf:Property ;
    rdfs:label 'Acm Amount' ;
    rdfs:comment 'Total value of Agency Credit Memos (ACMs) issued to the travel agent in this settlement period. ACMs represent credits owed to the agent for airline-initiated corrections, overpayments, or goodwill adjustments. Positive value reduces agent liability.' ;
    rdfs:domain ind:BspSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adjustmentReference rdf:type rdf:Property ;
    rdfs:label 'Adjustment Reference' ;
    rdfs:comment 'Reference number or identifier for any corrective adjustment applied to this BSP settlement. Populated when settlement_status is \'adjusted\'. Links to the originating ADM, ACM, or manual journal entry in the revenue accounting system (SAP S/4HANA).' ;
    rdfs:domain ind:BspSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:admAmount rdf:type rdf:Property ;
    rdfs:label 'Adm Amount' ;
    rdfs:comment 'Total value of Agency Debit Memos (ADMs) raised against the travel agent in this settlement period. ADMs recover amounts owed to the airline due to agent errors, fare violations, or unauthorized discounts. Positive value increases agent liability.' ;
    rdfs:domain ind:BspSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:arcReportReference rdf:type rdf:Property ;
    rdfs:label 'Arc Report Reference' ;
    rdfs:comment 'Reference identifier linking this BSP settlement to the corresponding ARC (Airlines Reporting Corporation) settlement report for US-market transactions. Populated for settlements processed through ARC rather than IATA BSP. Used for dual-channel reconciliation.' ;
    rdfs:domain ind:BspSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Billing Period End Date' ;
    rdfs:comment 'End date of the IATA BSP billing period covered by this settlement. Together with billing_period_start_date, defines the complete billing window for ticket sales included in this settlement.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Billing Period Start Date' ;
    rdfs:comment 'Start date of the IATA BSP billing period covered by this settlement. BSP billing periods are typically bi-monthly or monthly depending on the market. Defines the range of ticket sales included in this settlement.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bspFileReference rdf:type rdf:Property ;
    rdfs:label 'Bsp File Reference' ;
    rdfs:comment 'Externally-known IATA BSP file reference number assigned by the BSP clearing system to uniquely identify the settlement file batch. Used for reconciliation with IATA BSP reports and agent remittance matching.' ;
    rdfs:domain ind:BspSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bspMarketCountryCode rdf:type rdf:Property ;
    rdfs:label 'Bsp Market Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-2 country code identifying the BSP market (country or territory) in which this settlement was processed. Determines the applicable BSP rules, currency, and remittance schedule.' ;
    rdfs:domain ind:BspSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionAmount rdf:type rdf:Property ;
    rdfs:label 'Commission Amount' ;
    rdfs:comment 'Total commission amount deducted from gross sales and credited to the travel agent as per the applicable commission agreement. Reduces the net remittance amount owed to the airline.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commissionRate rdf:type rdf:Property ;
    rdfs:label 'Commission Rate' ;
    rdfs:comment 'The percentage commission rate applied to the base fare to calculate the commission_amount for this settlement. Expressed as a decimal (e.g., 0.0100 = 1%). Determined by the airline-agent commission agreement and applicable IATA rules.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costCenterCode rdf:type rdf:Property ;
    rdfs:label 'Cost Center Code' ;
    rdfs:comment 'SAP S/4HANA cost center code associated with the revenue management or sales function responsible for this BSP settlement. Used for internal financial reporting and P&L attribution by sales region or distribution channel.' ;
    rdfs:domain ind:BspSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeRaisedDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Raised Date' ;
    rdfs:comment 'Date on which the dispute was formally raised against this BSP settlement by either the airline or the travel agent. Populated only when settlement_status is \'disputed\'. Used to track dispute aging and SLA compliance.' ;
    rdfs:domain ind:BspSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disputeReasonCode rdf:type rdf:Property ;
    rdfs:label 'Dispute Reason Code' ;
    rdfs:comment 'Standardized IATA or internal code describing the reason for a disputed BSP settlement. Populated only when settlement_status is \'disputed\'. Used for dispute management, root cause analysis, and agent relationship management. [ENUM-REF-CANDIDATE: FARE_DIFF|COMM_DISPUTE|TAX_ERROR|DUPLICATE|UNAUTH_REFUND|ADM_REJECT — promote to reference product]' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Date' ;
    rdfs:comment 'Date on which the dispute for this BSP settlement was formally resolved. Populated when settlement_status transitions from \'disputed\' to \'settled\' or \'adjusted\'. Used for dispute lifecycle reporting and agent relationship analytics.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exchangeRate rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate' ;
    rdfs:comment 'Foreign exchange rate applied to convert the settlement amounts from the BSP market local currency to the airline\'s functional reporting currency (e.g., USD or EUR). Sourced from IATA Rate of Exchange (IROE) or the airline\'s treasury system.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossSalesAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Sales Amount' ;
    rdfs:comment 'Total gross ticket sales value (fare + taxes + surcharges) billed to the travel agent in this BSP settlement period, before deduction of commissions or adjustments. Expressed in the settlement currency.' ;
    rdfs:domain ind:BspSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ndcIndicator rdf:type rdf:Property ;
    rdfs:label 'Ndc Indicator' ;
    rdfs:comment 'Flag indicating whether the tickets in this BSP settlement were issued via IATA New Distribution Capability (NDC) API channels rather than traditional GDS. True = NDC-sourced settlement; False = traditional GDS/BSP settlement. Used for NDC adoption tracking and distribution analytics.' ;
    rdfs:domain ind:BspSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:netRemittanceAmount rdf:type rdf:Property ;
    rdfs:label 'Net Remittance Amount' ;
    rdfs:comment 'Net amount remitted by the travel agent to the airline after deducting commissions and applying any ADM/ACM adjustments from gross sales. This is the actual cash settlement amount transferred through the BSP clearing mechanism.' ;
    rdfs:domain ind:BspSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pfcAmount rdf:type rdf:Property ;
    rdfs:label 'Pfc Amount' ;
    rdfs:comment 'Total Passenger Facility Charge (PFC) amounts collected by the travel agent on behalf of US airports and included in this BSP settlement. PFCs are FAA-regulated charges that must be separately tracked and remitted to the relevant airport authorities.' ;
    rdfs:domain ind:BspSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remittanceDueDate rdf:type rdf:Property ;
    rdfs:label 'Remittance Due Date' ;
    rdfs:comment 'The date by which the travel agent is contractually required to remit the net settlement amount to the BSP clearing house. Determined by the BSP market remittance schedule. Used for cash flow forecasting and overdue tracking.' ;
    rdfs:domain ind:BspSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:settlementCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Settlement Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the currency in which the BSP settlement amounts (gross sales, commission, net remittance) are denominated. Determined by the BSP market country and IATA currency rules.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementDate rdf:type rdf:Property ;
    rdfs:label 'Settlement Date' ;
    rdfs:comment 'The principal business event date on which the BSP clearing house executed the financial settlement and funds were remitted between the travel agent and the airline. Corresponds to the IATA BSP remittance date.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:settlementStatus rdf:type rdf:Property ;
    rdfs:label 'Settlement Status' ;
    rdfs:comment 'Current lifecycle state of the BSP settlement transaction. \'pending\' indicates awaiting clearing; \'settled\' indicates funds remitted; \'disputed\' indicates agent or airline has raised a discrepancy; \'adjusted\' indicates a corrective entry has been applied; \'cancelled\' indicates the settlement was voided.' ;
    rdfs:domain ind:BspSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ticketCount rdf:type rdf:Property ;
    rdfs:label 'Ticket Count' ;
    rdfs:comment 'Total number of individual e-tickets included in this BSP settlement transaction. Used for volume reconciliation and agent productivity reporting.' ;
    rdfs:domain ind:BspSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ticketNumberRangeEnd rdf:type rdf:Property ;
    rdfs:label 'Ticket Number Range End' ;
    rdfs:comment 'The last e-ticket number in the range of tickets covered by this BSP settlement transaction. Together with ticket_number_range_start, defines the complete set of tickets included in this settlement batch.' ;
    rdfs:domain ind:BspSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ticketNumberRangeStart rdf:type rdf:Property ;
    rdfs:label 'Ticket Number Range Start' ;
    rdfs:comment 'The first e-ticket number in the range of tickets covered by this BSP settlement transaction. Follows IATA 13-digit ticket number format (3-digit airline code prefix + 10-digit serial). Used for reconciliation with the Passenger Service System (PSS).' ;
    rdfs:domain ind:BspSettlement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionType rdf:type rdf:Property ;
    rdfs:label 'Transaction Type' ;
    rdfs:comment 'Classification of the BSP settlement transaction. \'sale\' is a standard ticket sale; \'refund\' is a passenger refund; \'ADM\' (Agency Debit Memo) is a debit raised against the agent; \'ACM\' (Agency Credit Memo) is a credit issued to the agent; \'reversal\' is a correction of a prior transaction; \'adjustment\' is a manual correction entry. [ENUM-REF-CANDIDATE: sale|refund|ADM|ACM|reversal|adjustment — promote to reference product]' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognitionId rdf:type rdf:Property ;
    rdfs:label 'Recognition Id' ;
    rdfs:comment 'Primary key for recognition' ;
    rdfs:domain ind:Recognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ancillaryEmdId rdf:type rdf:Property ;
    rdfs:label 'Ancillary Emd Id' ;
    rdfs:comment 'Foreign key linking to ancillary.ancillary_emd. Business justification: Revenue recognition records must identify the source settlement document. For ancillary revenue (EMD-based), recognition must link to the ancillary_emd as the authoritative document. IFRS 15 and airli' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AncillaryEmd .

ind:interlineProrateId rdf:type rdf:Property ;
    rdfs:label 'Interline Prorate Id' ;
    rdfs:comment 'Foreign key linking to revenue.interline_prorate. Business justification: Revenue recognition records for interline journeys should reference the prorate agreement that governs revenue sharing. The prorate_agreement_reference and interline_partner_code attributes in recogni' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InterlineProrate .

ind:journalEntryId rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Id' ;
    rdfs:comment 'Foreign key linking to finance.journal_entry. Business justification: Each revenue recognition event under IFRS 15 generates a journal entry (debit deferred revenue, credit earned revenue). Airline revenue accounting systems require direct traceability from recognition ' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:JournalEntry .

ind:accountingPeriod rdf:type rdf:Property ;
    rdfs:label 'Accounting Period' ;
    rdfs:comment 'Financial accounting period (YYYY-MM) in which this revenue is recognized, aligned with the airline\'s fiscal calendar. Drives period-close reporting in SAP S/4HANA FI/CO and DOT financial filings.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountingStatus rdf:type rdf:Property ;
    rdfs:label 'Accounting Status' ;
    rdfs:comment 'Current workflow status of this revenue recognition record: PENDING (awaiting period-close processing), RECOGNIZED (revenue posted to GL), ADJUSTED (corrected after initial recognition), REVERSED (voided/cancelled entry), DISPUTED (under interline billing dispute).' ;
    rdfs:domain ind:Recognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentReasonCode rdf:type rdf:Property ;
    rdfs:label 'Adjustment Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for a revenue adjustment or reversal (e.g., IROP reprotection, involuntary downgrade, fare recalculation, interline dispute resolution). Populated only when accounting_status is ADJUSTED or REVERSED.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codeshareFlag rdf:type rdf:Property ;
    rdfs:label 'Codeshare Flag' ;
    rdfs:comment 'Indicates whether this coupon was flown on a codeshare flight where the issuing carrier\'s flight number was marketed but operated by a partner airline. Affects revenue recognition treatment and interline settlement.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fuelSurchargeAmount rdf:type rdf:Property ;
    rdfs:label 'Fuel Surcharge Amount' ;
    rdfs:comment 'Carrier-imposed fuel surcharge (IATA codes YQ for fuel surcharge, YR for carrier-imposed miscellaneous surcharge) collected on this coupon. Tracked separately for revenue accounting transparency and regulatory compliance.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interlineFlag rdf:type rdf:Property ;
    rdfs:label 'Interline Flag' ;
    rdfs:comment 'Indicates whether this coupon is part of an interline itinerary involving two or more carriers under an interline ticketing agreement. When true, prorate_amount and prorate_agreement_reference are applicable.' ;
    rdfs:domain ind:Recognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuingAirlineCode rdf:type rdf:Property ;
    rdfs:label 'Issuing Airline Code' ;
    rdfs:comment 'Two-character IATA designator of the airline that issued the ticket document. May differ from the operating carrier on codeshare or interline itineraries. Used to determine revenue accounting ownership.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prorateAmount rdf:type rdf:Property ;
    rdfs:label 'Prorate Amount' ;
    rdfs:comment 'The carrier\'s prorated share of the total through-fare for interline itineraries, calculated per the applicable IATA prorate agreement or bilateral prorate factor. Equals fare_amount for online (single-carrier) itineraries.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recognitionMethod rdf:type rdf:Property ;
    rdfs:label 'Recognition Method' ;
    rdfs:comment 'Method by which revenue is recognized for this record: FLOWN (recognized upon flight completion), ACCRUAL (deferred/accrual basis), PRORATE (interline prorate allocation), REDEMPTION (FFP miles redemption), REVERSAL (corrective reversal entry). Aligns with IFRS 15 performance obligation satisfaction.' ;
    rdfs:domain ind:Recognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognitionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Recognition Timestamp' ;
    rdfs:comment 'Timestamp when this revenue recognition entry was processed and posted in the revenue accounting system. Represents the business event time of recognition, distinct from the flight date and the record audit timestamp.' ;
    rdfs:domain ind:Recognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reportingCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Reporting Currency Amount' ;
    rdfs:comment 'Fare amount converted to the airline\'s functional reporting currency (e.g., USD) using the IROE exchange rate. Used for consolidated financial reporting in SAP S/4HANA FI/CO and DOT/IATA statistical submissions.' ;
    rdfs:domain ind:Recognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementCurrency rdf:type rdf:Property ;
    rdfs:label 'Settlement Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code in which the fare and surcharge amounts are denominated for BSP/ARC settlement (e.g., USD, EUR, GBP). Determines the settlement currency for interline billing.' ;
    rdfs:domain ind:Recognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemRecordReference rdf:type rdf:Property ;
    rdfs:label 'Source System Record Reference' ;
    rdfs:comment 'Native record identifier from the originating revenue accounting system (Sabre AirVision Revenue Management or SAP S/4HANA) for traceability and reconciliation between the lakehouse Silver layer and the operational system of record.' ;
    rdfs:domain ind:Recognition ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ticketIssueDate rdf:type rdf:Property ;
    rdfs:label 'Ticket Issue Date' ;
    rdfs:comment 'Date on which the original ticket was issued. Used to determine the advance purchase window, applicable fare rules, and the deferred revenue liability period between ticketing and flight date.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:interlineAgreementId rdf:type rdf:Property ;
    rdfs:label 'Interline Agreement Id' ;
    rdfs:comment 'Foreign key linking to route.interline_agreement. Business justification: Interline prorate calculations must be audited against the signed interline agreement (prorate basis, percentage, settlement terms). IATA revenue accounting standards require traceability from prorate' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:InterlineAgreement .

ind:ownCarrierId rdf:type rdf:Property ;
    rdfs:label 'Own Carrier Id' ;
    rdfs:comment 'Foreign key linking to route.carrier. Business justification: Interline prorate records must identify the own carrier (the airline running this system) linked to the authoritative carrier registry for IATA bilateral prorate audits and interline billing reconcili' ;
    rdfs:domain ind:InterlineProrate ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:agreementReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Agreement Reference Number' ;
    rdfs:comment 'Externally-known reference number assigned to the interline prorate agreement, used for identification in IATA billing and settlement communications. Corresponds to the Specific Prorate Agreement (SPA) or IATA pro-rate factor agreement identifier. BUSINESS_IDENTIFIER category.' ;
    rdfs:domain ind:InterlineProrate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementStatus rdf:type rdf:Property ;
    rdfs:label 'Agreement Status' ;
    rdfs:comment 'Current lifecycle state of the interline prorate agreement: ACTIVE (in force), SUSPENDED (temporarily halted), EXPIRED (past effective period), TERMINATED (cancelled before expiry), PENDING (awaiting activation). LIFECYCLE_STATUS category.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementType rdf:type rdf:Property ;
    rdfs:label 'Agreement Type' ;
    rdfs:comment 'Classification of the interline prorate agreement method: SPA (Specific Prorate Agreement), IATA_PRF (IATA Pro-Rate Factor), MILEAGE (mileage-based proration), FIXED_AMOUNT (fixed monetary split), or PERCENTAGE (percentage-based split). CLASSIFICATION_OR_TYPE category.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectedFareAmount rdf:type rdf:Property ;
    rdfs:label 'Collected Fare Amount' ;
    rdfs:comment 'Total fare amount collected from the passenger for the interline itinerary, in the settlement currency. This is the gross base amount from which the prorate split is calculated. MONETARY_TRIPLET — gross base amount.' ;
    rdfs:domain ind:InterlineProrate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeStatus rdf:type rdf:Property ;
    rdfs:label 'Dispute Status' ;
    rdfs:comment 'Indicates whether the proration transaction or agreement is subject to an interline billing dispute: NONE (no dispute), DISPUTED (partner carrier has raised a dispute), UNDER_REVIEW (dispute under investigation), RESOLVED (dispute settled).' ;
    rdfs:domain ind:InterlineProrate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iataConferenceArea rdf:type rdf:Property ;
    rdfs:label 'Iata Conference Area' ;
    rdfs:comment 'IATA Traffic Conference area applicable to this prorate agreement: TC1 (Americas), TC2 (Europe, Middle East, Africa), TC3 (Asia-Pacific). Determines the IATA tariff conference jurisdiction governing the agreement.' ;
    rdfs:domain ind:InterlineProrate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumProrateAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Prorate Amount' ;
    rdfs:comment 'Ceiling value for the prorate allocation in the agreement currency. Caps the carrier\'s revenue share to prevent over-recovery on high-yield itineraries under fixed-factor agreements.' ;
    rdfs:domain ind:InterlineProrate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumProrateAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Prorate Amount' ;
    rdfs:comment 'Floor value for the prorate allocation in the agreement currency. Ensures the carrier receives at least this amount regardless of the calculated prorate factor or percentage. Protects against under-recovery on low-yield itineraries.' ;
    rdfs:domain ind:InterlineProrate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partnerCarrierCode rdf:type rdf:Property ;
    rdfs:label 'Partner Carrier Code' ;
    rdfs:comment 'Two-character IATA airline designator code of the interline partner carrier participating in the prorate agreement. Identifies the counterparty airline for revenue split purposes.' ;
    rdfs:domain ind:InterlineProrate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prorateBasis rdf:type rdf:Property ;
    rdfs:label 'Prorate Basis' ;
    rdfs:comment 'The underlying basis on which proration is computed: FARE (based on published fare components), MILEAGE (based on IATA TPM/MPM mileage), WEIGHT (cargo weight-based, for cargo interline), or REVENUE (based on actual collected revenue).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prorateFactor rdf:type rdf:Property ;
    rdfs:label 'Prorate Factor' ;
    rdfs:comment 'Numeric prorate factor (ratio) applied to the total fare to determine the revenue share allocated to this carrier\'s segment of the interline journey. Used for IATA_PRF and MILEAGE agreement types. Value between 0 and 1 representing the carrier\'s proportional share.' ;
    rdfs:domain ind:InterlineProrate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proratePercentage rdf:type rdf:Property ;
    rdfs:label 'Prorate Percentage' ;
    rdfs:comment 'Percentage of the total interline fare revenue allocated to this carrier under the prorate agreement. Used for PERCENTAGE agreement types. Value between 0.0000 and 100.0000.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:proratedRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Prorated Revenue Amount' ;
    rdfs:comment 'Net revenue amount allocated to the own carrier after applying the prorate factor, percentage, or fixed amount to the collected fare. This is the carrier\'s actual revenue share from the interline itinerary. MONETARY_TRIPLET — net total.' ;
    rdfs:domain ind:InterlineProrate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:recordType rdf:type rdf:Property ;
    rdfs:label 'Record Type' ;
    rdfs:comment 'Discriminator indicating whether this record represents a prorate AGREEMENT (the standing agreement defining split rules) or a TRANSACTION (an actual proration event applied to a settled interline billing).' ;
    rdfs:domain ind:InterlineProrate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionDate rdf:type rdf:Property ;
    rdfs:label 'Transaction Date' ;
    rdfs:comment 'Date on which the actual proration transaction was applied to a settled interline billing. Populated only for TRANSACTION record types; null for AGREEMENT records. BUSINESS_EVENT_TIMESTAMP category.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:viaAirportCode rdf:type rdf:Property ;
    rdfs:label 'Via Airport Code' ;
    rdfs:comment 'Three-letter IATA airport code for an intermediate connecting point that further qualifies the applicable market for this prorate agreement. Null if the agreement applies to all routings between origin and destination.' ;
    rdfs:domain ind:InterlineProrate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ancillaryBundleCode rdf:type rdf:Property ;
    rdfs:label 'Ancillary Bundle Code' ;
    rdfs:comment 'Reference code identifying the ancillary services bundle configuration associated with this fare family in the ancillary revenue management system. Links to the specific set of included and excluded ancillary services (EMD-eligible items) for merchandising.' ;
    rdfs:domain ind:FareFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:brandName rdf:type rdf:Property ;
    rdfs:label 'Brand Name' ;
    rdfs:comment 'Commercial marketing name of the fare family as displayed to passengers across all sales channels (e.g., \'Basic Economy\', \'Standard\', \'Flex\', \'Business Lite\', \'Business Plus\'). This is the customer-facing label used in GDS displays, NDC offers, and airline.com.' ;
    rdfs:domain ind:FareFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carryOnBagsIncluded rdf:type rdf:Property ;
    rdfs:label 'Carry On Bags Included' ;
    rdfs:comment 'Number of carry-on bags included in the fare family at no additional charge. Zero indicates no carry-on is included (e.g., Basic Economy). Used for ancillary merchandising and EMD issuance logic.' ;
    rdfs:domain ind:FareFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:changePermitted rdf:type rdf:Property ;
    rdfs:label 'Change Permitted' ;
    rdfs:comment 'Indicates whether the passenger is permitted to change the itinerary (date, routing, or flight) on a ticket issued under this fare family. When true, change_fee_amount may apply.' ;
    rdfs:domain ind:FareFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:checkedBagsIncluded rdf:type rdf:Property ;
    rdfs:label 'Checked Bags Included' ;
    rdfs:comment 'Number of checked baggage pieces included in the fare family at no additional charge. Drives ancillary upsell logic and EMD issuance in Amadeus Altéa. Reported per DOT baggage disclosure requirements.' ;
    rdfs:domain ind:FareFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:combinabilityPermitted rdf:type rdf:Property ;
    rdfs:label 'Combinability Permitted' ;
    rdfs:comment 'Indicates whether fares within this fare family may be combined with fares from other fare families or carriers to construct a round-trip or multi-sector itinerary. Aligns with ATPCO Category 10 combinability rules.' ;
    rdfs:domain ind:FareFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:displayPriority rdf:type rdf:Property ;
    rdfs:label 'Display Priority' ;
    rdfs:comment 'Integer ranking that controls the display order of fare families in shopping results across GDS, NDC, and direct channels. Lower values indicate higher display priority (e.g., 1 = displayed first). Used by Sabre AirVision and Amadeus Altéa for branded fare shelf ordering.' ;
    rdfs:domain ind:FareFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:familyStatus rdf:type rdf:Property ;
    rdfs:label 'Family Status' ;
    rdfs:comment 'Current operational status of the fare family in the revenue management and merchandising system. ACTIVE = currently sold; DRAFT = under configuration; RETIRED = no longer sold; SUSPENDED = temporarily withdrawn from sale.' ;
    rdfs:domain ind:FareFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fareClassMapping rdf:type rdf:Property ;
    rdfs:label 'Fare Class Mapping' ;
    rdfs:comment 'Comma-separated list of one-letter IATA booking class codes (RBDs) that are associated with this fare family (e.g., \'Y,B,M,H\'). Defines which inventory buckets in Amadeus Altéa and Sabre AirVision are merchandised under this branded fare.' ;
    rdfs:domain ind:FareFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdsDisplayIndicator rdf:type rdf:Property ;
    rdfs:label 'Gds Display Indicator' ;
    rdfs:comment 'Indicates whether this fare family is visible and bookable through Global Distribution System (GDS) channels (e.g., Amadeus, Sabre, Travelport). When false, the fare family is restricted to direct or NDC channels only.' ;
    rdfs:domain ind:FareFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interlinePermitted rdf:type rdf:Property ;
    rdfs:label 'Interline Permitted' ;
    rdfs:comment 'Indicates whether tickets issued under this fare family may be used on interline partner carrier segments. When false, the fare family is restricted to the issuing carrier\'s own-metal flights only.' ;
    rdfs:domain ind:FareFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketingDescription rdf:type rdf:Property ;
    rdfs:label 'Marketing Description' ;
    rdfs:comment 'Short customer-facing marketing description of the fare family\'s value proposition, displayed in booking flows and GDS/NDC shopping responses (e.g., \'Our most flexible fare with full refund and free seat selection\'). Maximum 500 characters.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milesAccrualRate rdf:type rdf:Property ;
    rdfs:label 'Miles Accrual Rate' ;
    rdfs:comment 'Percentage of base miles earned per Revenue Passenger Kilometer (RPK) flown under this fare family, expressed as a decimal multiplier (e.g., 0.50 = 50%, 1.00 = 100%, 1.50 = 150%). Feeds Oracle Loyalty Cloud FFP mileage posting logic.' ;
    rdfs:domain ind:FareFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ndcEligible rdf:type rdf:Property ;
    rdfs:label 'Ndc Eligible' ;
    rdfs:comment 'Indicates whether this fare family is available for distribution via IATA New Distribution Capability (NDC) API channels, enabling rich offer and order management with full ancillary bundling.' ;
    rdfs:domain ind:FareFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:refundFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Refund Fee Amount' ;
    rdfs:comment 'Flat fee in the fare family\'s base currency charged to the passenger when processing a refund where refund_permitted is true. Zero indicates a fee-free refund. Null indicates refunds are not permitted.' ;
    rdfs:domain ind:FareFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:refundPermitted rdf:type rdf:Property ;
    rdfs:label 'Refund Permitted' ;
    rdfs:comment 'Indicates whether a refund to the original form of payment is permitted for tickets issued under this fare family. Drives refund eligibility logic in Amadeus Altéa and BSP/ARC settlement processing.' ;
    rdfs:domain ind:FareFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:routeApplicability rdf:type rdf:Property ;
    rdfs:label 'Route Applicability' ;
    rdfs:comment 'Geographic scope of routes to which this fare family applies. DOMESTIC = within a single country; INTERNATIONAL = cross-border; TRANSOCEANIC = long-haul intercontinental; ALL = no geographic restriction.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sabreBrandCode rdf:type rdf:Property ;
    rdfs:label 'Sabre Brand Code' ;
    rdfs:comment 'Native brand identifier assigned to this fare family within the Sabre AirVision Revenue Management system. Used for system-of-record traceability and reconciliation between the lakehouse silver layer and the operational Sabre environment.' ;
    rdfs:domain ind:FareFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierLevel rdf:type rdf:Property ;
    rdfs:label 'Tier Level' ;
    rdfs:comment 'Numeric tier ranking of this fare family within its cabin class, used for upsell and cross-sell logic (e.g., 1 = entry-level Basic Economy, 2 = Standard, 3 = Flex within Economy cabin). Enables structured upsell path configuration in Sabre AirVision.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wifiIncluded rdf:type rdf:Property ;
    rdfs:label 'Wifi Included' ;
    rdfs:comment 'Indicates whether complimentary in-flight Wi-Fi connectivity is included as part of this fare family\'s ancillary service bundle.' ;
    rdfs:domain ind:FareFamily ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:corporateAccountId rdf:type rdf:Property ;
    rdfs:label 'Corporate Account Id' ;
    rdfs:comment 'Reference to the corporate account or Travel Management Company (TMC) that is party to this contract. Links to the corporate account master record.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CorporateAccount .

ind:applicableBookingClasses rdf:type rdf:Property ;
    rdfs:label 'Applicable Booking Classes' ;
    rdfs:comment 'Pipe-delimited list of RBD (Reservation Booking Designator) booking class codes to which this contract\'s fares apply (e.g., \'Y|B|M|K\'). Governs inventory access in the Amadeus Altéa PSS.' ;
    rdfs:domain ind:CorporateContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableCabinClasses rdf:type rdf:Property ;
    rdfs:label 'Applicable Cabin Classes' ;
    rdfs:comment 'Pipe-delimited list of cabin classes to which the negotiated fares or discounts under this contract apply (e.g., \'Y|C|F\' for Economy, Business, First). Aligns with IATA cabin class designators.' ;
    rdfs:domain ind:CorporateContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoRenewalIndicator rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Indicator' ;
    rdfs:comment 'Indicates whether this corporate contract is set to automatically renew upon reaching the expiry date without requiring a new signed agreement. True = auto-renews; False = requires manual renewal.' ;
    rdfs:domain ind:CorporateContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:blackoutDates rdf:type rdf:Property ;
    rdfs:label 'Blackout Dates' ;
    rdfs:comment 'Pipe-delimited list of specific dates or date ranges (in yyyy-MM-dd format) during which the corporate contract fares are not applicable (e.g., peak holiday periods, major events). Stored as a structured string for downstream parsing.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionOverrideRate rdf:type rdf:Property ;
    rdfs:label 'Commission Override Rate' ;
    rdfs:comment 'Negotiated commission rate (as a percentage) paid to the TMC or travel agent above the standard base commission, applicable when contract_type is \'commission_override\'. Expressed as a percentage (e.g., 5.00 = 5%).' ;
    rdfs:domain ind:CorporateContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractName rdf:type rdf:Property ;
    rdfs:label 'Contract Name' ;
    rdfs:comment 'Descriptive name of the corporate contract, typically including the corporate account name and contract year (e.g., \'Acme Corp Global Agreement 2024\'). Used for display and reporting purposes.' ;
    rdfs:domain ind:CorporateContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Number' ;
    rdfs:comment 'Externally-known unique reference number assigned to the corporate contract, used in correspondence with the corporate account and TMC. Serves as the business identifier across systems including Sabre AirVision and SAP S/4HANA.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractStatus rdf:type rdf:Property ;
    rdfs:label 'Contract Status' ;
    rdfs:comment 'Current lifecycle state of the corporate contract. Draft: under negotiation. Active: in force and bookable. Expired: past end date. Suspended: temporarily halted. Terminated: cancelled before end date.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractType rdf:type rdf:Property ;
    rdfs:label 'Contract Type' ;
    rdfs:comment 'Classification of the pricing mechanism governing this corporate agreement. Net fare: fixed negotiated fare net of commission. Discount: percentage reduction off published fare. Commission override: elevated agency commission. Soft dollar: non-cash incentive credits. Zone fare: flat fare within a geographic zone.' ;
    rdfs:domain ind:CorporateContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:corporateContactEmail rdf:type rdf:Property ;
    rdfs:label 'Corporate Contact Email' ;
    rdfs:comment 'Email address of the primary contact person at the corporate account or TMC for contract-related communications, reporting delivery, and renewal notifications.' ;
    rdfs:domain ind:CorporateContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:corporateContactName rdf:type rdf:Property ;
    rdfs:label 'Corporate Contact Name' ;
    rdfs:comment 'Full name of the primary contact person at the corporate account or TMC who is the counterpart for this contract. Used for contract correspondence and account management.' ;
    rdfs:domain ind:CorporateContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationAirportCodes rdf:type rdf:Property ;
    rdfs:label 'Destination Airport Codes' ;
    rdfs:comment 'Pipe-delimited list of IATA three-letter airport codes representing the destination points covered by this corporate contract. Null or wildcard indicates all destinations are applicable.' ;
    rdfs:domain ind:CorporateContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountPercentage rdf:type rdf:Property ;
    rdfs:label 'Discount Percentage' ;
    rdfs:comment 'Negotiated percentage discount applied to the applicable published or base fare for this corporate contract. Expressed as a percentage (e.g., 15.00 = 15%). Applicable when contract_type is \'discount\'. Null for net_fare or commission_override contracts.' ;
    rdfs:domain ind:Revenue ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gdsCorporateCode rdf:type rdf:Property ;
    rdfs:label 'Gds Corporate Code' ;
    rdfs:comment 'Unique corporate code loaded into the Global Distribution System (GDS) — such as Amadeus, Sabre, or Travelport — that travel agents and TMCs use to access the negotiated corporate fares when booking on behalf of the corporate account.' ;
    rdfs:domain ind:CorporateContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minRevenueCommitment rdf:type rdf:Property ;
    rdfs:label 'Min Revenue Commitment' ;
    rdfs:comment 'Minimum annual or contract-period revenue (in contract currency) that the corporate account commits to generate under this agreement. Used for volume-based tier qualification and rebate calculations.' ;
    rdfs:domain ind:CorporateContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minSegmentCommitment rdf:type rdf:Property ;
    rdfs:label 'Min Segment Commitment' ;
    rdfs:comment 'Minimum number of flight segments the corporate account commits to book with the airline during the contract period. Used alongside or as an alternative to min_revenue_commitment for volume qualification.' ;
    rdfs:domain ind:CorporateContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:netFareAmount rdf:type rdf:Property ;
    rdfs:label 'Net Fare Amount' ;
    rdfs:comment 'Fixed negotiated net fare amount agreed under this corporate contract, net of all commissions and agency fees. Applicable when contract_type is \'net_fare\'. Expressed in the contract currency.' ;
    rdfs:domain ind:CorporateContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originAirportCodes rdf:type rdf:Property ;
    rdfs:label 'Origin Airport Codes' ;
    rdfs:comment 'Pipe-delimited list of IATA three-letter airport codes representing the origin points covered by this corporate contract. Null or wildcard indicates all origins are applicable.' ;
    rdfs:domain ind:CorporateContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pnrCorporateCode rdf:type rdf:Property ;
    rdfs:label 'Pnr Corporate Code' ;
    rdfs:comment 'Corporate identifier embedded in the PNR (Passenger Name Record) to associate bookings with this corporate contract for tracking, reporting, and volume measurement purposes within the Amadeus Altéa PSS.' ;
    rdfs:domain ind:CorporateContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rebateRate rdf:type rdf:Property ;
    rdfs:label 'Rebate Rate' ;
    rdfs:comment 'Percentage rebate paid back to the corporate account when volume commitments are met or exceeded. Expressed as a percentage of qualifying revenue (e.g., 3.00 = 3%).' ;
    rdfs:domain ind:CorporateContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rebateThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Rebate Threshold Amount' ;
    rdfs:comment 'Revenue threshold (in contract currency) that the corporate account must exceed to qualify for a volume rebate payment. When actual revenue exceeds this threshold, the rebate_rate applies to the qualifying spend.' ;
    rdfs:domain ind:CorporateContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewalDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Date' ;
    rdfs:comment 'Scheduled date for contract renewal review or automatic renewal. Used by account managers to trigger renegotiation workflows ahead of expiry.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reportingRequirement rdf:type rdf:Property ;
    rdfs:label 'Reporting Requirement' ;
    rdfs:comment 'Frequency at which the airline is contractually obligated to provide travel and spend reports to the corporate account or TMC. Drives automated report scheduling in the revenue management system.' ;
    rdfs:domain ind:CorporateContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:signingDate rdf:type rdf:Property ;
    rdfs:label 'Signing Date' ;
    rdfs:comment 'Date on which the corporate contract was formally executed and signed by both the airline and the corporate account or TMC. Used for audit and legal compliance tracking.' ;
    rdfs:domain ind:CorporateContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:softDollarCreditAmount rdf:type rdf:Property ;
    rdfs:label 'Soft Dollar Credit Amount' ;
    rdfs:comment 'Total non-cash incentive credit amount committed under this contract for soft dollar arrangements (e.g., upgrades, lounge access, marketing co-op funds). Applicable when contract_type is \'soft_dollar\'. Expressed in contract currency.' ;
    rdfs:domain ind:CorporateContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeMeasurementPeriod rdf:type rdf:Property ;
    rdfs:label 'Volume Measurement Period' ;
    rdfs:comment 'The time period over which minimum volume commitments (revenue or segment) are measured and evaluated for compliance and rebate qualification.' ;
    rdfs:domain ind:CorporateContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundId rdf:type rdf:Property ;
    rdfs:label 'Refund Id' ;
    rdfs:comment 'Primary key for refund' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Refund .

ind:maintenanceWorkOrderId rdf:type rdf:Property ;
    rdfs:label 'Maintenance Work Order Id' ;
    rdfs:comment 'Foreign key linking to maintenance.work_order. Business justification: Refunds resulting from maintenance-induced cancellations/delays must link to causative work orders for cost recovery from maintenance providers, dispute resolution, and operational impact tracking. Cr' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WorkOrder .

ind:occurrenceId rdf:type rdf:Property ;
    rdfs:label 'Occurrence Id' ;
    rdfs:comment 'Foreign key linking to safety.occurrence. Business justification: When a safety occurrence (emergency landing, diversion, cabin event) forces involuntary passenger disruption, refunds are issued. The \'involuntary refund due to safety event\' process requires linking ' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Occurrence .

ind:orderItemId rdf:type rdf:Property ;
    rdfs:label 'Order Item Id' ;
    rdfs:comment 'Foreign key linking to ancillary.order_item. Business justification: Ancillary service refunds must trace back to the specific order item being refunded for accurate refund processing, customer service resolution, and DOT/IATA refund reporting. Revenue refund processin' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrderItem .

ind:approvedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approved Timestamp' ;
    rdfs:comment 'The date and time (UTC) when the refund was approved by an authorised agent or automated revenue management rule engine. Distinct from the processed timestamp; captures the approval decision event in the refund workflow lifecycle.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:bspArcSettlementDate rdf:type rdf:Property ;
    rdfs:label 'Bsp Arc Settlement Date' ;
    rdfs:comment 'The date on which the refund amount was settled through the IATA Billing and Settlement Plan (BSP) or Airlines Reporting Corporation (ARC) settlement cycle. Null for direct refunds or miles refunds not routed through BSP/ARC.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ffpMilesRefunded rdf:type rdf:Property ;
    rdfs:label 'Ffp Miles Refunded' ;
    rdfs:comment 'Number of Frequent Flyer Program (FFP) miles credited back to the passenger\'s loyalty account as the refund method, or miles reinstated when an award ticket is cancelled. Populated only when refund_method is \'miles\'. Interfaces with Oracle Loyalty Cloud FFP Management.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:grossFareAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Fare Amount' ;
    rdfs:comment 'The total base fare amount on the original ticket or EMD before any taxes, fees, or surcharges. Represents the revenue component subject to refund calculation and penalty deduction. Expressed in the transaction currency.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:involuntaryReason rdf:type rdf:Property ;
    rdfs:label 'Involuntary Reason' ;
    rdfs:comment 'For involuntary refunds, the specific airline-caused reason triggering the mandatory refund obligation. \'flight_cancellation\' — flight cancelled by airline; \'significant_delay\' — delay exceeding regulatory threshold; \'denied_boarding\' — involuntary denied boarding (IDB); \'downgrade\' — passenger downgraded to lower cabin; \'schedule_change\' — schedule change beyond passenger tolerance. Null for voluntary refunds.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalFormOfPaymentCode rdf:type rdf:Property ;
    rdfs:label 'Original Form Of Payment Code' ;
    rdfs:comment 'IATA-standard form of payment code from the original ticket transaction (e.g., CC — credit card, CA — cash, CK — check, MS — miscellaneous, TP — tour order). Required for \'original_form_of_payment\' refund method to route the credit correctly through BSP or ARC settlement.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:penaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Penalty Amount' ;
    rdfs:comment 'The monetary penalty amount deducted from the gross fare amount per the fare rule conditions (e.g., ATPCO Category 16 — Penalties). Zero for involuntary refunds and IROP refunds where no penalty applies. Expressed in the transaction currency.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pnrCode rdf:type rdf:Property ;
    rdfs:label 'Pnr Code' ;
    rdfs:comment 'Six-character alphanumeric Passenger Name Record (PNR) locator code in the Amadeus Altéa PSS associated with the original booking from which this refund originates. Links the refund to the reservation context.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Processed Timestamp' ;
    rdfs:comment 'The date and time (UTC) when the refund was fully processed and funds were disbursed or credit was issued. Used to calculate refund processing duration for DOT compliance (7-day rule for credit card refunds, 20-day rule for cash/check). Null if not yet processed.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reasonCode rdf:type rdf:Property ;
    rdfs:label 'Reason Code' ;
    rdfs:comment 'Standardised IATA or carrier-defined reason code identifying the specific cause of the refund (e.g., CANX — flight cancelled, DELY — significant delay, INVOL — involuntary reroute, SKED — schedule change, VOLU — voluntary cancellation). Sourced from Sabre AirVision Revenue Management and Amadeus Altéa PSS refund reason tables. [ENUM-REF-CANDIDATE: CANX|DELY|INVOL|SKED|VOLU|DNBD|WVNO|MEDX|BEAV|DUPL — promote to reference product]' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Number' ;
    rdfs:comment 'Externally-known alphanumeric reference number assigned to this refund transaction by the Passenger Service System (PSS) or revenue accounting system. Used for passenger and agent communication and BSP/ARC settlement tracking.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundMethod rdf:type rdf:Property ;
    rdfs:label 'Refund Method' ;
    rdfs:comment 'The method by which the refund value is returned to the passenger or agent. \'original_form_of_payment\' — credit back to the original payment instrument; \'voucher\' — travel credit voucher issued; \'miles\' — Frequent Flyer Program (FFP) miles credited; \'cash\' — physical cash refund at airport; \'bank_transfer\' — direct bank transfer; \'check\' — paper check issued.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundStatus rdf:type rdf:Property ;
    rdfs:label 'Refund Status' ;
    rdfs:comment 'Current workflow lifecycle state of the refund transaction. \'requested\' — refund application received; \'approved\' — authorised by agent or automated rule; \'processed\' — funds disbursed or credit issued; \'rejected\' — refund denied; \'pending\' — awaiting additional information or system processing.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundType rdf:type rdf:Property ;
    rdfs:label 'Refund Type' ;
    rdfs:comment 'Classification of the reason category driving the refund. \'voluntary\' — passenger-initiated cancellation; \'involuntary\' — airline-initiated cancellation or denial of boarding; \'irop\' — Irregular Operations (IROP) such as flight cancellation or significant delay; \'schedule_change\' — airline schedule change exceeding MCT or passenger tolerance thresholds; \'no_show_waiver\' — waiver granted for no-show penalty under exceptional circumstances.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestTimestamp rdf:type rdf:Property ;
    rdfs:label 'Request Timestamp' ;
    rdfs:comment 'The date and time (UTC) when the refund was formally requested by the passenger, travel agent, or automated system. This is the principal business event timestamp for the refund lifecycle and is used for DOT refund processing time compliance measurement.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:taxBreakdownJson rdf:type rdf:Property ;
    rdfs:label 'Tax Breakdown Json' ;
    rdfs:comment 'Serialised JSON string containing the itemised breakdown of individual tax and fee components included in the tax_refund_amount (e.g., {"US": 12.50, "XF": 4.50, "AY": 5.60}). Each key is the IATA tax code and the value is the refund amount for that tax. Required for regulatory tax reporting and passenger transparency.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxRefundAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Refund Amount' ;
    rdfs:comment 'Total amount of government taxes and airport fees refunded to the passenger. Taxes are generally refundable even when the fare is non-refundable (e.g., Passenger Facility Charges (PFC), government-imposed taxes). Expressed in the transaction currency.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalRefundAmount rdf:type rdf:Property ;
    rdfs:label 'Total Refund Amount' ;
    rdfs:comment 'The total monetary amount disbursed to the passenger or agent, equal to refund_fare_amount plus tax_refund_amount. This is the net settlement value of the refund transaction. Expressed in the transaction currency. Used for revenue reversal accounting in SAP S/4HANA FI/CO.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:voucherNumber rdf:type rdf:Property ;
    rdfs:label 'Voucher Number' ;
    rdfs:comment 'Unique identifier of the travel credit voucher issued to the passenger when refund_method is \'voucher\'. Used to track voucher liability on the balance sheet and redemption against future bookings. Null when refund method is not voucher.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverCode rdf:type rdf:Property ;
    rdfs:label 'Waiver Code' ;
    rdfs:comment 'Airline-issued waiver code authorising the override of standard fare rule penalty conditions (e.g., weather waiver, pandemic waiver, operational disruption waiver). When populated, the penalty_amount is typically zero. Sourced from Sabre AirVision Revenue Management waiver management module.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ticketExchangeId rdf:type rdf:Property ;
    rdfs:label 'Ticket Exchange Id' ;
    rdfs:comment 'Primary key for ticket_exchange' ;
    rdfs:domain ind:TicketExchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eTicketId rdf:type rdf:Property ;
    rdfs:label 'E Ticket Id' ;
    rdfs:comment 'Foreign key linking to reservation.e_ticket. Business justification: A ticket exchange references the original e-ticket being reissued. Linking enables complete exchange audit trail, e-ticket lifecycle tracking, and conjunction ticket management required for IATA resol' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ETicket .

ind:iropEventId rdf:type rdf:Property ;
    rdfs:label 'Irop Event Id' ;
    rdfs:comment 'Foreign key linking to flight.flight_irop_event. Business justification: Involuntary ticket exchanges caused by IROP events (cancellations, diversions, mass delays) must reference the triggering IROP event for DOT/EC261 regulatory reporting, IROP cost attribution, and pass' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IropEvent .

ind:newFareId rdf:type rdf:Property ;
    rdfs:label 'New Fare Id' ;
    rdfs:comment 'Foreign key linking to revenue.fare. Business justification: ticket_exchange captures the new fare details after reissue (new_fare_amount, new_fare_basis_code as execution-specific values) but has no FK to the fare master. Adding new_fare_id → revenue.fare.fare' ;
    rdfs:domain ind:TicketExchange ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Fare .

ind:newFlightInventoryId rdf:type rdf:Property ;
    rdfs:label 'New Flight Inventory Id' ;
    rdfs:comment 'Foreign key linking to inventory.flight_inventory. Business justification: Ticket exchange (reissue) moves a passenger to a new flight, requiring confirmation of seat availability on the new flight_inventory. Role-prefix \'new_\' distinguishes the target flight from the origin' ;
    rdfs:domain ind:TicketExchange ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FlightInventory .

ind:originalTicketId rdf:type rdf:Property ;
    rdfs:label 'Original Ticket Id' ;
    rdfs:comment 'Foreign key linking to revenue.ticket. Business justification: ticket_exchange captures voluntary or involuntary ticket modifications (reissues). Each exchange references an original ticket being exchanged. The table has original_ticket_number (STRING) as a busin' ;
    rdfs:domain ind:TicketExchange ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Ticket .

ind:collectionMethod rdf:type rdf:Property ;
    rdfs:label 'Collection Method' ;
    rdfs:comment 'Method by which any additional fare difference or penalty was collected from the passenger. EMD (Electronic Miscellaneous Document) is used for ancillary collections per IATA standards. Waived applies to involuntary exchanges. [ENUM-REF-CANDIDATE: cash|credit_card|emd|residual_value|waived — promote to reference product]' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeDate rdf:type rdf:Property ;
    rdfs:label 'Exchange Date' ;
    rdfs:comment 'Principal business event timestamp recording the exact date and time (with timezone offset) when the ticket exchange transaction was executed in the PSS. Distinct from audit timestamps. Conforms to yyyy-MM-ddTHH:mm:ss.SSSXXX format.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Exchange Reference Number' ;
    rdfs:comment 'Externally-known business identifier for the ticket exchange transaction, typically generated by the Passenger Service System (PSS) or GDS at the time of reissue. Used for cross-system reconciliation and customer-facing reference.' ;
    rdfs:domain ind:TicketExchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeStatus rdf:type rdf:Property ;
    rdfs:label 'Exchange Status' ;
    rdfs:comment 'Current lifecycle status of the ticket exchange transaction. Pending indicates initiated but not finalized; completed indicates successfully processed; voided indicates cancelled before settlement; failed indicates processing error; reversed indicates post-completion reversal.' ;
    rdfs:domain ind:TicketExchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeType rdf:type rdf:Property ;
    rdfs:label 'Exchange Type' ;
    rdfs:comment 'Classification of the reason or nature of the ticket exchange. Voluntary indicates passenger-initiated change; involuntary indicates airline-initiated change; upgrade/downgrade reflect cabin class changes; irop_reprotection covers Irregular Operations (IROP) rebooking; schedule_change covers airline schedule modifications. [ENUM-REF-CANDIDATE: voluntary|involuntary|upgrade|downgrade|irop_reprotection|schedule_change — promote to reference product]' ;
    rdfs:domain ind:TicketExchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fareDifferenceAmount rdf:type rdf:Property ;
    rdfs:label 'Fare Difference Amount' ;
    rdfs:comment 'Net monetary difference between the new fare amount and the original fare amount (new_fare_amount minus original_fare_amount). A positive value indicates an additional collection (ADC) owed by the passenger; a negative value indicates a residual credit. Central to revenue impact tracking for ticket reissues.' ;
    rdfs:domain ind:TicketExchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gdsTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Gds Transaction Reference' ;
    rdfs:comment 'Unique transaction identifier assigned by the Global Distribution System (GDS) — such as Amadeus or Sabre — at the time the exchange was processed. Used for cross-system reconciliation between the PSS and GDS settlement records.' ;
    rdfs:domain ind:TicketExchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:involuntaryReasonCode rdf:type rdf:Property ;
    rdfs:label 'Involuntary Reason Code' ;
    rdfs:comment 'Airline-defined reason code specifying the cause of an involuntary ticket exchange (e.g., flight cancellation, significant schedule change, equipment downgrade, denied boarding). Populated only when exchange_type is involuntary or irop_reprotection. Required for DOT and EASA regulatory reporting on involuntary rerouting.' ;
    rdfs:domain ind:TicketExchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingCarrierCode rdf:type rdf:Property ;
    rdfs:label 'Issuing Carrier Code' ;
    rdfs:comment 'IATA two-letter or ICAO three-letter airline designator code of the carrier that issued the new ticket. May differ from the operating carrier in codeshare or interline scenarios.' ;
    rdfs:domain ind:TicketExchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newCabinClass rdf:type rdf:Property ;
    rdfs:label 'New Cabin Class' ;
    rdfs:comment 'IATA cabin class code of the newly issued ticket after exchange. F=First, C=Business, W=Premium Economy, Y=Economy. Used in conjunction with original_cabin_class to classify upgrade or downgrade transactions.' ;
    rdfs:domain ind:TicketExchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newDestinationAirportCode rdf:type rdf:Property ;
    rdfs:label 'New Destination Airport Code' ;
    rdfs:comment 'IATA three-letter airport code of the final destination on the newly issued ticket itinerary after exchange. Used for O&D revenue analysis and network planning.' ;
    rdfs:domain ind:TicketExchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newFareAmount rdf:type rdf:Property ;
    rdfs:label 'New Fare Amount' ;
    rdfs:comment 'Gross base fare amount of the newly issued ticket in the transaction currency, excluding taxes and fees. Used to compute the fare difference and assess revenue uplift or dilution from the exchange.' ;
    rdfs:domain ind:TicketExchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:newFareBasisCode rdf:type rdf:Property ;
    rdfs:label 'New Fare Basis Code' ;
    rdfs:comment 'IATA fare basis code of the newly issued ticket after exchange. Identifies the fare product, booking class, and applicable conditions governing the replacement itinerary. Used for revenue impact analysis and yield management reporting.' ;
    rdfs:domain ind:TicketExchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newOriginAirportCode rdf:type rdf:Property ;
    rdfs:label 'New Origin Airport Code' ;
    rdfs:comment 'IATA three-letter airport code of the origin point on the newly issued ticket itinerary after exchange. Used for route-level revenue impact analysis and yield management reporting.' ;
    rdfs:domain ind:TicketExchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newTicketNumber rdf:type rdf:Property ;
    rdfs:label 'New Ticket Number' ;
    rdfs:comment '13-digit IATA e-ticket number of the newly issued ticket resulting from the exchange. Conforms to IATA standard ticket numbering. Used to link the exchange event to the replacement travel document.' ;
    rdfs:domain ind:TicketExchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newTravelDate rdf:type rdf:Property ;
    rdfs:label 'New Travel Date' ;
    rdfs:comment 'Scheduled departure date of the first flight segment on the newly issued ticket itinerary after exchange. Used for demand forecasting, load factor impact assessment, and revenue period reporting.' ;
    rdfs:domain ind:TicketExchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originalCabinClass rdf:type rdf:Property ;
    rdfs:label 'Original Cabin Class' ;
    rdfs:comment 'IATA cabin class code of the original ticket prior to exchange. F=First, C=Business, W=Premium Economy, Y=Economy. Used to identify upgrade/downgrade exchanges and assess revenue impact.' ;
    rdfs:domain ind:TicketExchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalDestinationAirportCode rdf:type rdf:Property ;
    rdfs:label 'Original Destination Airport Code' ;
    rdfs:comment 'IATA three-letter airport code of the final destination on the original ticket itinerary prior to exchange. Used for O&D (Origin and Destination) revenue analysis.' ;
    rdfs:domain ind:TicketExchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalFareAmount rdf:type rdf:Property ;
    rdfs:label 'Original Fare Amount' ;
    rdfs:comment 'Gross base fare amount of the original ticket in the transaction currency, excluding taxes and fees. Used as the baseline for fare difference calculation and revenue accounting reconciliation.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalFareBasisCode rdf:type rdf:Property ;
    rdfs:label 'Original Fare Basis Code' ;
    rdfs:comment 'IATA fare basis code of the original ticket prior to exchange. Identifies the fare product, booking class, and applicable conditions that governed the original itinerary. Used for fare difference calculation and revenue accounting.' ;
    rdfs:domain ind:TicketExchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalOriginAirportCode rdf:type rdf:Property ;
    rdfs:label 'Original Origin Airport Code' ;
    rdfs:comment 'IATA three-letter airport code of the origin point on the original ticket itinerary prior to exchange. Used for route-level revenue impact analysis and yield management reporting.' ;
    rdfs:domain ind:TicketExchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalTravelDate rdf:type rdf:Property ;
    rdfs:label 'Original Travel Date' ;
    rdfs:comment 'Scheduled departure date of the first flight segment on the original ticket itinerary prior to exchange. Used for seasonality analysis, advance purchase tracking, and revenue accounting period alignment.' ;
    rdfs:domain ind:TicketExchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:settlementPlanType rdf:type rdf:Property ;
    rdfs:label 'Settlement Plan Type' ;
    rdfs:comment 'Identifies the settlement mechanism through which the exchange transaction will be financially settled. BSP (Billing and Settlement Plan) for IATA-member markets; ARC (Airlines Reporting Corporation) for US/Canada markets; direct for airline-direct sales channels.' ;
    rdfs:domain ind:TicketExchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxDifferenceAmount rdf:type rdf:Property ;
    rdfs:label 'Tax Difference Amount' ;
    rdfs:comment 'Net difference in applicable taxes and surcharges between the new ticket and the original ticket. Positive indicates additional tax collection; negative indicates tax credit. Required for accurate BSP settlement and revenue accounting.' ;
    rdfs:domain ind:TicketExchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:validatingCarrierCode rdf:type rdf:Property ;
    rdfs:label 'Validating Carrier Code' ;
    rdfs:comment 'IATA two-letter airline designator code of the validating carrier responsible for the new ticket. The validating carrier is accountable for BSP settlement and revenue recognition on the reissued document.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:waiverReason rdf:type rdf:Property ;
    rdfs:label 'Waiver Reason' ;
    rdfs:comment 'Categorical reason code explaining why a waiver was applied to the exchange transaction. Used for waiver cost tracking, regulatory compliance reporting, and customer service analytics. [ENUM-REF-CANDIDATE: weather|irop|schedule_change|goodwill|elite_status|pandemic|other — promote to reference product]' ;
    rdfs:domain ind:TicketExchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountingPrinciple rdf:type rdf:Property ;
    rdfs:label 'Accounting Principle' ;
    rdfs:comment 'The accounting standard under which this posting is recorded. Supports dual-reporting requirements for airlines operating across multiple jurisdictions. IFRS16 specifically tracks right-of-use asset and lease liability postings for aircraft operating leases.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amountCompanyCurrency rdf:type rdf:Property ;
    rdfs:label 'Amount Company Currency' ;
    rdfs:comment 'The posting amount converted to the company code\'s local currency (BSEG-DMBTR). Used for statutory financial reporting, local GAAP compliance, and period-end balance sheet preparation.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amountGroupCurrency rdf:type rdf:Property ;
    rdfs:label 'Amount Group Currency' ;
    rdfs:comment 'The posting amount translated to the group reporting currency (BSEG-KURSF-based calculation, stored as parallel ledger amount). Supports consolidated financial statements and group-level CASK/RASK reporting across all airline entities.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amountTransactionCurrency rdf:type rdf:Property ;
    rdfs:label 'Amount Transaction Currency' ;
    rdfs:comment 'The gross posting amount in the original transaction currency (BSEG-WRBTR). Represents the raw financial value before currency conversion. Used for interline billing settlements, BSP reconciliation, and multi-currency financial reporting.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignmentNumber rdf:type rdf:Property ;
    rdfs:label 'Assignment Number' ;
    rdfs:comment 'Free-form assignment field used for sorting and grouping line items in account statements (BSEG-ZUONR). Typically populated with flight number, route code, or cost object reference to facilitate operational cost reconciliation.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyCurrency rdf:type rdf:Property ;
    rdfs:label 'Company Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code of the company code\'s local (functional) currency (T001-WAERS). The currency in which statutory accounts are prepared for the legal entity.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costElement rdf:type rdf:Property ;
    rdfs:label 'Cost Element' ;
    rdfs:comment 'SAP CO cost element corresponding to the GL account for cost and revenue postings (BSEG-KOSTL-linked KSTAR). Bridges FI and CO modules, enabling detailed cost analysis for fuel uplift, crew costs, MRO expenses, and lease payments.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:debitCreditIndicator rdf:type rdf:Property ;
    rdfs:label 'Debit Credit Indicator' ;
    rdfs:comment 'SAP indicator specifying whether the line item is a debit (S = Soll) or credit (H = Haben) posting (BSEG-SHKZG). Fundamental to double-entry bookkeeping and ensures the document balances to zero.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentDate rdf:type rdf:Property ;
    rdfs:label 'Document Date' ;
    rdfs:comment 'The date of the original source document (invoice, receipt, contract) that triggered the accounting entry (BKPF-BLDAT). May differ from posting_date for accruals, prepayments, or late-received invoices.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:documentNumber rdf:type rdf:Property ;
    rdfs:label 'Document Number' ;
    rdfs:comment 'SAP FI accounting document number uniquely identifying the journal entry header within a company code and fiscal year. Corresponds to BKPF-BELNR in SAP. All line items sharing the same document number belong to the same posting event.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentType rdf:type rdf:Property ;
    rdfs:label 'Document Type' ;
    rdfs:comment 'SAP document type code classifying the nature of the accounting entry (BKPF-BLART). Controls number ranges and account types. Common airline values include SA (GL account document), KR (vendor invoice), DR (customer invoice), ZP (payment), AA (asset posting), AB (accounting document). [ENUM-REF-CANDIDATE: SA|KR|DR|ZP|AA|AB|RV|WA — promote to reference product]' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalPeriod rdf:type rdf:Property ;
    rdfs:label 'Fiscal Period' ;
    rdfs:comment 'Accounting period (1–16) within the fiscal year to which the posting belongs (BKPF-MONAT in SAP). Periods 13–16 are special closing periods used for year-end adjustments, accruals, and audit corrections.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fiscalYear rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year' ;
    rdfs:comment 'The fiscal year to which the accounting document belongs (BKPF-GJAHR in SAP). Used for period-end close, annual financial reporting, and year-over-year variance analysis.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:functionalArea rdf:type rdf:Property ;
    rdfs:label 'Functional Area' ;
    rdfs:comment 'SAP functional area classifying the business function of the posting for cost-of-sales accounting (BSEG-FKBER). Enables income statement presentation by function (e.g., Flight Operations, Sales & Distribution, Administration) per IFRS IAS 1.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccountName rdf:type rdf:Property ;
    rdfs:label 'Gl Account Name' ;
    rdfs:comment 'Human-readable description of the GL account (SKA1-TXT50). Denormalised from the chart of accounts for reporting convenience and audit trail completeness. Examples: \'Jet Fuel Expense\', \'Aircraft Lease Liability (IFRS 16)\', \'Interline Receivable\'.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headerText rdf:type rdf:Property ;
    rdfs:label 'Header Text' ;
    rdfs:comment 'Free-text description at the accounting document header level (BKPF-BKTXT). Provides overall context for the journal entry, shared across all line items of the same document. Used for audit trail and period-end close documentation.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:intercompanyIndicator rdf:type rdf:Property ;
    rdfs:label 'Intercompany Indicator' ;
    rdfs:comment 'Flag indicating whether this posting is an intercompany transaction between two legal entities within the airline group (BKPF-BVTYP populated). True = intercompany posting requiring elimination in group consolidation. Critical for IFRS 10 consolidation.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:internalOrder rdf:type rdf:Property ;
    rdfs:label 'Internal Order' ;
    rdfs:comment 'SAP CO internal order number used to collect costs for specific projects, campaigns, or temporary cost objects (BSEG-AUFNR). Used in aviation for aircraft modification projects, route launch campaigns, and MRO work orders.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastChangedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Changed Timestamp' ;
    rdfs:comment 'The date and time when the accounting document was last modified in SAP. Tracks changes to parked documents, header text updates, or clearing events. Supports change audit trail requirements under SOX and IFRS.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ledgerCode rdf:type rdf:Property ;
    rdfs:label 'Ledger Code' ;
    rdfs:comment 'SAP parallel ledger identifier (BKPF-RLDNR) supporting dual IFRS and local GAAP reporting. Common values: \'0L\' = leading ledger (IFRS), \'N1\' = local GAAP ledger. Enables simultaneous reporting under multiple accounting standards required for multinational airline operations.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineItemNumber rdf:type rdf:Property ;
    rdfs:label 'Line Item Number' ;
    rdfs:comment 'Sequential line item number within the accounting document (BSEG-BUZEI in SAP). Identifies the specific debit or credit posting line within the journal entry. Combined with document_number and company_code forms the natural key of a GL line item.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:postingDate rdf:type rdf:Property ;
    rdfs:label 'Posting Date' ;
    rdfs:comment 'The date on which the accounting document is posted to the general ledger (BKPF-BUDAT). Determines the fiscal period assignment and is the primary date used for financial reporting and period-end close.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:postingStatus rdf:type rdf:Property ;
    rdfs:label 'Posting Status' ;
    rdfs:comment 'Current lifecycle status of the accounting document. \'posted\' = active GL entry; \'reversed\' = entry has been reversed by a reversal document; \'parked\' = document saved but not yet posted; \'held\' = incomplete document; \'cleared\' = open item has been cleared against a payment or offsetting entry.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingText rdf:type rdf:Property ;
    rdfs:label 'Posting Text' ;
    rdfs:comment 'Free-text description of the individual line item posting (BSEG-SGTXT). Provides narrative context for the accounting entry, e.g., \'Jet fuel uplift JFK-LHR 15-Jan\', \'IFRS 16 lease liability accrual Q1\', \'Interline settlement IATA BSP Jan\'.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingUser rdf:type rdf:Property ;
    rdfs:label 'Posting User' ;
    rdfs:comment 'SAP user ID of the person or system process that created the accounting document (BKPF-USNAM). Essential for SOX audit trail, segregation of duties controls, and financial fraud detection. May be a batch job ID for automated postings.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCentre rdf:type rdf:Property ;
    rdfs:label 'Profit Centre' ;
    rdfs:comment 'SAP Controlling profit centre representing a business unit responsible for its own profitability (BSEG-PRCTR / CEPC-PRCTR). Used for route-level, hub-level, or business-segment P&L reporting. Supports RASK and yield analysis by profit centre.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reference Document Number' ;
    rdfs:comment 'External reference number from the source document (BKPF-XBLNR), such as a vendor invoice number, AWB (Air Waybill) number, PNR, interline billing statement number, or BSP settlement reference. Enables traceability from the GL back to the originating business transaction.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Reversal Document Number' ;
    rdfs:comment 'The document number of the corresponding reversal or reversed document (BKPF-STBLG). Populated when reversal_indicator is true, enabling bidirectional traceability between original and reversal entries for audit and compliance purposes.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalIndicator rdf:type rdf:Property ;
    rdfs:label 'Reversal Indicator' ;
    rdfs:comment 'Flag indicating whether this document is a reversal of a previously posted document (BKPF-STBLG is populated). True = this is a reversal document. Supports audit trail integrity and period-end close accuracy.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tradingPartnerCompanyCode rdf:type rdf:Property ;
    rdfs:label 'Trading Partner Company Code' ;
    rdfs:comment 'Company code of the intercompany trading partner for intercompany postings (BSEG-VBUND). Populated when intercompany_indicator is true. Used for automated intercompany elimination during group financial consolidation.' ;
    rdfs:domain ind:GeneralLedger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionCurrency rdf:type rdf:Property ;
    rdfs:label 'Transaction Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code of the original transaction (BSEG-WAERS). Identifies the currency in which the business event was denominated, e.g., USD for US routes, EUR for European operations, GBP for UK operations.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wbsElement rdf:type rdf:Property ;
    rdfs:label 'Wbs Element' ;
    rdfs:comment 'SAP Project System WBS element for project-based cost assignment (BSEG-PS_PSP_PNR). Used for capital expenditure projects such as fleet acquisition, terminal construction, and major MRO overhauls. Supports IFRS IAS 16 capitalisation tracking.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountType rdf:type rdf:Property ;
    rdfs:label 'Account Type' ;
    rdfs:comment 'SAP FI account type indicating the subledger category for this posting: A=Asset, D=Customer (Debtor/Accounts Receivable), K=Vendor (Creditor/Accounts Payable), M=Material, S=General Ledger. Determines which subledger is updated.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amountDocumentCurrency rdf:type rdf:Property ;
    rdfs:label 'Amount Document Currency' ;
    rdfs:comment 'The transaction amount in the original document currency (transaction currency). May differ from amount_local_currency when the source document is in a foreign currency, such as interline billing settlements in USD or EUR.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amountLocalCurrency rdf:type rdf:Property ;
    rdfs:label 'Amount Local Currency' ;
    rdfs:comment 'The gross transaction amount in the company code\'s local (functional) currency. This is the primary monetary value for statutory reporting and forms part of the MONETARY_TRIPLET for this transaction.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:businessArea rdf:type rdf:Property ;
    rdfs:label 'Business Area' ;
    rdfs:comment 'SAP FI business area code representing an organizational unit for which an internal balance sheet and P&L can be produced (e.g., passenger operations, cargo, MRO, loyalty). Supports segment reporting under IFRS 8.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearingDate rdf:type rdf:Property ;
    rdfs:label 'Clearing Date' ;
    rdfs:comment 'The date on which this open item was cleared (matched against a payment or offsetting entry). Used for accounts receivable aging analysis, days sales outstanding (DSO) calculation, and cash flow reporting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:clearingDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Clearing Document Number' ;
    rdfs:comment 'The SAP FI document number of the clearing transaction that matched and closed this open item (e.g., payment document clearing an invoice, credit memo clearing a debit). Populated when posting_status is \'cleared\'.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Document Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code of the original document currency (e.g., USD, EUR, GBP). Critical for interline billing, BSP settlements, and multi-currency treasury operations.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Entry Timestamp' ;
    rdfs:comment 'The precise date and time when this journal entry record was created in the SAP S/4HANA system. Serves as the RECORD_AUDIT_CREATED timestamp for audit trail and data lineage purposes.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:internalOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Internal Order Number' ;
    rdfs:comment 'SAP CO internal order number used to collect costs for specific projects or events (e.g., aircraft heavy maintenance C-check, airport terminal renovation, fleet acquisition project). Enables project-level cost tracking.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineItemText rdf:type rdf:Property ;
    rdfs:label 'Line Item Text' ;
    rdfs:comment 'Free-text description at the individual line item level providing specific context for this debit or credit posting (e.g., \'Jet-A fuel uplift LHR 15-Oct\', \'ACMI wet lease payment\', \'Crew hotel deadhead expense\').' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Local Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code of the company code\'s local (functional) currency. Defines the base currency for statutory financial reporting for the legal entity.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postingKey rdf:type rdf:Property ;
    rdfs:label 'Posting Key' ;
    rdfs:comment 'SAP FI two-digit posting key controlling the account type, debit/credit indicator, and field selection for this line item (e.g., 40=GL Debit, 50=GL Credit, 31=Vendor Credit, 01=Customer Debit). Determines the accounting treatment applied.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCenterCode rdf:type rdf:Property ;
    rdfs:label 'Profit Center Code' ;
    rdfs:comment 'SAP CO profit center identifying the business segment (e.g., route, hub, cabin class, cargo) responsible for this posting. Supports profitability analysis by route, fleet type, and business unit.' ;
    rdfs:domain ind:JournalEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activityTypeCode rdf:type rdf:Property ;
    rdfs:label 'Activity Type Code' ;
    rdfs:comment 'Primary SAP CO activity type associated with this cost centre, defining the unit of output for internal activity allocation (e.g., \'FLT-HRS\' = flight hours, \'BLK-HRS\' = block hours, \'MRO-MHR\' = maintenance man-hours, \'GND-TRN\' = ground turns). Used to calculate internal activity rates for cost allocation between centres.' ;
    rdfs:domain ind:CostCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:annualBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Budget Amount' ;
    rdfs:comment 'Total approved annual budget allocated to this cost centre for the current fiscal year, in the controlling area currency. Represents the authorised spending limit for departmental P&L management. Used in budget vs. actual variance reporting and financial planning.' ;
    rdfs:domain ind:CostCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetVersion rdf:type rdf:Property ;
    rdfs:label 'Budget Version' ;
    rdfs:comment 'SAP CO planning version identifier for the budget associated with this cost centre (e.g., \'000\' = actuals, \'001\' = original budget, \'002\' = revised forecast, \'PLAN\' = annual plan). Enables comparison of actuals vs. budget vs. forecast in variance reporting.' ;
    rdfs:domain ind:CostCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessAreaCode rdf:type rdf:Property ;
    rdfs:label 'Business Area Code' ;
    rdfs:comment 'SAP FI business area assigned to this cost centre, representing a distinct area of operations for internal balance sheet and P&L reporting (e.g., \'PASS\' = Passenger, \'CARG\' = Cargo, \'MRO\' = Maintenance). Enables segment reporting per IFRS 8 without full profit centre accounting.' ;
    rdfs:domain ind:CostCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:caskAllocationKey rdf:type rdf:Property ;
    rdfs:label 'Cask Allocation Key' ;
    rdfs:comment 'Allocation driver used to apportion this cost centre\'s costs to Available Seat Kilometers (ASK) for CASK reporting. \'ask\' = direct ASK-based allocation; \'block_hours\' = by block hours flown; \'departures\' = by number of departures; \'pax\' = by passenger count; \'revenue\' = by revenue share; \'equal\' = equal split; \'manual\' = manually defined percentages. Critical for unit cost benchmarking. [ENUM-REF-CANDIDATE: ask|block_hours|departures|pax|revenue|equal|manual — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CostCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryCode rdf:type rdf:Property ;
    rdfs:label 'Category Code' ;
    rdfs:comment 'SAP CO cost centre category that classifies the functional nature of the centre (e.g., \'F\' = Flight Operations, \'M\' = Maintenance, \'G\' = Ground Handling, \'A\' = Administration, \'C\' = Cargo, \'L\' = Loyalty). Controls which activity types and statistical key figures can be posted. [ENUM-REF-CANDIDATE: F|M|G|A|C|L|S|T — promote to reference product]' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:centreType rdf:type rdf:Property ;
    rdfs:label 'Centre Type' ;
    rdfs:comment 'Classification of the responsibility centre by financial accountability type. \'cost\' centres track expenditure only (e.g., maintenance base); \'profit\' centres track both revenue and cost for P&L reporting (e.g., route group, cargo division); \'investment\' centres include capital employed; \'revenue\' centres track revenue attribution (e.g., lounge, ancillary). Drives CASK/RASK allocation methodology.' ;
    rdfs:domain ind:CostCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controllingAreaCode rdf:type rdf:Property ;
    rdfs:label 'Controlling Area Code' ;
    rdfs:comment 'SAP CO controlling area to which this cost centre belongs. The controlling area defines the organisational unit within which cost accounting is performed (e.g., \'AA01\' for the airline group). Determines currency, fiscal year variant, and chart of accounts applicable to this centre.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:corsiaEmissionsFlag rdf:type rdf:Property ;
    rdfs:label 'Corsia Emissions Flag' ;
    rdfs:comment 'Indicates whether this cost centre is subject to CORSIA (Carbon Offsetting and Reduction Scheme for International Aviation) emissions monitoring and offset cost accounting. True for international route operations cost centres. Drives inclusion in ICAO CORSIA compliance reporting and carbon offset cost allocation.' ;
    rdfs:domain ind:CostCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:costCentreCode rdf:type rdf:Property ;
    rdfs:label 'Cost Centre Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying the cost centre within the SAP CO controlling area. Used in journal entries, budget allocations, and management reporting (e.g., \'FLT-OPS-001\', \'MRO-BASE-LHR\', \'CARGO-HUB-JFK\'). Aligns with SAP CO cost centre number.' ;
    rdfs:domain ind:CostCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCentreDescription rdf:type rdf:Property ;
    rdfs:label 'Cost Centre Description' ;
    rdfs:comment 'Long-form narrative description of the cost centre\'s business purpose, scope of operations, and cost accountability. Provides context for financial analysts and auditors beyond the short name (e.g., \'Responsible for all direct operating costs of widebody long-haul fleet on North Atlantic routes including fuel uplift, crew costs, and ATC charges\').' ;
    rdfs:domain ind:CostCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCentreName rdf:type rdf:Property ;
    rdfs:label 'Cost Centre Name' ;
    rdfs:comment 'Full descriptive name of the cost centre as maintained in SAP CO master data (e.g., \'Flight Operations — North Atlantic Hub\', \'Cabin Crew Training — Base London\', \'MRO Line Maintenance — Frankfurt\'). Used in financial reports and management dashboards.' ;
    rdfs:domain ind:CostCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCentreStatus rdf:type rdf:Property ;
    rdfs:label 'Cost Centre Status' ;
    rdfs:comment 'Current lifecycle status of the cost centre in SAP CO. \'active\' = open for postings; \'inactive\' = temporarily suspended; \'locked\' = blocked for new postings (period-end); \'pending_activation\' = created but not yet released; \'closed\' = permanently deactivated with no further postings permitted.' ;
    rdfs:domain ind:CostCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelCostFlag rdf:type rdf:Property ;
    rdfs:label 'Fuel Cost Flag' ;
    rdfs:comment 'Indicates whether this cost centre is designated for fuel cost accounting and uplift tracking. True for flight operations and route cost centres where jet fuel (Jet-A/A1) costs are directly attributed. Enables fuel cost per ASK (fuel CASK) component reporting and hedging P&L attribution.' ;
    rdfs:domain ind:CostCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:functionalAreaCode rdf:type rdf:Property ;
    rdfs:label 'Functional Area Code' ;
    rdfs:comment 'SAP FI/CO functional area classifying the cost centre by business function for cost-of-sales accounting and segment reporting (e.g., \'PROD\' = Production/Operations, \'SELL\' = Sales, \'ADMN\' = Administration, \'R&D\' = Research). Required for IFRS income statement by function of expense.' ;
    rdfs:domain ind:CostCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glAccountGroup rdf:type rdf:Property ;
    rdfs:label 'Gl Account Group' ;
    rdfs:comment 'SAP FI general ledger account group associated with primary cost postings for this cost centre. Defines the range of GL accounts permissible for postings, ensuring cost classification consistency (e.g., \'OPEX\' for operating expenses, \'FUEL\' for fuel costs, \'LABOR\' for crew and staff costs).' ;
    rdfs:domain ind:CostCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyArea rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Area' ;
    rdfs:comment 'Node identifier within the standard cost centre hierarchy (SAP CO standard hierarchy) to which this centre is assigned. Enables roll-up reporting by business segment, division, or region (e.g., \'FLIGHT-OPS\', \'MRO-EMEA\', \'CARGO-APAC\'). Used for group-level CASK reporting and segment P&L consolidation.' ;
    rdfs:domain ind:CostCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hierarchyLevel rdf:type rdf:Property ;
    rdfs:label 'Hierarchy Level' ;
    rdfs:comment 'Numeric depth of this cost centre within the standard hierarchy tree (1 = top-level division, 2 = sub-division, 3 = department, 4 = operational unit, etc.). Used to control report aggregation and drill-down navigation in management accounting dashboards.' ;
    rdfs:domain ind:CostCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hubAirportCode rdf:type rdf:Property ;
    rdfs:label 'Hub Airport Code' ;
    rdfs:comment 'IATA three-letter airport code of the hub or base airport associated with this cost centre, where applicable (e.g., \'LHR\' for London Heathrow hub operations, \'JFK\' for New York hub, \'FRA\' for Frankfurt MRO base). Enables geographic cost attribution and hub-level CASK analysis. Null for non-location-specific centres.' ;
    rdfs:domain ind:CostCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iataCostCategory rdf:type rdf:Property ;
    rdfs:label 'Iata Cost Category' ;
    rdfs:comment 'IATA standard cost category classification for airline management accounting and industry benchmarking (e.g., \'Flight Operations\', \'Maintenance\', \'Passenger Services\', \'Sales and Distribution\', \'General and Administration\'). Enables CASK component benchmarking against IATA industry data. [ENUM-REF-CANDIDATE: Flight Operations|Maintenance|Passenger Services|Sales and Distribution|General and Administration|Cargo|Ground Operations — promote to reference product]' ;
    rdfs:domain ind:CostCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ifrs16LeaseFlag rdf:type rdf:Property ;
    rdfs:label 'Ifrs16 Lease Flag' ;
    rdfs:comment 'Indicates whether this cost centre carries IFRS 16 right-of-use asset and lease liability obligations (e.g., aircraft operating leases, airport gate leases, hangar leases). True triggers inclusion in IFRS 16 lease liability reporting and depreciation of right-of-use assets. Critical for airline balance sheet compliance.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interlineSettlementFlag rdf:type rdf:Property ;
    rdfs:label 'Interline Settlement Flag' ;
    rdfs:comment 'Indicates whether this cost centre participates in interline billing settlement processes (IATA BSP/ARC). True for cost centres associated with interline revenue sharing, prorate agreements, and bilateral settlement with partner carriers. Drives inclusion in interline financial reconciliation workflows.' ;
    rdfs:domain ind:CostCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:internalActivityRate rdf:type rdf:Property ;
    rdfs:label 'Internal Activity Rate' ;
    rdfs:comment 'Planned cost rate per unit of activity output for this cost centre (in controlling area currency). Used for internal cost allocation between cost centres (e.g., cost per block hour charged from Flight Operations to Route cost centres). Recalculated each planning cycle. Classified confidential as it reflects internal transfer pricing.' ;
    rdfs:domain ind:CostCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastChangedBy rdf:type rdf:Property ;
    rdfs:label 'Last Changed By' ;
    rdfs:comment 'SAP user ID of the person who last modified this cost centre master record. Supports audit trail requirements for financial master data governance and SOX compliance controls over cost centre maintenance.' ;
    rdfs:domain ind:CostCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profitCentreCode rdf:type rdf:Property ;
    rdfs:label 'Profit Centre Code' ;
    rdfs:comment 'SAP CO profit centre to which this cost centre is assigned for internal P&L reporting. Enables revenue attribution and profitability analysis at route, hub, or business segment level. Supports RASK/CASK analysis by profit centre.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:raskAttributionFlag rdf:type rdf:Property ;
    rdfs:label 'Rask Attribution Flag' ;
    rdfs:comment 'Indicates whether this cost centre participates in Revenue per Available Seat Kilometer (RASK) attribution for route profitability analysis. True for profit centres and revenue-generating units (e.g., route groups, lounges, ancillary services); False for pure cost centres (e.g., corporate functions, back-office).' ;
    rdfs:domain ind:CostCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regionCode rdf:type rdf:Property ;
    rdfs:label 'Region Code' ;
    rdfs:comment 'Geographic region code to which this cost centre is assigned for regional management reporting (e.g., \'EMEA\', \'NORAM\', \'APAC\', \'LATAM\', \'DOM\' for domestic). Supports regional P&L roll-up, CASK benchmarking by region, and DOT/EASA regional regulatory reporting.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortName rdf:type rdf:Property ;
    rdfs:label 'Short Name' ;
    rdfs:comment 'Abbreviated name of the cost centre used in condensed reports, dashboards, and system displays where space is limited. Corresponds to SAP CO short text field (up to 20 characters).' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validFrom rdf:type rdf:Property ;
    rdfs:label 'Valid From' ;
    rdfs:comment 'Date from which this cost centre is valid and open for financial postings in SAP CO. Supports time-dependent master data management — cost centre attributes may change over time with new validity periods. Aligns with fiscal year planning cycles.' ;
    rdfs:domain ind:CostCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validTo rdf:type rdf:Property ;
    rdfs:label 'Valid To' ;
    rdfs:comment 'Date until which this cost centre is valid for financial postings. Null or 31-Dec-9999 indicates an open-ended validity. Used to manage cost centre lifecycle, seasonal operations (e.g., charter season cost centres), and organisational restructuring.' ;
    rdfs:domain ind:CostCentre ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fixedAssetId rdf:type rdf:Property ;
    rdfs:label 'Fixed Asset Id' ;
    rdfs:comment 'Foreign key linking to finance.fixed_asset. Business justification: AP invoices can be for the purchase or capitalization of fixed assets (aircraft, engines, ground equipment). A FK from accounts_payable to fixed_asset links the payment obligation to the asset being a' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FixedAsset .

ind:fleetOrderId rdf:type rdf:Property ;
    rdfs:label 'Fleet Order Id' ;
    rdfs:comment 'Foreign key linking to fleet.fleet_order. Business justification: Aircraft purchase progress payments and delivery milestone invoices are AP transactions that must reference the originating fleet order for three-way matching, CAPEX payment tracking, and purchase ord' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FleetOrder .

ind:groundHandlerId rdf:type rdf:Property ;
    rdfs:label 'Ground Handler Id' ;
    rdfs:comment 'Foreign key linking to airport.ground_handler. Business justification: AP invoices are issued by ground handlers for ramp, baggage, and passenger handling services. Linking AP to the ground_handler vendor record enables vendor payment tracking, SLA-linked invoice validat' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GroundHandler .

ind:leaseContractId rdf:type rdf:Property ;
    rdfs:label 'Lease Contract Id' ;
    rdfs:comment 'Foreign key linking to finance.lease_contract. Business justification: AP invoices for IFRS 16 lease payments should be linked to the lease contract. The accounts_payable table has ifrs16_lease_flag (BOOLEAN) indicating lease-related invoices, but no explicit FK. Adding ' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LeaseContract .

ind:approvalStatus rdf:type rdf:Property ;
    rdfs:label 'Approval Status' ;
    rdfs:comment 'Current status of the invoice within the internal approval workflow, reflecting authorization levels required before payment execution. Supports segregation of duties and internal controls per SOX compliance requirements.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bspArcSettlementRef rdf:type rdf:Property ;
    rdfs:label 'Bsp Arc Settlement Ref' ;
    rdfs:comment 'The IATA Billing and Settlement Plan (BSP) or Airlines Reporting Corporation (ARC) settlement reference number for invoices settled through interline or agency billing cycles. Applicable for GDS provider fees, interline billing, and travel agency commission settlements.' ;
    rdfs:domain ind:AccountsPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountAmount rdf:type rdf:Property ;
    rdfs:label 'Discount Amount' ;
    rdfs:comment 'The cash discount amount available if payment is made by the discount_due_date, as negotiated in the vendor payment terms. Supports working capital optimization and supplier relationship management.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discountDueDate rdf:type rdf:Property ;
    rdfs:label 'Discount Due Date' ;
    rdfs:comment 'The deadline by which early payment must be made to qualify for the cash discount offered under the vendor\'s payment terms (e.g., 2/10 net 30). Supports cash flow optimization and working capital management.' ;
    rdfs:domain ind:AccountsPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dueDate rdf:type rdf:Property ;
    rdfs:label 'Due Date' ;
    rdfs:comment 'The calculated date by which payment must be made to the vendor to comply with agreed payment terms and avoid late payment penalties. Derived from invoice date plus payment term days. Corresponds to SAP field FAEDT (Net Due Date).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fuelUpliftVolumeLiters rdf:type rdf:Property ;
    rdfs:label 'Fuel Uplift Volume Liters' ;
    rdfs:comment 'For fuel vendor invoices, the volume of jet fuel (Jet-A or Jet-A1) uplifted in liters as recorded on the fuel receipt. Supports fuel cost per liter analysis, CASK fuel component reporting, and CORSIA carbon emissions accounting. Null for non-fuel invoices.' ;
    rdfs:domain ind:AccountsPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:goodsReceiptDate rdf:type rdf:Property ;
    rdfs:label 'Goods Receipt Date' ;
    rdfs:comment 'The date on which goods or services were confirmed as received, forming the third leg of the three-way match (PO → Goods Receipt → Invoice). Critical for MRO parts, fuel uplift, and catering deliveries. Corresponds to SAP MIGO goods receipt posting date.' ;
    rdfs:domain ind:AccountsPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:grossAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Amount' ;
    rdfs:comment 'The total gross amount of the vendor invoice before deduction of taxes, withholding tax, or discounts, expressed in the invoice currency. Represents the full obligation as stated on the vendor\'s invoice document.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceCurrency rdf:type rdf:Property ;
    rdfs:label 'Invoice Currency' ;
    rdfs:comment 'The ISO 4217 three-letter currency code in which the vendor invoice is denominated (e.g., USD, EUR, GBP). May differ from the company code local currency, requiring foreign exchange translation for GL posting. Corresponds to SAP field WAERS.' ;
    rdfs:domain ind:AccountsPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceDate rdf:type rdf:Property ;
    rdfs:label 'Invoice Date' ;
    rdfs:comment 'The date printed on the vendor\'s invoice document, representing the business event date for the supply of goods or services. Used as the baseline for payment term calculation and tax point determination. Corresponds to SAP field BLDAT.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:invoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Invoice Number' ;
    rdfs:comment 'The externally-assigned invoice number as printed on the vendor\'s invoice document. Used for vendor reconciliation, dispute resolution, and audit trail. Corresponds to SAP field BELNR (Accounting Document Number) or XBLNR (Reference Document Number).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceStatus rdf:type rdf:Property ;
    rdfs:label 'Invoice Status' ;
    rdfs:comment 'Current lifecycle status of the vendor invoice within the SAP FI-AP workflow. \'open\' = posted and awaiting payment; \'parked\' = saved but not yet posted; \'blocked\' = payment block applied; \'in_approval\' = pending workflow approval; \'cleared\' = fully paid and cleared; \'cancelled\' = reversed/cancelled document.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:localCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Local Currency Amount' ;
    rdfs:comment 'The net payable amount translated into the company code\'s local (functional) currency using the exchange rate at posting date. Used for GL posting, financial reporting, and CASK calculation in the airline\'s reporting currency.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netAmount rdf:type rdf:Property ;
    rdfs:label 'Net Amount' ;
    rdfs:comment 'The net amount payable to the vendor after deducting withholding tax and any applicable cash discounts from the gross invoice amount. Represents the actual cash outflow obligation. Calculated as gross_amount minus withholding_tax_amount minus discount_amount.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentBlockReason rdf:type rdf:Property ;
    rdfs:label 'Payment Block Reason' ;
    rdfs:comment 'Reason code explaining why a payment block has been applied to this invoice, preventing it from being included in the next payment run. Corresponds to SAP field ZLSPR (Payment Block Key). Null when no block is active.' ;
    rdfs:domain ind:AccountsPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentDate rdf:type rdf:Property ;
    rdfs:label 'Payment Date' ;
    rdfs:comment 'The actual date on which payment was executed to the vendor, either via bank transfer, cheque, or BSP/ARC settlement. Populated upon payment run completion. Corresponds to SAP clearing document value date.' ;
    rdfs:domain ind:AccountsPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:paymentMethod rdf:type rdf:Property ;
    rdfs:label 'Payment Method' ;
    rdfs:comment 'The method by which payment is executed to the vendor. \'bank_transfer\' = SWIFT/SEPA wire; \'cheque\' = paper cheque; \'bsp_settlement\' = IATA Billing and Settlement Plan net settlement; \'arc_settlement\' = Airlines Reporting Corporation settlement; \'direct_debit\' = automated debit. Corresponds to SAP field ZLSCH.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermsCode rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Code' ;
    rdfs:comment 'The SAP payment terms key (e.g., NT30, NT60, 2/10N30) defining the agreed payment schedule, discount percentages, and due date calculation rules for this vendor. Corresponds to SAP field ZTERM.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sapDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Sap Document Number' ;
    rdfs:comment 'The internal SAP FI accounting document number (BELNR) assigned upon posting of the vendor invoice in the general ledger. Uniquely identifies the FI document within a company code and fiscal year.' ;
    rdfs:domain ind:AccountsPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:threeWayMatchStatus rdf:type rdf:Property ;
    rdfs:label 'Three Way Match Status' ;
    rdfs:comment 'Result of the automated three-way match validation comparing the purchase order, goods receipt, and vendor invoice for quantity and price alignment. \'matched\' = all three documents agree; \'price_variance\' = invoice price differs from PO; \'quantity_variance\' = invoice quantity differs from GR; \'pending_gr\' = goods receipt not yet confirmed; \'failed\' = match failed requiring manual review.' ;
    rdfs:domain ind:AccountsPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vendorCategory rdf:type rdf:Property ;
    rdfs:label 'Vendor Category' ;
    rdfs:comment 'Classification of the vendor type supplying goods or services to the airline. Drives cost allocation to CASK components and supports spend analytics by supplier category. [ENUM-REF-CANDIDATE: mro_supplier|fuel_vendor|airport_authority|gds_provider|catering|ground_handling|bsp_arc — promote to reference product]' ;
    rdfs:domain ind:AccountsPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withholdingTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Withholding Tax Amount' ;
    rdfs:comment 'The amount of withholding tax (WHT) to be deducted from the vendor payment and remitted to the tax authority on behalf of the vendor. Applicable for cross-border supplier payments subject to bilateral tax treaties. Corresponds to SAP Extended Withholding Tax (WITH_ITEM).' ;
    rdfs:domain ind:AccountsPayable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ageingBucket rdf:type rdf:Property ;
    rdfs:label 'Ageing Bucket' ;
    rdfs:comment 'Ageing classification of the open receivable based on days past due date: CURRENT (not yet due), 1_30_DAYS, 31_60_DAYS, 61_90_DAYS, 91_120_DAYS, OVER_120_DAYS. Drives credit risk assessment and bad debt provisioning under IFRS 9 expected credit loss model.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arStatus rdf:type rdf:Property ;
    rdfs:label 'Ar Status' ;
    rdfs:comment 'Current lifecycle status of the receivable: OPEN (unpaid), PARTIALLY_PAID (partial payment received), CLEARED (fully paid and matched), DISPUTED (customer dispute raised), WRITTEN_OFF (bad debt write-off applied), IN_DUNNING (active dunning process initiated).' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bankValueDate rdf:type rdf:Property ;
    rdfs:label 'Bank Value Date' ;
    rdfs:comment 'Value date on which funds were credited to the airline\'s bank account for this receivable. Distinct from posting date; used for treasury cash flow forecasting and bank reconciliation.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bspArcBillingPeriod rdf:type rdf:Property ;
    rdfs:label 'Bsp Arc Billing Period' ;
    rdfs:comment 'IATA BSP or ARC billing period identifier (e.g., 2024-W03 for weekly cycle) to which this agency receivable belongs. Supports settlement reconciliation and dispute management with travel agencies.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costCenter rdf:type rdf:Property ;
    rdfs:label 'Cost Center' ;
    rdfs:comment 'SAP cost center associated with the receivable for internal cost allocation and CASK (Cost per Available Seat Kilometer) reporting purposes.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditControlArea rdf:type rdf:Property ;
    rdfs:label 'Credit Control Area' ;
    rdfs:comment 'SAP credit control area (KKBER) under which the customer\'s credit limit is managed. Groups customers for credit exposure monitoring across company codes.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditLimit rdf:type rdf:Property ;
    rdfs:label 'Credit Limit' ;
    rdfs:comment 'Approved credit limit assigned to the customer in the credit control area, expressed in the credit control area currency. Used for credit exposure monitoring and order block decisions.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customerAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Customer Account Number' ;
    rdfs:comment 'SAP debtor account number (KUNNR) identifying the customer — travel agency, corporate account, interline carrier, or cargo shipper — against whom the receivable is raised.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerName rdf:type rdf:Property ;
    rdfs:label 'Customer Name' ;
    rdfs:comment 'Legal name of the debtor customer as maintained in SAP customer master. Covers travel agencies, corporate accounts, interline carriers, and cargo clients.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:daysOverdue rdf:type rdf:Property ;
    rdfs:label 'Days Overdue' ;
    rdfs:comment 'Number of calendar days the receivable is past its due date as of the last refresh date. Negative values indicate days until due. Used for DSO reporting and credit risk monitoring.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:documentCurrency rdf:type rdf:Property ;
    rdfs:label 'Document Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the AR document amounts are denominated (e.g., USD, EUR, GBP). Supports multi-currency airline operations and foreign exchange reporting.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dunningLevel rdf:type rdf:Property ;
    rdfs:label 'Dunning Level' ;
    rdfs:comment 'Current dunning level (1–4) assigned to this receivable in SAP dunning program, indicating the escalation stage of the collection notice. Level 0 means no dunning initiated.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:glAccount rdf:type rdf:Property ;
    rdfs:label 'Gl Account' ;
    rdfs:comment 'SAP general ledger account number to which the receivable is posted (e.g., trade receivables, interline receivables, cargo receivables). Drives financial statement classification.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interlineCarrierCode rdf:type rdf:Property ;
    rdfs:label 'Interline Carrier Code' ;
    rdfs:comment 'Two or three-character IATA airline designator code of the interline partner carrier for interline receivable types. Null for non-interline receivables. Supports interline prorate and settlement reconciliation.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastDunningDate rdf:type rdf:Property ;
    rdfs:label 'Last Dunning Date' ;
    rdfs:comment 'Date on which the most recent dunning notice was issued to the customer for this receivable. Used to track collection activity and enforce dunning intervals.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:openAmount rdf:type rdf:Property ;
    rdfs:label 'Open Amount' ;
    rdfs:comment 'Remaining unpaid balance on the receivable at the current point in time, calculated as gross amount minus payments received and credit memos applied. Core field for working capital management and ageing analysis.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:profitCenter rdf:type rdf:Property ;
    rdfs:label 'Profit Center' ;
    rdfs:comment 'SAP profit center to which the receivable revenue is attributed, enabling segment-level P&L reporting by route, cabin class, or business unit within the airline.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:receivableType rdf:type rdf:Property ;
    rdfs:label 'Receivable Type' ;
    rdfs:comment 'Classification of the receivable by originating business channel: BSP_AGENCY (IATA Billing and Settlement Plan agency), ARC_AGENCY (Airlines Reporting Corporation agency), CORPORATE (direct corporate account billing), INTERLINE (interline carrier settlement), CARGO_AWB (Air Waybill cargo collection), ANCILLARY (ancillary service charges such as excess baggage, upgrades).' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationStatus rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Status' ;
    rdfs:comment 'Status of the receivable reconciliation against the originating billing system (BSP, ARC, cargo system, or ancillary billing): MATCHED (confirmed and reconciled), UNMATCHED (discrepancy identified), DISPUTED (formal dispute raised), PENDING_REVIEW (awaiting finance review).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:referenceDocument rdf:type rdf:Property ;
    rdfs:label 'Reference Document' ;
    rdfs:comment 'External reference number associated with the receivable, such as the BSP billing period reference, ARC settlement report number, Air Waybill (AWB) number for cargo, or PNR for passenger billings. Enables cross-system reconciliation.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:writeOffAmount rdf:type rdf:Property ;
    rdfs:label 'Write Off Amount' ;
    rdfs:comment 'Amount written off as bad debt for this receivable, in document currency. Populated when ar_status is WRITTEN_OFF. Supports bad debt expense reporting and IFRS 9 expected credit loss provisioning.' ;
    rdfs:domain ind:AccountsReceivable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetPlanId rdf:type rdf:Property ;
    rdfs:label 'Budget Plan Id' ;
    rdfs:comment 'Unique surrogate identifier for the budget plan record in the finance data product. Primary key for the budget_plan entity.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BudgetPlan .

ind:primaryBudgetCostCentreId rdf:type rdf:Property ;
    rdfs:label 'Primary Budget Cost Centre Id' ;
    rdfs:comment 'Reference to the SAP CO cost centre to which this budget plan is assigned. Enables cost centre-level budget tracking and variance analysis across airline operational divisions.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCentre .

ind:approvalDate rdf:type rdf:Property ;
    rdfs:label 'Approval Date' ;
    rdfs:comment 'The date on which the budget plan received final approval from the designated authority (CFO, board, or budget committee). Marks the transition from \'submitted\' to \'approved\' status in the workflow.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:askBudget rdf:type rdf:Property ;
    rdfs:label 'Ask Budget' ;
    rdfs:comment 'Budgeted Available Seat Kilometers (ASK) for the planning period, representing planned capacity output. ASK is the industry-standard capacity metric (seats × kilometers flown). Used as the denominator for CASK and RASK budget calculations.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:budgetCategory rdf:type rdf:Property ;
    rdfs:label 'Budget Category' ;
    rdfs:comment 'High-level financial category of the budget plan. OPEX = Operating Expenditure; CAPEX = Capital Expenditure; REVENUE = Revenue budget; MIXED = combined OPEX and CAPEX plan. Aligns with SAP CO-PA cost element categories.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capexBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Capex Budget Amount' ;
    rdfs:comment 'Budgeted amount allocated to capital expenditure (CAPEX) within this plan, including aircraft acquisitions, fleet modifications, and infrastructure investments. Supports IFRS 16 lease liability planning.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:caskBudget rdf:type rdf:Property ;
    rdfs:label 'Cask Budget' ;
    rdfs:comment 'Budgeted Cost per Available Seat Kilometer (CASK), calculated as total OPEX budget divided by ASK budget. Expressed in currency units per ASK. Primary airline unit cost efficiency metric used in board-level financial planning and investor reporting.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:consolidationLevel rdf:type rdf:Property ;
    rdfs:label 'Consolidation Level' ;
    rdfs:comment 'The organisational level at which this budget plan is consolidated. \'entity\' = legal entity; \'division\' = business division (e.g., cargo, MRO); \'group\' = airline group; \'segment\' = IFRS 8 reportable segment. Supports financial consolidation and group reporting.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forecastCycle rdf:type rdf:Property ;
    rdfs:label 'Forecast Cycle' ;
    rdfs:comment 'The frequency at which this rolling forecast budget plan is updated and resubmitted. Applicable only when is_rolling_forecast is True. Supports planning cadence governance.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelCostBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Fuel Cost Budget Amount' ;
    rdfs:comment 'Budgeted amount specifically allocated to jet fuel procurement and uplift costs. Fuel is typically the largest single OPEX line for airlines. Supports fuel cost accounting and hedging strategy alignment.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interlineSettlementBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Interline Settlement Budget Amount' ;
    rdfs:comment 'Budgeted net interline billing settlement amount payable or receivable through IATA BSP/ARC for interline ticketing agreements with partner carriers. Supports interline prorate and billing reconciliation planning.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isRollingForecast rdf:type rdf:Property ;
    rdfs:label 'Is Rolling Forecast' ;
    rdfs:comment 'Indicates whether this budget plan is part of a rolling forecast cycle (True) or a fixed annual budget (False). Rolling forecasts are updated periodically (monthly/quarterly) to reflect current business conditions.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leaseLiabilityBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Lease Liability Budget Amount' ;
    rdfs:comment 'Budgeted amount for aircraft and facility lease liabilities recognised under IFRS 16. Covers both operating lease right-of-use asset depreciation and interest on lease liabilities for dry lease and ACMI arrangements.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:loadFactorBudgetPct rdf:type rdf:Property ;
    rdfs:label 'Load Factor Budget Pct' ;
    rdfs:comment 'Budgeted passenger load factor expressed as a percentage (e.g., 82.50 = 82.5%). Load factor is the percentage of available seats filled by revenue passengers. Used in revenue budget planning and yield management alignment.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lockedDate rdf:type rdf:Property ;
    rdfs:label 'Locked Date' ;
    rdfs:comment 'The date on which the budget plan was locked to prevent further modifications, marking the start of the execution period. Locked budgets serve as the baseline for variance reporting.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:opexBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Opex Budget Amount' ;
    rdfs:comment 'Budgeted amount allocated to operating expenditure (OPEX) within this plan, including fuel, crew, maintenance, airport charges, and overhead. Key input for CASK (Cost per Available Seat Kilometer) reporting.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planName rdf:type rdf:Property ;
    rdfs:label 'Plan Name' ;
    rdfs:comment 'Human-readable descriptive name of the budget plan (e.g., \'FY2025 Annual Operating Budget\', \'Q3 2025 Rolling Forecast\'). Used for display and reporting purposes.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planNumber rdf:type rdf:Property ;
    rdfs:label 'Plan Number' ;
    rdfs:comment 'Externally-known alphanumeric identifier for the budget plan, aligned with SAP BPC plan version numbering (e.g., BP-2025-001). Used for cross-system reference and audit trails.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planStatus rdf:type rdf:Property ;
    rdfs:label 'Plan Status' ;
    rdfs:comment 'Current lifecycle state of the budget plan within the approval workflow. \'draft\' = in preparation; \'submitted\' = awaiting review; \'under_review\' = being evaluated; \'approved\' = board/CFO approved; \'rejected\' = returned for revision; \'locked\' = frozen for execution; \'archived\' = superseded. [ENUM-REF-CANDIDATE: draft|submitted|under_review|approved|rejected|locked|archived — promote to reference product]' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planType rdf:type rdf:Property ;
    rdfs:label 'Plan Type' ;
    rdfs:comment 'Classification of the budget plan by planning methodology. \'annual\' = full-year fixed budget; \'rolling_forecast\' = continuously updated forecast; \'supplemental\' = mid-year adjustment; \'capital\' = CAPEX-specific plan; \'zero_based\' = zero-based budgeting cycle.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planVersion rdf:type rdf:Property ;
    rdfs:label 'Plan Version' ;
    rdfs:comment 'Version identifier of the budget plan, supporting iterative planning cycles (e.g., \'v1.0\', \'v2.3\', \'RF-Q2\'). Enables tracking of revisions and rolling forecast iterations within SAP BPC.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planningHorizonYears rdf:type rdf:Property ;
    rdfs:label 'Planning Horizon Years' ;
    rdfs:comment 'Number of years covered by this budget plan (e.g., 1 for annual, 3 or 5 for multi-year strategic plans). Supports long-range financial planning and IFRS 16 lease liability projections.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:raskBudget rdf:type rdf:Property ;
    rdfs:label 'Rask Budget' ;
    rdfs:comment 'Budgeted Revenue per Available Seat Kilometer (RASK), calculated as total revenue budget divided by ASK budget. Expressed in currency units per ASK. Key airline revenue productivity metric for strategic planning and investor reporting.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Revenue Budget Amount' ;
    rdfs:comment 'Budgeted revenue target for the planning period, covering passenger revenue, cargo revenue, ancillary services, and loyalty program income. Supports RASK (Revenue per Available Seat Kilometer) planning.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:submissionDate rdf:type rdf:Property ;
    rdfs:label 'Submission Date' ;
    rdfs:comment 'The date on which the budget plan was formally submitted for review and approval. Supports planning cycle governance and deadline tracking.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalBudgetAmount rdf:type rdf:Property ;
    rdfs:label 'Total Budget Amount' ;
    rdfs:comment 'The gross total budgeted amount for this plan in the plan currency, covering all line items. Represents the top-line financial commitment approved for the planning period. Used for board-level financial reporting.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Variance Threshold Amount' ;
    rdfs:comment 'The maximum allowable absolute monetary deviation between budgeted and actual amounts before a variance alert is triggered. Complements the percentage threshold for large-value budget lines where a fixed amount cap is more appropriate.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceThresholdPct rdf:type rdf:Property ;
    rdfs:label 'Variance Threshold Pct' ;
    rdfs:comment 'The maximum allowable percentage deviation between budgeted and actual amounts before a variance alert is triggered for management review. Expressed as a percentage (e.g., 5.00 = 5%). Supports financial control and exception reporting.' ;
    rdfs:domain ind:BudgetPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelCostTransactionId rdf:type rdf:Property ;
    rdfs:label 'Fuel Cost Transaction Id' ;
    rdfs:comment 'Unique surrogate identifier for each fuel cost transaction record in the finance domain silver layer. Primary key for this data product.' ;
    rdfs:domain ind:FuelCostTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fuelUpliftId rdf:type rdf:Property ;
    rdfs:label 'Fuel Uplift Id' ;
    rdfs:comment 'Reference to the physical fuel uplift event recorded in flight operations (Jeppesen / NetLine/Ops). Links the financial accounting entry back to the operational fuel uplift record for CASK reconciliation.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FuelUplift .

ind:airportIataCode rdf:type rdf:Property ;
    rdfs:label 'Airport Iata Code' ;
    rdfs:comment 'Three-letter IATA airport code identifying the station where the fuel uplift occurred (e.g., LHR, JFK, DXB). Used for geographic cost analysis, into-plane agent reconciliation, and fuel price benchmarking by station.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carbonEmissionKg rdf:type rdf:Property ;
    rdfs:label 'Carbon Emission Kg' ;
    rdfs:comment 'Estimated CO2-equivalent carbon emissions in kilograms attributable to this fuel uplift, calculated using ICAO/CORSIA emission factors applied to the fuel quantity and SAF blend. Required for CORSIA offsetting obligations and ESG regulatory reporting.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeReference rdf:type rdf:Property ;
    rdfs:label 'Dispute Reference' ;
    rdfs:comment 'Reference number of any active or resolved supplier dispute raised against this fuel cost transaction (e.g., quantity discrepancy, pricing error). Populated when transaction_status = \'disputed\'. Used for accounts payable dispute management.' ;
    rdfs:domain ind:FuelCostTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelDensity rdf:type rdf:Property ;
    rdfs:label 'Fuel Density' ;
    rdfs:comment 'Measured fuel density in kilograms per litre at the time of uplift, as recorded on the fuel delivery receipt. Used to reconcile volumetric (litres) and mass (kg) quantities and to validate fuel quality compliance.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelSupplierName rdf:type rdf:Property ;
    rdfs:label 'Fuel Supplier Name' ;
    rdfs:comment 'Name of the fuel supplier (oil major or independent) who provided the fuel (e.g., Shell Aviation, BP Aviation, ExxonMobil Aviation, World Fuel Services). Used for supplier spend analysis and contract compliance monitoring.' ;
    rdfs:domain ind:FuelCostTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelType rdf:type rdf:Property ;
    rdfs:label 'Fuel Type' ;
    rdfs:comment 'Type of aviation fuel uplifted. \'Jet-A1\' is the standard international jet fuel; \'SAF\' is Sustainable Aviation Fuel; \'Jet-A\' is the US domestic equivalent; \'TS-1\' is Russian-standard jet fuel; \'JP-8\' is military-grade. Critical for CORSIA carbon accounting and SAF blending cost tracking.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:functionalCurrencyAmount rdf:type rdf:Property ;
    rdfs:label 'Functional Currency Amount' ;
    rdfs:comment 'Net fuel cost translated into the airline\'s functional (reporting) currency using the exchange rate at the posting date. Required for consolidated P&L reporting and CASK calculation in a single currency.' ;
    rdfs:domain ind:FuelCostTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fxRate rdf:type rdf:Property ;
    rdfs:label 'Fx Rate' ;
    rdfs:comment 'Exchange rate applied to convert the transaction currency amount to the functional currency at the posting date. Sourced from SAP S/4HANA treasury exchange rate tables. Required for IFRS IAS 21 compliance.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossCostAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Cost Amount' ;
    rdfs:comment 'Total gross cost of the fuel uplift before any discounts, surcharges, or tax adjustments, in the transaction currency. Calculated as quantity × unit price. Base figure for CASK fuel component reporting.' ;
    rdfs:domain ind:FuelCostTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hedgeGainLossAmount rdf:type rdf:Property ;
    rdfs:label 'Hedge Gain Loss Amount' ;
    rdfs:comment 'Monetary gain or loss on the fuel hedge for this uplift, calculated as (hedged_unit_price - actual unit_price) × quantity. Positive = hedge gain (actual price exceeded hedged price); negative = hedge loss. Posted to the hedge reserve in OCI under IFRS 9.' ;
    rdfs:domain ind:FuelCostTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hedgedUnitPrice rdf:type rdf:Property ;
    rdfs:label 'Hedged Unit Price' ;
    rdfs:comment 'The locked-in fuel price per litre from the hedging contract applicable to this uplift. Compared against the actual unit_price to calculate hedge gain/loss and measure hedge effectiveness per IFRS 9.' ;
    rdfs:domain ind:FuelCostTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:intoPlaneAgentName rdf:type rdf:Property ;
    rdfs:label 'Into Plane Agent Name' ;
    rdfs:comment 'Name of the into-plane fuelling agent responsible for the physical delivery of fuel to the aircraft at the airport (may differ from the fuel supplier). Into-plane agents are contracted separately and charge a service fee included in the surcharge amount.' ;
    rdfs:domain ind:FuelCostTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netCostAmount rdf:type rdf:Property ;
    rdfs:label 'Net Cost Amount' ;
    rdfs:comment 'Net total cost of the fuel uplift after applying discounts and adjustments but inclusive of taxes and surcharges, in the transaction currency. This is the amount posted to the General Ledger and used for CASK fuel component reporting.' ;
    rdfs:domain ind:FuelCostTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Posting Timestamp' ;
    rdfs:comment 'Date and time when the fuel cost was posted to the General Ledger in SAP S/4HANA FI. Used for period-end close, accrual management, and financial reporting cut-off.' ;
    rdfs:domain ind:FuelCostTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:purchaseOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Purchase Order Number' ;
    rdfs:comment 'SAP S/4HANA purchase order number raised for the fuel procurement at this station. Links the financial posting to the procurement process for three-way matching and spend analytics.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityKg rdf:type rdf:Property ;
    rdfs:label 'Quantity Kg' ;
    rdfs:comment 'Mass of fuel uplifted expressed in kilograms. The operationally authoritative unit for flight planning and weight-and-balance. Used for CASK fuel component calculation (cost per ASK) and fuel hedge effectiveness measurement.' ;
    rdfs:domain ind:FuelCostTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:quantityLitres rdf:type rdf:Property ;
    rdfs:label 'Quantity Litres' ;
    rdfs:comment 'Volume of fuel uplifted expressed in litres. Standard volumetric unit used for into-plane agent invoicing and fuel supplier billing. Used alongside quantity_kg for density reconciliation.' ;
    rdfs:domain ind:FuelCostTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:safBlendPercentage rdf:type rdf:Property ;
    rdfs:label 'Saf Blend Percentage' ;
    rdfs:comment 'Percentage of Sustainable Aviation Fuel (SAF) in the total fuel uplift volume (0.00–100.00). Required for CORSIA carbon offsetting calculations, SAF mandate compliance reporting, and ESG/sustainability disclosures.' ;
    rdfs:domain ind:FuelCostTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxAndSurchargeAmount rdf:type rdf:Property ;
    rdfs:label 'Tax And Surcharge Amount' ;
    rdfs:comment 'Total taxes, levies, and into-plane service surcharges applied to the fuel uplift in the transaction currency. Includes Passenger Facility Charges (PFC) where applicable, fuel throughput fees, and local fuel taxes.' ;
    rdfs:domain ind:FuelCostTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionNumber rdf:type rdf:Property ;
    rdfs:label 'Transaction Number' ;
    rdfs:comment 'Externally-known business document number assigned by SAP S/4HANA FI at the time of financial posting (e.g., FI document number or material document number). Used for audit trail and cross-system reconciliation.' ;
    rdfs:domain ind:FuelCostTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionStatus rdf:type rdf:Property ;
    rdfs:label 'Transaction Status' ;
    rdfs:comment 'Current lifecycle state of the fuel cost transaction in the financial system. \'posted\' = FI document posted to GL; \'reversed\' = reversal document created; \'pending\' = awaiting invoice matching; \'disputed\' = under supplier dispute; \'cancelled\' = voided prior to posting.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitPrice rdf:type rdf:Property ;
    rdfs:label 'Unit Price' ;
    rdfs:comment 'Price per litre (or per metric tonne where applicable) charged by the fuel supplier or into-plane agent for this uplift. Commercially sensitive. Used for fuel price variance analysis and hedge effectiveness measurement.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unitPriceCurrency rdf:type rdf:Property ;
    rdfs:label 'Unit Price Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the unit price is denominated (e.g., USD, EUR, GBP). Fuel is typically priced in USD at international stations; local currency may apply at domestic stations.' ;
    rdfs:domain ind:FuelCostTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upliftSourceType rdf:type rdf:Property ;
    rdfs:label 'Uplift Source Type' ;
    rdfs:comment 'Method by which fuel was delivered to the aircraft: \'hydrant\' = airport hydrant system; \'bowser\' = mobile fuel tanker truck; \'pipeline\' = direct pipeline connection; \'barge\' = waterborne fuel barge (seaplane/amphibious operations). Affects into-plane service fee rates.' ;
    rdfs:domain ind:FuelCostTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upliftTimestamp rdf:type rdf:Property ;
    rdfs:label 'Uplift Timestamp' ;
    rdfs:comment 'Date and time (UTC) when the physical fuel uplift occurred at the airport. This is the principal real-world business event time, distinct from the financial posting timestamp. Critical for matching operational fuel records to financial entries.' ;
    rdfs:domain ind:FuelCostTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:baseId rdf:type rdf:Property ;
    rdfs:label 'Base Id' ;
    rdfs:comment 'Foreign key linking to crew.crew_base. Business justification: Aircraft and facility leases associated with crew bases for base operating cost allocation, hub economics analysis, and IFRS 16 lease accounting. Essential for base profitability and cost attribution.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Base .

ind:legalEntityId rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Id' ;
    rdfs:comment 'Foreign key linking to finance.legal_entity. Business justification: The legal_entity product description explicitly states it is \'Referenced by lessee_entity_id\', confirming that lease_contract should carry a lessee_entity_id FK to legal_entity. Under IFRS 16, the les' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:assetCategory rdf:type rdf:Property ;
    rdfs:label 'Asset Category' ;
    rdfs:comment 'High-level asset class of the underlying leased asset. Used for IFRS 16 disclosure note groupings (right-of-use asset classes) and fleet planning integration.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetRegistration rdf:type rdf:Property ;
    rdfs:label 'Asset Registration' ;
    rdfs:comment 'ICAO/national civil aviation authority tail number or asset registration identifier for the leased aircraft or engine (e.g., N-number, G-prefix). Null for property leases and spare part pool agreements. Links to fleet planning and MRO systems.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commencementDate rdf:type rdf:Property ;
    rdfs:label 'Commencement Date' ;
    rdfs:comment 'Date on which the lessor makes the underlying asset available for use by the lessee. This is the IFRS 16 commencement date from which the right-of-use (ROU) asset and lease liability are initially recognised on the balance sheet.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractCurrency rdf:type rdf:Property ;
    rdfs:label 'Contract Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which lease payments are denominated (e.g., USD for US Dollar, EUR for Euro). Aircraft leases are predominantly USD-denominated. Drives FX translation to functional currency for IFRS reporting.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discountRatePct rdf:type rdf:Property ;
    rdfs:label 'Discount Rate Pct' ;
    rdfs:comment 'Annual discount rate used to calculate the present value of future lease payments. Represents the rate implicit in the lease if readily determinable; otherwise the lessee\'s incremental borrowing rate (IBR) as determined by the treasury function. Stored as a decimal fraction (e.g., 0.045000 = 4.5%).' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:functionalCurrency rdf:type rdf:Property ;
    rdfs:label 'Functional Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code of the reporting entity\'s functional currency. Used for translating the lease liability and ROU asset from contract currency to functional currency per IAS 21.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glLeaseLiabilityAccount rdf:type rdf:Property ;
    rdfs:label 'Gl Lease Liability Account' ;
    rdfs:comment 'SAP S/4HANA GL account code for the lease liability balance sheet line. Supports automated posting of opening balance, interest accrual, and principal repayment journal entries.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:glRouAssetAccount rdf:type rdf:Property ;
    rdfs:label 'Gl Rou Asset Account' ;
    rdfs:comment 'SAP S/4HANA GL account code for the right-of-use asset balance sheet line. Used for automated journal entry generation for initial recognition, depreciation, and derecognition of the ROU asset.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:governingLaw rdf:type rdf:Property ;
    rdfs:label 'Governing Law' ;
    rdfs:comment 'Legal jurisdiction whose laws govern the lease contract (e.g., \'English Law\', \'New York Law\', \'Irish Law\'). Relevant for dispute resolution, enforcement, and cross-border lease structuring common in aviation.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ifrs16ExemptionType rdf:type rdf:Property ;
    rdfs:label 'Ifrs16 Exemption Type' ;
    rdfs:comment 'Indicates whether the lease qualifies for a recognition exemption under IFRS 16. \'short_term\' = lease term of 12 months or less at commencement; \'low_value\' = underlying asset value below the entity\'s low-value threshold (typically USD 5,000); \'none\' = full IFRS 16 recognition required.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModificationDate rdf:type rdf:Property ;
    rdfs:label 'Last Modification Date' ;
    rdfs:comment 'Date of the most recent lease modification event (e.g., extension of lease term, change in lease payments, change in scope). Triggers remeasurement of the lease liability at the revised discount rate.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leaseLiabilityOpening rdf:type rdf:Property ;
    rdfs:label 'Lease Liability Opening' ;
    rdfs:comment 'Present value of the lease payments not yet made at the commencement date, discounted at the incremental borrowing rate (IBR) or the rate implicit in the lease. This is the initial recognition amount of the lease liability on the balance sheet.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leaseTermMonths rdf:type rdf:Property ;
    rdfs:label 'Lease Term Months' ;
    rdfs:comment 'Total lease term in whole months as determined under IFRS 16, including the non-cancellable period plus any optional renewal periods that the lessee is reasonably certain to exercise, and excluding optional termination periods the lessee is reasonably certain to exercise.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:leaseType rdf:type rdf:Property ;
    rdfs:label 'Lease Type' ;
    rdfs:comment 'Classification of the lease by asset category and operational arrangement. Dry lease = aircraft without crew; wet lease / ACMI (Aircraft Crew Maintenance Insurance) = aircraft with crew, maintenance, and insurance; engine_lease = standalone engine; spare_part_pool = access agreement for pooled spare parts; property_lease = airport lounges, hangars, office space. Determines IFRS 16 scope and disclosure grouping.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lessorCountryCode rdf:type rdf:Property ;
    rdfs:label 'Lessor Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the lessor\'s registered jurisdiction. Relevant for withholding tax treatment, OECD transfer pricing, and cross-border lease disclosure.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceReserveFlag rdf:type rdf:Property ;
    rdfs:label 'Maintenance Reserve Flag' ;
    rdfs:comment 'Indicates whether the lease contract includes maintenance reserve payments (common in aircraft dry leases). Maintenance reserves are typically excluded from IFRS 16 lease liability measurement and treated as variable lease payments or prepaid maintenance.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:modificationCount rdf:type rdf:Property ;
    rdfs:label 'Modification Count' ;
    rdfs:comment 'Running count of the number of lease modifications processed against this contract since commencement. Each modification triggers remeasurement of the lease liability and ROU asset per IFRS 16 paragraphs 44–46. Supports audit trail and modification history tracking.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paymentFrequency rdf:type rdf:Property ;
    rdfs:label 'Payment Frequency' ;
    rdfs:comment 'Frequency at which fixed lease payments are contractually due. Determines the period length used in the amortisation schedule and GL journal entry generation cadence.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentInAdvanceFlag rdf:type rdf:Property ;
    rdfs:label 'Payment In Advance Flag' ;
    rdfs:comment 'Indicates whether lease payments are due at the beginning (True) or end (False) of each payment period. Affects the timing of interest expense accrual and principal repayment in the IFRS 16 amortisation schedule.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:periodicLeasePayment rdf:type rdf:Property ;
    rdfs:label 'Periodic Lease Payment' ;
    rdfs:comment 'Fixed lease payment amount due per payment period (monthly, quarterly, or annually as defined by payment_frequency). Excludes variable lease payments not dependent on an index or rate. Used as the primary input to the amortisation schedule.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:purchaseOptionFlag rdf:type rdf:Property ;
    rdfs:label 'Purchase Option Flag' ;
    rdfs:comment 'Indicates whether the lease contract includes an option for the lessee to purchase the underlying asset. If the lessee is reasonably certain to exercise the purchase option, the option price is included in the lease liability measurement.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:purchaseOptionPrice rdf:type rdf:Property ;
    rdfs:label 'Purchase Option Price' ;
    rdfs:comment 'Contractual price at which the lessee may purchase the underlying asset if the purchase option is exercised. Included in the lease liability present value calculation when the lessee is reasonably certain to exercise. Null when purchase_option_flag is False.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:renewalOptionFlag rdf:type rdf:Property ;
    rdfs:label 'Renewal Option Flag' ;
    rdfs:comment 'Indicates whether the lease contract contains one or more renewal options exercisable by the lessee. When True, renewal_option_reasonably_certain_flag must be assessed for IFRS 16 lease term determination.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalOptionReasonablyCertain rdf:type rdf:Property ;
    rdfs:label 'Renewal Option Reasonably Certain' ;
    rdfs:comment 'Management\'s assessment of whether the lessee is reasonably certain to exercise the renewal option. When True, the optional renewal period is included in the IFRS 16 lease term and the lease liability is remeasured accordingly.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:residualValueGuarantee rdf:type rdf:Property ;
    rdfs:label 'Residual Value Guarantee' ;
    rdfs:comment 'Amount of any residual value guarantee provided by the lessee to the lessor, representing the lessee\'s exposure to the residual value of the leased asset at lease end. Included in the IFRS 16 lease liability measurement as a lease payment.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rouAssetValue rdf:type rdf:Property ;
    rdfs:label 'Rou Asset Value' ;
    rdfs:comment 'Initial carrying amount of the right-of-use (ROU) asset recognised on the balance sheet at the lease commencement date, comprising the initial lease liability measurement plus any initial direct costs, prepaid lease payments, and estimated dismantling costs, less any lease incentives received. Expressed in the contract currency.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:securityDepositAmount rdf:type rdf:Property ;
    rdfs:label 'Security Deposit Amount' ;
    rdfs:comment 'Cash security deposit paid to the lessor at lease commencement, refundable at lease expiry subject to asset return conditions. Classified as a financial asset (receivable) on the lessee\'s balance sheet, separate from the lease liability.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:terminationOptionFlag rdf:type rdf:Property ;
    rdfs:label 'Termination Option Flag' ;
    rdfs:comment 'Indicates whether the lease contract contains a termination option exercisable by the lessee before the contractual expiry date. Affects IFRS 16 lease term and liability measurement.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:terminationOptionReasonablyCertain rdf:type rdf:Property ;
    rdfs:label 'Termination Option Reasonably Certain' ;
    rdfs:comment 'Management\'s assessment of whether the lessee is reasonably certain to exercise the termination option. When True, the lease term is shortened to the termination date and the liability is remeasured.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:variablePaymentTerms rdf:type rdf:Property ;
    rdfs:label 'Variable Payment Terms' ;
    rdfs:comment 'Free-text description of any variable lease payment clauses, including index-linked escalation (e.g., CPI, LIBOR/SOFR), utilisation-based payments (e.g., per flight hour for ACMI), or maintenance reserve adjustments. Required for IFRS 16 disclosure notes.' ;
    rdfs:domain ind:LeaseContract ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaseLiabilityScheduleId rdf:type rdf:Property ;
    rdfs:label 'Lease Liability Schedule Id' ;
    rdfs:comment 'Unique surrogate identifier for each lease liability amortisation schedule record in the IFRS 16 ledger. Primary key for this table.' ;
    rdfs:domain ind:LeaseLiabilitySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:closingBalance rdf:type rdf:Property ;
    rdfs:label 'Closing Balance' ;
    rdfs:comment 'Carrying amount of the lease liability at the end of the period (opening balance + interest expense − principal repayment). Becomes the next period\'s opening balance. Key IFRS 16 balance sheet figure.' ;
    rdfs:domain ind:LeaseLiabilitySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discountRate rdf:type rdf:Property ;
    rdfs:label 'Discount Rate' ;
    rdfs:comment 'The interest rate used to discount future lease payments to present value, typically the lessee\'s incremental borrowing rate (IBR) or the implicit rate in the lease if determinable. Expressed as an annual decimal (e.g., 0.045 = 4.5%).' ;
    rdfs:domain ind:LeaseLiabilitySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:extensionOptionFlag rdf:type rdf:Property ;
    rdfs:label 'Extension Option Flag' ;
    rdfs:comment 'Indicates whether the lease term used in the liability calculation includes one or more extension option periods that management has assessed as reasonably certain to be exercised.' ;
    rdfs:domain ind:LeaseLiabilitySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:functionalCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Functional Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 code for the airline\'s functional currency used for consolidated financial reporting. Enables FX translation of foreign-currency lease liabilities for IFRS disclosure.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initialRecognitionAmount rdf:type rdf:Property ;
    rdfs:label 'Initial Recognition Amount' ;
    rdfs:comment 'Present value of future lease payments at the commencement date, representing the lease liability recognised on the balance sheet at inception. Equals the initial ROU asset cost (before initial direct costs and lease incentives).' ;
    rdfs:domain ind:LeaseLiabilitySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interestExpense rdf:type rdf:Property ;
    rdfs:label 'Interest Expense' ;
    rdfs:comment 'Finance charge accrued during the period calculated by applying the incremental borrowing rate (or implicit rate) to the opening lease liability balance. Posted to the P&L interest expense account.' ;
    rdfs:domain ind:LeaseLiabilitySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:journalEntryPostedFlag rdf:type rdf:Property ;
    rdfs:label 'Journal Entry Posted Flag' ;
    rdfs:comment 'Indicates whether the automated IFRS 16 journal entries (interest accrual and principal repayment) for this period have been successfully posted to the SAP S/4HANA general ledger. Supports period-close control and reconciliation.' ;
    rdfs:domain ind:LeaseLiabilitySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leaseEndDate rdf:type rdf:Property ;
    rdfs:label 'Lease End Date' ;
    rdfs:comment 'Contractual end date of the lease term, including any reasonably certain extension options. Used to determine the remaining lease term for present value calculations and maturity analysis disclosures.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leasePayment rdf:type rdf:Property ;
    rdfs:label 'Lease Payment' ;
    rdfs:comment 'Total cash payment made to the lessor during the period, comprising both the principal repayment and the interest component. Corresponds to the cash outflow in the statement of cash flows.' ;
    rdfs:domain ind:LeaseLiabilitySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:leaseStatus rdf:type rdf:Property ;
    rdfs:label 'Lease Status' ;
    rdfs:comment 'Current lifecycle state of the lease contract as of the period. Drives whether amortisation rows continue to be generated and whether remeasurement events have occurred.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lessorName rdf:type rdf:Property ;
    rdfs:label 'Lessor Name' ;
    rdfs:comment 'Legal name of the lessor (aircraft leasing company, property owner, or equipment provider) from whom the asset is leased. Common aviation lessors include AerCap, Air Lease Corporation, SMBC Aviation Capital.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lowValueAssetFlag rdf:type rdf:Property ;
    rdfs:label 'Low Value Asset Flag' ;
    rdfs:comment 'Indicates whether the lease qualifies for the IFRS 16 low-value asset exemption (underlying asset value when new is approximately USD 5,000 or below). When true, payments are expensed and no liability is recognised.' ;
    rdfs:domain ind:LeaseLiabilitySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:openingBalance rdf:type rdf:Property ;
    rdfs:label 'Opening Balance' ;
    rdfs:comment 'Carrying amount of the lease liability at the beginning of the period before any payments or interest accrual. Equals the prior period\'s closing balance. Core IFRS 16 disclosure figure.' ;
    rdfs:domain ind:LeaseLiabilitySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:periodEndDate rdf:type rdf:Property ;
    rdfs:label 'Period End Date' ;
    rdfs:comment 'Last calendar date of the amortisation period covered by this schedule row. Typically the last day of the accounting month or quarter.' ;
    rdfs:domain ind:LeaseLiabilitySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodSequence rdf:type rdf:Property ;
    rdfs:label 'Period Sequence' ;
    rdfs:comment 'Sequential integer identifying the ordinal position of this amortisation period within the full lease term (e.g., 1 = first period, 24 = twenty-fourth period). Enables ordered traversal of the schedule.' ;
    rdfs:domain ind:LeaseLiabilitySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:periodStartDate rdf:type rdf:Property ;
    rdfs:label 'Period Start Date' ;
    rdfs:comment 'First calendar date of the amortisation period covered by this schedule row. Aligns with the accounting period open date in the general ledger.' ;
    rdfs:domain ind:LeaseLiabilitySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:principalRepayment rdf:type rdf:Property ;
    rdfs:label 'Principal Repayment' ;
    rdfs:comment 'Portion of the lease payment that reduces the lease liability principal (lease payment minus interest expense). Classified as a financing cash outflow under IAS 7.' ;
    rdfs:domain ind:LeaseLiabilitySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remeasurementAmount rdf:type rdf:Property ;
    rdfs:label 'Remeasurement Amount' ;
    rdfs:comment 'Adjustment to the lease liability arising from a remeasurement event (e.g., lease modification, change in extension option assessment, change in index/rate). Positive values increase the liability; negative values decrease it.' ;
    rdfs:domain ind:LeaseLiabilitySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remeasurementDate rdf:type rdf:Property ;
    rdfs:label 'Remeasurement Date' ;
    rdfs:comment 'Date on which the lease liability was remeasured due to a triggering event such as a lease modification, reassessment of extension option, or change in variable lease payments linked to an index. Null if no remeasurement occurred in this period.' ;
    rdfs:domain ind:LeaseLiabilitySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remeasurementReason rdf:type rdf:Property ;
    rdfs:label 'Remeasurement Reason' ;
    rdfs:comment 'Reason code explaining why the lease liability was remeasured in this period. Required for IFRS 16 disclosure notes and auditor reconciliation. Null if no remeasurement occurred.' ;
    rdfs:domain ind:LeaseLiabilitySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shortTermLeaseFlag rdf:type rdf:Property ;
    rdfs:label 'Short Term Lease Flag' ;
    rdfs:comment 'Indicates whether the lease qualifies for the IFRS 16 short-term lease exemption (lease term of 12 months or less at commencement). When true, payments are expensed on a straight-line basis and no liability is recognised.' ;
    rdfs:domain ind:LeaseLiabilitySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:variableLeasePayment rdf:type rdf:Property ;
    rdfs:label 'Variable Lease Payment' ;
    rdfs:comment 'Lease payments that depend on an index or rate (e.g., CPI-linked rent escalations) included in the lease liability measurement. Excludes purely variable payments not based on an index or rate, which are expensed as incurred.' ;
    rdfs:domain ind:LeaseLiabilitySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:awbNumber rdf:type rdf:Property ;
    rdfs:label 'Awb Number' ;
    rdfs:comment 'Eleven-digit Air Waybill number (format: 3-digit airline code + 8-digit serial number) for cargo interline billing. Links billing to the cargo shipment.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingDocumentNumber rdf:type rdf:Property ;
    rdfs:label 'Billing Document Number' ;
    rdfs:comment 'Unique externally-known billing document number or reference assigned to this interline billing transaction. Used for reconciliation and audit trail.' ;
    rdfs:domain ind:InterlineBilling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingStatus rdf:type rdf:Property ;
    rdfs:label 'Billing Status' ;
    rdfs:comment 'Current lifecycle status of the interline billing record. Tracks the billing through submission, acceptance, dispute resolution, and final settlement stages.' ;
    rdfs:domain ind:InterlineBilling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingType rdf:type rdf:Property ;
    rdfs:label 'Billing Type' ;
    rdfs:comment 'Type of interline billing transaction. Categorizes the nature of the settlement: passenger ticketing, cargo waybill, ancillary services, or billing adjustment.' ;
    rdfs:domain ind:InterlineBilling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationAirportIataCode rdf:type rdf:Property ;
    rdfs:label 'Destination Airport Iata Code' ;
    rdfs:comment 'Three-letter IATA airport code for the destination of the interline segment. Identifies the arrival point for billing allocation.' ;
    rdfs:domain ind:InterlineBilling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossBillingAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Billing Amount' ;
    rdfs:comment 'Total gross amount billed before any adjustments, fees, or commissions. Base amount for the interline transaction.' ;
    rdfs:domain ind:InterlineBilling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netSettlementAmount rdf:type rdf:Property ;
    rdfs:label 'Net Settlement Amount' ;
    rdfs:comment 'Final net amount to be settled between airlines after all adjustments, commissions, and taxes. This is the actual payable or receivable amount.' ;
    rdfs:domain ind:InterlineBilling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originAirportIataCode rdf:type rdf:Property ;
    rdfs:label 'Origin Airport Iata Code' ;
    rdfs:comment 'Three-letter IATA airport code for the origin of the interline segment. Identifies the departure point for billing allocation.' ;
    rdfs:domain ind:InterlineBilling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Original Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code of the original transaction before currency conversion for settlement. Used for reconciliation and audit purposes.' ;
    rdfs:domain ind:InterlineBilling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerAirlineIataCode rdf:type rdf:Property ;
    rdfs:label 'Partner Airline Iata Code' ;
    rdfs:comment 'Two-character IATA airline designator code of the partner carrier involved in the interline agreement. Identifies the counterparty airline for billing settlement.' ;
    rdfs:domain ind:InterlineBilling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prorationAmount rdf:type rdf:Property ;
    rdfs:label 'Proration Amount' ;
    rdfs:comment 'Revenue or cost amount allocated to the partner airline based on interline proration rules. Represents the partner\'s share of the total ticket or waybill value.' ;
    rdfs:domain ind:InterlineBilling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementDueDate rdf:type rdf:Property ;
    rdfs:label 'Settlement Due Date' ;
    rdfs:comment 'Date by which the interline settlement payment is due. Defines the payment deadline per IATA settlement cycle rules.' ;
    rdfs:domain ind:InterlineBilling ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:settlementMethod rdf:type rdf:Property ;
    rdfs:label 'Settlement Method' ;
    rdfs:comment 'Method used for interline settlement. BSP (Billing and Settlement Plan) for passenger, ARC (Airlines Reporting Corporation) for US market, CASS (Cargo Accounts Settlement System) for cargo, direct bilateral billing, or ICH (IATA Clearing House).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxTransactionId rdf:type rdf:Property ;
    rdfs:label 'Tax Transaction Id' ;
    rdfs:comment 'Unique surrogate identifier for each tax posting record in the finance domain. Primary key for the tax_transaction data product.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TaxTransaction .

ind:bookingPaymentId rdf:type rdf:Property ;
    rdfs:label 'Booking Payment Id' ;
    rdfs:comment 'Foreign key linking to reservation.booking_payment. Business justification: Airport taxes and surcharges collected at booking are remitted to tax authorities. Tax_transaction must reference the booking_payment that collected the tax to support tax remittance reconciliation, a' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BookingPayment .

ind:profileId rdf:type rdf:Property ;
    rdfs:label 'Profile Id' ;
    rdfs:comment 'Reference to the customer or passenger party associated with this tax transaction, applicable for output VAT/GST on ancillary services, passenger facility charges, and airport taxes.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Profile .

ind:refundTransactionId rdf:type rdf:Property ;
    rdfs:label 'Refund Transaction Id' ;
    rdfs:comment 'Foreign key linking to reservation.refund_transaction. Business justification: When tickets are refunded, collected taxes must be reversed and refunded to passengers, requiring tax authority notification. Tax_transaction records the reversal and must reference the originating re' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RefundTransaction .

ind:airportCode rdf:type rdf:Property ;
    rdfs:label 'Airport Code' ;
    rdfs:comment 'Three-letter IATA airport code associated with this tax transaction, applicable for airport taxes, Passenger Facility Charges (PFC), and slot-related levies. Identifies the airport at which the tax obligation arises.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingReference rdf:type rdf:Property ;
    rdfs:label 'Filing Reference' ;
    rdfs:comment 'The reference number assigned by the tax authority or internal tax filing system when this tax transaction is included in a periodic tax return or remittance filing (e.g., VAT return reference, PFC quarterly report number, WHT certificate number).' ;
    rdfs:domain ind:TaxTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRecoverable rdf:type rdf:Property ;
    rdfs:label 'Is Recoverable' ;
    rdfs:comment 'Indicates whether this input tax amount is recoverable (reclaimable) from the tax authority as a credit against output tax liability. True for recoverable input VAT/GST; False for irrecoverable taxes such as non-deductible VAT on entertainment or blocked input tax.' ;
    rdfs:domain ind:TaxTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:localCurrencyTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Local Currency Tax Amount' ;
    rdfs:comment 'The tax amount translated into the company code\'s local (functional) currency using the exchange rate at posting date. Required for statutory financial reporting and local tax authority filings.' ;
    rdfs:domain ind:TaxTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remittanceDate rdf:type rdf:Property ;
    rdfs:label 'Remittance Date' ;
    rdfs:comment 'The date on which the tax amount was remitted (paid) to the relevant tax authority. Null until payment is made. Used to confirm compliance with statutory payment deadlines and avoid late payment penalties.' ;
    rdfs:domain ind:TaxTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reversalReasonCode rdf:type rdf:Property ;
    rdfs:label 'Reversal Reason Code' ;
    rdfs:comment 'SAP FI reversal reason code explaining why this tax posting was reversed (e.g., data entry error, duplicate posting, credit note issued). Null for non-reversed transactions.' ;
    rdfs:domain ind:TaxTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Source Document Reference' ;
    rdfs:comment 'The reference number of the originating source document (e.g., vendor invoice number, AWB number for cargo customs, PNR for passenger-related taxes, BSP billing reference). Enables traceability from tax posting back to the originating business transaction.' ;
    rdfs:domain ind:TaxTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceDocumentType rdf:type rdf:Property ;
    rdfs:label 'Source Document Type' ;
    rdfs:comment 'Type of the originating business document that generated this tax posting. INVOICE=vendor or customer invoice; CREDIT_NOTE=credit memo; PAYMENT=payment document; JOURNAL=manual journal entry; CUSTOMS_DECL=customs declaration for cargo; PFC_REPORT=Passenger Facility Charge quarterly report; WHT_CERT=withholding tax certificate. [ENUM-REF-CANDIDATE: INVOICE|CREDIT_NOTE|PAYMENT|JOURNAL|CUSTOMS_DECL|PFC_REPORT|WHT_CERT — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TaxTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Tax Authority Name' ;
    rdfs:comment 'Name of the government or regulatory body to which this tax is remitted (e.g., \'IRS\', \'HMRC\', \'Bundeszentralamt für Steuern\', \'FAA - PFC\'). Required for tax filing and regulatory reporting.' ;
    rdfs:domain ind:TaxTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxDirection rdf:type rdf:Property ;
    rdfs:label 'Tax Direction' ;
    rdfs:comment 'Indicates whether this is an input tax (recoverable tax paid on purchases/vendor invoices) or output tax (tax collected from customers on sales of ancillary services and tickets). Drives VAT/GST net settlement calculation.' ;
    rdfs:domain ind:TaxTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxJurisdictionCode rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction Code' ;
    rdfs:comment 'Code identifying the tax jurisdiction (country, state, or municipality) that levies this tax. Supports multi-jurisdiction tax compliance across the airline\'s global route network. Aligns with SAP FI-TX jurisdiction configuration.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxJurisdictionName rdf:type rdf:Property ;
    rdfs:label 'Tax Jurisdiction Name' ;
    rdfs:comment 'Human-readable name of the tax jurisdiction (e.g., \'United States Federal\', \'Germany VAT\', \'New York State\', \'London Heathrow Airport\'). Supports tax reporting and audit documentation.' ;
    rdfs:domain ind:TaxTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxPeriod rdf:type rdf:Property ;
    rdfs:label 'Tax Period' ;
    rdfs:comment 'The fiscal tax reporting period in YYYY-MM format to which this tax transaction belongs. Used for VAT/GST return filing, withholding tax remittance, and corporate income tax provision reporting.' ;
    rdfs:domain ind:TaxTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxRate rdf:type rdf:Property ;
    rdfs:label 'Tax Rate' ;
    rdfs:comment 'The applicable tax rate as a percentage (e.g., 20.0000 for 20% VAT, 7.5000 for 7.5% WHT). Sourced from the tax code configuration in SAP FI-TX and validated against jurisdiction-specific statutory rates.' ;
    rdfs:domain ind:TaxTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxReturnPeriod rdf:type rdf:Property ;
    rdfs:label 'Tax Return Period' ;
    rdfs:comment 'The period identifier for the tax return in which this transaction is reported to the tax authority. May be monthly (YYYY-MM) or quarterly (YYYY-Q1 through YYYY-Q4) depending on jurisdiction requirements.' ;
    rdfs:domain ind:TaxTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxableBaseAmount rdf:type rdf:Property ;
    rdfs:label 'Taxable Base Amount' ;
    rdfs:comment 'The gross monetary amount on which the tax is calculated, expressed in the transaction currency. For VAT/GST this is the net invoice value; for PFC it is the per-passenger charge base; for WHT it is the gross vendor payment.' ;
    rdfs:domain ind:TaxTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accumulatedDepreciation rdf:type rdf:Property ;
    rdfs:label 'Accumulated Depreciation' ;
    rdfs:comment 'Total depreciation charged against the asset from acquisition date to the current reporting period. Corresponds to SAP ANLC.KNAFA (cumulative ordinary depreciation). Used to compute net book value and for balance sheet reporting.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acquisitionCost rdf:type rdf:Property ;
    rdfs:label 'Acquisition Cost' ;
    rdfs:comment 'Original acquisition cost (historical cost) of the asset in the document currency at the time of purchase. For aircraft, includes purchase price, import duties, and directly attributable costs to bring the asset to its intended use. Corresponds to SAP ANLC.KANSW.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acquisitionDate rdf:type rdf:Property ;
    rdfs:label 'Acquisition Date' ;
    rdfs:comment 'Date on which the asset was acquired, purchased, or placed in service. Corresponds to SAP ANLA.AKTIV. Used as the start date for depreciation calculation and CAPEX reporting.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assetClassCode rdf:type rdf:Property ;
    rdfs:label 'Asset Class Code' ;
    rdfs:comment 'SAP asset class (ANLKL) categorising the asset for depreciation rules, GL account determination, and reporting. Examples: 1000=Aircraft, 1100=Aircraft Engines, 1200=Simulators, 2000=Ground Support Equipment, 3000=IT Infrastructure, 4000=Leasehold Improvements, 5000=Right-of-Use Assets (IFRS 16). [ENUM-REF-CANDIDATE: 1000|1100|1200|2000|3000|4000|5000|6000 — promote to reference product]' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetClassName rdf:type rdf:Property ;
    rdfs:label 'Asset Class Name' ;
    rdfs:comment 'Human-readable name of the SAP asset class (e.g., \'Aircraft\', \'Aircraft Engines\', \'Flight Simulators\', \'Ground Support Equipment\'). Denormalised for reporting convenience.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetDescription rdf:type rdf:Property ;
    rdfs:label 'Asset Description' ;
    rdfs:comment 'Primary human-readable description of the fixed asset (e.g., \'Boeing 737-800 MSN 45123\', \'Full Flight Simulator B737\', \'Ground Power Unit GPU-400\'). Corresponds to SAP ANLA.TXT50 field.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetLocationCode rdf:type rdf:Property ;
    rdfs:label 'Asset Location Code' ;
    rdfs:comment 'IATA airport or facility code indicating the primary physical location of the asset (e.g., \'LHR\' for Heathrow maintenance base, \'JFK\' for ground support equipment). Corresponds to SAP ANLA.STORT. Supports insurance valuation and physical asset verification.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetNumber rdf:type rdf:Property ;
    rdfs:label 'Asset Number' ;
    rdfs:comment 'SAP FI-AA main asset number uniquely identifying the asset within the company code. Corresponds to the ANLN1 field in SAP Asset Master (ANLZ/ANLB tables). Used for CAPEX tracking and asset register reconciliation.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetStatus rdf:type rdf:Property ;
    rdfs:label 'Asset Status' ;
    rdfs:comment 'Current lifecycle status of the fixed asset. \'active\' = in service and depreciating; \'under_construction\' = Asset Under Construction (AUC) not yet capitalised; \'disposed\' = sold, scrapped, or written off; \'transferred\' = transferred to another company code or cost centre; \'impaired\' = impairment loss recognised per IAS 36; \'deactivated\' = temporarily taken out of service.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetSubnumber rdf:type rdf:Property ;
    rdfs:label 'Asset Subnumber' ;
    rdfs:comment 'SAP FI-AA sub-number (ANLN2) used to track component-level assets under a main asset number, such as individual aircraft engines under a parent airframe asset. Supports component accounting per IAS 16.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetType rdf:type rdf:Property ;
    rdfs:label 'Asset Type' ;
    rdfs:comment 'Categorises the asset by ownership or lease arrangement. \'owned\' = outright purchase; \'finance_lease\' = IFRS 16 right-of-use finance lease; \'operating_lease_rou\' = IFRS 16 right-of-use operating lease; \'dry_lease\' = aircraft leased without crew; \'wet_lease\' = aircraft leased with crew; \'acmi\' = Aircraft Crew Maintenance Insurance lease. Drives IFRS 16 vs IAS 16 accounting treatment.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:capitalisationDate rdf:type rdf:Property ;
    rdfs:label 'Capitalisation Date' ;
    rdfs:comment 'Date on which the asset was formally capitalised and transferred from Asset Under Construction (AUC) to a productive asset class. May differ from acquisition_date for self-constructed assets or aircraft deliveries with pre-delivery payments.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:depreciationArea rdf:type rdf:Property ;
    rdfs:label 'Depreciation Area' ;
    rdfs:comment 'SAP FI-AA depreciation area code (AFABE) identifying the valuation basis (e.g., 01=Book Depreciation IFRS, 10=Tax Depreciation, 20=Group Reporting). Multiple depreciation areas allow parallel valuation for IFRS, local GAAP, and tax purposes.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:depreciationMethodCode rdf:type rdf:Property ;
    rdfs:label 'Depreciation Method Code' ;
    rdfs:comment 'Code identifying the depreciation method applied to the asset. SL=Straight-Line; DB=Declining Balance; UOP=Units of Production (e.g., flight cycles or block hours for engines); SOYD=Sum of Years Digits; NONE=Non-depreciable (e.g., land). Corresponds to SAP ANLB.AFASL.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposalDate rdf:type rdf:Property ;
    rdfs:label 'Disposal Date' ;
    rdfs:comment 'Date on which the asset was disposed of, sold, scrapped, or retired from service. Triggers cessation of depreciation and recognition of disposal gain or loss. Corresponds to SAP ANLA.DEAKT.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disposalProceeds rdf:type rdf:Property ;
    rdfs:label 'Disposal Proceeds' ;
    rdfs:comment 'Net proceeds received on disposal or sale of the asset. Used to calculate the gain or loss on disposal (disposal proceeds minus net book value at disposal date). Relevant for aircraft sales, part-out transactions, and GSE disposals.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impairmentLoss rdf:type rdf:Property ;
    rdfs:label 'Impairment Loss' ;
    rdfs:comment 'Cumulative impairment loss recognised on the asset where the carrying amount exceeds the recoverable amount. Applicable for aircraft fleets affected by route network changes, AOG events, or market value declines. Corresponds to SAP ANLC extraordinary depreciation.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceValue rdf:type rdf:Property ;
    rdfs:label 'Insurance Value' ;
    rdfs:comment 'Agreed hull insurance value of the asset as declared to the insurer, typically the agreed value or replacement cost for aircraft. Used for insurance premium calculation and claims settlement. May differ from net book value for older aircraft.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isIfrs16RouAsset rdf:type rdf:Property ;
    rdfs:label 'Is Ifrs16 Rou Asset' ;
    rdfs:comment 'Indicates whether this asset is a right-of-use (ROU) asset recognised under IFRS 16 Leases. True for aircraft, engines, and equipment under finance or operating leases. Drives separate balance sheet presentation and disclosure requirements.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:leaseCommencementDate rdf:type rdf:Property ;
    rdfs:label 'Lease Commencement Date' ;
    rdfs:comment 'Date on which the lease term commences and the right-of-use (ROU) asset is recognised on the balance sheet under IFRS 16. Determines the start of ROU asset amortisation and lease liability unwinding.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:netBookValue rdf:type rdf:Property ;
    rdfs:label 'Net Book Value' ;
    rdfs:comment 'Current net book value of the asset calculated as acquisition cost minus accumulated depreciation and any impairment losses. Corresponds to SAP ANLC carrying amount. Key metric for CAPEX tracking, insurance valuation, and balance sheet reporting.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:registrationNumber rdf:type rdf:Property ;
    rdfs:label 'Registration Number' ;
    rdfs:comment 'Official civil aviation authority registration number (tail number) assigned to the aircraft asset (e.g., G-BOAC, N12345). Applicable to aircraft and rotorcraft assets. Used for cross-referencing with flight operations, MRO, and insurance records.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:residualValue rdf:type rdf:Property ;
    rdfs:label 'Residual Value' ;
    rdfs:comment 'Estimated residual (salvage) value of the asset at the end of its useful life. For aircraft, this is typically the estimated scrap or resale value. Depreciation is calculated on the depreciable amount (acquisition cost minus residual value). Corresponds to SAP ANLB.SCHRW.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revaluationAmount rdf:type rdf:Property ;
    rdfs:label 'Revaluation Amount' ;
    rdfs:comment 'Cumulative revaluation surplus or deficit recognised where the airline applies the revaluation model for aircraft or property assets. Recorded in Other Comprehensive Income (OCI) under IAS 16 revaluation model. Corresponds to SAP ANLC.KZINS.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serialNumber rdf:type rdf:Property ;
    rdfs:label 'Serial Number' ;
    rdfs:comment 'Manufacturer serial number (MSN) or equipment serial number uniquely identifying the physical asset. For aircraft, this is the Manufacturer Serial Number (MSN); for engines, the Engine Serial Number (ESN). Critical for cross-referencing with AMOS maintenance records and insurance policies.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usefulLifePeriods rdf:type rdf:Property ;
    rdfs:label 'Useful Life Periods' ;
    rdfs:comment 'Remaining useful life expressed in fiscal periods (months) within the current fiscal year. Complements useful_life_years for mid-year acquisitions and partial-period depreciation calculations. Corresponds to SAP ANLB.NDPER.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:usefulLifeYears rdf:type rdf:Property ;
    rdfs:label 'Useful Life Years' ;
    rdfs:comment 'Estimated useful economic life of the asset in years as defined in the depreciation key. For aircraft, typically 20-25 years; for engines, 15-20 years; for simulators, 10-15 years; for IT infrastructure, 3-5 years. Corresponds to SAP ANLB.NDJAR.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vendorNumber rdf:type rdf:Property ;
    rdfs:label 'Vendor Number' ;
    rdfs:comment 'SAP vendor account number (LIFNR) of the supplier or lessor from whom the asset was acquired or leased. Used for accounts payable reconciliation and CAPEX purchase order matching.' ;
    rdfs:domain ind:FixedAsset ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:airlineAccountingCode rdf:type rdf:Property ;
    rdfs:label 'Airline Accounting Code' ;
    rdfs:comment 'Three-digit IATA numeric airline accounting code (also known as the airline prefix) used in e-ticket stock numbering, interline billing, and BSP/ARC settlement transactions. Uniquely identifies the airline in financial settlement systems.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arcParticipantFlag rdf:type rdf:Property ;
    rdfs:label 'Arc Participant Flag' ;
    rdfs:comment 'Indicates whether this legal entity participates in the Airlines Reporting Corporation (ARC) settlement system for US domestic ticket sales. Relevant for North American entities and drives ARC settlement accounts receivable processing.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bspParticipantFlag rdf:type rdf:Property ;
    rdfs:label 'Bsp Participant Flag' ;
    rdfs:comment 'Indicates whether this legal entity is a registered participant in the IATA Billing and Settlement Plan (BSP) for settlement of ticket sales through travel agents. Drives interline billing and accounts receivable settlement workflows.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:chartOfAccounts rdf:type rdf:Property ;
    rdfs:label 'Chart Of Accounts' ;
    rdfs:comment 'Four-character SAP code identifying the chart of accounts assigned to this company code. Defines the general ledger account structure, account numbering, and account descriptions applicable to all financial postings. Corresponds to SAP KTOPL field.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyCodeCode rdf:type rdf:Property ;
    rdfs:label 'Company Code Code' ;
    rdfs:comment 'Four-character alphanumeric SAP FI company code uniquely identifying the legal entity within the SAP S/4HANA system. Matches the SAP Bukrs field. Used as the primary business key across all FI/CO postings, journal entries, and financial statements.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:companyCodeStatus rdf:type rdf:Property ;
    rdfs:label 'Company Code Status' ;
    rdfs:comment 'Current lifecycle status of the company code within SAP FI. Controls whether new financial postings can be made against this entity. \'inactive\' blocks new postings; \'in_liquidation\' triggers specific closing procedures under IFRS.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationGroup rdf:type rdf:Property ;
    rdfs:label 'Consolidation Group' ;
    rdfs:comment 'Identifier of the financial consolidation group to which this company code belongs within the group reporting hierarchy. Used for intercompany elimination, minority interest calculations, and preparation of consolidated financial statements under IFRS 10.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationUnit rdf:type rdf:Property ;
    rdfs:label 'Consolidation Unit' ;
    rdfs:comment 'SAP Group Reporting consolidation unit identifier mapped to this company code. Represents the lowest-level reporting unit in the consolidation hierarchy for multi-entity financial roll-up and statutory consolidation.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controllingArea rdf:type rdf:Property ;
    rdfs:label 'Controlling Area' ;
    rdfs:comment 'Four-character SAP CO controlling area code assigned to this company code. Defines the scope of cost accounting, profit center accounting, and internal order management. Enables CASK (Cost per Available Seat Kilometer) and RASK reporting by aligning cost objects to revenue data.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:corsiaParticipantFlag rdf:type rdf:Property ;
    rdfs:label 'Corsia Participant Flag' ;
    rdfs:comment 'Indicates whether this legal entity is subject to CORSIA (Carbon Offsetting and Reduction Scheme for International Aviation) obligations. Drives carbon offset liability accounting and regulatory reporting to ICAO.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:countryOfIncorporation rdf:type rdf:Property ;
    rdfs:label 'Country Of Incorporation' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code of the jurisdiction in which the legal entity is incorporated. Drives statutory reporting requirements, applicable tax law, and national civil aviation authority oversight.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveFromDate rdf:type rdf:Property ;
    rdfs:label 'Effective From Date' ;
    rdfs:comment 'Date from which this company code became active and eligible for financial postings in SAP FI. Marks the start of the entity\'s operational financial lifecycle within the group.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveToDate rdf:type rdf:Property ;
    rdfs:label 'Effective To Date' ;
    rdfs:comment 'Date on which this company code was deactivated or ceased financial operations. Null for currently active entities. Used to enforce period-end close and prevent postings after entity dissolution or merger.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:entityType rdf:type rdf:Property ;
    rdfs:label 'Entity Type' ;
    rdfs:comment 'Classification of the legal entity by its corporate structure. Determines consolidation treatment, intercompany elimination rules, and applicable accounting standards. [ENUM-REF-CANDIDATE: airline|subsidiary|holding|joint_venture|special_purpose_vehicle|branch — promote to reference product if additional types are required]' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalYearVariant rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year Variant' ;
    rdfs:comment 'Two-character SAP code defining the fiscal year structure for this company code, including the number of posting periods, special periods, and whether the fiscal year aligns with the calendar year. Corresponds to SAP PERIV field. Critical for period-end close and CASK reporting cycles.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Group Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code of the parent group\'s reporting currency used for financial consolidation. Transactions in local currency are translated to group currency for consolidated financial statements.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iataAirlineCode rdf:type rdf:Property ;
    rdfs:label 'Iata Airline Code' ;
    rdfs:comment 'Two-character IATA airline designator code assigned to this legal entity. Used in BSP (Billing and Settlement Plan) settlements, interline billing, ticket issuance, and ARC (Airlines Reporting Corporation) reporting. Links financial entity to operational airline identity.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icaoAirlineCode rdf:type rdf:Property ;
    rdfs:label 'Icao Airline Code' ;
    rdfs:comment 'Three-letter ICAO airline designator code for this legal entity. Used in flight plan filings, ATC communications, NOTAM references, and regulatory correspondence with national civil aviation authorities.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ifrs16LesseeFlag rdf:type rdf:Property ;
    rdfs:label 'Ifrs16 Lessee Flag' ;
    rdfs:comment 'Indicates whether this company code is subject to IFRS 16 Leases accounting, requiring recognition of right-of-use assets and lease liabilities on the balance sheet. Applicable to entities with aircraft dry leases, wet leases, or ACMI arrangements.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ifrsReportingStandard rdf:type rdf:Property ;
    rdfs:label 'Ifrs Reporting Standard' ;
    rdfs:comment 'Accounting standard under which this legal entity prepares its statutory financial statements. Determines recognition, measurement, and disclosure requirements including IFRS 16 lease liability treatment and CORSIA carbon offset accounting.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incorporationDate rdf:type rdf:Property ;
    rdfs:label 'Incorporation Date' ;
    rdfs:comment 'Date on which the legal entity was formally incorporated or registered with the relevant national company registry. Used for entity lifecycle tracking and statutory reporting.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:intercompanyEliminationFlag rdf:type rdf:Property ;
    rdfs:label 'Intercompany Elimination Flag' ;
    rdfs:comment 'Indicates whether intercompany transactions posted against this company code are subject to elimination during group financial consolidation. True for entities within the consolidation perimeter; false for associates or joint ventures accounted for under equity method.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalName rdf:type rdf:Property ;
    rdfs:label 'Legal Name' ;
    rdfs:comment 'Full registered legal name of the entity as recorded with the relevant national company registry or civil aviation authority. Used for statutory reporting, regulatory filings, and intercompany agreements.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Operating Certificate Number' ;
    rdfs:comment 'Air Operator Certificate (AOC) number issued by the national civil aviation authority authorising this legal entity to conduct commercial air transport operations. Links the financial entity to its operational regulatory authorisation.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipPercentage rdf:type rdf:Property ;
    rdfs:label 'Ownership Percentage' ;
    rdfs:comment 'Percentage of equity ownership held by the immediate parent entity in this legal entity. Determines consolidation method: full consolidation (>50%), equity method (20-50%), or cost method (<20%) under IFRS 10/IAS 28.' ;
    rdfs:domain ind:Finance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postingPeriodVariant rdf:type rdf:Property ;
    rdfs:label 'Posting Period Variant' ;
    rdfs:comment 'Four-character SAP code controlling which fiscal periods are open or closed for posting in this company code. Governs period-end close procedures and prevents backdated postings outside approved windows. Corresponds to SAP BDATV field.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredAddress rdf:type rdf:Property ;
    rdfs:label 'Registered Address' ;
    rdfs:comment 'Full registered office address of the legal entity as recorded with the national company registry. Used for statutory correspondence, regulatory filings, and legal notices.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredAddressCountry rdf:type rdf:Property ;
    rdfs:label 'Registered Address Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the registered office address of the legal entity. May differ from country of incorporation for branch entities. Required for statutory filings and regulatory correspondence.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystem rdf:type rdf:Property ;
    rdfs:label 'Source System' ;
    rdfs:comment 'Identifies the operational system of record from which this company code record was sourced. Supports data lineage, reconciliation, and Silver Layer provenance tracking.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vatRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Vat Registration Number' ;
    rdfs:comment 'Official VAT or GST registration number issued by the national tax authority for this legal entity. Required for VAT invoicing, reclaim submissions, and cross-border tax compliance. Sensitive business identifier.' ;
    rdfs:domain ind:CompanyCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slotId rdf:type rdf:Property ;
    rdfs:label 'Slot Id' ;
    rdfs:comment 'Foreign key linking to airport.slot. Business justification: IATA slot coordination requires each scheduled flight service to be assigned a specific airport slot. Schedule planning teams link scheduled flights to allocated slots for season filing, historic prec' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Slot .

ind:arrivalAirportCode rdf:type rdf:Property ;
    rdfs:label 'Arrival Airport Code' ;
    rdfs:comment 'Three-letter IATA airport code for the scheduled arrival airport (e.g., LAX, CDG, SIN).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Block Time Minutes' ;
    rdfs:comment 'Planned block time in minutes from gate departure (Out) to gate arrival (In). This is the scheduled elapsed time for the flight leg.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:departureAirportCode rdf:type rdf:Property ;
    rdfs:label 'Departure Airport Code' ;
    rdfs:comment 'Three-letter IATA airport code for the scheduled departure airport (e.g., JFK, LHR, DXB).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departureTerminal rdf:type rdf:Property ;
    rdfs:label 'Departure Terminal' ;
    rdfs:comment 'Scheduled departure terminal identifier at the origin airport (e.g., Terminal 1, T3, Concourse B).' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveUntilDate rdf:type rdf:Property ;
    rdfs:label 'Effective Until Date' ;
    rdfs:comment 'The last date this scheduled flight is valid and may operate. End of the schedule validity period. Nullable for open-ended schedules.' ;
    rdfs:domain ind:ScheduledFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:etopsApprovalIndicator rdf:type rdf:Property ;
    rdfs:label 'Etops Approval Indicator' ;
    rdfs:comment 'Flag indicating whether this scheduled flight route requires ETOPS certification for twin-engine aircraft operations over extended distances from diversion airports. True if ETOPS-certified route required.' ;
    rdfs:domain ind:ScheduledFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:flightDistanceKm rdf:type rdf:Property ;
    rdfs:label 'Flight Distance Km' ;
    rdfs:comment 'Great circle distance between departure and arrival airports in kilometers. Used for RPK and ASK calculations.' ;
    rdfs:domain ind:ScheduledFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mealServiceCode rdf:type rdf:Property ;
    rdfs:label 'Meal Service Code' ;
    rdfs:comment 'Single-character IATA code indicating the type of meal service provided: B=Breakfast, L=Lunch, D=Dinner, S=Snack, M=Meal (unspecified), N=No meal service.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumConnectingTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Minimum Connecting Time Minutes' ;
    rdfs:comment 'Minimum time in minutes required for passengers to make a legal connection from this flight to another flight at the arrival airport. Varies by airport, terminal, and connection type (domestic-domestic, domestic-international, international-international).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Status' ;
    rdfs:comment 'Status of regulatory approval from civil aviation authorities for this scheduled flight route and slot allocation: approved (fully authorized), pending (awaiting approval), conditional (approved with restrictions), or denied (not authorized).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeNetworkType rdf:type rdf:Property ;
    rdfs:label 'Route Network Type' ;
    rdfs:comment 'Classification of the scheduled flight within the airlines route network strategy: hub_spoke (connecting through a hub), point_to_point (direct city-pair), regional_feeder (short-haul feed to hub), long_haul_international (intercontinental), or domestic_trunk (major domestic route).' ;
    rdfs:domain ind:ScheduledFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleStatus rdf:type rdf:Property ;
    rdfs:label 'Schedule Status' ;
    rdfs:comment 'Current lifecycle status of the scheduled flight: active (currently operating), suspended (temporarily not operating), cancelled (permanently removed), seasonal_inactive (out of season), or pending_approval (awaiting regulatory approval).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleVersionNumber rdf:type rdf:Property ;
    rdfs:label 'Schedule Version Number' ;
    rdfs:comment 'Version number of this schedule record. Incremented each time the scheduled flight details are modified (time changes, equipment changes, etc.). Supports schedule change tracking and audit.' ;
    rdfs:domain ind:ScheduledFlight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceType rdf:type rdf:Property ;
    rdfs:label 'Service Type' ;
    rdfs:comment 'Classification of the flight service: passenger (revenue passenger service), cargo (freight-only), ferry (non-revenue repositioning), charter (non-scheduled charter), or positioning (crew/aircraft repositioning).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trafficRestrictionCode rdf:type rdf:Property ;
    rdfs:label 'Traffic Restriction Code' ;
    rdfs:comment 'IATA traffic restriction code indicating any limitations on passenger or cargo carriage (e.g., C=Cargo only, G=Technical stop no traffic rights, F=Passenger service only). Empty if no restrictions.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualArrivalTime rdf:type rdf:Property ;
    rdfs:label 'Actual Arrival Time' ;
    rdfs:comment 'The actual time the aircraft arrived at the gate (In time in OOOI), in local airport timezone.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualDepartureTime rdf:type rdf:Property ;
    rdfs:label 'Actual Departure Time' ;
    rdfs:comment 'The actual time the aircraft departed the gate (Out time in OOOI), in local airport timezone.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:airborneTimeHours rdf:type rdf:Property ;
    rdfs:label 'Airborne Time Hours' ;
    rdfs:comment 'Total time the aircraft was airborne, from wheels-off (Off) to wheels-on (On), measured in hours.' ;
    rdfs:domain ind:FlightLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:aircraftRegistration rdf:type rdf:Property ;
    rdfs:label 'Aircraft Registration' ;
    rdfs:comment 'The unique aircraft registration number (tail number) assigned to the aircraft operating this flight leg.' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockHours rdf:type rdf:Property ;
    rdfs:label 'Block Hours' ;
    rdfs:comment 'Total elapsed time from gate departure (Out) to gate arrival (In), measured in hours. Key metric for flight operations and crew duty time.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cancellationReasonCode rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason Code' ;
    rdfs:comment 'Code indicating the reason for flight cancellation (e.g., weather, mechanical, crew, operational).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:delayCode rdf:type rdf:Property ;
    rdfs:label 'Delay Code' ;
    rdfs:comment 'IATA standard two-digit delay code indicating the primary reason for any departure or arrival delay.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:delayMinutes rdf:type rdf:Property ;
    rdfs:label 'Delay Minutes' ;
    rdfs:comment 'Total delay time in minutes, calculated as the difference between scheduled and actual departure or arrival time.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dispatchReleaseNumber rdf:type rdf:Property ;
    rdfs:label 'Dispatch Release Number' ;
    rdfs:comment 'Unique identifier for the dispatch release document authorizing this flight leg to operate, issued by flight dispatch.' ;
    rdfs:domain ind:FlightLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diversionAirportCode rdf:type rdf:Property ;
    rdfs:label 'Diversion Airport Code' ;
    rdfs:comment 'Three-letter IATA airport code for the alternate airport if the flight was diverted from its original destination.' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedArrivalTime rdf:type rdf:Property ;
    rdfs:label 'Estimated Arrival Time' ;
    rdfs:comment 'The current estimated arrival time, updated based on operational conditions. ETA is the best current estimate of when the flight will arrive.' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:estimatedDepartureTime rdf:type rdf:Property ;
    rdfs:label 'Estimated Departure Time' ;
    rdfs:comment 'The current estimated departure time, updated based on operational conditions. ETD is the best current estimate of when the flight will depart.' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:flightStatus rdf:type rdf:Property ;
    rdfs:label 'Flight Status' ;
    rdfs:comment 'Current operational status of the flight leg in its lifecycle. Tracks progression from scheduled through boarding, departure, airborne, landing, arrival, or exceptional states like cancelled or diverted. [ENUM-REF-CANDIDATE: scheduled|boarding|departed|airborne|landed|arrived|cancelled|diverted — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FlightLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flightStatusTimestamp rdf:type rdf:Property ;
    rdfs:label 'Flight Status Timestamp' ;
    rdfs:comment 'The timestamp when the current flight status was last updated, in UTC.' ;
    rdfs:domain ind:FlightLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fuelUpliftKg rdf:type rdf:Property ;
    rdfs:label 'Fuel Uplift Kg' ;
    rdfs:comment 'The amount of fuel loaded onto the aircraft for this flight leg, measured in kilograms.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inTime rdf:type rdf:Property ;
    rdfs:label 'In Time' ;
    rdfs:comment 'The time the aircraft arrived at the gate and parking brake was set. Fourth event in OOOI (Out-Off-On-In) sequence.' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:offTime rdf:type rdf:Property ;
    rdfs:label 'Off Time' ;
    rdfs:comment 'The time the aircraft wheels left the ground at takeoff. Second event in OOOI (Out-Off-On-In) sequence.' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:onTime rdf:type rdf:Property ;
    rdfs:label 'On Time' ;
    rdfs:comment 'The time the aircraft wheels touched down on the runway at landing. Third event in OOOI (Out-Off-On-In) sequence.' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:operatingDate rdf:type rdf:Property ;
    rdfs:label 'Operating Date' ;
    rdfs:comment 'The date on which this flight leg is operated or planned to be operated, in local departure timezone.' ;
    rdfs:domain ind:FlightLeg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:outTime rdf:type rdf:Property ;
    rdfs:label 'Out Time' ;
    rdfs:comment 'The time the aircraft pushed back from the gate or began taxi for departure. First event in OOOI (Out-Off-On-In) sequence.' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:publicStatusMessage rdf:type rdf:Property ;
    rdfs:label 'Public Status Message' ;
    rdfs:comment 'Customer-facing status message displayed on airport FIDS, mobile apps, and passenger notifications describing the current flight status.' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusSource rdf:type rdf:Property ;
    rdfs:label 'Status Source' ;
    rdfs:comment 'The source system or feed that provided the current flight status update (ACARS, ATC feed, airport FIDS, manual OCC update, GDS, NetLine/Ops).' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatchReleaseId rdf:type rdf:Property ;
    rdfs:label 'Dispatch Release Id' ;
    rdfs:comment 'Unique identifier for the dispatch release document. Primary key for the dispatch release entity.' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DispatchRelease .

ind:departureStationId rdf:type rdf:Property ;
    rdfs:label 'Departure Station Id' ;
    rdfs:comment 'Foreign key linking to airport.station. Business justification: Dispatch releases are issued by the dispatcher at the departure station and are subject to station-specific regulatory authority oversight. Linking to station enables station-level dispatch audit repo' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Station .

ind:etopsAuthorizationId rdf:type rdf:Property ;
    rdfs:label 'Etops Authorization Id' ;
    rdfs:comment 'Foreign key linking to fleet.etops_authorization. Business justification: Dispatchers must verify and record the specific ETOPS authorization used when releasing an ETOPS flight. FAA/EASA regulations require traceability from the dispatch release to the valid authorization.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EtopsAuthorization .

ind:memberId rdf:type rdf:Property ;
    rdfs:label 'Member Id' ;
    rdfs:comment 'Reference to the pilot-in-command (captain) who accepted and co-signed this dispatch release.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Member .

ind:planId rdf:type rdf:Property ;
    rdfs:label 'Plan Id' ;
    rdfs:comment 'Foreign key linking to flight.flight_plan. Business justification: Dispatch release is based on and references a specific flight plan version. The dispatcher reviews the flight plan and issues the release authorizing departure. This is a core operational relationship' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Plan .

ind:releaseId rdf:type rdf:Property ;
    rdfs:label 'Release Id' ;
    rdfs:comment 'Foreign key linking to maintenance.release. Business justification: Dispatchers must verify the maintenance CRS before issuing a dispatch release — a direct regulatory requirement under Part 121. Linking dispatch_release.release_id → maintenance.release.release_id rep' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Release .

ind:supersededByReleaseDispatchReleaseId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Release Dispatch Release Id' ;
    rdfs:comment 'Reference to the dispatch release that superseded this one, if applicable. Used to track release amendment history.' ;
    rdfs:domain ind:DispatchRelease ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DispatchRelease .

ind:aircraftType rdf:type rdf:Property ;
    rdfs:label 'Aircraft Type' ;
    rdfs:comment 'ICAO aircraft type designator for the aircraft assigned to this flight (e.g., B738, A320, B77W).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alternateAirport1Icao rdf:type rdf:Property ;
    rdfs:label 'Alternate Airport 1 Icao' ;
    rdfs:comment 'Four-letter ICAO code of the primary alternate airport designated in case destination is unavailable.' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alternateAirport2Icao rdf:type rdf:Property ;
    rdfs:label 'Alternate Airport 2 Icao' ;
    rdfs:comment 'Four-letter ICAO code of the secondary alternate airport if required by operational conditions or regulations.' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alternateFuelKg rdf:type rdf:Property ;
    rdfs:label 'Alternate Fuel Kg' ;
    rdfs:comment 'Fuel required to fly from destination to the designated alternate airport, measured in kilograms.' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:captainName rdf:type rdf:Property ;
    rdfs:label 'Captain Name' ;
    rdfs:comment 'Full name of the pilot-in-command who accepted this dispatch release.' ;
    rdfs:domain ind:DispatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:captainSignoffTimestamp rdf:type rdf:Property ;
    rdfs:label 'Captain Signoff Timestamp' ;
    rdfs:comment 'Date and time when the captain electronically accepted and co-signed the dispatch release, indicating agreement with flight plan and operational conditions.' ;
    rdfs:domain ind:DispatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cargoWeightKg rdf:type rdf:Property ;
    rdfs:label 'Cargo Weight Kg' ;
    rdfs:comment 'Total weight of cargo and baggage loaded on this flight, measured in kilograms.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contingencyFuelKg rdf:type rdf:Property ;
    rdfs:label 'Contingency Fuel Kg' ;
    rdfs:comment 'Additional fuel to account for unforeseen factors such as weather deviations or ATC (Air Traffic Control) routing changes, typically 5% of trip fuel or 5 minutes holding, measured in kilograms.' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departureAirportIcao rdf:type rdf:Property ;
    rdfs:label 'Departure Airport Icao' ;
    rdfs:comment 'Four-letter ICAO code of the departure airport for this flight leg.' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departureMetar rdf:type rdf:Property ;
    rdfs:label 'Departure Metar' ;
    rdfs:comment 'Current METAR weather observation for the departure airport at time of dispatch release issuance.' ;
    rdfs:domain ind:DispatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationAirportIcao rdf:type rdf:Property ;
    rdfs:label 'Destination Airport Icao' ;
    rdfs:comment 'Four-letter ICAO code of the destination airport for this flight leg.' ;
    rdfs:domain ind:DispatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationMetar rdf:type rdf:Property ;
    rdfs:label 'Destination Metar' ;
    rdfs:comment 'Current METAR weather observation for the destination airport at time of dispatch release issuance.' ;
    rdfs:domain ind:DispatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationTaf rdf:type rdf:Property ;
    rdfs:label 'Destination Taf' ;
    rdfs:comment 'Terminal Aerodrome Forecast for the destination airport covering the estimated time of arrival window.' ;
    rdfs:domain ind:DispatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatcherLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Dispatcher License Number' ;
    rdfs:comment 'FAA or EASA license number of the dispatcher who authorized this release. Required for regulatory compliance.' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatcherName rdf:type rdf:Property ;
    rdfs:label 'Dispatcher Name' ;
    rdfs:comment 'Full name of the certified flight dispatcher who issued this dispatch release.' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatcherSignoffTimestamp rdf:type rdf:Property ;
    rdfs:label 'Dispatcher Signoff Timestamp' ;
    rdfs:comment 'Date and time when the dispatcher electronically signed and approved the dispatch release.' ;
    rdfs:domain ind:DispatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:estimatedBlockTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Estimated Block Time Minutes' ;
    rdfs:comment 'Estimated total block time from gate departure (out) to gate arrival (in), measured in minutes.' ;
    rdfs:domain ind:DispatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedFlightTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Estimated Flight Time Minutes' ;
    rdfs:comment 'Estimated total flight time from takeoff to landing, measured in minutes.' ;
    rdfs:domain ind:DispatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:etopsAuthorizationFlag rdf:type rdf:Property ;
    rdfs:label 'Etops Authorization Flag' ;
    rdfs:comment 'Indicates whether this flight is authorized for ETOPS operations (extended-range twin-engine flight over water or remote areas).' ;
    rdfs:domain ind:DispatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:etopsEntryPoint rdf:type rdf:Property ;
    rdfs:label 'Etops Entry Point' ;
    rdfs:comment 'Geographic waypoint or coordinate where the flight enters ETOPS airspace, if applicable.' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:etopsExitPoint rdf:type rdf:Property ;
    rdfs:label 'Etops Exit Point' ;
    rdfs:comment 'Geographic waypoint or coordinate where the flight exits ETOPS airspace, if applicable.' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finalReserveFuelKg rdf:type rdf:Property ;
    rdfs:label 'Final Reserve Fuel Kg' ;
    rdfs:comment 'Minimum fuel that must remain on board upon landing at the alternate airport, typically 30 minutes holding at 1500 feet above alternate, measured in kilograms.' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazmatOnboardFlag rdf:type rdf:Property ;
    rdfs:label 'Hazmat Onboard Flag' ;
    rdfs:comment 'Indicates whether dangerous goods or hazardous materials are being carried on this flight, requiring special handling and documentation.' ;
    rdfs:domain ind:DispatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:landingWeightKg rdf:type rdf:Property ;
    rdfs:label 'Landing Weight Kg' ;
    rdfs:comment 'Planned aircraft landing weight at destination, measured in kilograms.' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:melItemsAcceptedCount rdf:type rdf:Property ;
    rdfs:label 'Mel Items Accepted Count' ;
    rdfs:comment 'Number of MEL (Minimum Equipment List) deferred maintenance items accepted and documented in this dispatch release, allowing flight with specific inoperative equipment.' ;
    rdfs:domain ind:DispatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:melItemsSummary rdf:type rdf:Property ;
    rdfs:label 'Mel Items Summary' ;
    rdfs:comment 'Textual summary of all MEL items accepted for this flight, including item numbers, descriptions, and operational limitations.' ;
    rdfs:domain ind:DispatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumFuelKg rdf:type rdf:Property ;
    rdfs:label 'Minimum Fuel Kg' ;
    rdfs:comment 'Regulatory minimum fuel quantity required for this flight considering all fuel policy components, measured in kilograms.' ;
    rdfs:domain ind:DispatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:notamBriefingPackage rdf:type rdf:Property ;
    rdfs:label 'Notam Briefing Package' ;
    rdfs:comment 'Comprehensive text package of all relevant NOTAMs (Notices to Air Missions) for departure, en-route, destination, and alternate airports with operational significance flags.' ;
    rdfs:domain ind:DispatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passengerCount rdf:type rdf:Property ;
    rdfs:label 'Passenger Count' ;
    rdfs:comment 'Total number of passengers planned to be carried on this flight at time of dispatch release.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedCruiseAltitudeFt rdf:type rdf:Property ;
    rdfs:label 'Planned Cruise Altitude Ft' ;
    rdfs:comment 'Planned cruising altitude for this flight leg, measured in feet above mean sea level.' ;
    rdfs:domain ind:DispatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedCruiseSpeedKts rdf:type rdf:Property ;
    rdfs:label 'Planned Cruise Speed Kts' ;
    rdfs:comment 'Planned true airspeed during cruise phase, measured in knots.' ;
    rdfs:domain ind:DispatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedFuelUpliftKg rdf:type rdf:Property ;
    rdfs:label 'Planned Fuel Uplift Kg' ;
    rdfs:comment 'Total quantity of fuel planned to be loaded onto the aircraft for this flight, measured in kilograms.' ;
    rdfs:domain ind:DispatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:regulatoryAuthority rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority' ;
    rdfs:comment 'Primary aviation regulatory authority governing this flight operation (FAA for US, EASA for EU, etc.).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseIssuedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Release Issued Timestamp' ;
    rdfs:comment 'Date and time when the dispatch release was officially issued and authorized for flight departure. Principal business event timestamp for this regulatory document.' ;
    rdfs:domain ind:DispatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:releaseStatus rdf:type rdf:Property ;
    rdfs:label 'Release Status' ;
    rdfs:comment 'Current lifecycle status of the dispatch release document in the authorization workflow.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseVersionNumber rdf:type rdf:Property ;
    rdfs:label 'Release Version Number' ;
    rdfs:comment 'Version number of this dispatch release if it has been amended or superseded after initial issuance.' ;
    rdfs:domain ind:DispatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:routeDescription rdf:type rdf:Property ;
    rdfs:label 'Route Description' ;
    rdfs:comment 'Detailed flight route including airways, waypoints, and navigation fixes from departure to destination.' ;
    rdfs:domain ind:DispatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialHandlingNotes rdf:type rdf:Property ;
    rdfs:label 'Special Handling Notes' ;
    rdfs:comment 'Free-text field for any special operational considerations, restrictions, or handling instructions for this flight.' ;
    rdfs:domain ind:DispatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:takeoffWeightKg rdf:type rdf:Property ;
    rdfs:label 'Takeoff Weight Kg' ;
    rdfs:comment 'Planned aircraft takeoff weight including fuel, payload, and operating empty weight, measured in kilograms.' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tripFuelKg rdf:type rdf:Property ;
    rdfs:label 'Trip Fuel Kg' ;
    rdfs:comment 'Fuel required to fly from departure to destination under planned conditions, measured in kilograms.' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weatherBriefingPackage rdf:type rdf:Property ;
    rdfs:label 'Weather Briefing Package' ;
    rdfs:comment 'Comprehensive weather briefing including METARs (Meteorological Aerodrome Reports), TAFs (Terminal Aerodrome Forecasts), SIGMETs (Significant Meteorological Information), PIREPs (Pilot Reports), and winds-aloft data for all relevant stations.' ;
    rdfs:domain ind:DispatchRelease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:zeroFuelWeightKg rdf:type rdf:Property ;
    rdfs:label 'Zero Fuel Weight Kg' ;
    rdfs:comment 'Aircraft weight excluding all usable fuel, including operating empty weight and payload, measured in kilograms.' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertId rdf:type rdf:Property ;
    rdfs:label 'Alert Id' ;
    rdfs:comment 'Foreign key linking to safety.alert. Business justification: Dispatchers modify flight plans in response to active safety alerts (volcanic ash NOTAMs, airspace restriction alerts, manufacturer airworthiness bulletins). Linking flight_plan to the triggering safe' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Alert .

ind:arrivalAirportIcao rdf:type rdf:Property ;
    rdfs:label 'Arrival Airport Icao' ;
    rdfs:comment 'Four-letter ICAO code of the destination airport.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costIndex rdf:type rdf:Property ;
    rdfs:label 'Cost Index' ;
    rdfs:comment 'Cost index value used for flight planning optimization, balancing time cost versus fuel cost. Higher values favor speed; lower values favor fuel efficiency.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cruiseAltitudeFt rdf:type rdf:Property ;
    rdfs:label 'Cruise Altitude Ft' ;
    rdfs:comment 'Planned cruise altitude in feet above mean sea level (MSL) for the primary cruise segment.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cruiseSpeedKts rdf:type rdf:Property ;
    rdfs:label 'Cruise Speed Kts' ;
    rdfs:comment 'Planned cruise speed in knots (true airspeed or indicated airspeed as per flight planning convention).' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:etopsQualifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Etops Qualified Flag' ;
    rdfs:comment 'Indicates whether this flight plan is qualified for ETOPS operations (extended-range twin-engine flights over water or remote areas).' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:filedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Filed Timestamp' ;
    rdfs:comment 'Date and time when this flight plan version was filed with Air Traffic Control (ATC) or ICAO Flight Plan Processing System.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:operationalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Operational Timestamp' ;
    rdfs:comment 'Date and time when this flight plan version was accepted by the crew and loaded into the Flight Management System (FMS) as the operational flight plan (OFP).' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedBlockHours rdf:type rdf:Property ;
    rdfs:label 'Planned Block Hours' ;
    rdfs:comment 'Estimated total block time in hours from gate departure (Out) to gate arrival (In), including taxi, flight, and approach time.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedFlightTimeHours rdf:type rdf:Property ;
    rdfs:label 'Planned Flight Time Hours' ;
    rdfs:comment 'Estimated airborne time in hours from wheels-off to wheels-on.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedTaxiInMinutes rdf:type rdf:Property ;
    rdfs:label 'Planned Taxi In Minutes' ;
    rdfs:comment 'Estimated taxi time in minutes from landing to gate arrival.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedTaxiOutMinutes rdf:type rdf:Property ;
    rdfs:label 'Planned Taxi Out Minutes' ;
    rdfs:comment 'Estimated taxi time in minutes from gate departure to takeoff.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:routeOfFlight rdf:type rdf:Property ;
    rdfs:label 'Route Of Flight' ;
    rdfs:comment 'Full textual representation of the planned route including RNAV waypoints, airways, Standard Instrument Departures (SIDs), and Standard Terminal Arrival Routes (STARs).' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stepClimbSchedule rdf:type rdf:Property ;
    rdfs:label 'Step Climb Schedule' ;
    rdfs:comment 'Planned altitude step-climb profile showing waypoints and altitudes where the aircraft will request higher cruise levels to optimize fuel efficiency as weight decreases.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalFuelRequiredKg rdf:type rdf:Property ;
    rdfs:label 'Total Fuel Required Kg' ;
    rdfs:comment 'Total fuel required in kilograms: sum of trip fuel, contingency fuel, alternate fuel, final reserve fuel, taxi fuel, and any additional fuel.' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:windDataSource rdf:type rdf:Property ;
    rdfs:label 'Wind Data Source' ;
    rdfs:comment 'Source of wind and temperature forecast data used in flight planning (e.g., NOAA GFS, ECMWF, proprietary meteorological service).' ;
    rdfs:domain ind:Plan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oooiEventId rdf:type rdf:Property ;
    rdfs:label 'Oooi Event Id' ;
    rdfs:comment 'Unique identifier for each OOOI event record. Primary key for the OOOI event entity.' ;
    rdfs:domain ind:OooiEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:acarsMessageLabel rdf:type rdf:Property ;
    rdfs:label 'Acars Message Label' ;
    rdfs:comment 'The ACARS message label identifier associated with this OOOI event transmission (e.g., H1 for OUT, 10 for OFF, 11 for ON, 12 for IN). Null if data source is not ACARS.' ;
    rdfs:domain ind:OooiEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acarsMessageNumber rdf:type rdf:Property ;
    rdfs:label 'Acars Message Number' ;
    rdfs:comment 'The unique ACARS message sequence number for this OOOI event transmission. Used for message tracking and reconciliation. Null if data source is not ACARS.' ;
    rdfs:domain ind:OooiEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:altitudeFeet rdf:type rdf:Property ;
    rdfs:label 'Altitude Feet' ;
    rdfs:comment 'The aircraft altitude in feet above mean sea level at the time of the OOOI event. Primarily populated for OFF and ON events from FMS or ADS-B data. Used for performance analysis.' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:correctionReason rdf:type rdf:Property ;
    rdfs:label 'Correction Reason' ;
    rdfs:comment 'Free-text description explaining why this OOOI event timestamp was corrected. Null if is_corrected is False. Used for audit trail and data quality improvement.' ;
    rdfs:domain ind:OooiEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataQualityFlag rdf:type rdf:Property ;
    rdfs:label 'Data Quality Flag' ;
    rdfs:comment 'Indicates the quality and reliability of the OOOI event data: VERIFIED (confirmed accurate), ESTIMATED (calculated or interpolated), CORRECTED (manually adjusted after initial capture), DISPUTED (conflicting data from multiple sources), PENDING (awaiting validation).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSource rdf:type rdf:Property ;
    rdfs:label 'Data Source' ;
    rdfs:comment 'The system or method that captured and reported the OOOI event: ACARS (Aircraft Communications Addressing and Reporting System), ADS-B (Automatic Dependent Surveillance-Broadcast), MANUAL (crew or ground staff entry), FMS (Flight Management System), OOOI_SENSOR (dedicated aircraft sensor), GROUND_SYSTEM (airport ground handling system).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventTimestamp rdf:type rdf:Property ;
    rdfs:label 'Event Timestamp' ;
    rdfs:comment 'The actual date and time when the OOOI event occurred, recorded in UTC. This is the authoritative timestamp for the event used in OTP reporting and block hours calculation.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eventTimestampLocal rdf:type rdf:Property ;
    rdfs:label 'Event Timestamp Local' ;
    rdfs:comment 'The OOOI event timestamp converted to the local time zone of the airport where the event occurred. Used for operational reporting and crew scheduling.' ;
    rdfs:domain ind:OooiEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eventType rdf:type rdf:Property ;
    rdfs:label 'Event Type' ;
    rdfs:comment 'The type of OOOI event: OUT (pushback/gate departure), OFF (wheels-off/takeoff), ON (wheels-on/landing), IN (gate arrival/chocks-in). Foundation for block hours and OTP calculation.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateStand rdf:type rdf:Property ;
    rdfs:label 'Gate Stand' ;
    rdfs:comment 'The gate or stand identifier where the OUT (pushback) or IN (arrival) event occurred. Null for OFF and ON events. Used for ground operations coordination.' ;
    rdfs:domain ind:OooiEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groundSpeedKnots rdf:type rdf:Property ;
    rdfs:label 'Ground Speed Knots' ;
    rdfs:comment 'The aircraft ground speed in knots at the time of the OOOI event. Primarily populated for OFF and ON events. Used for performance and safety analysis.' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isCorrected rdf:type rdf:Property ;
    rdfs:label 'Is Corrected' ;
    rdfs:comment 'Boolean flag indicating whether this OOOI event timestamp was manually corrected after initial capture due to data quality issues or system errors. True if corrected, False if original.' ;
    rdfs:domain ind:OooiEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isEstimated rdf:type rdf:Property ;
    rdfs:label 'Is Estimated' ;
    rdfs:comment 'Boolean flag indicating whether this OOOI event timestamp was estimated or interpolated rather than directly captured from aircraft or ground systems. True if estimated, False if actual.' ;
    rdfs:domain ind:OooiEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:latitude rdf:type rdf:Property ;
    rdfs:label 'Latitude' ;
    rdfs:comment 'The geographic latitude coordinate where the OOOI event occurred, captured from ADS-B or FMS. Primarily populated for OFF and ON events. Used for flight path analysis and safety investigations.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:longitude rdf:type rdf:Property ;
    rdfs:label 'Longitude' ;
    rdfs:comment 'The geographic longitude coordinate where the OOOI event occurred, captured from ADS-B or FMS. Primarily populated for OFF and ON events. Used for flight path analysis and safety investigations.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Original Timestamp' ;
    rdfs:comment 'The original OOOI event timestamp before any corrections were applied. Null if is_corrected is False. Preserved for audit trail and data lineage.' ;
    rdfs:domain ind:OooiEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:otpEligible rdf:type rdf:Property ;
    rdfs:label 'Otp Eligible' ;
    rdfs:comment 'Boolean flag indicating whether this OOOI event is eligible for inclusion in OTP calculations per IATA or DOT standards. False if flight was cancelled, diverted, or otherwise excluded from OTP metrics.' ;
    rdfs:domain ind:OooiEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:receivedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Received Timestamp' ;
    rdfs:comment 'The timestamp when the OOOI event data was received and recorded by the ground-based flight operations system. Used for data latency analysis and system performance monitoring.' ;
    rdfs:domain ind:OooiEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reportingStatus rdf:type rdf:Property ;
    rdfs:label 'Reporting Status' ;
    rdfs:comment 'Indicates whether this OOOI event has been included in regulatory reporting submissions to DOT, IATA, or other authorities: REPORTED (included in submission), UNREPORTED (not yet submitted), EXCLUDED (intentionally omitted per reporting rules), AMENDED (corrected in a subsequent filing).' ;
    rdfs:domain ind:OooiEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runwayIdentifier rdf:type rdf:Property ;
    rdfs:label 'Runway Identifier' ;
    rdfs:comment 'The runway designation used for the OFF (takeoff) or ON (landing) event. Format follows ICAO runway naming conventions (e.g., 27L, 09R). Null for OUT and IN events.' ;
    rdfs:domain ind:OooiEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Timestamp' ;
    rdfs:comment 'The originally scheduled timestamp for this OOOI event type (scheduled departure for OUT, scheduled takeoff for OFF, scheduled landing for ON, scheduled arrival for IN). Used to calculate delay and OTP metrics.' ;
    rdfs:domain ind:OooiEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fuelBatchNumber rdf:type rdf:Property ;
    rdfs:label 'Fuel Batch Number' ;
    rdfs:comment 'Batch or lot number of the fuel supplied, used for quality traceability.' ;
    rdfs:domain ind:FuelUplift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelPriceCurrency rdf:type rdf:Property ;
    rdfs:label 'Fuel Price Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the fuel price.' ;
    rdfs:domain ind:FuelUplift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelPricePerUnit rdf:type rdf:Property ;
    rdfs:label 'Fuel Price Per Unit' ;
    rdfs:comment 'Price per unit (per kilogram or per litre) of fuel charged by the supplier.' ;
    rdfs:domain ind:FuelUplift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelQualityCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Fuel Quality Certificate Number' ;
    rdfs:comment 'Certificate number issued by the fuel supplier confirming fuel quality and compliance with aviation standards.' ;
    rdfs:domain ind:FuelUplift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelQuantityKg rdf:type rdf:Property ;
    rdfs:label 'Fuel Quantity Kg' ;
    rdfs:comment 'Quantity of fuel uplifted measured in kilograms.' ;
    rdfs:domain ind:FuelUplift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelQuantityLbs rdf:type rdf:Property ;
    rdfs:label 'Fuel Quantity Lbs' ;
    rdfs:comment 'Quantity of fuel uplifted measured in pounds.' ;
    rdfs:domain ind:FuelUplift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelQuantityLitres rdf:type rdf:Property ;
    rdfs:label 'Fuel Quantity Litres' ;
    rdfs:comment 'Quantity of fuel uplifted measured in litres.' ;
    rdfs:domain ind:FuelUplift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelTemperatureCelsius rdf:type rdf:Property ;
    rdfs:label 'Fuel Temperature Celsius' ;
    rdfs:comment 'Temperature of the fuel at the time of uplift, measured in degrees Celsius, used for density correction.' ;
    rdfs:domain ind:FuelUplift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelTicketNumber rdf:type rdf:Property ;
    rdfs:label 'Fuel Ticket Number' ;
    rdfs:comment 'Unique ticket or document number issued by the fueling company for this uplift transaction.' ;
    rdfs:domain ind:FuelUplift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelUpliftStatus rdf:type rdf:Property ;
    rdfs:label 'Fuel Uplift Status' ;
    rdfs:comment 'Current status of the fuel uplift transaction (e.g., completed, partial, cancelled, disputed).' ;
    rdfs:domain ind:FuelUplift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelingDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Fueling Duration Minutes' ;
    rdfs:comment 'Duration of the fueling operation in minutes.' ;
    rdfs:domain ind:FuelUplift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fuelingStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Fueling Start Timestamp' ;
    rdfs:comment 'Date and time when the fuel uplift operation began.' ;
    rdfs:domain ind:FuelUplift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fuelingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Fueling Timestamp' ;
    rdfs:comment 'Date and time when the fuel uplift operation was completed, in ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX).' ;
    rdfs:domain ind:FuelUplift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:intoPlaneAgent rdf:type rdf:Property ;
    rdfs:label 'Into Plane Agent' ;
    rdfs:comment 'Name or identifier of the into-plane agent or ground handler responsible for the physical fueling operation.' ;
    rdfs:domain ind:FuelUplift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postFuelingQuantityKg rdf:type rdf:Property ;
    rdfs:label 'Post Fueling Quantity Kg' ;
    rdfs:comment 'Total quantity of fuel on board the aircraft after the uplift, measured in kilograms.' ;
    rdfs:domain ind:FuelUplift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preFuelingQuantityKg rdf:type rdf:Property ;
    rdfs:label 'Pre Fueling Quantity Kg' ;
    rdfs:comment 'Quantity of fuel already on board the aircraft before the uplift, measured in kilograms.' ;
    rdfs:domain ind:FuelUplift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalFuelCost rdf:type rdf:Property ;
    rdfs:label 'Total Fuel Cost' ;
    rdfs:comment 'Total cost of the fuel uplift transaction in the specified currency.' ;
    rdfs:domain ind:FuelUplift ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:delayRecordId rdf:type rdf:Property ;
    rdfs:label 'Delay Record Id' ;
    rdfs:comment 'Unique identifier for the delay record. Primary key.' ;
    rdfs:domain ind:DelayRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:absenceId rdf:type rdf:Property ;
    rdfs:label 'Absence Id' ;
    rdfs:comment 'Foreign key linking to crew.absence. Business justification: Crew absence (sick call, no-show) is a primary IATA delay code category. DOT on-time reporting and delay cost attribution require linking a delay record directly to the crew absence that caused it. de' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Absence .

ind:responsibleStationId rdf:type rdf:Property ;
    rdfs:label 'Responsible Station Id' ;
    rdfs:comment 'Foreign key linking to airport.station. Business justification: Delay accountability requires linking to responsible station entity for performance tracking, cost allocation of controllable delays, station manager accountability, and regulatory DOT reporting by st' ;
    rdfs:domain ind:DelayRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Station .

ind:affectedPassengerCount rdf:type rdf:Property ;
    rdfs:label 'Affected Passenger Count' ;
    rdfs:comment 'Number of passengers (Pax) affected by this delay event. Used for customer impact assessment and compensation calculations.' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:compensationIssuedFlag rdf:type rdf:Property ;
    rdfs:label 'Compensation Issued Flag' ;
    rdfs:comment 'Boolean flag indicating whether passenger compensation (monetary or vouchers) was issued as a result of this delay under EU261, DOT, or airline policy. True if compensation issued, False if not.' ;
    rdfs:domain ind:DelayRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:correctiveActionTaken rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Taken' ;
    rdfs:comment 'Description of corrective or preventive actions taken to resolve the delay or prevent recurrence. Used for continuous improvement and safety management system (SMS) tracking.' ;
    rdfs:domain ind:DelayRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Data Source System' ;
    rdfs:comment 'Identifier of the source system from which this delay record originated (e.g., Lufthansa Systems NetLine/Ops, Jeppesen Flight Planning, manual entry by operations staff, ACARS messaging, or other systems).' ;
    rdfs:domain ind:DelayRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:delayCategory rdf:type rdf:Property ;
    rdfs:label 'Delay Category' ;
    rdfs:comment 'High-level classification of the delay cause: airline operational issues, ATC (Air Traffic Control) restrictions, airport facility problems, weather conditions, passenger-related issues, reactionary delays from late inbound aircraft, security events, or other causes. [ENUM-REF-CANDIDATE: airline_operational|air_traffic_control|airport_facilities|weather|passenger_related|reactionary|security|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DelayRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:delayCostEstimateUsd rdf:type rdf:Property ;
    rdfs:label 'Delay Cost Estimate Usd' ;
    rdfs:comment 'Estimated financial cost of the delay in US dollars, including crew overtime, passenger compensation, fuel burn, missed connections, and operational disruption. Used for cost-benefit analysis and delay reduction initiatives.' ;
    rdfs:domain ind:DelayRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:delayDescription rdf:type rdf:Property ;
    rdfs:label 'Delay Description' ;
    rdfs:comment 'Free-text narrative description providing detailed context and explanation of the delay event, root cause, and any corrective actions taken.' ;
    rdfs:domain ind:DelayRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:delayDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Delay Duration Minutes' ;
    rdfs:comment 'Total duration of the delay event measured in minutes. Used for OTP (On-Time Performance) calculations and DOT reporting.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:delayEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Delay End Timestamp' ;
    rdfs:comment 'Timestamp marking the resolution or end of the delay event in UTC. Nullable if delay is ongoing or not yet resolved.' ;
    rdfs:domain ind:DelayRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:delayNotificationSentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Delay Notification Sent Timestamp' ;
    rdfs:comment 'Timestamp when delay notification was sent to passengers via SMS, email, or mobile app. Used to measure compliance with customer communication standards.' ;
    rdfs:domain ind:DelayRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:delaySequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Delay Sequence Number' ;
    rdfs:comment 'Sequential ordering of multiple delay events for the same flight leg. Allows tracking of multiple delay causes on a single flight.' ;
    rdfs:domain ind:DelayRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:delayStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Delay Start Timestamp' ;
    rdfs:comment 'Timestamp marking the beginning of the delay event in UTC. Used to calculate delay duration and analyze delay patterns by time of day.' ;
    rdfs:domain ind:DelayRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:delayStatus rdf:type rdf:Property ;
    rdfs:label 'Delay Status' ;
    rdfs:comment 'Current lifecycle status of the delay record: open (delay ongoing), resolved (delay ended), under investigation (root cause analysis in progress), closed (finalized and archived), or disputed (under review or challenge).' ;
    rdfs:domain ind:DelayRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:delayVerificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Delay Verification Timestamp' ;
    rdfs:comment 'Timestamp when the delay record was verified and approved by a supervisor. Nullable if verification is pending.' ;
    rdfs:domain ind:DelayRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isControllableDelay rdf:type rdf:Property ;
    rdfs:label 'Is Controllable Delay' ;
    rdfs:comment 'Boolean flag indicating whether the delay was within the airline\'s control (e.g., maintenance, crew scheduling) versus external factors (e.g., weather, ATC). Used for internal performance accountability and root cause analysis.' ;
    rdfs:domain ind:DelayRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReactionaryDelay rdf:type rdf:Property ;
    rdfs:label 'Is Reactionary Delay' ;
    rdfs:comment 'Boolean flag indicating whether this delay was reactionary (caused by a late inbound aircraft from a previous flight leg). True if reactionary, False if not.' ;
    rdfs:domain ind:DelayRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isReportableToDot rdf:type rdf:Property ;
    rdfs:label 'Is Reportable To Dot' ;
    rdfs:comment 'Boolean flag indicating whether this delay must be reported to the US Department of Transportation under 14 CFR Part 234 (applies to delays of 15 minutes or more for covered carriers). True if reportable, False if not.' ;
    rdfs:domain ind:DelayRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:missedConnectionCount rdf:type rdf:Property ;
    rdfs:label 'Missed Connection Count' ;
    rdfs:comment 'Number of passengers who missed their connecting flights as a result of this delay. Used for IROP (Irregular Operations) management and customer service planning.' ;
    rdfs:domain ind:DelayRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryDelayCode rdf:type rdf:Property ;
    rdfs:label 'Primary Delay Code' ;
    rdfs:comment 'Two-digit IATA delay code representing the primary cause of the delay per AHM 730 standard (e.g., 11=Aircraft defects, 31=Flight deck crew, 81=Weather).' ;
    rdfs:domain ind:DelayRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordLastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Record Last Updated Timestamp' ;
    rdfs:comment 'Timestamp when this delay record was last modified. Used for audit trail and change tracking.' ;
    rdfs:domain ind:DelayRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:responsibleDepartmentCode rdf:type rdf:Property ;
    rdfs:label 'Responsible Department Code' ;
    rdfs:comment 'Internal department code identifying the organizational unit responsible for or associated with the delay (e.g., MX=Maintenance, OPS=Operations, CREW=Crew Scheduling, GND=Ground Handling).' ;
    rdfs:domain ind:DelayRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diversionId rdf:type rdf:Property ;
    rdfs:label 'Diversion Id' ;
    rdfs:comment 'Unique identifier for the flight diversion event. Primary key.' ;
    rdfs:domain ind:Diversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualGateArrivalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Gate Arrival Timestamp' ;
    rdfs:comment 'Date and time when the aircraft arrived at the gate at the diversion airport. Completes the In event of OOOI tracking. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Diversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualLandingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Landing Timestamp' ;
    rdfs:comment 'Date and time when the aircraft touched down at the diversion airport. Part of OOOI (Out-Off-On-In) event tracking. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Diversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:airportIcaoCode rdf:type rdf:Property ;
    rdfs:label 'Airport Icao Code' ;
    rdfs:comment 'Four-letter ICAO airport code of the diversion airport. Provides international standard identifier for flight planning and ATC coordination.' ;
    rdfs:domain ind:Diversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:atcCoordinationReference rdf:type rdf:Property ;
    rdfs:label 'Atc Coordination Reference' ;
    rdfs:comment 'Reference number or identifier provided by Air Traffic Control (ATC) for the diversion coordination. Used for operational tracking and incident investigation.' ;
    rdfs:domain ind:Diversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compensationEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Compensation Eligibility Flag' ;
    rdfs:comment 'Indicates whether passengers are eligible for monetary compensation under applicable passenger rights regulations due to the diversion. True if eligible; False otherwise.' ;
    rdfs:domain ind:Diversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:continuationDepartureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Continuation Departure Timestamp' ;
    rdfs:comment 'Date and time when the continuation flight departed from the diversion airport toward the original destination. Null if no continuation occurred. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Diversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:continuationFlightNumber rdf:type rdf:Property ;
    rdfs:label 'Continuation Flight Number' ;
    rdfs:comment 'Flight number assigned to the continuation flight if the aircraft or passengers continued to the original destination after the diversion. Null if flight was cancelled or returned to origin.' ;
    rdfs:domain ind:Diversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costImpactCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Cost Impact Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the estimated cost impact amount.' ;
    rdfs:domain ind:Diversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crewDutyTimeImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Crew Duty Time Impact Flag' ;
    rdfs:comment 'Indicates whether the diversion caused crew duty time or flight time limitations to be exceeded or approached, requiring crew replacement or schedule adjustments. True if impacted; False otherwise.' ;
    rdfs:domain ind:Diversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:decisionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Decision Timestamp' ;
    rdfs:comment 'Date and time when the decision to divert was made by the pilot-in-command or operational control. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dispatchReleaseUpdatedFlag rdf:type rdf:Property ;
    rdfs:label 'Dispatch Release Updated Flag' ;
    rdfs:comment 'Indicates whether a new or amended dispatch release was issued for the continuation flight from the diversion airport. True if updated; False otherwise.' ;
    rdfs:domain ind:Diversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dispositionAction rdf:type rdf:Property ;
    rdfs:label 'Disposition Action' ;
    rdfs:comment 'Subsequent operational action taken after landing at the diversion airport. Continued_to_destination indicates flight resumed to original destination; returned_to_origin indicates flight returned to departure airport; cancelled indicates flight was terminated; aircraft_swap indicates passengers transferred to another aircraft; overnight_recovery indicates passengers accommodated overnight.' ;
    rdfs:domain ind:Diversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diversionNumber rdf:type rdf:Property ;
    rdfs:label 'Diversion Number' ;
    rdfs:comment 'Business identifier for the diversion event, used for operational tracking and reporting. Format: DIV followed by numeric sequence.' ;
    rdfs:domain ind:Diversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:diversionStatus rdf:type rdf:Property ;
    rdfs:label 'Diversion Status' ;
    rdfs:comment 'Current lifecycle status of the diversion event. Tracks progression from initial declaration through resolution.' ;
    rdfs:domain ind:Diversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedCostImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Cost Impact Amount' ;
    rdfs:comment 'Estimated total financial cost impact of the diversion event, including fuel, landing fees, passenger care, crew expenses, and operational disruption costs. Expressed in the airline\'s reporting currency.' ;
    rdfs:domain ind:Diversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelUpliftAtDiversionKg rdf:type rdf:Property ;
    rdfs:label 'Fuel Uplift At Diversion Kg' ;
    rdfs:comment 'Amount of fuel uplifted at the diversion airport in kilograms. Required if the aircraft continued to the original destination or another airport after the diversion.' ;
    rdfs:domain ind:Diversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:groundTimeDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Ground Time Duration Minutes' ;
    rdfs:comment 'Total time in minutes that the aircraft spent on the ground at the diversion airport, from gate arrival to departure (if continuation occurred) or final shutdown.' ;
    rdfs:domain ind:Diversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:hotelAccommodationProvidedFlag rdf:type rdf:Property ;
    rdfs:label 'Hotel Accommodation Provided Flag' ;
    rdfs:comment 'Indicates whether hotel accommodation was provided to passengers due to the diversion. True if accommodation was arranged; False otherwise.' ;
    rdfs:domain ind:Diversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mealVoucherProvidedFlag rdf:type rdf:Property ;
    rdfs:label 'Meal Voucher Provided Flag' ;
    rdfs:comment 'Indicates whether meal vouchers or meals were provided to passengers due to the diversion. True if meals were provided; False otherwise.' ;
    rdfs:domain ind:Diversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notamReference rdf:type rdf:Property ;
    rdfs:label 'Notam Reference' ;
    rdfs:comment 'Reference to any relevant NOTAM (Notice to Air Missions) that contributed to or was issued in relation to the diversion event.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passengerCareActionTaken rdf:type rdf:Property ;
    rdfs:label 'Passenger Care Action Taken' ;
    rdfs:comment 'Description of passenger care actions provided at the diversion airport, including meals, accommodation, rebooking, ground transportation, and communication. Documents compliance with passenger rights regulations.' ;
    rdfs:domain ind:Diversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passengerCountDiverted rdf:type rdf:Property ;
    rdfs:label 'Passenger Count Diverted' ;
    rdfs:comment 'Total number of passengers (Pax) on board the aircraft at the time of diversion. Used for passenger care planning and regulatory reporting.' ;
    rdfs:domain ind:Diversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedDestinationAirportCode rdf:type rdf:Property ;
    rdfs:label 'Planned Destination Airport Code' ;
    rdfs:comment 'Three-letter IATA airport code of the original planned destination airport before diversion was declared.' ;
    rdfs:domain ind:Diversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonDescription rdf:type rdf:Property ;
    rdfs:label 'Reason Description' ;
    rdfs:comment 'Detailed narrative explanation of the specific circumstances that led to the diversion decision. Provides operational context beyond the reason code.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Required Flag' ;
    rdfs:comment 'Indicates whether the diversion event requires formal reporting to aviation regulatory authorities (FAA, EASA, national CAA). True if reporting is required; False otherwise.' ;
    rdfs:domain ind:Diversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryReportSubmittedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Submitted Timestamp' ;
    rdfs:comment 'Date and time when the required regulatory report was submitted to the aviation authority. Null if no report was required or not yet submitted. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Diversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:safetyReportReference rdf:type rdf:Property ;
    rdfs:label 'Safety Report Reference' ;
    rdfs:comment 'Reference number of any safety report filed in the airline\'s Safety Management System (SMS) related to the diversion event. Used for safety trend analysis and continuous improvement.' ;
    rdfs:domain ind:Diversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weatherConditionDescription rdf:type rdf:Property ;
    rdfs:label 'Weather Condition Description' ;
    rdfs:comment 'Description of the weather (wx) conditions at the planned destination or en route that contributed to the diversion decision, if weather was a factor. Includes visibility, ceiling, wind, precipitation, and other meteorological phenomena.' ;
    rdfs:domain ind:Diversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedStationId rdf:type rdf:Property ;
    rdfs:label 'Affected Station Id' ;
    rdfs:comment 'Foreign key linking to airport.station. Business justification: IROP events impact specific stations; linking enables station-level impact analysis, resource allocation during irregular operations, recovery plan coordination with station managers, and financial im' ;
    rdfs:domain ind:IropEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Station .

ind:actualPassengersAffected rdf:type rdf:Property ;
    rdfs:label 'Actual Passengers Affected' ;
    rdfs:comment 'Actual total number of passengers impacted by the irregular operations event across all affected flights. Calculated after event resolution.' ;
    rdfs:domain ind:IropEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualTotalDelayMinutes rdf:type rdf:Property ;
    rdfs:label 'Actual Total Delay Minutes' ;
    rdfs:comment 'Actual cumulative delay minutes across all affected flights resulting from this irregular operations event. Calculated after event resolution.' ;
    rdfs:domain ind:IropEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:atcCoordinationNotes rdf:type rdf:Property ;
    rdfs:label 'Atc Coordination Notes' ;
    rdfs:comment 'Notes documenting coordination activities and communications with Air Traffic Control during the irregular operations event.' ;
    rdfs:domain ind:IropEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdmSessionReference rdf:type rdf:Property ;
    rdfs:label 'Cdm Session Reference' ;
    rdfs:comment 'Reference identifier linking to the Collaborative Decision Making session coordinating the operational response to this irregular operations event.' ;
    rdfs:domain ind:IropEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedFinancialImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Financial Impact Amount' ;
    rdfs:comment 'Estimated total financial impact of the irregular operations event including operational costs, passenger compensation, and revenue loss. Expressed in airline base currency.' ;
    rdfs:domain ind:IropEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedPassengersAffected rdf:type rdf:Property ;
    rdfs:label 'Estimated Passengers Affected' ;
    rdfs:comment 'Estimated total number of passengers impacted by the irregular operations event across all affected flights. Used for customer service resource planning.' ;
    rdfs:domain ind:IropEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:estimatedTotalDelayMinutes rdf:type rdf:Property ;
    rdfs:label 'Estimated Total Delay Minutes' ;
    rdfs:comment 'Estimated cumulative delay minutes across all affected flights resulting from this irregular operations event. Used for impact assessment and reporting.' ;
    rdfs:domain ind:IropEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eventCode rdf:type rdf:Property ;
    rdfs:label 'Event Code' ;
    rdfs:comment 'Standardized code identifying the type of irregular operations event. Used for operational reporting and analysis.' ;
    rdfs:domain ind:IropEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventDescription rdf:type rdf:Property ;
    rdfs:label 'Event Description' ;
    rdfs:comment 'Detailed narrative description of the irregular operations event including circumstances, operational impact, and contributing factors.' ;
    rdfs:domain ind:IropEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Event End Timestamp' ;
    rdfs:comment 'Date and time when the irregular operations event was resolved and normal operations resumed. Nullable for ongoing events.' ;
    rdfs:domain ind:IropEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eventStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Event Start Timestamp' ;
    rdfs:comment 'Date and time when the irregular operations event was first detected or began affecting operations. Critical for timeline analysis and delay attribution.' ;
    rdfs:domain ind:IropEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eventStatus rdf:type rdf:Property ;
    rdfs:label 'Event Status' ;
    rdfs:comment 'Current lifecycle state of the irregular operations event. Tracks progression from initial detection through resolution and closure.' ;
    rdfs:domain ind:IropEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flightsCancelledCount rdf:type rdf:Property ;
    rdfs:label 'Flights Cancelled Count' ;
    rdfs:comment 'Total number of flights cancelled as a direct result of this irregular operations event. Key metric for operational impact assessment.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:flightsDelayedCount rdf:type rdf:Property ;
    rdfs:label 'Flights Delayed Count' ;
    rdfs:comment 'Total number of flights delayed as a direct result of this irregular operations event. Key metric for operational impact assessment.' ;
    rdfs:domain ind:IropEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:flightsDivertedCount rdf:type rdf:Property ;
    rdfs:label 'Flights Diverted Count' ;
    rdfs:comment 'Total number of flights diverted to alternate airports as a direct result of this irregular operations event.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:passengerCompensationTriggeredFlag rdf:type rdf:Property ;
    rdfs:label 'Passenger Compensation Triggered Flag' ;
    rdfs:comment 'Indicates whether this irregular operations event triggered passenger compensation obligations under applicable regulations such as EU261 or DOT rules.' ;
    rdfs:domain ind:IropEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recoveryPlanDescription rdf:type rdf:Property ;
    rdfs:label 'Recovery Plan Description' ;
    rdfs:comment 'Detailed description of the operational recovery plan including actions, resource allocation, and timeline for restoring normal operations.' ;
    rdfs:domain ind:IropEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recoveryPlanStatus rdf:type rdf:Property ;
    rdfs:label 'Recovery Plan Status' ;
    rdfs:comment 'Current state of the operational recovery plan developed to address the irregular operations event and restore normal operations.' ;
    rdfs:domain ind:IropEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryNotificationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Required Flag' ;
    rdfs:comment 'Indicates whether this irregular operations event requires notification to regulatory authorities such as FAA, EASA, or national civil aviation authorities.' ;
    rdfs:domain ind:IropEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryNotificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Timestamp' ;
    rdfs:comment 'Date and time when regulatory authorities were notified of this irregular operations event. Nullable if notification not required or not yet completed.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:responsibleDepartment rdf:type rdf:Property ;
    rdfs:label 'Responsible Department' ;
    rdfs:comment 'Name of the operational department or division responsible for managing the response to this irregular operations event.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseDescription rdf:type rdf:Property ;
    rdfs:label 'Root Cause Description' ;
    rdfs:comment 'Detailed explanation of the underlying root cause that triggered the irregular operations event. Used for post-event analysis and prevention planning.' ;
    rdfs:domain ind:IropEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severityLevel rdf:type rdf:Property ;
    rdfs:label 'Severity Level' ;
    rdfs:comment 'Operational impact severity classification of the irregular operations event. Determines escalation procedures and resource allocation priority.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weatherConditionSummary rdf:type rdf:Property ;
    rdfs:label 'Weather Condition Summary' ;
    rdfs:comment 'Summary of weather conditions contributing to or associated with the irregular operations event. Applicable for weather-related IROP events.' ;
    rdfs:domain ind:IropEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationId rdf:type rdf:Property ;
    rdfs:label 'Cancellation Id' ;
    rdfs:comment 'Unique identifier for the flight cancellation record. Primary key.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Cancellation .

ind:advanceNoticeHours rdf:type rdf:Property ;
    rdfs:label 'Advance Notice Hours' ;
    rdfs:comment 'Number of hours between cancellation decision and scheduled departure time. Critical for determining passenger compensation eligibility under EU261 (14-day, 7-day thresholds).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:atcRestrictionType rdf:type rdf:Property ;
    rdfs:label 'Atc Restriction Type' ;
    rdfs:comment 'Type of air traffic control restriction that contributed to the cancellation (SLOT=slot restriction, GDP=ground delay program, GS=ground stop, CLOSURE=airport closure, CAPACITY=capacity reduction, FLOW=flow control).' ;
    rdfs:domain ind:Cancellation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationType rdf:type rdf:Property ;
    rdfs:label 'Cancellation Type' ;
    rdfs:comment 'Whether the cancellation was proactive (planned in advance to minimize disruption) or reactive (last-minute response to an operational event).' ;
    rdfs:domain ind:Cancellation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compensationAmountPerPassenger rdf:type rdf:Property ;
    rdfs:label 'Compensation Amount Per Passenger' ;
    rdfs:comment 'Standard compensation amount per passenger under applicable regulations (e.g., EUR 250/400/600 under EU261 based on distance and delay).' ;
    rdfs:domain ind:Cancellation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compensationEligibilityStatus rdf:type rdf:Property ;
    rdfs:label 'Compensation Eligibility Status' ;
    rdfs:comment 'Status of passenger compensation eligibility determination under applicable regulations (EU261, DOT, local regulations).' ;
    rdfs:domain ind:Cancellation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crewLegalityIssue rdf:type rdf:Property ;
    rdfs:label 'Crew Legality Issue' ;
    rdfs:comment 'Type of crew legality or availability issue that caused the cancellation (DUTY_TIME=exceeded duty limits, REST=insufficient rest, QUALIFICATION=crew not qualified, AVAILABILITY=crew unavailable, POSITIONING=crew positioning failure).' ;
    rdfs:domain ind:Cancellation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveTimestamp rdf:type rdf:Property ;
    rdfs:label 'Effective Timestamp' ;
    rdfs:comment 'Date and time when the cancellation became effective in operational systems and passenger notifications were triggered.' ;
    rdfs:domain ind:Cancellation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:estimatedRevenueImpactAmount rdf:type rdf:Property ;
    rdfs:label 'Estimated Revenue Impact Amount' ;
    rdfs:comment 'Estimated revenue loss from the cancelled flight including ticket revenue, ancillary revenue, and potential future booking impact.' ;
    rdfs:domain ind:Cancellation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:firstNotificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'First Notification Timestamp' ;
    rdfs:comment 'Date and time when the first passenger notification was sent regarding the cancellation.' ;
    rdfs:domain ind:Cancellation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isControllable rdf:type rdf:Property ;
    rdfs:label 'Is Controllable' ;
    rdfs:comment 'Indicates whether the cancellation was within the airline\'s control (maintenance, crew, operational decisions) versus uncontrollable (weather, ATC, security, force majeure). Used for passenger compensation eligibility under EU261 and DOT regulations.' ;
    rdfs:domain ind:Cancellation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDotReportable rdf:type rdf:Property ;
    rdfs:label 'Is Dot Reportable' ;
    rdfs:comment 'Indicates whether this cancellation must be reported to the US Department of Transportation under 14 CFR Part 234 (applies to US domestic flights and international flights to/from US by US carriers).' ;
    rdfs:domain ind:Cancellation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:networkOptimizationFlag rdf:type rdf:Property ;
    rdfs:label 'Network Optimization Flag' ;
    rdfs:comment 'Indicates whether the cancellation was a strategic network optimization decision (e.g., consolidating low-load flights, repositioning aircraft) rather than an operational failure.' ;
    rdfs:domain ind:Cancellation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationMethod rdf:type rdf:Property ;
    rdfs:label 'Notification Method' ;
    rdfs:comment 'Primary method(s) used to notify affected passengers of the cancellation (e.g., SMS, email, mobile app push, airport announcement, GDS message). [ENUM-REF-CANDIDATE: SMS|EMAIL|PUSH|AIRPORT_ANNOUNCEMENT|GDS|PHONE|WEBSITE — promote to reference product]' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:occRemarks rdf:type rdf:Property ;
    rdfs:label 'Occ Remarks' ;
    rdfs:comment 'Free-text operational remarks and notes from the Operations Control Center regarding the cancellation decision and handling.' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passengerCareCostAmount rdf:type rdf:Property ;
    rdfs:label 'Passenger Care Cost Amount' ;
    rdfs:comment 'Total cost incurred for passenger care obligations including meals, accommodation, transportation, and compensation payments under EU261 or DOT regulations.' ;
    rdfs:domain ind:Cancellation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rebookedPassengerCount rdf:type rdf:Property ;
    rdfs:label 'Rebooked Passenger Count' ;
    rdfs:comment 'Number of affected passengers who were successfully rebooked on alternative flights.' ;
    rdfs:domain ind:Cancellation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:refundedPassengerCount rdf:type rdf:Property ;
    rdfs:label 'Refunded Passenger Count' ;
    rdfs:comment 'Number of affected passengers who requested and received full refunds instead of rebooking.' ;
    rdfs:domain ind:Cancellation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryReportSubmittedFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Submitted Flag' ;
    rdfs:comment 'Indicates whether the required regulatory report (DOT, EASA, local CAA) has been submitted for this cancellation.' ;
    rdfs:domain ind:Cancellation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryReportTimestamp rdf:type rdf:Property ;
    rdfs:label 'Regulatory Report Timestamp' ;
    rdfs:comment 'Date and time when the regulatory report for this cancellation was submitted to the governing authority.' ;
    rdfs:domain ind:Cancellation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:substituteDepartureTime rdf:type rdf:Property ;
    rdfs:label 'Substitute Departure Time' ;
    rdfs:comment 'Scheduled departure time of the substitute flight, if one was operated to replace the cancelled service.' ;
    rdfs:domain ind:Cancellation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:substituteFlightNumber rdf:type rdf:Property ;
    rdfs:label 'Substitute Flight Number' ;
    rdfs:comment 'Flight number of the substitute or replacement flight operated to cover the cancelled service, if applicable.' ;
    rdfs:domain ind:Cancellation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weatherConditionCode rdf:type rdf:Property ;
    rdfs:label 'Weather Condition Code' ;
    rdfs:comment 'METAR/TAF weather phenomenon code if weather was a contributing factor to the cancellation (e.g., TS for thunderstorm, FG for fog, SN for snow).' ;
    rdfs:domain ind:Flight ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightBalanceId rdf:type rdf:Property ;
    rdfs:label 'Weight Balance Id' ;
    rdfs:comment 'Unique identifier for the weight and balance loadsheet record. Primary key.' ;
    rdfs:domain ind:WeightBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:loadPlanId rdf:type rdf:Property ;
    rdfs:label 'Load Plan Id' ;
    rdfs:comment 'Foreign key linking to cargo.load_plan. Business justification: The W&B sheet is produced directly from the cargo load plan — loadmasters use the load plan as the source document for W&B calculations. Regulatory compliance and dispatch sign-off require traceabilit' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LoadPlan .

ind:loadmasterMemberId rdf:type rdf:Property ;
    rdfs:label 'Loadmaster Member Id' ;
    rdfs:comment 'Foreign key linking to crew.member. Business justification: Regulatory load sheet accountability: the loadmaster who prepares and signs the weight & balance sheet is a licensed crew member. Aviation regulators require traceability of load control sign-offs to ' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Member .

ind:aircraftTypeCode rdf:type rdf:Property ;
    rdfs:label 'Aircraft Type Code' ;
    rdfs:comment 'ICAO or IATA aircraft type designator (e.g., B738, A320, B77W) identifying the aircraft model.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baggageWeightKg rdf:type rdf:Property ;
    rdfs:label 'Baggage Weight Kg' ;
    rdfs:comment 'Total weight of checked passenger baggage loaded in cargo holds.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:captainAcceptanceSignature rdf:type rdf:Property ;
    rdfs:label 'Captain Acceptance Signature' ;
    rdfs:comment 'Digital or physical signature of the pilot in command accepting the weight and balance loadsheet and authorizing departure.' ;
    rdfs:domain ind:WeightBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:captainAcceptanceTimestamp rdf:type rdf:Property ;
    rdfs:label 'Captain Acceptance Timestamp' ;
    rdfs:comment 'Date and time when the pilot in command accepted and signed the weight and balance loadsheet.' ;
    rdfs:domain ind:WeightBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cgAftLimitPercentMac rdf:type rdf:Property ;
    rdfs:label 'Cg Aft Limit Percent Mac' ;
    rdfs:comment 'Aft limit of the certified CG envelope for this weight and configuration. CG must not be behind this limit.' ;
    rdfs:domain ind:WeightBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cgForwardLimitPercentMac rdf:type rdf:Property ;
    rdfs:label 'Cg Forward Limit Percent Mac' ;
    rdfs:comment 'Forward limit of the certified CG envelope for this weight and configuration. CG must not be ahead of this limit.' ;
    rdfs:domain ind:WeightBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cgLandingPercentMac rdf:type rdf:Property ;
    rdfs:label 'Cg Landing Percent Mac' ;
    rdfs:comment 'Estimated longitudinal centre of gravity position at landing expressed as percentage of mean aerodynamic chord. Must remain within certified CG envelope.' ;
    rdfs:domain ind:WeightBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cgTakeoffPercentMac rdf:type rdf:Property ;
    rdfs:label 'Cg Takeoff Percent Mac' ;
    rdfs:comment 'Longitudinal centre of gravity position at takeoff expressed as percentage of mean aerodynamic chord. Must be within certified CG envelope.' ;
    rdfs:domain ind:WeightBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dryOperatingWeightKg rdf:type rdf:Property ;
    rdfs:label 'Dry Operating Weight Kg' ;
    rdfs:comment 'The weight of the aircraft including crew, crew baggage, catering, and all operational equipment but excluding fuel, passengers, cargo, and baggage. Also known as basic operating weight.' ;
    rdfs:domain ind:WeightBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:finalizedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Finalized Timestamp' ;
    rdfs:comment 'Date and time when the loadsheet was finalized and signed off, authorizing the flight for departure.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:holdAftWeightKg rdf:type rdf:Property ;
    rdfs:label 'Hold Aft Weight Kg' ;
    rdfs:comment 'Total weight loaded in the aft cargo hold compartment.' ;
    rdfs:domain ind:WeightBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holdBulkWeightKg rdf:type rdf:Property ;
    rdfs:label 'Hold Bulk Weight Kg' ;
    rdfs:comment 'Total weight loaded in the bulk cargo hold compartment, typically used for loose baggage and small cargo items.' ;
    rdfs:domain ind:WeightBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holdForwardWeightKg rdf:type rdf:Property ;
    rdfs:label 'Hold Forward Weight Kg' ;
    rdfs:comment 'Total weight loaded in the forward cargo hold compartment.' ;
    rdfs:domain ind:WeightBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:loadDistributionCompliant rdf:type rdf:Property ;
    rdfs:label 'Load Distribution Compliant' ;
    rdfs:comment 'Flag indicating whether the load distribution meets all structural and CG envelope requirements for safe flight.' ;
    rdfs:domain ind:WeightBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loadsheetNumber rdf:type rdf:Property ;
    rdfs:label 'Loadsheet Number' ;
    rdfs:comment 'Unique externally-known identifier for the weight and balance loadsheet document, typically assigned by the load control system or dispatcher.' ;
    rdfs:domain ind:WeightBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadsheetStatus rdf:type rdf:Property ;
    rdfs:label 'Loadsheet Status' ;
    rdfs:comment 'Current lifecycle status of the weight and balance loadsheet. Final status indicates dispatcher sign-off and regulatory compliance approval.' ;
    rdfs:domain ind:WeightBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadsheetVersion rdf:type rdf:Property ;
    rdfs:label 'Loadsheet Version' ;
    rdfs:comment 'Version number of the loadsheet. Incremented when corrections or updates are made prior to departure.' ;
    rdfs:domain ind:WeightBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mailWeightKg rdf:type rdf:Property ;
    rdfs:label 'Mail Weight Kg' ;
    rdfs:comment 'Weight of mail cargo loaded in cargo holds.' ;
    rdfs:domain ind:WeightBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxLandingWeightKg rdf:type rdf:Property ;
    rdfs:label 'Max Landing Weight Kg' ;
    rdfs:comment 'Maximum permissible landing weight for this aircraft as specified in the aircraft flight manual. Structural limit.' ;
    rdfs:domain ind:WeightBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxTakeoffWeightKg rdf:type rdf:Property ;
    rdfs:label 'Max Takeoff Weight Kg' ;
    rdfs:comment 'Maximum permissible takeoff weight for this aircraft under current conditions (runway length, temperature, altitude, obstacles). May be limited below certified MTOW.' ;
    rdfs:domain ind:WeightBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxZeroFuelWeightKg rdf:type rdf:Property ;
    rdfs:label 'Max Zero Fuel Weight Kg' ;
    rdfs:comment 'Maximum permissible zero fuel weight for this aircraft as specified in the aircraft flight manual. Structural limit.' ;
    rdfs:domain ind:WeightBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:passengerCountBusiness rdf:type rdf:Property ;
    rdfs:label 'Passenger Count Business' ;
    rdfs:comment 'Number of passengers seated in business class cabin.' ;
    rdfs:domain ind:WeightBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:passengerCountEconomy rdf:type rdf:Property ;
    rdfs:label 'Passenger Count Economy' ;
    rdfs:comment 'Number of passengers seated in economy cabin.' ;
    rdfs:domain ind:WeightBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:passengerCountFirst rdf:type rdf:Property ;
    rdfs:label 'Passenger Count First' ;
    rdfs:comment 'Number of passengers seated in first class cabin.' ;
    rdfs:domain ind:WeightBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:passengerCountPremiumEconomy rdf:type rdf:Property ;
    rdfs:label 'Passenger Count Premium Economy' ;
    rdfs:comment 'Number of passengers seated in premium economy cabin.' ;
    rdfs:domain ind:WeightBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:passengerCountTotal rdf:type rdf:Property ;
    rdfs:label 'Passenger Count Total' ;
    rdfs:comment 'Total number of passengers on board across all cabin classes (first, business, premium economy, economy).' ;
    rdfs:domain ind:WeightBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:passengerWeightKg rdf:type rdf:Property ;
    rdfs:label 'Passenger Weight Kg' ;
    rdfs:comment 'Total weight of all passengers calculated using standard or actual passenger weights per regulatory requirements.' ;
    rdfs:domain ind:WeightBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preparedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Prepared Timestamp' ;
    rdfs:comment 'Date and time when the weight and balance loadsheet was initially prepared by the loadmaster or dispatcher.' ;
    rdfs:domain ind:WeightBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:specialLoadIndicator rdf:type rdf:Property ;
    rdfs:label 'Special Load Indicator' ;
    rdfs:comment 'Flag indicating whether the flight carries special loads requiring additional handling or documentation (dangerous goods, live animals, human remains, etc.).' ;
    rdfs:domain ind:WeightBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:takeoffFuelKg rdf:type rdf:Property ;
    rdfs:label 'Takeoff Fuel Kg' ;
    rdfs:comment 'Total usable fuel on board at takeoff, including trip fuel, contingency, alternate, final reserve, and additional fuel.' ;
    rdfs:domain ind:WeightBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPayloadKg rdf:type rdf:Property ;
    rdfs:label 'Total Payload Kg' ;
    rdfs:comment 'Total revenue payload weight including passengers, baggage, cargo, and mail.' ;
    rdfs:domain ind:WeightBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trimSetting rdf:type rdf:Property ;
    rdfs:label 'Trim Setting' ;
    rdfs:comment 'Calculated horizontal stabilizer trim setting required for takeoff based on CG position and weight. Entered into flight management system or set manually.' ;
    rdfs:domain ind:WeightBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:underfloorCargoUldCount rdf:type rdf:Property ;
    rdfs:label 'Underfloor Cargo Uld Count' ;
    rdfs:comment 'Number of unit load devices (containers and pallets) loaded in underfloor cargo holds.' ;
    rdfs:domain ind:WeightBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:statusId rdf:type rdf:Property ;
    rdfs:label 'Status Id' ;
    rdfs:comment 'Unique identifier for the flight status record. Primary key.' ;
    rdfs:domain ind:Status ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:arrivalGate rdf:type rdf:Property ;
    rdfs:label 'Arrival Gate' ;
    rdfs:comment 'Current gate assignment for arrival. May be updated during flight based on airport operations and gate availability.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:atcSlotTime rdf:type rdf:Property ;
    rdfs:label 'Atc Slot Time' ;
    rdfs:comment 'Allocated takeoff or landing slot time assigned by ATC. Critical for slot-controlled airports and ATFM (Air Traffic Flow Management) compliance.' ;
    rdfs:domain ind:Status ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:boardingStartTime rdf:type rdf:Property ;
    rdfs:label 'Boarding Start Time' ;
    rdfs:comment 'Actual time when passenger boarding commenced at the departure gate. Used for operational metrics and passenger communication.' ;
    rdfs:domain ind:Status ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:boardingStatus rdf:type rdf:Property ;
    rdfs:label 'Boarding Status' ;
    rdfs:comment 'Current boarding process status. Indicates the stage of passenger boarding operations at the departure gate.' ;
    rdfs:domain ind:Status ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:delayReasonCode rdf:type rdf:Property ;
    rdfs:label 'Delay Reason Code' ;
    rdfs:comment 'Standardized code indicating the primary cause of delay if the flight is delayed. Used for operational analysis and regulatory reporting.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departureGate rdf:type rdf:Property ;
    rdfs:label 'Departure Gate' ;
    rdfs:comment 'Current gate assignment for departure. May change during operational disruptions or gate reassignments.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fidsPublishedFlag rdf:type rdf:Property ;
    rdfs:label 'Fids Published Flag' ;
    rdfs:comment 'Indicates whether this status has been published to airport FIDS displays. Used for display synchronization and audit purposes.' ;
    rdfs:domain ind:Status ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:flightPhase rdf:type rdf:Property ;
    rdfs:label 'Flight Phase' ;
    rdfs:comment 'Current phase of flight operations. Provides granular operational state for real-time tracking and operational control center monitoring. [ENUM-REF-CANDIDATE: pre_departure|taxi_out|takeoff|climb|cruise|descent|approach|landing|taxi_in|arrived — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateClosureTime rdf:type rdf:Property ;
    rdfs:label 'Gate Closure Time' ;
    rdfs:comment 'Actual time when the departure gate was closed and no further passengers were accepted for boarding. Critical for on-time departure metrics.' ;
    rdfs:domain ind:Status ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:gdsDistributionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Gds Distribution Timestamp' ;
    rdfs:comment 'Timestamp when this status was distributed to GDS systems (Amadeus, Sabre, Travelport). Used for external partner data synchronization tracking.' ;
    rdfs:domain ind:Status ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isIrop rdf:type rdf:Property ;
    rdfs:label 'Is Irop' ;
    rdfs:comment 'Indicates whether this flight is currently under irregular operations status requiring special handling, rebooking, or recovery procedures.' ;
    rdfs:domain ind:Status ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:notificationSentFlag rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Flag' ;
    rdfs:comment 'Indicates whether passenger notifications (SMS, email, push) have been sent for this status update. Used to prevent duplicate notifications.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:positionLatitude rdf:type rdf:Property ;
    rdfs:label 'Position Latitude' ;
    rdfs:comment 'Current latitude coordinate of the aircraft in decimal degrees. Updated from ACARS or ADS-B feeds during flight for real-time tracking.' ;
    rdfs:domain ind:Status ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:positionLongitude rdf:type rdf:Property ;
    rdfs:label 'Position Longitude' ;
    rdfs:comment 'Current longitude coordinate of the aircraft in decimal degrees. Updated from ACARS or ADS-B feeds during flight for real-time tracking.' ;
    rdfs:domain ind:Status ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:statusCode rdf:type rdf:Property ;
    rdfs:label 'Status Code' ;
    rdfs:comment 'Current operational state of the flight leg. Represents the lifecycle stage from scheduled through completion or cancellation. [ENUM-REF-CANDIDATE: scheduled|boarding|departed|airborne|landed|arrived|cancelled|diverted|delayed|returned — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Status ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusTimestamp rdf:type rdf:Property ;
    rdfs:label 'Status Timestamp' ;
    rdfs:comment 'Date and time when this status was recorded or became effective. Represents the business event time for this status change.' ;
    rdfs:domain ind:Status ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deadheadCrewMemberId rdf:type rdf:Property ;
    rdfs:label 'Deadhead Crew Member Id' ;
    rdfs:comment 'Foreign key linking to crew.member. Business justification: Deadhead crew positioning: when crew travel as passengers to reposition, a PNR is created for them. This FK enables deadhead cost tracking, crew scheduling integration, and operational reporting. Avia' ;
    rdfs:domain ind:Pnr ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Member .

ind:groupBookingId rdf:type rdf:Property ;
    rdfs:label 'Group Booking Id' ;
    rdfs:comment 'Foreign key linking to reservation.group_booking. Business justification: A PNR can be part of a group booking master record (10+ passengers travelling together). This is the correct direction (many PNRs → one group booking). Column group_name can be retrieved via JOIN from' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GroupBooking .

ind:bookingSource rdf:type rdf:Property ;
    rdfs:label 'Booking Source' ;
    rdfs:comment 'Origin system or channel through which the PNR was created. Distinguishes between GDS (Global Distribution System), direct airline channels, NDC (New Distribution Capability), call center, mobile app, web, or airport kiosk. [ENUM-REF-CANDIDATE: gds|direct|ndc|call_center|mobile_app|web|kiosk — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Pnr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookingStatus rdf:type rdf:Property ;
    rdfs:label 'Booking Status' ;
    rdfs:comment 'Current lifecycle status of the PNR. Indicates whether the reservation is active, on waitlist, cancelled, or archived after travel completion or expiry.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookingType rdf:type rdf:Property ;
    rdfs:label 'Booking Type' ;
    rdfs:comment 'Classification of the booking based on passenger type and commercial arrangement. Distinguishes individual, group, corporate contract, interline, and codeshare bookings.' ;
    rdfs:domain ind:Pnr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactEmail rdf:type rdf:Property ;
    rdfs:label 'Contact Email' ;
    rdfs:comment 'Primary email address for PNR-level communication. Used for booking confirmations, itinerary changes, and operational notifications. May differ from individual passenger emails.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactPhone rdf:type rdf:Property ;
    rdfs:label 'Contact Phone' ;
    rdfs:comment 'Primary phone number for PNR-level communication. Used for operational notifications, IROP (Irregular Operations) alerts, and customer service contact.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:corporateAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Corporate Account Number' ;
    rdfs:comment 'Corporate discount or contract account number associated with the booking. Used for negotiated fare application and corporate reporting.' ;
    rdfs:domain ind:Pnr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creatingAgentSign rdf:type rdf:Property ;
    rdfs:label 'Creating Agent Sign' ;
    rdfs:comment 'Agent sign or user ID of the individual who created the PNR. Used for audit trail and quality control.' ;
    rdfs:domain ind:Pnr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Creation Timestamp' ;
    rdfs:comment 'Date and time when the PNR was first created in the reservation system. Represents the initial booking event. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Pnr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:destinationCityCode rdf:type rdf:Property ;
    rdfs:label 'Destination City Code' ;
    rdfs:comment 'Three-letter IATA city code for the final arrival point in the itinerary. Used for origin-destination (O&D) analysis.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:formOfPaymentSummary rdf:type rdf:Property ;
    rdfs:label 'Form Of Payment Summary' ;
    rdfs:comment 'Summary description of the payment method(s) used for this PNR. May include credit card type, cash, voucher, or multiple forms of payment. Detailed payment data stored separately for PCI compliance.' ;
    rdfs:domain ind:Pnr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifyingAgentSign rdf:type rdf:Property ;
    rdfs:label 'Last Modifying Agent Sign' ;
    rdfs:comment 'Agent sign or user ID of the individual who last modified the PNR. Updated with each change for audit trail.' ;
    rdfs:domain ind:Pnr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pointOfSaleCity rdf:type rdf:Property ;
    rdfs:label 'Point Of Sale City' ;
    rdfs:comment 'Three-letter IATA city code representing the city where the booking was made. Used for market analysis and revenue management.' ;
    rdfs:domain ind:Pnr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pointOfSaleCountry rdf:type rdf:Property ;
    rdfs:label 'Point Of Sale Country' ;
    rdfs:comment 'Three-letter ISO country code representing the country where the booking was made. Critical for revenue accounting, tax calculation, and regulatory reporting.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purgeDate rdf:type rdf:Property ;
    rdfs:label 'Purge Date' ;
    rdfs:comment 'Date when the PNR is scheduled to be purged or archived from the active reservation system. Typically set based on last travel date plus retention period. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Pnr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:queueNumber rdf:type rdf:Property ;
    rdfs:label 'Queue Number' ;
    rdfs:comment 'PSS queue number where the PNR is currently placed for agent action. Used for workflow management and ticketing time limit monitoring.' ;
    rdfs:domain ind:Pnr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordLocator rdf:type rdf:Property ;
    rdfs:label 'Record Locator' ;
    rdfs:comment 'Six-character alphanumeric code uniquely identifying the PNR across systems. The externally-known business identifier used by agents, passengers, and partner systems. Also known as booking reference or confirmation code.' ;
    rdfs:domain ind:Pnr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialServiceRequestCodes rdf:type rdf:Property ;
    rdfs:label 'Special Service Request Codes' ;
    rdfs:comment 'Comma-separated list of four-letter SSR codes applicable to the entire PNR (e.g., WCHR for wheelchair, PETC for pet in cabin). Individual passenger SSRs stored separately.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ticketedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ticketed Timestamp' ;
    rdfs:comment 'Date and time when the PNR was ticketed (e-ticket issued). Null if not yet ticketed. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Pnr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:awardInventoryId rdf:type rdf:Property ;
    rdfs:label 'Award Inventory Id' ;
    rdfs:comment 'Foreign key linking to loyalty.award_inventory. Business justification: Award bookings consume specific award inventory allocations per segment. Business process: award seat allocation tracking, inventory management, waitlist clearance, dynamic award pricing.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AwardInventory .

ind:actionCode rdf:type rdf:Property ;
    rdfs:label 'Action Code' ;
    rdfs:comment 'Transaction action code representing the booking action taken. NN=Need, HN=Have need, HK=Holding confirmed, KK=Confirmed, UC=Unable to confirm, UN=Unable need, NO=No action, HL=Have waitlist, KL=Confirmed from waitlist, TK=Schedule change confirmed, TL=Schedule change waitlist, HX=Have cancel, XX=Cancel confirmed, WK=Waitlist, RQ=On request. [ENUM-REF-CANDIDATE: NN|HN|HK|KK|UC|UN|NO|HL|KL|TK|TL|HX|XX|WK|RQ — 15 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ItinerarySegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookingChannelCode rdf:type rdf:Property ;
    rdfs:label 'Booking Channel Code' ;
    rdfs:comment 'Channel through which this segment was booked. GDS=Global Distribution System, WEB=Website, MOB=Mobile App, CTO=City Ticket Office, RES=Reservations Call Center, API=Direct API.' ;
    rdfs:domain ind:ItinerarySegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookingClassCode rdf:type rdf:Property ;
    rdfs:label 'Booking Class Code' ;
    rdfs:comment 'Single-letter Reservation Booking Designator (RBD) representing the fare class booked. Determines inventory bucket and fare rules.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endorsementRestrictions rdf:type rdf:Property ;
    rdfs:label 'Endorsement Restrictions' ;
    rdfs:comment 'Free-text field containing fare rule endorsements and restrictions applicable to this segment (e.g., NON-REF, CHG FEE APPLIES).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flownIndicator rdf:type rdf:Property ;
    rdfs:label 'Flown Indicator' ;
    rdfs:comment 'Flag indicating whether the passenger has completed travel on this segment. Set to true after departure or boarding confirmation.' ;
    rdfs:domain ind:ItinerarySegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gdsPccCode rdf:type rdf:Property ;
    rdfs:label 'Gds Pcc Code' ;
    rdfs:comment 'GDS Pseudo City Code identifying the travel agency or corporate booking location that created this segment reservation.' ;
    rdfs:domain ind:ItinerarySegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marriageGroupIndicator rdf:type rdf:Property ;
    rdfs:label 'Marriage Group Indicator' ;
    rdfs:comment 'Single-letter code grouping segments that must be priced together as a married segment. Segments with the same indicator are married for fare construction.' ;
    rdfs:domain ind:ItinerarySegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberOfSeats rdf:type rdf:Property ;
    rdfs:label 'Number Of Seats' ;
    rdfs:comment 'Quantity of seats booked on this segment for the associated passengers in the PNR.' ;
    rdfs:domain ind:ItinerarySegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operatingFlightNumber rdf:type rdf:Property ;
    rdfs:label 'Operating Flight Number' ;
    rdfs:comment 'Actual flight number operated by the operating carrier. Populated when segment is a codeshare and differs from marketing flight number.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Segment Created Timestamp' ;
    rdfs:comment 'Date and time when this segment was first added to the PNR in the reservation system.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:segmentMileage rdf:type rdf:Property ;
    rdfs:label 'Segment Mileage' ;
    rdfs:comment 'Great circle distance in miles between departure and arrival airports. Used for fare construction and frequent flyer accrual.' ;
    rdfs:domain ind:ItinerarySegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:segmentModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Segment Modified Timestamp' ;
    rdfs:comment 'Date and time when this segment was last modified (status change, schedule change, or other update).' ;
    rdfs:domain ind:ItinerarySegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:segmentSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Segment Sequence Number' ;
    rdfs:comment 'Sequential ordering of this segment within the PNR itinerary. Determines the travel flow from origin to final destination.' ;
    rdfs:domain ind:ItinerarySegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:segmentStatusCode rdf:type rdf:Property ;
    rdfs:label 'Segment Status Code' ;
    rdfs:comment 'Current reservation status of the segment. HK=Confirmed, KK=Confirmed by carrier, KL=Confirmed waitlist cleared, HL=Have requested waitlist, UN=Unable to confirm, UC=Unable to accept, NO=No action taken, WK=Waitlisted, RQ=Requested, TK=Schedule change confirmed, TL=Schedule change waitlist. [ENUM-REF-CANDIDATE: HK|KK|KL|HL|UN|UC|NO|WK|RQ|TK|TL — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ItinerarySegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionPercentage rdf:type rdf:Property ;
    rdfs:label 'Commission Percentage' ;
    rdfs:comment 'Commission rate percentage applied to calculate the commission amount. Null if flat commission was used.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conjunctionTicketNumbers rdf:type rdf:Property ;
    rdfs:label 'Conjunction Ticket Numbers' ;
    rdfs:comment 'Comma-separated list of related conjunction ticket numbers if this ticket is part of a multi-ticket set. Empty if not a conjunction ticket.' ;
    rdfs:domain ind:ETicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:equivalentCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Equivalent Currency Code' ;
    rdfs:comment 'ISO 4217 3-letter currency code for the equivalent fare amount. Null if no currency conversion was applied.' ;
    rdfs:domain ind:ETicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeTicketIndicator rdf:type rdf:Property ;
    rdfs:label 'Exchange Ticket Indicator' ;
    rdfs:comment 'Flag indicating whether this ticket was issued as an exchange for a previous ticket. True if this is a reissued ticket.' ;
    rdfs:domain ind:ETicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:formOfPaymentDetails rdf:type rdf:Property ;
    rdfs:label 'Form Of Payment Details' ;
    rdfs:comment 'Detailed payment information including masked card number, approval code, or account reference. Sensitive financial data stored according to PCI-DSS requirements.' ;
    rdfs:domain ind:ETicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdsPcc rdf:type rdf:Property ;
    rdfs:label 'Gds Pcc' ;
    rdfs:comment 'GDS Pseudo City Code (PCC) of the agency or office that created the booking. Used for GDS reporting and commission tracking.' ;
    rdfs:domain ind:ETicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdsRecordLocator rdf:type rdf:Property ;
    rdfs:label 'Gds Record Locator' ;
    rdfs:comment 'GDS-specific booking reference number (record locator) linking the ticket to the GDS reservation. May differ from airline PNR.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inConnectionWithTicket rdf:type rdf:Property ;
    rdfs:label 'In Connection With Ticket' ;
    rdfs:comment 'Ticket number of a related ticket when this ticket is issued in connection with another (e.g., companion ticket, family booking). Null if standalone.' ;
    rdfs:domain ind:ETicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundIndicator rdf:type rdf:Property ;
    rdfs:label 'Refund Indicator' ;
    rdfs:comment 'Flag indicating whether a refund has been processed for this ticket. True if ticket has been refunded (fully or partially).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ticketDesignator rdf:type rdf:Property ;
    rdfs:label 'Ticket Designator' ;
    rdfs:comment 'Special fare qualifier or corporate discount code applied to the ticket. Used for negotiated corporate rates or promotional fares.' ;
    rdfs:domain ind:ETicket ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookedTierStatusId rdf:type rdf:Property ;
    rdfs:label 'Booked Tier Status Id' ;
    rdfs:comment 'Foreign key linking to loyalty.tier_status. Business justification: Tier-at-booking-time snapshot is a named benefit-application requirement: tier can change between booking and travel, so the tier that qualified the booking benefits (seat preference, upgrade eligibil' ;
    rdfs:domain ind:BookingPassenger ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TierStatus .

ind:crewMemberId rdf:type rdf:Property ;
    rdfs:label 'Crew Member Id' ;
    rdfs:comment 'Foreign key linking to crew.member. Business justification: Staff travel and deadhead management: crew members traveling on staff benefit tickets or deadhead bookings appear as passengers. This FK links the passenger booking record to the crew member for staff' ;
    rdfs:domain ind:BookingPassenger ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Member .

ind:seatMapId rdf:type rdf:Property ;
    rdfs:label 'Seat Map Id' ;
    rdfs:comment 'Foreign key linking to fleet.seat_map. Business justification: Seat assignment validation is a core reservation process: when assigning a seat, the system must verify seat eligibility (exit row age/ability restrictions, bassinet capability, accessibility complian' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SeatMap .

ind:apisDataCompleteFlag rdf:type rdf:Property ;
    rdfs:label 'Apis Data Complete Flag' ;
    rdfs:comment 'Indicates whether all required APIS data elements (name, DOB, gender, nationality, passport) have been collected for this passenger. Required for international travel compliance.' ;
    rdfs:domain ind:BookingPassenger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:boardingPassIssuedFlag rdf:type rdf:Property ;
    rdfs:label 'Boarding Pass Issued Flag' ;
    rdfs:comment 'Indicates whether a boarding pass has been issued to this passenger for at least one segment in the itinerary.' ;
    rdfs:domain ind:BookingPassenger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:checkInStatus rdf:type rdf:Property ;
    rdfs:label 'Check In Status' ;
    rdfs:comment 'Current check-in and boarding status of the passenger. Tracks progression from reservation through boarding.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkInTimestamp rdf:type rdf:Property ;
    rdfs:label 'Check In Timestamp' ;
    rdfs:comment 'Date and time when the passenger completed check-in for the first flight segment in the itinerary. Used for boarding priority and operational reporting.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:contactPhoneNumber rdf:type rdf:Property ;
    rdfs:label 'Contact Phone Number' ;
    rdfs:comment 'Primary contact phone number for this passenger. Used for flight notifications, IROP rebooking, and operational communication.' ;
    rdfs:domain ind:BookingPassenger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dateOfBirth rdf:type rdf:Property ;
    rdfs:label 'Date Of Birth' ;
    rdfs:comment 'Date of birth of the passenger. Required for infant and child passengers, and for APIS (Advanced Passenger Information System) compliance on international flights.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:emergencyContactName rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Name' ;
    rdfs:comment 'Full name of the passenger\'s emergency contact person. Collected for safety and incident response purposes.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emergencyContactPhone rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Phone' ;
    rdfs:comment 'Phone number of the passenger\'s emergency contact person. Used in case of flight incidents or medical emergencies.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:firstName rdf:type rdf:Property ;
    rdfs:label 'First Name' ;
    rdfs:comment 'Given name of the passenger as it appears on travel documents. Must match government-issued ID for international travel.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gender rdf:type rdf:Property ;
    rdfs:label 'Gender' ;
    rdfs:comment 'Gender of the passenger as recorded in the booking. M=Male, F=Female, U=Unspecified, X=Non-binary. Required for APIS compliance.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:knownTravellerNumber rdf:type rdf:Property ;
    rdfs:label 'Known Traveller Number' ;
    rdfs:comment 'TSA PreCheck or other trusted traveler program number. Enables expedited security screening for eligible passengers on US domestic and international flights.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastName rdf:type rdf:Property ;
    rdfs:label 'Last Name' ;
    rdfs:comment 'Family name or surname of the passenger as it appears on travel documents. Must match government-issued ID for international travel.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mealPreferenceCode rdf:type rdf:Property ;
    rdfs:label 'Meal Preference Code' ;
    rdfs:comment 'IATA standard meal code representing the passenger\'s dietary preference or restriction. VGML=Vegetarian, HNML=Hindu, KSML=Kosher, MOML=Muslim, AVML=Asian Vegetarian, DBML=Diabetic. [ENUM-REF-CANDIDATE: REGULAR|VGML|HNML|KSML|MOML|AVML|DBML — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BookingPassenger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:middleName rdf:type rdf:Property ;
    rdfs:label 'Middle Name' ;
    rdfs:comment 'Middle name or initial of the passenger. Optional field used when provided on travel documents.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Modified Timestamp' ;
    rdfs:comment 'Date and time when this passenger name element was last modified. Tracks name corrections, SSR updates, and status changes.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:nationalityCountryCode rdf:type rdf:Property ;
    rdfs:label 'Nationality Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code representing the passenger\'s nationality. Required for APIS and visa validation.' ;
    rdfs:domain ind:BookingPassenger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passengerSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Passenger Sequence Number' ;
    rdfs:comment 'Sequential ordering of this passenger within the PNR. Used for display, SSR association, and segment assignment. Typically starts at 1.' ;
    rdfs:domain ind:BookingPassenger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:redressNumber rdf:type rdf:Property ;
    rdfs:label 'Redress Number' ;
    rdfs:comment 'DHS Traveler Redress Inquiry Program (TRIP) number issued to passengers who have been misidentified during security screening. Prevents false matches on watchlists.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seatPreferenceCode rdf:type rdf:Property ;
    rdfs:label 'Seat Preference Code' ;
    rdfs:comment 'Passenger\'s preferred seat location type. Used by seat assignment algorithms and displayed to agents during check-in.' ;
    rdfs:domain ind:BookingPassenger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialServiceRequestCount rdf:type rdf:Property ;
    rdfs:label 'Special Service Request Count' ;
    rdfs:comment 'Total number of SSR records associated with this passenger in the PNR. Includes wheelchair assistance, unaccompanied minor service, pet in cabin, extra baggage, etc.' ;
    rdfs:domain ind:BookingPassenger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:suffix rdf:type rdf:Property ;
    rdfs:label 'Suffix' ;
    rdfs:comment 'Generational or professional suffix appended to the passenger name (e.g., Jr., Sr., III). Used for name disambiguation.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:title rdf:type rdf:Property ;
    rdfs:label 'Title' ;
    rdfs:comment 'Honorific title of the passenger as recorded in the booking. Used for ticket issuance and customer communication. [ENUM-REF-CANDIDATE: MR|MS|MRS|MISS|DR|PROF|MSTR — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unaccompaniedMinorFlag rdf:type rdf:Property ;
    rdfs:label 'Unaccompanied Minor Flag' ;
    rdfs:comment 'Indicates whether this passenger is traveling as an unaccompanied minor and requires special handling, escort service, and guardian handoff procedures.' ;
    rdfs:domain ind:BookingPassenger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:wheelchairAssistanceCode rdf:type rdf:Property ;
    rdfs:label 'Wheelchair Assistance Code' ;
    rdfs:comment 'IATA SSR code indicating level of wheelchair assistance required. WCHR=Can walk short distances, WCHS=Cannot climb stairs, WCHC=Immobile, requires wheelchair throughout.' ;
    rdfs:domain ind:BookingPassenger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ssrId rdf:type rdf:Property ;
    rdfs:label 'Ssr Id' ;
    rdfs:comment 'Unique identifier for the special service request record. Primary key.' ;
    rdfs:domain ind:Ssr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Action Required Flag' ;
    rdfs:comment 'Indicates whether operational action is required by airline staff to fulfill this SSR (e.g., wheelchair provision, meal loading, document verification).' ;
    rdfs:domain ind:Ssr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:apisRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Apis Required Flag' ;
    rdfs:comment 'Indicates whether this SSR is required for APIS compliance (e.g., DOCS, DOCA, DOCO SSRs for border control and security).' ;
    rdfs:domain ind:Ssr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cancellationReason rdf:type rdf:Property ;
    rdfs:label 'Cancellation Reason' ;
    rdfs:comment 'Free-text explanation of why this SSR was cancelled (e.g., passenger request, flight change, service unavailable).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancelledTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cancelled Timestamp' ;
    rdfs:comment 'Date and time when this SSR was cancelled or removed from the PNR. Null if still active.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:chargeAmount rdf:type rdf:Property ;
    rdfs:label 'Charge Amount' ;
    rdfs:comment 'Monetary amount charged for this SSR if charge_applicable_flag is true. Null if complimentary.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chargeApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Charge Applicable Flag' ;
    rdfs:comment 'Indicates whether this SSR incurs a charge to the passenger (e.g., paid meal upgrade, pet in cabin fee). False for complimentary services.' ;
    rdfs:domain ind:Ssr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:chargeCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Charge Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the charge amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creationSource rdf:type rdf:Property ;
    rdfs:label 'Creation Source' ;
    rdfs:comment 'Channel or system through which the SSR was originally created (e.g., GDS, airline website, mobile app, call center, airport check-in, API integration). [ENUM-REF-CANDIDATE: gds|web|mobile|call_center|airport|api|amadeus|sabre|galileo|worldspan — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freeText rdf:type rdf:Property ;
    rdfs:label 'Free Text' ;
    rdfs:comment 'Free-text field containing additional details or remarks associated with the SSR. May include passenger-specific instructions, medical details, or document numbers.' ;
    rdfs:domain ind:Ssr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfillmentStatus rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Status' ;
    rdfs:comment 'Operational status indicating whether the SSR has been fulfilled by ground or cabin crew (e.g., wheelchair provided, meal loaded, document verified).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfillmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Timestamp' ;
    rdfs:comment 'Date and time when the SSR was marked as fulfilled by operational staff. Null if not yet fulfilled.' ;
    rdfs:domain ind:Ssr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:interlineAgreementFlag rdf:type rdf:Property ;
    rdfs:label 'Interline Agreement Flag' ;
    rdfs:comment 'Indicates whether this SSR is subject to interline agreement terms between multiple carriers in a multi-carrier itinerary.' ;
    rdfs:domain ind:Ssr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:operatingAirlineCode rdf:type rdf:Property ;
    rdfs:label 'Operating Airline Code' ;
    rdfs:comment 'Two-character IATA airline code of the carrier operating the flight segment to which this SSR applies. May differ from responsible airline in codeshare scenarios.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityLevel rdf:type rdf:Property ;
    rdfs:label 'Priority Level' ;
    rdfs:comment 'Operational priority assigned to this SSR for fulfillment and crew attention (e.g., critical for medical oxygen, high for wheelchair, medium for meal).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantity rdf:type rdf:Property ;
    rdfs:label 'Quantity' ;
    rdfs:comment 'Number of units or instances of this SSR requested (e.g., 2 wheelchairs, 3 special meals). Defaults to 1 if not specified.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Flag' ;
    rdfs:comment 'Indicates whether this SSR is mandated by regulatory or security requirements (e.g., TSA, FAA, EASA, national civil aviation authorities).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:responsibleAirlineCode rdf:type rdf:Property ;
    rdfs:label 'Responsible Airline Code' ;
    rdfs:comment 'Two-character IATA airline code of the carrier responsible for fulfilling this SSR. Relevant for codeshare and interline bookings.' ;
    rdfs:domain ind:Ssr ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ssrCategory rdf:type rdf:Property ;
    rdfs:label 'Ssr Category' ;
    rdfs:comment 'Business classification of the SSR for operational routing and fulfillment (e.g., meal service, mobility assistance, travel documentation, frequent flyer program). [ENUM-REF-CANDIDATE: meal|wheelchair|medical|document|loyalty|security|baggage|pet|infant|unaccompanied_minor|seating|other — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ssrCode rdf:type rdf:Property ;
    rdfs:label 'Ssr Code' ;
    rdfs:comment 'Four-letter IATA SSR code identifying the type of special service (e.g., WCHR for wheelchair, VGML for vegetarian meal, UMNR for unaccompanied minor, DOCS for travel document, FQTV for frequent flyer).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ssrStatus rdf:type rdf:Property ;
    rdfs:label 'Ssr Status' ;
    rdfs:comment 'Current status of the SSR. HK=confirmed by airline, KK=confirmed by carrier, UN=unable to confirm, NO=not processed, NN=need confirmation, UC=unable to confirm space, UU=unconfirmed, RQ=requested. [ENUM-REF-CANDIDATE: HK|KK|UN|NO|NN|UC|UU|RQ — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boardingPassId rdf:type rdf:Property ;
    rdfs:label 'Boarding Pass Id' ;
    rdfs:comment 'Unique identifier for the boarding pass record. Primary key. Inferred role: TRANSACTION_HEADER (discrete check-in event with lifecycle).' ;
    rdfs:domain ind:BoardingPass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:checkInEventId rdf:type rdf:Property ;
    rdfs:label 'Check In Event Id' ;
    rdfs:comment 'Foreign key linking to reservation.check_in_event. Business justification: A boarding pass is the direct output of a check-in event — it is issued as a result of the check-in transaction. boarding_pass already has pnr_id, itinerary_segment_id, and reservation_booking_passeng' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CheckInEvent .

ind:gateAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Gate Assignment Id' ;
    rdfs:comment 'Foreign key linking to airport.gate_assignment. Business justification: Boarding passes are issued for specific gate assignments. Operational coordination between reservation systems and airport operations (gate changes, boarding status) requires this link for real-time p' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GateAssignment .

ind:gateId rdf:type rdf:Property ;
    rdfs:label 'Gate Id' ;
    rdfs:comment 'Foreign key linking to airport.gate. Business justification: Boarding passes specify gate assignments for passenger boarding. Gate utilization tracking, passenger flow management, and boarding sequence coordination require this link. Core operational relationsh' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Gate .

ind:primaryBaggageItemId rdf:type rdf:Property ;
    rdfs:label 'Primary Baggage Item Id' ;
    rdfs:comment 'Foreign key linking to airport.baggage_item. Business justification: Boarding passes are issued to passengers who check baggage. Baggage reconciliation (positive passenger bag match), tracking, and irregularity investigation require this link for operational safety and' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BaggageItem .

ind:seatAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Seat Assignment Id' ;
    rdfs:comment 'Foreign key linking to ancillary.seat_assignment. Business justification: A boarding pass must reflect the confirmed seat assignment record for DCS/CUTE system integrity. Linking boarding_pass to ancillary.seat_assignment enables seat change tracking, fee reconciliation, an' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SeatAssignment .

ind:baggageTagNumbers rdf:type rdf:Property ;
    rdfs:label 'Baggage Tag Numbers' ;
    rdfs:comment 'Comma-separated list of baggage tag numbers (10-digit IATA license plate codes) for checked bags associated with this boarding pass.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:barcodeData rdf:type rdf:Property ;
    rdfs:label 'Barcode Data' ;
    rdfs:comment 'Encoded barcode data string conforming to IATA BCBP Type M format. Contains passenger name, flight details, seat, boarding pass number, and security data. Confidential due to embedded passenger information.' ;
    rdfs:domain ind:BoardingPass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boardingGroup rdf:type rdf:Property ;
    rdfs:label 'Boarding Group' ;
    rdfs:comment 'Descriptive boarding group name assigned to the passenger (e.g., priority, general, family). Complements boarding_zone with business-friendly label.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boardingPassNumber rdf:type rdf:Property ;
    rdfs:label 'Boarding Pass Number' ;
    rdfs:comment 'Unique boarding pass sequence number issued by the check-in system. Business identifier for the boarding pass. Satisfies TRANSACTION_HEADER minimum requirement for BUSINESS_IDENTIFIER.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boardingPassStatus rdf:type rdf:Property ;
    rdfs:label 'Boarding Pass Status' ;
    rdfs:comment 'Current lifecycle status of the boarding pass. Tracks progression from issuance through boarding gate scan. Satisfies TRANSACTION_HEADER minimum requirement for LIFECYCLE_STATUS.' ;
    rdfs:domain ind:BoardingPass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boardingScanTimestamp rdf:type rdf:Property ;
    rdfs:label 'Boarding Scan Timestamp' ;
    rdfs:comment 'Timestamp when the boarding pass barcode was scanned at the gate, confirming passenger boarded the aircraft. Null if not yet scanned.' ;
    rdfs:domain ind:BoardingPass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:boardingTime rdf:type rdf:Property ;
    rdfs:label 'Boarding Time' ;
    rdfs:comment 'Scheduled boarding commencement time printed on the boarding pass. Advises passengers when to arrive at the gate.' ;
    rdfs:domain ind:BoardingPass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:boardingZone rdf:type rdf:Property ;
    rdfs:label 'Boarding Zone' ;
    rdfs:comment 'Boarding zone or group assigned to the passenger for sequenced boarding. May be numeric (1-9) or alphabetic (A-Z) depending on airline policy.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkInCounterNumber rdf:type rdf:Property ;
    rdfs:label 'Check In Counter Number' ;
    rdfs:comment 'Counter or kiosk number where the boarding pass was issued. Null for web or mobile check-in.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkInLocationCode rdf:type rdf:Property ;
    rdfs:label 'Check In Location Code' ;
    rdfs:comment 'Three-letter IATA airport code where the boarding pass was issued. May differ from departure airport for interline or codeshare itineraries.' ;
    rdfs:domain ind:BoardingPass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkInMethod rdf:type rdf:Property ;
    rdfs:label 'Check In Method' ;
    rdfs:comment 'Channel through which the passenger completed check-in and received the boarding pass. CUSS = Common Use Self-Service.' ;
    rdfs:domain ind:BoardingPass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkedBagCount rdf:type rdf:Property ;
    rdfs:label 'Checked Bag Count' ;
    rdfs:comment 'Number of checked bags associated with this boarding pass at check-in.' ;
    rdfs:domain ind:BoardingPass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:documentCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Document Check Status' ;
    rdfs:comment 'Status of travel document verification (passport, visa, ID) at check-in. Required for international flights.' ;
    rdfs:domain ind:BoardingPass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fastTrackEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Fast Track Eligible Flag' ;
    rdfs:comment 'Indicates whether the passenger is eligible for fast-track security or priority boarding based on fare class, status, or purchase.' ;
    rdfs:domain ind:BoardingPass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:format rdf:type rdf:Property ;
    rdfs:label 'Format' ;
    rdfs:comment 'Physical or digital format of the boarding pass issued to the passenger. BCBP = Bar Coded Boarding Pass (2D barcode).' ;
    rdfs:domain ind:BoardingPass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastReprintTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Reprint Timestamp' ;
    rdfs:comment 'Timestamp of the most recent boarding pass reprint event. Null if never reprinted.' ;
    rdfs:domain ind:BoardingPass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:loungeAccessFlag rdf:type rdf:Property ;
    rdfs:label 'Lounge Access Flag' ;
    rdfs:comment 'Indicates whether the passenger has lounge access entitlement printed on the boarding pass.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reprintCount rdf:type rdf:Property ;
    rdfs:label 'Reprint Count' ;
    rdfs:comment 'Number of times this boarding pass has been reprinted (e.g., at kiosk, counter, or gate). Zero indicates original issuance.' ;
    rdfs:domain ind:BoardingPass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:securitySelecteeFlag rdf:type rdf:Property ;
    rdfs:label 'Security Selectee Flag' ;
    rdfs:comment 'Indicates whether the passenger has been selected for additional security screening by TSA or equivalent authority. Confidential security data.' ;
    rdfs:domain ind:BoardingPass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specialServiceCodes rdf:type rdf:Property ;
    rdfs:label 'Special Service Codes' ;
    rdfs:comment 'Comma-separated list of IATA SSR codes applicable to this boarding pass (e.g., WCHR for wheelchair, PETC for pet in cabin, UMNR for unaccompanied minor).' ;
    rdfs:domain ind:BoardingPass ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkinSessionId rdf:type rdf:Property ;
    rdfs:label 'Checkin Session Id' ;
    rdfs:comment 'Foreign key linking to airport.checkin_session. Business justification: Check-in events are recorded within checkin sessions. Counter utilization metrics, agent performance tracking, and operational efficiency analysis require this link for facility and staffing planning.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CheckinSession .

ind:primaryCheckBookingPnrId rdf:type rdf:Property ;
    rdfs:label 'Primary Check Booking Pnr Id' ;
    rdfs:comment 'Foreign key reference to the booking record for which this check-in was performed.' ;
    rdfs:domain ind:CheckInEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Pnr .

ind:upgradeRequestId rdf:type rdf:Property ;
    rdfs:label 'Upgrade Request Id' ;
    rdfs:comment 'Foreign key linking to loyalty.upgrade_request. Business justification: Check-in triggers operational upgrade clearance processing. Business process: departure control upgrade confirmation, seat assignment, boarding pass issuance with upgraded cabin, waitlist clearance.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UpgradeRequest .

ind:apisSubmissionStatus rdf:type rdf:Property ;
    rdfs:label 'Apis Submission Status' ;
    rdfs:comment 'Status of the APIS data submission to border control authorities. APIS is required for international flights to transmit passenger data to destination countries.' ;
    rdfs:domain ind:CheckInEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apisSubmissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Apis Submission Timestamp' ;
    rdfs:comment 'The date and time when APIS data was successfully submitted to border control authorities.' ;
    rdfs:domain ind:CheckInEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:boardingSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Boarding Sequence Number' ;
    rdfs:comment 'Sequential boarding number assigned to the passenger, used to determine boarding priority and order.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:checkInChannel rdf:type rdf:Property ;
    rdfs:label 'Check In Channel' ;
    rdfs:comment 'The channel or interface through which the passenger performed check-in. CUSS refers to Common Use Self-Service kiosks. [ENUM-REF-CANDIDATE: web|mobile|airport_kiosk|counter|cuss|api|call_center — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CheckInEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkInCloseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Check In Close Timestamp' ;
    rdfs:comment 'The scheduled or actual timestamp when check-in closed for this flight. Used to determine if passenger checked in before the cutoff time.' ;
    rdfs:domain ind:CheckInEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:checkInConfirmationCode rdf:type rdf:Property ;
    rdfs:label 'Check In Confirmation Code' ;
    rdfs:comment 'Unique confirmation code or reference number generated upon successful check-in completion, provided to the passenger.' ;
    rdfs:domain ind:CheckInEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkInRemarks rdf:type rdf:Property ;
    rdfs:label 'Check In Remarks' ;
    rdfs:comment 'Free-text remarks or notes recorded by the agent or system during check-in, capturing special circumstances, passenger requests, or operational notes.' ;
    rdfs:domain ind:CheckInEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkInSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Check In Sequence Number' ;
    rdfs:comment 'Sequential number indicating the order of check-in within a booking or PNR when multiple passengers or segments are involved.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:checkInStationCode rdf:type rdf:Property ;
    rdfs:label 'Check In Station Code' ;
    rdfs:comment 'Three-letter IATA airport code or city code where the check-in transaction was performed.' ;
    rdfs:domain ind:CheckInEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkedBaggageWeightKg rdf:type rdf:Property ;
    rdfs:label 'Checked Baggage Weight Kg' ;
    rdfs:comment 'Total weight in kilograms of all checked baggage for this passenger during check-in.' ;
    rdfs:domain ind:CheckInEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:checkedBagsCount rdf:type rdf:Property ;
    rdfs:label 'Checked Bags Count' ;
    rdfs:comment 'The total number of bags checked by the passenger during this check-in event.' ;
    rdfs:domain ind:CheckInEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:documentVerificationStatus rdf:type rdf:Property ;
    rdfs:label 'Document Verification Status' ;
    rdfs:comment 'Status of travel document verification (passport, visa, ID) performed during check-in to ensure compliance with destination country requirements.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:excessBaggageFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Excess Baggage Fee Amount' ;
    rdfs:comment 'The fee charged for excess baggage beyond the allowed free baggage allowance. Zero if no excess baggage fee was applied.' ;
    rdfs:domain ind:CheckInEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:excessBaggageFeeCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Excess Baggage Fee Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the excess baggage fee amount.' ;
    rdfs:domain ind:CheckInEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frequentFlyerNumber rdf:type rdf:Property ;
    rdfs:label 'Frequent Flyer Number' ;
    rdfs:comment 'The passenger\'s frequent flyer program membership number used during check-in for mileage accrual and status recognition.' ;
    rdfs:domain ind:CheckInEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minutesBeforeDeparture rdf:type rdf:Property ;
    rdfs:label 'Minutes Before Departure' ;
    rdfs:comment 'The number of minutes before scheduled departure time that the passenger completed check-in. Used for OTP analysis and no-show prediction.' ;
    rdfs:domain ind:CheckInEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mobileBoardingPassIssuedFlag rdf:type rdf:Property ;
    rdfs:label 'Mobile Boarding Pass Issued Flag' ;
    rdfs:comment 'Boolean indicator of whether a mobile boarding pass was issued to the passenger\'s mobile device during check-in.' ;
    rdfs:domain ind:CheckInEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorityBoardingFlag rdf:type rdf:Property ;
    rdfs:label 'Priority Boarding Flag' ;
    rdfs:comment 'Boolean indicator of whether the passenger is entitled to priority boarding based on ticket class, status, or purchased service.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specialServiceRequests rdf:type rdf:Property ;
    rdfs:label 'Special Service Requests' ;
    rdfs:comment 'Comma-separated list of SSR codes confirmed or added during check-in (e.g., WCHR for wheelchair, VGML for vegetarian meal, PETC for pet in cabin).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upgradeAtCheckInFlag rdf:type rdf:Property ;
    rdfs:label 'Upgrade At Check In Flag' ;
    rdfs:comment 'Boolean indicator of whether the passenger received a cabin class upgrade during the check-in process.' ;
    rdfs:domain ind:CheckInEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:upgradedCabinClass rdf:type rdf:Property ;
    rdfs:label 'Upgraded Cabin Class' ;
    rdfs:comment 'The cabin class to which the passenger was upgraded during check-in (e.g., Business, First). Null if no upgrade occurred.' ;
    rdfs:domain ind:CheckInEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundleId rdf:type rdf:Property ;
    rdfs:label 'Bundle Id' ;
    rdfs:comment 'Foreign key linking to ancillary.bundle. Business justification: Fare quotes in NDC and fare-family pricing include bundled ancillaries. A fare_quote must reference the specific ancillary bundle priced to enable bundle revenue attribution, fare-family reporting, an' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Bundle .

ind:originalFareQuoteId rdf:type rdf:Property ;
    rdfs:label 'Original Fare Quote Id' ;
    rdfs:comment 'Reference to the original fare quote ID if this is a repricing. Null for original quotes.' ;
    rdfs:domain ind:FareQuote ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FareQuote .

ind:tierStatusId rdf:type rdf:Property ;
    rdfs:label 'Tier Status Id' ;
    rdfs:comment 'Foreign key linking to loyalty.tier_status. Business justification: Tier-gated pricing is a named airline revenue management process: private fares, upgrade discounts, and award booking discounts are conditioned on the passenger\'s tier. fare_quote must reference the q' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TierStatus .

ind:corporateAccountCode rdf:type rdf:Property ;
    rdfs:label 'Corporate Account Code' ;
    rdfs:comment 'Corporate discount or account code applied to this fare quote for negotiated corporate pricing.' ;
    rdfs:domain ind:FareQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fareBasisSummary rdf:type rdf:Property ;
    rdfs:label 'Fare Basis Summary' ;
    rdfs:comment 'Concatenated or summarized list of fare basis codes applied across all segments in this quote (e.g., YLOW/YLOW/MLOW). Detailed segment-level fare basis stored in related segment records.' ;
    rdfs:domain ind:FareQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fareCalculationLine rdf:type rdf:Property ;
    rdfs:label 'Fare Calculation Line' ;
    rdfs:comment 'Encoded fare construction string showing city pairs, fare basis codes, and amounts per IATA fare calculation standards. Used for ticket validation and interline proration.' ;
    rdfs:domain ind:FareQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fareQuoteNumber rdf:type rdf:Property ;
    rdfs:label 'Fare Quote Number' ;
    rdfs:comment 'Business identifier for the fare quote, typically assigned by the PSS (Passenger Service System) or GDS (Global Distribution System) at time of pricing.' ;
    rdfs:domain ind:FareQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fareQuoteStatus rdf:type rdf:Property ;
    rdfs:label 'Fare Quote Status' ;
    rdfs:comment 'Current lifecycle status of the fare quote: active (valid for ticketing), ticketed (converted to ticket), expired (past TTL), repriced (superseded by new quote), cancelled, or voided.' ;
    rdfs:domain ind:FareQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberOfPassengers rdf:type rdf:Property ;
    rdfs:label 'Number Of Passengers' ;
    rdfs:comment 'Count of passengers covered by this fare quote. Typically 1 for individual pricing, or multiple for group or family fares.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:platingCarrierCode rdf:type rdf:Property ;
    rdfs:label 'Plating Carrier Code' ;
    rdfs:comment 'Two-character IATA code of the airline whose ticket stock (plate) will be used to issue the ticket. May differ from validating carrier in interline scenarios.' ;
    rdfs:domain ind:FareQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingCommand rdf:type rdf:Property ;
    rdfs:label 'Pricing Command' ;
    rdfs:comment 'The cryptic command or API call used to generate this fare quote (e.g., FXP, WPNC, pricing modifiers). Used for audit and repricing.' ;
    rdfs:domain ind:FareQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:privateFareIndicator rdf:type rdf:Property ;
    rdfs:label 'Private Fare Indicator' ;
    rdfs:comment 'Flag indicating whether this fare quote uses a private or negotiated fare (true) versus a published public fare (false).' ;
    rdfs:domain ind:FareQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:promotionalCode rdf:type rdf:Property ;
    rdfs:label 'Promotional Code' ;
    rdfs:comment 'Promotional or discount code applied at time of pricing to obtain special fare rates.' ;
    rdfs:domain ind:FareQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repricingIndicator rdf:type rdf:Property ;
    rdfs:label 'Repricing Indicator' ;
    rdfs:comment 'Flag indicating whether this fare quote is a repricing of a previous quote (true) or an original pricing (false).' ;
    rdfs:domain ind:FareQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalSurchargeAmount rdf:type rdf:Property ;
    rdfs:label 'Total Surcharge Amount' ;
    rdfs:comment 'Sum of all carrier-imposed surcharges including YQ (fuel surcharge) and YR (carrier surcharge) codes.' ;
    rdfs:domain ind:FareQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Total Tax Amount' ;
    rdfs:comment 'Sum of all government taxes, airport fees, and regulatory charges applicable to this fare quote.' ;
    rdfs:domain ind:FareQuote ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mileageRedemptionId rdf:type rdf:Property ;
    rdfs:label 'Mileage Redemption Id' ;
    rdfs:comment 'Foreign key linking to loyalty.mileage_redemption. Business justification: Award booking copay payments reference the redemption transaction. Business process: award payment reconciliation, copay collection, refund processing for cancelled awards.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MileageRedemption .

ind:promotionId rdf:type rdf:Property ;
    rdfs:label 'Promotion Id' ;
    rdfs:comment 'Foreign key linking to loyalty.loyalty_promotion. Business justification: Promotion voucher redemption at booking payment is a named loyalty/revenue process: loyalty promotions generate voucher codes applied at payment. voucher_code is a denormalized representation of the l' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Promotion .

ind:authorizationCode rdf:type rdf:Property ;
    rdfs:label 'Authorization Code' ;
    rdfs:comment 'Authorization code returned by the payment gateway or card issuer upon successful payment authorization. Used for transaction tracking and reconciliation.' ;
    rdfs:domain ind:BookingPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Billing Address Line1' ;
    rdfs:comment 'First line of the billing address associated with the payment method. Used for payment verification and fraud prevention.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Billing Address Line2' ;
    rdfs:comment 'Second line of the billing address (apartment, suite, etc.). Optional additional address detail.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCity rdf:type rdf:Property ;
    rdfs:label 'Billing City' ;
    rdfs:comment 'City of the billing address associated with the payment method.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Billing Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code of the billing address (e.g., USA, GBR, CAN).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingPostalCode rdf:type rdf:Property ;
    rdfs:label 'Billing Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the billing address. Used for address verification and fraud prevention.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingStateProvince rdf:type rdf:Property ;
    rdfs:label 'Billing State Province' ;
    rdfs:comment 'State or province of the billing address. Format varies by country (e.g., two-letter US state codes, full province names).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardExpiryMonth rdf:type rdf:Property ;
    rdfs:label 'Card Expiry Month' ;
    rdfs:comment 'Expiration month of the payment card (1-12). Used for payment authorization and validation.' ;
    rdfs:domain ind:BookingPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cardExpiryYear rdf:type rdf:Property ;
    rdfs:label 'Card Expiry Year' ;
    rdfs:comment 'Expiration year of the payment card (four-digit year). Used for payment authorization and validation.' ;
    rdfs:domain ind:BookingPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cardType rdf:type rdf:Property ;
    rdfs:label 'Card Type' ;
    rdfs:comment 'Brand of the payment card used (e.g., Visa, Mastercard, American Express). Applicable only when payment method is credit or debit card. [ENUM-REF-CANDIDATE: visa|mastercard|amex|discover|jcb|diners|unionpay — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BookingPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardholderName rdf:type rdf:Property ;
    rdfs:label 'Cardholder Name' ;
    rdfs:comment 'Name of the cardholder as it appears on the payment card. Used for payment verification and fraud prevention.' ;
    rdfs:domain ind:BookingPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudScore rdf:type rdf:Property ;
    rdfs:label 'Fraud Score' ;
    rdfs:comment 'Fraud risk score assigned by the payment gateway or fraud detection system (typically 0-100 scale). Higher scores indicate higher fraud risk.' ;
    rdfs:domain ind:BookingPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gatewayTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Gateway Transaction Reference' ;
    rdfs:comment 'Unique transaction identifier assigned by the payment gateway or processor. Used for reconciliation, dispute resolution, and gateway-level tracking.' ;
    rdfs:domain ind:BookingPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instalmentCount rdf:type rdf:Property ;
    rdfs:label 'Instalment Count' ;
    rdfs:comment 'Total number of instalments in the payment plan. Null if not an instalment payment.' ;
    rdfs:domain ind:BookingPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:instalmentNumber rdf:type rdf:Property ;
    rdfs:label 'Instalment Number' ;
    rdfs:comment 'Current instalment number in the sequence (e.g., 1 of 3, 2 of 3). Null if not an instalment payment.' ;
    rdfs:domain ind:BookingPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:instalmentPlanFlag rdf:type rdf:Property ;
    rdfs:label 'Instalment Plan Flag' ;
    rdfs:comment 'Indicates whether this payment is part of an instalment plan. True if the payment is structured as multiple instalments, false otherwise.' ;
    rdfs:domain ind:BookingPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maskedCardNumber rdf:type rdf:Property ;
    rdfs:label 'Masked Card Number' ;
    rdfs:comment 'Masked payment card number showing only the last four digits (e.g., ****1234) for identification and customer service purposes while maintaining PCI compliance.' ;
    rdfs:domain ind:BookingPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milesRedeemedQuantity rdf:type rdf:Property ;
    rdfs:label 'Miles Redeemed Quantity' ;
    rdfs:comment 'Number of frequent flyer miles redeemed for this payment. Applicable when payment method is miles redemption.' ;
    rdfs:domain ind:BookingPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paymentAmount rdf:type rdf:Property ;
    rdfs:label 'Payment Amount' ;
    rdfs:comment 'Total monetary amount of the payment transaction in the specified currency. Represents the gross payment value before any adjustments.' ;
    rdfs:domain ind:BookingPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Payment Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the payment amount (e.g., USD, EUR, GBP). Defines the currency in which the payment was processed.' ;
    rdfs:domain ind:BookingPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentMethodType rdf:type rdf:Property ;
    rdfs:label 'Payment Method Type' ;
    rdfs:comment 'Type of payment instrument used for the transaction. Indicates the form of payment selected by the customer or agent. [ENUM-REF-CANDIDATE: credit_card|debit_card|cash|agency_account|voucher|miles_redemption|corporate_account|bank_transfer|digital_wallet — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BookingPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Reference Number' ;
    rdfs:comment 'Externally-known unique reference number for this payment transaction, used for reconciliation and customer service inquiries.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Status' ;
    rdfs:comment 'Current lifecycle status of the payment transaction. Tracks the payment from authorization through settlement or failure. [ENUM-REF-CANDIDATE: pending|authorized|captured|settled|declined|failed|refunded|partially_refunded|chargeback|voided — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Payment Timestamp' ;
    rdfs:comment 'Date and time when the payment transaction was initiated or authorized. Represents the business event time of the payment in ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX).' ;
    rdfs:domain ind:BookingPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:processorResponseCode rdf:type rdf:Property ;
    rdfs:label 'Processor Response Code' ;
    rdfs:comment 'Response code returned by the payment processor indicating the result of the transaction (e.g., approval, decline reason). Used for troubleshooting and reporting.' ;
    rdfs:domain ind:BookingPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processorResponseMessage rdf:type rdf:Property ;
    rdfs:label 'Processor Response Message' ;
    rdfs:comment 'Human-readable message from the payment processor describing the transaction result or decline reason.' ;
    rdfs:domain ind:BookingPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Settlement Timestamp' ;
    rdfs:comment 'Date and time when the payment was settled and funds were transferred. Null if payment has not yet been settled.' ;
    rdfs:domain ind:BookingPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:threeDsAuthenticationStatus rdf:type rdf:Property ;
    rdfs:label 'Three Ds Authentication Status' ;
    rdfs:comment 'Status of 3D Secure authentication for the card transaction. Indicates whether additional cardholder verification was performed to reduce fraud risk.' ;
    rdfs:domain ind:BookingPayment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ancillaryOrderId rdf:type rdf:Property ;
    rdfs:label 'Ancillary Order Id' ;
    rdfs:comment 'Foreign key linking to ancillary.ancillary_order. Business justification: Ancillary service refunds (baggage fees, seat fees, meal fees) must reference the original ancillary_order for revenue reversal and accounting. Refund processing workflows require this link to validat' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AncillaryOrder .

ind:baggageIrregularityId rdf:type rdf:Property ;
    rdfs:label 'Baggage Irregularity Id' ;
    rdfs:comment 'Foreign key linking to airport.baggage_irregularity. Business justification: Refunds may be triggered by baggage delays, loss, or damage. Compensation processing, liability tracking, and claims reconciliation require this link for financial and customer service operations.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BaggageIrregularity .

ind:mileageAccrualId rdf:type rdf:Property ;
    rdfs:label 'Mileage Accrual Id' ;
    rdfs:comment 'Foreign key linking to loyalty.mileage_accrual. Business justification: Mileage reversal on ticket refund is a distinct named process from redemption refund (already covered by mileage_redemption_id). When a flown ticket is refunded, the associated earned mileage accrual ' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MileageAccrual .

ind:feeRefundAmount rdf:type rdf:Property ;
    rdfs:label 'Fee Refund Amount' ;
    rdfs:comment 'The amount of carrier-imposed fees and surcharges being refunded.' ;
    rdfs:domain ind:RefundTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:milesRefunded rdf:type rdf:Property ;
    rdfs:label 'Miles Refunded' ;
    rdfs:comment 'Number of frequent flyer miles refunded to the passenger\'s FFP account, if refund method is miles.' ;
    rdfs:domain ind:RefundTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalFormOfPayment rdf:type rdf:Property ;
    rdfs:label 'Original Form Of Payment' ;
    rdfs:comment 'The original payment method used when the ticket or EMD was purchased. [ENUM-REF-CANDIDATE: credit_card|debit_card|cash|bank_transfer|check|voucher|miles — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:RefundTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingChannel rdf:type rdf:Property ;
    rdfs:label 'Processing Channel' ;
    rdfs:comment 'The channel through which the refund was requested and processed.' ;
    rdfs:domain ind:Reservation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Refund Approval Date' ;
    rdfs:comment 'Date when the refund was approved by the airline or authorized agent.' ;
    rdfs:domain ind:RefundTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:refundNotes rdf:type rdf:Property ;
    rdfs:label 'Refund Notes' ;
    rdfs:comment 'Free-text notes and comments regarding the refund transaction, including special circumstances or agent remarks.' ;
    rdfs:domain ind:RefundTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundProcessingDate rdf:type rdf:Property ;
    rdfs:label 'Refund Processing Date' ;
    rdfs:comment 'Date when the refund was fully processed and payment was issued or credited.' ;
    rdfs:domain ind:RefundTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:refundProcessingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Refund Processing Timestamp' ;
    rdfs:comment 'Precise timestamp when the refund processing was completed.' ;
    rdfs:domain ind:RefundTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:refundReasonCode rdf:type rdf:Property ;
    rdfs:label 'Refund Reason Code' ;
    rdfs:comment 'Standardized code indicating the business reason for the refund (e.g., schedule change, flight cancellation, passenger no-show, medical emergency, death in family, fare difference).' ;
    rdfs:domain ind:RefundTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Refund Reason Description' ;
    rdfs:comment 'Detailed textual explanation of the refund reason, providing additional context beyond the reason code.' ;
    rdfs:domain ind:RefundTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Refund Reference Number' ;
    rdfs:comment 'Unique business identifier for the refund transaction, used for customer communication and tracking.' ;
    rdfs:domain ind:RefundTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundRequestDate rdf:type rdf:Property ;
    rdfs:label 'Refund Request Date' ;
    rdfs:comment 'Date when the refund was requested by the passenger or initiated by the airline.' ;
    rdfs:domain ind:RefundTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:refundRequestTimestamp rdf:type rdf:Property ;
    rdfs:label 'Refund Request Timestamp' ;
    rdfs:comment 'Precise timestamp when the refund request was submitted or created in the system.' ;
    rdfs:domain ind:RefundTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:refundVoucherNumber rdf:type rdf:Property ;
    rdfs:label 'Refund Voucher Number' ;
    rdfs:comment 'Unique voucher number issued when refund method is voucher or credit shell, used for future travel redemption.' ;
    rdfs:domain ind:RefundTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:voucherExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Voucher Expiry Date' ;
    rdfs:comment 'Expiration date of the refund voucher or credit shell, after which it cannot be redeemed.' ;
    rdfs:domain ind:RefundTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:waiverFlag rdf:type rdf:Property ;
    rdfs:label 'Waiver Flag' ;
    rdfs:comment 'Boolean indicator whether penalty waiver was applied to this refund transaction.' ;
    rdfs:domain ind:RefundTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:travelDocumentId rdf:type rdf:Property ;
    rdfs:label 'Travel Document Id' ;
    rdfs:comment 'Primary key for travel_document' ;
    rdfs:domain ind:TravelDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:apisResponseCode rdf:type rdf:Property ;
    rdfs:label 'Apis Response Code' ;
    rdfs:comment 'Response code received from the border control authority after APIS transmission. Used to identify acceptance, rejection, or error conditions.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apisResponseMessage rdf:type rdf:Property ;
    rdfs:label 'Apis Response Message' ;
    rdfs:comment 'Detailed response message received from the border control authority after APIS transmission. Contains error details or acceptance confirmation.' ;
    rdfs:domain ind:TravelDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apisTransmissionStatus rdf:type rdf:Property ;
    rdfs:label 'Apis Transmission Status' ;
    rdfs:comment 'Status of the APIS data transmission to the destination country border control authority. Tracks whether passenger travel document data has been successfully submitted and acknowledged.' ;
    rdfs:domain ind:TravelDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apisTransmissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Apis Transmission Timestamp' ;
    rdfs:comment 'Date and time when the APIS data was transmitted to the border control authority.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:boardingEligibilityStatus rdf:type rdf:Property ;
    rdfs:label 'Boarding Eligibility Status' ;
    rdfs:comment 'Indicates whether the passenger is eligible to board based on travel document validation and APIS clearance. Used by gate agents and automated boarding systems.' ;
    rdfs:domain ind:TravelDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceValidationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Compliance Validation Timestamp' ;
    rdfs:comment 'Date and time when the travel document record was last validated for regulatory compliance.' ;
    rdfs:domain ind:TravelDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:documentExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Document Expiry Date' ;
    rdfs:comment 'Date on which the travel document expires. Critical for validating passenger eligibility for international travel and compliance with destination country entry requirements (typically 6-month validity rule).' ;
    rdfs:domain ind:TravelDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:documentIssueDate rdf:type rdf:Property ;
    rdfs:label 'Document Issue Date' ;
    rdfs:comment 'Date on which the travel document was issued by the issuing authority. Used for document validity verification.' ;
    rdfs:domain ind:TravelDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:givenNames rdf:type rdf:Property ;
    rdfs:label 'Given Names' ;
    rdfs:comment 'Given name(s) (first and middle names) of the passenger exactly as they appear on the travel document. Required for APIS and border control matching.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ineligibilityReason rdf:type rdf:Property ;
    rdfs:label 'Ineligibility Reason' ;
    rdfs:comment 'Detailed reason why the passenger is ineligible to board, if boarding_eligibility_status is ineligible. May include expired document, APIS rejection, or missing information.' ;
    rdfs:domain ind:TravelDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Issuing Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 code of the country that issued the travel document.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nationalityCode rdf:type rdf:Property ;
    rdfs:label 'Nationality Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 code representing the nationality of the passenger as stated on the travel document.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:placeOfBirth rdf:type rdf:Property ;
    rdfs:label 'Place Of Birth' ;
    rdfs:comment 'City and/or country of birth of the passenger as stated on the travel document. May be required by certain destination countries for visa and entry validation.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ssrDocsElement rdf:type rdf:Property ;
    rdfs:label 'Ssr Docs Element' ;
    rdfs:comment 'Raw SSR DOCS element string as received from the GDS or PSS. Contains structured travel document information in IATA format for APIS transmission.' ;
    rdfs:domain ind:TravelDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surname rdf:type rdf:Property ;
    rdfs:label 'Surname' ;
    rdfs:comment 'Surname (family name) of the passenger exactly as it appears on the travel document. Required for APIS and border control matching.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Verification Timestamp' ;
    rdfs:comment 'Date and time when the travel document verification was completed or last attempted.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:awbId rdf:type rdf:Property ;
    rdfs:label 'Awb Id' ;
    rdfs:comment 'Foreign key linking to cargo.awb. Business justification: Charter/group passenger movements (sports teams, military charters) generate an AWB for associated equipment cargo on the same aircraft. Group operations and load planning teams link the group booking' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Awb .

ind:bookingId rdf:type rdf:Property ;
    rdfs:label 'Booking Id' ;
    rdfs:comment 'Foreign key linking to cargo.cargo_booking. Business justification: Charter and group operations teams coordinate passenger group bookings with associated cargo bookings for the same movement (sports equipment, military gear). Weight & balance planning, revenue manage' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Booking .

ind:depositDueDate rdf:type rdf:Property ;
    rdfs:label 'Deposit Due Date' ;
    rdfs:comment 'Deadline by which the deposit payment must be received to maintain the group booking option or confirmation status.' ;
    rdfs:domain ind:GroupBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:depositReceivedFlag rdf:type rdf:Property ;
    rdfs:label 'Deposit Received Flag' ;
    rdfs:comment 'Indicator of whether the required deposit payment has been received and processed. True indicates deposit obligation fulfilled.' ;
    rdfs:domain ind:GroupBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:destinationStationCode rdf:type rdf:Property ;
    rdfs:label 'Destination Station Code' ;
    rdfs:comment 'Three-letter IATA airport code representing the primary arrival point for the group travel. Defines the ending location of the group itinerary.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupBookingStatus rdf:type rdf:Property ;
    rdfs:label 'Group Booking Status' ;
    rdfs:comment 'Current lifecycle status of the group booking indicating progression through reservation, confirmation, ticketing, and fulfillment stages.' ;
    rdfs:domain ind:GroupBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupCoordinatorEmail rdf:type rdf:Property ;
    rdfs:label 'Group Coordinator Email' ;
    rdfs:comment 'Primary email address of the group coordinator for all booking communications, updates, and documentation delivery.' ;
    rdfs:domain ind:GroupBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupCoordinatorName rdf:type rdf:Property ;
    rdfs:label 'Group Coordinator Name' ;
    rdfs:comment 'Full name of the primary contact person responsible for coordinating the group booking on behalf of the organizing entity.' ;
    rdfs:domain ind:GroupBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupCoordinatorPhone rdf:type rdf:Property ;
    rdfs:label 'Group Coordinator Phone' ;
    rdfs:comment 'Primary contact phone number for the group coordinator. Used for urgent communications and operational coordination.' ;
    rdfs:domain ind:GroupBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingAirlineCode rdf:type rdf:Property ;
    rdfs:label 'Marketing Airline Code' ;
    rdfs:comment 'IATA or ICAO airline code of the carrier marketing and selling the group booking. May differ from operating carrier in codeshare scenarios.' ;
    rdfs:domain ind:GroupBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nameListDeadline rdf:type rdf:Property ;
    rdfs:label 'Name List Deadline' ;
    rdfs:comment 'Deadline by which the complete passenger name list must be submitted to the airline. Critical for inventory management and seat release policies.' ;
    rdfs:domain ind:GroupBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:negotiatedFareAmount rdf:type rdf:Property ;
    rdfs:label 'Negotiated Fare Amount' ;
    rdfs:comment 'Contracted fare amount per passenger for the group booking. Represents the negotiated rate agreed between the airline and group organizer.' ;
    rdfs:domain ind:GroupBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pnrLocatorList rdf:type rdf:Property ;
    rdfs:label 'Pnr Locator List' ;
    rdfs:comment 'Comma-separated list of PNR record locators associated with individual passenger bookings within this group. Links group master record to individual reservations.' ;
    rdfs:domain ind:GroupBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seatsNamed rdf:type rdf:Property ;
    rdfs:label 'Seats Named' ;
    rdfs:comment 'Number of seats for which passenger names have been provided and assigned. Tracks name list completion progress against contracted seats.' ;
    rdfs:domain ind:GroupBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:specialServiceRequirements rdf:type rdf:Property ;
    rdfs:label 'Special Service Requirements' ;
    rdfs:comment 'Consolidated list of special service requests applicable to the group, such as meal preferences, accessibility needs, or equipment requirements.' ;
    rdfs:domain ind:GroupBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalSeatsContracted rdf:type rdf:Property ;
    rdfs:label 'Total Seats Contracted' ;
    rdfs:comment 'Total number of seats allocated and contracted for the group booking. Represents the inventory commitment made by the airline to the group organizer.' ;
    rdfs:domain ind:GroupBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:airworthinessDirectiveId rdf:type rdf:Property ;
    rdfs:label 'Airworthiness Directive Id' ;
    rdfs:comment 'Foreign key linking to maintenance.airworthiness_directive. Business justification: work_order.ad_reference is a denormalized STRING reference to an Airworthiness Directive. Replacing with a proper FK to maintenance.airworthiness_directive normalizes the relationship, enables referen' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AirworthinessDirective .

ind:approvedMaintenanceOrgId rdf:type rdf:Property ;
    rdfs:label 'Approved Maintenance Org Id' ;
    rdfs:comment 'Reference to the AMO (Approved Maintenance Organisation) or Part-145 certified organization performing the work. Links to the maintenance organization master record.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ApprovedMaintenanceOrg .

ind:engineId rdf:type rdf:Property ;
    rdfs:label 'Engine Id' ;
    rdfs:comment 'Foreign key linking to fleet.engine. Business justification: Engine shop visit work orders must reference the specific fleet engine asset to update TSN/CSN, last shop visit date, LLP status, and power-by-hour contract tracking. Engine asset management is a core' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Engine .

ind:melItemId rdf:type rdf:Property ;
    rdfs:label 'Mel Item Id' ;
    rdfs:comment 'Foreign key linking to maintenance.mel_item. Business justification: work_order.mel_reference is a denormalized STRING reference to a MEL item. Replacing with a proper FK to maintenance.mel_item normalizes the relationship. No reverse FK from mel_item to work_order exi' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MelItem .

ind:mitigatingHazardId rdf:type rdf:Property ;
    rdfs:label 'Mitigating Hazard Id' ;
    rdfs:comment 'Foreign key linking to safety.hazard. Business justification: Work orders may be generated to mitigate identified hazards (e.g., proactive modification to address known risk). Link tracks hazard control implementation, supports SMS hazard register closure, and d' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Hazard .

ind:programId rdf:type rdf:Property ;
    rdfs:label 'Program Id' ;
    rdfs:comment 'Foreign key linking to maintenance.program. Business justification: A work order is frequently generated from an approved Aircraft Maintenance Program (AMP). Linking work_order to program enables traceability from scheduled maintenance tasks back to the governing prog' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Program .

ind:serviceBulletinId rdf:type rdf:Property ;
    rdfs:label 'Service Bulletin Id' ;
    rdfs:comment 'Foreign key linking to maintenance.service_bulletin. Business justification: work_order.sb_reference is a denormalized STRING reference to a Service Bulletin. Replacing with a proper FK to maintenance.service_bulletin normalizes the relationship and enables referential integri' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ServiceBulletin .

ind:turnaroundId rdf:type rdf:Property ;
    rdfs:label 'Turnaround Id' ;
    rdfs:comment 'Foreign key linking to airport.turnaround. Business justification: Line maintenance work orders raised during aircraft turnarounds must reference the turnaround for delay code attribution, OTP reporting, and ground operations coordination. Aviation operations experts' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Turnaround .

ind:uldId rdf:type rdf:Property ;
    rdfs:label 'Uld Id' ;
    rdfs:comment 'Foreign key linking to cargo.uld. Business justification: Line maintenance raises work orders specifically for ULD repair and inspection (damage, structural integrity). Aviation MRO operations routinely track which ULD a work order addresses. No existing col' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Uld .

ind:actualCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Timestamp' ;
    rdfs:comment 'Actual date and time when maintenance work was completed and aircraft returned to service. Used for turnaround time analysis and maintenance efficiency metrics.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualLaborCost rdf:type rdf:Property ;
    rdfs:label 'Actual Labor Cost' ;
    rdfs:comment 'Actual labor cost incurred for the work order in the airlines reporting currency, calculated from actual man-hours and labor rates. Used for cost accounting and variance analysis.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualManHours rdf:type rdf:Property ;
    rdfs:label 'Actual Man Hours' ;
    rdfs:comment 'Actual labor hours expended on the work order, aggregated from technician time entries. Used for cost accounting, efficiency analysis, and maintenance program refinement.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualMaterialCost rdf:type rdf:Property ;
    rdfs:label 'Actual Material Cost' ;
    rdfs:comment 'Actual material and parts cost incurred for the work order in the airlines reporting currency, aggregated from material requisitions and component removals. Used for cost accounting and inventory valuation.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Start Timestamp' ;
    rdfs:comment 'Actual date and time when maintenance work commenced. Used for schedule adherence tracking and labor cost allocation.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:aogFlag rdf:type rdf:Property ;
    rdfs:label 'Aog Flag' ;
    rdfs:comment 'Boolean indicator whether this work order is an AOG (Aircraft on Ground) event requiring critical priority and expedited parts/labor. True indicates aircraft is grounded and out of service; false indicates aircraft is serviceable or work is scheduled.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ataChapterCode rdf:type rdf:Property ;
    rdfs:label 'Ata Chapter Code' ;
    rdfs:comment 'ATA 100 system chapter code identifying the aircraft system or component this work order addresses. Format is two-digit chapter, optional two-digit section, optional two-digit subject (e.g., 32 for Landing Gear, 32-41 for Wheels and Brakes).' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveAction rdf:type rdf:Property ;
    rdfs:label 'Corrective Action' ;
    rdfs:comment 'Free-text description of the maintenance action performed to rectify the defect or complete the scheduled task. Includes reference to maintenance manual procedures, parts replaced, and tests performed.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crsReference rdf:type rdf:Property ;
    rdfs:label 'Crs Reference' ;
    rdfs:comment 'Reference number of the Certificate of Release to Service issued upon work order completion. Required for airworthiness compliance and regulatory audit trail.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectDescription rdf:type rdf:Property ;
    rdfs:label 'Defect Description' ;
    rdfs:comment 'Free-text description of the defect, discrepancy, or maintenance requirement that triggered this work order. Captured from pilot reports, engineer inspections, or system alerts. May reference ATA chapter codes.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deferralExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Deferral Expiry Date' ;
    rdfs:comment 'Date by which a deferred work order (MEL deferral) must be completed to maintain airworthiness compliance. Null if work order is not deferred. Used for compliance tracking and maintenance planning.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:downtimeHours rdf:type rdf:Property ;
    rdfs:label 'Downtime Hours' ;
    rdfs:comment 'Total aircraft out-of-service hours from work order start to completion. Used for aircraft utilization analysis and maintenance efficiency metrics. Calculated as the difference between actual start and actual completion timestamps.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedLaborCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Labor Cost' ;
    rdfs:comment 'Planned labor cost for the work order in the airlines reporting currency, calculated from estimated man-hours and labor rates. Used for budgeting and cost forecasting.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedManHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Man Hours' ;
    rdfs:comment 'Planned labor hours required to complete the work order, based on maintenance program standards or engineering estimates. Used for resource planning and cost estimation.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:estimatedMaterialCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Material Cost' ;
    rdfs:comment 'Planned material and parts cost for the work order in the airlines reporting currency. Includes consumables, rotables, and expendables. Used for budgeting and inventory planning.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maintenanceCheckType rdf:type rdf:Property ;
    rdfs:label 'Maintenance Check Type' ;
    rdfs:comment 'The maintenance program check interval or package this work order belongs to. A-check through D-check represent increasing scope and interval; daily/weekly/transit are operational checks; line maintenance is performed at the gate; base maintenance is performed in hangar; component maintenance is off-wing shop work. [ENUM-REF-CANDIDATE: a_check|b_check|c_check|d_check|daily|weekly|transit|line|base|component — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originatingSource rdf:type rdf:Property ;
    rdfs:label 'Originating Source' ;
    rdfs:comment 'The trigger or authority that initiated this work order. AD (Airworthiness Directive) indicates mandatory regulatory action; SB (Service Bulletin) indicates manufacturer recommendation; MEL indicates deferred defect; defect indicates pilot or engineer report; interval indicates scheduled maintenance program; modification indicates design change; inspection indicates regulatory or operational audit. [ENUM-REF-CANDIDATE: ad|sb|mel|defect|interval|modification|inspection — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:part145ApprovalReference rdf:type rdf:Property ;
    rdfs:label 'Part 145 Approval Reference' ;
    rdfs:comment 'Reference to the Part-145 maintenance organisation approval certificate number under which this work was performed. Required for regulatory compliance and airworthiness release.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Completion Timestamp' ;
    rdfs:comment 'Planned date and time when maintenance work is scheduled to be completed. Used for aircraft return-to-service planning and slot management.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Timestamp' ;
    rdfs:comment 'Planned date and time when maintenance work is scheduled to begin. Used for resource planning and aircraft availability forecasting.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:signOffTimestamp rdf:type rdf:Property ;
    rdfs:label 'Sign Off Timestamp' ;
    rdfs:comment 'Date and time when the certifying engineer signed off the work order and issued the Certificate of Release to Service (CRS). Marks the official completion and airworthiness release.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:workOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Work Order Number' ;
    rdfs:comment 'Externally-known business identifier for the work order, typically formatted as WO followed by numeric sequence. Used for cross-system reference and operator communication.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workOrderStatus rdf:type rdf:Property ;
    rdfs:label 'Work Order Status' ;
    rdfs:comment 'Current lifecycle state of the work order. Open indicates work is scheduled but not started; in-progress indicates active execution; deferred indicates MEL (Minimum Equipment List) deferral or resource constraint; completed indicates work finished pending sign-off; closed indicates final approval and record closure; cancelled indicates work order voided.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workOrderType rdf:type rdf:Property ;
    rdfs:label 'Work Order Type' ;
    rdfs:comment 'Classification of the work order by maintenance category. Scheduled includes routine checks and intervals; unscheduled covers reactive maintenance; AOG (Aircraft on Ground) indicates critical grounding events; modification covers STC (Supplemental Type Certificate) and design changes; inspection includes regulatory and operational checks; defect rectification addresses reported discrepancies.' ;
    rdfs:domain ind:WorkOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:workOrderTaskId rdf:type rdf:Property ;
    rdfs:label 'Work Order Task Id' ;
    rdfs:comment 'Unique identifier for the work order task line item. Primary key.' ;
    rdfs:domain ind:WorkOrderTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:addressingAuditFindingId rdf:type rdf:Property ;
    rdfs:label 'Addressing Audit Finding Id' ;
    rdfs:comment 'Foreign key linking to safety.audit_finding. Business justification: Specific tasks within a work order may be added to address individual audit findings (e.g., an audit finding about a specific inspection technique requiring a dedicated task). Task-level audit finding' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AuditFinding .

ind:componentId rdf:type rdf:Property ;
    rdfs:label 'Component Id' ;
    rdfs:comment 'Foreign key linking to maintenance.component. Business justification: Work order task may involve a specific component. The work_order_task table has component_part_number and component_serial_number but no FK. Adding component_id FK normalizes this and removes redundan' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Component .

ind:crewTechnicianCrewMemberId rdf:type rdf:Property ;
    rdfs:label 'Crew Technician Crew Member Id' ;
    rdfs:comment 'Foreign key linking to crew.crew_member. Business justification: Dual-role crew members (pilot-engineers, flight engineers with A&P) perform line maintenance tasks. Business process: dual-role workforce utilization tracking, labor cost allocation, regulatory compli' ;
    rdfs:domain ind:WorkOrderTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Member .

ind:defectReportId rdf:type rdf:Property ;
    rdfs:label 'Defect Report Id' ;
    rdfs:comment 'Reference to the originating defect or discrepancy record that triggered this corrective maintenance task. Links unscheduled maintenance to reported defects.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DefectReport .

ind:identifiedHazardId rdf:type rdf:Property ;
    rdfs:label 'Identified Hazard Id' ;
    rdfs:comment 'Foreign key linking to safety.hazard. Business justification: Individual work order tasks may identify or mitigate specific hazards distinct from the parent work_order\'s hazard (e.g., a task discovers a new hazard during execution). SMS-integrated maintenance re' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Hazard .

ind:implementingCorrectiveActionId rdf:type rdf:Property ;
    rdfs:label 'Implementing Corrective Action Id' ;
    rdfs:comment 'Foreign key linking to safety.corrective_action. Business justification: Individual tasks may fulfill specific corrective actions (granular implementation tracking). Enables task-level verification of corrective action completion for audit compliance, supports detailed eff' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CorrectiveAction .

ind:melDeferralId rdf:type rdf:Property ;
    rdfs:label 'Mel Deferral Id' ;
    rdfs:comment 'Foreign key linking to maintenance.mel_deferral. Business justification: Work order task may be related to a MEL deferral. The work_order_task table has mel_reference (STRING) but no FK. Adding mel_deferral_id FK normalizes this and removes redundant mel_reference.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MelDeferral .

ind:originatingOccurrenceId rdf:type rdf:Property ;
    rdfs:label 'Originating Occurrence Id' ;
    rdfs:comment 'Foreign key linking to safety.occurrence. Business justification: Individual maintenance tasks may be tied to specific safety events requiring rectification (e.g., post-incident inspection tasks). Enables granular tracking of occurrence-driven maintenance actions fo' ;
    rdfs:domain ind:WorkOrderTask ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Occurrence .

ind:actualLaborHours rdf:type rdf:Property ;
    rdfs:label 'Actual Labor Hours' ;
    rdfs:comment 'Actual labor hours expended to complete this task, captured for cost accounting, productivity analysis, and future task planning.' ;
    rdfs:domain ind:WorkOrderTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ataChapter rdf:type rdf:Property ;
    rdfs:label 'Ata Chapter' ;
    rdfs:comment 'Two-digit ATA chapter code identifying the aircraft system category (e.g., 32=Landing Gear, 71=Power Plant, 24=Electrical Power). Standard aircraft system classification.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ataSection rdf:type rdf:Property ;
    rdfs:label 'Ata Section' ;
    rdfs:comment 'ATA section code providing finer granularity within the ATA chapter, identifying the specific subsystem or component area.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deferralFlag rdf:type rdf:Property ;
    rdfs:label 'Deferral Flag' ;
    rdfs:comment 'Boolean indicator whether this task has been deferred under MEL or other approved deferral provisions. True indicates the task is deferred and must be tracked for completion within allowable limits.' ;
    rdfs:domain ind:WorkOrderTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedLaborHours rdf:type rdf:Property ;
    rdfs:label 'Estimated Labor Hours' ;
    rdfs:comment 'Planned or standard labor hours required to complete this task, used for work planning, scheduling, and cost estimation.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:inspectorLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Inspector License Number' ;
    rdfs:comment 'The Part-66 or equivalent aircraft maintenance license number of the inspector who verified the task, required for regulatory traceability and airworthiness certification.' ;
    rdfs:domain ind:WorkOrderTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectorSignoffTimestamp rdf:type rdf:Property ;
    rdfs:label 'Inspector Signoff Timestamp' ;
    rdfs:comment 'Date and time when the inspector signed off the task verification, certifying that the work meets airworthiness standards and approved procedures.' ;
    rdfs:domain ind:WorkOrderTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:installedComponentSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Installed Component Serial Number' ;
    rdfs:comment 'Serial number of the component installed during a replacement task, required for aircraft configuration control and life-limited parts tracking.' ;
    rdfs:domain ind:WorkOrderTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:materialsCostAmount rdf:type rdf:Property ;
    rdfs:label 'Materials Cost Amount' ;
    rdfs:comment 'Total cost of materials, parts, and consumables used in this task, captured for maintenance cost accounting and budget tracking.' ;
    rdfs:domain ind:WorkOrderTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:removedComponentSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Removed Component Serial Number' ;
    rdfs:comment 'Serial number of the component removed during a replacement task, required for component tracking, warranty claims, and rotable pool management.' ;
    rdfs:domain ind:WorkOrderTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:skillTradeRequired rdf:type rdf:Property ;
    rdfs:label 'Skill Trade Required' ;
    rdfs:comment 'The specialized maintenance trade or skill category required to perform this task (avionics, airframe, powerplant, electrical, hydraulic, composite). Determines technician assignment and certification requirements.' ;
    rdfs:domain ind:WorkOrderTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskCardReference rdf:type rdf:Property ;
    rdfs:label 'Task Card Reference' ;
    rdfs:comment 'Reference number or code of the maintenance task card, job card, or work instruction document that defines this task. Links to approved maintenance procedures.' ;
    rdfs:domain ind:WorkOrderTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskCompletionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Task Completion Timestamp' ;
    rdfs:comment 'Date and time when this task was completed and signed off, marking the end of work and enabling aircraft return-to-service processing.' ;
    rdfs:domain ind:WorkOrderTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:taskDescription rdf:type rdf:Property ;
    rdfs:label 'Task Description' ;
    rdfs:comment 'Detailed narrative description of the maintenance action, inspection step, or repair work to be performed. Includes scope, method, and acceptance criteria.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskNotes rdf:type rdf:Property ;
    rdfs:label 'Task Notes' ;
    rdfs:comment 'Free-text field for technician notes, observations, findings, or special instructions related to this task. Captures important context not covered by structured fields.' ;
    rdfs:domain ind:WorkOrderTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskPriority rdf:type rdf:Property ;
    rdfs:label 'Task Priority' ;
    rdfs:comment 'Priority level assigned to this task for scheduling and resource allocation: critical (AOG/safety), high (operational impact), medium (scheduled), low (routine).' ;
    rdfs:domain ind:WorkOrderTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Task Sequence Number' ;
    rdfs:comment 'Sequential ordering of this task within the parent work order, used to control execution sequence and dependencies.' ;
    rdfs:domain ind:WorkOrderTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:taskStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Task Start Timestamp' ;
    rdfs:comment 'Date and time when work on this task was initiated, used for labor tracking, downtime analysis, and task duration measurement.' ;
    rdfs:domain ind:WorkOrderTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:taskStatus rdf:type rdf:Property ;
    rdfs:label 'Task Status' ;
    rdfs:comment 'Current lifecycle status of the task: open (not started), in_progress (work underway), completed (finished and signed off), deferred (postponed under MEL), cancelled (no longer required).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taskType rdf:type rdf:Property ;
    rdfs:label 'Task Type' ;
    rdfs:comment 'Classification of the maintenance task type indicating the nature of work: inspection (visual/NDT), repair (corrective action), replacement (component swap), modification (SB/AD compliance), lubrication, or servicing.' ;
    rdfs:domain ind:WorkOrderTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicianLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Technician License Number' ;
    rdfs:comment 'The Part-66 or equivalent aircraft maintenance license number of the technician who performed the task, required for regulatory traceability and certification compliance.' ;
    rdfs:domain ind:WorkOrderTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicianSignoffTimestamp rdf:type rdf:Property ;
    rdfs:label 'Technician Signoff Timestamp' ;
    rdfs:comment 'Date and time when the technician signed off the completed task, certifying that the work was performed in accordance with approved data and procedures.' ;
    rdfs:domain ind:WorkOrderTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:workLocation rdf:type rdf:Property ;
    rdfs:label 'Work Location' ;
    rdfs:comment 'Physical location where the task is performed: hangar (heavy maintenance), line (gate/ramp), shop (component workshop), vendor (external MRO facility).' ;
    rdfs:domain ind:WorkOrderTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskAssessmentId rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Id' ;
    rdfs:comment 'Foreign key linking to safety.risk_assessment. Business justification: MSG-3 maintenance programs are developed and revised based on safety risk assessments. CAMO and SMS managers require traceability from a program to the risk_assessment that justified its intervals or ' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RiskAssessment .

ind:aocNumber rdf:type rdf:Property ;
    rdfs:label 'Aoc Number' ;
    rdfs:comment 'Air Operator Certificate number under which this maintenance program is approved and operated.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalReference rdf:type rdf:Property ;
    rdfs:label 'Approval Reference' ;
    rdfs:comment 'Official reference number or certificate identifier issued by the regulatory authority approving this maintenance program.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:camoOrganization rdf:type rdf:Property ;
    rdfs:label 'Camo Organization' ;
    rdfs:comment 'Name or identifier of the EASA Part-M Subpart G CAMO responsible for managing the continuing airworthiness under this program.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivityConfiguration rdf:type rdf:Property ;
    rdfs:label 'Effectivity Configuration' ;
    rdfs:comment 'Specific aircraft configuration, modification state, or service bulletin incorporation status defining the applicability of this maintenance program.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivitySerialNumbers rdf:type rdf:Property ;
    rdfs:label 'Effectivity Serial Numbers' ;
    rdfs:comment 'Comma-separated list or range of aircraft manufacturer serial numbers (MSN) to which this maintenance program applies. Null for type-level programs applicable to all aircraft of the type.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationApprovalReference rdf:type rdf:Property ;
    rdfs:label 'Escalation Approval Reference' ;
    rdfs:comment 'Regulatory approval reference for any interval escalation applied to this maintenance program. Null if no escalation.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationFactor rdf:type rdf:Property ;
    rdfs:label 'Escalation Factor' ;
    rdfs:comment 'Multiplier applied to maintenance intervals for escalation purposes (e.g., 1.05 for 5% escalation). Null if no escalation is approved.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:intervalStructure rdf:type rdf:Property ;
    rdfs:label 'Interval Structure' ;
    rdfs:comment 'Primary interval structure used by this maintenance program to schedule tasks: flight hours (FH), flight cycles (FC), calendar days (DY), or combined thresholds.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:melReference rdf:type rdf:Property ;
    rdfs:label 'Mel Reference' ;
    rdfs:comment 'Reference to the approved Minimum Equipment List (MEL) document associated with this maintenance program, defining permissible equipment deferrals.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:modifiedBy rdf:type rdf:Property ;
    rdfs:label 'Modified By' ;
    rdfs:comment 'User identifier or name of the person who last modified this maintenance program record.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mpdBaseline rdf:type rdf:Property ;
    rdfs:label 'Mpd Baseline' ;
    rdfs:comment 'Manufacturer\'s Maintenance Planning Document (MPD) baseline version or revision that forms the foundation of this approved maintenance program (e.g., \'Boeing D622W001 Rev 45\', \'Airbus A320 MPD Rev 38\').' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatorName rdf:type rdf:Property ;
    rdfs:label 'Operator Name' ;
    rdfs:comment 'Legal name of the airline or aircraft operator to whom this maintenance program is issued and approved.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programDescription rdf:type rdf:Property ;
    rdfs:label 'Program Description' ;
    rdfs:comment 'Detailed textual description of the maintenance program scope, objectives, and key features.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programName rdf:type rdf:Property ;
    rdfs:label 'Program Name' ;
    rdfs:comment 'Business-friendly name or title of the maintenance program (e.g., \'B737-800 AMP Rev 12\', \'A320 Family Maintenance Program\').' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programStatus rdf:type rdf:Property ;
    rdfs:label 'Program Status' ;
    rdfs:comment 'Current lifecycle status of the maintenance program indicating its regulatory and operational state. [ENUM-REF-CANDIDATE: draft|pending_approval|approved|active|superseded|withdrawn|archived — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programType rdf:type rdf:Property ;
    rdfs:label 'Program Type' ;
    rdfs:comment 'Classification of the maintenance program: AMP (Aircraft Maintenance Program), CMP (Component Maintenance Program), EMP (Engine Maintenance Program), sampling program, MSG-3 based, or other.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reliabilityProgramReference rdf:type rdf:Property ;
    rdfs:label 'Reliability Program Reference' ;
    rdfs:comment 'Reference to the associated aircraft reliability program or monitoring system that feeds data into maintenance program adjustments.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revision rdf:type rdf:Property ;
    rdfs:label 'Revision' ;
    rdfs:comment 'Revision or version identifier of the maintenance program as approved by the regulatory authority (e.g., \'Rev 12\', \'2023-01\', \'V3.5\').' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdBy rdf:type rdf:Property ;
    rdfs:label 'Created By' ;
    rdfs:comment 'User identifier or name of the person who created this maintenance program record.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkId rdf:type rdf:Property ;
    rdfs:label 'Check Id' ;
    rdfs:comment 'Primary key for check' ;
    rdfs:domain ind:Check ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:aircraftLeaseId rdf:type rdf:Property ;
    rdfs:label 'Aircraft Lease Id' ;
    rdfs:comment 'Foreign key linking to fleet.aircraft_lease. Business justification: Pre-redelivery and lease-return checks are contractually mandated by the aircraft lease agreement — the check must reference the specific lease to verify return condition compliance (max cycles/hours,' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AircraftLease .

ind:complianceAlertId rdf:type rdf:Property ;
    rdfs:label 'Compliance Alert Id' ;
    rdfs:comment 'Foreign key linking to safety.alert. Business justification: A safety alert (EASA SIB, airworthiness alert) can trigger a maintenance check as the required compliance action. Linking check to alert at the planning level is a real regulatory compliance tracking ' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Alert .

ind:maintenanceProgramId rdf:type rdf:Property ;
    rdfs:label 'Maintenance Program Id' ;
    rdfs:comment 'Reference to the overarching maintenance program that defines the schedule and requirements for this check type. Links to the regulatory-approved maintenance plan.' ;
    rdfs:domain ind:Check ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Program .

ind:maintenanceStationId rdf:type rdf:Property ;
    rdfs:label 'Maintenance Station Id' ;
    rdfs:comment 'Foreign key linking to airport.station. Business justification: Maintenance checks (A/C/D checks) performed at specific stations. Links maintenance_station_code to station.station_id for hangar capacity planning, check performance tracking by location, and regulat' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Station .

ind:triggeringOccurrenceId rdf:type rdf:Property ;
    rdfs:label 'Triggering Occurrence Id' ;
    rdfs:comment 'Foreign key linking to safety.occurrence. Business justification: Major maintenance checks may be triggered by safety occurrences (e.g., heavy landing requiring special inspection). Links unscheduled checks to causal events for fleet-wide risk assessment and regulat' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Occurrence .

ind:actualInductionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Induction Date' ;
    rdfs:comment 'The actual date when the aircraft entered the maintenance facility and work commenced. May differ from scheduled date due to operational constraints.' ;
    rdfs:domain ind:Check ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Actual Release Date' ;
    rdfs:comment 'The actual date when the aircraft was certified airworthy and released back to operational service after completion of the maintenance check.' ;
    rdfs:domain ind:Check ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:airworthinessDirectivesComplied rdf:type rdf:Property ;
    rdfs:label 'Airworthiness Directives Complied' ;
    rdfs:comment 'The number of mandatory Airworthiness Directives (ADs) complied with during this maintenance check. ADs are legally enforceable safety regulations issued by aviation authorities.' ;
    rdfs:domain ind:Check ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:aogEventFlag rdf:type rdf:Property ;
    rdfs:label 'Aog Event Flag' ;
    rdfs:comment 'Boolean indicator of whether this maintenance check was triggered by or resulted in an Aircraft on Ground event, indicating unscheduled downtime with high operational impact.' ;
    rdfs:domain ind:Check ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:checkStatus rdf:type rdf:Property ;
    rdfs:label 'Check Status' ;
    rdfs:comment 'Current lifecycle status of the maintenance check event. Tracks progression from planning through execution to completion or cancellation.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkType rdf:type rdf:Property ;
    rdfs:label 'Check Type' ;
    rdfs:comment 'The category of scheduled maintenance check being performed. A-checks are light, frequent inspections; D-checks are heavy overhauls requiring aircraft disassembly.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Completion Timestamp' ;
    rdfs:comment 'The precise date and time when all maintenance tasks were completed and the aircraft was certified for return to service. Used for audit trail and performance tracking.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:costCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Cost Currency Code' ;
    rdfs:comment 'The three-letter ISO 4217 currency code for the total cost amount. Airlines operate globally and may incur maintenance costs in multiple currencies.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectsFoundCount rdf:type rdf:Property ;
    rdfs:label 'Defects Found Count' ;
    rdfs:comment 'The total number of defects, discrepancies, or non-conformities identified during execution of this maintenance check. Used for quality and reliability analysis.' ;
    rdfs:domain ind:Check ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:downtimeDays rdf:type rdf:Property ;
    rdfs:label 'Downtime Days' ;
    rdfs:comment 'The total number of days the aircraft was out of service for this maintenance check, calculated from induction to release. Critical for fleet utilization metrics.' ;
    rdfs:domain ind:Check ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dueFlightCycles rdf:type rdf:Property ;
    rdfs:label 'Due Flight Cycles' ;
    rdfs:comment 'The cumulative aircraft flight cycles (takeoff-landing pairs) at which this maintenance check is due. Critical for structural fatigue monitoring.' ;
    rdfs:domain ind:Check ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dueFlightHours rdf:type rdf:Property ;
    rdfs:label 'Due Flight Hours' ;
    rdfs:comment 'The cumulative aircraft flight hours at which this maintenance check is due. One of three interval metrics (hours, cycles, calendar) used to trigger maintenance.' ;
    rdfs:domain ind:Check ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:intervalDays rdf:type rdf:Property ;
    rdfs:label 'Interval Days' ;
    rdfs:comment 'The calendar day interval between occurrences of this check type as defined in the maintenance program. For example, A-checks typically occur every 500-800 flight hours or 200-300 cycles or 60-90 days, whichever comes first.' ;
    rdfs:domain ind:Check ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:intervalFlightCycles rdf:type rdf:Property ;
    rdfs:label 'Interval Flight Cycles' ;
    rdfs:comment 'The flight cycle interval between occurrences of this check type as defined in the maintenance program.' ;
    rdfs:domain ind:Check ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:intervalFlightHours rdf:type rdf:Property ;
    rdfs:label 'Interval Flight Hours' ;
    rdfs:comment 'The flight hour interval between occurrences of this check type as defined in the maintenance program.' ;
    rdfs:domain ind:Check ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:melDeferralsCount rdf:type rdf:Property ;
    rdfs:label 'Mel Deferrals Count' ;
    rdfs:comment 'The number of defects deferred under Minimum Equipment List provisions during this check, allowing aircraft return to service with specific inoperative equipment.' ;
    rdfs:domain ind:Check ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Due Date' ;
    rdfs:comment 'The projected calendar date when the next occurrence of this check type will be due, calculated from completion date plus maintenance interval.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextDueFlightCycles rdf:type rdf:Property ;
    rdfs:label 'Next Due Flight Cycles' ;
    rdfs:comment 'The projected cumulative aircraft flight cycles at which the next occurrence of this check type will be due.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextDueFlightHours rdf:type rdf:Property ;
    rdfs:label 'Next Due Flight Hours' ;
    rdfs:comment 'The projected cumulative aircraft flight hours at which the next occurrence of this check type will be due.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedManHours rdf:type rdf:Property ;
    rdfs:label 'Planned Man Hours' ;
    rdfs:comment 'The estimated total labor hours required to complete this maintenance check, used for resource planning and cost estimation.' ;
    rdfs:domain ind:Check ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:releaseCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Release Certificate Number' ;
    rdfs:comment 'The unique identifier of the Certificate of Release to Service issued upon completion of this maintenance check, certifying the aircraft is airworthy.' ;
    rdfs:domain ind:Check ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledInductionDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Induction Date' ;
    rdfs:comment 'The planned date when the aircraft will enter the maintenance facility to begin this check. Used for capacity planning and aircraft rotation scheduling.' ;
    rdfs:domain ind:Check ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:scheduledReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Release Date' ;
    rdfs:comment 'The planned date when the aircraft is expected to be released back to service after completion of the maintenance check.' ;
    rdfs:domain ind:Check ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:serviceBulletinsIncorporated rdf:type rdf:Property ;
    rdfs:label 'Service Bulletins Incorporated' ;
    rdfs:comment 'The number of manufacturer service bulletins (recommended but not mandatory modifications or inspections) incorporated during this maintenance check.' ;
    rdfs:domain ind:Check ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adNumber rdf:type rdf:Property ;
    rdfs:label 'Ad Number' ;
    rdfs:comment 'Official AD number issued by the regulatory authority (e.g., FAA AD 2023-12-05, EASA AD 2023-0145). Unique identifier assigned by the issuing authority.' ;
    rdfs:domain ind:AirworthinessDirective ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adStatus rdf:type rdf:Property ;
    rdfs:label 'Ad Status' ;
    rdfs:comment 'Current lifecycle status of the AD. Active=currently enforceable, Superseded=replaced by newer AD, Cancelled=no longer applicable, Proposed=under review, Interim=temporary emergency AD.' ;
    rdfs:domain ind:AirworthinessDirective ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:airworthinessDirectiveDescription rdf:type rdf:Property ;
    rdfs:label 'Airworthiness Directive Description' ;
    rdfs:comment 'Detailed description of the unsafe condition, the corrective action required, and the rationale for the airworthiness directive.' ;
    rdfs:domain ind:AirworthinessDirective ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alternativeComplianceMethod rdf:type rdf:Property ;
    rdfs:label 'Alternative Compliance Method' ;
    rdfs:comment 'Description of approved Alternative Methods of Compliance (AMOC) that may be used in lieu of the prescribed action, if permitted by the issuing authority.' ;
    rdfs:domain ind:AirworthinessDirective ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicability rdf:type rdf:Property ;
    rdfs:label 'Applicability' ;
    rdfs:comment 'Defines which aircraft, engines, propellers, or components are affected by this AD. Includes aircraft type, model, serial number ranges, and part numbers.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceIntervalUnit rdf:type rdf:Property ;
    rdfs:label 'Compliance Interval Unit' ;
    rdfs:comment 'Unit of measure for repetitive compliance interval. FH=Flight Hours, FC=Flight Cycles, days/months/years=calendar time. Null for one-time ADs.' ;
    rdfs:domain ind:AirworthinessDirective ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceIntervalValue rdf:type rdf:Property ;
    rdfs:label 'Compliance Interval Value' ;
    rdfs:comment 'Numeric interval value for repetitive compliance actions (e.g., repeat inspection every 1000 flight hours). Null for one-time ADs.' ;
    rdfs:domain ind:AirworthinessDirective ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceMethod rdf:type rdf:Property ;
    rdfs:label 'Compliance Method' ;
    rdfs:comment 'Type of compliance action required. One-time=single inspection or action, Repetitive=recurring inspections at intervals, Terminating=final action that eliminates need for repetitive compliance.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceThresholdUnit rdf:type rdf:Property ;
    rdfs:label 'Compliance Threshold Unit' ;
    rdfs:comment 'Unit of measure for compliance threshold. FH=Flight Hours, FC=Flight Cycles, days/months/years=calendar time.' ;
    rdfs:domain ind:AirworthinessDirective ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceThresholdValue rdf:type rdf:Property ;
    rdfs:label 'Compliance Threshold Value' ;
    rdfs:comment 'Numeric threshold value at which initial compliance action must be performed (e.g., 5000 flight hours, 2500 flight cycles, 180 calendar days).' ;
    rdfs:domain ind:AirworthinessDirective ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:componentType rdf:type rdf:Property ;
    rdfs:label 'Component Type' ;
    rdfs:comment 'Category of component affected by the AD. Airframe=aircraft structure, Engine=propulsion system, Propeller=propeller assembly, Appliance=accessory or system component, APU=Auxiliary Power Unit.' ;
    rdfs:domain ind:AirworthinessDirective ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentUrl rdf:type rdf:Property ;
    rdfs:label 'Document Url' ;
    rdfs:comment 'URL link to the official AD document on the issuing authority\'s website (e.g., FAA AD docket, EASA AD repository).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedCostPerAircraft rdf:type rdf:Property ;
    rdfs:label 'Estimated Cost Per Aircraft' ;
    rdfs:comment 'Estimated cost in USD to comply with the AD per affected aircraft, including labor, parts, and downtime. Provided by issuing authority or operator estimate.' ;
    rdfs:domain ind:AirworthinessDirective ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partNumberAffected rdf:type rdf:Property ;
    rdfs:label 'Part Number Affected' ;
    rdfs:comment 'Specific part number(s) of components affected by this AD. May include multiple part numbers if AD applies to a family of parts.' ;
    rdfs:domain ind:AirworthinessDirective ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serialNumberRange rdf:type rdf:Property ;
    rdfs:label 'Serial Number Range' ;
    rdfs:comment 'Serial number range of aircraft or components to which this AD applies (e.g., \'S/N 1001 through 5000\'). Null if AD applies to all serial numbers.' ;
    rdfs:domain ind:AirworthinessDirective ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subject rdf:type rdf:Property ;
    rdfs:label 'Subject' ;
    rdfs:comment 'Brief title or subject line describing the nature of the airworthiness directive (e.g., \'Engine Fan Blade Inspection\', \'Landing Gear Actuator Replacement\').' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededAdNumber rdf:type rdf:Property ;
    rdfs:label 'Superseded Ad Number' ;
    rdfs:comment 'AD number(s) that this directive supersedes or replaces. Multiple ADs may be listed if this AD consolidates previous directives. Null if no supersession.' ;
    rdfs:domain ind:AirworthinessDirective ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adComplianceId rdf:type rdf:Property ;
    rdfs:label 'Ad Compliance Id' ;
    rdfs:comment 'Unique identifier for the airworthiness directive compliance record.' ;
    rdfs:domain ind:AdCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maintenanceAirworthinessDirectiveId rdf:type rdf:Property ;
    rdfs:label 'Maintenance Airworthiness Directive Id' ;
    rdfs:comment 'Foreign key linking to maintenance.airworthiness_directive. Business justification: AD compliance tracks compliance with a specific airworthiness directive. The ad_compliance table has ad_number, ad_title, and issuing_authority but no FK to airworthiness_directive. Adding maintenance' ;
    rdfs:domain ind:AdCompliance ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AirworthinessDirective .

ind:accomplishmentDate rdf:type rdf:Property ;
    rdfs:label 'Accomplishment Date' ;
    rdfs:comment 'The date on which the airworthiness directive compliance action was completed.' ;
    rdfs:domain ind:AdCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accomplishmentFlightCycles rdf:type rdf:Property ;
    rdfs:label 'Accomplishment Flight Cycles' ;
    rdfs:comment 'The total flight cycles (airframe or component) at the time the airworthiness directive compliance action was completed.' ;
    rdfs:domain ind:AdCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accomplishmentFlightHours rdf:type rdf:Property ;
    rdfs:label 'Accomplishment Flight Hours' ;
    rdfs:comment 'The total flight hours (airframe or component) at the time the airworthiness directive compliance action was completed.' ;
    rdfs:domain ind:AdCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:adEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Ad Effective Date' ;
    rdfs:comment 'The date on which the airworthiness directive becomes effective and compliance is required.' ;
    rdfs:domain ind:AdCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:amocApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Amoc Approval Date' ;
    rdfs:comment 'The date on which the alternative method of compliance was approved by the regulatory authority.' ;
    rdfs:domain ind:AdCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:amocApprovalNumber rdf:type rdf:Property ;
    rdfs:label 'Amoc Approval Number' ;
    rdfs:comment 'The regulatory approval number for an alternative method of compliance, if an AMOC has been granted by the authority.' ;
    rdfs:domain ind:AdCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifyingMechanicLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Certifying Mechanic License Number' ;
    rdfs:comment 'The license or certificate number of the mechanic who certified the airworthiness directive compliance action.' ;
    rdfs:domain ind:AdCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceNotes rdf:type rdf:Property ;
    rdfs:label 'Compliance Notes' ;
    rdfs:comment 'Free-text notes documenting additional details, findings, or special circumstances related to the airworthiness directive compliance action.' ;
    rdfs:domain ind:AdCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Status' ;
    rdfs:comment 'Current status of compliance with the airworthiness directive: open (pending action), complied (completed), deferred (postponed under MEL), not applicable (does not apply to this aircraft/component), superseded (replaced by newer AD), or cancelled (withdrawn by authority).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deferralReference rdf:type rdf:Property ;
    rdfs:label 'Deferral Reference' ;
    rdfs:comment 'Reference to the Minimum Equipment List (MEL) or Configuration Deviation List (CDL) item under which compliance with this airworthiness directive has been deferred.' ;
    rdfs:domain ind:AdCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordUpdatedBy rdf:type rdf:Property ;
    rdfs:label 'Record Updated By' ;
    rdfs:comment 'The user or system identifier that last updated this airworthiness directive compliance record.' ;
    rdfs:domain ind:AdCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:repetitiveFlag rdf:type rdf:Property ;
    rdfs:label 'Repetitive Flag' ;
    rdfs:comment 'Indicates whether the airworthiness directive requires repetitive compliance actions (true) or is a one-time action (false).' ;
    rdfs:domain ind:AdCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:repetitiveIntervalCycles rdf:type rdf:Property ;
    rdfs:label 'Repetitive Interval Cycles' ;
    rdfs:comment 'The flight cycles interval at which the airworthiness directive compliance action must be repeated, if applicable.' ;
    rdfs:domain ind:AdCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:repetitiveIntervalDays rdf:type rdf:Property ;
    rdfs:label 'Repetitive Interval Days' ;
    rdfs:comment 'The calendar days interval at which the airworthiness directive compliance action must be repeated, if applicable.' ;
    rdfs:domain ind:AdCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:repetitiveIntervalHours rdf:type rdf:Property ;
    rdfs:label 'Repetitive Interval Hours' ;
    rdfs:comment 'The flight hours interval at which the airworthiness directive compliance action must be repeated, if applicable.' ;
    rdfs:domain ind:AdCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supersededByAdNumber rdf:type rdf:Property ;
    rdfs:label 'Superseded By Ad Number' ;
    rdfs:comment 'The airworthiness directive number that supersedes this AD, if applicable.' ;
    rdfs:domain ind:AdCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aircraftModelApplicability rdf:type rdf:Property ;
    rdfs:label 'Aircraft Model Applicability' ;
    rdfs:comment 'Aircraft model designations to which this service bulletin applies (e.g., \'A320-200\', \'Boeing 737-800\', \'Embraer E190\'). May include multiple models separated by commas.' ;
    rdfs:domain ind:ServiceBulletin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bulletinCategory rdf:type rdf:Property ;
    rdfs:label 'Bulletin Category' ;
    rdfs:comment 'Classification of the service bulletin indicating the urgency and compliance requirement. Mandatory bulletins are typically linked to Airworthiness Directives (ADs), while Recommended and Optional bulletins are at operator discretion.' ;
    rdfs:domain ind:ServiceBulletin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bulletinNumber rdf:type rdf:Property ;
    rdfs:label 'Bulletin Number' ;
    rdfs:comment 'Official service bulletin number issued by the Original Equipment Manufacturer (OEM). Format varies by manufacturer (e.g., Boeing SB format: 737-57-1234, Airbus SB format: A320-32-1045).' ;
    rdfs:domain ind:ServiceBulletin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bulletinTitle rdf:type rdf:Property ;
    rdfs:label 'Bulletin Title' ;
    rdfs:comment 'Descriptive title of the service bulletin summarizing the subject matter and purpose of the modification or inspection.' ;
    rdfs:domain ind:ServiceBulletin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bulletinType rdf:type rdf:Property ;
    rdfs:label 'Bulletin Type' ;
    rdfs:comment 'Type of technical communication issued by the OEM. Service Bulletins are formal modification instructions, Service Letters are informational, Alert Service Bulletins address urgent safety issues.' ;
    rdfs:domain ind:ServiceBulletin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Compliance Completion Date' ;
    rdfs:comment 'Date when compliance with the service bulletin was completed across the applicable fleet. Null if compliance is not yet complete. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:ServiceBulletin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceThreshold rdf:type rdf:Property ;
    rdfs:label 'Compliance Threshold' ;
    rdfs:comment 'Compliance deadline or threshold expressed in flight hours, flight cycles, calendar time, or next scheduled maintenance event (e.g., \'Within 12 months\', \'Before 10,000 flight hours\', \'At next C-Check\').' ;
    rdfs:domain ind:ServiceBulletin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivity rdf:type rdf:Property ;
    rdfs:label 'Effectivity' ;
    rdfs:comment 'Aircraft serial numbers, model series, or configuration codes to which the service bulletin applies. Defines the population of aircraft or components affected (e.g., \'All A320-200 MSN 1000-5000\', \'Boeing 737-800 Line Numbers 1-999\').' ;
    rdfs:domain ind:ServiceBulletin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engineModelApplicability rdf:type rdf:Property ;
    rdfs:label 'Engine Model Applicability' ;
    rdfs:comment 'Engine model designations to which this service bulletin applies (e.g., \'CFM56-5B\', \'PW1100G\', \'Trent 1000\'). Null if bulletin does not apply to engines.' ;
    rdfs:domain ind:ServiceBulletin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedCostUsd rdf:type rdf:Property ;
    rdfs:label 'Estimated Cost Usd' ;
    rdfs:comment 'Estimated total cost to implement the service bulletin including parts, labor, and downtime. Expressed in USD for standardization.' ;
    rdfs:domain ind:ServiceBulletin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isActive rdf:type rdf:Property ;
    rdfs:label 'Is Active' ;
    rdfs:comment 'Indicates whether the service bulletin is currently active and applicable. False if the bulletin has been superseded, cancelled, or completed across the fleet.' ;
    rdfs:domain ind:ServiceBulletin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:oemName rdf:type rdf:Property ;
    rdfs:label 'Oem Name' ;
    rdfs:comment 'Name of the manufacturer or supplier that issued the service bulletin (e.g., Airbus, Boeing, CFM International, Pratt & Whitney). [ENUM-REF-CANDIDATE: Airbus|Boeing|Bombardier|Embraer|ATR|CFM International|Pratt & Whitney|Rolls-Royce|General Electric|Honeywell|Collins Aerospace|Safran|Thales|Liebherr|Goodrich — 15 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:ServiceBulletin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partNumbersAffected rdf:type rdf:Property ;
    rdfs:label 'Part Numbers Affected' ;
    rdfs:comment 'Comma-separated list of part numbers (P/N) affected by this service bulletin. Identifies components requiring modification, inspection, or replacement.' ;
    rdfs:domain ind:ServiceBulletin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonForIssue rdf:type rdf:Property ;
    rdfs:label 'Reason For Issue' ;
    rdfs:comment 'Business or technical justification for issuing the service bulletin (e.g., \'Prevent premature wear\', \'Improve reliability\', \'Address safety concern\', \'Regulatory compliance\').' ;
    rdfs:domain ind:ServiceBulletin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionDate rdf:type rdf:Property ;
    rdfs:label 'Revision Date' ;
    rdfs:comment 'Date of the most recent revision to the service bulletin. Null if no revisions have been issued. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:ServiceBulletin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revisionNumber rdf:type rdf:Property ;
    rdfs:label 'Revision Number' ;
    rdfs:comment 'Revision level of the service bulletin. Tracks updates and amendments to the original bulletin (e.g., Original, 1, 2, A, B).' ;
    rdfs:domain ind:ServiceBulletin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededBulletinNumber rdf:type rdf:Property ;
    rdfs:label 'Superseded Bulletin Number' ;
    rdfs:comment 'Service bulletin number that this bulletin supersedes or replaces. Null if this is the original bulletin with no predecessor.' ;
    rdfs:domain ind:ServiceBulletin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalDescription rdf:type rdf:Property ;
    rdfs:label 'Technical Description' ;
    rdfs:comment 'Detailed technical description of the modification, inspection, or replacement procedure outlined in the service bulletin. Summarizes the work scope and technical rationale.' ;
    rdfs:domain ind:ServiceBulletin ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionId rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Id' ;
    rdfs:comment 'Foreign key linking to safety.corrective_action. Business justification: A recurring or safety-significant defect report can directly drive a corrective action raised by the quality/safety department, independent of a formal investigation. This is a real airline quality pr' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CorrectiveAction .

ind:discoveryStationId rdf:type rdf:Property ;
    rdfs:label 'Discovery Station Id' ;
    rdfs:comment 'Foreign key linking to airport.station. Business justification: Defects discovered at specific airport stations. Links discovery_station_code to station.station_id for quality tracking by location, identifying stations with high defect discovery rates, and targeti' ;
    rdfs:domain ind:DefectReport ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Station .

ind:investigationId rdf:type rdf:Property ;
    rdfs:label 'Investigation Id' ;
    rdfs:comment 'Foreign key linking to safety.investigation. Business justification: Defects often trigger formal safety investigations; linking enables tracking investigation outcomes back to originating defect. Critical for SMS closed-loop corrective action tracking and regulatory i' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Investigation .

ind:reportId rdf:type rdf:Property ;
    rdfs:label 'Report Id' ;
    rdfs:comment 'Foreign key linking to safety.report. Business justification: A safety-reportable defect (defect_report.safety_reportable_flag=true) generates a safety report directly — this can occur without an occurrence being raised (e.g., a ground maintenance finding). Dire' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Report .

ind:reportingCrewMemberId rdf:type rdf:Property ;
    rdfs:label 'Reporting Crew Member Id' ;
    rdfs:comment 'Foreign key linking to crew.crew_member. Business justification: Flight/cabin crew discover and report defects during operations. Complements existing employee_id FK with crew-specific context (qualifications, recency, position). Business process: defect discovery ' ;
    rdfs:domain ind:DefectReport ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Member .

ind:cdlApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Cdl Applicable Flag' ;
    rdfs:comment 'Indicates whether the defect is eligible for deferral under the aircraft Configuration Deviation List (CDL) for missing or inoperative external components. True if CDL item exists, false otherwise.' ;
    rdfs:domain ind:DefectReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:closedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Closed Timestamp' ;
    rdfs:comment 'Date and time when the defect report was formally closed after verification and sign-off. Null if not yet closed.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:defectNumber rdf:type rdf:Property ;
    rdfs:label 'Defect Number' ;
    rdfs:comment 'Business identifier for the defect report, typically generated by AMOS or technical log system. Externally referenced in work orders and maintenance records.' ;
    rdfs:domain ind:DefectReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:defectStatus rdf:type rdf:Property ;
    rdfs:label 'Defect Status' ;
    rdfs:comment 'Current lifecycle status of the defect report (open - awaiting action, deferred - MEL/CDL deferral applied, rectified - repair completed, closed - verified and signed off, cancelled - invalid report).' ;
    rdfs:domain ind:DefectReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deferralExpiryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Deferral Expiry Timestamp' ;
    rdfs:comment 'Date and time by which the deferred defect must be rectified per MEL/CDL category. Null if not deferred or if defect is already rectified.' ;
    rdfs:domain ind:DefectReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:discoveryPhase rdf:type rdf:Property ;
    rdfs:label 'Discovery Phase' ;
    rdfs:comment 'Operational phase during which the defect was discovered (pre-flight inspection, in-flight, post-flight walk-around, hangar maintenance, line maintenance, or base maintenance check).' ;
    rdfs:domain ind:DefectReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discoveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Discovery Timestamp' ;
    rdfs:comment 'Date and time when the defect was discovered. Principal business event timestamp for the defect lifecycle.' ;
    rdfs:domain ind:DefectReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:melApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Mel Applicable Flag' ;
    rdfs:comment 'Indicates whether the defect is eligible for deferral under the aircraft Minimum Equipment List (MEL). True if MEL item exists for this defect, false otherwise.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:melCategory rdf:type rdf:Property ;
    rdfs:label 'Mel Category' ;
    rdfs:comment 'MEL deferral category indicating repair interval: A (repair interval specified by MEL), B (repair within 3 days), C (repair within 10 days), D (repair within 120 days). Null if not deferred.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partNumberReplaced rdf:type rdf:Property ;
    rdfs:label 'Part Number Replaced' ;
    rdfs:comment 'Manufacturer part number of the component replaced during rectification. Null if no part replacement occurred.' ;
    rdfs:domain ind:DefectReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rectificationActionDescription rdf:type rdf:Property ;
    rdfs:label 'Rectification Action Description' ;
    rdfs:comment 'Detailed description of the corrective action taken to rectify the defect, including parts replaced, repairs performed, and tests conducted. Null if not yet rectified.' ;
    rdfs:domain ind:DefectReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rectificationStationCode rdf:type rdf:Property ;
    rdfs:label 'Rectification Station Code' ;
    rdfs:comment 'IATA three-letter airport code of the station where the defect was rectified. Null if not yet rectified.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rectificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Rectification Timestamp' ;
    rdfs:comment 'Date and time when the defect rectification work was completed. Null if not yet rectified.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reportedByRole rdf:type rdf:Property ;
    rdfs:label 'Reported By Role' ;
    rdfs:comment 'Role of the person who reported the defect (flight crew, cabin crew, maintenance technician, quality inspector, or engineer).' ;
    rdfs:domain ind:DefectReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyReportableFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Reportable Flag' ;
    rdfs:comment 'Indicates whether this defect meets regulatory criteria for mandatory safety occurrence reporting to aviation authorities (FAA, EASA, national CAA). True if reportable, false otherwise.' ;
    rdfs:domain ind:DefectReport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hazardId rdf:type rdf:Property ;
    rdfs:label 'Hazard Id' ;
    rdfs:comment 'Foreign key linking to safety.hazard. Business justification: Each MEL item manages a specific known hazard (an inoperative system representing a defined safety hazard). SMS integration requires traceability from MEL items to the hazard register — a real require' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Hazard .

ind:ataSubject rdf:type rdf:Property ;
    rdfs:label 'Ata Subject' ;
    rdfs:comment 'Two-digit ATA subject code providing the most granular system classification.' ;
    rdfs:domain ind:MelItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deferralCategory rdf:type rdf:Property ;
    rdfs:label 'Deferral Category' ;
    rdfs:comment 'The MEL category defining the maximum time an item may remain inoperative: A (no time limit with conditions), B (3 consecutive calendar days), C (10 consecutive calendar days), D (120 consecutive calendar days).' ;
    rdfs:domain ind:MelItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatchConditions rdf:type rdf:Property ;
    rdfs:label 'Dispatch Conditions' ;
    rdfs:comment 'Additional conditions or restrictions for dispatch with this item inoperative (e.g., \'Day VFR only\', \'Maximum altitude FL250\', \'Reduced passenger capacity\').' ;
    rdfs:domain ind:MelItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemDescription rdf:type rdf:Property ;
    rdfs:label 'Item Description' ;
    rdfs:comment 'Detailed description of the inoperative system, component, or equipment covered by this MEL item (e.g., \'Passenger Oxygen System - One Passenger Service Unit\').' ;
    rdfs:domain ind:MelItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceProcedures rdf:type rdf:Property ;
    rdfs:label 'Maintenance Procedures' ;
    rdfs:comment 'Specific maintenance actions required before dispatch with this item inoperative (e.g., \'Deactivate and placard\', \'Secure and stow equipment\').' ;
    rdfs:domain ind:MelItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumDeferralDays rdf:type rdf:Property ;
    rdfs:label 'Maximum Deferral Days' ;
    rdfs:comment 'The maximum number of consecutive calendar days the item may remain inoperative before rectification is required. Null for Category A items with no time limit.' ;
    rdfs:domain ind:MelItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:melItemNumber rdf:type rdf:Property ;
    rdfs:label 'Mel Item Number' ;
    rdfs:comment 'The unique MEL item number following ATA chapter structure (e.g., 21-31-01, 34-12-02A). This is the externally-known identifier for the MEL item.' ;
    rdfs:domain ind:MelItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:melItemStatus rdf:type rdf:Property ;
    rdfs:label 'Mel Item Status' ;
    rdfs:comment 'Current lifecycle status of this MEL item configuration: active (in use), superseded (replaced by newer revision), withdrawn (no longer applicable), pending_approval (awaiting regulatory acceptance).' ;
    rdfs:domain ind:MelItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mmelReference rdf:type rdf:Property ;
    rdfs:label 'Mmel Reference' ;
    rdfs:comment 'Reference to the corresponding Master MEL item number and revision from the aircraft manufacturer or regulatory authority MMEL document.' ;
    rdfs:domain ind:MelItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mmelRevisionDate rdf:type rdf:Property ;
    rdfs:label 'Mmel Revision Date' ;
    rdfs:comment 'The effective date of the MMEL revision from which this MEL item was derived.' ;
    rdfs:domain ind:MelItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:numberInstalled rdf:type rdf:Property ;
    rdfs:label 'Number Installed' ;
    rdfs:comment 'The total number of units of this system or component installed on the aircraft type.' ;
    rdfs:domain ind:MelItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numberRequiredDispatch rdf:type rdf:Property ;
    rdfs:label 'Number Required Dispatch' ;
    rdfs:comment 'The minimum number of units that must be operative for the aircraft to be dispatched under this MEL item.' ;
    rdfs:domain ind:MelItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operationalProcedures rdf:type rdf:Property ;
    rdfs:label 'Operational Procedures' ;
    rdfs:comment 'Specific operational procedures, limitations, or restrictions that flight crew must follow when dispatching with this item inoperative (e.g., \'Flight in icing conditions prohibited\').' ;
    rdfs:domain ind:MelItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatorMelRevision rdf:type rdf:Property ;
    rdfs:label 'Operator Mel Revision' ;
    rdfs:comment 'The operator-specific MEL document revision number under which this item is published.' ;
    rdfs:domain ind:MelItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:placardLocation rdf:type rdf:Property ;
    rdfs:label 'Placard Location' ;
    rdfs:comment 'The specific location where the placard must be installed (e.g., \'Overhead panel\', \'Seat 12A armrest\', \'Flight deck door\').' ;
    rdfs:domain ind:MelItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:placardRequired rdf:type rdf:Property ;
    rdfs:label 'Placard Required' ;
    rdfs:comment 'Indicates whether a placard must be installed in the cockpit or cabin to inform crew of the inoperative item.' ;
    rdfs:domain ind:MelItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:placardText rdf:type rdf:Property ;
    rdfs:label 'Placard Text' ;
    rdfs:comment 'The exact text that must appear on the placard if placard_required is true (e.g., \'INOP\', \'DO NOT USE\').' ;
    rdfs:domain ind:MelItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryApprovalReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Reference' ;
    rdfs:comment 'Reference to the regulatory authority approval document or letter of acceptance for this MEL item (e.g., FAA OpSpec D085, EASA Part-CAT approval).' ;
    rdfs:domain ind:MelItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acceptingCommanderCrewMemberId rdf:type rdf:Property ;
    rdfs:label 'Accepting Commander Crew Member Id' ;
    rdfs:comment 'Foreign key linking to crew.crew_member. Business justification: Commander accepts MEL deferral and operational restrictions before flight. Business process: crew acceptance of deferred defects, operational decision tracking, regulatory compliance (commander must a' ;
    rdfs:domain ind:MelDeferral ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Member .

ind:deferralStationId rdf:type rdf:Property ;
    rdfs:label 'Deferral Station Id' ;
    rdfs:comment 'Foreign key linking to airport.station. Business justification: MEL deferrals opened at specific stations. Links deferral_station_code to station.station_id for regulatory compliance tracking by location, identifying stations with high deferral rates, and ensuring' ;
    rdfs:domain ind:MelDeferral ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Station .

ind:maintenanceMelItemId rdf:type rdf:Property ;
    rdfs:label 'Maintenance Mel Item Id' ;
    rdfs:comment 'Foreign key linking to maintenance.mel_item. Business justification: MEL deferral is based on a MEL item definition. The mel_deferral table has mel_item_reference (STRING) but no FK. Adding maintenance_mel_item_id FK normalizes this and removes redundant mel_item_refer' ;
    rdfs:domain ind:MelDeferral ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MelItem .

ind:aogRiskFlag rdf:type rdf:Property ;
    rdfs:label 'Aog Risk Flag' ;
    rdfs:comment 'Boolean flag indicating whether this deferral poses a high risk of causing an AOG event if not rectified promptly (true) or not (false).' ;
    rdfs:domain ind:MelDeferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certifyingStaffLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Certifying Staff License Number' ;
    rdfs:comment 'The license or authorization number of the certifying staff who approved the deferral.' ;
    rdfs:domain ind:MelDeferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureDate rdf:type rdf:Property ;
    rdfs:label 'Closure Date' ;
    rdfs:comment 'The date on which the MEL deferral record was administratively closed in the maintenance system. Null if still open.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:closureRemarks rdf:type rdf:Property ;
    rdfs:label 'Closure Remarks' ;
    rdfs:comment 'Free-text remarks or notes recorded when the deferral was closed, including any follow-up actions or observations.' ;
    rdfs:domain ind:MelDeferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deferralDescription rdf:type rdf:Property ;
    rdfs:label 'Deferral Description' ;
    rdfs:comment 'Free-text description of the inoperative item and the nature of the deferral, including any operational restrictions or procedures.' ;
    rdfs:domain ind:MelDeferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deferralOpenDate rdf:type rdf:Property ;
    rdfs:label 'Deferral Open Date' ;
    rdfs:comment 'The date on which the MEL deferral was opened and the item was deferred from service.' ;
    rdfs:domain ind:MelDeferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deferralOpenTimestamp rdf:type rdf:Property ;
    rdfs:label 'Deferral Open Timestamp' ;
    rdfs:comment 'The precise timestamp when the MEL deferral was opened in the maintenance system.' ;
    rdfs:domain ind:MelDeferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:deferralStatus rdf:type rdf:Property ;
    rdfs:label 'Deferral Status' ;
    rdfs:comment 'Current lifecycle status of the MEL deferral: open (active), extended (interval extended), rectified (repair completed), closed (administratively closed), expired (exceeded allowed interval).' ;
    rdfs:domain ind:MelDeferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:extensionAuthority rdf:type rdf:Property ;
    rdfs:label 'Extension Authority' ;
    rdfs:comment 'The name or identifier of the authority (e.g., Chief Engineer, Maintenance Control) who approved the deferral extension.' ;
    rdfs:domain ind:MelDeferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:extensionCount rdf:type rdf:Property ;
    rdfs:label 'Extension Count' ;
    rdfs:comment 'The number of times the deferral expiry date has been extended beyond the original MEL category interval.' ;
    rdfs:domain ind:MelDeferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:flightCyclesAtDeferral rdf:type rdf:Property ;
    rdfs:label 'Flight Cycles At Deferral' ;
    rdfs:comment 'The total accumulated flight cycles (takeoff-landing cycles) on the aircraft at the time the MEL deferral was opened.' ;
    rdfs:domain ind:MelDeferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:flightHoursAtDeferral rdf:type rdf:Property ;
    rdfs:label 'Flight Hours At Deferral' ;
    rdfs:comment 'The total accumulated flight hours (block hours) on the aircraft at the time the MEL deferral was opened.' ;
    rdfs:domain ind:MelDeferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastExtensionDate rdf:type rdf:Property ;
    rdfs:label 'Last Extension Date' ;
    rdfs:comment 'The date of the most recent extension of the deferral expiry date. Null if never extended.' ;
    rdfs:domain ind:MelDeferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maintenanceProceduresApplied rdf:type rdf:Property ;
    rdfs:label 'Maintenance Procedures Applied' ;
    rdfs:comment 'Description of any maintenance procedures or placarding actions performed when the deferral was opened (e.g., circuit breaker collared, placard installed).' ;
    rdfs:domain ind:MelDeferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationalRestrictions rdf:type rdf:Property ;
    rdfs:label 'Operational Restrictions' ;
    rdfs:comment 'Specific operational restrictions or limitations imposed by the MEL deferral (e.g., flight altitude limits, route restrictions, weather minimums).' ;
    rdfs:domain ind:MelDeferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rectificationDate rdf:type rdf:Property ;
    rdfs:label 'Rectification Date' ;
    rdfs:comment 'The date on which the deferred item was rectified and returned to service. Null if not yet rectified.' ;
    rdfs:domain ind:MelDeferral ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryNotificationDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Date' ;
    rdfs:comment 'The date on which the civil aviation authority was notified of this deferral. Null if notification not required or not yet sent.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryNotificationRequired rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Required' ;
    rdfs:comment 'Boolean flag indicating whether this deferral requires notification to the civil aviation authority (true) or not (false).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:currentStationId rdf:type rdf:Property ;
    rdfs:label 'Current Station Id' ;
    rdfs:comment 'Foreign key linking to airport.station. Business justification: Component tracking and rotable part logistics require knowing which station a component is currently located at. Aviation MRO operations depend on this for AOG dispatch, loan/exchange decisions, and i' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Station .

ind:fleetEngineId rdf:type rdf:Property ;
    rdfs:label 'Fleet Engine Id' ;
    rdfs:comment 'Foreign key linking to fleet.engine. Business justification: When a maintenance.component record represents an engine module or LLP, it must reference the fleet.engine asset record for TSN/CSN reconciliation, LLP life tracking, and lease return condition verifi' ;
    rdfs:domain ind:Component ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Engine .

ind:airworthinessCertificateDate rdf:type rdf:Property ;
    rdfs:label 'Airworthiness Certificate Date' ;
    rdfs:comment 'Issue date of the current airworthiness release certificate for this component.' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:airworthinessCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Airworthiness Certificate Number' ;
    rdfs:comment 'Unique reference number of the airworthiness release certificate (EASA Form 1, FAA 8130-3, or equivalent) certifying this component as airworthy and fit for installation.' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:airworthinessCertificateType rdf:type rdf:Property ;
    rdfs:label 'Airworthiness Certificate Type' ;
    rdfs:comment 'Type of airworthiness release certificate accompanying this component. EASA Form 1, FAA Form 8130-3, and CAA CRS are the most common authorized release certificates.' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:batchNumber rdf:type rdf:Property ;
    rdfs:label 'Batch Number' ;
    rdfs:comment 'Manufacturing batch or lot number for batch-tracked components. Used for traceability in case of manufacturing defects or airworthiness directives. Null for serialized-only components.' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentDescription rdf:type rdf:Property ;
    rdfs:label 'Component Description' ;
    rdfs:comment 'Detailed textual description of the component including type, function, and key characteristics. Used for identification and maintenance planning.' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conditionCode rdf:type rdf:Property ;
    rdfs:label 'Condition Code' ;
    rdfs:comment 'Two-letter ATA Spec 2000 condition code indicating the maintenance and airworthiness status of the component (e.g., AR=As Removed, OH=Overhauled, NE=New, RP=Repaired, SV=Serviceable).' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:criticalityClassification rdf:type rdf:Property ;
    rdfs:label 'Criticality Classification' ;
    rdfs:comment 'Classification of the components criticality to flight operations and safety. AOG-critical components ground the aircraft if unserviceable, flight-safety components affect airworthiness, operational components affect dispatch reliability.' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentLocationType rdf:type rdf:Property ;
    rdfs:label 'Current Location Type' ;
    rdfs:comment 'Type of location where the component is currently held. Aircraft indicates installed on aircraft, shop indicates undergoing maintenance, store indicates warehouse inventory, quarantine indicates awaiting inspection, scrap indicates condemned.' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cyclesRemainingToLimit rdf:type rdf:Property ;
    rdfs:label 'Cycles Remaining To Limit' ;
    rdfs:comment 'Flight cycles remaining before the component reaches its life limit or next scheduled maintenance event. Null if not applicable or unlimited.' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cyclesSinceOverhaul rdf:type rdf:Property ;
    rdfs:label 'Cycles Since Overhaul' ;
    rdfs:comment 'Flight cycles accumulated since the last major overhaul or shop visit. Reset to zero after overhaul. Null if component has never been overhauled.' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:installationDate rdf:type rdf:Property ;
    rdfs:label 'Installation Date' ;
    rdfs:comment 'Date when the component was installed on the current aircraft. Null if component is not currently installed on an aircraft.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastOverhaulDate rdf:type rdf:Property ;
    rdfs:label 'Last Overhaul Date' ;
    rdfs:comment 'Date when the component last underwent major overhaul or shop visit. Null if component has never been overhauled.' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lifeLimitedPartFlag rdf:type rdf:Property ;
    rdfs:label 'Life Limited Part Flag' ;
    rdfs:comment 'Indicates whether this component is a life-limited part subject to mandatory retirement at specified life limits per airworthiness directives. True if LLP, false otherwise.' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:manufactureDate rdf:type rdf:Property ;
    rdfs:label 'Manufacture Date' ;
    rdfs:comment 'Date when the component was originally manufactured by the OEM. Used for age-based maintenance requirements and warranty tracking.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:manufacturerCode rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Code' ;
    rdfs:comment 'Standardized code identifying the component manufacturer. Typically ICAO or industry-standard manufacturer identifier.' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturerName rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Name' ;
    rdfs:comment 'Name of the original equipment manufacturer (OEM) who produced this component.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownerType rdf:type rdf:Property ;
    rdfs:label 'Owner Type' ;
    rdfs:comment 'Ownership classification of the component. Owned indicates airline-owned, leased indicates leased from lessor, pooled indicates part of rotable pool agreement, consignment indicates supplier-owned inventory.' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partNumber rdf:type rdf:Property ;
    rdfs:label 'Part Number' ;
    rdfs:comment 'Manufacturer part number identifying the component type. Standard alphanumeric identifier used across aviation industry for component cataloging.' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:removalDate rdf:type rdf:Property ;
    rdfs:label 'Removal Date' ;
    rdfs:comment 'Date when the component was last removed from an aircraft. Null if component has never been installed or is currently installed.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:removalReason rdf:type rdf:Property ;
    rdfs:label 'Removal Reason' ;
    rdfs:comment 'Reason code for the last removal of this component from an aircraft. Used for reliability analysis and maintenance planning. [ENUM-REF-CANDIDATE: scheduled_maintenance|unscheduled_maintenance|defect|llp_limit|modification|aog|inspection|lease_return|other — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rotableFlag rdf:type rdf:Property ;
    rdfs:label 'Rotable Flag' ;
    rdfs:comment 'Indicates whether this component is a rotable (repairable) part that can be overhauled and returned to service, as opposed to expendable parts. True if rotable, false if expendable.' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceableStatus rdf:type rdf:Property ;
    rdfs:label 'Serviceable Status' ;
    rdfs:comment 'Current airworthiness and serviceability status of the component. Serviceable indicates ready for installation, unserviceable indicates requires maintenance, quarantine indicates awaiting inspection. [ENUM-REF-CANDIDATE: serviceable|unserviceable|repairable|beyond_economic_repair|condemned|quarantine|inspection_required — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shelfLifeExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Shelf Life Expiry Date' ;
    rdfs:comment 'Date when the component reaches the end of its shelf life and must be inspected, tested, or scrapped. Applicable to time-sensitive components such as rubber seals, batteries, and life vests. Null if not applicable.' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:timeRemainingToLimit rdf:type rdf:Property ;
    rdfs:label 'Time Remaining To Limit' ;
    rdfs:comment 'Flight hours remaining before the component reaches its life limit or next scheduled maintenance event. Measured in hours. Null if not applicable or unlimited.' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:timeSinceOverhaul rdf:type rdf:Property ;
    rdfs:label 'Time Since Overhaul' ;
    rdfs:comment 'Flight hours accumulated since the last major overhaul or shop visit. Measured in hours. Reset to zero after overhaul. Null if component has never been overhauled.' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCyclesSinceNew rdf:type rdf:Property ;
    rdfs:label 'Total Cycles Since New' ;
    rdfs:comment 'Cumulative flight cycles (takeoff/landing cycles) accumulated by this component since original manufacture. Critical for fatigue-sensitive components and LLP tracking.' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalTimeSinceNew rdf:type rdf:Property ;
    rdfs:label 'Total Time Since New' ;
    rdfs:comment 'Cumulative flight hours accumulated by this component since original manufacture. Measured in hours. Critical for life-limited part tracking and maintenance scheduling.' ;
    rdfs:domain ind:Component ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:warrantyExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Warranty Expiry Date' ;
    rdfs:comment 'Date when the manufacturer or overhaul shop warranty for this component expires. Null if no warranty applies.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:commanderCrewMemberId rdf:type rdf:Property ;
    rdfs:label 'Commander Crew Member Id' ;
    rdfs:comment 'Foreign key linking to crew.crew_member. Business justification: Aircraft commander signs technical log accepting aircraft airworthiness. Complements employee_id with crew operational context. Business process: commander accountability for airworthiness acceptance,' ;
    rdfs:domain ind:TechnicalLog ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Member .

ind:aircraftTotalCycles rdf:type rdf:Property ;
    rdfs:label 'Aircraft Total Cycles' ;
    rdfs:comment 'The cumulative total flight cycles (takeoff and landing pairs) at the end of this sector. Critical for fatigue-sensitive component life tracking.' ;
    rdfs:domain ind:TechnicalLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:aircraftTotalHours rdf:type rdf:Property ;
    rdfs:label 'Aircraft Total Hours' ;
    rdfs:comment 'The cumulative total airframe hours at the end of this sector. Critical for maintenance scheduling and airworthiness compliance.' ;
    rdfs:domain ind:TechnicalLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:airworthinessDirectiveCompliance rdf:type rdf:Property ;
    rdfs:label 'Airworthiness Directive Compliance' ;
    rdfs:comment 'Notes or references to any Airworthiness Directives (ADs) complied with during this sector or affecting the aircraft\'s airworthiness status.' ;
    rdfs:domain ind:TechnicalLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arrivalStationCode rdf:type rdf:Property ;
    rdfs:label 'Arrival Station Code' ;
    rdfs:comment 'The three-letter IATA airport code for the arrival station (e.g., LHR, JFK, SIN).' ;
    rdfs:domain ind:TechnicalLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockOffTimestamp rdf:type rdf:Property ;
    rdfs:label 'Block Off Timestamp' ;
    rdfs:comment 'The timestamp when the aircraft pushed back from the gate or commenced taxi for departure (Out time in OOOI). Marks the start of block hours.' ;
    rdfs:domain ind:TechnicalLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:blockOnTimestamp rdf:type rdf:Property ;
    rdfs:label 'Block On Timestamp' ;
    rdfs:comment 'The timestamp when the aircraft arrived at the gate and parking brake was set (In time in OOOI). Marks the end of block hours.' ;
    rdfs:domain ind:TechnicalLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:crsIssuedFlag rdf:type rdf:Property ;
    rdfs:label 'Crs Issued Flag' ;
    rdfs:comment 'Indicates whether a Certificate of Release to Service was issued for maintenance work performed before or during this sector. True if CRS was issued, false otherwise.' ;
    rdfs:domain ind:TechnicalLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:defectsRaisedCount rdf:type rdf:Property ;
    rdfs:label 'Defects Raised Count' ;
    rdfs:comment 'The number of new defects or discrepancies raised by the crew during or after this sector. Links to individual defect records.' ;
    rdfs:domain ind:TechnicalLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deferredDefectsCarriedForward rdf:type rdf:Property ;
    rdfs:label 'Deferred Defects Carried Forward' ;
    rdfs:comment 'A summary or list of deferred defect reference numbers carried forward from previous sectors and still active on this flight. Provides continuity of airworthiness status.' ;
    rdfs:domain ind:TechnicalLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flightHours rdf:type rdf:Property ;
    rdfs:label 'Flight Hours' ;
    rdfs:comment 'The duration in hours from takeoff to landing for this sector. Used for airframe and engine life-limited parts tracking.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelRemainingKg rdf:type rdf:Property ;
    rdfs:label 'Fuel Remaining Kg' ;
    rdfs:comment 'The quantity of fuel remaining at the end of the sector, measured in kilograms. Used for fuel planning and anomaly detection.' ;
    rdfs:domain ind:TechnicalLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:landingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Landing Timestamp' ;
    rdfs:comment 'The timestamp when the aircraft touched down on the runway (On time in OOOI). Used for flight cycle counting.' ;
    rdfs:domain ind:TechnicalLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:melItemsActiveCount rdf:type rdf:Property ;
    rdfs:label 'Mel Items Active Count' ;
    rdfs:comment 'The number of MEL deferred defects active and carried forward on this sector. Indicates aircraft dispatch with inoperative equipment under MEL authority.' ;
    rdfs:domain ind:TechnicalLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:oilUpliftLitres rdf:type rdf:Property ;
    rdfs:label 'Oil Uplift Litres' ;
    rdfs:comment 'The quantity of engine oil uplifted for this sector, measured in litres. Monitored for engine health and consumption trends.' ;
    rdfs:domain ind:TechnicalLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preFlightInspectionStatus rdf:type rdf:Property ;
    rdfs:label 'Pre Flight Inspection Status' ;
    rdfs:comment 'The outcome of the commander\'s pre-flight walk-around inspection. Indicates whether the aircraft was found airworthy or defects were noted.' ;
    rdfs:domain ind:TechnicalLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sectorDate rdf:type rdf:Property ;
    rdfs:label 'Sector Date' ;
    rdfs:comment 'The calendar date on which this flight sector was operated, in UTC.' ;
    rdfs:domain ind:TechnicalLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:takeoffTimestamp rdf:type rdf:Property ;
    rdfs:label 'Takeoff Timestamp' ;
    rdfs:comment 'The timestamp when the aircraft became airborne (Off time in OOOI). Used for flight cycle counting.' ;
    rdfs:domain ind:TechnicalLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:technicalLogStatus rdf:type rdf:Property ;
    rdfs:label 'Technical Log Status' ;
    rdfs:comment 'The current status of this technical log sector page record. Open indicates the sector is in progress or pending closure; closed indicates all entries are complete and signed off.' ;
    rdfs:domain ind:TechnicalLog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifyingStaffCrewMemberId rdf:type rdf:Property ;
    rdfs:label 'Certifying Staff Crew Member Id' ;
    rdfs:comment 'Foreign key linking to crew.member. Business justification: A Certificate of Release to Service (CRS) must be signed by a licensed certifying staff member. Regulatory requirement (Part-145/Part-66) mandates traceability of the individual who released the aircr' ;
    rdfs:domain ind:Release ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Member .

ind:clearedFlightLegId rdf:type rdf:Property ;
    rdfs:label 'Cleared Flight Leg Id' ;
    rdfs:comment 'Foreign key linking to flight.flight_leg. Business justification: A Certificate of Release to Service (CRS) clears the aircraft for a specific next departure flight_leg. Role-prefix \'cleared_\' distinguishes this from the work_order FK already on release. Regulatory ' ;
    rdfs:domain ind:Release ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FlightLeg .

ind:aircraftTotalCyclesAtRelease rdf:type rdf:Property ;
    rdfs:label 'Aircraft Total Cycles At Release' ;
    rdfs:comment 'Cumulative total flight cycles (takeoff and landing pairs) recorded on the aircraft at the time of release to service. Used for fatigue-sensitive component life tracking.' ;
    rdfs:domain ind:Release ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:aircraftTotalHoursAtRelease rdf:type rdf:Property ;
    rdfs:label 'Aircraft Total Hours At Release' ;
    rdfs:comment 'Cumulative total flight hours (block hours) recorded on the aircraft at the time of release to service. Critical for life-limited parts tracking and maintenance interval calculations.' ;
    rdfs:domain ind:Release ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:approvalAuthority rdf:type rdf:Property ;
    rdfs:label 'Approval Authority' ;
    rdfs:comment 'National or regional aviation authority under whose regulations this release to service is issued (e.g., EASA, FAA, TCCA, CAAC). Determines applicable regulatory framework.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certifyingStaffAuthorizationReference rdf:type rdf:Property ;
    rdfs:label 'Certifying Staff Authorization Reference' ;
    rdfs:comment 'Internal authorization or stamp number issued by the Part-145 organization to the certifying staff, confirming their scope of approval within the AMO.' ;
    rdfs:domain ind:Release ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentCyclesAtRelease rdf:type rdf:Property ;
    rdfs:label 'Component Cycles At Release' ;
    rdfs:comment 'Total operating cycles accumulated on the component at the time of release, applicable for component-level maintenance releases. Tracks cycles-since-new or cycles-since-overhaul.' ;
    rdfs:domain ind:Release ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:componentHoursAtRelease rdf:type rdf:Property ;
    rdfs:label 'Component Hours At Release' ;
    rdfs:comment 'Total operating hours accumulated on the component at the time of release, applicable for component-level maintenance releases. Tracks time-since-new or time-since-overhaul.' ;
    rdfs:domain ind:Release ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:crsNumber rdf:type rdf:Property ;
    rdfs:label 'Crs Number' ;
    rdfs:comment 'Unique externally-known certificate number issued by the Part-145 approved maintenance organization certifying airworthiness release. Legally mandated document identifier.' ;
    rdfs:domain ind:Release ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalSignatureHash rdf:type rdf:Property ;
    rdfs:label 'Digital Signature Hash' ;
    rdfs:comment 'Cryptographic hash of the digital signature applied to the electronic CRS document, ensuring authenticity and non-repudiation of the release certification.' ;
    rdfs:domain ind:Release ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maintenanceType rdf:type rdf:Property ;
    rdfs:label 'Maintenance Type' ;
    rdfs:comment 'Classification of the maintenance activity certified by this release: scheduled check, unscheduled defect repair, airworthiness directive compliance, service bulletin incorporation, MEL rectification, AOG recovery, component overhaul, or aircraft modification. [ENUM-REF-CANDIDATE: scheduled|unscheduled|ad_compliance|sb_incorporation|mel_deferral_rectification|aog_recovery|component_overhaul|modification — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Release ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextDueCycles rdf:type rdf:Property ;
    rdfs:label 'Next Due Cycles' ;
    rdfs:comment 'Aircraft total cycles at which the next scheduled maintenance action is due, as established or updated by this release. Used for maintenance planning and scheduling.' ;
    rdfs:domain ind:Release ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextDueHours rdf:type rdf:Property ;
    rdfs:label 'Next Due Hours' ;
    rdfs:comment 'Aircraft total hours at which the next scheduled maintenance action is due, as established or updated by this release. Used for maintenance planning and scheduling.' ;
    rdfs:domain ind:Release ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:openItemsDescription rdf:type rdf:Property ;
    rdfs:label 'Open Items Description' ;
    rdfs:comment 'Description of any open maintenance items, deferred defects, or limitations that remain after this release. Documents any MEL deferrals or work not completed that affect operational capability.' ;
    rdfs:domain ind:Release ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationalLimitations rdf:type rdf:Property ;
    rdfs:label 'Operational Limitations' ;
    rdfs:comment 'Any operational restrictions or limitations imposed on the aircraft or component as a result of the maintenance performed or deferred items. May include speed, altitude, or route restrictions.' ;
    rdfs:domain ind:Release ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseCategory rdf:type rdf:Property ;
    rdfs:label 'Release Category' ;
    rdfs:comment 'Category of asset for which this release to service is issued: complete aircraft, engine, APU (Auxiliary Power Unit), line-replaceable component, or cabin interior.' ;
    rdfs:domain ind:Release ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Release Timestamp' ;
    rdfs:comment 'Date and time when the certifying staff signed the Certificate of Release to Service, officially releasing the aircraft or component back to airworthy status. Principal business event timestamp for this transaction.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scopeOfWorkDescription rdf:type rdf:Property ;
    rdfs:label 'Scope Of Work Description' ;
    rdfs:comment 'Detailed narrative description of the maintenance tasks, inspections, repairs, modifications, or component replacements performed under this release. Summarizes the work certified as airworthy.' ;
    rdfs:domain ind:Release ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditId rdf:type rdf:Property ;
    rdfs:label 'Audit Id' ;
    rdfs:comment 'Foreign key linking to safety.audit. Business justification: Maintenance organizations are audited (Part-145 audits, IOSA). Link tracks audit history and findings against specific MROs, supports vendor quality management, and enables audit-driven MRO selection ' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Audit .

ind:accountableManagerName rdf:type rdf:Property ;
    rdfs:label 'Accountable Manager Name' ;
    rdfs:comment 'Name of the accountable manager responsible for ensuring the maintenance organisation complies with Part-145 requirements.' ;
    rdfs:domain ind:ApprovedMaintenanceOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line1' ;
    rdfs:comment 'Primary street address line of the maintenance organisation facility.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line2' ;
    rdfs:comment 'Secondary street address line (building, suite, floor) of the maintenance organisation facility.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:airframeRatingFlag rdf:type rdf:Property ;
    rdfs:label 'Airframe Rating Flag' ;
    rdfs:comment 'Indicates whether the organisation holds airframe maintenance rating approval.' ;
    rdfs:domain ind:ApprovedMaintenanceOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:aogSupportAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Aog Support Available Flag' ;
    rdfs:comment 'Indicates whether the maintenance organisation provides 24/7 AOG (Aircraft on Ground) emergency support services.' ;
    rdfs:domain ind:ApprovedMaintenanceOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvalExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Approval Expiry Date' ;
    rdfs:comment 'Date when the Part-145 approval certificate expires and requires renewal. Null if approval has no fixed expiry (continuous validity subject to surveillance).' ;
    rdfs:domain ind:ApprovedMaintenanceOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvalIssueDate rdf:type rdf:Property ;
    rdfs:label 'Approval Issue Date' ;
    rdfs:comment 'Date when the Part-145 approval certificate was originally issued by the regulatory authority.' ;
    rdfs:domain ind:ApprovedMaintenanceOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvalNumber rdf:type rdf:Property ;
    rdfs:label 'Approval Number' ;
    rdfs:comment 'Official Part-145 approval certificate number issued by the regulatory authority (e.g., EASA.145.1234, FAA-RS-ABC123).' ;
    rdfs:domain ind:ApprovedMaintenanceOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalScope rdf:type rdf:Property ;
    rdfs:label 'Approval Scope' ;
    rdfs:comment 'Textual description of the maintenance capabilities and ratings covered by the approval (e.g., \'Airframe rating: Boeing 737 series, Airbus A320 family; Engine rating: CFM56-7B; Component rating: Landing gear, hydraulics\').' ;
    rdfs:domain ind:ApprovedMaintenanceOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apuRatingFlag rdf:type rdf:Property ;
    rdfs:label 'Apu Rating Flag' ;
    rdfs:comment 'Indicates whether the organisation holds Auxiliary Power Unit (APU) maintenance rating approval.' ;
    rdfs:domain ind:ApprovedMaintenanceOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:auditFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Audit Findings Count' ;
    rdfs:comment 'Number of open audit findings or corrective action requests from the last audit.' ;
    rdfs:domain ind:ApprovedMaintenanceOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:avionicsRatingFlag rdf:type rdf:Property ;
    rdfs:label 'Avionics Rating Flag' ;
    rdfs:comment 'Indicates whether the organisation holds avionics and electrical systems maintenance rating approval.' ;
    rdfs:domain ind:ApprovedMaintenanceOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capabilityListReference rdf:type rdf:Property ;
    rdfs:label 'Capability List Reference' ;
    rdfs:comment 'Reference identifier or document number for the detailed capability list (CoA appendix) that enumerates specific aircraft types, engines, and components the organisation is approved to maintain.' ;
    rdfs:domain ind:ApprovedMaintenanceOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:city rdf:type rdf:Property ;
    rdfs:label 'City' ;
    rdfs:comment 'City where the maintenance organisation facility is located.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:componentRatingFlag rdf:type rdf:Property ;
    rdfs:label 'Component Rating Flag' ;
    rdfs:comment 'Indicates whether the organisation holds component maintenance rating approval (e.g., landing gear, avionics, hydraulics).' ;
    rdfs:domain ind:ApprovedMaintenanceOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractEndDate rdf:type rdf:Property ;
    rdfs:label 'Contract End Date' ;
    rdfs:comment 'Expiry or termination date of the commercial maintenance services contract. Null for open-ended contracts.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractStartDate rdf:type rdf:Property ;
    rdfs:label 'Contract Start Date' ;
    rdfs:comment 'Effective start date of the commercial maintenance services contract.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:countryCode rdf:type rdf:Property ;
    rdfs:label 'Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code where the maintenance organisation is registered and operates (e.g., DEU, USA, GBR).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engineRatingFlag rdf:type rdf:Property ;
    rdfs:label 'Engine Rating Flag' ;
    rdfs:comment 'Indicates whether the organisation holds engine maintenance rating approval.' ;
    rdfs:domain ind:ApprovedMaintenanceOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuingAuthority rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority' ;
    rdfs:comment 'National or regional aviation authority that issued the Part-145 approval certificate (e.g., EASA, FAA, CAAC, TCCA, CASA, ANAC, DGCA). [ENUM-REF-CANDIDATE: EASA|FAA|CAAC|TCCA|CASA|ANAC|DGCA — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastAuditDate rdf:type rdf:Property ;
    rdfs:label 'Last Audit Date' ;
    rdfs:comment 'Date of the most recent regulatory or internal audit conducted at the maintenance organisation.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextAuditDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Audit Due Date' ;
    rdfs:comment 'Scheduled date for the next regulatory surveillance audit or internal quality audit.' ;
    rdfs:domain ind:ApprovedMaintenanceOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:organizationCode rdf:type rdf:Property ;
    rdfs:label 'Organization Code' ;
    rdfs:comment 'Internal short code or identifier for the maintenance organisation used in operational systems.' ;
    rdfs:domain ind:ApprovedMaintenanceOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organizationName rdf:type rdf:Property ;
    rdfs:label 'Organization Name' ;
    rdfs:comment 'Legal name of the approved maintenance organisation (AMO) as registered with the issuing authority.' ;
    rdfs:domain ind:ApprovedMaintenanceOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organizationType rdf:type rdf:Property ;
    rdfs:label 'Organization Type' ;
    rdfs:comment 'Classification of the maintenance organisation: internal base maintenance, internal line maintenance, third-party MRO provider, OEM service center, component repair shop, or engine overhaul shop.' ;
    rdfs:domain ind:ApprovedMaintenanceOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postalCode rdf:type rdf:Property ;
    rdfs:label 'Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the maintenance organisation facility address.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredVendorFlag rdf:type rdf:Property ;
    rdfs:label 'Preferred Vendor Flag' ;
    rdfs:comment 'Indicates whether this maintenance organisation is designated as a preferred or strategic vendor for outsourced MRO services.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityRating rdf:type rdf:Property ;
    rdfs:label 'Quality Rating' ;
    rdfs:comment 'Internal quality performance rating score for the maintenance organisation, typically on a scale of 0.00 to 5.00, based on defect rates, on-time delivery, and audit results.' ;
    rdfs:domain ind:ApprovedMaintenanceOrg ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:addressLine1 rdf:type rdf:Property ;
    rdfs:label 'Address Line 1' ;
    rdfs:comment 'First line of the member\'s mailing address (street number and name).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addressLine2 rdf:type rdf:Property ;
    rdfs:label 'Address Line 2' ;
    rdfs:comment 'Second line of the member\'s mailing address (apartment, suite, unit number).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentMilesBalance rdf:type rdf:Property ;
    rdfs:label 'Current Miles Balance' ;
    rdfs:comment 'Current available miles or points balance that can be redeemed for awards, upgrades, or partner benefits. Reflects accruals minus redemptions and expirations.' ;
    rdfs:domain ind:FfpMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emailAddress rdf:type rdf:Property ;
    rdfs:label 'Email Address' ;
    rdfs:comment 'Primary email address for member communication, account notifications, and promotional offers.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emailConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Email Consent Flag' ;
    rdfs:comment 'Indicates whether the member has consented to receive email communications. True=consent given, False=opt-out.' ;
    rdfs:domain ind:FfpMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:enrollmentChannel rdf:type rdf:Property ;
    rdfs:label 'Enrollment Channel' ;
    rdfs:comment 'Channel through which the member enrolled in the FFP. Used for channel attribution and marketing analysis.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentDate rdf:type rdf:Property ;
    rdfs:label 'Enrollment Date' ;
    rdfs:comment 'Date when the member first enrolled in the FFP. Used for tenure-based benefits and anniversary promotions.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ffpNumber rdf:type rdf:Property ;
    rdfs:label 'Ffp Number' ;
    rdfs:comment 'Externally-known unique FFP membership number issued to the member. This is the business identifier used across all customer touchpoints, partner airlines, and GDS systems.' ;
    rdfs:domain ind:FfpMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:homeAirportCode rdf:type rdf:Property ;
    rdfs:label 'Home Airport Code' ;
    rdfs:comment 'Three-letter IATA airport code representing the member\'s primary departure airport. Used for targeted route promotions and service personalization.' ;
    rdfs:domain ind:FfpMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastActivityDate rdf:type rdf:Property ;
    rdfs:label 'Last Activity Date' ;
    rdfs:comment 'Date of the member\'s most recent FFP activity (flight, redemption, or partner transaction). Used for dormancy detection and reactivation campaigns.' ;
    rdfs:domain ind:FfpMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lifetimeMilesBalance rdf:type rdf:Property ;
    rdfs:label 'Lifetime Miles Balance' ;
    rdfs:comment 'Total cumulative miles or points earned by the member since enrollment, never decremented by redemptions. Used for lifetime status qualification.' ;
    rdfs:domain ind:FfpMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lifetimeStatusFlag rdf:type rdf:Property ;
    rdfs:label 'Lifetime Status Flag' ;
    rdfs:comment 'Indicates whether the member has achieved lifetime elite status, which is never revoked regardless of annual activity. True=lifetime status achieved, False=standard annual qualification.' ;
    rdfs:domain ind:FfpMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketingConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Marketing Consent Flag' ;
    rdfs:comment 'Indicates whether the member has consented to receive marketing communications and promotional offers. True=consent given, False=opt-out.' ;
    rdfs:domain ind:FfpMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mealPreference rdf:type rdf:Property ;
    rdfs:label 'Meal Preference' ;
    rdfs:comment 'Member\'s dietary preference or special meal request code (e.g., VGML=vegetarian, KSML=kosher, DBML=diabetic). Free-text or SSR code.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:memberFirstName rdf:type rdf:Property ;
    rdfs:label 'Member First Name' ;
    rdfs:comment 'First name (given name) of the FFP member as registered in the loyalty program.' ;
    rdfs:domain ind:FfpMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:memberLastName rdf:type rdf:Property ;
    rdfs:label 'Member Last Name' ;
    rdfs:comment 'Last name (family name) of the FFP member as registered in the loyalty program.' ;
    rdfs:domain ind:FfpMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:memberMiddleName rdf:type rdf:Property ;
    rdfs:label 'Member Middle Name' ;
    rdfs:comment 'Middle name or initial of the FFP member, if provided.' ;
    rdfs:domain ind:FfpMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:membershipStatus rdf:type rdf:Property ;
    rdfs:label 'Membership Status' ;
    rdfs:comment 'Current lifecycle status of the FFP membership. Active=member in good standing, Inactive=no recent activity, Suspended=temporarily restricted, Closed=permanently terminated, Pending=enrollment not yet complete.' ;
    rdfs:domain ind:FfpMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phoneNumber rdf:type rdf:Property ;
    rdfs:label 'Phone Number' ;
    rdfs:comment 'Primary contact phone number for the FFP member, including country code.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredCabinClass rdf:type rdf:Property ;
    rdfs:label 'Preferred Cabin Class' ;
    rdfs:comment 'Member\'s preferred cabin class for travel. Used for upgrade targeting and personalized offers.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredLanguage rdf:type rdf:Property ;
    rdfs:label 'Preferred Language' ;
    rdfs:comment 'Two-letter ISO 639-1 language code for member communication preferences.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredSeatType rdf:type rdf:Property ;
    rdfs:label 'Preferred Seat Type' ;
    rdfs:comment 'Member\'s preferred seat location on the aircraft.' ;
    rdfs:domain ind:FfpMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:smsConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Sms Consent Flag' ;
    rdfs:comment 'Indicates whether the member has consented to receive SMS/text message communications. True=consent given, False=opt-out.' ;
    rdfs:domain ind:FfpMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stateProvince rdf:type rdf:Property ;
    rdfs:label 'State Province' ;
    rdfs:comment 'State, province, or region of the member\'s mailing address.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Tier Expiration Date' ;
    rdfs:comment 'Date when the current tier status expires and will be re-evaluated based on qualifying activity.' ;
    rdfs:domain ind:FfpMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tierQualificationDate rdf:type rdf:Property ;
    rdfs:label 'Tier Qualification Date' ;
    rdfs:comment 'Date when the member achieved their current tier level.' ;
    rdfs:domain ind:FfpMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tierQualifyingMiles rdf:type rdf:Property ;
    rdfs:label 'Tier Qualifying Miles' ;
    rdfs:comment 'Miles earned in the current qualification period that count toward tier status. Typically excludes bonus miles and partner accruals.' ;
    rdfs:domain ind:FfpMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tierQualifyingSegments rdf:type rdf:Property ;
    rdfs:label 'Tier Qualifying Segments' ;
    rdfs:comment 'Number of flight segments flown in the current qualification period that count toward tier status.' ;
    rdfs:domain ind:FfpMember ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:awardBookingDiscountPercent rdf:type rdf:Property ;
    rdfs:label 'Award Booking Discount Percent' ;
    rdfs:comment 'Percentage discount applied to the mileage cost of award bookings for members at this tier level (e.g., 10.00 for 10% discount). Zero if no discount is provided.' ;
    rdfs:domain ind:TierStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:benefitsSummary rdf:type rdf:Property ;
    rdfs:label 'Benefits Summary' ;
    rdfs:comment 'Comprehensive text description of all benefits, privileges, and entitlements associated with this tier level. Used for member communications, marketing materials, and customer service reference.' ;
    rdfs:domain ind:TierStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bonusMileMultiplier rdf:type rdf:Property ;
    rdfs:label 'Bonus Mile Multiplier' ;
    rdfs:comment 'Multiplier applied to base miles earned on eligible flights for members holding this tier status (e.g., 1.25 for 25% bonus, 1.50 for 50% bonus). Used to calculate total accrued miles including tier bonuses.' ;
    rdfs:domain ind:TierStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:expirationDate rdf:type rdf:Property ;
    rdfs:label 'Expiration Date' ;
    rdfs:comment 'Date when this tier level definition was discontinued or superseded. Null for currently active tiers. Used for historical tracking and legacy member support.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:extraBaggageAllowanceKg rdf:type rdf:Property ;
    rdfs:label 'Extra Baggage Allowance Kg' ;
    rdfs:comment 'Additional checked baggage weight allowance in kilograms granted to members at this tier level beyond the standard fare allowance. Zero if no extra allowance is provided.' ;
    rdfs:domain ind:TierStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lifetimeStatusEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Lifetime Status Eligible Flag' ;
    rdfs:comment 'Indicates whether achieving this tier level contributes toward lifetime status qualification. True if this tier counts toward lifetime elite status milestones.' ;
    rdfs:domain ind:TierStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:partnerTierEquivalentCode rdf:type rdf:Property ;
    rdfs:label 'Partner Tier Equivalent Code' ;
    rdfs:comment 'Code representing the equivalent tier level in partner airline frequent flyer programs for reciprocal benefit recognition (e.g., Star Alliance Gold, oneworld Sapphire). Used for interline and codeshare benefit mapping.' ;
    rdfs:domain ind:TierStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityBaggageFlag rdf:type rdf:Property ;
    rdfs:label 'Priority Baggage Flag' ;
    rdfs:comment 'Indicates whether members at this tier level receive priority baggage handling, ensuring their checked luggage is among the first delivered at baggage claim. True if priority baggage handling is included.' ;
    rdfs:domain ind:TierStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorityCheckinFlag rdf:type rdf:Property ;
    rdfs:label 'Priority Checkin Flag' ;
    rdfs:comment 'Indicates whether members at this tier level have access to priority check-in counters and expedited check-in processes. True if priority check-in is a tier benefit.' ;
    rdfs:domain ind:TierStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualificationMilesThreshold rdf:type rdf:Property ;
    rdfs:label 'Qualification Miles Threshold' ;
    rdfs:comment 'Minimum number of qualifying miles a member must earn within the qualification period to achieve or maintain this tier status. Measured in miles flown on eligible flights.' ;
    rdfs:domain ind:TierStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualificationPeriodMonths rdf:type rdf:Property ;
    rdfs:label 'Qualification Period Months' ;
    rdfs:comment 'Number of months over which qualification activity is measured (e.g., 12 for calendar year, 24 for rolling two-year period). Defines the window for accumulating qualifying miles, segments, or spend.' ;
    rdfs:domain ind:TierStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualificationSegmentsThreshold rdf:type rdf:Property ;
    rdfs:label 'Qualification Segments Threshold' ;
    rdfs:comment 'Minimum number of qualifying flight segments a member must complete within the qualification period to achieve or maintain this tier status. One segment equals one takeoff and landing.' ;
    rdfs:domain ind:TierStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualificationSpendThreshold rdf:type rdf:Property ;
    rdfs:label 'Qualification Spend Threshold' ;
    rdfs:comment 'Minimum monetary spend amount on eligible flights required within the qualification period to achieve or maintain this tier status. Typically measured in the program\'s base currency.' ;
    rdfs:domain ind:TierStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tierCode rdf:type rdf:Property ;
    rdfs:label 'Tier Code' ;
    rdfs:comment 'Short alphanumeric code uniquely identifying the tier level within the FFP system (e.g., SLV, GLD, PLT, EXPL). Used as business identifier in operational systems.' ;
    rdfs:domain ind:TierStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierName rdf:type rdf:Property ;
    rdfs:label 'Tier Name' ;
    rdfs:comment 'Full marketing name of the tier level (e.g., Silver, Gold, Platinum, Executive Platinum). Human-readable label displayed to members and in customer communications.' ;
    rdfs:domain ind:TierStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierStatusStatus rdf:type rdf:Property ;
    rdfs:label 'Tier Status Status' ;
    rdfs:comment 'Current lifecycle status of the tier level within the program. Active tiers are available for member qualification; discontinued tiers are legacy levels no longer offered but may still have active members.' ;
    rdfs:domain ind:TierStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierValidityMonths rdf:type rdf:Property ;
    rdfs:label 'Tier Validity Months' ;
    rdfs:comment 'Number of months the tier status remains valid once earned, before re-qualification is required. Common values are 12 (annual) or 24 (biennial).' ;
    rdfs:domain ind:TierStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:upgradeEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Upgrade Eligibility Flag' ;
    rdfs:comment 'Indicates whether members at this tier level are eligible for complimentary or mileage-based cabin upgrades (e.g., economy to business, business to first). True if upgrade benefits are included.' ;
    rdfs:domain ind:TierStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waitlistPriorityRank rdf:type rdf:Property ;
    rdfs:label 'Waitlist Priority Rank' ;
    rdfs:comment 'Numeric priority ranking for waitlist clearance and standby processing. Lower numbers indicate higher priority. Used when multiple members are waitlisted for the same flight or upgrade.' ;
    rdfs:domain ind:TierStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tierQualificationId rdf:type rdf:Property ;
    rdfs:label 'Tier Qualification Id' ;
    rdfs:comment 'Unique identifier for the tier qualification record. Primary key.' ;
    rdfs:domain ind:TierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adjudicationNotes rdf:type rdf:Property ;
    rdfs:label 'Adjudication Notes' ;
    rdfs:comment 'Free-text notes recorded by FFP administrators during the adjudication of status match, tier challenge, or special qualification cases.' ;
    rdfs:domain ind:TierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:challengeActivityAchieved rdf:type rdf:Property ;
    rdfs:label 'Challenge Activity Achieved' ;
    rdfs:comment 'Description of the actual activity achieved by the member during the tier challenge period, used to determine challenge success.' ;
    rdfs:domain ind:TierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:challengeActivityRequired rdf:type rdf:Property ;
    rdfs:label 'Challenge Activity Required' ;
    rdfs:comment 'Description of the activity requirements (e.g., number of flights, miles, or spend) that the member must achieve during the tier challenge period to qualify.' ;
    rdfs:domain ind:TierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:challengeEndDate rdf:type rdf:Property ;
    rdfs:label 'Challenge End Date' ;
    rdfs:comment 'Date on which the tier challenge period ends and qualification is evaluated for members participating in a tier challenge program.' ;
    rdfs:domain ind:TierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:challengeStartDate rdf:type rdf:Property ;
    rdfs:label 'Challenge Start Date' ;
    rdfs:comment 'Date on which the tier challenge period commenced for members participating in a tier challenge program.' ;
    rdfs:domain ind:TierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:competingAirlineCode rdf:type rdf:Property ;
    rdfs:label 'Competing Airline Code' ;
    rdfs:comment 'IATA two-letter or three-letter airline code of the competing carrier from which the member held status for status match or tier challenge purposes.' ;
    rdfs:domain ind:TierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:competingTierHeld rdf:type rdf:Property ;
    rdfs:label 'Competing Tier Held' ;
    rdfs:comment 'Name or level of the elite tier held by the member with the competing airline at the time of status match or tier challenge request.' ;
    rdfs:domain ind:TierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:extensionExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Extension Expiry Date' ;
    rdfs:comment 'Date on which the tier extension period expires if an extension was granted.' ;
    rdfs:domain ind:TierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:extensionGrantedFlag rdf:type rdf:Property ;
    rdfs:label 'Extension Granted Flag' ;
    rdfs:comment 'Indicates whether a tier extension or grace period was granted to the member (True if extension granted, False otherwise).' ;
    rdfs:domain ind:TierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:extensionReason rdf:type rdf:Property ;
    rdfs:label 'Extension Reason' ;
    rdfs:comment 'Business reason for granting a tier extension (e.g., medical hardship, service recovery, loyalty gesture, pandemic exception).' ;
    rdfs:domain ind:TierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lifetimeMilesAccumulated rdf:type rdf:Property ;
    rdfs:label 'Lifetime Miles Accumulated' ;
    rdfs:comment 'Cumulative lifetime qualifying miles accumulated by the member across all qualification cycles, used for lifetime status determination.' ;
    rdfs:domain ind:TierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:matchApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Match Approval Date' ;
    rdfs:comment 'Date on which the status match or tier challenge request was approved by the FFP administration team.' ;
    rdfs:domain ind:TierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:matchOutcome rdf:type rdf:Property ;
    rdfs:label 'Match Outcome' ;
    rdfs:comment 'Outcome of the status match or tier challenge request: approved (status granted), denied (request rejected), pending (under review), or expired (request lapsed).' ;
    rdfs:domain ind:TierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proofOfStatusReference rdf:type rdf:Property ;
    rdfs:label 'Proof Of Status Reference' ;
    rdfs:comment 'Reference identifier or document number for the proof of status submitted by the member (e.g., membership card image, statement reference) for status match adjudication.' ;
    rdfs:domain ind:TierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationSourceBreakdown rdf:type rdf:Property ;
    rdfs:label 'Qualification Source Breakdown' ;
    rdfs:comment 'Detailed breakdown of the sources contributing to the qualification (e.g., own flights, partner airline flights, credit card spend, hotel stays, car rentals) with corresponding qualifying miles or segments.' ;
    rdfs:domain ind:TierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationStatus rdf:type rdf:Property ;
    rdfs:label 'Qualification Status' ;
    rdfs:comment 'Current status of the tier qualification: in progress (cycle active), qualified (tier achieved), not qualified (thresholds not met), extended (grace period granted), expired (tier period ended), or revoked (status removed).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationType rdf:type rdf:Property ;
    rdfs:label 'Qualification Type' ;
    rdfs:comment 'Type of qualification event: standard annual qualification based on activity, status match from competing airline, tier challenge program, lifetime status award, promotional grant, or courtesy status.' ;
    rdfs:domain ind:TierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationYear rdf:type rdf:Property ;
    rdfs:label 'Qualification Year' ;
    rdfs:comment 'Calendar year in which the tier qualification was earned or evaluated.' ;
    rdfs:domain ind:TierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualifyingMilesEarned rdf:type rdf:Property ;
    rdfs:label 'Qualifying Miles Earned' ;
    rdfs:comment 'Total qualifying miles (QM) earned by the member during the qualification period. Used to determine tier eligibility.' ;
    rdfs:domain ind:TierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualifyingSegmentsEarned rdf:type rdf:Property ;
    rdfs:label 'Qualifying Segments Earned' ;
    rdfs:comment 'Total number of qualifying flight segments (QS) flown by the member during the qualification period. Used to determine tier eligibility.' ;
    rdfs:domain ind:TierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualifyingSpendAmount rdf:type rdf:Property ;
    rdfs:label 'Qualifying Spend Amount' ;
    rdfs:comment 'Total qualifying spend (QSP) amount in base currency spent by the member on eligible flights and services during the qualification period. Used to determine tier eligibility.' ;
    rdfs:domain ind:TierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualifyingSpendCurrency rdf:type rdf:Property ;
    rdfs:label 'Qualifying Spend Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the qualifying spend amount.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rolloverMiles rdf:type rdf:Property ;
    rdfs:label 'Rollover Miles' ;
    rdfs:comment 'Excess qualifying miles earned beyond the tier threshold that may roll over to the next qualification cycle or contribute to lifetime status.' ;
    rdfs:domain ind:TierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tierAchieved rdf:type rdf:Property ;
    rdfs:label 'Tier Achieved' ;
    rdfs:comment 'The elite tier level achieved by the member as a result of this qualification (e.g., Silver, Gold, Platinum, Diamond, or lifetime tiers). [ENUM-REF-CANDIDATE: base|silver|gold|platinum|diamond|lifetime_gold|lifetime_platinum — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Tier Effective Date' ;
    rdfs:comment 'Date on which the achieved tier status becomes active and member benefits commence.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tierExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Tier Expiry Date' ;
    rdfs:comment 'Date on which the achieved tier status expires unless re-qualified. Null for lifetime status.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tierThresholdMiles rdf:type rdf:Property ;
    rdfs:label 'Tier Threshold Miles' ;
    rdfs:comment 'Minimum qualifying miles (QM) threshold required to achieve the tier for this qualification cycle.' ;
    rdfs:domain ind:TierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tierThresholdSegments rdf:type rdf:Property ;
    rdfs:label 'Tier Threshold Segments' ;
    rdfs:comment 'Minimum qualifying segments (QS) threshold required to achieve the tier for this qualification cycle.' ;
    rdfs:domain ind:TierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tierThresholdSpend rdf:type rdf:Property ;
    rdfs:label 'Tier Threshold Spend' ;
    rdfs:comment 'Minimum qualifying spend (QSP) threshold required to achieve the tier for this qualification cycle.' ;
    rdfs:domain ind:TierQualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bookingSegmentId rdf:type rdf:Property ;
    rdfs:label 'Booking Segment Id' ;
    rdfs:comment 'Foreign key linking to flight.booking_segment. Business justification: Mileage accrual must trace back to the specific booking segment (fare class, cabin, ticket number, boarding status) for audit, dispute resolution, and retroactive accrual claims. Aviation loyalty oper' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BookingSegment .

ind:partnerProgramId rdf:type rdf:Property ;
    rdfs:label 'Partner Program Id' ;
    rdfs:comment 'Foreign key linking to loyalty.partner_program. Business justification: mileage_accrual has partner_code (STRING) attribute indicating miles earned on partner airline flights. partner_program is the master table for partner agreements. Adding partner_program_id FK enables' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PartnerProgram .

ind:partnerTransactionId rdf:type rdf:Property ;
    rdfs:label 'Partner Transaction Id' ;
    rdfs:comment 'Foreign key linking to loyalty.partner_transaction. Business justification: mileage_accrual.partner_transaction_reference is a STRING denormalized reference to the originating partner transaction. When miles are earned through a partner (hotel, car rental, etc.), a partner_tr' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PartnerTransaction .

ind:reservationETicketId rdf:type rdf:Property ;
    rdfs:label 'Reservation E Ticket Id' ;
    rdfs:comment 'Foreign key linking to reservation.e_ticket. Business justification: Accrual records are posted FOR specific tickets. Structural link enables accrual reconciliation, audit, reversal processing. Business process: post-flight accrual posting, dispute resolution, ticket-t' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ETicket .

ind:accrualDate rdf:type rdf:Property ;
    rdfs:label 'Accrual Date' ;
    rdfs:comment 'Business date when the mileage-earning activity occurred (e.g., flight departure date, partner transaction date, purchase date). This is the real-world event date, distinct from posting date.' ;
    rdfs:domain ind:MileageAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accrualSourceType rdf:type rdf:Property ;
    rdfs:label 'Accrual Source Type' ;
    rdfs:comment 'Category of the mileage earning activity. Distinguishes between flight-based earnings, partner transactions, direct purchases, and manual adjustments. [ENUM-REF-CANDIDATE: flight|partner_airline|credit_card|hotel|car_rental|retail|purchase|adjustment|reinstatement — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MileageAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accrualStatus rdf:type rdf:Property ;
    rdfs:label 'Accrual Status' ;
    rdfs:comment 'Current lifecycle status of the mileage accrual transaction. Pending indicates awaiting validation or posting; posted indicates credited to member account; reversed indicates clawed back due to refund or fraud; expired indicates miles lapsed before use; cancelled indicates transaction voided.' ;
    rdfs:domain ind:MileageAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustmentNotes rdf:type rdf:Property ;
    rdfs:label 'Adjustment Notes' ;
    rdfs:comment 'Free-text explanation for manual adjustments. Captures customer service agent notes, retro-claim justification, or fraud investigation details. Null for standard accruals.' ;
    rdfs:domain ind:MileageAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseMiles rdf:type rdf:Property ;
    rdfs:label 'Base Miles' ;
    rdfs:comment 'Core mileage amount earned before any bonuses or multipliers. For flights, typically calculated from actual flown distance or fare class earning rate. For partners, based on transaction value or partner agreement.' ;
    rdfs:domain ind:MileageAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eliteBonusMiles rdf:type rdf:Property ;
    rdfs:label 'Elite Bonus Miles' ;
    rdfs:comment 'Additional miles earned due to member\'s elite tier status (e.g., Gold, Platinum, Diamond). Calculated as a percentage multiplier of base miles based on tier level.' ;
    rdfs:domain ind:MileageAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:eliteBonusMultiplier rdf:type rdf:Property ;
    rdfs:label 'Elite Bonus Multiplier' ;
    rdfs:comment 'Percentage multiplier applied to base miles for elite tier members (e.g., 1.25 for 25% bonus, 1.50 for 50% bonus). Zero or 1.00 for non-elite members.' ;
    rdfs:domain ind:MileageAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:milesExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Miles Expiry Date' ;
    rdfs:comment 'Date when the miles earned in this transaction will expire if not used. Null for programs with no expiration policy or lifetime miles.' ;
    rdfs:domain ind:MileageAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:pnr rdf:type rdf:Property ;
    rdfs:label 'Pnr' ;
    rdfs:comment 'Six-character alphanumeric booking reference for flight-based accruals. Links the mileage credit to the original reservation. Null for non-flight accruals.' ;
    rdfs:domain ind:MileageAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionalBonusMiles rdf:type rdf:Property ;
    rdfs:label 'Promotional Bonus Miles' ;
    rdfs:comment 'Additional miles earned through limited-time promotions, campaigns, or special offers (e.g., double miles promotion, new route bonus, seasonal campaign). Zero if no promotion applies.' ;
    rdfs:domain ind:MileageAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reversalDate rdf:type rdf:Property ;
    rdfs:label 'Reversal Date' ;
    rdfs:comment 'Date when the miles were reversed or clawed back from the member account. Null unless accrual_status is reversed.' ;
    rdfs:domain ind:MileageAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reversalReason rdf:type rdf:Property ;
    rdfs:label 'Reversal Reason' ;
    rdfs:comment 'Explanation for why miles were reversed after initial posting (e.g., ticket refund, fraudulent activity detected, duplicate posting, partner transaction cancelled). Null unless accrual_status is reversed.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalMilesCredited rdf:type rdf:Property ;
    rdfs:label 'Total Miles Credited' ;
    rdfs:comment 'Sum of base miles, elite bonus miles, and promotional bonus miles. This is the net amount credited to the member\'s account for this transaction.' ;
    rdfs:domain ind:MileageAccrual ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionAmount rdf:type rdf:Property ;
    rdfs:label 'Transaction Amount' ;
    rdfs:comment 'Monetary value of the partner transaction in the transaction currency for spend-based accruals (e.g., credit card purchase amount, hotel bill total). Null for distance-based flight accruals.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Transaction Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for partner transactions where miles are earned based on spend amount (e.g., credit card purchases, hotel stays). Null for distance-based flight accruals.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awardBookingReference rdf:type rdf:Property ;
    rdfs:label 'Award Booking Reference' ;
    rdfs:comment 'Passenger Name Record (PNR) or booking reference for award flight redemptions. Null for non-flight redemptions.' ;
    rdfs:domain ind:MileageRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:coPayAmount rdf:type rdf:Property ;
    rdfs:label 'Co Pay Amount' ;
    rdfs:comment 'Cash amount paid by the member in addition to miles for this redemption (e.g., taxes, fees, or partial cash payment for award).' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:coPayCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Co Pay Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the co-pay amount (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milesDiscountApplied rdf:type rdf:Property ;
    rdfs:label 'Miles Discount Applied' ;
    rdfs:comment 'Number of miles discounted due to promotional campaign or elite status benefit. Zero if no discount applied.' ;
    rdfs:domain ind:MileageRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:milesRedeemed rdf:type rdf:Property ;
    rdfs:label 'Miles Redeemed' ;
    rdfs:comment 'Total number of loyalty miles debited from the member account for this redemption transaction.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:partnerTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Partner Transaction Reference' ;
    rdfs:comment 'External transaction reference provided by the partner program for reconciliation. Null for airline-only redemptions.' ;
    rdfs:domain ind:MileageRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Processing Fee Amount' ;
    rdfs:comment 'Fee charged by the airline or partner for processing the redemption transaction (e.g., award booking fee, transfer fee).' ;
    rdfs:domain ind:MileageRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processingFeeCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Processing Fee Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the processing fee.' ;
    rdfs:domain ind:MileageRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionChannel rdf:type rdf:Property ;
    rdfs:label 'Redemption Channel' ;
    rdfs:comment 'Channel through which the member initiated the redemption: airline website, mobile app, call center, airport counter, partner portal, or self-service kiosk.' ;
    rdfs:domain ind:MileageRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionNotes rdf:type rdf:Property ;
    rdfs:label 'Redemption Notes' ;
    rdfs:comment 'Free-text notes or comments about the redemption transaction, captured by agent or system for audit and customer service purposes.' ;
    rdfs:domain ind:MileageRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionStatus rdf:type rdf:Property ;
    rdfs:label 'Redemption Status' ;
    rdfs:comment 'Current lifecycle status of the redemption transaction: requested (pending), confirmed (approved), ticketed (award ticket issued), cancelled (member cancelled), refunded (miles returned), or expired (award not used).' ;
    rdfs:domain ind:MileageRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Redemption Timestamp' ;
    rdfs:comment 'Date and time when the redemption transaction was initiated by the member or agent.' ;
    rdfs:domain ind:MileageRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:redemptionTransactionNumber rdf:type rdf:Property ;
    rdfs:label 'Redemption Transaction Number' ;
    rdfs:comment 'Externally-visible unique transaction number for the redemption event, used for customer service and reconciliation.' ;
    rdfs:domain ind:MileageRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionType rdf:type rdf:Property ;
    rdfs:label 'Redemption Type' ;
    rdfs:comment 'Category of redemption: award flight booking, cabin upgrade, partner airline/hotel reward, merchandise purchase, charity donation, peer-to-peer miles transfer, miles purchase with cash co-pay, or co-pay booking combining miles and cash. [ENUM-REF-CANDIDATE: award_flight|upgrade|partner_reward|merchandise|charity_donation|miles_transfer|purchase_miles|co_pay_booking — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MileageRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundMiles rdf:type rdf:Property ;
    rdfs:label 'Refund Miles' ;
    rdfs:comment 'Number of miles returned to the member account upon cancellation or refund of the redemption. Zero if no refund occurred.' ;
    rdfs:domain ind:MileageRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transferFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Transfer Fee Amount' ;
    rdfs:comment 'Fee charged for transferring miles to another member. Null for non-transfer redemptions.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transferFeeCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Transfer Fee Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the transfer fee.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferRecipientFfpNumber rdf:type rdf:Property ;
    rdfs:label 'Transfer Recipient Ffp Number' ;
    rdfs:comment 'FFP membership number of the recipient member for peer-to-peer miles transfers or family pooling. Null for non-transfer redemptions.' ;
    rdfs:domain ind:MileageRedemption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferType rdf:type rdf:Property ;
    rdfs:label 'Transfer Type' ;
    rdfs:comment 'Type of miles transfer: gift (peer-to-peer gifting), family_pool (pooling within family account), purchase (buying miles for another member), or none (not a transfer redemption).' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milesBalanceId rdf:type rdf:Property ;
    rdfs:label 'Miles Balance Id' ;
    rdfs:comment 'Unique identifier for the miles balance ledger record. Primary key for the miles balance entity.' ;
    rdfs:domain ind:MilesBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountInceptionDate rdf:type rdf:Property ;
    rdfs:label 'Account Inception Date' ;
    rdfs:comment 'Date when the member first enrolled in the FFP and the miles balance account was created. Used for member tenure analysis and lifetime value calculation.' ;
    rdfs:domain ind:MilesBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:balanceAsOfTimestamp rdf:type rdf:Property ;
    rdfs:label 'Balance As Of Timestamp' ;
    rdfs:comment 'Timestamp indicating when this balance snapshot was calculated. Critical for point-in-time balance queries and historical balance reconstruction.' ;
    rdfs:domain ind:MilesBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:balanceCalculationMethod rdf:type rdf:Property ;
    rdfs:label 'Balance Calculation Method' ;
    rdfs:comment 'Method used to calculate this balance snapshot. Real-time balances are updated transactionally; batch balances are calculated in nightly runs; reconciled balances include manual adjustments.' ;
    rdfs:domain ind:MilesBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:balanceLastUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Balance Last Updated Timestamp' ;
    rdfs:comment 'Timestamp when this balance record was last modified by any transaction or adjustment. Used for data freshness validation and audit trail.' ;
    rdfs:domain ind:MilesBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:balanceStatus rdf:type rdf:Property ;
    rdfs:label 'Balance Status' ;
    rdfs:comment 'Current lifecycle status of the miles balance account. Active accounts allow accrual and redemption; suspended accounts are temporarily restricted; frozen accounts are under investigation; closed accounts are terminated.' ;
    rdfs:domain ind:MilesBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:balanceVersionNumber rdf:type rdf:Property ;
    rdfs:label 'Balance Version Number' ;
    rdfs:comment 'Version number of this balance record, incremented with each update. Used for optimistic locking and concurrency control in real-time balance updates.' ;
    rdfs:domain ind:MilesBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bonusMilesBalance rdf:type rdf:Property ;
    rdfs:label 'Bonus Miles Balance' ;
    rdfs:comment 'Subset of total miles balance earned through promotional campaigns, partner bonuses, or special offers. Tracked separately for marketing attribution analysis.' ;
    rdfs:domain ind:MilesBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eliteBonusMilesYtd rdf:type rdf:Property ;
    rdfs:label 'Elite Bonus Miles Ytd' ;
    rdfs:comment 'Additional miles earned year-to-date as elite tier status bonuses (e.g., 25%, 50%, 100% bonus on base miles). Separate from base miles for tier benefit tracking.' ;
    rdfs:domain ind:MilesBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isLifetimeStatusQualified rdf:type rdf:Property ;
    rdfs:label 'Is Lifetime Status Qualified' ;
    rdfs:comment 'Boolean flag indicating whether the member has achieved lifetime elite status qualification based on lifetime miles earned or lifetime qualifying criteria. True if qualified, False otherwise.' ;
    rdfs:domain ind:MilesBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastAccrualDate rdf:type rdf:Property ;
    rdfs:label 'Last Accrual Date' ;
    rdfs:comment 'Date of the most recent miles accrual transaction posted to this account. Used for account activity monitoring and dormancy detection.' ;
    rdfs:domain ind:MilesBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastRedemptionDate rdf:type rdf:Property ;
    rdfs:label 'Last Redemption Date' ;
    rdfs:comment 'Date of the most recent miles redemption transaction posted to this account. Used for member engagement analysis and redemption pattern tracking.' ;
    rdfs:domain ind:MilesBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastTransactionDate rdf:type rdf:Property ;
    rdfs:label 'Last Transaction Date' ;
    rdfs:comment 'Date of the most recent transaction (accrual or redemption) posted to this account. Used for account activity monitoring and expiration policy enforcement.' ;
    rdfs:domain ind:MilesBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lifetimeMilesEarned rdf:type rdf:Property ;
    rdfs:label 'Lifetime Miles Earned' ;
    rdfs:comment 'Cumulative total of all miles earned by the member since program enrollment. Used for lifetime status qualification and member recognition. Never decreases.' ;
    rdfs:domain ind:MilesBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lifetimeMilesRedeemed rdf:type rdf:Property ;
    rdfs:label 'Lifetime Miles Redeemed' ;
    rdfs:comment 'Cumulative total of all miles redeemed by the member since program enrollment. Used for member engagement analytics and redemption behavior analysis.' ;
    rdfs:domain ind:MilesBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:memberNumber rdf:type rdf:Property ;
    rdfs:label 'Member Number' ;
    rdfs:comment 'The externally-known FFP membership number assigned to the member. Used for member identification across all touchpoints.' ;
    rdfs:domain ind:MilesBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milesExpiring180Days rdf:type rdf:Property ;
    rdfs:label 'Miles Expiring 180 Days' ;
    rdfs:comment 'Total miles scheduled to expire within the next 180 days based on program expiration policy. Used for proactive member engagement and redemption encouragement.' ;
    rdfs:domain ind:MilesBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:milesExpiring90Days rdf:type rdf:Property ;
    rdfs:label 'Miles Expiring 90 Days' ;
    rdfs:comment 'Total miles scheduled to expire within the next 90 days based on program expiration policy. Used for member communication and retention campaigns.' ;
    rdfs:domain ind:MilesBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Next Expiration Date' ;
    rdfs:comment 'Date when the next batch of miles is scheduled to expire based on program expiration policy. Used for member notification and retention campaigns.' ;
    rdfs:domain ind:MilesBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:onHoldMiles rdf:type rdf:Property ;
    rdfs:label 'On Hold Miles' ;
    rdfs:comment 'Miles temporarily held and unavailable for redemption due to fraud investigation, dispute resolution, or account review. Released once issue is resolved.' ;
    rdfs:domain ind:MilesBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:partnerMilesBalance rdf:type rdf:Property ;
    rdfs:label 'Partner Miles Balance' ;
    rdfs:comment 'Subset of total miles balance earned through partner airline flights, hotel stays, car rentals, credit card spend, or coalition program activities. Tracked for partner settlement.' ;
    rdfs:domain ind:MilesBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pendingMiles rdf:type rdf:Property ;
    rdfs:label 'Pending Miles' ;
    rdfs:comment 'Miles that have been earned but not yet posted to the redeemable balance. Typically includes miles from recent flights or partner transactions awaiting verification.' ;
    rdfs:domain ind:MilesBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualificationYearEndDate rdf:type rdf:Property ;
    rdfs:label 'Qualification Year End Date' ;
    rdfs:comment 'End date of the current qualification year for elite tier status. QM, QS, and QSP counters reset after this date.' ;
    rdfs:domain ind:MilesBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualificationYearStartDate rdf:type rdf:Property ;
    rdfs:label 'Qualification Year Start Date' ;
    rdfs:comment 'Start date of the current qualification year for elite tier status. Typically calendar year or membership anniversary date depending on program rules.' ;
    rdfs:domain ind:MilesBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualifyingMilesYtd rdf:type rdf:Property ;
    rdfs:label 'Qualifying Miles Ytd' ;
    rdfs:comment 'Total qualifying miles earned year-to-date that count toward elite tier status qualification. QM are typically based on distance flown and fare class, excluding bonus miles.' ;
    rdfs:domain ind:MilesBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualifyingSegmentsYtd rdf:type rdf:Property ;
    rdfs:label 'Qualifying Segments Ytd' ;
    rdfs:comment 'Total number of qualifying flight segments flown year-to-date that count toward elite tier status qualification. Each eligible flight leg counts as one segment.' ;
    rdfs:domain ind:MilesBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:qualifyingSpendYtd rdf:type rdf:Property ;
    rdfs:label 'Qualifying Spend Ytd' ;
    rdfs:comment 'Total qualifying spend amount year-to-date that counts toward elite tier status qualification. Typically based on ticket price paid, excluding taxes and fees.' ;
    rdfs:domain ind:MilesBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:redeemableMiles rdf:type rdf:Property ;
    rdfs:label 'Redeemable Miles' ;
    rdfs:comment 'Subset of total miles balance that is currently available for redemption. Excludes miles that are pending, on hold, or not yet eligible for use.' ;
    rdfs:domain ind:MilesBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalMilesBalance rdf:type rdf:Property ;
    rdfs:label 'Total Miles Balance' ;
    rdfs:comment 'Total accumulated miles currently available in the member account, including all earned miles minus all redeemed miles. This is the authoritative running balance.' ;
    rdfs:domain ind:MilesBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:awardBookingId rdf:type rdf:Property ;
    rdfs:label 'Award Booking Id' ;
    rdfs:comment 'Unique identifier for the award flight booking. Primary key for the award booking record.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AwardBooking .

ind:awardType rdf:type rdf:Property ;
    rdfs:label 'Award Type' ;
    rdfs:comment 'Classification of the award booking type. Saver awards require fewer miles but have limited availability; standard awards have higher mileage cost but greater availability; upgrade awards convert paid tickets to higher cabin; companion awards allow a second passenger at reduced miles; mixed cabin combines different service classes; partner awards are on codeshare or alliance airlines.' ;
    rdfs:domain ind:AwardBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookingChannel rdf:type rdf:Property ;
    rdfs:label 'Booking Channel' ;
    rdfs:comment 'Channel through which the award booking was made. Web indicates airline website; mobile app is the carrier\'s mobile application; call center is telephone reservation; airport counter is in-person booking; partner portal is through alliance or coalition partner; GDS is Global Distribution System booking.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Booking Timestamp' ;
    rdfs:comment 'Date and time when the award booking was created in the reservation system. Represents the moment the member initiated the award redemption.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cancellationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cancellation Timestamp' ;
    rdfs:comment 'Date and time when the award booking was cancelled. Null if booking has not been cancelled. Represents when the member or system terminated the reservation.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:copayAmount rdf:type rdf:Property ;
    rdfs:label 'Copay Amount' ;
    rdfs:comment 'Monetary amount paid by the member in addition to miles for this award booking. Covers taxes, fees, and carrier-imposed surcharges not covered by miles.' ;
    rdfs:domain ind:AwardBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:copayCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Copay Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the co-pay amount. Indicates the currency in which taxes and fees were charged.' ;
    rdfs:domain ind:AwardBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPartnerAward rdf:type rdf:Property ;
    rdfs:label 'Is Partner Award' ;
    rdfs:comment 'Boolean flag indicating whether this award booking involves travel on a partner airline (alliance member or codeshare partner) rather than the marketing carrier\'s own metal.' ;
    rdfs:domain ind:AwardBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isRoundTrip rdf:type rdf:Property ;
    rdfs:label 'Is Round Trip' ;
    rdfs:comment 'Boolean flag indicating whether this is a round-trip award booking (true) or one-way (false). Round-trip awards include both outbound and return travel.' ;
    rdfs:domain ind:AwardBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:numberOfSegments rdf:type rdf:Property ;
    rdfs:label 'Number Of Segments' ;
    rdfs:comment 'Total count of flight segments (individual flight legs) included in this award booking itinerary. Multi-segment awards involve connections.' ;
    rdfs:domain ind:AwardBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:refundFeeMiles rdf:type rdf:Property ;
    rdfs:label 'Refund Fee Miles' ;
    rdfs:comment 'Number of FFP miles charged as a cancellation or change fee when refunding the award booking. Represents the penalty for award cancellation.' ;
    rdfs:domain ind:AwardBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:refundMilesAmount rdf:type rdf:Property ;
    rdfs:label 'Refund Miles Amount' ;
    rdfs:comment 'Number of FFP miles returned to the member account upon cancellation or refund of the award booking. May be less than original redemption if cancellation fees apply.' ;
    rdfs:domain ind:AwardBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ticketingStatus rdf:type rdf:Property ;
    rdfs:label 'Ticketing Status' ;
    rdfs:comment 'Current status of e-ticket issuance for the award booking. Not ticketed means reservation exists but no ticket issued; ticketed means e-ticket generated; voided indicates ticket cancelled before travel; refunded means ticket cancelled with miles returned; exchanged means ticket modified for different travel.' ;
    rdfs:domain ind:AwardBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ticketingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Ticketing Timestamp' ;
    rdfs:comment 'Date and time when the award e-ticket was issued. Null if booking has not been ticketed. Represents when the reservation was converted to a confirmed ticket.' ;
    rdfs:domain ind:AwardBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:totalMilesRedeemed rdf:type rdf:Property ;
    rdfs:label 'Total Miles Redeemed' ;
    rdfs:comment 'Total number of FFP miles debited from the member account for this award booking. Represents the mileage cost across all passengers and segments.' ;
    rdfs:domain ind:AwardBooking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:waitlistPosition rdf:type rdf:Property ;
    rdfs:label 'Waitlist Position' ;
    rdfs:comment 'Numeric position in the waitlist queue for this award booking. Lower numbers indicate higher priority. Null if not waitlisted.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accrualDelayDays rdf:type rdf:Property ;
    rdfs:label 'Accrual Delay Days' ;
    rdfs:comment 'Number of days after a qualifying partner transaction before earned miles are posted to the member account. Allows for transaction validation and fraud prevention.' ;
    rdfs:domain ind:PartnerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:agreementEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Agreement Effective Date' ;
    rdfs:comment 'Date when the partner agreement becomes active and earn/burn transactions are permitted. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:agreementExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Agreement Expiry Date' ;
    rdfs:comment 'Date when the partner agreement terminates. Null for evergreen agreements with no fixed end date. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:autoEnrollmentFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Enrollment Flag' ;
    rdfs:comment 'Indicates whether Airlines FFP members are automatically enrolled in the partner loyalty program for seamless earn/burn. True if auto-enrollment is enabled.' ;
    rdfs:domain ind:PartnerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bonusMileEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Bonus Mile Eligibility Flag' ;
    rdfs:comment 'Indicates whether transactions with this partner are eligible for promotional bonus mile campaigns and tier multipliers. True if eligible.' ;
    rdfs:domain ind:PartnerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:burnRate rdf:type rdf:Property ;
    rdfs:label 'Burn Rate' ;
    rdfs:comment 'Redemption rate for using FFP miles with this partner, expressed as miles required per reward unit (e.g., miles per free night, miles per rental day, miles per dollar value).' ;
    rdfs:domain ind:PartnerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:burnUnit rdf:type rdf:Property ;
    rdfs:label 'Burn Unit' ;
    rdfs:comment 'Unit of measure for the burn rate calculation (e.g., per hotel night redeemed, per car rental day, per dollar value of merchandise). [ENUM-REF-CANDIDATE: night|day|dollar|euro|pound|item|service — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PartnerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:earnRate rdf:type rdf:Property ;
    rdfs:label 'Earn Rate' ;
    rdfs:comment 'Base mileage accrual rate for member transactions with this partner, expressed as miles earned per unit (dollar, euro, night, rental day, etc.). Subject to tier multipliers and promotions.' ;
    rdfs:domain ind:PartnerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:earnUnit rdf:type rdf:Property ;
    rdfs:label 'Earn Unit' ;
    rdfs:comment 'Unit of measure for the earn rate calculation (e.g., per dollar spent, per hotel night, per car rental day). [ENUM-REF-CANDIDATE: dollar|euro|pound|night|day|transaction|point — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PartnerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumEarnPerTransaction rdf:type rdf:Property ;
    rdfs:label 'Maximum Earn Per Transaction' ;
    rdfs:comment 'Maximum number of miles that can be earned in a single transaction with this partner. Null if no cap applies. Prevents abuse and controls liability.' ;
    rdfs:domain ind:PartnerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumTransactionAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Transaction Amount' ;
    rdfs:comment 'Minimum transaction value (in settlement currency) required for a partner transaction to qualify for mileage accrual. Null if no minimum applies.' ;
    rdfs:domain ind:PartnerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partnerContactEmail rdf:type rdf:Property ;
    rdfs:label 'Partner Contact Email' ;
    rdfs:comment 'Primary email address for the partner business contact. Used for operational communications, settlement queries, and program updates.' ;
    rdfs:domain ind:PartnerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerContactName rdf:type rdf:Property ;
    rdfs:label 'Partner Contact Name' ;
    rdfs:comment 'Full name of the primary business contact at the partner organization responsible for FFP program coordination and issue resolution.' ;
    rdfs:domain ind:PartnerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerContactPhone rdf:type rdf:Property ;
    rdfs:label 'Partner Contact Phone' ;
    rdfs:comment 'Primary telephone number for the partner business contact, including country code and extension where applicable.' ;
    rdfs:domain ind:PartnerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerCountryCode rdf:type rdf:Property ;
    rdfs:label 'Partner Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code for the partners primary country of operation or headquarters location.' ;
    rdfs:domain ind:PartnerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerName rdf:type rdf:Property ;
    rdfs:label 'Partner Name' ;
    rdfs:comment 'Legal or trading name of the FFP earn/burn partner organization (e.g., Marriott Hotels, Hertz Car Rental, Chase Bank).' ;
    rdfs:domain ind:PartnerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerProgramCode rdf:type rdf:Property ;
    rdfs:label 'Partner Program Code' ;
    rdfs:comment 'Short alphanumeric code used in operational systems to identify this partner program in transaction records, reports, and member statements.' ;
    rdfs:domain ind:PartnerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerTaxNumber rdf:type rdf:Property ;
    rdfs:label 'Partner Tax Number' ;
    rdfs:comment 'Tax identification number or business registration number for the partner organization. Used for financial settlement and regulatory compliance.' ;
    rdfs:domain ind:PartnerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerType rdf:type rdf:Property ;
    rdfs:label 'Partner Type' ;
    rdfs:comment 'Classification of the partner organization by business category. Determines applicable earn/burn rules and integration requirements. [ENUM-REF-CANDIDATE: airline_codeshare|hotel|car_rental|credit_card|retail|telecom|dining|travel_services — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PartnerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerWebsiteUrl rdf:type rdf:Property ;
    rdfs:label 'Partner Website Url' ;
    rdfs:comment 'Primary website URL for the partner organization. Used for member communications and marketing materials promoting partner earn/burn opportunities.' ;
    rdfs:domain ind:PartnerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionBlackoutFlag rdf:type rdf:Property ;
    rdfs:label 'Redemption Blackout Flag' ;
    rdfs:comment 'Indicates whether this partner imposes blackout dates or capacity restrictions on award redemptions. True if blackouts apply.' ;
    rdfs:domain ind:PartnerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:settlementFrequency rdf:type rdf:Property ;
    rdfs:label 'Settlement Frequency' ;
    rdfs:comment 'Frequency at which financial reconciliation and settlement occurs between Airlines and the partner for accrued earn/burn transactions.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierRecognitionFlag rdf:type rdf:Property ;
    rdfs:label 'Tier Recognition Flag' ;
    rdfs:comment 'Indicates whether the partner honors Airlines FFP elite tier status with reciprocal benefits (e.g., priority service, upgrades, bonus earn). True if tier benefits apply.' ;
    rdfs:domain ind:PartnerProgram ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:originalTransactionPartnerTransactionId rdf:type rdf:Property ;
    rdfs:label 'Original Transaction Partner Transaction Id' ;
    rdfs:comment 'Reference to the original partner transaction ID if this record is a reversal or adjustment of a prior transaction.' ;
    rdfs:domain ind:PartnerTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PartnerTransaction .

ind:baseMilesAwarded rdf:type rdf:Property ;
    rdfs:label 'Base Miles Awarded' ;
    rdfs:comment 'Number of base FFP miles earned or redeemed through this partner transaction, calculated per the partner agreement earn/burn rate.' ;
    rdfs:domain ind:PartnerTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bonusMilesAwarded rdf:type rdf:Property ;
    rdfs:label 'Bonus Miles Awarded' ;
    rdfs:comment 'Number of bonus or promotional miles awarded in addition to base miles, based on member tier status, promotional campaigns, or partner-specific bonuses.' ;
    rdfs:domain ind:Loyalty ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:disputeFlag rdf:type rdf:Property ;
    rdfs:label 'Dispute Flag' ;
    rdfs:comment 'Indicates whether this partner transaction is under dispute by the member or partner (true if disputed, false otherwise).' ;
    rdfs:domain ind:PartnerTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:disputeReason rdf:type rdf:Property ;
    rdfs:label 'Dispute Reason' ;
    rdfs:comment 'Description of the reason for dispute if the transaction is flagged for dispute (e.g., miles not posted, incorrect amount, transaction not recognized).' ;
    rdfs:domain ind:PartnerTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:earnRateMultiplier rdf:type rdf:Property ;
    rdfs:label 'Earn Rate Multiplier' ;
    rdfs:comment 'Multiplier applied to calculate miles earned per unit of partner transaction amount, as defined in the partner agreement (e.g., 1.5 miles per dollar spent).' ;
    rdfs:domain ind:PartnerTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:memberTierAtTransaction rdf:type rdf:Property ;
    rdfs:label 'Member Tier At Transaction' ;
    rdfs:comment 'FFP tier status of the member at the time of the partner transaction (e.g., Silver, Gold, Platinum), which may affect bonus miles calculation.' ;
    rdfs:domain ind:PartnerTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerCategory rdf:type rdf:Property ;
    rdfs:label 'Partner Category' ;
    rdfs:comment 'Category of partner business type (hotel, car rental, credit card issuer, retail merchant, dining, travel services).' ;
    rdfs:domain ind:PartnerTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerLocationCity rdf:type rdf:Property ;
    rdfs:label 'Partner Location City' ;
    rdfs:comment 'City where the partner transaction occurred.' ;
    rdfs:domain ind:PartnerTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerLocationCode rdf:type rdf:Property ;
    rdfs:label 'Partner Location Code' ;
    rdfs:comment 'Code identifying the specific partner location where the transaction occurred (e.g., hotel property code, car rental branch code, retail store identifier).' ;
    rdfs:domain ind:PartnerTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerLocationCountryCode rdf:type rdf:Property ;
    rdfs:label 'Partner Location Country Code' ;
    rdfs:comment 'Three-letter ISO country code where the partner transaction occurred.' ;
    rdfs:domain ind:PartnerTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerLocationName rdf:type rdf:Property ;
    rdfs:label 'Partner Location Name' ;
    rdfs:comment 'Descriptive name of the partner location where the transaction occurred (e.g., Marriott Times Square, Hertz LAX Airport).' ;
    rdfs:domain ind:PartnerTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationDate rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Date' ;
    rdfs:comment 'Date when this transaction was reconciled with the partner for settlement purposes.' ;
    rdfs:domain ind:PartnerTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reversalFlag rdf:type rdf:Property ;
    rdfs:label 'Reversal Flag' ;
    rdfs:comment 'Indicates whether this transaction is a reversal of a previous partner transaction (true if reversal, false otherwise).' ;
    rdfs:domain ind:PartnerTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:settlementAmount rdf:type rdf:Property ;
    rdfs:label 'Settlement Amount' ;
    rdfs:comment 'Amount paid or received by Airlines for this partner transaction as part of the partner revenue-sharing or cost-sharing agreement.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceSystemTransactionCode rdf:type rdf:Property ;
    rdfs:label 'Source System Transaction Code' ;
    rdfs:comment 'Unique transaction identifier in the source system or partner platform, used for traceability and audit.' ;
    rdfs:domain ind:PartnerTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalMiles rdf:type rdf:Property ;
    rdfs:label 'Total Miles' ;
    rdfs:comment 'Total miles awarded or redeemed in this transaction (sum of base miles and bonus miles).' ;
    rdfs:domain ind:PartnerTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transactionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transaction Timestamp' ;
    rdfs:comment 'Precise timestamp when the partner transaction was recorded in the partner system, including time zone information.' ;
    rdfs:domain ind:PartnerTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualCost rdf:type rdf:Property ;
    rdfs:label 'Actual Cost' ;
    rdfs:comment 'Actual total financial cost incurred by the promotion after completion, calculated from bonus miles awarded and their valuation. Used for ROI (Return on Investment) analysis. Business-sensitive financial data.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bonusMilesFormula rdf:type rdf:Property ;
    rdfs:label 'Bonus Miles Formula' ;
    rdfs:comment 'Business rule or formula defining how bonus miles are calculated (e.g., \'2x base miles\', \'flat 5000 miles\', \'base_miles * 1.5 + 1000\'). Free-text expression used by accrual engine. Measurement/value category for the promotion.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:communicationChannel rdf:type rdf:Property ;
    rdfs:label 'Communication Channel' ;
    rdfs:comment 'Primary channel(s) used to communicate the promotion to members (email, SMS, push notification, in-app message, website banner, or all). Used for campaign execution and member engagement.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibleMemberTiers rdf:type rdf:Property ;
    rdfs:label 'Eligible Member Tiers' ;
    rdfs:comment 'Comma-separated list of FFP (Frequent Flyer Program) member tier codes eligible to participate (e.g., \'SILVER,GOLD,PLATINUM\' or \'ALL\'). Empty or \'ALL\' indicates no tier restriction.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligiblePartners rdf:type rdf:Property ;
    rdfs:label 'Eligible Partners' ;
    rdfs:comment 'Comma-separated list of partner airline IATA codes or coalition partner identifiers eligible for bonus earn (e.g., \'AA,BA,QF\' for airline partners or \'HOTEL_CHAIN_X\' for non-air partners). Empty or \'ALL\' indicates no partner restriction.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:endDate rdf:type rdf:Property ;
    rdfs:label 'End Date' ;
    rdfs:comment 'Date when the promotion expires and no further bonus accruals are allowed. Effective-until date for the promotion. Nullable for open-ended promotions.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:estimatedCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Cost' ;
    rdfs:comment 'Estimated total financial cost or liability of the promotion in the airline\'s reporting currency (e.g., USD). Used for budgeting and financial planning. Business-sensitive financial data.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:externalPromotionCode rdf:type rdf:Property ;
    rdfs:label 'External Promotion Code' ;
    rdfs:comment 'Unique identifier for the promotion in the source operational system (e.g., Oracle Loyalty Cloud promotion ID). Used for cross-system reconciliation and data lineage.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastModifiedBy rdf:type rdf:Property ;
    rdfs:label 'Last Modified By' ;
    rdfs:comment 'User ID or name of the staff who last updated the promotion record. Used for audit trail and change tracking.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumBonusCap rdf:type rdf:Property ;
    rdfs:label 'Maximum Bonus Cap' ;
    rdfs:comment 'Maximum total bonus miles a member can earn under this promotion. Null indicates no cap. Used to control promotion liability and prevent abuse.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:optInCount rdf:type rdf:Property ;
    rdfs:label 'Opt In Count' ;
    rdfs:comment 'Total number of members who have opted into this promotion. Updated in real-time or batch. Used for campaign performance measurement.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:optInRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Opt In Required Flag' ;
    rdfs:comment 'Indicates whether members must explicitly opt-in or register for the promotion (true) or if it is automatically applied to eligible members (false). Used for campaign engagement tracking.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:promotionCode rdf:type rdf:Property ;
    rdfs:label 'Promotion Code' ;
    rdfs:comment 'Externally-known unique alphanumeric code identifying the promotion (e.g., DOUBLE2024, TIERBOOST). Used by members to opt-in or by system to auto-apply. Business identifier for the promotion.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionDescription rdf:type rdf:Property ;
    rdfs:label 'Promotion Description' ;
    rdfs:comment 'Detailed marketing description of the promotion, including terms, conditions, and member benefits. Used for customer communication and internal reference.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionName rdf:type rdf:Property ;
    rdfs:label 'Promotion Name' ;
    rdfs:comment 'Human-readable marketing name of the promotion (e.g., \'Summer Double Miles\', \'Elite Status Challenge\'). Identity label for the promotion.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionStatus rdf:type rdf:Property ;
    rdfs:label 'Promotion Status' ;
    rdfs:comment 'Current lifecycle state of the promotion: draft (being designed), scheduled (approved, not yet started), active (currently running), paused (temporarily suspended), completed (ended successfully), cancelled (terminated before completion). Lifecycle status for the promotion.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionType rdf:type rdf:Property ;
    rdfs:label 'Promotion Type' ;
    rdfs:comment 'Classification of the promotional campaign mechanism: double_miles (2x earn rate), triple_miles (3x earn rate), tier_challenge (accelerated tier qualification), status_match (match competitor status), bonus_on_route (extra miles on specific routes), partner_bonus (bonus on partner airline or coalition earn), upgrade_bonus (complimentary or discounted upgrades). Classification category for the promotion. [ENUM-REF-CANDIDATE: double_miles|triple_miles|tier_challenge|status_match|bonus_on_route|partner_bonus|upgrade_bonus — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:redemptionCount rdf:type rdf:Property ;
    rdfs:label 'Redemption Count' ;
    rdfs:comment 'Total number of transactions or bookings where this promotion was successfully applied and bonus miles were awarded. Used for ROI (Return on Investment) analysis and campaign effectiveness.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:startDate rdf:type rdf:Property ;
    rdfs:label 'Start Date' ;
    rdfs:comment 'Date when the promotion becomes active and members can begin earning bonus miles or benefits. Effective-from date for the promotion.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:targetSegment rdf:type rdf:Property ;
    rdfs:label 'Target Segment' ;
    rdfs:comment 'Marketing segment or customer cohort targeted by this promotion (e.g., \'Inactive Members\', \'High-Value Flyers\', \'New Enrollees\', \'Corporate Travelers\'). Used for campaign targeting and performance analysis.' ;
    rdfs:domain ind:Promotion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:termsAndConditionsUrl rdf:type rdf:Property ;
    rdfs:label 'Terms And Conditions Url' ;
    rdfs:comment 'Web URL linking to the full legal terms and conditions document for the promotion. Used for regulatory compliance and member transparency.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:promotionEnrollmentId rdf:type rdf:Property ;
    rdfs:label 'Promotion Enrollment Id' ;
    rdfs:comment 'Unique identifier for the promotion enrollment record. Primary key.' ;
    rdfs:domain ind:PromotionEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:autoEnrolledFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Enrolled Flag' ;
    rdfs:comment 'Indicates whether the member was automatically enrolled based on tier status or other eligibility criteria, versus explicit opt-in.' ;
    rdfs:domain ind:PromotionEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bonusMilesEarned rdf:type rdf:Property ;
    rdfs:label 'Bonus Miles Earned' ;
    rdfs:comment 'Total bonus miles or points awarded to the member upon successful completion of the promotion.' ;
    rdfs:domain ind:PromotionEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bonusPostingDate rdf:type rdf:Property ;
    rdfs:label 'Bonus Posting Date' ;
    rdfs:comment 'Date when bonus miles or rewards were posted to the member\'s FFP account.' ;
    rdfs:domain ind:PromotionEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bonusPostingStatus rdf:type rdf:Property ;
    rdfs:label 'Bonus Posting Status' ;
    rdfs:comment 'Status of the bonus miles posting transaction to the member\'s account.' ;
    rdfs:domain ind:PromotionEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationDate rdf:type rdf:Property ;
    rdfs:label 'Cancellation Date' ;
    rdfs:comment 'Date when the enrollment was cancelled by the member or system.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:completionDate rdf:type rdf:Property ;
    rdfs:label 'Completion Date' ;
    rdfs:comment 'Date when the promotion enrollment was marked as completed and rewards were posted or scheduled.' ;
    rdfs:domain ind:PromotionEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:enrollmentNumber rdf:type rdf:Property ;
    rdfs:label 'Enrollment Number' ;
    rdfs:comment 'Business-facing unique enrollment reference number for tracking and customer service inquiries.' ;
    rdfs:domain ind:PromotionEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentSourceCampaign rdf:type rdf:Property ;
    rdfs:label 'Enrollment Source Campaign' ;
    rdfs:comment 'Marketing campaign code or identifier that drove the enrollment, used for campaign effectiveness tracking.' ;
    rdfs:domain ind:PromotionEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentStatus rdf:type rdf:Property ;
    rdfs:label 'Enrollment Status' ;
    rdfs:comment 'Current lifecycle status of the promotion enrollment. Tracks progression from initial enrollment through completion or termination. [ENUM-REF-CANDIDATE: enrolled|in_progress|qualified|completed|expired|cancelled|disqualified — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PromotionEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Enrollment Timestamp' ;
    rdfs:comment 'Precise date and time when the member enrolled in the promotion, including timezone information.' ;
    rdfs:domain ind:PromotionEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:notificationSentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Notification Sent Timestamp' ;
    rdfs:comment 'Date and time when enrollment or completion notification was sent to the member.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:optInConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Opt In Consent Flag' ;
    rdfs:comment 'Indicates whether the member provided explicit consent to participate in the promotion and receive related communications.' ;
    rdfs:domain ind:PromotionEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:partnerPromotionFlag rdf:type rdf:Property ;
    rdfs:label 'Partner Promotion Flag' ;
    rdfs:comment 'Indicates whether this is a co-branded promotion with a partner airline, hotel, or coalition program.' ;
    rdfs:domain ind:PromotionEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:promotionEndDate rdf:type rdf:Property ;
    rdfs:label 'Promotion End Date' ;
    rdfs:comment 'Date when the promotion period ends and qualification window closes.' ;
    rdfs:domain ind:PromotionEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:promotionStartDate rdf:type rdf:Property ;
    rdfs:label 'Promotion Start Date' ;
    rdfs:comment 'Date when the promotion period begins for this enrollment, may differ from enrollment date for future-dated promotions.' ;
    rdfs:domain ind:PromotionEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualificationCriteriaType rdf:type rdf:Property ;
    rdfs:label 'Qualification Criteria Type' ;
    rdfs:comment 'Type of qualification criteria the member must meet to complete the promotion (e.g., number of flights, miles earned, spend threshold).' ;
    rdfs:domain ind:PromotionEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationCurrentValue rdf:type rdf:Property ;
    rdfs:label 'Qualification Current Value' ;
    rdfs:comment 'Current progress value toward the qualification target, updated as qualifying activities are completed.' ;
    rdfs:domain ind:PromotionEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualificationDeadlineDate rdf:type rdf:Property ;
    rdfs:label 'Qualification Deadline Date' ;
    rdfs:comment 'Final date by which the member must complete qualification criteria to earn promotion rewards.' ;
    rdfs:domain ind:PromotionEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualificationPercentage rdf:type rdf:Property ;
    rdfs:label 'Qualification Percentage' ;
    rdfs:comment 'Percentage of qualification criteria completed, calculated as (current_value / target_value) * 100.' ;
    rdfs:domain ind:PromotionEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualificationTargetValue rdf:type rdf:Property ;
    rdfs:label 'Qualification Target Value' ;
    rdfs:comment 'Target value the member must achieve to qualify for promotion completion (e.g., 5 flights, 10000 miles, 500 USD spend).' ;
    rdfs:domain ind:PromotionEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:qualificationUnit rdf:type rdf:Property ;
    rdfs:label 'Qualification Unit' ;
    rdfs:comment 'Unit of measure for qualification progress (e.g., flights, miles, currency units). [ENUM-REF-CANDIDATE: flights|segments|miles|kilometers|currency|points|nights|transactions — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PromotionEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualifiedDate rdf:type rdf:Property ;
    rdfs:label 'Qualified Date' ;
    rdfs:comment 'Date when the member met all qualification criteria and became eligible for promotion rewards.' ;
    rdfs:domain ind:PromotionEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:qualifyingActivitiesCount rdf:type rdf:Property ;
    rdfs:label 'Qualifying Activities Count' ;
    rdfs:comment 'Number of qualifying activities (flights, transactions, partner activities) completed toward promotion requirements.' ;
    rdfs:domain ind:PromotionEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:termsVersion rdf:type rdf:Property ;
    rdfs:label 'Terms Version' ;
    rdfs:comment 'Version identifier of the promotion terms and conditions that the member agreed to at enrollment.' ;
    rdfs:domain ind:PromotionEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierBonusMultiplier rdf:type rdf:Property ;
    rdfs:label 'Tier Bonus Multiplier' ;
    rdfs:comment 'Additional multiplier applied to promotion rewards based on the member\'s elite tier status at time of qualification.' ;
    rdfs:domain ind:PromotionEnrollment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:memberBenefitId rdf:type rdf:Property ;
    rdfs:label 'Member Benefit Id' ;
    rdfs:comment 'Unique identifier for the member benefit entitlement record. Primary key.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MemberBenefit .

ind:partnerCarrierId rdf:type rdf:Property ;
    rdfs:label 'Partner Carrier Id' ;
    rdfs:comment 'Foreign key linking to route.carrier. Business justification: Member benefits such as lounge access, upgrade eligibility, and baggage allowances on partner airlines require a structured reference to the partner carrier for eligibility validation at check-in and ' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:activationTrigger rdf:type rdf:Property ;
    rdfs:label 'Activation Trigger' ;
    rdfs:comment 'Event or condition that triggered the activation of this benefit entitlement (e.g., tier qualification, manual grant by admin, promotional campaign, lifetime status achievement, status challenge match).' ;
    rdfs:domain ind:MemberBenefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoRenewFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Renew Flag' ;
    rdfs:comment 'Indicates whether the benefit automatically renews upon tier re-qualification or expiration (True) or requires manual re-issuance (False).' ;
    rdfs:domain ind:MemberBenefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:benefitCode rdf:type rdf:Property ;
    rdfs:label 'Benefit Code' ;
    rdfs:comment 'Unique alphanumeric code identifying the benefit type (e.g., LOUNGE_ACCESS, PRIORITY_CHECKIN, EXTRA_BAG).' ;
    rdfs:domain ind:MemberBenefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benefitDescription rdf:type rdf:Property ;
    rdfs:label 'Benefit Description' ;
    rdfs:comment 'Detailed description of the benefit entitlement, including terms, conditions, and usage instructions.' ;
    rdfs:domain ind:MemberBenefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benefitName rdf:type rdf:Property ;
    rdfs:label 'Benefit Name' ;
    rdfs:comment 'Human-readable name of the benefit (e.g., Priority Lounge Access, Extra Baggage Allowance).' ;
    rdfs:domain ind:MemberBenefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benefitQuantity rdf:type rdf:Property ;
    rdfs:label 'Benefit Quantity' ;
    rdfs:comment 'Numeric quantity or limit of the benefit entitlement (e.g., 2 lounge passes, 20kg extra baggage). Null indicates unlimited.' ;
    rdfs:domain ind:MemberBenefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:benefitStatus rdf:type rdf:Property ;
    rdfs:label 'Benefit Status' ;
    rdfs:comment 'Current lifecycle status of the benefit entitlement: active (usable), suspended (temporarily unavailable), expired (validity period ended), revoked (administratively removed), or pending activation.' ;
    rdfs:domain ind:MemberBenefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benefitTerms rdf:type rdf:Property ;
    rdfs:label 'Benefit Terms' ;
    rdfs:comment 'Full text of terms and conditions governing the use of this benefit, including restrictions, blackout dates, and eligibility criteria.' ;
    rdfs:domain ind:MemberBenefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benefitType rdf:type rdf:Property ;
    rdfs:label 'Benefit Type' ;
    rdfs:comment 'Category of benefit entitlement: lounge access, priority check-in, priority boarding, extra baggage allowance, seat upgrade priority, companion ticket, bonus mile multiplier, or dedicated phone support. [ENUM-REF-CANDIDATE: lounge_access|priority_checkin|priority_boarding|extra_baggage|seat_upgrade|companion_ticket|bonus_miles|dedicated_support — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MemberBenefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benefitUnit rdf:type rdf:Property ;
    rdfs:label 'Benefit Unit' ;
    rdfs:comment 'Unit of measurement for the benefit quantity (e.g., passes, kg for baggage, segments, upgrade certificates, multiplier for bonus miles). [ENUM-REF-CANDIDATE: passes|kg|segments|upgrades|multiplier|tickets|hours — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MemberBenefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:benefitValidityEndDate rdf:type rdf:Property ;
    rdfs:label 'Benefit Validity End Date' ;
    rdfs:comment 'Date on which the benefit entitlement expires. Null indicates no expiration.' ;
    rdfs:domain ind:MemberBenefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:benefitValidityStartDate rdf:type rdf:Property ;
    rdfs:label 'Benefit Validity Start Date' ;
    rdfs:comment 'Date from which the benefit entitlement becomes active and usable by the member.' ;
    rdfs:domain ind:MemberBenefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:costCurrency rdf:type rdf:Property ;
    rdfs:label 'Cost Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the cost_to_airline amount.' ;
    rdfs:domain ind:MemberBenefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costToAirline rdf:type rdf:Property ;
    rdfs:label 'Cost To Airline' ;
    rdfs:comment 'Estimated cost to the airline for providing this benefit entitlement, used for financial planning and benefit valuation analysis.' ;
    rdfs:domain ind:MemberBenefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deliveryChannel rdf:type rdf:Property ;
    rdfs:label 'Delivery Channel' ;
    rdfs:comment 'Channel through which the benefit is delivered or redeemed (e.g., airport counter, online portal, mobile app, call center, partner location, automatic application).' ;
    rdfs:domain ind:MemberBenefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicRestriction rdf:type rdf:Property ;
    rdfs:label 'Geographic Restriction' ;
    rdfs:comment 'Geographic scope or restriction for benefit usage (e.g., domestic only, international only, specific regions or airport codes). Null if no restriction.' ;
    rdfs:domain ind:MemberBenefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastUsageDate rdf:type rdf:Property ;
    rdfs:label 'Last Usage Date' ;
    rdfs:comment 'Date when the benefit was most recently used or redeemed by the member.' ;
    rdfs:domain ind:MemberBenefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:remainingBalance rdf:type rdf:Property ;
    rdfs:label 'Remaining Balance' ;
    rdfs:comment 'Remaining quantity of the benefit available for use (benefit_quantity minus usage_count). Null if unlimited.' ;
    rdfs:domain ind:MemberBenefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revocationReason rdf:type rdf:Property ;
    rdfs:label 'Revocation Reason' ;
    rdfs:comment 'Reason for benefit revocation if status is \'revoked\' (e.g., tier downgrade, policy violation, account closure). Null if benefit has not been revoked.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierApplicability rdf:type rdf:Property ;
    rdfs:label 'Tier Applicability' ;
    rdfs:comment 'Comma-separated list of tier codes to which this benefit applies (e.g., GOLD,PLATINUM,DIAMOND).' ;
    rdfs:domain ind:MemberBenefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferableFlag rdf:type rdf:Property ;
    rdfs:label 'Transferable Flag' ;
    rdfs:comment 'Indicates whether the benefit can be transferred to another FFP member or companion (True) or is non-transferable (False).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:usageCount rdf:type rdf:Property ;
    rdfs:label 'Usage Count' ;
    rdfs:comment 'Number of times this benefit has been used or redeemed by the member during the current validity period.' ;
    rdfs:domain ind:MemberBenefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:usageHistorySummary rdf:type rdf:Property ;
    rdfs:label 'Usage History Summary' ;
    rdfs:comment 'Summary text of benefit usage history, including dates, locations, and transaction references for audit and member inquiry purposes.' ;
    rdfs:domain ind:MemberBenefit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentCabinClassId rdf:type rdf:Property ;
    rdfs:label 'Current Cabin Class Id' ;
    rdfs:comment 'Foreign key linking to inventory.cabin_class. Business justification: Upgrade eligibility rules depend on current cabin class. Normalizes current_cabin_class text column. Required for upgrade policy enforcement and operational upgrade clearance workflows.' ;
    rdfs:domain ind:UpgradeRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CabinClass .

ind:targetFareClassBucketId rdf:type rdf:Property ;
    rdfs:label 'Target Fare Class Bucket Id' ;
    rdfs:comment 'Foreign key linking to inventory.fare_class_bucket. Business justification: Upgrade clearance processing checks fare class bucket availability in the target cabin before confirming an upgrade. The role prefix \'target_\' distinguishes this from the current cabin reference. Avia' ;
    rdfs:domain ind:UpgradeRequest ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FareClassBucket .

ind:upgradeOfferId rdf:type rdf:Property ;
    rdfs:label 'Upgrade Offer Id' ;
    rdfs:comment 'Foreign key linking to ancillary.upgrade_offer. Business justification: Upgrade offer matching for loyalty requests: when a loyalty upgrade request is processed, the system must identify which ancillary upgrade_offer was presented or applied. This FK enables upgrade conve' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UpgradeOffer .

ind:upgradeTransactionId rdf:type rdf:Property ;
    rdfs:label 'Upgrade Transaction Id' ;
    rdfs:comment 'Foreign key linking to ancillary.upgrade_transaction. Business justification: Upgrade clearance reconciliation: when a loyalty upgrade request (miles/complimentary) is fulfilled via a paid ancillary upgrade transaction, this FK links the two records for audit, revenue accountin' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UpgradeTransaction .

ind:companionUpgradeFlag rdf:type rdf:Property ;
    rdfs:label 'Companion Upgrade Flag' ;
    rdfs:comment 'Indicates whether this upgrade request includes a companion passenger traveling on the same PNR and eligible for upgrade under the member\'s benefits.' ;
    rdfs:domain ind:UpgradeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:denialReasonCode rdf:type rdf:Property ;
    rdfs:label 'Denial Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason an upgrade request was denied: no availability in requested cabin, insufficient miles balance, ineligible fare class, cabin at capacity, operational restrictions, or request expired.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fareClassCode rdf:type rdf:Property ;
    rdfs:label 'Fare Class Code' ;
    rdfs:comment 'Single-letter fare class booking code of the original ticket, which influences upgrade eligibility and priority.' ;
    rdfs:domain ind:UpgradeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milesDeducted rdf:type rdf:Property ;
    rdfs:label 'Miles Deducted' ;
    rdfs:comment 'Number of frequent flyer miles deducted from the member\'s account for a miles-based or co-pay upgrade. Null for complimentary elite upgrades.' ;
    rdfs:domain ind:UpgradeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requestChannel rdf:type rdf:Property ;
    rdfs:label 'Request Channel' ;
    rdfs:comment 'Channel through which the upgrade request was submitted: web portal, mobile application, call center agent, airport self-service kiosk, gate agent, or partner airline portal.' ;
    rdfs:domain ind:UpgradeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestType rdf:type rdf:Property ;
    rdfs:label 'Request Type' ;
    rdfs:comment 'Type of upgrade request indicating the method or entitlement basis: complimentary elite upgrade based on tier status, miles-based redemption, co-pay upgrade combining miles and cash, operational upgrade at airline discretion, or revenue upgrade purchased at gate.' ;
    rdfs:domain ind:UpgradeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedCabinClass rdf:type rdf:Property ;
    rdfs:label 'Requested Cabin Class' ;
    rdfs:comment 'The target cabin class to which the passenger is requesting an upgrade.' ;
    rdfs:domain ind:UpgradeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seatNumberAssigned rdf:type rdf:Property ;
    rdfs:label 'Seat Number Assigned' ;
    rdfs:comment 'Specific seat number assigned to the passenger in the upgraded cabin once the upgrade is cleared. Format: row number followed by seat letter.' ;
    rdfs:domain ind:UpgradeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upgradeClearedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Upgrade Cleared Timestamp' ;
    rdfs:comment 'Date and time when the upgrade was confirmed and cleared, allowing the passenger to board in the upgraded cabin.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:upgradePriorityScore rdf:type rdf:Property ;
    rdfs:label 'Upgrade Priority Score' ;
    rdfs:comment 'Calculated priority score determining the member\'s position in the upgrade queue, based on factors such as tier status, fare class, lifetime miles, and request timing.' ;
    rdfs:domain ind:UpgradeRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:upgradeStatus rdf:type rdf:Property ;
    rdfs:label 'Upgrade Status' ;
    rdfs:comment 'Current status of the upgrade request in its lifecycle: requested (initial submission), waitlisted (pending availability), confirmed (upgrade space allocated), cleared (passenger checked in with upgrade), denied (request rejected), expired (request lapsed), or cancelled (passenger withdrew request). [ENUM-REF-CANDIDATE: requested|waitlisted|confirmed|cleared|denied|expired|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:milesTransferId rdf:type rdf:Property ;
    rdfs:label 'Miles Transfer Id' ;
    rdfs:comment 'Unique identifier for the peer-to-peer miles transfer transaction. Primary key.' ;
    rdfs:domain ind:MilesTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryMilesSenderFfpMemberId rdf:type rdf:Property ;
    rdfs:label 'Primary Miles Sender Ffp Member Id' ;
    rdfs:comment 'FFP member identifier of the member sending/gifting miles. References the member initiating the transfer.' ;
    rdfs:domain ind:MilesTransfer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FfpMember .

ind:approvalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Approval Required Flag' ;
    rdfs:comment 'Indicates whether this transfer requires manual approval by FFP operations team (e.g., high-value transfers, fraud risk, first-time transfer). True if approval required, False if auto-approved.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:approvalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Approval Timestamp' ;
    rdfs:comment 'Date and time when the transfer was approved. Null if auto-approved (approval timestamp equals transfer timestamp) or still pending.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:feeDiscountApplied rdf:type rdf:Property ;
    rdfs:label 'Fee Discount Applied' ;
    rdfs:comment 'Monetary discount amount applied to the standard transfer fee due to promotion, tier status, or relationship type. Zero if no discount applied.' ;
    rdfs:domain ind:MilesTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fraudReviewFlag rdf:type rdf:Property ;
    rdfs:label 'Fraud Review Flag' ;
    rdfs:comment 'Indicates whether this transfer was flagged for manual fraud review. True if flagged, False otherwise.' ;
    rdfs:domain ind:MilesTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fraudRiskScore rdf:type rdf:Property ;
    rdfs:label 'Fraud Risk Score' ;
    rdfs:comment 'Automated fraud detection risk score assigned to this transfer at time of initiation (0.00 = no risk, 100.00 = high risk). Used to flag suspicious transfers for review.' ;
    rdfs:domain ind:MilesTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:milesTransferred rdf:type rdf:Property ;
    rdfs:label 'Miles Transferred' ;
    rdfs:comment 'Quantity of loyalty miles transferred from sender to recipient in this transaction. Must be positive integer value.' ;
    rdfs:domain ind:MilesTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recipientAnnualReceiptConsumed rdf:type rdf:Property ;
    rdfs:label 'Recipient Annual Receipt Consumed' ;
    rdfs:comment 'Cumulative miles the recipient has received in the current calendar year after this transaction completes. Used to enforce annual receipt limits.' ;
    rdfs:domain ind:MilesTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recipientAnnualReceiptLimit rdf:type rdf:Property ;
    rdfs:label 'Recipient Annual Receipt Limit' ;
    rdfs:comment 'Maximum miles the recipient is allowed to receive per calendar year according to FFP program rules. Captured at time of transfer for audit purposes.' ;
    rdfs:domain ind:MilesTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rejectionReason rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason' ;
    rdfs:comment 'Free-text explanation for why the transfer was rejected (e.g., insufficient miles, limit exceeded, fraud detected, policy violation). Null if not rejected.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipType rdf:type rdf:Property ;
    rdfs:label 'Relationship Type' ;
    rdfs:comment 'Declared relationship between sender and recipient. Some FFP programs offer preferential transfer terms for family members. Self-declared by sender at time of transfer. [ENUM-REF-CANDIDATE: family|friend|spouse|partner|child|parent|sibling|unrelated — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:MilesTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:relationshipVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Relationship Verified Flag' ;
    rdfs:comment 'Indicates whether the declared relationship between sender and recipient has been verified by the airline (e.g., through documentation submission). True if verified, False if unverified or not required.' ;
    rdfs:domain ind:MilesTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reversalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reversal Timestamp' ;
    rdfs:comment 'Date and time when the transfer was reversed and miles returned to sender. Null if not reversed.' ;
    rdfs:domain ind:MilesTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:senderAnnualTransferConsumed rdf:type rdf:Property ;
    rdfs:label 'Sender Annual Transfer Consumed' ;
    rdfs:comment 'Cumulative miles the sender has transferred in the current calendar year after this transaction completes. Used to enforce annual transfer limits.' ;
    rdfs:domain ind:MilesTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:senderAnnualTransferLimit rdf:type rdf:Property ;
    rdfs:label 'Sender Annual Transfer Limit' ;
    rdfs:comment 'Maximum miles the sender is allowed to transfer per calendar year according to FFP program rules and sender tier status. Captured at time of transfer for audit purposes.' ;
    rdfs:domain ind:MilesTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transferChannel rdf:type rdf:Property ;
    rdfs:label 'Transfer Channel' ;
    rdfs:comment 'Digital or physical channel through which the transfer was initiated: web (airline website), mobile_app, call_center (agent-assisted), partner_portal (coalition partner interface), kiosk (airport self-service).' ;
    rdfs:domain ind:MilesTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferNotes rdf:type rdf:Property ;
    rdfs:label 'Transfer Notes' ;
    rdfs:comment 'Free-text notes or comments about the transfer, entered by sender (e.g., gift message) or operations agent (e.g., special handling instructions). Null if no notes.' ;
    rdfs:domain ind:MilesTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferStatus rdf:type rdf:Property ;
    rdfs:label 'Transfer Status' ;
    rdfs:comment 'Current lifecycle status of the miles transfer: pending (awaiting approval), approved (authorized but not yet posted), completed (miles successfully transferred), rejected (transfer denied), cancelled (sender cancelled before completion), reversed (transfer reversed after completion due to fraud or error).' ;
    rdfs:domain ind:MilesTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferTimestamp rdf:type rdf:Property ;
    rdfs:label 'Transfer Timestamp' ;
    rdfs:comment 'Date and time when the miles transfer was initiated by the sender. Represents the business event time of the transfer request.' ;
    rdfs:domain ind:MilesTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:transferTransactionNumber rdf:type rdf:Property ;
    rdfs:label 'Transfer Transaction Number' ;
    rdfs:comment 'Externally visible unique transaction reference number for the miles transfer, used for customer service inquiries and audit trails.' ;
    rdfs:domain ind:MilesTransfer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumTierStatusId rdf:type rdf:Property ;
    rdfs:label 'Minimum Tier Status Id' ;
    rdfs:comment 'Foreign key linking to loyalty.tier_status. Business justification: award_inventory.minimum_tier_required is a STRING denormalized reference to the minimum tier level required to access this award inventory bucket. Adding minimum_tier_status_id FK to tier_status norma' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TierStatus .

ind:allocationEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Allocation Effective Date' ;
    rdfs:comment 'The date from which this award seat allocation becomes effective and available for member booking.' ;
    rdfs:domain ind:AwardInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allocationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Allocation Expiry Date' ;
    rdfs:comment 'The date after which this award seat allocation expires and is no longer available for booking. Null for open-ended allocations.' ;
    rdfs:domain ind:AwardInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:allocationNotes rdf:type rdf:Property ;
    rdfs:label 'Allocation Notes' ;
    rdfs:comment 'Free-text notes regarding special conditions, restrictions, or context for this award inventory allocation. Used by revenue management and FFP operations teams.' ;
    rdfs:domain ind:AwardInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationSource rdf:type rdf:Property ;
    rdfs:label 'Allocation Source' ;
    rdfs:comment 'The source or method by which award seats were allocated to this inventory bucket. Revenue management indicates standard RM allocation; partner agreement indicates contractual allocation; promotional indicates campaign-driven allocation; dynamic indicates real-time algorithmic allocation.' ;
    rdfs:domain ind:AwardInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awardBucketType rdf:type rdf:Property ;
    rdfs:label 'Award Bucket Type' ;
    rdfs:comment 'The award redemption tier type. Saver awards require fewer miles but have limited availability; standard and premium awards offer greater availability at higher mileage cost.' ;
    rdfs:domain ind:AwardInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blackoutDateFlag rdf:type rdf:Property ;
    rdfs:label 'Blackout Date Flag' ;
    rdfs:comment 'Indicates whether this travel date is designated as a blackout date for award redemptions. True means no award seats are available regardless of inventory.' ;
    rdfs:domain ind:AwardInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bookingWindowCloseDays rdf:type rdf:Property ;
    rdfs:label 'Booking Window Close Days' ;
    rdfs:comment 'The minimum number of days before departure that award bookings close. Typically 1-14 days depending on route and cabin.' ;
    rdfs:domain ind:AwardInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bookingWindowOpenDays rdf:type rdf:Property ;
    rdfs:label 'Booking Window Open Days' ;
    rdfs:comment 'The number of days in advance that award seats become available for booking. Standard is 330-365 days for most airlines.' ;
    rdfs:domain ind:AwardInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cancellationFeeWaivedFlag rdf:type rdf:Property ;
    rdfs:label 'Cancellation Fee Waived Flag' ;
    rdfs:comment 'Indicates whether the standard award cancellation fee is waived for bookings in this inventory bucket. Often applies to elite members or promotional awards.' ;
    rdfs:domain ind:AwardInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:changeFeeWaivedFlag rdf:type rdf:Property ;
    rdfs:label 'Change Fee Waived Flag' ;
    rdfs:comment 'Indicates whether the standard award change fee is waived for bookings in this inventory bucket. Often applies to elite members or promotional awards.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dynamicPricingEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Dynamic Pricing Enabled Flag' ;
    rdfs:comment 'Indicates whether dynamic award pricing is enabled for this inventory, allowing mileage cost to vary based on demand and availability rather than fixed award chart rates.' ;
    rdfs:domain ind:AwardInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eliteOnlyFlag rdf:type rdf:Property ;
    rdfs:label 'Elite Only Flag' ;
    rdfs:comment 'Indicates whether award seat availability is restricted to elite tier members only. Used for premium cabin inventory management.' ;
    rdfs:domain ind:AwardInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:milesRequired rdf:type rdf:Property ;
    rdfs:label 'Miles Required' ;
    rdfs:comment 'The number of FFP miles required to redeem one award seat in this bucket and cabin class. Varies by route, cabin, and bucket type.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:partnerAwardAvailabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Partner Award Availability Flag' ;
    rdfs:comment 'Indicates whether these award seats are available for redemption by partner FFP members under reciprocal agreements.' ;
    rdfs:domain ind:AwardInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:seatsRedeemed rdf:type rdf:Property ;
    rdfs:label 'Seats Redeemed' ;
    rdfs:comment 'The cumulative number of award seats that have been successfully redeemed and ticketed for this flight, cabin, and bucket.' ;
    rdfs:domain ind:AwardInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seatsWaitlisted rdf:type rdf:Property ;
    rdfs:label 'Seats Waitlisted' ;
    rdfs:comment 'The number of members currently on the waitlist for award seats on this flight and cabin when availability is zero.' ;
    rdfs:domain ind:AwardInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalAwardSeatsAllocated rdf:type rdf:Property ;
    rdfs:label 'Total Award Seats Allocated' ;
    rdfs:comment 'The total number of seats allocated to the FFP award inventory pool for this flight, cabin, and bucket combination. Set by revenue management.' ;
    rdfs:domain ind:AwardInventory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:upgradeEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Upgrade Eligible Flag' ;
    rdfs:comment 'Indicates whether these award seats are eligible for mileage upgrade from a lower cabin class. Relevant for upgrade award inventory management.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferredCityPairId rdf:type rdf:Property ;
    rdfs:label 'Preferred City Pair Id' ;
    rdfs:comment 'Foreign key linking to route.city_pair. Business justification: Route development and network planning teams analyze passenger home/preferred city pairs to identify underserved markets and optimize route networks. Marketing uses this for targeted route launch camp' ;
    rdfs:domain ind:Passenger ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CityPair .

ind:accessibilityRequirements rdf:type rdf:Property ;
    rdfs:label 'Accessibility Requirements' ;
    rdfs:comment 'Special assistance or accessibility needs for passengers with disabilities or reduced mobility. Free-text field capturing wheelchair requirements, visual/hearing impairments, service animal needs, medical equipment, etc. Detailed SSR codes stored in separate SSR product.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:completenessScore rdf:type rdf:Property ;
    rdfs:label 'Completeness Score' ;
    rdfs:comment 'Calculated percentage score (0.00 to 100.00) indicating the completeness of the passenger profile based on presence of key fields (contact details, travel documents, preferences, loyalty linkage). Used for data quality monitoring and personalization readiness.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:countryOfResidence rdf:type rdf:Property ;
    rdfs:label 'Country Of Residence' ;
    rdfs:comment 'Country where the passenger permanently resides, represented as ISO 3166-1 alpha-3 country code. Used for customs declarations and passenger segmentation analytics.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customerSegment rdf:type rdf:Property ;
    rdfs:label 'Customer Segment' ;
    rdfs:comment 'Marketing segmentation classification for the passenger based on travel behavior, spend patterns, and loyalty tier. Examples: premium_frequent_flyer, leisure_traveler, business_traveler, occasional_flyer, vip_corporate. [ENUM-REF-CANDIDATE: premium_frequent_flyer|leisure_traveler|business_traveler|occasional_flyer|vip_corporate|group_traveler|family_traveler — promote to reference product]' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSharingConsent rdf:type rdf:Property ;
    rdfs:label 'Data Sharing Consent' ;
    rdfs:comment 'Indicates whether the passenger has consented to sharing their personal data with airline partners, codeshare airlines, and third-party service providers. True=consented, False=not consented.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:emergencyContactRelationship rdf:type rdf:Property ;
    rdfs:label 'Emergency Contact Relationship' ;
    rdfs:comment 'Relationship of the emergency contact person to the passenger (e.g., spouse, parent, child, sibling, friend).' ;
    rdfs:domain ind:Passenger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:knownTravelerNumber rdf:type rdf:Property ;
    rdfs:label 'Known Traveler Number' ;
    rdfs:comment 'TSA PreCheck Known Traveler Number or equivalent trusted traveler program identifier (e.g., Global Entry, NEXUS, SENTRI). Enables expedited security screening at participating airports.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingOptIn rdf:type rdf:Property ;
    rdfs:label 'Marketing Opt In' ;
    rdfs:comment 'Indicates whether the passenger has consented to receive marketing communications, promotional offers, and newsletters from the airline. True=opted in, False=opted out.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nationality rdf:type rdf:Property ;
    rdfs:label 'Nationality' ;
    rdfs:comment 'Nationality of the passenger represented as ISO 3166-1 alpha-3 country code. Required for visa validation, customs processing, and API submission to destination countries.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passengerType rdf:type rdf:Property ;
    rdfs:label 'Passenger Type' ;
    rdfs:comment 'Classification of passenger by age and travel status. ADT=Adult (12+ years), CHD=Child (2-11 years), INF=Infant (under 2 years), UMN=Unaccompanied Minor. Determines fare rules, seating requirements, and service protocols.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Email' ;
    rdfs:comment 'Primary email address for passenger communications, booking confirmations, flight notifications, and digital receipts. Display-only summary field; authoritative multi-valued contact store is the contact_detail product.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Phone' ;
    rdfs:comment 'Primary contact phone number for passenger communications, flight alerts, and operational notifications. E.164 international format recommended. Display-only summary field; authoritative multi-valued contact store is the contact_detail product.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileStatus rdf:type rdf:Property ;
    rdfs:label 'Profile Status' ;
    rdfs:comment 'Current lifecycle status of the passenger profile. Active=profile in use, Inactive=dormant profile, Suspended=temporarily blocked, Merged=consolidated into another profile, Deceased=passenger deceased per notification.' ;
    rdfs:domain ind:Passenger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seatPreference rdf:type rdf:Property ;
    rdfs:label 'Seat Preference' ;
    rdfs:comment 'Passenger\'s preferred seat location on the aircraft. Used for automated seat assignment and upgrade processing.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unaccompaniedMinorGuardianName rdf:type rdf:Property ;
    rdfs:label 'Unaccompanied Minor Guardian Name' ;
    rdfs:comment 'Full name of the parent or legal guardian responsible for an unaccompanied minor passenger. Required for UMN bookings to coordinate drop-off and pick-up procedures.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unaccompaniedMinorGuardianPhone rdf:type rdf:Property ;
    rdfs:label 'Unaccompanied Minor Guardian Phone' ;
    rdfs:comment 'Contact phone number for the parent or legal guardian of an unaccompanied minor passenger. Used for coordination during travel and emergency contact.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vipIndicator rdf:type rdf:Property ;
    rdfs:label 'Vip Indicator' ;
    rdfs:comment 'Flag indicating whether the passenger is designated as a VIP requiring special handling, premium services, or executive attention. True=VIP status, False=standard passenger.' ;
    rdfs:domain ind:Profile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:apisTransmittedFlag rdf:type rdf:Property ;
    rdfs:label 'Apis Transmitted Flag' ;
    rdfs:comment 'Indicates whether this documents data has been successfully transmitted to destination country border control authorities via APIS. Required for flights to USA, Canada, UK, EU, and many other jurisdictions.' ;
    rdfs:domain ind:TravelIdentityDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:documentImageUrl rdf:type rdf:Property ;
    rdfs:label 'Document Image Url' ;
    rdfs:comment 'Secure storage location (URI) of the scanned or photographed document image. Used for manual verification, fraud investigation, and regulatory compliance. Access restricted to authorized personnel only.' ;
    rdfs:domain ind:TravelIdentityDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentSource rdf:type rdf:Property ;
    rdfs:label 'Document Source' ;
    rdfs:comment 'Method by which the document data was captured. Manual_entry=agent typed data; OCR_scan=automated optical character recognition from image; Mobile_app=passenger self-service via mobile; GDS=received from Global Distribution System; API_integration=received from partner system.' ;
    rdfs:domain ind:TravelIdentityDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPrimaryDocument rdf:type rdf:Property ;
    rdfs:label 'Is Primary Document' ;
    rdfs:comment 'Flag indicating whether this is the passengers primary travel document for the current booking. A passenger may hold multiple documents (e.g., passport + national ID), but only one is designated primary for APIS reporting.' ;
    rdfs:domain ind:TravelIdentityDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:knownTravellerProgram rdf:type rdf:Property ;
    rdfs:label 'Known Traveller Program' ;
    rdfs:comment 'Name of the trusted traveller program associated with the known traveller number. Determines which expedited lanes and services the passenger is eligible for.' ;
    rdfs:domain ind:TravelIdentityDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastUsedFlightDate rdf:type rdf:Property ;
    rdfs:label 'Last Used Flight Date' ;
    rdfs:comment 'Date of the most recent flight on which this document was used for travel. Helps identify stale or outdated document records and supports passenger profile analytics.' ;
    rdfs:domain ind:TravelIdentityDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mrzLine1 rdf:type rdf:Property ;
    rdfs:label 'Mrz Line1' ;
    rdfs:comment 'First line of the machine-readable zone at the bottom of the document. Contains document type, issuing country, and surname/given names in standardized format. Used for automated document scanning and APIS transmission.' ;
    rdfs:domain ind:TravelIdentityDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mrzLine2 rdf:type rdf:Property ;
    rdfs:label 'Mrz Line2' ;
    rdfs:comment 'Second line of the machine-readable zone. Contains document number, nationality, date of birth, gender, expiry date, and check digits. Enables rapid data capture via optical character recognition (OCR) at check-in kiosks and border control.' ;
    rdfs:domain ind:TravelIdentityDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mrzLine3 rdf:type rdf:Property ;
    rdfs:label 'Mrz Line3' ;
    rdfs:comment 'Third line of the machine-readable zone (present on some document types such as ID cards). Contains additional personal data and check digits.' ;
    rdfs:domain ind:TravelIdentityDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:secureFlightStatus rdf:type rdf:Property ;
    rdfs:label 'Secure Flight Status' ;
    rdfs:comment 'TSA Secure Flight screening result for USA-bound flights. Not_submitted=data not yet sent; Cleared=passenger approved for boarding; Inhibited=passenger denied boarding (no-fly list match); Conditional=requires additional screening or documentation.' ;
    rdfs:domain ind:TravelIdentityDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationStatus rdf:type rdf:Property ;
    rdfs:label 'Verification Status' ;
    rdfs:comment 'Current verification state of the document. Not_verified=newly entered, pending check; Verified=passed authenticity and expiry checks; Failed=document rejected (invalid format, fraudulent); Expired=document past expiry date; Flagged=requires manual review by security or compliance team.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verifiedBy rdf:type rdf:Property ;
    rdfs:label 'Verified By' ;
    rdfs:comment 'User ID or system identifier of the agent or automated process that performed the verification. Supports audit trail and accountability for document acceptance decisions.' ;
    rdfs:domain ind:TravelIdentityDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visaRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Visa Required Flag' ;
    rdfs:comment 'Indicates whether a visa is required for the passengers itinerary based on nationality, destination, and transit countries. Calculated using IATA Timatic rules. If true, a separate visa document record must exist.' ;
    rdfs:domain ind:TravelIdentityDocument ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contactDetailId rdf:type rdf:Property ;
    rdfs:label 'Contact Detail Id' ;
    rdfs:comment 'Unique identifier for the contact detail record. Primary key.' ;
    rdfs:domain ind:ContactDetail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contactChannel rdf:type rdf:Property ;
    rdfs:label 'Contact Channel' ;
    rdfs:comment 'The communication channel or medium through which this contact method operates (voice, SMS, email, postal, WhatsApp, app notification). Distinct from contact_type which defines the category.' ;
    rdfs:domain ind:ContactDetail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactStatus rdf:type rdf:Property ;
    rdfs:label 'Contact Status' ;
    rdfs:comment 'The current lifecycle status of this contact detail: active (in use), inactive (not in use), bounced (delivery failed), invalid (format error), pending_verification (awaiting confirmation).' ;
    rdfs:domain ind:ContactDetail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactType rdf:type rdf:Property ;
    rdfs:label 'Contact Type' ;
    rdfs:comment 'The category of contact channel: email, mobile phone, home phone, work phone, postal address, or emergency contact.' ;
    rdfs:domain ind:ContactDetail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPreferred rdf:type rdf:Property ;
    rdfs:label 'Is Preferred' ;
    rdfs:comment 'Flag indicating whether this is the passengers preferred contact method for operational and marketing communications. Only one contact per type should be marked preferred.' ;
    rdfs:domain ind:ContactDetail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isVerified rdf:type rdf:Property ;
    rdfs:label 'Is Verified' ;
    rdfs:comment 'Flag indicating whether this contact detail has been verified (e.g., email confirmed via link, phone verified via OTP). Supports data quality and fraud prevention.' ;
    rdfs:domain ind:ContactDetail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastUsedDate rdf:type rdf:Property ;
    rdfs:label 'Last Used Date' ;
    rdfs:comment 'The date when this contact detail was last used for communication (email sent, SMS delivered, call made). Supports contact data quality and hygiene.' ;
    rdfs:domain ind:ContactDetail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:optInDate rdf:type rdf:Property ;
    rdfs:label 'Opt In Date' ;
    rdfs:comment 'The date when the passenger provided consent for communications via this contact channel. Required for audit and compliance purposes.' ;
    rdfs:domain ind:ContactDetail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:optInMarketing rdf:type rdf:Property ;
    rdfs:label 'Opt In Marketing' ;
    rdfs:comment 'Flag indicating whether the passenger has consented to receive marketing communications via this contact channel. Required for GDPR and CAN-SPAM compliance.' ;
    rdfs:domain ind:ContactDetail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optInOperational rdf:type rdf:Property ;
    rdfs:label 'Opt In Operational' ;
    rdfs:comment 'Flag indicating whether the passenger has consented to receive operational communications (flight status, IROP notifications, gate changes) via this contact channel. Typically defaults to true for service delivery.' ;
    rdfs:domain ind:ContactDetail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:optOutDate rdf:type rdf:Property ;
    rdfs:label 'Opt Out Date' ;
    rdfs:comment 'The date when the passenger withdrew consent for communications via this contact channel. Supports unsubscribe tracking and compliance.' ;
    rdfs:domain ind:ContactDetail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:phoneCountryCode rdf:type rdf:Property ;
    rdfs:label 'Phone Country Code' ;
    rdfs:comment 'The international dialing code for the phone number (e.g., +1 for USA, +44 for UK). Supports global passenger contact management.' ;
    rdfs:domain ind:ContactDetail ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationDate rdf:type rdf:Property ;
    rdfs:label 'Verification Date' ;
    rdfs:comment 'The date when this contact detail was last verified by the passenger. Supports contact data quality management.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ssrRecordId rdf:type rdf:Property ;
    rdfs:label 'Ssr Record Id' ;
    rdfs:comment 'Unique identifier for the SSR record instance. Primary key.' ;
    rdfs:domain ind:SsrRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accessibilityProfileId rdf:type rdf:Property ;
    rdfs:label 'Accessibility Profile Id' ;
    rdfs:comment 'Foreign key linking to passenger.accessibility_profile. Business justification: SSR records for mobility assistance (WCHR, WCHC, WCHS), oxygen requirements, medical equipment, and other PRM-related service codes are directly derived from or linked to a passenger\'s accessibility_p' ;
    rdfs:domain ind:Passenger ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccessibilityProfile .

ind:handlingCrewMemberId rdf:type rdf:Property ;
    rdfs:label 'Handling Crew Member Id' ;
    rdfs:comment 'Foreign key linking to crew.crew_member. Business justification: Airlines track which cabin crew member fulfilled special service requests (wheelchair assistance, medical needs, special meals) for quality assurance, training feedback, and incident investigation. Op' ;
    rdfs:domain ind:SsrRecord ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Member .

ind:confirmationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Confirmation Timestamp' ;
    rdfs:comment 'Date and time when the SSR was confirmed by the airline or service provider. Nullable if not yet confirmed.' ;
    rdfs:domain ind:SsrRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:equipmentRequired rdf:type rdf:Property ;
    rdfs:label 'Equipment Required' ;
    rdfs:comment 'Description of special equipment needed to fulfill this SSR (e.g., onboard wheelchair, oxygen concentrator, stretcher, incubator).' ;
    rdfs:domain ind:SsrRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfillmentNotes rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Notes' ;
    rdfs:comment 'Free-text notes recorded by ground staff or cabin crew documenting how the SSR was fulfilled, any issues encountered, or passenger feedback.' ;
    rdfs:domain ind:SsrRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handlingInstructions rdf:type rdf:Property ;
    rdfs:label 'Handling Instructions' ;
    rdfs:comment 'Operational instructions for ground staff, cabin crew, or service providers on how to fulfill this SSR, including equipment needs, timing, and coordination requirements.' ;
    rdfs:domain ind:SsrRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isChargeable rdf:type rdf:Property ;
    rdfs:label 'Is Chargeable' ;
    rdfs:comment 'Boolean flag indicating whether this SSR incurs a charge to the passenger (true) or is provided as a complimentary service (false).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isInterline rdf:type rdf:Property ;
    rdfs:label 'Is Interline' ;
    rdfs:comment 'Boolean flag indicating whether this SSR applies to an interline segment operated by a partner carrier (true) or an own-metal flight (false).' ;
    rdfs:domain ind:SsrRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isStandingPreference rdf:type rdf:Property ;
    rdfs:label 'Is Standing Preference' ;
    rdfs:comment 'Boolean flag indicating whether this SSR was auto-populated from the passenger\'s standing travel preferences (true) or requested ad-hoc for this booking (false).' ;
    rdfs:domain ind:SsrRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mealCode rdf:type rdf:Property ;
    rdfs:label 'Meal Code' ;
    rdfs:comment 'Four-letter IATA meal code for dietary SSRs (e.g., VGML for vegetarian, KSML for kosher, DBML for diabetic). Applicable only when ssr_code is SPML.' ;
    rdfs:domain ind:SsrRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalClearanceStatus rdf:type rdf:Property ;
    rdfs:label 'Medical Clearance Status' ;
    rdfs:comment 'Status of medical clearance for SSRs requiring medical approval. Values: not_required, pending, approved, denied.' ;
    rdfs:domain ind:SsrRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiresAdvanceNotice rdf:type rdf:Property ;
    rdfs:label 'Requires Advance Notice' ;
    rdfs:comment 'Boolean flag indicating whether this SSR type requires advance notice to the airline (true) or can be requested at check-in or boarding (false).' ;
    rdfs:domain ind:SsrRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:requiresMedicalClearance rdf:type rdf:Property ;
    rdfs:label 'Requires Medical Clearance' ;
    rdfs:comment 'Boolean flag indicating whether this SSR requires medical clearance or MEDA form approval before confirmation (true for MEDA, OXYG, STCR SSRs).' ;
    rdfs:domain ind:SsrRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceDeliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Service Delivery Timestamp' ;
    rdfs:comment 'Date and time when the SSR service was actually delivered or completed. Nullable if not yet delivered.' ;
    rdfs:domain ind:SsrRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ssrDescription rdf:type rdf:Property ;
    rdfs:label 'Ssr Description' ;
    rdfs:comment 'Free-text description providing additional details about the SSR, including handling instructions, meal preferences, medical conditions, or special equipment requirements.' ;
    rdfs:domain ind:SsrRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wheelchairType rdf:type rdf:Property ;
    rdfs:label 'Wheelchair Type' ;
    rdfs:comment 'Specific wheelchair assistance level for accessibility SSRs: WCHR (can walk stairs), WCHS (cannot walk stairs), WCHC (immobile, requires onboard wheelchair). Applicable only for wheelchair SSR codes.' ;
    rdfs:domain ind:SsrRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loyaltyLinkageId rdf:type rdf:Property ;
    rdfs:label 'Loyalty Linkage Id' ;
    rdfs:comment 'Unique identifier for the loyalty program linkage record. Primary key.' ;
    rdfs:domain ind:LoyaltyLinkage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recognizedTierStatusId rdf:type rdf:Property ;
    rdfs:label 'Recognized Tier Status Id' ;
    rdfs:comment 'Foreign key linking to loyalty.tier_status. Business justification: Tier recognition during account linkage: when an external FFP is linked, the airline records which tier_status was recognized/matched. loyalty_linkage already stores tier_effective_date and tier_expir' ;
    rdfs:domain ind:LoyaltyLinkage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TierStatus .

ind:allianceCode rdf:type rdf:Property ;
    rdfs:label 'Alliance Code' ;
    rdfs:comment 'The global airline alliance to which the FFP program belongs (Star Alliance, oneworld, SkyTeam). None indicates the program is not part of a major alliance or is the airline\'s own non-alliance program.' ;
    rdfs:domain ind:LoyaltyLinkage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:autoRecognitionEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Recognition Enabled Flag' ;
    rdfs:comment 'Boolean flag indicating whether automatic tier recognition and benefit application is enabled for this linkage at check-in, boarding, and service touchpoints. True enables automatic recognition; False requires manual override.' ;
    rdfs:domain ind:LoyaltyLinkage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataQualityScore rdf:type rdf:Property ;
    rdfs:label 'Data Quality Score' ;
    rdfs:comment 'Numeric score (0.00 to 100.00) representing the completeness and accuracy of the loyalty linkage data. Higher scores indicate higher confidence in the linkage validity. Used for data stewardship and cleansing prioritization.' ;
    rdfs:domain ind:LoyaltyLinkage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:externalReferenceCode rdf:type rdf:Property ;
    rdfs:label 'External Reference Code' ;
    rdfs:comment 'The unique identifier or key used by the external loyalty system or partner FFP to reference this linkage. Used for API calls, reconciliation, and cross-system traceability.' ;
    rdfs:domain ind:LoyaltyLinkage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ffpProgramCode rdf:type rdf:Property ;
    rdfs:label 'Ffp Program Code' ;
    rdfs:comment 'IATA two-letter or three-character airline code identifying the loyalty program (e.g., UA for United MileagePlus, BA for British Airways Executive Club, LH for Lufthansa Miles & More). Includes own airline and partner programs within alliances (Star Alliance, oneworld, SkyTeam).' ;
    rdfs:domain ind:LoyaltyLinkage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastSyncTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Sync Timestamp' ;
    rdfs:comment 'The timestamp when this loyalty linkage record was last synchronized with the source loyalty system (e.g., Oracle Loyalty Cloud, partner FFP API). Used for data freshness monitoring and incremental load orchestration.' ;
    rdfs:domain ind:LoyaltyLinkage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastVerifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Verified Timestamp' ;
    rdfs:comment 'The timestamp when the linkage and tier status were last verified or synchronized with the authoritative loyalty system. Used to determine data freshness and trigger re-verification workflows.' ;
    rdfs:domain ind:LoyaltyLinkage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:linkageSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Linkage Source System' ;
    rdfs:comment 'The operational system or channel from which this loyalty linkage was created or last updated (e.g., Amadeus Altéa PSS, Oracle Loyalty Cloud, Mobile App, Web Portal, Customer Service, GDS).' ;
    rdfs:domain ind:LoyaltyLinkage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linkageStatus rdf:type rdf:Property ;
    rdfs:label 'Linkage Status' ;
    rdfs:comment 'Current status of the loyalty program linkage. Active indicates the linkage is operational and tier benefits apply. Suspended indicates temporary hold (e.g., fraud investigation). Unlinked indicates the passenger has removed the association. Pending verification indicates awaiting confirmation from the FFP. Expired indicates the membership has lapsed. Merged indicates the membership was consolidated into another record.' ;
    rdfs:domain ind:LoyaltyLinkage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:linkageType rdf:type rdf:Property ;
    rdfs:label 'Linkage Type' ;
    rdfs:comment 'Classification of the loyalty linkage. Primary indicates the passenger\'s main FFP membership with the airline. Secondary indicates an additional membership. Partner indicates a linked membership with a codeshare or alliance partner. Reciprocal indicates a mutual recognition agreement membership.' ;
    rdfs:domain ind:LoyaltyLinkage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reciprocalBenefitEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Reciprocal Benefit Eligible Flag' ;
    rdfs:comment 'Boolean flag indicating whether this linkage qualifies for reciprocal benefits under alliance or partnership agreements (e.g., lounge access, priority boarding on partner airlines). True indicates eligibility; False indicates ineligible or restricted.' ;
    rdfs:domain ind:LoyaltyLinkage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:recognitionPriority rdf:type rdf:Property ;
    rdfs:label 'Recognition Priority' ;
    rdfs:comment 'Numeric priority order for tier recognition when a passenger has multiple linked FFP memberships. Lower numbers indicate higher priority (1 = highest). Used at check-in and boarding to determine which tier benefits to apply.' ;
    rdfs:domain ind:LoyaltyLinkage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:syncStatus rdf:type rdf:Property ;
    rdfs:label 'Sync Status' ;
    rdfs:comment 'Status of the most recent synchronization attempt with the source loyalty system. Success indicates data is current. Failed indicates synchronization error. Pending indicates sync in progress. Skipped indicates sync was bypassed. Partial indicates incomplete data received.' ;
    rdfs:domain ind:LoyaltyLinkage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unlinkedDate rdf:type rdf:Property ;
    rdfs:label 'Unlinked Date' ;
    rdfs:comment 'The date on which this loyalty program membership was unlinked from the passenger profile. Null if the linkage is still active or has never been unlinked.' ;
    rdfs:domain ind:LoyaltyLinkage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:unlinkedReasonCode rdf:type rdf:Property ;
    rdfs:label 'Unlinked Reason Code' ;
    rdfs:comment 'The reason code explaining why the loyalty linkage was unlinked. Null if the linkage has never been unlinked.' ;
    rdfs:domain ind:LoyaltyLinkage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:travellerSegmentId rdf:type rdf:Property ;
    rdfs:label 'Traveller Segment Id' ;
    rdfs:comment 'Primary key for traveller_segment' ;
    rdfs:domain ind:TravellerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ancillaryPropensityScore rdf:type rdf:Property ;
    rdfs:label 'Ancillary Propensity Score' ;
    rdfs:comment 'Propensity score (0.0000 to 1.0000) indicating likelihood of purchasing ancillary services (seat selection, baggage, meals, lounge access). Used for upsell targeting.' ;
    rdfs:domain ind:TravellerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:assignmentDate rdf:type rdf:Property ;
    rdfs:label 'Assignment Date' ;
    rdfs:comment 'Date when the passenger was assigned to this segment. Used for segment tenure analysis and lifecycle tracking.' ;
    rdfs:domain ind:TravellerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bookingChannelPreference rdf:type rdf:Property ;
    rdfs:label 'Booking Channel Preference' ;
    rdfs:comment 'Preferred or most frequently used booking channel: direct web, mobile app, GDS (Global Distribution System), travel agent, call center, or mixed.' ;
    rdfs:domain ind:TravellerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:churnRiskScore rdf:type rdf:Property ;
    rdfs:label 'Churn Risk Score' ;
    rdfs:comment 'Predictive score (0.0000 to 1.0000) indicating the likelihood of passenger churn (switching to competitor or ceasing travel). Higher score indicates higher risk.' ;
    rdfs:domain ind:TravellerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:confidenceScore rdf:type rdf:Property ;
    rdfs:label 'Confidence Score' ;
    rdfs:comment 'Statistical confidence or probability score (0.0000 to 1.0000) indicating the model\'s certainty in this segment assignment. Applicable for ML-derived segments; null for rule-based assignments.' ;
    rdfs:domain ind:TravellerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:corporateAffiliationFlag rdf:type rdf:Property ;
    rdfs:label 'Corporate Affiliation Flag' ;
    rdfs:comment 'Indicates whether the passenger is affiliated with a corporate travel program or business account (true) or is a leisure/individual traveller (false).' ;
    rdfs:domain ind:TravellerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Review Date' ;
    rdfs:comment 'Date when this segment assignment was last reviewed or refreshed by the segmentation process. Used for data quality monitoring and refresh scheduling.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lifetimeValueTier rdf:type rdf:Property ;
    rdfs:label 'Lifetime Value Tier' ;
    rdfs:comment 'Lifetime value tier classification derived from historical and predicted revenue: platinum (highest value), gold, silver, bronze, or standard. Distinct from loyalty program tier.' ;
    rdfs:domain ind:TravellerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loyaltyEngagementLevel rdf:type rdf:Property ;
    rdfs:label 'Loyalty Engagement Level' ;
    rdfs:comment 'Level of engagement with the airline\'s FFP (Frequent Flyer Program): highly engaged (active accrual and redemption), engaged, moderately engaged, low engagement, or not enrolled.' ;
    rdfs:domain ind:TravellerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceSensitivityIndicator rdf:type rdf:Property ;
    rdfs:label 'Price Sensitivity Indicator' ;
    rdfs:comment 'Assessed price sensitivity level of the passenger segment: very high (highly price-sensitive, seeks lowest fares), high, medium, low, or very low (price-insensitive, values convenience/service).' ;
    rdfs:domain ind:TravellerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueContributionScore rdf:type rdf:Property ;
    rdfs:label 'Revenue Contribution Score' ;
    rdfs:comment 'Estimated or actual revenue contribution value associated with this passenger segment, used for value-based segmentation and prioritization. Currency in airline\'s base currency.' ;
    rdfs:domain ind:TravellerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:routePreferenceType rdf:type rdf:Property ;
    rdfs:label 'Route Preference Type' ;
    rdfs:comment 'Predominant route type preference: domestic, short-haul international, long-haul international, or mixed. Used for network planning and targeted offers.' ;
    rdfs:domain ind:TravellerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentCategory rdf:type rdf:Property ;
    rdfs:label 'Segment Category' ;
    rdfs:comment 'High-level classification of the segment type: value-based, behavior-based, lifecycle stage, propensity model, demographic, or geographic segmentation.' ;
    rdfs:domain ind:TravellerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentCode rdf:type rdf:Property ;
    rdfs:label 'Segment Code' ;
    rdfs:comment 'Unique code identifying the segment type (e.g., HVT for high-value traveller, CFF for corporate frequent flyer, LSR for leisure traveller, PSN for price-sensitive, PRM for premium loyalist, LPS for lapsed traveller).' ;
    rdfs:domain ind:TravellerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentDescription rdf:type rdf:Property ;
    rdfs:label 'Segment Description' ;
    rdfs:comment 'Detailed textual description of the segment characteristics, targeting criteria, and business rationale. Used for segment documentation and stakeholder communication.' ;
    rdfs:domain ind:TravellerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentModelVersion rdf:type rdf:Property ;
    rdfs:label 'Segment Model Version' ;
    rdfs:comment 'Version identifier of the segmentation model or rule set used to assign this segment. Enables tracking of model evolution and reprocessing.' ;
    rdfs:domain ind:TravellerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentName rdf:type rdf:Property ;
    rdfs:label 'Segment Name' ;
    rdfs:comment 'Human-readable name of the passenger segment (e.g., High-Value Traveller, Corporate Frequent Flyer, Leisure Traveller, Price-Sensitive, Premium Loyalist, Lapsed Traveller).' ;
    rdfs:domain ind:TravellerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentNotes rdf:type rdf:Property ;
    rdfs:label 'Segment Notes' ;
    rdfs:comment 'Free-text field for additional notes, comments, or context about this segment assignment. Used for manual overrides, special cases, or analyst annotations.' ;
    rdfs:domain ind:TravellerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentPriority rdf:type rdf:Property ;
    rdfs:label 'Segment Priority' ;
    rdfs:comment 'Numeric priority ranking (1=highest) used when a passenger belongs to multiple segments simultaneously. Determines which segment takes precedence for targeting and personalization.' ;
    rdfs:domain ind:TravellerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:segmentSource rdf:type rdf:Property ;
    rdfs:label 'Segment Source' ;
    rdfs:comment 'Origin of the segment assignment: rules engine (business rule-based), ML model (machine learning algorithm), manual (analyst-assigned), third-party (external data provider), or hybrid (combination of methods).' ;
    rdfs:domain ind:TravellerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:segmentSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Segment Source System' ;
    rdfs:comment 'Name or identifier of the system or model that generated the segment assignment (e.g., Sabre AirVision Revenue Management, internal propensity model, CRM segmentation engine).' ;
    rdfs:domain ind:TravellerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetingEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Targeting Eligible Flag' ;
    rdfs:comment 'Indicates whether this segment assignment makes the passenger eligible for targeted marketing campaigns and personalized offers (true) or should be excluded (false) due to opt-out or regulatory restrictions.' ;
    rdfs:domain ind:TravellerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:travelFrequencyBand rdf:type rdf:Property ;
    rdfs:label 'Travel Frequency Band' ;
    rdfs:comment 'Classification of passenger travel frequency based on flight count over a defined period: very high (frequent business traveller), high, medium, low, very low, or inactive (lapsed).' ;
    rdfs:domain ind:TravellerSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentId rdf:type rdf:Property ;
    rdfs:label 'Consent Id' ;
    rdfs:comment 'Primary key for consent' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minorGuardianId rdf:type rdf:Property ;
    rdfs:label 'Minor Guardian Id' ;
    rdfs:comment 'Foreign key linking to passenger.minor_guardian. Business justification: The consent table has explicit minor_consent_flag and parental_consent_verified_flag attributes, indicating that consent records for unaccompanied minors are a distinct business scenario requiring gua' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MinorGuardian .

ind:auditTrail rdf:type rdf:Property ;
    rdfs:label 'Audit Trail' ;
    rdfs:comment 'A structured log or reference to detailed audit records capturing all consent lifecycle events (granted, modified, withdrawn, expired). Supports regulatory audit and dispute resolution.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channel rdf:type rdf:Property ;
    rdfs:label 'Channel' ;
    rdfs:comment 'The channel or touchpoint through which the passenger provided or updated their consent. Critical for audit trail and consent validity verification.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentStatus rdf:type rdf:Property ;
    rdfs:label 'Consent Status' ;
    rdfs:comment 'Current lifecycle status of the consent. Indicates whether the passenger has granted, withdrawn, or is pending decision on the consent request. Expired indicates consent has passed its validity period.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consentType rdf:type rdf:Property ;
    rdfs:label 'Consent Type' ;
    rdfs:comment 'The category of consent granted or withheld by the passenger. Defines the specific data processing activity for which consent is required under GDPR, CCPA, PDPA, or other applicable data protection regulations.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceType rdf:type rdf:Property ;
    rdfs:label 'Device Type' ;
    rdfs:comment 'The type of device used by the passenger to provide consent. Supports user experience analysis and consent validity verification.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dpoReviewFlag rdf:type rdf:Property ;
    rdfs:label 'Dpo Review Flag' ;
    rdfs:comment 'Boolean indicator of whether this consent record has been reviewed or flagged for review by the airline\'s Data Protection Officer (DPO). Used for high-risk or disputed consent cases.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:grantedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Granted Timestamp' ;
    rdfs:comment 'The date and time when the passenger granted consent. Recorded in ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX). Required for GDPR and CCPA audit trails.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ipAddress rdf:type rdf:Property ;
    rdfs:label 'Ip Address' ;
    rdfs:comment 'The IP address from which the passenger submitted their consent. Used for fraud detection, audit trail, and jurisdiction determination. May be considered PII in some jurisdictions.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionCode rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Code' ;
    rdfs:comment 'The three-letter ISO 3166-1 alpha-3 country code representing the legal jurisdiction under which this consent was collected. Determines applicable data protection regulation (GDPR for EU, CCPA for California, PDPA for Singapore, etc.).' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageCode rdf:type rdf:Property ;
    rdfs:label 'Language Code' ;
    rdfs:comment 'The two-letter ISO 639-1 language code in which the consent request was presented to the passenger. Required for demonstrating informed consent in the passenger\'s preferred language.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalBasis rdf:type rdf:Property ;
    rdfs:label 'Legal Basis' ;
    rdfs:comment 'The lawful basis under GDPR Article 6 for processing the passenger\'s personal data. While this product focuses on consent, other legal bases may apply for specific processing activities.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minorConsentFlag rdf:type rdf:Property ;
    rdfs:label 'Minor Consent Flag' ;
    rdfs:comment 'Boolean indicator of whether this consent record pertains to a minor (passenger under the age of consent in the applicable jurisdiction). Triggers additional parental consent and verification requirements under GDPR Article 8 and COPPA.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:modifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Modified By User' ;
    rdfs:comment 'The identifier of the system user or automated process that last modified this consent record. Supports audit trail and accountability.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optInFlag rdf:type rdf:Property ;
    rdfs:label 'Opt In Flag' ;
    rdfs:comment 'Boolean indicator of whether the consent was obtained via opt-in (true) or opt-out (false) mechanism. GDPR requires opt-in for most marketing and profiling activities.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parentalConsentVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Parental Consent Verified Flag' ;
    rdfs:comment 'Boolean indicator of whether parental or guardian consent has been verified for a minor passenger. Null if minor_consent_flag is false. Required for GDPR Article 8 and COPPA compliance.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:processingPurpose rdf:type rdf:Property ;
    rdfs:label 'Processing Purpose' ;
    rdfs:comment 'The specific purpose for which the passenger\'s data will be processed under this consent. Examples include marketing communications, service personalization, loyalty program analytics, or partner offers. Required for GDPR Article 13 transparency.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalDueDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Due Date' ;
    rdfs:comment 'The date by which the airline should proactively request consent renewal from the passenger. Used for consent lifecycle management and regulatory compliance in jurisdictions requiring periodic re-consent.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:textSnapshot rdf:type rdf:Property ;
    rdfs:label 'Text Snapshot' ;
    rdfs:comment 'A snapshot or reference to the exact consent text presented to the passenger at the time of consent. Supports audit and dispute resolution by preserving the wording the passenger agreed to.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thirdPartySharingScope rdf:type rdf:Property ;
    rdfs:label 'Third Party Sharing Scope' ;
    rdfs:comment 'Description of the third-party entities or categories of entities with whom passenger data may be shared under this consent. Required for transparency under GDPR Article 13 and CCPA Section 1798.100(b).' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:userAgent rdf:type rdf:Property ;
    rdfs:label 'User Agent' ;
    rdfs:comment 'The user agent string of the browser or application used by the passenger to provide consent. Supports technical audit and fraud detection.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:version rdf:type rdf:Property ;
    rdfs:label 'Version' ;
    rdfs:comment 'The version identifier of the privacy policy or consent terms that were in effect at the time the passenger granted consent. Enables tracking of consent under different policy versions and supports re-consent workflows when policies change.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:withdrawnTimestamp rdf:type rdf:Property ;
    rdfs:label 'Withdrawn Timestamp' ;
    rdfs:comment 'The date and time when the passenger withdrew their consent. Null if consent has not been withdrawn. Recorded in ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX). Required for right-to-erasure compliance.' ;
    rdfs:domain ind:Consent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:acceptingCrewMemberId rdf:type rdf:Property ;
    rdfs:label 'Accepting Crew Member Id' ;
    rdfs:comment 'Foreign key linking to crew.crew_member. Business justification: Unaccompanied minor programs require airlines to document which cabin crew member accepted custody of the child at departure and handover. Legal liability and duty-of-care mandate. Crew member signs h' ;
    rdfs:domain ind:MinorGuardian ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Member .

ind:acceptingFlightLegAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Accepting Flight Leg Assignment Id' ;
    rdfs:comment 'Foreign key linking to crew.flight_leg_assignment. Business justification: Unaccompanied minor (UM) regulatory compliance and post-flight audit trails require tracing the exact crew flight leg assignment under which a crew member accepted a minor. Links the UM handoff event ' ;
    rdfs:domain ind:MinorGuardian ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FlightLegAssignment .

ind:authorizationDocumentExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Authorization Document Expiry Date' ;
    rdfs:comment 'Expiration date of the authorization document, if applicable. Ensures authorization is valid for the travel date.' ;
    rdfs:domain ind:MinorGuardian ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authorizationDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Authorization Document Reference' ;
    rdfs:comment 'Reference number or identifier of the authorization document. Used for audit trail and compliance verification.' ;
    rdfs:domain ind:MinorGuardian ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizationDocumentType rdf:type rdf:Property ;
    rdfs:label 'Authorization Document Type' ;
    rdfs:comment 'Type of legal authorization document provided to permit the minor to travel unaccompanied. Required for regulatory compliance and liability protection.' ;
    rdfs:domain ind:MinorGuardian ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dropoffAuthorizationFlag rdf:type rdf:Property ;
    rdfs:label 'Dropoff Authorization Flag' ;
    rdfs:comment 'Indicates whether this guardian is authorized to drop off the minor at the origin airport. True if authorized, False otherwise. Used for origin handover verification.' ;
    rdfs:domain ind:MinorGuardian ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:guardianAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Guardian Address Line 1' ;
    rdfs:comment 'Primary street address line for the guardian. Required for emergency contact and legal documentation.' ;
    rdfs:domain ind:MinorGuardian ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guardianAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Guardian Address Line 2' ;
    rdfs:comment 'Secondary address line for the guardian (apartment, suite, unit number). Optional address component.' ;
    rdfs:domain ind:MinorGuardian ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guardianAlternatePhoneNumber rdf:type rdf:Property ;
    rdfs:label 'Guardian Alternate Phone Number' ;
    rdfs:comment 'Secondary contact phone number for the guardian. Used as backup contact channel during UMNR service delivery.' ;
    rdfs:domain ind:MinorGuardian ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guardianCity rdf:type rdf:Property ;
    rdfs:label 'Guardian City' ;
    rdfs:comment 'City or municipality of the guardian residence. Part of the complete contact address.' ;
    rdfs:domain ind:MinorGuardian ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guardianCountryCode rdf:type rdf:Property ;
    rdfs:label 'Guardian Country Code' ;
    rdfs:comment 'Three-letter ISO country code of the guardian residence country (e.g., USA, CAN, GBR). Required for international UMNR services.' ;
    rdfs:domain ind:MinorGuardian ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guardianEmailAddress rdf:type rdf:Property ;
    rdfs:label 'Guardian Email Address' ;
    rdfs:comment 'Email address of the guardian. Used for pre-flight notifications, service confirmations, and post-flight communication.' ;
    rdfs:domain ind:MinorGuardian ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guardianFirstName rdf:type rdf:Property ;
    rdfs:label 'Guardian First Name' ;
    rdfs:comment 'First name or given name of the guardian. Used for identity verification during minor handover.' ;
    rdfs:domain ind:MinorGuardian ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guardianFullName rdf:type rdf:Property ;
    rdfs:label 'Guardian Full Name' ;
    rdfs:comment 'Full legal name of the authorized guardian or escort responsible for the unaccompanied minor. Required for handover procedures at origin and destination.' ;
    rdfs:domain ind:MinorGuardian ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guardianGovernmentIdNumber rdf:type rdf:Property ;
    rdfs:label 'Guardian Government Id Number' ;
    rdfs:comment 'Identification number from the guardian government-issued document. Recorded for liability and handover audit trail.' ;
    rdfs:domain ind:MinorGuardian ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guardianGovernmentIdType rdf:type rdf:Property ;
    rdfs:label 'Guardian Government Id Type' ;
    rdfs:comment 'Type of government-issued identification document presented by the guardian for identity verification during minor handover.' ;
    rdfs:domain ind:MinorGuardian ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guardianIdIssuingCountry rdf:type rdf:Property ;
    rdfs:label 'Guardian Id Issuing Country' ;
    rdfs:comment 'Three-letter ISO country code of the country that issued the guardian identification document (e.g., USA, GBR, CAN).' ;
    rdfs:domain ind:MinorGuardian ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guardianLastName rdf:type rdf:Property ;
    rdfs:label 'Guardian Last Name' ;
    rdfs:comment 'Last name or family name of the guardian. Used for identity verification during minor handover.' ;
    rdfs:domain ind:MinorGuardian ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guardianPhoneCountryCode rdf:type rdf:Property ;
    rdfs:label 'Guardian Phone Country Code' ;
    rdfs:comment 'International dialing code for the guardian phone number (e.g., +1, +44, +971). Ensures correct routing for international UMNR services.' ;
    rdfs:domain ind:MinorGuardian ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guardianPhoneNumber rdf:type rdf:Property ;
    rdfs:label 'Guardian Phone Number' ;
    rdfs:comment 'Primary contact phone number for the guardian. Used for operational communication during UMNR service delivery and irregular operations (IROP).' ;
    rdfs:domain ind:MinorGuardian ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guardianPostalCode rdf:type rdf:Property ;
    rdfs:label 'Guardian Postal Code' ;
    rdfs:comment 'Postal or ZIP code of the guardian residence. Used for address validation and emergency contact.' ;
    rdfs:domain ind:MinorGuardian ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guardianRole rdf:type rdf:Property ;
    rdfs:label 'Guardian Role' ;
    rdfs:comment 'Operational role of the guardian in the UMNR service workflow. Determines which airport handover procedures apply.' ;
    rdfs:domain ind:MinorGuardian ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guardianStateProvince rdf:type rdf:Property ;
    rdfs:label 'Guardian State Province' ;
    rdfs:comment 'State, province, or administrative region of the guardian residence. Required for certain jurisdictions.' ;
    rdfs:domain ind:MinorGuardian ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:guardianshipStatus rdf:type rdf:Property ;
    rdfs:label 'Guardianship Status' ;
    rdfs:comment 'Current lifecycle status of the guardian authorization record. Determines whether the guardian can be used for active UMNR bookings.' ;
    rdfs:domain ind:MinorGuardian ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pickupAuthorizationFlag rdf:type rdf:Property ;
    rdfs:label 'Pickup Authorization Flag' ;
    rdfs:comment 'Indicates whether this guardian is authorized to pick up the minor at the destination airport. True if authorized, False otherwise. Critical for ground handling handover procedures.' ;
    rdfs:domain ind:MinorGuardian ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:relationshipToMinor rdf:type rdf:Property ;
    rdfs:label 'Relationship To Minor' ;
    rdfs:comment 'Nature of the relationship between the guardian and the unaccompanied minor. Determines authorization level and liability scope.' ;
    rdfs:domain ind:MinorGuardian ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialInstructions rdf:type rdf:Property ;
    rdfs:label 'Special Instructions' ;
    rdfs:comment 'Free-text field for special handling instructions related to the guardian handover (e.g., custody arrangements, security concerns, language preferences). Used by ground handling staff.' ;
    rdfs:domain ind:Passenger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:watchlistCheckId rdf:type rdf:Property ;
    rdfs:label 'Watchlist Check Id' ;
    rdfs:comment 'Primary key for watchlist_check' ;
    rdfs:domain ind:WatchlistCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:triggeringApisSubmissionId rdf:type rdf:Property ;
    rdfs:label 'Triggering Apis Submission Id' ;
    rdfs:comment 'Foreign key linking to passenger.apis_submission. Business justification: Watchlist screening in airline operations is frequently triggered by or performed in conjunction with APIS data submission to border authorities. Linking watchlist_check.triggering_apis_submission_id ' ;
    rdfs:domain ind:WatchlistCheck ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ApisSubmission .

ind:apiPnrIndicator rdf:type rdf:Property ;
    rdfs:label 'Api Pnr Indicator' ;
    rdfs:comment 'Indicates whether the screening was performed using API data, PNR data, or both.' ;
    rdfs:domain ind:WatchlistCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boardingPassIssued rdf:type rdf:Property ;
    rdfs:label 'Boarding Pass Issued' ;
    rdfs:comment 'Indicates whether a boarding pass was issued following the watchlist check clearance.' ;
    rdfs:domain ind:WatchlistCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:checkTimestamp rdf:type rdf:Property ;
    rdfs:label 'Check Timestamp' ;
    rdfs:comment 'Date and time when the watchlist screening check was performed.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dataRetentionDate rdf:type rdf:Property ;
    rdfs:label 'Data Retention Date' ;
    rdfs:comment 'Date when this watchlist check record must be purged per regulatory data retention requirements.' ;
    rdfs:domain ind:WatchlistCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:matchReason rdf:type rdf:Property ;
    rdfs:label 'Match Reason' ;
    rdfs:comment 'Description of the reason for the match, including which passenger attributes triggered the screening alert.' ;
    rdfs:domain ind:WatchlistCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:matchScore rdf:type rdf:Property ;
    rdfs:label 'Match Score' ;
    rdfs:comment 'Numerical confidence score (0.00 to 100.00) indicating the likelihood of a true match when a potential match is detected.' ;
    rdfs:domain ind:WatchlistCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:matchStatus rdf:type rdf:Property ;
    rdfs:label 'Match Status' ;
    rdfs:comment 'Result of the watchlist screening check indicating whether the passenger matched any watchlist entries.' ;
    rdfs:domain ind:WatchlistCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorySubmissionReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Submission Reference' ;
    rdfs:comment 'Reference number or identifier for the regulatory submission of screening results to TSA, EU authorities, or other governing bodies.' ;
    rdfs:domain ind:WatchlistCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionAction rdf:type rdf:Property ;
    rdfs:label 'Resolution Action' ;
    rdfs:comment 'Action taken to resolve a potential or confirmed match, including clearance, escalation, or denial.' ;
    rdfs:domain ind:WatchlistCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionNotes rdf:type rdf:Property ;
    rdfs:label 'Resolution Notes' ;
    rdfs:comment 'Free-text notes documenting the resolution process, verification steps, and outcome.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resolutionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Resolution Timestamp' ;
    rdfs:comment 'Date and time when the watchlist match was resolved or cleared.' ;
    rdfs:domain ind:WatchlistCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:screeningJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Screening Jurisdiction' ;
    rdfs:comment 'Two or three-letter country or region code indicating the regulatory jurisdiction under which screening was performed.' ;
    rdfs:domain ind:WatchlistCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningProgram rdf:type rdf:Property ;
    rdfs:label 'Screening Program' ;
    rdfs:comment 'The regulatory or security program under which the watchlist check was performed.' ;
    rdfs:domain ind:WatchlistCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningSystem rdf:type rdf:Property ;
    rdfs:label 'Screening System' ;
    rdfs:comment 'Name or identifier of the automated screening system that performed the watchlist check.' ;
    rdfs:domain ind:WatchlistCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:screeningVersion rdf:type rdf:Property ;
    rdfs:label 'Screening Version' ;
    rdfs:comment 'Version number of the screening algorithm or watchlist data used for the check.' ;
    rdfs:domain ind:WatchlistCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:selecteeIndicator rdf:type rdf:Property ;
    rdfs:label 'Selectee Indicator' ;
    rdfs:comment 'Indicates whether the passenger was designated for enhanced secondary screening (SSSS - Secondary Security Screening Selection).' ;
    rdfs:domain ind:WatchlistCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:submissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Submission Timestamp' ;
    rdfs:comment 'Date and time when screening results were submitted to the regulatory authority.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:watchlistName rdf:type rdf:Property ;
    rdfs:label 'Watchlist Name' ;
    rdfs:comment 'Name or identifier of the specific watchlist that triggered a match (e.g., No Fly List, Selectee List, OFAC SDN List).' ;
    rdfs:domain ind:WatchlistCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apisSubmissionId rdf:type rdf:Property ;
    rdfs:label 'Apis Submission Id' ;
    rdfs:comment 'Unique identifier for the APIS submission record. Primary key.' ;
    rdfs:domain ind:ApisSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalSubmissionApisSubmissionId rdf:type rdf:Property ;
    rdfs:label 'Original Submission Apis Submission Id' ;
    rdfs:comment 'Reference to the original APIS submission record if this is a resubmission or correction. Null for original submissions.' ;
    rdfs:domain ind:ApisSubmission ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:ApisSubmission .

ind:authorityResponseCode rdf:type rdf:Property ;
    rdfs:label 'Authority Response Code' ;
    rdfs:comment 'Response code returned by the border control authority indicating acceptance, rejection reason, or error condition. Codes vary by authority (e.g., CBP response codes, UKBF codes).' ;
    rdfs:domain ind:ApisSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorityResponseMessage rdf:type rdf:Property ;
    rdfs:label 'Authority Response Message' ;
    rdfs:comment 'Human-readable message returned by the border control authority providing additional detail on the submission outcome or rejection reason.' ;
    rdfs:domain ind:ApisSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorityResponseTimestamp rdf:type rdf:Property ;
    rdfs:label 'Authority Response Timestamp' ;
    rdfs:comment 'Date and time when the border control authority returned a response to the APIS submission.' ;
    rdfs:domain ind:ApisSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:borderAuthorityCode rdf:type rdf:Property ;
    rdfs:label 'Border Authority Code' ;
    rdfs:comment 'Code identifying the specific border control authority that received the submission (e.g., CBP for US Customs and Border Protection, UKBF for UK Border Force, EES for EU Entry/Exit System).' ;
    rdfs:domain ind:ApisSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceMandate rdf:type rdf:Property ;
    rdfs:label 'Compliance Mandate' ;
    rdfs:comment 'The specific regulatory mandate or legal requirement under which this APIS submission was made (e.g., US CBP APIS Final Rule, EU Entry/Exit System Regulation 2017/2226, ICAO Annex 9 Standard 3.47).' ;
    rdfs:domain ind:ApisSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:messageReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Message Reference Number' ;
    rdfs:comment 'Unique reference number assigned to the APIS transmission message by the sending system or border control authority for tracking and reconciliation purposes.' ;
    rdfs:domain ind:ApisSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:resubmissionFlag rdf:type rdf:Property ;
    rdfs:label 'Resubmission Flag' ;
    rdfs:comment 'Indicates whether this submission is a resubmission of previously rejected or corrected APIS data (True) or an original submission (False).' ;
    rdfs:domain ind:ApisSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduledArrivalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Arrival Timestamp' ;
    rdfs:comment 'Scheduled arrival date and time of the flight leg for which APIS data was submitted.' ;
    rdfs:domain ind:ApisSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledDepartureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scheduled Departure Timestamp' ;
    rdfs:comment 'Scheduled departure date and time of the flight leg for which APIS data was submitted.' ;
    rdfs:domain ind:ApisSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:submissionChannel rdf:type rdf:Property ;
    rdfs:label 'Submission Channel' ;
    rdfs:comment 'Technical channel or interface used to transmit the APIS data (e.g., SITA Type B message, XML web service, EDI, proprietary API).' ;
    rdfs:domain ind:ApisSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionMethod rdf:type rdf:Property ;
    rdfs:label 'Submission Method' ;
    rdfs:comment 'Method by which the APIS data was submitted to border control authorities: automated (system-triggered), manual (agent-initiated), batch (scheduled bulk transmission), real_time (interactive submission).' ;
    rdfs:domain ind:ApisSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Submission Source System' ;
    rdfs:comment 'Name or code of the operational system that generated and transmitted the APIS submission (e.g., Amadeus Altéa DCS, Sabre AirCentre, SITA Horizon).' ;
    rdfs:domain ind:ApisSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:submissionStatus rdf:type rdf:Property ;
    rdfs:label 'Submission Status' ;
    rdfs:comment 'Current lifecycle status of the APIS submission: pending (awaiting authority response), accepted (approved by border control), rejected (denied by border control), error (technical transmission failure), cancelled (submission withdrawn).' ;
    rdfs:domain ind:ApisSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seatProductId rdf:type rdf:Property ;
    rdfs:label 'Seat Product Id' ;
    rdfs:comment 'Foreign key linking to ancillary.seat_product. Business justification: PRM (Persons with Reduced Mobility) seat pre-assignment process: accessibility profiles mandate specific seat product types (bulkhead, aisle, no-exit-row). Check-in and seat assignment systems use thi' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SeatProduct .

ind:ambulatoryStatus rdf:type rdf:Property ;
    rdfs:label 'Ambulatory Status' ;
    rdfs:comment 'Passengers ability to walk and move independently. Determines boarding method, seating restrictions, and emergency evacuation capability.' ;
    rdfs:domain ind:AccessibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assistanceAtArrivalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Assistance At Arrival Required Flag' ;
    rdfs:comment 'Indicates whether the passenger requires ground handling assistance at arrival airport (deplaning, baggage claim, customs, onward connection). Triggers PRM service request to ground handler.' ;
    rdfs:domain ind:AccessibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assistanceAtDepartureRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Assistance At Departure Required Flag' ;
    rdfs:comment 'Indicates whether the passenger requires ground handling assistance at departure airport (check-in, security, gate, boarding). Triggers PRM service request to ground handler.' ;
    rdfs:domain ind:AccessibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:assistanceAtTransitRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Assistance At Transit Required Flag' ;
    rdfs:comment 'Indicates whether the passenger requires ground handling assistance during transit or connection. Ensures continuity of care between flights.' ;
    rdfs:domain ind:AccessibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:boardingMethodPreference rdf:type rdf:Property ;
    rdfs:label 'Boarding Method Preference' ;
    rdfs:comment 'Preferred method for boarding the aircraft. Pre-board allows extra time; ambulift is a hydraulic lift vehicle; aisle chair is a narrow wheelchair for aircraft aisle; carry-onboard means passenger is carried by assistance personnel.' ;
    rdfs:domain ind:AccessibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cognitiveAssistanceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Cognitive Assistance Required Flag' ;
    rdfs:comment 'Indicates whether the passenger requires cognitive or developmental disability assistance. May require simplified instructions, extra time, or companion support.' ;
    rdfs:domain ind:AccessibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:companionTravelerRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Companion Traveler Required Flag' ;
    rdfs:comment 'Indicates whether the passenger is required to travel with a companion or safety assistant due to the severity of their disability. May be mandated by airline medical policy.' ;
    rdfs:domain ind:AccessibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hearingImpairmentLevel rdf:type rdf:Property ;
    rdfs:label 'Hearing Impairment Level' ;
    rdfs:comment 'Degree of hearing impairment. Determines need for visual safety briefings, written communication, and assistive listening devices.' ;
    rdfs:domain ind:AccessibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastVerifiedDate rdf:type rdf:Property ;
    rdfs:label 'Last Verified Date' ;
    rdfs:comment 'Date when the accessibility profile information was last verified or updated by the passenger or airline staff. Used for data quality and compliance auditing.' ;
    rdfs:domain ind:AccessibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:medicalClearanceExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Medical Clearance Expiry Date' ;
    rdfs:comment 'Date until which the medical clearance (MEDIF) is valid. Passenger cannot travel after this date without renewed clearance.' ;
    rdfs:domain ind:AccessibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:medicalClearanceRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Medical Clearance Required Flag' ;
    rdfs:comment 'Indicates whether the passenger requires medical clearance (MEDIF form) from airline medical services before travel. Triggered by certain medical conditions or equipment.' ;
    rdfs:domain ind:AccessibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:medicalEquipmentCarried rdf:type rdf:Property ;
    rdfs:label 'Medical Equipment Carried' ;
    rdfs:comment 'Description of medical equipment the passenger carries onboard (CPAP, portable oxygen concentrator, nebulizer, insulin pump). Free-text field for crew awareness and stowage planning.' ;
    rdfs:domain ind:AccessibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mobilityAidBatteryType rdf:type rdf:Property ;
    rdfs:label 'Mobility Aid Battery Type' ;
    rdfs:comment 'Type of battery powering the mobility aid device. Critical for dangerous goods compliance and cargo hold safety. Lithium-ion batteries have specific IATA DGR restrictions.' ;
    rdfs:domain ind:AccessibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mobilityAidBatteryWattHours rdf:type rdf:Property ;
    rdfs:label 'Mobility Aid Battery Watt Hours' ;
    rdfs:comment 'Energy capacity of the mobility aid battery in watt-hours. Required for lithium battery compliance checks per IATA DGR (batteries over 300Wh require special handling).' ;
    rdfs:domain ind:AccessibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mobilityAidFoldableFlag rdf:type rdf:Property ;
    rdfs:label 'Mobility Aid Foldable Flag' ;
    rdfs:comment 'Indicates whether the mobility aid device can be folded or disassembled for stowage. Affects cargo hold space allocation and handling procedures.' ;
    rdfs:domain ind:AccessibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mobilityAidHeightCm rdf:type rdf:Property ;
    rdfs:label 'Mobility Aid Height Cm' ;
    rdfs:comment 'Height dimension of the mobility aid device in centimeters. Used to determine cargo hold compatibility and stowage location.' ;
    rdfs:domain ind:AccessibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mobilityAidLengthCm rdf:type rdf:Property ;
    rdfs:label 'Mobility Aid Length Cm' ;
    rdfs:comment 'Length dimension of the mobility aid device in centimeters. Used to determine cargo hold compatibility and stowage location.' ;
    rdfs:domain ind:AccessibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mobilityAidType rdf:type rdf:Property ;
    rdfs:label 'Mobility Aid Type' ;
    rdfs:comment 'Type of mobility aid device used by the passenger. Determines handling and stowage requirements. [ENUM-REF-CANDIDATE: manual_wheelchair|electric_wheelchair|mobility_scooter|walker|cane|crutches|prosthetic|none — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AccessibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mobilityAidWeightKg rdf:type rdf:Property ;
    rdfs:label 'Mobility Aid Weight Kg' ;
    rdfs:comment 'Weight of the mobility aid device in kilograms. Required for cargo hold planning and aircraft weight and balance calculations.' ;
    rdfs:domain ind:AccessibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mobilityAidWidthCm rdf:type rdf:Property ;
    rdfs:label 'Mobility Aid Width Cm' ;
    rdfs:comment 'Width dimension of the mobility aid device in centimeters. Used to determine cargo hold compatibility and stowage location.' ;
    rdfs:domain ind:AccessibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oxygenFlowRateLpm rdf:type rdf:Property ;
    rdfs:label 'Oxygen Flow Rate Lpm' ;
    rdfs:comment 'Prescribed oxygen flow rate in liters per minute. Required for aircraft oxygen system configuration and medical clearance.' ;
    rdfs:domain ind:AccessibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:oxygenRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Oxygen Required Flag' ;
    rdfs:comment 'Indicates whether the passenger requires supplemental oxygen during flight. Requires advance coordination with medical services and aircraft equipment availability.' ;
    rdfs:domain ind:AccessibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preferredSeatingLocation rdf:type rdf:Property ;
    rdfs:label 'Preferred Seating Location' ;
    rdfs:comment 'Passengers preferred seating location based on accessibility needs. Bulkhead seats provide extra space for mobility aids; aisle seats facilitate lavatory access.' ;
    rdfs:domain ind:AccessibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prmCategory rdf:type rdf:Property ;
    rdfs:label 'Prm Category' ;
    rdfs:comment 'IATA standard PRM category code. WCHR=wheelchair for ramp, WCHS=wheelchair for stairs, WCHC=wheelchair for cabin seat, WCBD=dry cell battery wheelchair, WCBW=wet cell battery wheelchair, WCMP=manual wheelchair, BLND=blind, DEAF=deaf, DPNA=disabled passenger needing assistance, MAAS=meet and assist. [ENUM-REF-CANDIDATE: WCHR|WCHS|WCHC|WCBD|WCBW|WCMP|BLND|DEAF|DPNA|MAAS — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AccessibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:profileEffectiveFromDate rdf:type rdf:Property ;
    rdfs:label 'Profile Effective From Date' ;
    rdfs:comment 'Date from which this accessibility profile becomes effective and can be used for booking and SSR generation.' ;
    rdfs:domain ind:AccessibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:profileEffectiveToDate rdf:type rdf:Property ;
    rdfs:label 'Profile Effective To Date' ;
    rdfs:comment 'Date until which this accessibility profile remains valid. Nullable for indefinite profiles; populated for time-limited medical clearances.' ;
    rdfs:domain ind:AccessibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:seatingRestrictionNotes rdf:type rdf:Property ;
    rdfs:label 'Seating Restriction Notes' ;
    rdfs:comment 'Free-text notes on seating restrictions or requirements (e.g., cannot sit in exit row, requires adjacent seat for companion, needs armrest removal). Used by inventory and departure control systems.' ;
    rdfs:domain ind:AccessibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceAnimalFlag rdf:type rdf:Property ;
    rdfs:label 'Service Animal Flag' ;
    rdfs:comment 'Indicates whether the passenger travels with a trained service animal (guide dog, hearing dog, psychiatric service animal). Requires cabin accommodation and documentation.' ;
    rdfs:domain ind:AccessibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:serviceAnimalType rdf:type rdf:Property ;
    rdfs:label 'Service Animal Type' ;
    rdfs:comment 'Type of trained service animal accompanying the passenger. Determines seating location and cabin crew briefing requirements.' ;
    rdfs:domain ind:AccessibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stretcherRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Stretcher Required Flag' ;
    rdfs:comment 'Indicates whether the passenger requires stretcher accommodation. Requires removal of multiple seat rows and advance aircraft configuration.' ;
    rdfs:domain ind:AccessibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:visualImpairmentLevel rdf:type rdf:Property ;
    rdfs:label 'Visual Impairment Level' ;
    rdfs:comment 'Degree of visual impairment. Determines need for sighted guide, Braille materials, audio announcements, and service animal accommodation.' ;
    rdfs:domain ind:AccessibilityProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryId rdf:type rdf:Property ;
    rdfs:label 'Category Id' ;
    rdfs:comment 'Foreign key linking to ancillary.category. Business justification: Every ancillary product should be classified into a category from the reference taxonomy. The product_catalog table has product_category and product_subcategory as STRING columns, which are denormaliz' ;
    rdfs:domain ind:Ancillary ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Category .

ind:basePriceAmount rdf:type rdf:Property ;
    rdfs:label 'Base Price Amount' ;
    rdfs:comment 'Standard base price for the ancillary product in the default currency, before taxes, fees, and channel-specific adjustments. Used as reference price for revenue management and dynamic pricing.' ;
    rdfs:domain ind:Ancillary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:basePriceCurrency rdf:type rdf:Property ;
    rdfs:label 'Base Price Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the base price amount (e.g., \'USD\', \'EUR\', \'GBP\'). Defines the currency in which the product is priced in the master catalog.' ;
    rdfs:domain ind:ProductCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookingWindowEndHours rdf:type rdf:Property ;
    rdfs:label 'Booking Window End Hours' ;
    rdfs:comment 'Number of hours before scheduled departure when the ancillary product is no longer available for purchase (e.g., 24 hours before departure for baggage, 2 hours for seat selection). Null if available until departure.' ;
    rdfs:domain ind:ProductCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bookingWindowStartHours rdf:type rdf:Property ;
    rdfs:label 'Booking Window Start Hours' ;
    rdfs:comment 'Number of hours before scheduled departure when the ancillary product becomes available for purchase. Null if available immediately upon flight booking. Used for time-sensitive products like seat upgrades.' ;
    rdfs:domain ind:ProductCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cabinClassEligibility rdf:type rdf:Property ;
    rdfs:label 'Cabin Class Eligibility' ;
    rdfs:comment 'Comma-separated list of cabin classes for which this ancillary product is available (e.g., \'economy,premium_economy,business,first\'). Used to restrict or target products by travel class.' ;
    rdfs:domain ind:ProductCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:channelAvailability rdf:type rdf:Property ;
    rdfs:label 'Channel Availability' ;
    rdfs:comment 'Comma-separated list of sales channels where the ancillary product is available for purchase (e.g., \'web,mobile,airport,call_center,gds\'). Used to control distribution and channel-specific merchandising.' ;
    rdfs:domain ind:Ancillary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionRatePercent rdf:type rdf:Property ;
    rdfs:label 'Commission Rate Percent' ;
    rdfs:comment 'Percentage commission rate paid to sales agents, travel agencies, or distribution partners for selling this ancillary product. Used for partner settlement and revenue sharing calculations.' ;
    rdfs:domain ind:Ancillary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:effectiveEndDate rdf:type rdf:Property ;
    rdfs:label 'Effective End Date' ;
    rdfs:comment 'Date after which the ancillary product is no longer available for new bookings. Null for products with indefinite availability. Used for limited-time offers and product phase-outs.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:effectiveStartDate rdf:type rdf:Property ;
    rdfs:label 'Effective Start Date' ;
    rdfs:comment 'Date from which the ancillary product becomes available for sale and booking. Used for seasonal products, new product launches, and promotional offerings.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fareFamilyEligibility rdf:type rdf:Property ;
    rdfs:label 'Fare Family Eligibility' ;
    rdfs:comment 'Comma-separated list of fare families or branded fare products for which this ancillary is available or included (e.g., \'basic,standard,flex,premium\'). Used for unbundled fare strategy and fare family differentiation.' ;
    rdfs:domain ind:ProductCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iataEmdServiceType rdf:type rdf:Property ;
    rdfs:label 'Iata Emd Service Type' ;
    rdfs:comment 'IATA-standardized service type code used for EMD issuance and settlement. Maps ancillary products to industry-standard codes for interline billing and BSP/ARC settlement (e.g., \'0CC\' for baggage, \'0G1\' for lounge).' ;
    rdfs:domain ind:ProductCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iataSsimServiceCode rdf:type rdf:Property ;
    rdfs:label 'Iata Ssim Service Code' ;
    rdfs:comment 'IATA SSIM service code used for schedule and service data exchange. Identifies ancillary services in GDS and reservation systems.' ;
    rdfs:domain ind:ProductCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inventoryControlledFlag rdf:type rdf:Property ;
    rdfs:label 'Inventory Controlled Flag' ;
    rdfs:comment 'Indicates whether the ancillary product is subject to inventory control and capacity limits (e.g., lounge seats, premium seats, onboard meal quantities). True if inventory-controlled; false if unlimited availability.' ;
    rdfs:domain ind:Ancillary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maximumQuantity rdf:type rdf:Property ;
    rdfs:label 'Maximum Quantity' ;
    rdfs:comment 'Maximum number of units that can be purchased per passenger or per booking. Used to enforce business rules and prevent inventory abuse (e.g., maximum 3 checked bags per passenger).' ;
    rdfs:domain ind:Ancillary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minimumQuantity rdf:type rdf:Property ;
    rdfs:label 'Minimum Quantity' ;
    rdfs:comment 'Minimum number of units that must be purchased in a single transaction. Typically 1 for most ancillary products; may be higher for bulk or group purchases.' ;
    rdfs:domain ind:Ancillary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:partnerProductFlag rdf:type rdf:Property ;
    rdfs:label 'Partner Product Flag' ;
    rdfs:comment 'Indicates whether the ancillary product is provided by a third-party partner (e.g., car rental, hotel, travel insurance) rather than directly by the airline. True if partner product; false if airline-owned product.' ;
    rdfs:domain ind:ProductCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:passengerTypeEligibility rdf:type rdf:Property ;
    rdfs:label 'Passenger Type Eligibility' ;
    rdfs:comment 'Comma-separated list of passenger types eligible to purchase this ancillary product (e.g., \'adult,child,infant,senior,military,ffp_elite\'). Used to enforce eligibility rules and targeted merchandising.' ;
    rdfs:domain ind:ProductCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingModel rdf:type rdf:Property ;
    rdfs:label 'Pricing Model' ;
    rdfs:comment 'Pricing strategy applied to the ancillary product. Fixed pricing uses a constant price; dynamic pricing varies by demand, route, or booking class; tiered pricing offers volume discounts; bundled pricing includes multiple products; promotional pricing applies temporary discounts.' ;
    rdfs:domain ind:ProductCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productCode rdf:type rdf:Property ;
    rdfs:label 'Product Code' ;
    rdfs:comment 'Unique alphanumeric code identifying the ancillary product across all systems. Used for inventory, pricing, and settlement. Aligns with IATA EMD service type codes where applicable.' ;
    rdfs:domain ind:Ancillary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productDescription rdf:type rdf:Property ;
    rdfs:label 'Product Description' ;
    rdfs:comment 'Detailed description of the ancillary product, including features, benefits, terms, and conditions. Used for customer-facing marketing and internal reference.' ;
    rdfs:domain ind:ProductCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productName rdf:type rdf:Property ;
    rdfs:label 'Product Name' ;
    rdfs:comment 'Full business name of the ancillary product as displayed to customers and used in internal systems (e.g., \'Priority Boarding\', \'Extra Baggage 23kg\', \'Lounge Access Day Pass\').' ;
    rdfs:domain ind:Ancillary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productShortName rdf:type rdf:Property ;
    rdfs:label 'Product Short Name' ;
    rdfs:comment 'Abbreviated or shortened display name for the product, used in space-constrained interfaces such as mobile apps, boarding passes, and receipts.' ;
    rdfs:domain ind:ProductCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:productStatus rdf:type rdf:Property ;
    rdfs:label 'Product Status' ;
    rdfs:comment 'Current lifecycle status of the ancillary product in the catalog. Active products are available for sale; inactive products are temporarily unavailable; suspended products are under review; discontinued products are permanently retired; pending_approval products await commercial approval.' ;
    rdfs:domain ind:Ancillary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueAccountingCode rdf:type rdf:Property ;
    rdfs:label 'Revenue Accounting Code' ;
    rdfs:comment 'Internal accounting code used to classify ancillary revenue for financial reporting, revenue management, and general ledger posting. Maps to specific GL accounts in SAP FI/CO.' ;
    rdfs:domain ind:Ancillary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Tax Category Code' ;
    rdfs:comment 'Tax classification code used to determine applicable taxes, VAT, GST, or other government charges for the ancillary product. Maps to tax calculation rules in revenue accounting systems.' ;
    rdfs:domain ind:ProductCatalog ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Unit Of Measure' ;
    rdfs:comment 'Unit by which the ancillary product is quantified and sold (e.g., \'each\' for lounge access, \'kilogram\' for baggage weight, \'hour\' for Wi-Fi, \'segment\' for seat selection, \'piece\' for baggage count). [ENUM-REF-CANDIDATE: each|kilogram|pound|hour|day|trip|segment|piece — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentCategoryAncillaryCategoryId rdf:type rdf:Property ;
    rdfs:label 'Parent Category Ancillary Category Id' ;
    rdfs:comment 'Foreign key reference to a parent ancillary category, enabling hierarchical taxonomy structures (e.g., Baggage as parent, Checked Baggage and Carry-On Baggage as children).' ;
    rdfs:domain ind:Category ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Category .

ind:ancillaryCategoryStatus rdf:type rdf:Property ;
    rdfs:label 'Ancillary Category Status' ;
    rdfs:comment 'Current lifecycle status of the ancillary category indicating whether it is actively used in merchandising and revenue systems.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:atpcoServiceGroup rdf:type rdf:Property ;
    rdfs:label 'Atpco Service Group' ;
    rdfs:comment 'ATPCO Optional Services service group classification for the ancillary category, used for fare filing and distribution through GDS channels.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryDescription rdf:type rdf:Property ;
    rdfs:label 'Category Description' ;
    rdfs:comment 'Detailed textual description of the ancillary category, including scope, typical products included, and business purpose.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryLevel rdf:type rdf:Property ;
    rdfs:label 'Category Level' ;
    rdfs:comment 'Numeric indicator of the hierarchical level of this category within the taxonomy (e.g., 1 for top-level, 2 for sub-category, 3 for detailed classification).' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:categoryType rdf:type rdf:Property ;
    rdfs:label 'Category Type' ;
    rdfs:comment 'High-level classification of the ancillary category distinguishing between service-based, product-based, bundled offerings, insurance, ground transport, or accommodation.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:directChannelOnlyFlag rdf:type rdf:Property ;
    rdfs:label 'Direct Channel Only Flag' ;
    rdfs:comment 'Indicates whether this category is exclusively sold through direct airline channels (website, mobile app, call center) and not available via third-party distributors.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:displaySequence rdf:type rdf:Property ;
    rdfs:label 'Display Sequence' ;
    rdfs:comment 'Numeric ordering for display of this category in user interfaces, merchandising platforms, and reporting hierarchies.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dotReportableFlag rdf:type rdf:Property ;
    rdfs:label 'Dot Reportable Flag' ;
    rdfs:comment 'Indicates whether revenue from this ancillary category must be reported to the US Department of Transportation (DOT) in quarterly ancillary revenue disclosures.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:emdEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Emd Eligible Flag' ;
    rdfs:comment 'Indicates whether ancillary products in this category are eligible for issuance via Electronic Miscellaneous Document (EMD) per IATA standards.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gdsDistributionFlag rdf:type rdf:Property ;
    rdfs:label 'Gds Distribution Flag' ;
    rdfs:comment 'Indicates whether ancillary products in this category are distributed through Global Distribution Systems (GDS) such as Amadeus, Sabre, and Travelport.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iataPadisCode rdf:type rdf:Property ;
    rdfs:label 'Iata Padis Code' ;
    rdfs:comment 'IATA PADIS standard code for the ancillary category, enabling interoperability across Global Distribution Systems (GDS) and Passenger Service Systems (PSS).' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:merchandisingPriority rdf:type rdf:Property ;
    rdfs:label 'Merchandising Priority' ;
    rdfs:comment 'Numeric ranking indicating the priority of this category in merchandising and upsell workflows, with lower numbers representing higher priority.' ;
    rdfs:domain ind:Ancillary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ndcCompatibleFlag rdf:type rdf:Property ;
    rdfs:label 'Ndc Compatible Flag' ;
    rdfs:comment 'Indicates whether this ancillary category is compatible with IATA New Distribution Capability (NDC) standards for modern retailing and distribution.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryComplianceNotes rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Notes' ;
    rdfs:comment 'Free-text field capturing any regulatory compliance considerations specific to this ancillary category, including Department of Transportation (DOT), Federal Aviation Administration (FAA), European Union Aviation Safety Agency (EASA), or consumer protection requirements.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceDeliveryPoint rdf:type rdf:Property ;
    rdfs:label 'Service Delivery Point' ;
    rdfs:comment 'Indicates the primary point in the passenger journey where the ancillary service is delivered (e.g., pre-flight for advance seat selection, in-flight for meals, airport for lounge access).' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:unbundledFareComponentFlag rdf:type rdf:Property ;
    rdfs:label 'Unbundled Fare Component Flag' ;
    rdfs:comment 'Indicates whether this category represents a component of an unbundled fare strategy, where services traditionally included in the base fare are sold separately.' ;
    rdfs:domain ind:Category ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priceId rdf:type rdf:Property ;
    rdfs:label 'Price Id' ;
    rdfs:comment 'Primary key for price' ;
    rdfs:domain ind:Price ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:createdByUser rdf:type rdf:Property ;
    rdfs:label 'Created By User' ;
    rdfs:comment 'User identifier or system account that created this price record. Used for audit trail and accountability.' ;
    rdfs:domain ind:Ancillary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketCode rdf:type rdf:Property ;
    rdfs:label 'Market Code' ;
    rdfs:comment 'Geographic market or region code where this price applies (e.g., origin-destination pair, country, or region). Used when price is market-specific rather than route-specific.' ;
    rdfs:domain ind:Price ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceCode rdf:type rdf:Property ;
    rdfs:label 'Price Code' ;
    rdfs:comment 'Business identifier for the price record, used in revenue management and offer generation systems.' ;
    rdfs:domain ind:Price ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceDescription rdf:type rdf:Property ;
    rdfs:label 'Price Description' ;
    rdfs:comment 'Detailed textual description of the price, including any special conditions, restrictions, or promotional messaging. Used for customer-facing display.' ;
    rdfs:domain ind:Price ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceStatus rdf:type rdf:Property ;
    rdfs:label 'Price Status' ;
    rdfs:comment 'Current lifecycle status of the price record: active (in use), inactive (not currently offered), pending (scheduled for future activation), expired (past expiration date), or suspended (temporarily disabled).' ;
    rdfs:domain ind:Price ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priceType rdf:type rdf:Property ;
    rdfs:label 'Price Type' ;
    rdfs:comment 'Classification of the pricing strategy: flat fee (fixed amount), yield-linked (varies with fare class), dynamic (real-time demand-based), bundled (part of fare package), promotional (temporary discount), or seasonal (time-based).' ;
    rdfs:domain ind:Price ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfiscCode rdf:type rdf:Property ;
    rdfs:label 'Rfisc Code' ;
    rdfs:comment 'IATA Reason For Issuance Sub-Code identifying the specific ancillary service type (e.g., 0CC for checked baggage, 0B5 for seat selection). Used in EMD processing and settlement.' ;
    rdfs:domain ind:Ancillary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:travelDateFrom rdf:type rdf:Property ;
    rdfs:label 'Travel Date From' ;
    rdfs:comment 'The earliest travel date for which this price is applicable. Used for seasonal or date-restricted pricing. Null if no travel date restriction applies.' ;
    rdfs:domain ind:Ancillary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:travelDateTo rdf:type rdf:Property ;
    rdfs:label 'Travel Date To' ;
    rdfs:comment 'The latest travel date for which this price is applicable. Used for seasonal or date-restricted pricing. Null if no travel date restriction applies.' ;
    rdfs:domain ind:Ancillary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:updatedByUser rdf:type rdf:Property ;
    rdfs:label 'Updated By User' ;
    rdfs:comment 'User identifier or system account that last modified this price record. Used for audit trail and accountability.' ;
    rdfs:domain ind:Price ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baggageAllowancePieces rdf:type rdf:Property ;
    rdfs:label 'Baggage Allowance Pieces' ;
    rdfs:comment 'Number of checked baggage pieces included in the bundle entitlement. Null if baggage is not included or uses weight-based allowance.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:baggageAllowanceWeightKg rdf:type rdf:Property ;
    rdfs:label 'Baggage Allowance Weight Kg' ;
    rdfs:comment 'Total weight allowance in kilograms for checked baggage included in the bundle. Null if baggage is not included or uses piece-based allowance.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bookingChannelRestriction rdf:type rdf:Property ;
    rdfs:label 'Booking Channel Restriction' ;
    rdfs:comment 'Specifies any restrictions on which booking channels can sell this bundle (e.g., direct channels only, GDS excluded, mobile app exclusive). Empty if available on all channels. [ENUM-REF-CANDIDATE: all_channels|direct_only|gds_only|mobile_only|web_only|call_center_only|travel_agent_excluded — promote to reference product]' ;
    rdfs:domain ind:Ancillary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundleCode rdf:type rdf:Property ;
    rdfs:label 'Bundle Code' ;
    rdfs:comment 'Unique business identifier code for the bundle product used in reservation systems and merchandising platforms (e.g., BASIC_ECO, FLEX_PLUS, PREMIUM_BIZ).' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundleDescription rdf:type rdf:Property ;
    rdfs:label 'Bundle Description' ;
    rdfs:comment 'Detailed description of the bundle product including all included services, entitlements, restrictions, and value proposition for customer communication.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundleName rdf:type rdf:Property ;
    rdfs:label 'Bundle Name' ;
    rdfs:comment 'Marketing name of the bundle displayed to customers during booking and merchandising (e.g., Basic Economy, Flex Plus, Premium Business).' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundleStatus rdf:type rdf:Property ;
    rdfs:label 'Bundle Status' ;
    rdfs:comment 'Current lifecycle status of the bundle product indicating its availability for sale and merchandising.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundleTier rdf:type rdf:Property ;
    rdfs:label 'Bundle Tier' ;
    rdfs:comment 'Hierarchical tier level of the bundle within the airlines branded fare structure, indicating the level of service and entitlements included.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bundleType rdf:type rdf:Property ;
    rdfs:label 'Bundle Type' ;
    rdfs:comment 'Classification of the bundle product by its primary business purpose and composition strategy.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationRefundableFlag rdf:type rdf:Property ;
    rdfs:label 'Cancellation Refundable Flag' ;
    rdfs:comment 'Indicates whether tickets purchased with this bundle are refundable upon cancellation (True) or non-refundable (False).' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:includedServicesCount rdf:type rdf:Property ;
    rdfs:label 'Included Services Count' ;
    rdfs:comment 'The total number of distinct ancillary services included in this bundle composition.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:loungeAccessIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Lounge Access Included Flag' ;
    rdfs:comment 'Indicates whether airport lounge access is included as an entitlement in this bundle (True) or not (False).' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maximumAdvancePurchaseDays rdf:type rdf:Property ;
    rdfs:label 'Maximum Advance Purchase Days' ;
    rdfs:comment 'The maximum number of days before departure that this bundle can be purchased. Null if no maximum advance purchase restriction exists.' ;
    rdfs:domain ind:Ancillary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:mealServiceIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Meal Service Included Flag' ;
    rdfs:comment 'Indicates whether complimentary in-flight meal service is included in this bundle (True) or meals must be purchased separately (False).' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mileageAccrualPercentage rdf:type rdf:Property ;
    rdfs:label 'Mileage Accrual Percentage' ;
    rdfs:comment 'The percentage of flown miles that accrue to the passengers Frequent Flyer Program (FFP) account when traveling on this bundle (e.g., 100.00 for full accrual, 50.00 for half accrual).' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumAdvancePurchaseDays rdf:type rdf:Property ;
    rdfs:label 'Minimum Advance Purchase Days' ;
    rdfs:comment 'The minimum number of days before departure that this bundle must be purchased. Null if no advance purchase requirement exists.' ;
    rdfs:domain ind:Ancillary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pricingStrategy rdf:type rdf:Property ;
    rdfs:label 'Pricing Strategy' ;
    rdfs:comment 'The pricing methodology applied to this bundle indicating whether pricing is fixed, dynamically adjusted based on demand, or subject to yield management rules.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityBoardingIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Priority Boarding Included Flag' ;
    rdfs:comment 'Indicates whether priority boarding privileges are included in this bundle entitlement (True) or not (False).' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:routeRestrictionType rdf:type rdf:Property ;
    rdfs:label 'Route Restriction Type' ;
    rdfs:comment 'Indicates whether this bundle is available on all routes or restricted to specific route types (domestic, international, regional, or specific route list).' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seatSelectionIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Seat Selection Included Flag' ;
    rdfs:comment 'Indicates whether advance seat selection is included as an entitlement in this bundle (True) or must be purchased separately (False).' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:seatSelectionType rdf:type rdf:Property ;
    rdfs:label 'Seat Selection Type' ;
    rdfs:comment 'The category of seats available for selection under this bundle entitlement (standard, preferred, extra legroom, or any seat).' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standbyPriorityLevel rdf:type rdf:Property ;
    rdfs:label 'Standby Priority Level' ;
    rdfs:comment 'The priority level assigned to passengers on this bundle when placed on standby lists for earlier or alternative flights. Lower numbers indicate higher priority.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:travelDateRestrictionEnd rdf:type rdf:Property ;
    rdfs:label 'Travel Date Restriction End' ;
    rdfs:comment 'The latest travel date for which this bundle is valid and can be applied to bookings. Null if no end date restriction exists.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:travelDateRestrictionStart rdf:type rdf:Property ;
    rdfs:label 'Travel Date Restriction Start' ;
    rdfs:comment 'The earliest travel date for which this bundle is valid and can be applied to bookings. Null if no start date restriction exists.' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:wifiIncludedFlag rdf:type rdf:Property ;
    rdfs:label 'Wifi Included Flag' ;
    rdfs:comment 'Indicates whether complimentary in-flight Wi-Fi connectivity is included in this bundle entitlement (True) or not (False).' ;
    rdfs:domain ind:Bundle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bundleComponentId rdf:type rdf:Property ;
    rdfs:label 'Bundle Component Id' ;
    rdfs:comment 'Unique identifier for the bundle component junction record linking a bundle to a constituent ancillary product.' ;
    rdfs:domain ind:BundleComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ancillaryBundleComponentStatus rdf:type rdf:Property ;
    rdfs:label 'Ancillary Bundle Component Status' ;
    rdfs:comment 'Current lifecycle status of this bundle component: active (available for sale), inactive (not offered), suspended (temporarily unavailable), pending_approval (awaiting commercial approval), deprecated (being phased out), seasonal_inactive (off-season).' ;
    rdfs:domain ind:BundleComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cabinClassRestriction rdf:type rdf:Property ;
    rdfs:label 'Cabin Class Restriction' ;
    rdfs:comment 'Cabin class restriction for this component. Defines which cabin classes this component applies to within the bundle. All indicates no restriction.' ;
    rdfs:domain ind:BundleComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commissionEligible rdf:type rdf:Property ;
    rdfs:label 'Commission Eligible' ;
    rdfs:comment 'Indicates whether this component is eligible for travel agent or distribution partner commission. True if commissionable; false if non-commissionable.' ;
    rdfs:domain ind:BundleComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:componentSequence rdf:type rdf:Property ;
    rdfs:label 'Component Sequence' ;
    rdfs:comment 'Merchandising display order for this component within the bundle presentation, used for consistent UI rendering and fare comparison displays.' ;
    rdfs:domain ind:BundleComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:entitlementUnit rdf:type rdf:Property ;
    rdfs:label 'Entitlement Unit' ;
    rdfs:comment 'Unit of measure for the quantity entitlement: piece (baggage items), kilogram (weight allowance), segment (per flight leg), trip (round-trip), hour (lounge time), day (rental period), access (single entry), selection (seat choice), upgrade (cabin class). [ENUM-REF-CANDIDATE: piece|kilogram|segment|trip|hour|day|access|selection|upgrade — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BundleComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfillmentTiming rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Timing' ;
    rdfs:comment 'Defines when this component is delivered or activated in the customer journey: at_booking (immediate), pre_departure (before travel date), at_checkin (during check-in), at_gate (boarding area), onboard (during flight), post_flight (after arrival), on_demand (customer-initiated). [ENUM-REF-CANDIDATE: at_booking|pre_departure|at_checkin|at_gate|onboard|post_flight|on_demand — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BundleComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inclusionType rdf:type rdf:Property ;
    rdfs:label 'Inclusion Type' ;
    rdfs:comment 'Defines how this ancillary product is included in the bundle: mandatory (always included), optional (customer may decline), upgradeable (customer may enhance), conditional (subject to availability or route), promotional (limited-time offer), or seasonal (specific travel periods).' ;
    rdfs:domain ind:BundleComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incrementalChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Incremental Charge Amount' ;
    rdfs:comment 'Additional charge amount for this component if is_chargeable is true. Null or zero if component is fully included in bundle base price.' ;
    rdfs:domain ind:BundleComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isTransferable rdf:type rdf:Property ;
    rdfs:label 'Is Transferable' ;
    rdfs:comment 'Indicates whether this component entitlement can be transferred to another passenger or booking. True if transferable; false if restricted to original purchaser.' ;
    rdfs:domain ind:Ancillary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:passengerTypeRestriction rdf:type rdf:Property ;
    rdfs:label 'Passenger Type Restriction' ;
    rdfs:comment 'Passenger type restriction for this component. Defines which passenger types are eligible for this component within the bundle. All indicates no restriction. [ENUM-REF-CANDIDATE: all|adult|child|infant|senior|student|military|corporate — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BundleComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityEntitlement rdf:type rdf:Property ;
    rdfs:label 'Quantity Entitlement' ;
    rdfs:comment 'Number of units of this ancillary product included in the bundle entitlement (e.g., 1 for one checked bag, 2 for two lounge passes). Zero indicates unlimited or not-applicable.' ;
    rdfs:domain ind:BundleComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:serviceFeeCode rdf:type rdf:Property ;
    rdfs:label 'Service Fee Code' ;
    rdfs:comment 'Internal or IATA service fee code for revenue accounting and settlement of this component within the bundle.' ;
    rdfs:domain ind:BundleComponent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeAmount rdf:type rdf:Property ;
    rdfs:label 'Fee Amount' ;
    rdfs:comment 'Total fees charged on the ancillary order, including booking fees, service charges, and payment processing fees.' ;
    rdfs:domain ind:Ancillary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fulfillmentDate rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Date' ;
    rdfs:comment 'Timestamp when the ancillary service was delivered or consumed by the passenger. Null if not yet fulfilled.' ;
    rdfs:domain ind:AncillaryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:orderDate rdf:type rdf:Property ;
    rdfs:label 'Order Date' ;
    rdfs:comment 'Timestamp when the ancillary order was placed by the passenger or agent. Represents the principal business event time for revenue recognition.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderNumber rdf:type rdf:Property ;
    rdfs:label 'Order Number' ;
    rdfs:comment 'Externally-visible unique order number assigned to this ancillary purchase. Used for customer service, refunds, and revenue reconciliation.' ;
    rdfs:domain ind:AncillaryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderStatus rdf:type rdf:Property ;
    rdfs:label 'Order Status' ;
    rdfs:comment 'Current lifecycle status of the ancillary order. Tracks progression from initial booking through fulfillment or cancellation.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentReference rdf:type rdf:Property ;
    rdfs:label 'Payment Reference' ;
    rdfs:comment 'External reference number or transaction identifier from the payment gateway or processor. Used for payment reconciliation and dispute resolution.' ;
    rdfs:domain ind:AncillaryOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundEligibility rdf:type rdf:Property ;
    rdfs:label 'Refund Eligibility' ;
    rdfs:comment 'Indicates whether the ancillary order is eligible for refund based on fare rules, timing, and fulfillment status.' ;
    rdfs:domain ind:Ancillary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fulfillmentStationId rdf:type rdf:Property ;
    rdfs:label 'Fulfillment Station Id' ;
    rdfs:comment 'Foreign key linking to airport.station. Business justification: Order items have station-specific fulfillment points (baggage charges at check-in, lounge access at specific airports). Essential for station performance tracking, revenue attribution by location, and' ;
    rdfs:domain ind:OrderItem ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Station .

ind:terminalFacilityId rdf:type rdf:Property ;
    rdfs:label 'Terminal Facility Id' ;
    rdfs:comment 'Foreign key linking to airport.terminal_facility. Business justification: Lounge access, fast-track security, and terminal retail ancillary items are fulfilled at specific terminal facilities. This link enables terminal-level ancillary revenue reporting and facility utiliza' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TerminalFacility .

ind:confirmationNumber rdf:type rdf:Property ;
    rdfs:label 'Confirmation Number' ;
    rdfs:comment 'Confirmation or reference number issued upon successful booking of the ancillary service.' ;
    rdfs:domain ind:OrderItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fulfilmentReference rdf:type rdf:Property ;
    rdfs:label 'Fulfilment Reference' ;
    rdfs:comment 'Reference identifier used by operational systems to track delivery or fulfilment of the ancillary service (e.g., baggage tag number, seat assignment, lounge access code).' ;
    rdfs:domain ind:OrderItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Issued Timestamp' ;
    rdfs:comment 'Date and time when the EMD or service document was issued for this ancillary item, in yyyy-MM-ddTHH:mm:ss.SSSXXX format.' ;
    rdfs:domain ind:OrderItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lineNumber rdf:type rdf:Property ;
    rdfs:label 'Line Number' ;
    rdfs:comment 'Sequential ordering number of this item within the parent ancillary order. Used for display and processing order.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceStatus rdf:type rdf:Property ;
    rdfs:label 'Service Status' ;
    rdfs:comment 'Current status of the ancillary service: confirmed (service guaranteed), waitlisted (pending availability), cancelled (service cancelled), refunded (payment returned), pending (awaiting confirmation), or delivered (service fulfilled).' ;
    rdfs:domain ind:OrderItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ancillaryServiceCode rdf:type rdf:Property ;
    rdfs:label 'Ancillary Service Code' ;
    rdfs:comment 'IATA RFIC (Reason for Issuance Code) or RFISC (Reason for Issuance Sub-Code) identifying the specific ancillary service. Examples: 0CC=baggage, 0B5=seat selection, 0G1=lounge access.' ;
    rdfs:domain ind:AncillaryEmd ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeIndicator rdf:type rdf:Property ;
    rdfs:label 'Exchange Indicator' ;
    rdfs:comment 'Boolean flag indicating whether the EMD is exchangeable. True if the ancillary service can be exchanged for another service or flight, false if non-exchangeable.' ;
    rdfs:domain ind:AncillaryEmd ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:faceValueAmount rdf:type rdf:Property ;
    rdfs:label 'Face Value Amount' ;
    rdfs:comment 'Total face value amount of the EMD in the currency of issuance. Represents the gross charge for the ancillary service before any adjustments or taxes.' ;
    rdfs:domain ind:AncillaryEmd ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:formOfPayment rdf:type rdf:Property ;
    rdfs:label 'Form Of Payment' ;
    rdfs:comment 'Detailed form of payment string including masked card number or payment reference. Format follows IATA FOP standards. Contains partial payment card data.' ;
    rdfs:domain ind:AncillaryEmd ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalIssueDate rdf:type rdf:Property ;
    rdfs:label 'Original Issue Date' ;
    rdfs:comment 'Original issue date for exchanged or reissued EMDs. Tracks the first issuance date when an EMD has been modified or replaced.' ;
    rdfs:domain ind:AncillaryEmd ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:serviceQuantity rdf:type rdf:Property ;
    rdfs:label 'Service Quantity' ;
    rdfs:comment 'Quantity of the ancillary service purchased. For example, number of baggage pieces, number of meal vouchers, or 1 for single-use services like lounge access.' ;
    rdfs:domain ind:AncillaryEmd ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:validityEndDate rdf:type rdf:Property ;
    rdfs:label 'Validity End Date' ;
    rdfs:comment 'Last date on which the EMD is valid for use. After this date, the EMD expires and cannot be consumed or refunded.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validityStartDate rdf:type rdf:Property ;
    rdfs:label 'Validity Start Date' ;
    rdfs:comment 'First date on which the EMD is valid for use. Defines the beginning of the service consumption window.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:advanceSelectionWindowHours rdf:type rdf:Property ;
    rdfs:label 'Advance Selection Window Hours' ;
    rdfs:comment 'Number of hours before departure that advance seat selection opens for this product. Null if no time restriction applies.' ;
    rdfs:domain ind:SeatProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:basePriceUsd rdf:type rdf:Property ;
    rdfs:label 'Base Price Usd' ;
    rdfs:comment 'Standard base price for this seat product in USD. Actual pricing may vary by route, fare class, and dynamic pricing rules. Used as reference price for revenue attribution.' ;
    rdfs:domain ind:SeatProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bundleEligibility rdf:type rdf:Property ;
    rdfs:label 'Bundle Eligibility' ;
    rdfs:comment 'Comma-separated list of fare bundle codes that include this seat product as a complimentary benefit (e.g., \'BASIC,STANDARD,PREMIUM,BUSINESS\'). Empty if not included in any bundle.' ;
    rdfs:domain ind:SeatProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fareClassEligibility rdf:type rdf:Property ;
    rdfs:label 'Fare Class Eligibility' ;
    rdfs:comment 'Comma-separated list of fare class codes eligible to purchase or select this seat product (e.g., \'Y,B,M,H,Q,V,W\'). Empty indicates available to all fare classes.' ;
    rdfs:domain ind:SeatProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inSeatEntertainment rdf:type rdf:Property ;
    rdfs:label 'In Seat Entertainment' ;
    rdfs:comment 'Indicates whether this seat product includes a personal in-flight entertainment (IFE) screen. Key amenity for merchandising and customer experience differentiation.' ;
    rdfs:domain ind:SeatProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isAdvanceSelectionAllowed rdf:type rdf:Property ;
    rdfs:label 'Is Advance Selection Allowed' ;
    rdfs:comment 'Indicates whether passengers can select this seat product in advance during booking or check-in. False for seats assigned only at gate or by operational staff.' ;
    rdfs:domain ind:SeatProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isBassinetCompatible rdf:type rdf:Property ;
    rdfs:label 'Is Bassinet Compatible' ;
    rdfs:comment 'Indicates whether this seat product supports bassinet attachment for infant passengers. Typically applies to bulkhead seats in long-haul configurations.' ;
    rdfs:domain ind:SeatProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isBulkhead rdf:type rdf:Property ;
    rdfs:label 'Is Bulkhead' ;
    rdfs:comment 'Indicates whether this seat product is located at a bulkhead position (wall or divider in front). Affects legroom, storage, and bassinet availability.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isExitRow rdf:type rdf:Property ;
    rdfs:label 'Is Exit Row' ;
    rdfs:comment 'Indicates whether this seat product is located in an emergency exit row. Triggers regulatory eligibility checks and safety briefing requirements per FAA/EASA regulations.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pricingTier rdf:type rdf:Property ;
    rdfs:label 'Pricing Tier' ;
    rdfs:comment 'Revenue tier classification for this seat product. References pricing rules and fare class eligibility in revenue management systems.' ;
    rdfs:domain ind:SeatProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reclineInches rdf:type rdf:Property ;
    rdfs:label 'Recline Inches' ;
    rdfs:comment 'Maximum recline distance of the seat in inches. Null for non-reclining seats (e.g., exit row, bulkhead).' ;
    rdfs:domain ind:SeatProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:refundabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Refundability Flag' ;
    rdfs:comment 'Indicates whether the seat product purchase is refundable if the passenger cancels or changes their seat selection. Subject to fare rules and timing restrictions.' ;
    rdfs:domain ind:SeatProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:seatType rdf:type rdf:Property ;
    rdfs:label 'Seat Type' ;
    rdfs:comment 'Primary classification of the seat product defining its physical and commercial characteristics. Drives merchandising strategy and revenue attribution. [ENUM-REF-CANDIDATE: standard|preferred|extra_legroom|exit_row|bulkhead|bassinet|window|aisle|middle — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialServiceRequestCode rdf:type rdf:Property ;
    rdfs:label 'Special Service Request Code' ;
    rdfs:comment 'Four-letter IATA SSR code associated with this seat product for GDS and Passenger Service System (PSS) integration (e.g., \'EXST\' for extra seat, \'BLND\' for blind passenger). Null if no SSR applies.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Transferability Flag' ;
    rdfs:comment 'Indicates whether the seat product can be transferred to another passenger on the same Passenger Name Record (PNR) or flight. Typically false for personalized seat assignments.' ;
    rdfs:domain ind:SeatProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:wifiAccessIncluded rdf:type rdf:Property ;
    rdfs:label 'Wifi Access Included' ;
    rdfs:comment 'Indicates whether complimentary Wi-Fi access is included with this seat product. False if Wi-Fi requires separate purchase or is not available.' ;
    rdfs:domain ind:SeatProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:zoneClassification rdf:type rdf:Property ;
    rdfs:label 'Zone Classification' ;
    rdfs:comment 'Cabin zone or section identifier where this seat product is typically located (e.g., \'Forward Cabin\', \'Mid Cabin\', \'Aft Cabin\', \'Zone A\', \'Zone B\'). Used for operational boarding and merchandising segmentation.' ;
    rdfs:domain ind:SeatProduct ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ancillaryOrderItemId rdf:type rdf:Property ;
    rdfs:label 'Ancillary Order Item Id' ;
    rdfs:comment 'Reference to the ancillary order item if this seat assignment was purchased as a paid ancillary product. Null for complimentary or auto-assigned seats.' ;
    rdfs:domain ind:SeatAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:OrderItem .

ind:assignmentMethod rdf:type rdf:Property ;
    rdfs:label 'Assignment Method' ;
    rdfs:comment 'The method or channel through which the seat assignment was made, indicating whether it was passenger self-service, agent-assisted, or system auto-assigned. [ENUM-REF-CANDIDATE: self_select|agent_assigned|auto_assigned|kiosk|mobile_app|web|gate — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SeatAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Assignment Source System' ;
    rdfs:comment 'The source system or channel that originated the seat assignment transaction (PSS=Passenger Service System, DCS=Departure Control System, GDS=Global Distribution System). [ENUM-REF-CANDIDATE: pss|dcs|kiosk|mobile_app|web|gds|api — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SeatAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentStatus rdf:type rdf:Property ;
    rdfs:label 'Assignment Status' ;
    rdfs:comment 'Current lifecycle status of the seat assignment indicating whether it is active, cancelled, or in transition.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assignment Timestamp' ;
    rdfs:comment 'The date and time when the seat assignment was created or last modified. Follows ISO 8601 format yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:blockReason rdf:type rdf:Property ;
    rdfs:label 'Block Reason' ;
    rdfs:comment 'Free-text description of the reason why the seat is blocked if is_blocked is true. Examples include crew rest, broken seat, social distancing, etc.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cabinClassCode rdf:type rdf:Property ;
    rdfs:label 'Cabin Class Code' ;
    rdfs:comment 'Single-letter IATA cabin class code indicating the service class of the assigned seat (F=First, J=Business, W=Premium Economy, Y=Economy).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeReasonCode rdf:type rdf:Property ;
    rdfs:label 'Change Reason Code' ;
    rdfs:comment 'Code indicating the reason for a seat assignment change if the seat was reassigned after initial assignment. [ENUM-REF-CANDIDATE: passenger_request|operational|equipment_change|overbooking|upgrade|downgrade|irop|other — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:SeatAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deckLevel rdf:type rdf:Property ;
    rdfs:label 'Deck Level' ;
    rdfs:comment 'The deck or level of the aircraft where the seat is located. Relevant for wide-body aircraft with multiple decks.' ;
    rdfs:domain ind:SeatAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groupBookingIndicator rdf:type rdf:Property ;
    rdfs:label 'Group Booking Indicator' ;
    rdfs:comment 'Boolean flag indicating whether this seat assignment is part of a group booking, which may have special handling or pricing rules.' ;
    rdfs:domain ind:SeatAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:infantIndicator rdf:type rdf:Property ;
    rdfs:label 'Infant Indicator' ;
    rdfs:comment 'Boolean flag indicating whether an infant (lap child) is associated with this seat assignment, which may restrict certain seat types such as exit rows.' ;
    rdfs:domain ind:SeatAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isBlocked rdf:type rdf:Property ;
    rdfs:label 'Is Blocked' ;
    rdfs:comment 'Boolean flag indicating whether the seat is blocked from assignment due to operational, safety, or commercial reasons.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isComplimentary rdf:type rdf:Property ;
    rdfs:label 'Is Complimentary' ;
    rdfs:comment 'Boolean flag indicating whether the seat assignment was provided at no charge (true) or as a paid ancillary service (false).' ;
    rdfs:domain ind:SeatAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loyaltyTierAtAssignment rdf:type rdf:Property ;
    rdfs:label 'Loyalty Tier At Assignment' ;
    rdfs:comment 'The passenger\'s loyalty program tier status at the time of seat assignment, which may influence seat selection privileges and complimentary upgrades.' ;
    rdfs:domain ind:SeatAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousSeatNumber rdf:type rdf:Property ;
    rdfs:label 'Previous Seat Number' ;
    rdfs:comment 'The seat number previously assigned to this passenger on this flight segment before a change was made. Null if this is the first assignment.' ;
    rdfs:domain ind:SeatAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seatCharacteristics rdf:type rdf:Property ;
    rdfs:label 'Seat Characteristics' ;
    rdfs:comment 'Comma-separated list of seat characteristics or attributes such as window, aisle, extra legroom, power outlet, restricted recline, etc.' ;
    rdfs:domain ind:SeatAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seatFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Seat Fee Amount' ;
    rdfs:comment 'The monetary amount charged for the seat assignment if it was a paid ancillary product. Zero or null for complimentary assignments.' ;
    rdfs:domain ind:SeatAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:seatFeeCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Seat Fee Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the seat assignment fee amount.' ;
    rdfs:domain ind:SeatAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seatNumber rdf:type rdf:Property ;
    rdfs:label 'Seat Number' ;
    rdfs:comment 'The alphanumeric seat identifier consisting of row number and seat letter (e.g., 12A, 34F). Follows standard aircraft seat numbering convention.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upgradeType rdf:type rdf:Property ;
    rdfs:label 'Upgrade Type' ;
    rdfs:comment 'Indicates the type of upgrade applied if the seat assignment represents an upgrade from the originally booked cabin or seat type. Null or none if no upgrade. [ENUM-REF-CANDIDATE: paid|complimentary|operational|elite_status|voucher|bid|none — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Ancillary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allowanceCode rdf:type rdf:Property ;
    rdfs:label 'Allowance Code' ;
    rdfs:comment 'Unique business identifier for the baggage allowance rule, used for reference in fare products and ancillary catalogs.' ;
    rdfs:domain ind:BaggageAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allowanceName rdf:type rdf:Property ;
    rdfs:label 'Allowance Name' ;
    rdfs:comment 'Human-readable name of the baggage allowance rule (e.g., \'Economy Standard 2PC\', \'Business Premium 3PC 32KG\').' ;
    rdfs:domain ind:BaggageAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allowanceType rdf:type rdf:Property ;
    rdfs:label 'Allowance Type' ;
    rdfs:comment 'The allowance model applied: piece_concept (number of bags), weight_concept (total weight limit), or hybrid (combination of both).' ;
    rdfs:domain ind:BaggageAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicablePtc rdf:type rdf:Property ;
    rdfs:label 'Applicable Ptc' ;
    rdfs:comment 'Passenger Type Code this allowance applies to (e.g., ADT=adult, CHD=child, INF=infant, MIL=military). Null if applies to all passenger types.' ;
    rdfs:domain ind:BaggageAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baggageAllowanceStatus rdf:type rdf:Property ;
    rdfs:label 'Baggage Allowance Status' ;
    rdfs:comment 'Current lifecycle status of the baggage allowance rule: active (in use), inactive (not in use), pending (scheduled for future), expired (past validity), suspended (temporarily disabled).' ;
    rdfs:domain ind:BaggageAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationRegionCode rdf:type rdf:Property ;
    rdfs:label 'Destination Region Code' ;
    rdfs:comment 'IATA region or sub-region code for the destination (e.g., TC1=North America, TC2=Europe, TC3=Asia). Null if not region-specific.' ;
    rdfs:domain ind:BaggageAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dimensionLimitCm rdf:type rdf:Property ;
    rdfs:label 'Dimension Limit Cm' ;
    rdfs:comment 'Maximum dimensions allowed for each piece in centimeters, expressed as LxWxH (e.g., \'158x90x75\'). Null if no dimension restriction applies.' ;
    rdfs:domain ind:BaggageAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dimensionLimitInches rdf:type rdf:Property ;
    rdfs:label 'Dimension Limit Inches' ;
    rdfs:comment 'Maximum dimensions allowed for each piece in inches, expressed as LxWxH (e.g., \'62x35x30\'). Provided for markets using imperial units.' ;
    rdfs:domain ind:BaggageAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fareBrandCode rdf:type rdf:Property ;
    rdfs:label 'Fare Brand Code' ;
    rdfs:comment 'Fare brand or product code associated with this allowance (e.g., BASIC, STANDARD, FLEX, PREMIUM). Null if not brand-specific.' ;
    rdfs:domain ind:BaggageAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCombinable rdf:type rdf:Property ;
    rdfs:label 'Is Combinable' ;
    rdfs:comment 'Indicates whether this allowance can be combined with other allowances (e.g., fare allowance + FFP tier allowance). True if combinable, false if exclusive.' ;
    rdfs:domain ind:Ancillary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:linearDimensionLimitCm rdf:type rdf:Property ;
    rdfs:label 'Linear Dimension Limit Cm' ;
    rdfs:comment 'Maximum sum of length, width, and height in centimeters (L+W+H). Common standard is 158 cm for international checked baggage.' ;
    rdfs:domain ind:BaggageAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:linearDimensionLimitInches rdf:type rdf:Property ;
    rdfs:label 'Linear Dimension Limit Inches' ;
    rdfs:comment 'Maximum sum of length, width, and height in inches (L+W+H). Common standard is 62 inches for international checked baggage.' ;
    rdfs:domain ind:BaggageAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originRegionCode rdf:type rdf:Property ;
    rdfs:label 'Origin Region Code' ;
    rdfs:comment 'IATA region or sub-region code for the origin (e.g., TC1=North America, TC2=Europe, TC3=Asia). Null if not region-specific.' ;
    rdfs:domain ind:BaggageAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pieceCount rdf:type rdf:Property ;
    rdfs:label 'Piece Count' ;
    rdfs:comment 'Number of baggage pieces allowed under this rule (applicable for piece concept allowances). Null if weight concept only.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:routeGroupCode rdf:type rdf:Property ;
    rdfs:label 'Route Group Code' ;
    rdfs:comment 'Route group or geographic zone code this allowance applies to (e.g., DOM=domestic, INTL=international, TRANSATLANTIC). Null if applies globally.' ;
    rdfs:domain ind:BaggageAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialConditions rdf:type rdf:Property ;
    rdfs:label 'Special Conditions' ;
    rdfs:comment 'Free-text field describing any special conditions, restrictions, or notes applicable to this baggage allowance (e.g., \'Applies only to direct flights\', \'Excludes codeshare partners\').' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightLimitKg rdf:type rdf:Property ;
    rdfs:label 'Weight Limit Kg' ;
    rdfs:comment 'Maximum weight allowed per piece or total weight limit in kilograms. Applicable for weight concept or per-piece weight restrictions.' ;
    rdfs:domain ind:BaggageAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightLimitLbs rdf:type rdf:Property ;
    rdfs:label 'Weight Limit Lbs' ;
    rdfs:comment 'Maximum weight allowed per piece or total weight limit in pounds. Provided for markets using imperial units.' ;
    rdfs:domain ind:BaggageAllowance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sourceCabinClassId rdf:type rdf:Property ;
    rdfs:label 'Source Cabin Class Id' ;
    rdfs:comment 'Foreign key linking to inventory.cabin_class. Business justification: Upgrade offers specify source cabin class for eligibility (economy to business, business to first). Upgrade program design and offer targeting require formal cabin class linkage for source eligibility' ;
    rdfs:domain ind:UpgradeOffer ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CabinClass .

ind:eligibleFareClasses rdf:type rdf:Property ;
    rdfs:label 'Eligible Fare Classes' ;
    rdfs:comment 'Comma-separated list of fare class codes (booking classes) that qualify for this upgrade offer. Fare classes determine revenue management eligibility and upgrade priority.' ;
    rdfs:domain ind:UpgradeOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emdTypeCode rdf:type rdf:Property ;
    rdfs:label 'Emd Type Code' ;
    rdfs:comment 'IATA Electronic Miscellaneous Document (EMD) type code associated with this upgrade offer when issued as an ancillary charge. Typically \'A\' for EMD-A (standalone) or \'S\' for EMD-S (associated with e-ticket).' ;
    rdfs:domain ind:UpgradeOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fixedPriceAmount rdf:type rdf:Property ;
    rdfs:label 'Fixed Price Amount' ;
    rdfs:comment 'The fixed monetary price for instant upgrade offers. Null for bid-based or miles-based offers. Represents the non-negotiable purchase price.' ;
    rdfs:domain ind:UpgradeOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastModifiedByUser rdf:type rdf:Property ;
    rdfs:label 'Last Modified By User' ;
    rdfs:comment 'User identifier or system account that last modified this upgrade offer record. Audit field for change accountability and compliance.' ;
    rdfs:domain ind:Ancillary ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumBidAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Bid Amount' ;
    rdfs:comment 'The maximum monetary bid amount allowed for bid-based upgrade offers. Null for non-bid offer types. Represents the ceiling price for competitive bidding.' ;
    rdfs:domain ind:UpgradeOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumBidAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Bid Amount' ;
    rdfs:comment 'The minimum monetary bid amount required for bid-based upgrade offers. Null for non-bid offer types. Represents the floor price for competitive bidding.' ;
    rdfs:domain ind:UpgradeOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:offerCloseHours rdf:type rdf:Property ;
    rdfs:label 'Offer Close Hours' ;
    rdfs:comment 'Number of hours before scheduled departure when this upgrade offer closes and is no longer available for purchase or bidding. Defines the closing of the offer window.' ;
    rdfs:domain ind:UpgradeOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:offerCode rdf:type rdf:Property ;
    rdfs:label 'Offer Code' ;
    rdfs:comment 'Externally-known unique code identifying this upgrade offer in merchandising and revenue management systems.' ;
    rdfs:domain ind:UpgradeOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerDescription rdf:type rdf:Property ;
    rdfs:label 'Offer Description' ;
    rdfs:comment 'Detailed description of the upgrade offer including benefits, terms, and conditions presented to passengers during the offer flow.' ;
    rdfs:domain ind:UpgradeOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerName rdf:type rdf:Property ;
    rdfs:label 'Offer Name' ;
    rdfs:comment 'Marketing name or title of the upgrade offer displayed to passengers in booking channels and merchandising platforms.' ;
    rdfs:domain ind:UpgradeOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerStatus rdf:type rdf:Property ;
    rdfs:label 'Offer Status' ;
    rdfs:comment 'Current lifecycle status of the upgrade offer. Active offers are available for purchase or bidding; inactive offers are not currently presented; expired offers have passed their validity window; suspended offers are temporarily paused; withdrawn offers have been permanently removed.' ;
    rdfs:domain ind:UpgradeOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerType rdf:type rdf:Property ;
    rdfs:label 'Offer Type' ;
    rdfs:comment 'Classification of the upgrade offer mechanism. Bid upgrade allows passengers to submit competitive bids; instant upgrade is fixed-price immediate purchase; miles upgrade uses Frequent Flyer Program (FFP) miles; operational upgrade is airline-initiated for operational reasons; points upgrade uses loyalty points; voucher upgrade redeems a voucher or certificate.' ;
    rdfs:domain ind:UpgradeOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:offerWindowHours rdf:type rdf:Property ;
    rdfs:label 'Offer Window Hours' ;
    rdfs:comment 'Number of hours before scheduled departure that this upgrade offer becomes available to eligible passengers. Defines the opening of the offer window.' ;
    rdfs:domain ind:UpgradeOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pointsRequired rdf:type rdf:Property ;
    rdfs:label 'Points Required' ;
    rdfs:comment 'Number of loyalty points required to redeem this upgrade offer. Null for non-points-based offers. Distinct from miles for coalition or partner loyalty programs.' ;
    rdfs:domain ind:UpgradeOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetCabinClass rdf:type rdf:Property ;
    rdfs:label 'Target Cabin Class' ;
    rdfs:comment 'The destination cabin class to which the passenger will be upgraded if the offer is accepted and confirmed.' ;
    rdfs:domain ind:UpgradeOffer ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationFareClassBucketId rdf:type rdf:Property ;
    rdfs:label 'Destination Fare Class Bucket Id' ;
    rdfs:comment 'Foreign key linking to inventory.fare_class_bucket. Business justification: Upgrade clearance tracking by destination fare class bucket is a core RM process — upgrades consume inventory in the destination RBD bucket. upgrade_transaction has destination_fare_class as a plain d' ;
    rdfs:domain ind:UpgradeTransaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FareClassBucket .

ind:bidAcceptanceTimestamp rdf:type rdf:Property ;
    rdfs:label 'Bid Acceptance Timestamp' ;
    rdfs:comment 'Date and time when the upgrade bid was accepted and confirmed by the system. Null for non-bid or unsuccessful bid upgrades.' ;
    rdfs:domain ind:UpgradeTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:bidAmount rdf:type rdf:Property ;
    rdfs:label 'Bid Amount' ;
    rdfs:comment 'Amount bid by the passenger in an upgrade auction or bid program. Null for non-bid upgrades.' ;
    rdfs:domain ind:UpgradeTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bidSubmissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Bid Submission Timestamp' ;
    rdfs:comment 'Date and time when the passenger submitted the upgrade bid. Null for non-bid upgrades.' ;
    rdfs:domain ind:UpgradeTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:destinationCabinClass rdf:type rdf:Property ;
    rdfs:label 'Destination Cabin Class' ;
    rdfs:comment 'The target cabin class to which the passenger is upgrading (economy, premium_economy, business, first).' ;
    rdfs:domain ind:UpgradeTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationFareClass rdf:type rdf:Property ;
    rdfs:label 'Destination Fare Class' ;
    rdfs:comment 'Single-letter fare class code assigned after the upgrade is confirmed.' ;
    rdfs:domain ind:UpgradeTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originCabinClass rdf:type rdf:Property ;
    rdfs:label 'Origin Cabin Class' ;
    rdfs:comment 'The original cabin class from which the passenger is upgrading (economy, premium_economy, business, first).' ;
    rdfs:domain ind:UpgradeTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originFareClass rdf:type rdf:Property ;
    rdfs:label 'Origin Fare Class' ;
    rdfs:comment 'Single-letter fare class code of the original booking, determining upgrade eligibility and priority.' ;
    rdfs:domain ind:UpgradeTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityScore rdf:type rdf:Property ;
    rdfs:label 'Priority Score' ;
    rdfs:comment 'Calculated priority score determining upgrade clearance order, based on fare class, elite status, bid amount, and other factors.' ;
    rdfs:domain ind:UpgradeTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:refundProcessedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Refund Processed Timestamp' ;
    rdfs:comment 'Date and time when the refund was processed and returned to the passenger. Null if no refund issued.' ;
    rdfs:domain ind:UpgradeTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:seatNumberDestination rdf:type rdf:Property ;
    rdfs:label 'Seat Number Destination' ;
    rdfs:comment 'New seat assignment after the upgrade is cleared (e.g., 2A, 8D).' ;
    rdfs:domain ind:UpgradeTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seatNumberOrigin rdf:type rdf:Property ;
    rdfs:label 'Seat Number Origin' ;
    rdfs:comment 'Original seat assignment before the upgrade (e.g., 23A, 45F).' ;
    rdfs:domain ind:UpgradeTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upgradeAmount rdf:type rdf:Property ;
    rdfs:label 'Upgrade Amount' ;
    rdfs:comment 'Monetary amount paid by the passenger for the upgrade, in the transaction currency. Zero for non-purchased upgrades (miles, operational, complimentary).' ;
    rdfs:domain ind:UpgradeTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:upgradeConfirmedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Upgrade Confirmed Timestamp' ;
    rdfs:comment 'Date and time when the upgrade was confirmed and guaranteed to the passenger.' ;
    rdfs:domain ind:UpgradeTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:upgradeRequestTimestamp rdf:type rdf:Property ;
    rdfs:label 'Upgrade Request Timestamp' ;
    rdfs:comment 'Date and time when the upgrade transaction was initiated or requested by the passenger or system.' ;
    rdfs:domain ind:UpgradeTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:upgradeTransactionNumber rdf:type rdf:Property ;
    rdfs:label 'Upgrade Transaction Number' ;
    rdfs:comment 'Externally-visible unique transaction number for the upgrade event, used for customer service reference and audit tracking.' ;
    rdfs:domain ind:UpgradeTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:voucherCode rdf:type rdf:Property ;
    rdfs:label 'Voucher Code' ;
    rdfs:comment 'Alphanumeric code of the upgrade voucher or certificate applied to this transaction. Null if no voucher used.' ;
    rdfs:domain ind:UpgradeTransaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eligibilityRuleId rdf:type rdf:Property ;
    rdfs:label 'Eligibility Rule Id' ;
    rdfs:comment 'Primary key for eligibility_rule' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:aircraftTypeList rdf:type rdf:Property ;
    rdfs:label 'Aircraft Type List' ;
    rdfs:comment 'Comma-separated list of IATA aircraft type codes (e.g., 737, 777, A320) for which this ancillary product is eligible. Empty indicates no aircraft restriction.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bookingDateFrom rdf:type rdf:Property ;
    rdfs:label 'Booking Date From' ;
    rdfs:comment 'Start date of the booking window during which this eligibility rule is active. Null indicates no booking start date restriction.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bookingDateTo rdf:type rdf:Property ;
    rdfs:label 'Booking Date To' ;
    rdfs:comment 'End date of the booking window during which this eligibility rule is active. Null indicates no booking end date restriction.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cabinClassList rdf:type rdf:Property ;
    rdfs:label 'Cabin Class List' ;
    rdfs:comment 'Comma-separated list of cabin classes (First, Business, Premium Economy, Economy) eligible for this ancillary product. Empty indicates no cabin restriction.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationAirportList rdf:type rdf:Property ;
    rdfs:label 'Destination Airport List' ;
    rdfs:comment 'Comma-separated list of IATA airport codes representing eligible destination points. Empty indicates no destination restriction.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationCountryList rdf:type rdf:Property ;
    rdfs:label 'Destination Country List' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-2 country codes representing eligible destination countries. Empty indicates no destination country restriction.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exclusionRuleFlag rdf:type rdf:Property ;
    rdfs:label 'Exclusion Rule Flag' ;
    rdfs:comment 'Indicates whether this is an exclusion rule (true) that prevents eligibility, or an inclusion rule (false) that grants eligibility.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fareClassList rdf:type rdf:Property ;
    rdfs:label 'Fare Class List' ;
    rdfs:comment 'Comma-separated list of booking class codes (RBD - Revenue Booking Designator) to which this rule applies. Empty indicates no fare class restriction.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ffpTierList rdf:type rdf:Property ;
    rdfs:label 'Ffp Tier List' ;
    rdfs:comment 'Comma-separated list of loyalty program tier codes (e.g., Gold, Platinum, Diamond) eligible for this ancillary product. Empty indicates no tier restriction.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketingCarrierList rdf:type rdf:Property ;
    rdfs:label 'Marketing Carrier List' ;
    rdfs:comment 'Comma-separated list of IATA airline codes representing marketing carriers for which this rule applies. Empty indicates all carriers.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingCarrierList rdf:type rdf:Property ;
    rdfs:label 'Operating Carrier List' ;
    rdfs:comment 'Comma-separated list of IATA airline codes representing operating carriers for which this rule applies. Empty indicates all carriers.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originAirportList rdf:type rdf:Property ;
    rdfs:label 'Origin Airport List' ;
    rdfs:comment 'Comma-separated list of IATA airport codes representing eligible origin points. Empty indicates no origin restriction.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originCountryList rdf:type rdf:Property ;
    rdfs:label 'Origin Country List' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-2 country codes representing eligible origin countries. Empty indicates no origin country restriction.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Override Allowed Flag' ;
    rdfs:comment 'Indicates whether authorized agents or systems may override this eligibility rule under exceptional circumstances.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:passengerTypeCodeList rdf:type rdf:Property ;
    rdfs:label 'Passenger Type Code List' ;
    rdfs:comment 'Comma-separated list of IATA passenger type codes (ADT, CHD, INF, MIL, SRC, etc.) eligible for this ancillary product. Empty indicates no passenger type restriction.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleCode rdf:type rdf:Property ;
    rdfs:label 'Rule Code' ;
    rdfs:comment 'Business-assigned unique code identifying this eligibility rule for operational reference and system integration.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleDescription rdf:type rdf:Property ;
    rdfs:label 'Rule Description' ;
    rdfs:comment 'Detailed business description of the eligibility rule, including rationale, business context, and any special conditions or exceptions.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleLogicExpression rdf:type rdf:Property ;
    rdfs:label 'Rule Logic Expression' ;
    rdfs:comment 'Complex logical expression or formula defining advanced eligibility conditions beyond standard attribute filters. Used for multi-condition rules requiring AND/OR/NOT logic.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleName rdf:type rdf:Property ;
    rdfs:label 'Rule Name' ;
    rdfs:comment 'Human-readable name describing the purpose and scope of this eligibility rule.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ruleType rdf:type rdf:Property ;
    rdfs:label 'Rule Type' ;
    rdfs:comment 'Classification of the eligibility rule defining the primary dimension of restriction or entitlement (fare class, route, FFP tier, booking window, passenger type, or cabin).' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:salesChannelList rdf:type rdf:Property ;
    rdfs:label 'Sales Channel List' ;
    rdfs:comment 'Comma-separated list of sales channels (web, mobile, GDS, call_center, airport, agency) through which this ancillary product may be purchased. Empty indicates all channels.' ;
    rdfs:domain ind:EligibilityRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cityPairId rdf:type rdf:Property ;
    rdfs:label 'City Pair Id' ;
    rdfs:comment 'Unique identifier for the origin-destination city pair. Primary key for the city pair master entity.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CityPair .

ind:activeFlag rdf:type rdf:Property ;
    rdfs:label 'Active Flag' ;
    rdfs:comment 'Indicates whether this city pair is currently active in the airline\'s route network. Inactive city pairs are retained for historical analysis and potential future reactivation.' ;
    rdfs:domain ind:CityPair ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bilateralAgreementCode rdf:type rdf:Property ;
    rdfs:label 'Bilateral Agreement Code' ;
    rdfs:comment 'Reference code for the bilateral air service agreement governing this city pair (e.g., US-UK Open Skies, US-Japan bilateral). Determines traffic rights, capacity limits, and operational freedoms.' ;
    rdfs:domain ind:CityPair ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codeshareEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Codeshare Eligible Flag' ;
    rdfs:comment 'Indicates whether this city pair is eligible for codeshare operations under existing alliance agreements and regulatory approvals.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:competitiveIntensity rdf:type rdf:Property ;
    rdfs:label 'Competitive Intensity' ;
    rdfs:comment 'Market competition classification based on number of carriers serving the city pair: monopoly (single carrier), duopoly (two carriers), oligopoly (3-5 carriers), highly_competitive (6+ carriers).' ;
    rdfs:domain ind:CityPair ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationIataRegion rdf:type rdf:Property ;
    rdfs:label 'Destination Iata Region' ;
    rdfs:comment 'IATA Traffic Conference region for the destination (TC1=Americas, TC2=Europe/Africa/Middle East, TC3=Asia/Pacific). Used for fare construction and bilateral agreement classification.' ;
    rdfs:domain ind:CityPair ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distanceBand rdf:type rdf:Property ;
    rdfs:label 'Distance Band' ;
    rdfs:comment 'Categorical classification of route length: short_haul (<1500km), medium_haul (1500-4000km), long_haul (4000-8000km), ultra_long_haul (>8000km). Used for fleet assignment, crew planning, and market segmentation.' ;
    rdfs:domain ind:CityPair ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:etopsRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Etops Required Flag' ;
    rdfs:comment 'Indicates whether ETOPS certification is required for twin-engine aircraft operations on this city pair due to extended overwater or remote routing beyond 60 minutes single-engine diversion time.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:greatCircleDistanceKm rdf:type rdf:Property ;
    rdfs:label 'Great Circle Distance Km' ;
    rdfs:comment 'Shortest distance between origin and destination airports measured along the surface of the Earth (great circle route), expressed in kilometers. Used for ASK and RPK calculations.' ;
    rdfs:domain ind:CityPair ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:greatCircleDistanceMiles rdf:type rdf:Property ;
    rdfs:label 'Great Circle Distance Miles' ;
    rdfs:comment 'Shortest distance between origin and destination airports measured along the surface of the Earth (great circle route), expressed in statute miles. Used for mileage accrual in FFP programs.' ;
    rdfs:domain ind:CityPair ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hubSpokeClassification rdf:type rdf:Property ;
    rdfs:label 'Hub Spoke Classification' ;
    rdfs:comment 'Network topology classification indicating whether the city pair connects two hubs, a hub to a spoke, two spokes, or operates as a point-to-point route outside the hub network.' ;
    rdfs:domain ind:CityPair ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interlineEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Interline Eligible Flag' ;
    rdfs:comment 'Indicates whether this city pair is eligible for interline ticketing agreements with partner carriers, allowing through-ticketing and baggage transfer.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketClassification rdf:type rdf:Property ;
    rdfs:label 'Market Classification' ;
    rdfs:comment 'Classification of the city pair market type: domestic (within same country), international (between different countries), or transborder (specific cross-border markets with special regulatory treatment, e.g., US-Canada).' ;
    rdfs:domain ind:CityPair ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:marketMaturity rdf:type rdf:Property ;
    rdfs:label 'Market Maturity' ;
    rdfs:comment 'Lifecycle stage of the city pair market: emerging (new route, low traffic), growth (increasing demand), mature (stable established market), declining (reducing demand).' ;
    rdfs:domain ind:CityPair ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originCityCode rdf:type rdf:Property ;
    rdfs:label 'Origin City Code' ;
    rdfs:comment 'Three-letter IATA city code for the origin metropolitan area. May differ from airport code when multiple airports serve one city (e.g., NYC for JFK/LGA/EWR).' ;
    rdfs:domain ind:CityPair ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originIataRegion rdf:type rdf:Property ;
    rdfs:label 'Origin Iata Region' ;
    rdfs:comment 'IATA Traffic Conference region for the origin (TC1=Americas, TC2=Europe/Africa/Middle East, TC3=Asia/Pacific). Used for fare construction and bilateral agreement classification.' ;
    rdfs:domain ind:CityPair ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledDistanceKm rdf:type rdf:Property ;
    rdfs:label 'Scheduled Distance Km' ;
    rdfs:comment 'Actual flown distance based on typical flight routing including airways, ATC routing, and operational constraints. May differ from great circle distance due to airspace restrictions, weather routing, or operational procedures.' ;
    rdfs:domain ind:CityPair ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:seasonalPattern rdf:type rdf:Property ;
    rdfs:label 'Seasonal Pattern' ;
    rdfs:comment 'Typical seasonal operating pattern for this city pair: year_round (continuous service), summer_only (IATA summer season), winter_only (IATA winter season), peak_season (high-demand periods), shoulder_season (transitional periods).' ;
    rdfs:domain ind:CityPair ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slotConstrainedFlag rdf:type rdf:Property ;
    rdfs:label 'Slot Constrained Flag' ;
    rdfs:comment 'Indicates whether either the origin or destination airport is slot-controlled under IATA Worldwide Slot Guidelines (Level 3 airport), requiring allocated takeoff and landing slots.' ;
    rdfs:domain ind:CityPair ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:timeZoneDifferenceHours rdf:type rdf:Property ;
    rdfs:label 'Time Zone Difference Hours' ;
    rdfs:comment 'Time difference in hours between origin and destination time zones. Positive values indicate destination is ahead; negative values indicate destination is behind. Used for schedule planning and passenger communication.' ;
    rdfs:domain ind:CityPair ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trafficRightsCategory rdf:type rdf:Property ;
    rdfs:label 'Traffic Rights Category' ;
    rdfs:comment 'ICAO freedom of the air classification applicable to this city pair, defining the operational rights granted under bilateral agreements (e.g., third_freedom for outbound, fourth_freedom for inbound, fifth_freedom for beyond rights). [ENUM-REF-CANDIDATE: first_freedom|second_freedom|third_freedom|fourth_freedom|fifth_freedom|sixth_freedom|seventh_freedom|eighth_freedom|ninth_freedom — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:typicalBlockTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Typical Block Time Minutes' ;
    rdfs:comment 'Average scheduled block time (gate-to-gate time) in minutes for flights operating this city pair, including taxi time. Used for crew scheduling, aircraft utilization planning, and schedule design.' ;
    rdfs:domain ind:CityPair ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:typicalFlightTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Typical Flight Time Minutes' ;
    rdfs:comment 'Average airborne flight time in minutes for this city pair, excluding taxi time. Used for fuel planning and flight operations analysis.' ;
    rdfs:domain ind:CityPair ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:destinationStationId rdf:type rdf:Property ;
    rdfs:label 'Destination Station Id' ;
    rdfs:comment 'FK to airport.station' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Station .

ind:authorityType rdf:type rdf:Property ;
    rdfs:label 'Authority Type' ;
    rdfs:comment 'Regulatory classification of the route: domestic (within single country), international (between countries), or cabotage (domestic service by foreign carrier, typically restricted).' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:averageLoadFactorPercent rdf:type rdf:Property ;
    rdfs:label 'Average Load Factor Percent' ;
    rdfs:comment 'Historical average load factor (percentage of seats filled) for this route over the trailing 12 months. Key performance indicator for route profitability.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageOtpPercent rdf:type rdf:Property ;
    rdfs:label 'Average Otp Percent' ;
    rdfs:comment 'Historical average on-time performance percentage (flights arriving within 15 minutes of scheduled time) for this route over the trailing 12 months.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:competitiveRouteIndicator rdf:type rdf:Property ;
    rdfs:label 'Competitive Route Indicator' ;
    rdfs:comment 'Flag indicating whether this route faces direct competition from other carriers (true) or is operated exclusively by this airline (false).' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:distanceKm rdf:type rdf:Property ;
    rdfs:label 'Distance Km' ;
    rdfs:comment 'Great circle distance between origin and destination airports in kilometers. Used for ASK (Available Seat Kilometer) and RPK (Revenue Passenger Kilometer) calculations.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:distanceMiles rdf:type rdf:Property ;
    rdfs:label 'Distance Miles' ;
    rdfs:comment 'Great circle distance between origin and destination airports in statute miles. Used for frequent flyer mileage accrual and US DOT reporting.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:etopsRatingMinutes rdf:type rdf:Property ;
    rdfs:label 'Etops Rating Minutes' ;
    rdfs:comment 'Required ETOPS rating in minutes (e.g., 120, 180, 207, 330) for aircraft operating this route. Null if ETOPS not required.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:etopsRequired rdf:type rdf:Property ;
    rdfs:label 'Etops Required' ;
    rdfs:comment 'Flag indicating whether this route requires ETOPS certification due to extended overwater or remote area operations beyond 60 minutes single-engine diversion time.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:flightTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Flight Time Minutes' ;
    rdfs:comment 'Standard airborne flight time in minutes from wheels-up at origin to wheels-down at destination, excluding taxi time.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inauguralDate rdf:type rdf:Property ;
    rdfs:label 'Inaugural Date' ;
    rdfs:comment 'Date when the route was first launched and entered commercial service.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:numberOfCompetitors rdf:type rdf:Property ;
    rdfs:label 'Number Of Competitors' ;
    rdfs:comment 'Count of other airlines operating direct service on this origin-destination pair. Zero indicates monopoly route.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operatingSeason rdf:type rdf:Property ;
    rdfs:label 'Operating Season' ;
    rdfs:comment 'Season during which the route operates: year-round (all seasons), summer-only (IATA summer schedule), or winter-only (IATA winter schedule).' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedLaunchDate rdf:type rdf:Property ;
    rdfs:label 'Planned Launch Date' ;
    rdfs:comment 'Expected date for route launch for routes in planned status. Null for active or discontinued routes.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:profitabilityTier rdf:type rdf:Property ;
    rdfs:label 'Profitability Tier' ;
    rdfs:comment 'Internal classification of route profitability: tier_1 (highest margin), tier_2 (above average), tier_3 (break-even), tier_4 (loss-making). Used for strategic network decisions.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeCode rdf:type rdf:Property ;
    rdfs:label 'Route Code' ;
    rdfs:comment 'Six-character alphanumeric code representing the origin-destination pair (e.g., JFKLHR for New York JFK to London Heathrow). Typically constructed as origin IATA code + destination IATA code.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeStatus rdf:type rdf:Property ;
    rdfs:label 'Route Status' ;
    rdfs:comment 'Current operational status of the route: active (currently operating), suspended (temporarily halted), planned (approved but not yet launched), or discontinued (permanently ceased).' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeType rdf:type rdf:Property ;
    rdfs:label 'Route Type' ;
    rdfs:comment 'Classification of the route based on network topology: hub-to-hub (connecting two major hubs), hub-to-spoke (hub to regional destination), spoke-to-spoke (regional to regional), or point-to-point (direct service bypassing hubs).' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonalIndicator rdf:type rdf:Property ;
    rdfs:label 'Seasonal Indicator' ;
    rdfs:comment 'Flag indicating whether this route operates seasonally (true) or year-round (false). Seasonal routes typically align with IATA summer/winter schedule seasons.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slotControlledDestination rdf:type rdf:Property ;
    rdfs:label 'Slot Controlled Destination' ;
    rdfs:comment 'Flag indicating whether the destination airport is slot-controlled (true), requiring allocated takeoff/landing slots, or non-slot-controlled (false).' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slotControlledOrigin rdf:type rdf:Property ;
    rdfs:label 'Slot Controlled Origin' ;
    rdfs:comment 'Flag indicating whether the origin airport is slot-controlled (true), requiring allocated takeoff/landing slots, or non-slot-controlled (false).' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:suspensionDate rdf:type rdf:Property ;
    rdfs:label 'Suspension Date' ;
    rdfs:comment 'Date when the route was suspended or discontinued. Null if route is currently active or planned.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:weeklyFrequency rdf:type rdf:Property ;
    rdfs:label 'Weekly Frequency' ;
    rdfs:comment 'Number of scheduled flights per week on this route. Used for capacity planning and network optimization.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slotAllocationId rdf:type rdf:Property ;
    rdfs:label 'Slot Allocation Id' ;
    rdfs:comment 'Reference to the airport slot allocation record for constrained airports. Links to the assigned takeoff/landing time window granted by the airport coordinator or Air Traffic Control (ATC).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SlotAllocation .

ind:direction rdf:type rdf:Property ;
    rdfs:label 'Direction' ;
    rdfs:comment 'Directional classification of the flight within the route network: outbound (departing from hub), inbound (arriving at hub), circular (multi-leg routing returning to origin).' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:etopsCertifiedIndicator rdf:type rdf:Property ;
    rdfs:label 'Etops Certified Indicator' ;
    rdfs:comment 'Flag indicating whether this flight operates under Extended-range Twin-engine Operational Performance Standards (ETOPS) certification for extended overwater or remote area operations (true) or standard operations (false).' ;
    rdfs:domain ind:FlightNumber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:flightNumberStatus rdf:type rdf:Property ;
    rdfs:label 'Flight Number Status' ;
    rdfs:comment 'Current lifecycle status of the flight number: active (in operational use), inactive (temporarily not scheduled), suspended (operationally blocked), pending (approved but not yet active), retired (permanently discontinued).' ;
    rdfs:domain ind:FlightNumber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flightNumberType rdf:type rdf:Property ;
    rdfs:label 'Flight Number Type' ;
    rdfs:comment 'Classification of the flight number based on operational arrangement: operating (airline operates the flight), codeshare (marketing carrier sells seats on another carrier\'s flight), wetlease (aircraft leased with crew), drylease (aircraft leased without crew), blocked (reserved but not in active use).' ;
    rdfs:domain ind:FlightNumber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frequencyPattern rdf:type rdf:Property ;
    rdfs:label 'Frequency Pattern' ;
    rdfs:comment 'Seven-character string indicating days of operation (1=operates, 0=does not operate) in sequence Monday through Sunday (e.g., 1111100 = Monday-Friday only, 0000011 = weekends only).' ;
    rdfs:domain ind:FlightNumber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fullFlightNumber rdf:type rdf:Property ;
    rdfs:label 'Full Flight Number' ;
    rdfs:comment 'Complete flight number including carrier code and numeric designator (e.g., AA1234, BA567A). This is the externally-known business identifier displayed to passengers and used in reservations.' ;
    rdfs:domain ind:FlightNumber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gdsDistributionIndicator rdf:type rdf:Property ;
    rdfs:label 'Gds Distribution Indicator' ;
    rdfs:comment 'Flag indicating whether this flight number is distributed through Global Distribution Systems (GDS) such as Amadeus, Sabre, Travelport for travel agency bookings (true) or restricted to direct channels (false).' ;
    rdfs:domain ind:FlightNumber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:icaoCarrierCode rdf:type rdf:Property ;
    rdfs:label 'Icao Carrier Code' ;
    rdfs:comment 'Three-character ICAO airline designator code for the carrier (e.g., AAL for American Airlines, BAW for British Airways). Used in flight plans and air traffic control communications.' ;
    rdfs:domain ind:FlightNumber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interlineEligibleIndicator rdf:type rdf:Property ;
    rdfs:label 'Interline Eligible Indicator' ;
    rdfs:comment 'Flag indicating whether this flight number is eligible for interline ticketing agreements with partner carriers (true) or restricted to online bookings only (false).' ;
    rdfs:domain ind:FlightNumber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:networkHubIndicator rdf:type rdf:Property ;
    rdfs:label 'Network Hub Indicator' ;
    rdfs:comment 'Flag indicating whether this flight serves a hub airport in the carrier\'s hub-and-spoke network topology (true) or is a point-to-point spoke route (false).' ;
    rdfs:domain ind:FlightNumber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorityRanking rdf:type rdf:Property ;
    rdfs:label 'Priority Ranking' ;
    rdfs:comment 'Internal priority ranking for this flight number within the carrier\'s network. Lower numbers indicate higher priority for resource allocation, slot protection, and operational recovery during Irregular Operations (IROP).' ;
    rdfs:domain ind:FlightNumber ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:daylightSavingTransitionApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Daylight Saving Transition Applicable Flag' ;
    rdfs:comment 'Indicates whether daylight saving time transitions occur during this scheduling season, requiring schedule adjustments for affected routes and airports. True if DST transitions occur within the season period.' ;
    rdfs:domain ind:ScheduleSeason ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:durationDays rdf:type rdf:Property ;
    rdfs:label 'Duration Days' ;
    rdfs:comment 'Total number of calendar days in the scheduling season, calculated from start_date to end_date inclusive. Typically ranges from 180 to 185 days.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:historicalUseItOrLoseItThresholdPercent rdf:type rdf:Property ;
    rdfs:label 'Historical Use It Or Lose It Threshold Percent' ;
    rdfs:comment 'The minimum slot utilization percentage required during this season to retain grandfather rights for the next equivalent season. Typically 80% per IATA WSG, but may vary by jurisdiction (e.g., EU Regulation 95/93). Expressed as a percentage (e.g., 80.00 for 80%).' ;
    rdfs:domain ind:ScheduleSeason ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:iataSchedulesConferenceEndDate rdf:type rdf:Property ;
    rdfs:label 'Iata Schedules Conference End Date' ;
    rdfs:comment 'The end date of the biannual IATA Schedules Conference. Conferences typically last 3-5 days and occur twice per year (spring for winter season, fall for summer season).' ;
    rdfs:domain ind:ScheduleSeason ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:iataSchedulesConferenceLocation rdf:type rdf:Property ;
    rdfs:label 'Iata Schedules Conference Location' ;
    rdfs:comment 'The city and country where the IATA Schedules Conference for this season is held (e.g., \'Geneva, Switzerland\', \'Singapore\').' ;
    rdfs:domain ind:ScheduleSeason ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iataSchedulesConferenceStartDate rdf:type rdf:Property ;
    rdfs:label 'Iata Schedules Conference Start Date' ;
    rdfs:comment 'The start date of the biannual IATA Schedules Conference where airlines, airports, and slot coordinators meet to coordinate seasonal schedules, negotiate slots, and finalize bilateral agreements.' ;
    rdfs:domain ind:ScheduleSeason ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:iataSeasonYear rdf:type rdf:Property ;
    rdfs:label 'Iata Season Year' ;
    rdfs:comment 'The calendar year in which the season primarily falls or begins, used for grouping and filtering seasons by year (e.g., 2025 for S25 or W25/26).' ;
    rdfs:domain ind:ScheduleSeason ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:initialScheduleSubmissionDeadline rdf:type rdf:Property ;
    rdfs:label 'Initial Schedule Submission Deadline' ;
    rdfs:comment 'The deadline by which airlines must submit their initial seasonal schedule requests to slot coordinators and Global Distribution Systems (GDS). Typically occurs several months before season start per IATA Schedules Information Standards (SIS).' ;
    rdfs:domain ind:ScheduleSeason ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:northernHemisphereDstEndDate rdf:type rdf:Property ;
    rdfs:label 'Northern Hemisphere Dst End Date' ;
    rdfs:comment 'The date when daylight saving time ends in the northern hemisphere during this season (typically first Sunday in November for North America, last Sunday in October for Europe). Null if not applicable to this season.' ;
    rdfs:domain ind:ScheduleSeason ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:northernHemisphereDstStartDate rdf:type rdf:Property ;
    rdfs:label 'Northern Hemisphere Dst Start Date' ;
    rdfs:comment 'The date when daylight saving time begins in the northern hemisphere during this season (typically second Sunday in March for North America, last Sunday in March for Europe). Null if not applicable to this season.' ;
    rdfs:domain ind:ScheduleSeason ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:peakTravelPeriodFlag rdf:type rdf:Property ;
    rdfs:label 'Peak Travel Period Flag' ;
    rdfs:comment 'Indicates whether this season is considered a peak travel period with higher demand and load factors. Summer seasons are typically peak periods for leisure travel in the northern hemisphere.' ;
    rdfs:domain ind:ScheduleSeason ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduleSeasonStatus rdf:type rdf:Property ;
    rdfs:label 'Schedule Season Status' ;
    rdfs:comment 'Current lifecycle status of the scheduling season. Planning: season is being prepared and schedules are being submitted. Active: season is currently in effect. Completed: season has ended but data is still operational. Archived: season is historical and closed for reporting only.' ;
    rdfs:domain ind:ScheduleSeason ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonCode rdf:type rdf:Property ;
    rdfs:label 'Season Code' ;
    rdfs:comment 'IATA standard season code identifying the scheduling period. Format: S25 for Summer 2025, W25/26 for Winter 2025/2026. This is the externally-known business identifier for the season.' ;
    rdfs:domain ind:ScheduleSeason ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seasonName rdf:type rdf:Property ;
    rdfs:label 'Season Name' ;
    rdfs:comment 'Human-readable descriptive name for the scheduling season (e.g., \'Summer 2025\', \'Winter 2025/2026\').' ;
    rdfs:domain ind:ScheduleSeason ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slotCoordinationCycle rdf:type rdf:Property ;
    rdfs:label 'Slot Coordination Cycle' ;
    rdfs:comment 'The IATA slot coordination cycle identifier corresponding to this season, used by slot coordinators at Level 2 and Level 3 airports for capacity management and slot allocation.' ;
    rdfs:domain ind:ScheduleSeason ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slotReturnDeadline rdf:type rdf:Property ;
    rdfs:label 'Slot Return Deadline' ;
    rdfs:comment 'The final date by which airlines must return unused or unwanted airport slots to the slot coordinator to avoid use-it-or-lose-it penalties. Critical for slot allocation compliance at Level 3 coordinated airports.' ;
    rdfs:domain ind:ScheduleSeason ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:southernHemisphereDstEndDate rdf:type rdf:Property ;
    rdfs:label 'Southern Hemisphere Dst End Date' ;
    rdfs:comment 'The date when daylight saving time ends in the southern hemisphere during this season (typically first Sunday in April for Australia). Null if not applicable to this season.' ;
    rdfs:domain ind:ScheduleSeason ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:southernHemisphereDstStartDate rdf:type rdf:Property ;
    rdfs:label 'Southern Hemisphere Dst Start Date' ;
    rdfs:comment 'The date when daylight saving time begins in the southern hemisphere during this season (typically first Sunday in October for Australia). Null if not applicable to this season.' ;
    rdfs:domain ind:ScheduleSeason ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:supplementaryScheduleSubmissionDeadline rdf:type rdf:Property ;
    rdfs:label 'Supplementary Schedule Submission Deadline' ;
    rdfs:comment 'The deadline for airlines to submit supplementary or revised schedule changes after the initial submission. Allows for adjustments closer to the season start date.' ;
    rdfs:domain ind:ScheduleSeason ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:originTerminalFacilityId rdf:type rdf:Property ;
    rdfs:label 'Origin Terminal Facility Id' ;
    rdfs:comment 'Foreign key linking to airport.terminal_facility. Business justification: Airlines file terminal preferences with schedule submissions for capacity planning and passenger connectivity. origin_terminal is a denormalized text field; a FK to terminal_facility enables terminal ' ;
    rdfs:domain ind:SeasonalSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TerminalFacility .

ind:primarySeasonalMarketingCarrierId rdf:type rdf:Property ;
    rdfs:label 'Primary Seasonal Marketing Carrier Id' ;
    rdfs:comment 'FK to route.carrier' ;
    rdfs:domain ind:SeasonalSchedule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:aircraftOwner rdf:type rdf:Property ;
    rdfs:label 'Aircraft Owner' ;
    rdfs:comment 'Indicates the ownership/lease arrangement for the aircraft planned for this schedule. Values: owned (airline-owned), wet_lease (leased with crew), dry_lease (leased without crew), acmi (Aircraft Crew Maintenance Insurance lease), charter (chartered from third party).' ;
    rdfs:domain ind:SeasonalSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arrivalTimeLocal rdf:type rdf:Property ;
    rdfs:label 'Arrival Time Local' ;
    rdfs:comment 'Scheduled arrival time in local time at the destination airport. Format: HH:MM (24-hour). This is the planned gate arrival time (on-blocks time) in the destination airport local timezone. May show next-day arrival if flight crosses midnight.' ;
    rdfs:domain ind:SeasonalSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:arrivalTimeUtc rdf:type rdf:Property ;
    rdfs:label 'Arrival Time Utc' ;
    rdfs:comment 'Scheduled arrival time in UTC (Coordinated Universal Time). Format: HH:MM (24-hour). Used for operational planning and coordination across time zones.' ;
    rdfs:domain ind:SeasonalSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:askPlanned rdf:type rdf:Property ;
    rdfs:label 'Ask Planned' ;
    rdfs:comment 'Planned Available Seat Kilometers for this seasonal schedule. Calculated as total seats multiplied by route distance in kilometers. Key capacity metric for network planning and revenue management.' ;
    rdfs:domain ind:SeasonalSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dayChangeIndicator rdf:type rdf:Property ;
    rdfs:label 'Day Change Indicator' ;
    rdfs:comment 'Indicates the number of days difference between departure and arrival dates. Values: 0 (same day), 1 (next day), 2 (two days later), -1 (previous day for flights crossing international date line westbound). Used to calculate actual arrival date from departure date.' ;
    rdfs:domain ind:SeasonalSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:departureTimeLocal rdf:type rdf:Property ;
    rdfs:label 'Departure Time Local' ;
    rdfs:comment 'Scheduled departure time in local time at the origin airport. Format: HH:MM (24-hour). This is the planned gate departure time (off-blocks time) in the origin airport local timezone.' ;
    rdfs:domain ind:SeasonalSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:departureTimeUtc rdf:type rdf:Property ;
    rdfs:label 'Departure Time Utc' ;
    rdfs:comment 'Scheduled departure time in UTC (Coordinated Universal Time). Format: HH:MM (24-hour). Used for operational planning and coordination across time zones.' ;
    rdfs:domain ind:SeasonalSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationTerminal rdf:type rdf:Property ;
    rdfs:label 'Destination Terminal' ;
    rdfs:comment 'Terminal identifier at the destination airport where this flight arrives. Used for passenger information and ground operations planning. Format varies by airport (e.g., 1, A, T1, North).' ;
    rdfs:domain ind:SeasonalSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:frequencyPerWeek rdf:type rdf:Property ;
    rdfs:label 'Frequency Per Week' ;
    rdfs:comment 'The number of times this flight operates per week during the seasonal schedule period. Derived from the days_of_operation mask. Range: 0-7.' ;
    rdfs:domain ind:SeasonalSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalSeats rdf:type rdf:Property ;
    rdfs:label 'Total Seats' ;
    rdfs:comment 'Total number of passenger seats available on the planned aircraft configuration for this seasonal schedule. Used for capacity planning and ASK (Available Seat Kilometer) calculations.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:aircraftSizeCategory rdf:type rdf:Property ;
    rdfs:label 'Aircraft Size Category' ;
    rdfs:comment 'General aircraft size category restriction for the slot. Used when specific type restrictions are not applied but size-based capacity management is in effect.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aircraftTypeRestriction rdf:type rdf:Property ;
    rdfs:label 'Aircraft Type Restriction' ;
    rdfs:comment 'ICAO aircraft type code restriction for this slot allocation (e.g., B738, A320, B77W). Some slots at noise-sensitive or capacity-constrained airports may be restricted to specific aircraft types or size categories. Null if no restriction applies.' ;
    rdfs:domain ind:SlotAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocatedTime rdf:type rdf:Property ;
    rdfs:label 'Allocated Time' ;
    rdfs:comment 'The specific time allocated for the departure or arrival movement in local airport time (HH:MM format, 24-hour clock). This is the coordinated time window the airline must operate within.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:environmentalRestrictionFlag rdf:type rdf:Property ;
    rdfs:label 'Environmental Restriction Flag' ;
    rdfs:comment 'Indicates whether this slot is subject to environmental restrictions such as noise abatement procedures, curfew limitations, or emissions-based access rules. True if environmental constraints apply to the slot usage.' ;
    rdfs:domain ind:SlotAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:historicalPrecedenceFlag rdf:type rdf:Property ;
    rdfs:label 'Historical Precedence Flag' ;
    rdfs:comment 'Indicates whether this slot carries historical precedence (grandfather rights) for the airline. True if the airline has operated this slot in previous equivalent seasons and is entitled to priority retention under IATA use-it-or-lose-it rules (80% usage threshold).' ;
    rdfs:domain ind:SlotAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slotAllocationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Slot Allocation Timestamp' ;
    rdfs:comment 'Date and time when the slot coordinator officially allocated this slot to the airline. Marks the transition from requested to allocated status.' ;
    rdfs:domain ind:SlotAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:slotCancellationReason rdf:type rdf:Property ;
    rdfs:label 'Slot Cancellation Reason' ;
    rdfs:comment 'Reason for cancellation of the slot allocation by the coordinator or airline. Populated when slot_status is \'cancelled\'. May include regulatory changes, airport capacity reductions, or airline non-compliance with usage requirements.' ;
    rdfs:domain ind:SlotAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slotConferenceReference rdf:type rdf:Property ;
    rdfs:label 'Slot Conference Reference' ;
    rdfs:comment 'Reference to the IATA slot coordination conference where this slot was discussed or allocated (e.g., IATA Slot Conference Worldwide, Regional Slot Conference). IATA holds biannual slot conferences where airlines and coordinators negotiate slot allocations.' ;
    rdfs:domain ind:SlotAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slotConfirmationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Slot Confirmation Timestamp' ;
    rdfs:comment 'Date and time when the airline confirmed acceptance and intention to use the allocated slot. Required by IATA WSG to retain slot rights for future seasons.' ;
    rdfs:domain ind:SlotAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:slotCoordinationLevel rdf:type rdf:Property ;
    rdfs:label 'Slot Coordination Level' ;
    rdfs:comment 'IATA coordination level of the airport for this slot. Level 1 (non-coordinated): no slot coordination required; Level 2 (schedule-facilitated): voluntary schedule coordination; Level 3 (fully coordinated): mandatory slot allocation by coordinator. Only Level 2 and Level 3 airports issue formal slot allocations.' ;
    rdfs:domain ind:SlotAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slotCoordinatorReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Slot Coordinator Reference Number' ;
    rdfs:comment 'Unique reference number assigned by the airport slot coordinator to this slot allocation. Used for official correspondence and slot coordination activities.' ;
    rdfs:domain ind:SlotAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slotMovementType rdf:type rdf:Property ;
    rdfs:label 'Slot Movement Type' ;
    rdfs:comment 'Indicates whether this slot is for an arrival or departure movement at the coordinated airport.' ;
    rdfs:domain ind:SlotAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slotPriorityScore rdf:type rdf:Property ;
    rdfs:label 'Slot Priority Score' ;
    rdfs:comment 'Numeric score assigned by the slot coordinator to prioritize this slot request relative to competing requests. Higher scores indicate higher priority. Factors include historical precedence, new entrant status, network connectivity, and public interest considerations.' ;
    rdfs:domain ind:SlotAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slotRequestTimestamp rdf:type rdf:Property ;
    rdfs:label 'Slot Request Timestamp' ;
    rdfs:comment 'Date and time when the airline submitted the slot request to the coordinator. Used to establish priority in slot allocation processes where multiple carriers request the same time.' ;
    rdfs:domain ind:SlotAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:slotReturnReason rdf:type rdf:Property ;
    rdfs:label 'Slot Return Reason' ;
    rdfs:comment 'Business reason for returning the slot to the coordinator pool. Populated when slot_status is \'returned\'. Common reasons include route discontinuation, schedule optimization, fleet changes, or commercial underperformance.' ;
    rdfs:domain ind:SlotAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slotSeriesType rdf:type rdf:Property ;
    rdfs:label 'Slot Series Type' ;
    rdfs:comment 'Indicates whether the slot allocation covers the full IATA season, a partial period within the season, or a single date. Full season slots run for the entire summer or winter season; partial season slots cover a subset of dates.' ;
    rdfs:domain ind:SlotAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slotStatus rdf:type rdf:Property ;
    rdfs:label 'Slot Status' ;
    rdfs:comment 'Current status of the slot allocation in the coordination lifecycle. Requested: airline has submitted a slot request; Allocated: coordinator has provisionally allocated the slot; Confirmed: airline has confirmed acceptance and usage; Returned: airline has returned the slot to the pool; Swapped: slot has been exchanged with another carrier; Cancelled: slot allocation has been cancelled.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slotSwapPartnerAirlineCode rdf:type rdf:Property ;
    rdfs:label 'Slot Swap Partner Airline Code' ;
    rdfs:comment 'IATA airline code of the partner airline involved in a slot swap transaction. Populated only when slot_status is \'swapped\'. Slot swaps allow airlines to exchange slots to optimize their network schedules.' ;
    rdfs:domain ind:SlotAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slotSwapReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Slot Swap Reference Number' ;
    rdfs:comment 'Unique reference number for the slot swap transaction, assigned by the slot coordinator. Links this slot allocation to the corresponding swapped slot record.' ;
    rdfs:domain ind:SlotAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slotToleranceMinutes rdf:type rdf:Property ;
    rdfs:label 'Slot Tolerance Minutes' ;
    rdfs:comment 'Number of minutes before or after the allocated time within which the flight operation is considered compliant with the slot. Typically -5 to +10 minutes for departures and -10 to +5 minutes for arrivals, but varies by airport coordinator policy.' ;
    rdfs:domain ind:SlotAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slotType rdf:type rdf:Property ;
    rdfs:label 'Slot Type' ;
    rdfs:comment 'Classification of the slot allocation type. Historical grandfather slots are held by airlines with historic precedence; new entrant slots are reserved for new carriers; pool slots are available for general allocation; ad hoc slots are one-time allocations; emergency slots are for irregular operations.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slotUsagePercentage rdf:type rdf:Property ;
    rdfs:label 'Slot Usage Percentage' ;
    rdfs:comment 'Percentage of allocated slot times that were actually used by the airline during the season. IATA WSG requires 80% usage to retain historical rights. Calculated as (flights operated within slot tolerance / total allocated slot occurrences) * 100.' ;
    rdfs:domain ind:SlotAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:terminalRestriction rdf:type rdf:Property ;
    rdfs:label 'Terminal Restriction' ;
    rdfs:comment 'Specific terminal designation at the airport where this slot must be used (e.g., Terminal 1, Terminal 5, Concourse B). Some airports allocate slots with terminal restrictions due to capacity or operational constraints.' ;
    rdfs:domain ind:SlotAllocation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnershipOperatingCarrierId rdf:type rdf:Property ;
    rdfs:label 'Partnership Operating Carrier Id' ;
    rdfs:comment 'FK to route.carrier' ;
    rdfs:domain ind:Partnership ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:partnershipPartnerCarrierId rdf:type rdf:Property ;
    rdfs:label 'Partnership Partner Carrier Id' ;
    rdfs:comment 'Foreign key linking to route.carrier. Business justification: partnership currently has partner_carrier_iata_code as STRING. Normalizing to carrier.carrier_id establishes proper FK to the partner carrier in the codeshare/interline partnership. The partner_carrie' ;
    rdfs:domain ind:Partnership ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Carrier .

ind:routeCodeshareAgreementId rdf:type rdf:Property ;
    rdfs:label 'Route Codeshare Agreement Id' ;
    rdfs:comment 'Unique identifier for the route partnership agreement record. Primary key.' ;
    rdfs:domain ind:Partnership ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CodeshareAgreement .

ind:agreementNumber rdf:type rdf:Property ;
    rdfs:label 'Agreement Number' ;
    rdfs:comment 'Externally-known unique business identifier for this partnership agreement, used in contracts and commercial correspondence.' ;
    rdfs:domain ind:Partnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:antitrustImmunityGranted rdf:type rdf:Property ;
    rdfs:label 'Antitrust Immunity Granted' ;
    rdfs:comment 'Indicates whether the partnership (typically joint venture) has been granted antitrust immunity by regulatory authorities, allowing revenue and capacity coordination.' ;
    rdfs:domain ind:Partnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:autoRenewalEnabled rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Enabled' ;
    rdfs:comment 'Indicates whether the partnership agreement automatically renews for an additional term upon expiry unless either party provides notice of termination.' ;
    rdfs:domain ind:Partnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:baggageThroughCheckEligible rdf:type rdf:Property ;
    rdfs:label 'Baggage Through Check Eligible' ;
    rdfs:comment 'Indicates whether passengers on interline itineraries under this agreement are eligible for baggage through-check (baggage checked to final destination without re-check at transfer point).' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:blockSpaceSeatCount rdf:type rdf:Property ;
    rdfs:label 'Block Space Seat Count' ;
    rdfs:comment 'Number of seats purchased by the marketing carrier under a block-space codeshare agreement. Null if not a block-space agreement.' ;
    rdfs:domain ind:Partnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cabinClassAvailability rdf:type rdf:Property ;
    rdfs:label 'Cabin Class Availability' ;
    rdfs:comment 'Comma-separated list of cabin classes (e.g., F, J, W, Y) for which this partnership agreement applies. Null if applies to all classes.' ;
    rdfs:domain ind:Partnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:codeshareFlightNumberRangeEnd rdf:type rdf:Property ;
    rdfs:label 'Codeshare Flight Number Range End' ;
    rdfs:comment 'Ending flight number in the range allocated to the marketing carrier for codeshare flights under this agreement. Null if not a codeshare agreement.' ;
    rdfs:domain ind:Partnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:codeshareFlightNumberRangeStart rdf:type rdf:Property ;
    rdfs:label 'Codeshare Flight Number Range Start' ;
    rdfs:comment 'Starting flight number in the range allocated to the marketing carrier for codeshare flights under this agreement. Null if not a codeshare agreement.' ;
    rdfs:domain ind:Partnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eticketInterlineCapable rdf:type rdf:Property ;
    rdfs:label 'Eticket Interline Capable' ;
    rdfs:comment 'Indicates whether electronic ticketing is supported for interline itineraries under this agreement (both carriers must support e-ticket interline).' ;
    rdfs:domain ind:Partnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:frequentFlyerAccrualEligible rdf:type rdf:Property ;
    rdfs:label 'Frequent Flyer Accrual Eligible' ;
    rdfs:comment 'Indicates whether passengers can accrue frequent flyer miles/points on the partner carrier when traveling on codeshare or interline flights under this agreement.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:frequentFlyerRedemptionEligible rdf:type rdf:Property ;
    rdfs:label 'Frequent Flyer Redemption Eligible' ;
    rdfs:comment 'Indicates whether passengers can redeem frequent flyer miles/points for award travel on the partner carrier under this agreement.' ;
    rdfs:domain ind:Partnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gdsDistributionEnabled rdf:type rdf:Property ;
    rdfs:label 'Gds Distribution Enabled' ;
    rdfs:comment 'Indicates whether codeshare flights under this agreement are distributed through Global Distribution Systems (Amadeus, Sabre, Travelport) for travel agent booking.' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:noticePeriodDays rdf:type rdf:Property ;
    rdfs:label 'Notice Period Days' ;
    rdfs:comment 'Number of days advance notice required by either party to terminate the partnership agreement.' ;
    rdfs:domain ind:Partnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revenueSharingBasis rdf:type rdf:Property ;
    rdfs:label 'Revenue Sharing Basis' ;
    rdfs:comment 'Method by which revenue is allocated between partner carriers: prorate (IATA standard prorate formula based on mileage), block_space (fixed payment for seat block), revenue_share_pool (joint venture pooling), cost_plus (cost reimbursement plus margin), or fixed_fee (flat payment per flight or period).' ;
    rdfs:domain ind:Partnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routeScope rdf:type rdf:Property ;
    rdfs:label 'Route Scope' ;
    rdfs:comment 'Geographic scope of the partnership agreement: specific_od_pair (applies to one origin-destination pair), regional_network (applies to routes within a region), or global_network (applies to all routes between the carriers).' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialServiceRequestPassthrough rdf:type rdf:Property ;
    rdfs:label 'Special Service Request Passthrough' ;
    rdfs:comment 'Indicates whether Special Service Requests (meal preferences, wheelchair assistance, etc.) are passed through between carriers for interline passengers under this agreement.' ;
    rdfs:domain ind:Partnership ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:terminationDate rdf:type rdf:Property ;
    rdfs:label 'Termination Date' ;
    rdfs:comment 'Actual date on which the partnership agreement was terminated, if terminated before the scheduled expiry_date. Null if not terminated early.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:terminationReason rdf:type rdf:Property ;
    rdfs:label 'Termination Reason' ;
    rdfs:comment 'Free-text explanation of why the partnership agreement was terminated early, if applicable.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:agreementNotes rdf:type rdf:Property ;
    rdfs:label 'Agreement Notes' ;
    rdfs:comment 'Free-text field for additional notes, special conditions, restrictions, or operational instructions related to the interline agreement.' ;
    rdfs:domain ind:InterlineAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allianceMembership rdf:type rdf:Property ;
    rdfs:label 'Alliance Membership' ;
    rdfs:comment 'Indicates whether the interline agreement is facilitated by membership in a global airline alliance (Star Alliance, oneworld, SkyTeam, Value Alliance) or is a standalone bilateral agreement (none).' ;
    rdfs:domain ind:Route ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eTicketInterlineCapable rdf:type rdf:Property ;
    rdfs:label 'E Ticket Interline Capable' ;
    rdfs:comment 'Boolean flag indicating whether electronic ticketing (e-ticket) is supported for interline itineraries under this agreement (True) or paper tickets are required (False).' ;
    rdfs:domain ind:InterlineAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:iropReprotectionEligible rdf:type rdf:Property ;
    rdfs:label 'Irop Reprotection Eligible' ;
    rdfs:comment 'Boolean flag indicating whether passengers can be reprotected on the partner carrier in case of irregular operations (IROP) such as delays, cancellations, or missed connections (True) or not (False).' ;
    rdfs:domain ind:InterlineAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:liabilityLimitSdr rdf:type rdf:Property ;
    rdfs:label 'Liability Limit Sdr' ;
    rdfs:comment 'Maximum liability limit per passenger for baggage, delay, or injury claims under the interline agreement, expressed in Special Drawing Rights (SDR) as defined by the Montreal Convention.' ;
    rdfs:domain ind:InterlineAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementBasis rdf:type rdf:Property ;
    rdfs:label 'Settlement Basis' ;
    rdfs:comment 'Financial settlement mechanism for interline revenue: BSP (Billing and Settlement Plan), ARC (Airlines Reporting Corporation), direct billing between carriers, ICH (IATA Clearing House), or bilateral settlement agreement.' ;
    rdfs:domain ind:InterlineAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialProrateAgreementNumber rdf:type rdf:Property ;
    rdfs:label 'Special Prorate Agreement Number' ;
    rdfs:comment 'Unique identifier for a Special Prorate Agreement (SPA) filed with IATA or negotiated bilaterally, if applicable. Nullable for standard interline agreements.' ;
    rdfs:domain ind:InterlineAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ssrHandlingAgreement rdf:type rdf:Property ;
    rdfs:label 'Ssr Handling Agreement' ;
    rdfs:comment 'Defines the level of Special Service Request (SSR) data exchange and handling between carriers: full SSR exchange, limited SSR support, or no SSR exchange.' ;
    rdfs:domain ind:InterlineAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:performanceId rdf:type rdf:Property ;
    rdfs:label 'Performance Id' ;
    rdfs:comment 'Unique identifier for the route performance measurement record. Primary key.' ;
    rdfs:domain ind:Performance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ask rdf:type rdf:Property ;
    rdfs:label 'Ask' ;
    rdfs:comment 'The total number of seat-kilometers available for sale on this route. Calculated as sum of (available seats on each flight * flight distance in km). Fundamental capacity metric.' ;
    rdfs:domain ind:Performance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:availableSeatsTotal rdf:type rdf:Property ;
    rdfs:label 'Available Seats Total' ;
    rdfs:comment 'The total number of seats available for sale on all operated flights on this route during the measurement period. Basis for load factor calculation.' ;
    rdfs:domain ind:Performance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:averageBlockTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Average Block Time Minutes' ;
    rdfs:comment 'The mean block time (gate-to-gate elapsed time) for all operated flights on this route during the measurement period. Used for schedule planning and crew productivity analysis.' ;
    rdfs:domain ind:Performance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageDelayMinutes rdf:type rdf:Property ;
    rdfs:label 'Average Delay Minutes' ;
    rdfs:comment 'The mean arrival delay in minutes for all operated flights on this route during the measurement period. Negative values indicate early arrivals.' ;
    rdfs:domain ind:Performance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:blockTimeVarianceMinutes rdf:type rdf:Property ;
    rdfs:label 'Block Time Variance Minutes' ;
    rdfs:comment 'The difference between average actual block time and scheduled block time. Positive values indicate flights took longer than scheduled; negative values indicate shorter actual times. Used for schedule buffer optimization.' ;
    rdfs:domain ind:Performance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cancellationRatePercent rdf:type rdf:Property ;
    rdfs:label 'Cancellation Rate Percent' ;
    rdfs:comment 'The percentage of scheduled flights that were cancelled. Calculated as (flights cancelled / flights scheduled) * 100. Key operational reliability metric.' ;
    rdfs:domain ind:Performance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cask rdf:type rdf:Property ;
    rdfs:label 'Cask' ;
    rdfs:comment 'Cost per unit of capacity. Calculated as (total cost / ASK). Key unit cost metric for route efficiency analysis. Expressed in cost_currency_code per kilometer.' ;
    rdfs:domain ind:Performance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:diversionRatePercent rdf:type rdf:Property ;
    rdfs:label 'Diversion Rate Percent' ;
    rdfs:comment 'The percentage of operated flights that were diverted. Calculated as (flights diverted / flights operated) * 100. Indicator of weather, ATC, or operational disruption impact.' ;
    rdfs:domain ind:Performance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:flightsOperatedCount rdf:type rdf:Property ;
    rdfs:label 'Flights Operated Count' ;
    rdfs:comment 'The total number of flights that actually departed on this route during the measurement period. Excludes cancelled flights.' ;
    rdfs:domain ind:Performance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:flightsScheduledCount rdf:type rdf:Property ;
    rdfs:label 'Flights Scheduled Count' ;
    rdfs:comment 'The total number of flights scheduled to operate on this route during the measurement period, as published in the airline schedule.' ;
    rdfs:domain ind:Performance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:grade rdf:type rdf:Property ;
    rdfs:label 'Grade' ;
    rdfs:comment 'Overall qualitative assessment of route performance based on composite scoring of OTP, load factor, yield, and RASK against targets. Used for executive dashboards and network optimization prioritization.' ;
    rdfs:domain ind:Performance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadFactorPercent rdf:type rdf:Property ;
    rdfs:label 'Load Factor Percent' ;
    rdfs:comment 'The percentage of available seats that were occupied by revenue passengers. Calculated as (passengers carried / available seats) * 100. Core capacity utilization metric.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Measurement Period End Date' ;
    rdfs:comment 'The last date of the performance measurement period. Typically the last day of a calendar month or the end of a seasonal period.' ;
    rdfs:domain ind:Performance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measurementPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Measurement Period Start Date' ;
    rdfs:comment 'The first date of the performance measurement period. Typically the first day of a calendar month or the start of a seasonal period.' ;
    rdfs:domain ind:Performance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measurementPeriodType rdf:type rdf:Property ;
    rdfs:label 'Measurement Period Type' ;
    rdfs:comment 'The granularity of the performance measurement period. Monthly is most common for operational scorecards; seasonal aligns with IATA schedule seasons; custom supports ad-hoc analysis windows.' ;
    rdfs:domain ind:Performance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otpPercent rdf:type rdf:Property ;
    rdfs:label 'Otp Percent' ;
    rdfs:comment 'The percentage of operated flights that arrived within 15 minutes of scheduled arrival time. Industry-standard KPI for route punctuality. Calculated as (on-time arrivals / flights operated) * 100.' ;
    rdfs:domain ind:Performance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:passengersCarriedCount rdf:type rdf:Property ;
    rdfs:label 'Passengers Carried Count' ;
    rdfs:comment 'The total number of revenue passengers transported on this route during the measurement period. Excludes non-revenue passengers (crew, deadheads, etc.).' ;
    rdfs:domain ind:Performance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rask rdf:type rdf:Property ;
    rdfs:label 'Rask' ;
    rdfs:comment 'Revenue per unit of capacity. Calculated as (total revenue / ASK). Key unit revenue metric for route profitability analysis. Expressed in revenue_currency_code per kilometer.' ;
    rdfs:domain ind:Performance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Revenue Currency Code' ;
    rdfs:comment 'The three-letter ISO 4217 currency code in which total_revenue_amount is denominated (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:Performance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rpk rdf:type rdf:Property ;
    rdfs:label 'Rpk' ;
    rdfs:comment 'The total number of kilometers flown by revenue passengers on this route. Calculated as sum of (passengers on each flight * flight distance in km). Fundamental traffic volume metric.' ;
    rdfs:domain ind:Performance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCostAmount rdf:type rdf:Property ;
    rdfs:label 'Total Cost Amount' ;
    rdfs:comment 'The total operating cost allocated to this route during the measurement period, including direct costs (fuel, crew, airport charges) and allocated indirect costs (maintenance, overhead). Used for route profitability analysis.' ;
    rdfs:domain ind:Performance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Total Revenue Amount' ;
    rdfs:comment 'The total passenger revenue generated on this route during the measurement period, including base fare, fuel surcharges, and ancillary revenue allocated to the route. Excludes cargo revenue.' ;
    rdfs:domain ind:Performance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:yield rdf:type rdf:Property ;
    rdfs:label 'Yield' ;
    rdfs:comment 'Revenue per unit of traffic. Calculated as (total revenue / RPK). Measures pricing power and fare realization. Expressed in revenue_currency_code per kilometer.' ;
    rdfs:domain ind:Performance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:airborneTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Airborne Time Minutes' ;
    rdfs:comment 'Planned airborne time in minutes from takeoff (wheels-up) to landing (wheels-down). Represents the actual flight time in the air, excluding ground operations.' ;
    rdfs:domain ind:BlockTimeStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:atcDelayFactorMinutes rdf:type rdf:Property ;
    rdfs:label 'Atc Delay Factor Minutes' ;
    rdfs:comment 'Expected ATC delay factor in minutes based on historical congestion patterns at origin and destination airports, en-route airspace constraints, and time-of-day traffic density.' ;
    rdfs:domain ind:BlockTimeStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:blockTimeStandardStatus rdf:type rdf:Property ;
    rdfs:label 'Block Time Standard Status' ;
    rdfs:comment 'Current lifecycle status of the block time standard. Active standards are used for schedule construction; inactive standards are historical; under_review standards are being validated; superseded standards have been replaced by newer versions.' ;
    rdfs:domain ind:BlockTimeStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contingencyBufferMinutes rdf:type rdf:Property ;
    rdfs:label 'Contingency Buffer Minutes' ;
    rdfs:comment 'Additional buffer time in minutes added to the planned block time to account for operational variability, ATC delays, weather, and other uncertainties. Used to improve schedule reliability and OTP performance.' ;
    rdfs:domain ind:BlockTimeStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:crewDutyTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Crew Duty Time Minutes' ;
    rdfs:comment 'Block time used for crew duty time and flight time limitation calculations. May include additional time for pre-flight briefing, post-flight duties, and regulatory compliance. Foundation for crew pairing and rostering.' ;
    rdfs:domain ind:BlockTimeStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:etopsTimeAdjustmentMinutes rdf:type rdf:Property ;
    rdfs:label 'Etops Time Adjustment Minutes' ;
    rdfs:comment 'Additional block time in minutes for ETOPS-certified routes requiring extended-range twin-engine operations. Accounts for required routing to remain within diversion distance of suitable alternate airports.' ;
    rdfs:domain ind:BlockTimeStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fuelPlanningTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Fuel Planning Time Minutes' ;
    rdfs:comment 'Block time used for fuel planning calculations, which may differ from scheduled block time to ensure adequate fuel reserves for contingencies, alternate airports, and regulatory requirements.' ;
    rdfs:domain ind:BlockTimeStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:historicalAverageBlockTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Historical Average Block Time Minutes' ;
    rdfs:comment 'Historical average actual block time in minutes based on past flight performance data. Used for benchmarking and validating planned block time standards against operational reality.' ;
    rdfs:domain ind:BlockTimeStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:percentile85BlockTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Percentile 85 Block Time Minutes' ;
    rdfs:comment '85th percentile of historical actual block times in minutes. Represents the block time that 85% of flights achieve or beat. Used as a reliability target for schedule planning to balance OTP performance with schedule efficiency.' ;
    rdfs:domain ind:BlockTimeStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedBlockTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Planned Block Time Minutes' ;
    rdfs:comment 'Total planned gate-to-gate block time in minutes, representing the scheduled duration from gate departure (off-blocks) to gate arrival (on-blocks). This is the foundation for schedule construction, crew duty time calculations, and OTP measurement.' ;
    rdfs:domain ind:BlockTimeStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sampleSize rdf:type rdf:Property ;
    rdfs:label 'Sample Size' ;
    rdfs:comment 'Number of historical flight records used to calculate this block time standard. Larger sample sizes provide greater statistical confidence in the standard\'s accuracy and reliability.' ;
    rdfs:domain ind:BlockTimeStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seasonalAdjustmentType rdf:type rdf:Property ;
    rdfs:label 'Seasonal Adjustment Type' ;
    rdfs:comment 'Indicates whether this block time standard applies to summer season (typically March-October in Northern Hemisphere), winter season (typically October-March), or year-round. Seasonal variations account for prevailing winds, jet stream patterns, and daylight saving time impacts.' ;
    rdfs:domain ind:BlockTimeStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slotConstrainedAdjustmentMinutes rdf:type rdf:Property ;
    rdfs:label 'Slot Constrained Adjustment Minutes' ;
    rdfs:comment 'Additional time in minutes added to block time for slot-constrained airports where departure or arrival slot availability may require schedule padding to ensure slot compliance and reduce IROP risk.' ;
    rdfs:domain ind:BlockTimeStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:standardDeviationMinutes rdf:type rdf:Property ;
    rdfs:label 'Standard Deviation Minutes' ;
    rdfs:comment 'Standard deviation of historical block times in minutes, representing the variability and consistency of actual flight performance. Lower standard deviation indicates more predictable block times.' ;
    rdfs:domain ind:BlockTimeStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxiInTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Taxi In Time Minutes' ;
    rdfs:comment 'Planned taxi-in time in minutes from landing (wheels-down) to gate arrival (on-blocks). Varies by airport layout, gate assignment, and ground traffic.' ;
    rdfs:domain ind:BlockTimeStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:taxiOutTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Taxi Out Time Minutes' ;
    rdfs:comment 'Planned taxi-out time in minutes from gate departure (off-blocks) to takeoff (wheels-up). Varies by airport congestion, runway configuration, and time of day.' ;
    rdfs:domain ind:BlockTimeStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:windAdjustmentMinutes rdf:type rdf:Property ;
    rdfs:label 'Wind Adjustment Minutes' ;
    rdfs:comment 'Adjustment in minutes to account for prevailing wind patterns, jet stream effects, and seasonal wind variations. Positive values indicate headwind penalties; negative values indicate tailwind benefits.' ;
    rdfs:domain ind:BlockTimeStandard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvedByUser rdf:type rdf:Property ;
    rdfs:label 'Approved By User' ;
    rdfs:comment 'User ID or name of the network planning manager or fleet planner who approved this fleet assignment.' ;
    rdfs:domain ind:FleetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentCode rdf:type rdf:Property ;
    rdfs:label 'Assignment Code' ;
    rdfs:comment 'Business identifier code for this fleet assignment, used in operational planning and crew scheduling systems.' ;
    rdfs:domain ind:FleetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentDurationDays rdf:type rdf:Property ;
    rdfs:label 'Assignment Duration Days' ;
    rdfs:comment 'Total number of days this fleet assignment is planned to be in effect, calculated from effective start to end date.' ;
    rdfs:domain ind:FleetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignmentPriority rdf:type rdf:Property ;
    rdfs:label 'Assignment Priority' ;
    rdfs:comment 'Priority ranking of this fleet assignment relative to other assignments, used for conflict resolution and aircraft allocation decisions. Lower numbers indicate higher priority.' ;
    rdfs:domain ind:FleetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignmentRationale rdf:type rdf:Property ;
    rdfs:label 'Assignment Rationale' ;
    rdfs:comment 'Business justification or reasoning for this specific fleet type assignment to the route, capturing strategic considerations such as demand patterns, competitive positioning, or operational constraints.' ;
    rdfs:domain ind:FleetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentType rdf:type rdf:Property ;
    rdfs:label 'Assignment Type' ;
    rdfs:comment 'Classification of the fleet assignment: permanent (year-round), seasonal (specific season only), temporary (short-term substitution), charter (ad-hoc charter operation), wet_lease (leased aircraft with crew), dry_lease (leased aircraft without crew).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:businessClassSeats rdf:type rdf:Property ;
    rdfs:label 'Business Class Seats' ;
    rdfs:comment 'Number of business class seats in the assigned aircraft configuration.' ;
    rdfs:domain ind:FleetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cargoBellyCapacityKg rdf:type rdf:Property ;
    rdfs:label 'Cargo Belly Capacity Kg' ;
    rdfs:comment 'Available cargo capacity in the belly hold of the assigned aircraft, measured in kilograms, used for cargo revenue planning.' ;
    rdfs:domain ind:FleetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cargoBellyCapacityM3 rdf:type rdf:Property ;
    rdfs:label 'Cargo Belly Capacity M3' ;
    rdfs:comment 'Available cargo volume in the belly hold of the assigned aircraft, measured in cubic meters.' ;
    rdfs:domain ind:FleetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:economyClassSeats rdf:type rdf:Property ;
    rdfs:label 'Economy Class Seats' ;
    rdfs:comment 'Number of economy class seats in the assigned aircraft configuration.' ;
    rdfs:domain ind:FleetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:firstClassSeats rdf:type rdf:Property ;
    rdfs:label 'First Class Seats' ;
    rdfs:comment 'Number of first class or premium cabin seats in the assigned aircraft configuration.' ;
    rdfs:domain ind:FleetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:plannedAskCapacity rdf:type rdf:Property ;
    rdfs:label 'Planned Ask Capacity' ;
    rdfs:comment 'Planned ASK (Available Seat Kilometers) capacity for this route-fleet assignment, calculated as total seats multiplied by route distance and frequency, used for network capacity planning.' ;
    rdfs:domain ind:FleetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:premiumEconomySeats rdf:type rdf:Property ;
    rdfs:label 'Premium Economy Seats' ;
    rdfs:comment 'Number of premium economy seats in the assigned aircraft configuration.' ;
    rdfs:domain ind:FleetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:targetLoadFactorPercent rdf:type rdf:Property ;
    rdfs:label 'Target Load Factor Percent' ;
    rdfs:comment 'Target load factor percentage (percentage of seats filled) that revenue management aims to achieve for this route-fleet assignment.' ;
    rdfs:domain ind:FleetAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualAltitudeFt rdf:type rdf:Property ;
    rdfs:label 'Actual Altitude Ft' ;
    rdfs:comment 'Actual altitude in feet flown during an airspace deviation occurrence. Populated only for airspace_deviation subtype.' ;
    rdfs:domain ind:Occurrence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:aircraftDamageLevel rdf:type rdf:Property ;
    rdfs:label 'Aircraft Damage Level' ;
    rdfs:comment 'Extent of damage sustained by the aircraft: destroyed (total loss), substantial (major structural damage affecting airworthiness), minor (cosmetic or repairable without affecting airworthiness), or none.' ;
    rdfs:domain ind:Occurrence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:classification rdf:type rdf:Property ;
    rdfs:label 'Classification' ;
    rdfs:comment 'Primary classification of the safety event per ICAO Annex 13 definitions: accident (fatal or substantial damage), serious incident (near-accident), incident (safety concern), or occurrence (reportable event).' ;
    rdfs:domain ind:Occurrence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:clearedAltitudeFt rdf:type rdf:Property ;
    rdfs:label 'Cleared Altitude Ft' ;
    rdfs:comment 'ATC-cleared altitude in feet for an airspace deviation occurrence. Populated only for airspace_deviation subtype.' ;
    rdfs:domain ind:Occurrence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dangerousGoodsClass rdf:type rdf:Property ;
    rdfs:label 'Dangerous Goods Class' ;
    rdfs:comment 'ICAO/IATA dangerous goods classification (e.g., Class 3 Flammable Liquids, Class 8 Corrosives). Populated only for dangerous_goods_incident subtype.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dangerousGoodsUnNumber rdf:type rdf:Property ;
    rdfs:label 'Dangerous Goods Un Number' ;
    rdfs:comment 'United Nations identification number for dangerous goods involved in a dangerous goods incident (e.g., UN1950 for aerosols). Populated only for dangerous_goods_incident subtype.' ;
    rdfs:domain ind:Occurrence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fatalitiesCount rdf:type rdf:Property ;
    rdfs:label 'Fatalities Count' ;
    rdfs:comment 'Total number of fatalities resulting from the occurrence (passengers, crew, and ground personnel).' ;
    rdfs:domain ind:Occurrence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:initialCausalFactors rdf:type rdf:Property ;
    rdfs:label 'Initial Causal Factors' ;
    rdfs:comment 'Preliminary assessment of contributing or causal factors identified during initial occurrence reporting. Subject to revision during formal investigation.' ;
    rdfs:domain ind:Occurrence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:injurySeverity rdf:type rdf:Property ;
    rdfs:label 'Injury Severity' ;
    rdfs:comment 'Highest level of injury sustained by any person involved in the occurrence (fatal, serious, minor, none) per ICAO definitions.' ;
    rdfs:domain ind:Occurrence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:location rdf:type rdf:Property ;
    rdfs:label 'Location' ;
    rdfs:comment 'Textual description of the geographic location where the occurrence took place (airport name, airspace sector, coordinates, or nearest landmark).' ;
    rdfs:domain ind:Occurrence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minorInjuriesCount rdf:type rdf:Property ;
    rdfs:label 'Minor Injuries Count' ;
    rdfs:comment 'Total number of persons who sustained minor injuries not meeting the serious injury threshold.' ;
    rdfs:domain ind:Occurrence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:narrativeDescription rdf:type rdf:Property ;
    rdfs:label 'Narrative Description' ;
    rdfs:comment 'Detailed free-text narrative describing the sequence of events, circumstances, and conditions surrounding the occurrence. Captures initial reporter observations and factual account.' ;
    rdfs:domain ind:Occurrence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:occurrenceDate rdf:type rdf:Property ;
    rdfs:label 'Occurrence Date' ;
    rdfs:comment 'Date on which the safety occurrence took place (UTC).' ;
    rdfs:domain ind:Occurrence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:occurrenceNumber rdf:type rdf:Property ;
    rdfs:label 'Occurrence Number' ;
    rdfs:comment 'Externally-known unique reference number assigned to the occurrence for tracking and regulatory reporting. Format varies by airline SMS system.' ;
    rdfs:domain ind:Occurrence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:occurrenceTimestamp rdf:type rdf:Property ;
    rdfs:label 'Occurrence Timestamp' ;
    rdfs:comment 'Precise date and time (UTC) when the safety occurrence event happened. Principal business event timestamp.' ;
    rdfs:domain ind:Occurrence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:packagingFailureDescription rdf:type rdf:Property ;
    rdfs:label 'Packaging Failure Description' ;
    rdfs:comment 'Description of packaging failure or non-compliance that led to a dangerous goods incident. Populated only for dangerous_goods_incident subtype.' ;
    rdfs:domain ind:Occurrence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryNotificationStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Status' ;
    rdfs:comment 'Current status of regulatory notification process: not required, pending submission, submitted to authority, or acknowledged by authority.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reporterName rdf:type rdf:Property ;
    rdfs:label 'Reporter Name' ;
    rdfs:comment 'Name of the individual who reported the occurrence. Confidential to encourage just culture reporting per SMS principles.' ;
    rdfs:domain ind:Occurrence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingSource rdf:type rdf:Property ;
    rdfs:label 'Reporting Source' ;
    rdfs:comment 'Source or role of the individual or system that initially reported the occurrence (crew, maintenance, ground staff, ATC, passenger, external party, automated system). [ENUM-REF-CANDIDATE: crew|maintenance|ground_staff|atc|passenger|external|automated_system — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Occurrence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runwayDesignator rdf:type rdf:Property ;
    rdfs:label 'Runway Designator' ;
    rdfs:comment 'Runway identifier involved in a runway incursion occurrence (e.g., 27L, 09R, 33). Populated only for runway_incursion subtype.' ;
    rdfs:domain ind:Occurrence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:runwayIncursionSeverity rdf:type rdf:Property ;
    rdfs:label 'Runway Incursion Severity' ;
    rdfs:comment 'FAA/ICAO severity classification for runway incursion: A (extreme risk of collision), B (significant potential for collision), C (ample time to avoid collision), D (little or no chance of collision). Populated only for runway_incursion subtype.' ;
    rdfs:domain ind:Occurrence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seriousInjuriesCount rdf:type rdf:Property ;
    rdfs:label 'Serious Injuries Count' ;
    rdfs:comment 'Total number of persons who sustained serious injuries as defined by ICAO Annex 13 (hospitalization >48 hours, fractures, severe burns, etc.).' ;
    rdfs:domain ind:Occurrence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:subtype rdf:type rdf:Property ;
    rdfs:label 'Subtype' ;
    rdfs:comment 'Detailed subtype classification for the occurrence enabling subtype-specific attribute capture (wildlife strike, runway incursion, airspace deviation, dangerous goods incident, CFIT, loss of control, turbulence encounter, ground collision, fuel emergency, cabin safety, other). [ENUM-REF-CANDIDATE: wildlife_strike|runway_incursion|airspace_deviation|dangerous_goods_incident|cfit|loss_of_control|turbulence_encounter|ground_collision|fuel_emergency|cabin_safety|other — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Occurrence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wildlifeIngestionFlag rdf:type rdf:Property ;
    rdfs:label 'Wildlife Ingestion Flag' ;
    rdfs:comment 'Indicates whether wildlife was ingested into an engine during a wildlife strike. Populated only for wildlife_strike subtype.' ;
    rdfs:domain ind:Occurrence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:wildlifeSpecies rdf:type rdf:Property ;
    rdfs:label 'Wildlife Species' ;
    rdfs:comment 'Species of wildlife involved in a wildlife strike occurrence (bird species, mammal, reptile). Populated only for wildlife_strike subtype.' ;
    rdfs:domain ind:Occurrence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wildlifeStrikeLocation rdf:type rdf:Property ;
    rdfs:label 'Wildlife Strike Location' ;
    rdfs:comment 'Aircraft component or area struck by wildlife (engine, nose, windshield, wing, fuselage, landing gear). Populated only for wildlife_strike subtype.' ;
    rdfs:domain ind:Occurrence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingMemberId rdf:type rdf:Property ;
    rdfs:label 'Reporting Member Id' ;
    rdfs:comment 'Foreign key linking to crew.member. Business justification: Crew members are primary hazard reporters in an airline SMS. hazard.identification_source is a text field. A FK to the reporting crew member enables SMS hazard reporting traceability, crew safety part' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Member .

ind:affectedOperationsArea rdf:type rdf:Property ;
    rdfs:label 'Affected Operations Area' ;
    rdfs:comment 'Operational domain or business area impacted by the hazard (e.g., flight operations, ground handling, maintenance, cargo, passenger services, crew scheduling).' ;
    rdfs:domain ind:Hazard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentLikelihoodRating rdf:type rdf:Property ;
    rdfs:label 'Current Likelihood Rating' ;
    rdfs:comment 'Current qualitative assessment of the probability that the hazard will result in a safety event, reflecting any mitigations applied since initial identification.' ;
    rdfs:domain ind:Hazard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentRiskIndex rdf:type rdf:Property ;
    rdfs:label 'Current Risk Index' ;
    rdfs:comment 'Current composite risk score derived from current likelihood and severity ratings using the ICAO SMS risk matrix, reflecting residual risk after mitigations. [ENUM-REF-CANDIDATE: 5A|5B|5C|4A|4B|4C|3A|3B|3C|2A|2B|1A — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Hazard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentSeverityRating rdf:type rdf:Property ;
    rdfs:label 'Current Severity Rating' ;
    rdfs:comment 'Current qualitative assessment of the worst credible consequence if the hazard materializes, reflecting any mitigations applied since initial identification.' ;
    rdfs:domain ind:Hazard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardCategory rdf:type rdf:Property ;
    rdfs:label 'Hazard Category' ;
    rdfs:comment 'Primary classification of the hazard type: operational (flight ops, ground ops), technical (aircraft systems, equipment), organizational (procedures, management), environmental (weather, terrain), human_factors (crew performance, fatigue), or external (third-party, regulatory).' ;
    rdfs:domain ind:Hazard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardDescription rdf:type rdf:Property ;
    rdfs:label 'Hazard Description' ;
    rdfs:comment 'Detailed narrative description of the hazard, including conditions, circumstances, and potential consequences that could lead to safety events.' ;
    rdfs:domain ind:Hazard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardNumber rdf:type rdf:Property ;
    rdfs:label 'Hazard Number' ;
    rdfs:comment 'Business-facing unique reference number assigned to the hazard for tracking and reporting purposes. Format: HAZ-NNNNNN.' ;
    rdfs:domain ind:Hazard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hazardStatus rdf:type rdf:Property ;
    rdfs:label 'Hazard Status' ;
    rdfs:comment 'Current lifecycle status of the hazard in the SMS register: open (newly identified), under_review (being assessed), mitigation_in_progress (controls being implemented), mitigated (controls in place, residual risk acceptable), closed (no longer applicable), accepted (risk accepted by accountable executive).' ;
    rdfs:domain ind:Hazard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identificationSource rdf:type rdf:Property ;
    rdfs:label 'Identification Source' ;
    rdfs:comment 'Method or channel through which the hazard was identified: safety audit, incident report, occurrence report, crew observation, maintenance finding, proactive analysis (FMEA, FHA), regulatory inspection, or third-party report. [ENUM-REF-CANDIDATE: safety_audit|incident_report|occurrence_report|crew_observation|maintenance_finding|proactive_analysis|regulatory_inspection|third_party_report — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Hazard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:identifiedDate rdf:type rdf:Property ;
    rdfs:label 'Identified Date' ;
    rdfs:comment 'Date on which the hazard was first identified and entered into the SMS hazard register.' ;
    rdfs:domain ind:Hazard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:initialLikelihoodRating rdf:type rdf:Property ;
    rdfs:label 'Initial Likelihood Rating' ;
    rdfs:comment 'Initial qualitative assessment of the probability that the hazard will result in a safety event, using ICAO SMS risk matrix categories: frequent, occasional, remote, improbable, extremely_improbable.' ;
    rdfs:domain ind:Hazard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initialRiskIndex rdf:type rdf:Property ;
    rdfs:label 'Initial Risk Index' ;
    rdfs:comment 'Initial composite risk score derived from likelihood and severity ratings using the ICAO SMS risk matrix (e.g., 5A = frequent/catastrophic, 1A = extremely_improbable/negligible). Format: <likelihood_level><severity_level>. [ENUM-REF-CANDIDATE: 5A|5B|5C|4A|4B|4C|3A|3B|3C|2A|2B|1A — 12 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Hazard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initialSeverityRating rdf:type rdf:Property ;
    rdfs:label 'Initial Severity Rating' ;
    rdfs:comment 'Initial qualitative assessment of the worst credible consequence if the hazard materializes, using ICAO SMS risk matrix categories: catastrophic, hazardous, major, minor, negligible.' ;
    rdfs:domain ind:Hazard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mitigationTargetDate rdf:type rdf:Property ;
    rdfs:label 'Mitigation Target Date' ;
    rdfs:comment 'Target date by which mitigation controls are planned to be fully implemented and effective.' ;
    rdfs:domain ind:Hazard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nextReviewDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Review Due Date' ;
    rdfs:comment 'Scheduled date for the next mandatory review of the hazard status and risk assessment, per SMS periodic review requirements.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:notamIssuedFlag rdf:type rdf:Property ;
    rdfs:label 'Notam Issued Flag' ;
    rdfs:comment 'Indicates whether a NOTAM (Notice to Air Missions) was issued to communicate this hazard to flight crews and operational personnel.' ;
    rdfs:domain ind:Hazard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryReportableFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reportable Flag' ;
    rdfs:comment 'Indicates whether this hazard meets the criteria for mandatory reporting to the national civil aviation authority (e.g., FAA, EASA) under occurrence reporting regulations.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewDate rdf:type rdf:Property ;
    rdfs:label 'Review Date' ;
    rdfs:comment 'Date of the most recent formal review of the hazard by the safety review board or safety action group.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sopRevisionRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Sop Revision Required Flag' ;
    rdfs:comment 'Indicates whether this hazard has triggered a requirement to revise or create a Standard Operating Procedure (SOP) as part of mitigation.' ;
    rdfs:domain ind:Hazard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:subcategory rdf:type rdf:Property ;
    rdfs:label 'Subcategory' ;
    rdfs:comment 'Secondary classification providing additional granularity within the primary hazard category (e.g., under technical: avionics, hydraulics, engines).' ;
    rdfs:domain ind:Hazard ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedOperations rdf:type rdf:Property ;
    rdfs:label 'Affected Operations' ;
    rdfs:comment 'Description of the operational scope impacted by the assessed risk (e.g., specific aircraft types, routes, phases of flight, operational procedures, airports). Used for targeted risk mitigation and communication.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentDate rdf:type rdf:Property ;
    rdfs:label 'Assessment Date' ;
    rdfs:comment 'The date on which this risk assessment was formally conducted and documented. Represents the principal business event timestamp for the assessment.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:assessmentMethodology rdf:type rdf:Property ;
    rdfs:label 'Assessment Methodology' ;
    rdfs:comment 'The formal risk assessment technique or framework applied (e.g., ICAO 5×5 Matrix, Bow-Tie Analysis, FMEA, HAZOP, Preliminary Hazard Analysis). Documents the analytical approach for audit and repeatability.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentNarrative rdf:type rdf:Property ;
    rdfs:label 'Assessment Narrative' ;
    rdfs:comment 'Detailed textual justification for the likelihood and severity scores assigned, including rationale, assumptions, data sources, and expert judgment applied. Critical for audit trail and knowledge transfer.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentNumber rdf:type rdf:Property ;
    rdfs:label 'Assessment Number' ;
    rdfs:comment 'Business-facing unique identifier for the risk assessment, typically formatted as RA-YYYYNNNNNN for external reference and audit trails.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentStatus rdf:type rdf:Property ;
    rdfs:label 'Assessment Status' ;
    rdfs:comment 'Current lifecycle state of the risk assessment record. Draft = in progress; Submitted = awaiting review; Under Review = being evaluated by safety committee; Approved = formally accepted; Closed = actions completed; Superseded = replaced by newer assessment.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentTeamMembers rdf:type rdf:Property ;
    rdfs:label 'Assessment Team Members' ;
    rdfs:comment 'Names or identifiers of additional subject matter experts, operational personnel, or safety committee members who contributed to the assessment. Captures collaborative input beyond the primary assessor.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentType rdf:type rdf:Property ;
    rdfs:label 'Assessment Type' ;
    rdfs:comment 'Classification of the assessment stage within the risk management lifecycle. Initial = first assessment of a new hazard; Residual = assessment after controls applied; Reviewed = periodic re-evaluation; Reassessment = triggered by new information; Periodic = scheduled routine review.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessorName rdf:type rdf:Property ;
    rdfs:label 'Assessor Name' ;
    rdfs:comment 'Full name of the individual who performed the risk assessment, captured for audit and accountability purposes.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSources rdf:type rdf:Property ;
    rdfs:label 'Data Sources' ;
    rdfs:comment 'List of data sources, evidence, and references used to inform the risk assessment (e.g., FDR/CVR analysis, incident reports, maintenance records, industry safety bulletins, statistical data). Supports traceability and repeatability.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:existingControlsSummary rdf:type rdf:Property ;
    rdfs:label 'Existing Controls Summary' ;
    rdfs:comment 'Summary of current risk mitigation controls, barriers, and defenses already in place at the time of assessment. Used to distinguish initial vs residual risk.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:likelihoodScore rdf:type rdf:Property ;
    rdfs:label 'Likelihood Score' ;
    rdfs:comment 'Probability rating of the hazard occurring, scored on the ICAO 1-5 scale where 1=Extremely Improbable, 2=Improbable, 3=Remote, 4=Occasional, 5=Frequent. Used to calculate risk index.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:notificationDate rdf:type rdf:Property ;
    rdfs:label 'Notification Date' ;
    rdfs:comment 'Date on which the risk assessment was formally reported to the regulatory authority. Nullable if notification not required or not yet completed.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:notificationReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Notification Reference Number' ;
    rdfs:comment 'Official reference number or tracking identifier assigned by the regulatory authority upon receipt of the risk assessment notification. Used for compliance audit trails.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendedActions rdf:type rdf:Property ;
    rdfs:label 'Recommended Actions' ;
    rdfs:comment 'Proposed corrective actions, additional controls, or risk treatments recommended by the assessor to reduce risk to an acceptable level. May link to formal corrective action plans.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAuthorityNotifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority Notified Flag' ;
    rdfs:comment 'Indicates whether the risk assessment and associated hazard were reported to the national civil aviation authority (e.g., FAA, EASA) as required for high-severity or intolerable risks.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reviewComments rdf:type rdf:Property ;
    rdfs:label 'Review Comments' ;
    rdfs:comment 'Feedback, observations, or directives provided by the reviewer during the approval process. May include requests for additional analysis or clarification.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskCategory rdf:type rdf:Property ;
    rdfs:label 'Risk Category' ;
    rdfs:comment 'High-level classification of the risk domain. Operational = flight operations and procedures; Technical = aircraft systems and equipment; Organizational = management and processes; Environmental = weather and external conditions; Human Factors = crew performance and fatigue; Security = intentional threats.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskIndex rdf:type rdf:Property ;
    rdfs:label 'Risk Index' ;
    rdfs:comment 'Calculated risk score derived from likelihood and severity scores, typically computed as likelihood × severity. Range 1-25 on ICAO matrix. Determines risk tolerance classification.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:riskMatrixQuadrant rdf:type rdf:Property ;
    rdfs:label 'Risk Matrix Quadrant' ;
    rdfs:comment 'Visual position on the 5×5 ICAO risk matrix, typically expressed as coordinate notation (e.g., L3S4) or color-coded zone (green/yellow/amber/red). Used for dashboard visualization and executive reporting.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskToleranceLevel rdf:type rdf:Property ;
    rdfs:label 'Risk Tolerance Level' ;
    rdfs:comment 'Management decision on acceptability of the assessed risk. Acceptable = no further action required; Tolerable = acceptable with mitigation and monitoring; Intolerable = unacceptable, immediate action required. Aligns with ALARP (As Low As Reasonably Practicable) principle.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:severityScore rdf:type rdf:Property ;
    rdfs:label 'Severity Score' ;
    rdfs:comment 'Consequence rating of the hazard if it occurs, scored on the ICAO 1-5 scale where 1=Negligible, 2=Minor, 3=Major, 4=Hazardous, 5=Catastrophic. Used to calculate risk index.' ;
    rdfs:domain ind:RiskAssessment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:recommendationId rdf:type rdf:Property ;
    rdfs:label 'Recommendation Id' ;
    rdfs:comment 'Foreign key linking to safety.recommendation. Business justification: Corrective actions implement formal safety recommendations. Adding corrective_action.recommendation_id → recommendation.recommendation_id tracks which recommendation the action implements. No redundan' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Recommendation .

ind:actionDescription rdf:type rdf:Property ;
    rdfs:label 'Action Description' ;
    rdfs:comment 'Detailed narrative describing the corrective action, preventive measure, or safety recommendation including scope, methodology, and expected outcome.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionNumber rdf:type rdf:Property ;
    rdfs:label 'Action Number' ;
    rdfs:comment 'Business-facing unique reference number for the corrective action, typically formatted as CA-YYYYNNNNNN for external communication and tracking.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionTitle rdf:type rdf:Property ;
    rdfs:label 'Action Title' ;
    rdfs:comment 'Short descriptive title summarizing the corrective action or recommendation.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actionType rdf:type rdf:Property ;
    rdfs:label 'Action Type' ;
    rdfs:comment 'Classification of the action: corrective (addresses existing deficiency), preventive (prevents future occurrence), mitigating (reduces severity), or recommendation (formal safety recommendation from investigation body).' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Actual Completion Date' ;
    rdfs:comment 'Actual date when the corrective action implementation was completed, prior to verification.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:addresseeResponse rdf:type rdf:Property ;
    rdfs:label 'Addressee Response' ;
    rdfs:comment 'Formal response received from the external addressee or AIB regarding acceptance, implementation plan, or rejection of the recommendation.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedDepartment rdf:type rdf:Property ;
    rdfs:label 'Assigned Department' ;
    rdfs:comment 'Internal department or organizational unit responsible for implementing the corrective action.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureNotes rdf:type rdf:Property ;
    rdfs:label 'Closure Notes' ;
    rdfs:comment 'Detailed justification and notes supporting the closure decision including effectiveness evidence and lessons learned.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureStatus rdf:type rdf:Property ;
    rdfs:label 'Closure Status' ;
    rdfs:comment 'Final disposition status indicating whether the corrective action has been formally closed and the reason for closure.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionStatus rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Status' ;
    rdfs:comment 'Current lifecycle status of the corrective action from identification through closure and effectiveness review. [ENUM-REF-CANDIDATE: open|in_progress|pending_verification|verified|closed|overdue|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costEstimate rdf:type rdf:Property ;
    rdfs:label 'Cost Estimate' ;
    rdfs:comment 'Estimated financial cost to implement the corrective action including labor, materials, training, and system modifications.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:effectivenessRating rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Rating' ;
    rdfs:comment 'Assessment of whether the corrective action achieved its intended safety improvement objective after monitoring period.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivenessReviewDate rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Review Date' ;
    rdfs:comment 'Scheduled or actual date for reviewing the long-term effectiveness of the corrective action after a monitoring period.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:externalAddressee rdf:type rdf:Property ;
    rdfs:label 'External Addressee' ;
    rdfs:comment 'Name of external organization or Accident Investigation Body (AIB) to whom this recommendation is addressed, if applicable.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:implementationEvidence rdf:type rdf:Property ;
    rdfs:label 'Implementation Evidence' ;
    rdfs:comment 'Description or reference to documentation, records, or artifacts that provide evidence of corrective action implementation.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryTrackingReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Tracking Reference' ;
    rdfs:comment 'External reference number assigned by regulatory authority or AIB for tracking formal safety recommendations requiring airline response.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsiblePersonEmail rdf:type rdf:Property ;
    rdfs:label 'Responsible Person Email' ;
    rdfs:comment 'Email address of the individual accountable for the corrective action implementation.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responsiblePersonName rdf:type rdf:Property ;
    rdfs:label 'Responsible Person Name' ;
    rdfs:comment 'Name of the individual accountable for ensuring the corrective action is completed and effective.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Source Reference Number' ;
    rdfs:comment 'Reference identifier of the source event, occurrence report, audit finding, investigation, hazard, or risk assessment that generated this action.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceType rdf:type rdf:Property ;
    rdfs:label 'Source Type' ;
    rdfs:comment 'Category of the originating event or process that triggered this corrective action within the SMS.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetCompletionDate rdf:type rdf:Property ;
    rdfs:label 'Target Completion Date' ;
    rdfs:comment 'Planned date by which the corrective action should be fully implemented and verified.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:verificationMethod rdf:type rdf:Property ;
    rdfs:label 'Verification Method' ;
    rdfs:comment 'Method used to verify that the corrective action has been implemented as intended and is effective.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:verificationNotes rdf:type rdf:Property ;
    rdfs:label 'Verification Notes' ;
    rdfs:comment 'Detailed notes from the verification process including findings, evidence reviewed, and any concerns identified.' ;
    rdfs:domain ind:CorrectiveAction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualEndDate rdf:type rdf:Property ;
    rdfs:label 'Actual End Date' ;
    rdfs:comment 'Actual date when the audit concluded. May differ from planned date due to scope changes or findings requiring extended investigation.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualStartDate rdf:type rdf:Property ;
    rdfs:label 'Actual Start Date' ;
    rdfs:comment 'Actual date when the audit commenced. May differ from planned date due to operational changes.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:auditScope rdf:type rdf:Property ;
    rdfs:label 'Audit Scope' ;
    rdfs:comment 'Detailed description of the audit scope, including areas, processes, and standards being audited (e.g., \'Flight Operations SMS compliance - all hub stations\', \'IOSA IRM sections 1.1-1.5\', \'Part 121 operational control procedures\').' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditStatus rdf:type rdf:Property ;
    rdfs:label 'Audit Status' ;
    rdfs:comment 'Current lifecycle status of the audit. Values: planned (scheduled but not started), in_progress (fieldwork underway), completed (fieldwork finished, report pending), closed (report issued and all corrective actions tracked), cancelled (audit cancelled before completion).' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditType rdf:type rdf:Property ;
    rdfs:label 'Audit Type' ;
    rdfs:comment 'Classification of the audit. Values: internal_sms (internal Safety Management System audit), iosa_preparation (IATA Operational Safety Audit preparation audit), regulatory_authority (FAA/EASA/CAA audit), losa (Line Operations Safety Audit), line_station (line station operational audit), maintenance (MRO facility audit).' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditedDepartment rdf:type rdf:Property ;
    rdfs:label 'Audited Department' ;
    rdfs:comment 'Name of the department, division, or functional area being audited (e.g., \'Flight Operations\', \'Ground Handling\', \'Maintenance Engineering\', \'Crew Scheduling\').' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditedFunction rdf:type rdf:Property ;
    rdfs:label 'Audited Function' ;
    rdfs:comment 'Specific operational function or process being audited (e.g., \'Dispatch Release Procedures\', \'Fuel Uplift Operations\', \'Cabin Safety Procedures\', \'MEL Compliance\').' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionPlanDueDate rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Plan Due Date' ;
    rdfs:comment 'Date by which the corrective action plan must be submitted to the audit authority or safety management team. Null if no CAP required.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:correctiveActionPlanRequired rdf:type rdf:Property ;
    rdfs:label 'Corrective Action Plan Required' ;
    rdfs:comment 'Indicates whether a formal corrective action plan is required based on audit findings. True if findings require documented corrective actions.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:criticalFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Critical Findings Count' ;
    rdfs:comment 'Number of critical findings requiring immediate corrective action due to significant safety risk or regulatory non-compliance.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:followUpAuditRequired rdf:type rdf:Property ;
    rdfs:label 'Follow Up Audit Required' ;
    rdfs:comment 'Indicates whether a follow-up audit is required to verify implementation of corrective actions. True if findings severity or regulatory requirement mandates follow-up.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:followUpAuditScheduledDate rdf:type rdf:Property ;
    rdfs:label 'Follow Up Audit Scheduled Date' ;
    rdfs:comment 'Scheduled date for the follow-up audit to verify corrective action effectiveness. Null if no follow-up required.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:iosaRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Iosa Registration Number' ;
    rdfs:comment 'IATA IOSA registration number if this audit is part of IOSA certification or renewal process (e.g., \'IOSA-123456\'). Null for non-IOSA audits.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leadAuditorName rdf:type rdf:Property ;
    rdfs:label 'Lead Auditor Name' ;
    rdfs:comment 'Full name of the lead auditor responsible for conducting and reporting the audit.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:majorFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Major Findings Count' ;
    rdfs:comment 'Number of major findings representing significant non-conformities that could affect safety or compliance if not addressed.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:minorFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Minor Findings Count' ;
    rdfs:comment 'Number of minor findings representing isolated non-conformities or opportunities for improvement with low safety impact.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overallFindingSummary rdf:type rdf:Property ;
    rdfs:label 'Overall Finding Summary' ;
    rdfs:comment 'Executive summary of the audit findings, including overall compliance assessment, number of findings by severity, and key themes identified.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:plannedEndDate rdf:type rdf:Property ;
    rdfs:label 'Planned End Date' ;
    rdfs:comment 'Scheduled date when the audit is planned to conclude.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedStartDate rdf:type rdf:Property ;
    rdfs:label 'Planned Start Date' ;
    rdfs:comment 'Scheduled date when the audit is planned to commence.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:regulatoryAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority Name' ;
    rdfs:comment 'Name of the regulatory authority conducting or sponsoring the audit (e.g., \'FAA\', \'EASA\', \'UK CAA\', \'DGCA India\'). Null for internal audits.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAuthorityReference rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority Reference' ;
    rdfs:comment 'Reference number or identifier assigned by the regulatory authority for this audit. Null for internal audits.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportDocumentReference rdf:type rdf:Property ;
    rdfs:label 'Report Document Reference' ;
    rdfs:comment 'Document management system reference or file path to the formal audit report document.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportIssuedDate rdf:type rdf:Property ;
    rdfs:label 'Report Issued Date' ;
    rdfs:comment 'Date when the formal audit report was issued to the audited department and relevant stakeholders.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:smsAccountableExecutiveNotified rdf:type rdf:Property ;
    rdfs:label 'Sms Accountable Executive Notified' ;
    rdfs:comment 'Indicates whether the SMS Accountable Executive has been notified of the audit findings, as required for critical or major findings under ICAO Annex 19.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:standardReference rdf:type rdf:Property ;
    rdfs:label 'Standard Reference' ;
    rdfs:comment 'Reference to the standard, regulation, or framework against which the audit was conducted (e.g., \'IOSA IRM Edition 14\', \'FAA Part 121\', \'ICAO Annex 19\', \'ISO 9001:2015\').' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:teamMembers rdf:type rdf:Property ;
    rdfs:label 'Team Members' ;
    rdfs:comment 'Comma-separated list of audit team member names participating in the audit.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalFindingsCount rdf:type rdf:Property ;
    rdfs:label 'Total Findings Count' ;
    rdfs:comment 'Total number of findings (non-conformities, observations, opportunities for improvement) identified during the audit.' ;
    rdfs:domain ind:Audit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:auditFindingId rdf:type rdf:Property ;
    rdfs:label 'Audit Finding Id' ;
    rdfs:comment 'Unique identifier for the audit finding record. Primary key.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:previousFindingAuditFindingId rdf:type rdf:Property ;
    rdfs:label 'Previous Finding Audit Finding Id' ;
    rdfs:comment 'Reference to the previous audit finding record if this is a recurrence. Links to historical finding for trend analysis and corrective action effectiveness review.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AuditFinding .

ind:auditOrganization rdf:type rdf:Property ;
    rdfs:label 'Audit Organization' ;
    rdfs:comment 'Organization or authority that conducted the audit (e.g., IATA IOSA, FAA, EASA, Internal Audit, National CAA). Identifies the source and authority level of the finding.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:auditorName rdf:type rdf:Property ;
    rdfs:label 'Auditor Name' ;
    rdfs:comment 'Name of the auditor or inspector who identified and documented the finding. May be internal auditor, IOSA auditor, FAA inspector, or EASA inspector.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:escalationFlag rdf:type rdf:Property ;
    rdfs:label 'Escalation Flag' ;
    rdfs:comment 'Indicates whether the finding has been escalated to senior management or the accountable executive due to high risk, regulatory significance, or overdue corrective actions. True if escalated, false otherwise.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:findingCategory rdf:type rdf:Property ;
    rdfs:label 'Finding Category' ;
    rdfs:comment 'Business or operational category of the finding (e.g., Flight Operations, Maintenance, Ground Operations, Crew Training, Safety Management, Security, Cargo). Aligns with airline operational domains.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingDate rdf:type rdf:Property ;
    rdfs:label 'Finding Date' ;
    rdfs:comment 'Date on which the finding was identified and documented during the audit or inspection activity.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:findingDescription rdf:type rdf:Property ;
    rdfs:label 'Finding Description' ;
    rdfs:comment 'Detailed narrative description of the finding, including what was observed, the context, and why it constitutes a finding. Provides full business context for auditors, management, and corrective action teams.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Finding Reference Number' ;
    rdfs:comment 'Externally-known unique reference number assigned to this finding for tracking and communication purposes. Used in audit reports and corrective action tracking.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingStatus rdf:type rdf:Property ;
    rdfs:label 'Finding Status' ;
    rdfs:comment 'Current lifecycle status of the finding. Tracks progression from identification through corrective action implementation to closure and verification. [ENUM-REF-CANDIDATE: open|under_review|corrective_action_assigned|in_progress|pending_verification|closed|overdue — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:findingType rdf:type rdf:Property ;
    rdfs:label 'Finding Type' ;
    rdfs:comment 'Classification of the finding severity and nature. Non-conformance indicates a breach of regulatory or standard requirements; observation is a noted concern without immediate compliance impact; opportunity for improvement suggests enhancement areas; positive finding recognizes good practice.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:managementResponse rdf:type rdf:Property ;
    rdfs:label 'Management Response' ;
    rdfs:comment 'Formal response from management acknowledging the finding, accepting or disputing it, and committing to corrective actions. Part of the audit finding closure process.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preventiveAction rdf:type rdf:Property ;
    rdfs:label 'Preventive Action' ;
    rdfs:comment 'Description of preventive measures implemented to prevent recurrence of similar findings across the organization. Addresses systemic improvements beyond immediate corrective action.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recurrenceFlag rdf:type rdf:Property ;
    rdfs:label 'Recurrence Flag' ;
    rdfs:comment 'Indicates whether this finding is a recurrence of a previously identified and closed finding. True if recurrent, false if new. Recurrent findings indicate ineffective corrective actions and require escalation.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:riskLevel rdf:type rdf:Property ;
    rdfs:label 'Risk Level' ;
    rdfs:comment 'Risk severity level assigned to the finding based on safety risk assessment. Determines priority for corrective action and management escalation. Aligns with SMS risk matrix (likelihood x severity).' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskScore rdf:type rdf:Property ;
    rdfs:label 'Risk Score' ;
    rdfs:comment 'Numeric risk score calculated from the SMS risk matrix, typically ranging from 1 (lowest risk) to 25 (highest risk). Used for quantitative risk prioritization and trending.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rootCauseAnalysis rdf:type rdf:Property ;
    rdfs:label 'Root Cause Analysis' ;
    rdfs:comment 'Analysis of the underlying root cause(s) that led to the finding. May reference human factors, procedural gaps, training deficiencies, equipment failures, or systemic issues. Critical for effective corrective action planning.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sopReference rdf:type rdf:Property ;
    rdfs:label 'Sop Reference' ;
    rdfs:comment 'Reference to the specific Standard Operating Procedure (SOP) document, version, or section that was not followed or requires revision as a result of this finding.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stationCode rdf:type rdf:Property ;
    rdfs:label 'Station Code' ;
    rdfs:comment 'Three-letter IATA airport code of the station where the finding was identified, if location-specific. Null if finding is not tied to a specific airport or station.' ;
    rdfs:domain ind:AuditFinding ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acknowledgementCount rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Count' ;
    rdfs:comment 'Number of required recipients who have acknowledged the safety communication.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:acknowledgementRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Required Flag' ;
    rdfs:comment 'Indicates whether recipients are required to formally acknowledge receipt and understanding of the safety communication. True/False.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:affectedAircraftTypes rdf:type rdf:Property ;
    rdfs:label 'Affected Aircraft Types' ;
    rdfs:comment 'Comma-separated list of aircraft type codes affected by the safety alert or bulletin.' ;
    rdfs:domain ind:Report ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedFleetTailNumbers rdf:type rdf:Property ;
    rdfs:label 'Affected Fleet Tail Numbers' ;
    rdfs:comment 'Comma-separated list of specific aircraft registrations in the fleet affected by the safety alert or bulletin.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceDeadline rdf:type rdf:Property ;
    rdfs:label 'Compliance Deadline' ;
    rdfs:comment 'Date by which required actions must be completed for safety alerts and bulletins. Format: yyyy-MM-dd.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deIdentificationFlag rdf:type rdf:Property ;
    rdfs:label 'De Identification Flag' ;
    rdfs:comment 'Indicates whether personally identifiable information has been removed from the report to protect reporter identity under Just Culture principles. True/False.' ;
    rdfs:domain ind:Report ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:distributionStatus rdf:type rdf:Property ;
    rdfs:label 'Distribution Status' ;
    rdfs:comment 'Status of distribution of the safety alert or bulletin to relevant personnel and departments.' ;
    rdfs:domain ind:Report ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:distributionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Distribution Timestamp' ;
    rdfs:comment 'Date and time when the safety alert or bulletin was distributed to the organization. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:investigationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Investigation Required Flag' ;
    rdfs:comment 'Indicates whether the safety event requires formal investigation. True/False.' ;
    rdfs:domain ind:Report ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:narrative rdf:type rdf:Property ;
    rdfs:label 'Narrative' ;
    rdfs:comment 'Detailed free-text narrative describing the safety event, circumstances, and observations. May be de-identified for confidential reports.' ;
    rdfs:domain ind:Report ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryNotificationFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Notification Flag' ;
    rdfs:comment 'Indicates whether the safety event was reported to external regulatory authorities (FAA, EASA, etc.). True/False.' ;
    rdfs:domain ind:Report ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportStatus rdf:type rdf:Property ;
    rdfs:label 'Report Status' ;
    rdfs:comment 'Current processing status of the safety report in the SMS workflow.' ;
    rdfs:domain ind:Report ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportType rdf:type rdf:Property ;
    rdfs:label 'Report Type' ;
    rdfs:comment 'Classification of the safety report: voluntary (crew-initiated), mandatory (regulatory requirement), confidential (anonymous), safety_alert (urgent communication), SIB (Safety Information Bulletin), SAFO (Safety Alert for Operators).' ;
    rdfs:domain ind:Report ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reporterRole rdf:type rdf:Property ;
    rdfs:label 'Reporter Role' ;
    rdfs:comment 'Functional role of the person who submitted the safety report.' ;
    rdfs:domain ind:Report ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requiredActionDescription rdf:type rdf:Property ;
    rdfs:label 'Required Action Description' ;
    rdfs:comment 'Description of corrective actions, compliance requirements, or operational changes required in response to the safety alert or bulletin.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:urgencyLevel rdf:type rdf:Property ;
    rdfs:label 'Urgency Level' ;
    rdfs:comment 'Urgency classification for safety alerts and bulletins indicating required response timeframe.' ;
    rdfs:domain ind:Safety ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:smsHazardId rdf:type rdf:Property ;
    rdfs:label 'Sms Hazard Id' ;
    rdfs:comment 'Reference to the SMS hazard record that was identified or updated as a result of this investigation. Links investigation findings back to the hazard identification and risk assessment process.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Hazard .

ind:subjectCrewMemberId rdf:type rdf:Property ;
    rdfs:label 'Subject Crew Member Id' ;
    rdfs:comment 'Foreign key linking to crew.member. Business justification: Safety investigations involve specific crew members as subjects or key witnesses. investigation.team_members is a denormalized text field. A FK to the subject crew member supports regulatory investiga' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Member .

ind:acarsDataReviewed rdf:type rdf:Property ;
    rdfs:label 'Acars Data Reviewed' ;
    rdfs:comment 'Indicates whether ACARS (Aircraft Communications Addressing and Reporting System) messages and data were reviewed as part of the investigation.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:causalFactorsIdentified rdf:type rdf:Property ;
    rdfs:label 'Causal Factors Identified' ;
    rdfs:comment 'Detailed description of the root causal factors identified during the investigation that directly led to the occurrence. May include human factors, technical failures, procedural deficiencies, or organizational factors.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contributingFactors rdf:type rdf:Property ;
    rdfs:label 'Contributing Factors' ;
    rdfs:comment 'Description of contributing factors that did not directly cause the occurrence but increased the likelihood or severity of the event. May include environmental conditions, latent organizational weaknesses, or systemic issues.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:correctiveActionsRequired rdf:type rdf:Property ;
    rdfs:label 'Corrective Actions Required' ;
    rdfs:comment 'Description of mandatory corrective actions required to address the causal and contributing factors identified in the investigation. Links to corrective action tracking systems.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cvrFdrDataReviewed rdf:type rdf:Property ;
    rdfs:label 'Cvr Fdr Data Reviewed' ;
    rdfs:comment 'Indicates whether CVR (Cockpit Voice Recorder) and FDR (Flight Data Recorder) data were reviewed as part of the investigation. True if recorder data were analyzed, false otherwise.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:externalExpertConsulted rdf:type rdf:Property ;
    rdfs:label 'External Expert Consulted' ;
    rdfs:comment 'Indicates whether external subject matter experts, technical specialists, or consultants were engaged to support the investigation.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:investigationStatus rdf:type rdf:Property ;
    rdfs:label 'Investigation Status' ;
    rdfs:comment 'Current lifecycle status of the investigation: open (assigned but not started), in-progress (active investigation), draft-report (findings being documented), final (report completed), closed (all actions complete), suspended (temporarily halted).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:investigationType rdf:type rdf:Property ;
    rdfs:label 'Investigation Type' ;
    rdfs:comment 'Classification of the investigation scope and authority: internal SMS investigation, regulatory authority-led investigation, joint investigation with multiple parties, independent third-party investigation, or preliminary investigation.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priority rdf:type rdf:Property ;
    rdfs:label 'Priority' ;
    rdfs:comment 'Priority level assigned to the investigation based on severity of the occurrence, potential safety impact, and regulatory requirements.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAuthorityNotified rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority Notified' ;
    rdfs:comment 'Regulatory or accident investigation authority that was notified of this investigation. NTSB (US National Transportation Safety Board), AAIB (UK Air Accidents Investigation Branch), BEA (French Bureau of Enquiry and Analysis), TSB (Transportation Safety Board of Canada), JTSB (Japan Transport Safety Board), or national AIB. [ENUM-REF-CANDIDATE: NTSB|AAIB|BEA|EASA|FAA|TSB|JTSB|national-AIB|none — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportReference rdf:type rdf:Property ;
    rdfs:label 'Report Reference' ;
    rdfs:comment 'Reference identifier or document management system link to the formal investigation report, including preliminary, interim, and final reports.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskAssessmentUpdated rdf:type rdf:Property ;
    rdfs:label 'Risk Assessment Updated' ;
    rdfs:comment 'Indicates whether the SMS risk assessment was updated based on the findings of this investigation. True if risk matrices or risk registers were revised.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:safetyRecommendationsIssued rdf:type rdf:Property ;
    rdfs:label 'Safety Recommendations Issued' ;
    rdfs:comment 'Detailed list of safety recommendations issued as a result of the investigation findings. Recommendations may address procedural changes, training enhancements, equipment modifications, or policy updates.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:witnessStatementsCollected rdf:type rdf:Property ;
    rdfs:label 'Witness Statements Collected' ;
    rdfs:comment 'Indicates whether witness statements from crew, passengers, ground personnel, or other parties were collected and documented as part of the investigation.' ;
    rdfs:domain ind:Investigation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceAuditId rdf:type rdf:Property ;
    rdfs:label 'Source Audit Id' ;
    rdfs:comment 'Reference to the safety audit or inspection that generated this recommendation, if applicable. Links to audit record in safety management system.' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Audit .

ind:sourceOccurrenceId rdf:type rdf:Property ;
    rdfs:label 'Source Occurrence Id' ;
    rdfs:comment 'Reference to the safety occurrence or event that triggered this recommendation, if applicable. Links to occurrence reporting system.' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Occurrence .

ind:actualImplementationDate rdf:type rdf:Property ;
    rdfs:label 'Actual Implementation Date' ;
    rdfs:comment 'Actual date when the recommended action was fully implemented and verified.' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:addresseeDepartment rdf:type rdf:Property ;
    rdfs:label 'Addressee Department' ;
    rdfs:comment 'Internal department or organizational unit responsible for responding to and implementing the recommendation (e.g., Flight Operations, Maintenance, Training, Ground Operations).' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addresseeExternalOrganization rdf:type rdf:Property ;
    rdfs:label 'Addressee External Organization' ;
    rdfs:comment 'External organization or regulatory authority to whom the recommendation is addressed, if applicable (e.g., FAA, EASA, aircraft manufacturer, airport authority).' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureVerificationMethod rdf:type rdf:Property ;
    rdfs:label 'Closure Verification Method' ;
    rdfs:comment 'Method used to verify that the recommendation has been effectively implemented (e.g., audit, inspection, documentation review, operational monitoring, SMS assessment).' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureVerifiedBy rdf:type rdf:Property ;
    rdfs:label 'Closure Verified By' ;
    rdfs:comment 'Name or role of the individual or body that verified and approved closure of the recommendation (e.g., Safety Manager, SMS Committee, external auditor).' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectivenessAssessment rdf:type rdf:Property ;
    rdfs:label 'Effectiveness Assessment' ;
    rdfs:comment 'Narrative assessment of the effectiveness of the implemented recommendation in achieving its intended safety improvement, based on operational data and monitoring.' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:estimatedImplementationCost rdf:type rdf:Property ;
    rdfs:label 'Estimated Implementation Cost' ;
    rdfs:comment 'Estimated financial cost to implement the recommendation, including capital expenditure, operational changes, training, and ongoing costs. Used for resource planning and cost-benefit analysis.' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:implementationActionPlan rdf:type rdf:Property ;
    rdfs:label 'Implementation Action Plan' ;
    rdfs:comment 'Detailed description of the corrective actions, procedural changes, or system modifications planned or executed to implement the recommendation.' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingAuthorityCode rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority Code' ;
    rdfs:comment 'Standardized code for the issuing authority (e.g., NTSB for National Transportation Safety Board, AAIB for Air Accidents Investigation Branch, FAA for Federal Aviation Administration, EASA for European Union Aviation Safety Agency).' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendationStatus rdf:type rdf:Property ;
    rdfs:label 'Recommendation Status' ;
    rdfs:comment 'Current lifecycle status of the safety recommendation: open (newly issued), under_review (being evaluated), accepted (approved for action), in_progress (implementation underway), implemented (action completed), closed (verified and closed), rejected (not accepted with justification), or superseded (replaced by newer recommendation). [ENUM-REF-CANDIDATE: open|under_review|accepted|in_progress|implemented|closed|rejected|superseded — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendationText rdf:type rdf:Property ;
    rdfs:label 'Recommendation Text' ;
    rdfs:comment 'Full text of the safety recommendation as issued, describing the specific action or change recommended to improve safety.' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recommendationType rdf:type rdf:Property ;
    rdfs:label 'Recommendation Type' ;
    rdfs:comment 'Classification of the recommendation based on its origin: internal (generated by airline), external_received (from national AIB or other authority), regulatory_mandate (required by regulator), audit_finding (from safety audit), proactive_study (from safety analysis), or sms_output (from SMS process).' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionJustification rdf:type rdf:Property ;
    rdfs:label 'Rejection Justification' ;
    rdfs:comment 'Detailed justification provided when a recommendation is rejected, including technical, operational, or economic rationale and alternative mitigations if applicable.' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseDueDate rdf:type rdf:Property ;
    rdfs:label 'Response Due Date' ;
    rdfs:comment 'Date by which a formal response to the recommendation is required, particularly for external recommendations from regulatory authorities or AIBs.' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responseNarrative rdf:type rdf:Property ;
    rdfs:label 'Response Narrative' ;
    rdfs:comment 'Detailed narrative of the airline\'s response to the recommendation, including acceptance rationale, implementation plan, or justification for rejection.' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseSubmittedDate rdf:type rdf:Property ;
    rdfs:label 'Response Submitted Date' ;
    rdfs:comment 'Date when the formal response to the recommendation was submitted to the issuing authority.' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:responsiblePersonRole rdf:type rdf:Property ;
    rdfs:label 'Responsible Person Role' ;
    rdfs:comment 'Job title or role of the individual responsible for the recommendation (e.g., Chief Pilot, Director of Safety, Maintenance Manager, Training Manager).' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyRiskCategory rdf:type rdf:Property ;
    rdfs:label 'Safety Risk Category' ;
    rdfs:comment 'Classification of the safety risk addressed by this recommendation (e.g., flight operations, maintenance, ground handling, crew fatigue, airworthiness, ATC coordination).' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:smsIntegrationFlag rdf:type rdf:Property ;
    rdfs:label 'Sms Integration Flag' ;
    rdfs:comment 'Indicates whether this recommendation has been formally integrated into the airline\'s SMS processes and risk register (true) or remains external tracking only (false).' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:summary rdf:type rdf:Property ;
    rdfs:label 'Summary' ;
    rdfs:comment 'Brief executive summary or title of the recommendation for quick reference and reporting purposes.' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetImplementationDate rdf:type rdf:Property ;
    rdfs:label 'Target Implementation Date' ;
    rdfs:comment 'Target or required date by which the recommendation should be implemented. May be mandated by regulator or set internally based on risk assessment.' ;
    rdfs:domain ind:Recommendation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:supersededByAlertId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Alert Id' ;
    rdfs:comment 'Reference to the alert_id of a newer alert that replaces or supersedes this alert. Null if this alert is still current.' ;
    rdfs:domain ind:Alert ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Alert .

ind:acknowledgementDeadline rdf:type rdf:Property ;
    rdfs:label 'Acknowledgement Deadline' ;
    rdfs:comment 'Date by which all required departments and personnel must acknowledge receipt of the alert. Null if no acknowledgement is required.' ;
    rdfs:domain ind:Alert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:alertDescription rdf:type rdf:Property ;
    rdfs:label 'Alert Description' ;
    rdfs:comment 'Detailed narrative describing the safety issue, hazard, or concern that prompted the alert, including background context and technical details.' ;
    rdfs:domain ind:Alert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertStatus rdf:type rdf:Property ;
    rdfs:label 'Alert Status' ;
    rdfs:comment 'Current lifecycle status of the safety alert: draft (under preparation), issued (distributed to stakeholders), acknowledged (receipt confirmed by departments), complied (required actions completed), closed (alert lifecycle complete), or superseded (replaced by newer alert).' ;
    rdfs:domain ind:Alert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alertType rdf:type rdf:Property ;
    rdfs:label 'Alert Type' ;
    rdfs:comment 'Classification of the safety alert by its originating source: internal (airline-issued), EASA SIB (European Union Aviation Safety Agency Safety Information Bulletin), FAA SAFO (Federal Aviation Administration Safety Alert for Operators), manufacturer (OEM safety bulletin), IATA (International Air Transport Association safety alert), or ICAO NOTAM (International Civil Aviation Organization Notice to Air Missions).' ;
    rdfs:domain ind:Alert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturerBulletinReference rdf:type rdf:Property ;
    rdfs:label 'Manufacturer Bulletin Reference' ;
    rdfs:comment 'Reference number of the original equipment manufacturer (OEM) safety bulletin or service bulletin that this alert is based on or references. Null if not applicable.' ;
    rdfs:domain ind:Alert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetRecipientCount rdf:type rdf:Property ;
    rdfs:label 'Target Recipient Count' ;
    rdfs:comment 'Total number of departments or individuals to whom this alert was distributed and from whom acknowledgement is expected.' ;
    rdfs:domain ind:Alert ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accessibilityComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Accessibility Compliance Flag' ;
    rdfs:comment 'Indicates whether the terminal facility meets accessibility standards for passengers with reduced mobility (PRM) including wheelchair access, accessible counters, and assistance services.' ;
    rdfs:domain ind:TerminalFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:annualPassengerVolume rdf:type rdf:Property ;
    rdfs:label 'Annual Passenger Volume' ;
    rdfs:comment 'Total number of passengers processed through this terminal facility in the most recent full calendar year.' ;
    rdfs:domain ind:TerminalFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bagDropCounterCount rdf:type rdf:Property ;
    rdfs:label 'Bag Drop Counter Count' ;
    rdfs:comment 'Number of dedicated self-service bag drop counters for passengers who have completed online or kiosk check-in.' ;
    rdfs:domain ind:TerminalFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:biometricCapabilityFlag rdf:type rdf:Property ;
    rdfs:label 'Biometric Capability Flag' ;
    rdfs:comment 'Indicates whether the terminal facility is equipped with biometric passenger processing technology (facial recognition, fingerprint scanning) for check-in and boarding.' ;
    rdfs:domain ind:TerminalFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cdmEnabledFlag rdf:type rdf:Property ;
    rdfs:label 'Cdm Enabled Flag' ;
    rdfs:comment 'Indicates whether the terminal facility participates in Airport Collaborative Decision Making (A-CDM) for real-time information sharing between airport, airlines, and Air Traffic Control (ATC).' ;
    rdfs:domain ind:Airport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:checkInCounterCount rdf:type rdf:Property ;
    rdfs:label 'Check In Counter Count' ;
    rdfs:comment 'Total number of full-service check-in counters staffed by airline agents for passenger processing and baggage acceptance.' ;
    rdfs:domain ind:TerminalFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:contactGateCount rdf:type rdf:Property ;
    rdfs:label 'Contact Gate Count' ;
    rdfs:comment 'Number of contact gates equipped with jet bridges for direct aircraft-to-terminal passenger boarding.' ;
    rdfs:domain ind:TerminalFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:counterZoneDesignation rdf:type rdf:Property ;
    rdfs:label 'Counter Zone Designation' ;
    rdfs:comment 'Alphanumeric designation of check-in counter zones within the terminal (e.g., Zone A, Rows 1-20, Island 3).' ;
    rdfs:domain ind:TerminalFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsFacilityFlag rdf:type rdf:Property ;
    rdfs:label 'Customs Facility Flag' ;
    rdfs:comment 'Indicates whether the terminal has customs and border control facilities for international passenger processing.' ;
    rdfs:domain ind:TerminalFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:facilityAddress rdf:type rdf:Property ;
    rdfs:label 'Facility Address' ;
    rdfs:comment 'Physical street address of the terminal facility for operational coordination and ground transportation routing.' ;
    rdfs:domain ind:TerminalFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityCity rdf:type rdf:Property ;
    rdfs:label 'Facility City' ;
    rdfs:comment 'City where the terminal facility is located.' ;
    rdfs:domain ind:TerminalFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityCountryCode rdf:type rdf:Property ;
    rdfs:label 'Facility Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code for the terminal facility location (e.g., USA, GBR, ARE).' ;
    rdfs:domain ind:TerminalFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityEmail rdf:type rdf:Property ;
    rdfs:label 'Facility Email' ;
    rdfs:comment 'Primary email address for terminal facility operational communications and coordination.' ;
    rdfs:domain ind:TerminalFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityPhone rdf:type rdf:Property ;
    rdfs:label 'Facility Phone' ;
    rdfs:comment 'Primary contact telephone number for terminal facility operations and coordination.' ;
    rdfs:domain ind:TerminalFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityPostalCode rdf:type rdf:Property ;
    rdfs:label 'Facility Postal Code' ;
    rdfs:comment 'Postal or ZIP code for the terminal facility address.' ;
    rdfs:domain ind:TerminalFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:facilityType rdf:type rdf:Property ;
    rdfs:label 'Facility Type' ;
    rdfs:comment 'Classification of the terminal facility structure type.' ;
    rdfs:domain ind:TerminalFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hubClassification rdf:type rdf:Property ;
    rdfs:label 'Hub Classification' ;
    rdfs:comment 'Strategic classification of the airport station in the airline\'s network (hub = central connecting airport, spoke = route from hub to destination).' ;
    rdfs:domain ind:Airport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastRenovationDate rdf:type rdf:Property ;
    rdfs:label 'Last Renovation Date' ;
    rdfs:comment 'Date of the most recent major renovation or modernization project completed for this terminal facility.' ;
    rdfs:domain ind:TerminalFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:loungeCount rdf:type rdf:Property ;
    rdfs:label 'Lounge Count' ;
    rdfs:comment 'Number of airline lounges operated within this terminal facility for premium passengers and Frequent Flyer Program (FFP) members.' ;
    rdfs:domain ind:TerminalFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:openingDate rdf:type rdf:Property ;
    rdfs:label 'Opening Date' ;
    rdfs:comment 'Date when the terminal facility first became operational for passenger services.' ;
    rdfs:domain ind:TerminalFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operationalStatus rdf:type rdf:Property ;
    rdfs:label 'Operational Status' ;
    rdfs:comment 'Current operational state of the terminal facility.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipModel rdf:type rdf:Property ;
    rdfs:label 'Ownership Model' ;
    rdfs:comment 'Designation of facility ownership and usage rights (airline-owned, joint-use with other carriers, or airport authority managed).' ;
    rdfs:domain ind:TerminalFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:passengerCapacityPerHour rdf:type rdf:Property ;
    rdfs:label 'Passenger Capacity Per Hour' ;
    rdfs:comment 'Design capacity of the terminal facility measured in passengers (PAX) that can be processed per hour during peak operations.' ;
    rdfs:domain ind:TerminalFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:remoteGateCount rdf:type rdf:Property ;
    rdfs:label 'Remote Gate Count' ;
    rdfs:comment 'Number of remote gates requiring bus transportation for passenger boarding (no jet bridge connection).' ;
    rdfs:domain ind:TerminalFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:securityCheckpointCount rdf:type rdf:Property ;
    rdfs:label 'Security Checkpoint Count' ;
    rdfs:comment 'Number of Transportation Security Administration (TSA) or equivalent security screening checkpoints in the terminal facility.' ;
    rdfs:domain ind:TerminalFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:selfServiceKioskCount rdf:type rdf:Property ;
    rdfs:label 'Self Service Kiosk Count' ;
    rdfs:comment 'Number of self-service check-in kiosks (CUSS - Common Use Self-Service) available for passenger self-check-in.' ;
    rdfs:domain ind:TerminalFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slotCoordinatedFlag rdf:type rdf:Property ;
    rdfs:label 'Slot Coordinated Flag' ;
    rdfs:comment 'Indicates whether the airport requires slot coordination (allocated takeoff and landing times) due to capacity constraints.' ;
    rdfs:domain ind:Airport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:terminalAreaSqm rdf:type rdf:Property ;
    rdfs:label 'Terminal Area Sqm' ;
    rdfs:comment 'Total floor area of the terminal facility measured in square meters.' ;
    rdfs:domain ind:TerminalFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:terminalIdentifier rdf:type rdf:Property ;
    rdfs:label 'Terminal Identifier' ;
    rdfs:comment 'Business identifier for the terminal within the airport (e.g., Terminal 1, Terminal A, Concourse B, Satellite Terminal).' ;
    rdfs:domain ind:TerminalFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalGateCount rdf:type rdf:Property ;
    rdfs:label 'Total Gate Count' ;
    rdfs:comment 'Total number of aircraft gates available in this terminal facility for passenger boarding and deplaning operations.' ;
    rdfs:domain ind:TerminalFacility ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:aircraftSizeCodeMax rdf:type rdf:Property ;
    rdfs:label 'Aircraft Size Code Max' ;
    rdfs:comment 'Maximum ICAO aircraft size code (A through F) that this gate can accommodate based on wingspan, parking envelope, and structural limitations.' ;
    rdfs:domain ind:Gate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aircraftSizeCodeMin rdf:type rdf:Property ;
    rdfs:label 'Aircraft Size Code Min' ;
    rdfs:comment 'Minimum ICAO aircraft size code (A through F) that this gate can accommodate based on wingspan and parking envelope.' ;
    rdfs:domain ind:Gate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commonUseGate rdf:type rdf:Property ;
    rdfs:label 'Common Use Gate' ;
    rdfs:comment 'Indicates whether this gate is operated as a common-use facility available to multiple airlines through dynamic assignment, or is dedicated to a specific carrier.' ;
    rdfs:domain ind:Gate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:concourse rdf:type rdf:Property ;
    rdfs:label 'Concourse' ;
    rdfs:comment 'The concourse or pier designation within the terminal (e.g., A, B, C, D, International).' ;
    rdfs:domain ind:Gate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsFacility rdf:type rdf:Property ;
    rdfs:label 'Customs Facility' ;
    rdfs:comment 'Indicates whether this gate has direct access to customs and immigration facilities for international arrivals processing.' ;
    rdfs:domain ind:Gate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:domesticCapable rdf:type rdf:Property ;
    rdfs:label 'Domestic Capable' ;
    rdfs:comment 'Indicates whether this gate is equipped and authorized to handle domestic flights.' ;
    rdfs:domain ind:Gate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fuelHydrantAvailable rdf:type rdf:Property ;
    rdfs:label 'Fuel Hydrant Available' ;
    rdfs:comment 'Indicates whether underground fuel hydrant system is available at this gate position for aircraft refueling operations.' ;
    rdfs:domain ind:Gate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gateNumber rdf:type rdf:Property ;
    rdfs:label 'Gate Number' ;
    rdfs:comment 'The alphanumeric gate identifier displayed to passengers and used in operational systems (e.g., A12, B5, C23).' ;
    rdfs:domain ind:Gate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateType rdf:type rdf:Property ;
    rdfs:label 'Gate Type' ;
    rdfs:comment 'Classification of gate based on aircraft parking configuration: contact (jetbridge-connected), remote (apron position requiring bus), hardstand (unpaved remote stand), bus_gate (passenger bus boarding point), swing_gate (can serve domestic or international).' ;
    rdfs:domain ind:Airport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groundPowerUnitAvailable rdf:type rdf:Property ;
    rdfs:label 'Ground Power Unit Available' ;
    rdfs:comment 'Indicates whether fixed ground power unit (GPU) electrical supply is available at this gate for aircraft systems during turnaround.' ;
    rdfs:domain ind:Gate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:internationalCapable rdf:type rdf:Property ;
    rdfs:label 'International Capable' ;
    rdfs:comment 'Indicates whether this gate is equipped and authorized to handle international flights with customs, immigration, and border control requirements.' ;
    rdfs:domain ind:Gate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jetbridgeAvailable rdf:type rdf:Property ;
    rdfs:label 'Jetbridge Available' ;
    rdfs:comment 'Indicates whether a passenger boarding bridge (jetbridge/airbridge) is installed and operational at this gate.' ;
    rdfs:domain ind:Gate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jetbridgeCount rdf:type rdf:Property ;
    rdfs:label 'Jetbridge Count' ;
    rdfs:comment 'Number of passenger boarding bridges available at this gate (0 for remote stands, 1-3 for contact gates serving wide-body aircraft).' ;
    rdfs:domain ind:Gate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxAircraftLengthMeters rdf:type rdf:Property ;
    rdfs:label 'Max Aircraft Length Meters' ;
    rdfs:comment 'Maximum aircraft fuselage length in meters that can be accommodated at this gate position.' ;
    rdfs:domain ind:Gate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxWingspanMeters rdf:type rdf:Property ;
    rdfs:label 'Max Wingspan Meters' ;
    rdfs:comment 'Maximum aircraft wingspan in meters that can be safely accommodated at this gate position.' ;
    rdfs:domain ind:Gate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumTurnaroundTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Minimum Turnaround Time Minutes' ;
    rdfs:comment 'Minimum aircraft turnaround time in minutes required at this gate based on facility capabilities and Ground Support Equipment (GSE) availability.' ;
    rdfs:domain ind:Gate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:narrowBodyCapable rdf:type rdf:Property ;
    rdfs:label 'Narrow Body Capable' ;
    rdfs:comment 'Indicates whether this gate can accommodate narrow-body aircraft (typically ICAO codes B, C such as A320 family, B737 family).' ;
    rdfs:domain ind:Gate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:parkingStandDesignation rdf:type rdf:Property ;
    rdfs:label 'Parking Stand Designation' ;
    rdfs:comment 'The official apron parking stand identifier used in airport operations and ATC communications (may differ from passenger-facing gate number).' ;
    rdfs:domain ind:Gate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:potableWaterAvailable rdf:type rdf:Property ;
    rdfs:label 'Potable Water Available' ;
    rdfs:comment 'Indicates whether fixed potable water supply connection is available at this gate for aircraft water system servicing.' ;
    rdfs:domain ind:Gate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preconditionedAirAvailable rdf:type rdf:Property ;
    rdfs:label 'Preconditioned Air Available' ;
    rdfs:comment 'Indicates whether fixed preconditioned air system is available at this gate for aircraft cabin climate control during turnaround, reducing APU usage.' ;
    rdfs:domain ind:Gate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regionalJetCapable rdf:type rdf:Property ;
    rdfs:label 'Regional Jet Capable' ;
    rdfs:comment 'Indicates whether this gate can accommodate regional jet aircraft (typically ICAO code A such as CRJ, ERJ families).' ;
    rdfs:domain ind:Gate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:schengenCapable rdf:type rdf:Property ;
    rdfs:label 'Schengen Capable' ;
    rdfs:comment 'Indicates whether this gate can handle flights within the Schengen Area (European airports only) without passport control requirements.' ;
    rdfs:domain ind:Gate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:wideBodyCapable rdf:type rdf:Property ;
    rdfs:label 'Wide Body Capable' ;
    rdfs:comment 'Indicates whether this gate can accommodate wide-body aircraft (typically ICAO codes D, E, F such as B777, B787, A330, A350, A380).' ;
    rdfs:domain ind:Gate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:actualGateInTime rdf:type rdf:Property ;
    rdfs:label 'Actual Gate In Time' ;
    rdfs:comment 'Actual timestamp when aircraft arrived at gate and set parking brake (Actual On-block from OOOI). Captured via ACARS or manual entry. Critical for OTP calculation and turnaround tracking.' ;
    rdfs:domain ind:GateAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualGateOutTime rdf:type rdf:Property ;
    rdfs:label 'Actual Gate Out Time' ;
    rdfs:comment 'Actual timestamp when aircraft pushed back from gate and released parking brake (Actual Off-block from OOOI). Captured via ACARS or manual entry. Marks gate release and availability for next assignment.' ;
    rdfs:domain ind:GateAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assignmentEndTime rdf:type rdf:Property ;
    rdfs:label 'Assignment End Time' ;
    rdfs:comment 'Timestamp when the gate reservation expires and becomes available for next assignment, typically includes buffer after scheduled gate-out for cleanup and turnaround completion.' ;
    rdfs:domain ind:GateAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assignmentSource rdf:type rdf:Property ;
    rdfs:label 'Assignment Source' ;
    rdfs:comment 'Origin of the gate assignment decision. CDM: Collaborative Decision Making system; Manual: dispatcher override; Auto-assign: automated allocation; Rescheduled: changed from original; IROP: irregular operations reassignment.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignmentStartTime rdf:type rdf:Property ;
    rdfs:label 'Assignment Start Time' ;
    rdfs:comment 'Timestamp when the gate was reserved for this flight, typically earlier than scheduled gate-in to allow for ground equipment setup and early arrival buffer.' ;
    rdfs:domain ind:GateAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cdmMilestoneStatus rdf:type rdf:Property ;
    rdfs:label 'Cdm Milestone Status' ;
    rdfs:comment 'Current CDM milestone achieved for this gate assignment. TOBT: Target Off-Block Time set; TSAT: Target Start-Up Approval Time issued; AOBT: Actual Off-Block Time; AIBT: Actual In-Block Time; ALDT: Actual Landing Time.' ;
    rdfs:domain ind:Airport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conflictFlag rdf:type rdf:Property ;
    rdfs:label 'Conflict Flag' ;
    rdfs:comment 'Indicates whether this gate assignment has a scheduling conflict with another assignment (overlapping time windows). True when conflict detected; requires resolution by operations.' ;
    rdfs:domain ind:GateAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:conflictResolutionNotes rdf:type rdf:Property ;
    rdfs:label 'Conflict Resolution Notes' ;
    rdfs:comment 'Free-text notes documenting how a gate assignment conflict was resolved, including dispatcher actions, alternative gate assignments, or operational adjustments made.' ;
    rdfs:domain ind:GateAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:domesticInternationalFlag rdf:type rdf:Property ;
    rdfs:label 'Domestic International Flag' ;
    rdfs:comment 'Indicates whether the flight assigned to this gate is domestic or international. Schengen applies to intra-European flights with no border control. Determines gate area assignment and customs/immigration requirements.' ;
    rdfs:domain ind:GateAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gateHoldReason rdf:type rdf:Property ;
    rdfs:label 'Gate Hold Reason' ;
    rdfs:comment 'Free-text explanation for any gate hold or delay in releasing the gate assignment. Documents operational reasons such as late arriving aircraft, maintenance issues, or ATC delays.' ;
    rdfs:domain ind:GateAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groundPowerAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Ground Power Available Flag' ;
    rdfs:comment 'Indicates whether ground power unit (GPU) is available at this gate for this assignment. Required for aircraft electrical power during turnaround when APU is shut down.' ;
    rdfs:domain ind:GateAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hubSpokeIndicator rdf:type rdf:Property ;
    rdfs:label 'Hub Spoke Indicator' ;
    rdfs:comment 'Classification of airport operational role in airline network. Hub: major connecting airport; Spoke: destination from hub; Focus city: secondary hub; Outstation: remote station with limited operations.' ;
    rdfs:domain ind:GateAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jetBridgeAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Jet Bridge Available Flag' ;
    rdfs:comment 'Indicates whether a jet bridge (passenger boarding bridge) is available and operational at this gate for this assignment. Critical for passenger boarding operations and accessibility requirements.' ;
    rdfs:domain ind:GateAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:passengerFacilityChargeApplicableFlag rdf:type rdf:Property ;
    rdfs:label 'Passenger Facility Charge Applicable Flag' ;
    rdfs:comment 'Indicates whether Passenger Facility Charge applies to this gate assignment based on airport authority regulations. Used for financial settlement and regulatory reporting to DOT.' ;
    rdfs:domain ind:GateAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:preconditionedAirAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Preconditioned Air Available Flag' ;
    rdfs:comment 'Indicates whether preconditioned air (PCA) system is available at this gate for cabin climate control during turnaround. Reduces APU usage and fuel burn.' ;
    rdfs:domain ind:GateAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorityOverrideFlag rdf:type rdf:Property ;
    rdfs:label 'Priority Override Flag' ;
    rdfs:comment 'Indicates whether this assignment received priority treatment overriding normal allocation rules. True for VIP flights, IROP recovery, or operational priority situations.' ;
    rdfs:domain ind:GateAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:priorityOverrideReason rdf:type rdf:Property ;
    rdfs:label 'Priority Override Reason' ;
    rdfs:comment 'Business reason for priority override of normal gate assignment rules. Documents justification for preferential gate allocation outside standard procedures. [ENUM-REF-CANDIDATE: vip_flight|irop_recovery|maintenance_priority|diplomatic|medical_emergency|operational_necessity|none — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:GateAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledGateInTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Gate In Time' ;
    rdfs:comment 'Planned timestamp when aircraft is scheduled to arrive at the gate and set parking brake (On-block time from OOOI). Used for gate allocation planning and OTP reporting.' ;
    rdfs:domain ind:GateAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledGateOutTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Gate Out Time' ;
    rdfs:comment 'Planned timestamp when aircraft is scheduled to push back from gate and release parking brake (Off-block time from OOOI). Used for gate release planning and next assignment scheduling.' ;
    rdfs:domain ind:GateAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:slotCoordinationRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Slot Coordination Required Flag' ;
    rdfs:comment 'Indicates whether this gate assignment requires coordination with airport slot allocation due to capacity constraints at slot-controlled airport. True for Level 3 coordinated airports.' ;
    rdfs:domain ind:GateAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:specialHandlingCode rdf:type rdf:Property ;
    rdfs:label 'Special Handling Code' ;
    rdfs:comment 'Special Service Request code indicating special handling requirements for this gate assignment (e.g., WCHR for wheelchair, DEPA for deportee, MEDA for medical). Drives ground service and security coordination.' ;
    rdfs:domain ind:GateAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standCompatibilityCode rdf:type rdf:Property ;
    rdfs:label 'Stand Compatibility Code' ;
    rdfs:comment 'ICAO aerodrome reference code indicating maximum aircraft size the gate can accommodate (A through F). Ensures aircraft-gate physical compatibility for safe operations.' ;
    rdfs:domain ind:GateAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:turnaroundDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Turnaround Duration Minutes' ;
    rdfs:comment 'Planned duration in minutes for aircraft turnaround at the gate, from gate-in to gate-out. Varies by aircraft type, service level, and operational requirements.' ;
    rdfs:domain ind:GateAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:turnaroundInboundFlightLegId rdf:type rdf:Property ;
    rdfs:label 'Turnaround Inbound Flight Leg Id' ;
    rdfs:comment 'Reference to the arriving flight leg that initiates this turnaround event.' ;
    rdfs:domain ind:Turnaround ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FlightLeg .

ind:turnaroundOutboundFlightLegId rdf:type rdf:Property ;
    rdfs:label 'Turnaround Outbound Flight Leg Id' ;
    rdfs:comment 'Reference to the departing flight leg that concludes this turnaround event.' ;
    rdfs:domain ind:Turnaround ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FlightLeg .

ind:actualBlockInTime rdf:type rdf:Property ;
    rdfs:label 'Actual Block In Time' ;
    rdfs:comment 'Actual timestamp when the inbound aircraft arrived at the gate and parking brake was set (OOOI - On event).' ;
    rdfs:domain ind:Turnaround ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualBlockOutTime rdf:type rdf:Property ;
    rdfs:label 'Actual Block Out Time' ;
    rdfs:comment 'Actual timestamp when the outbound aircraft pushed back from the gate and began taxi (OOOI - Off event).' ;
    rdfs:domain ind:Turnaround ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualTurnaroundTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Actual Turnaround Time Minutes' ;
    rdfs:comment 'Actual duration in minutes from block-in to block-out. Calculated as the difference between actual_block_out_time and actual_block_in_time.' ;
    rdfs:domain ind:Turnaround ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:allServicesCompletedFlag rdf:type rdf:Property ;
    rdfs:label 'All Services Completed Flag' ;
    rdfs:comment 'Indicates whether all ordered ground services have been completed and signed off. True when turnaround is ready for departure.' ;
    rdfs:domain ind:Turnaround ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:baggagePiecesLoaded rdf:type rdf:Property ;
    rdfs:label 'Baggage Pieces Loaded' ;
    rdfs:comment 'Total number of baggage pieces loaded onto the outbound flight during turnaround.' ;
    rdfs:domain ind:Turnaround ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:baggagePiecesOffloaded rdf:type rdf:Property ;
    rdfs:label 'Baggage Pieces Offloaded' ;
    rdfs:comment 'Total number of baggage pieces offloaded from the inbound flight during turnaround.' ;
    rdfs:domain ind:Turnaround ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cargoWeightLoadedKg rdf:type rdf:Property ;
    rdfs:label 'Cargo Weight Loaded Kg' ;
    rdfs:comment 'Total weight in kilograms of cargo and mail loaded onto the outbound flight.' ;
    rdfs:domain ind:Turnaround ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cargoWeightOffloadedKg rdf:type rdf:Property ;
    rdfs:label 'Cargo Weight Offloaded Kg' ;
    rdfs:comment 'Total weight in kilograms of cargo and mail offloaded from the inbound flight.' ;
    rdfs:domain ind:Turnaround ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deviationNotes rdf:type rdf:Property ;
    rdfs:label 'Deviation Notes' ;
    rdfs:comment 'Free-text description of any deviations from standard turnaround procedures, service failures, or operational irregularities encountered.' ;
    rdfs:domain ind:Turnaround ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:groundSupportEquipmentAssigned rdf:type rdf:Property ;
    rdfs:label 'Ground Support Equipment Assigned' ;
    rdfs:comment 'Comma-separated list of GSE unit identifiers assigned to this turnaround (e.g., GPU-123, belt loader-456, tug-789).' ;
    rdfs:domain ind:Turnaround ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handlerInstructions rdf:type rdf:Property ;
    rdfs:label 'Handler Instructions' ;
    rdfs:comment 'Special instructions or notes for the ground handler regarding this specific turnaround (e.g., VIP passenger, special cargo, MEL items, security requirements).' ;
    rdfs:domain ind:Turnaround ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:otpImpactFlag rdf:type rdf:Property ;
    rdfs:label 'Otp Impact Flag' ;
    rdfs:comment 'Indicates whether this turnaround contributed to an on-time performance failure (departure delay >15 minutes). Used for OTP root-cause analysis.' ;
    rdfs:domain ind:Turnaround ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:passengerCountBoarded rdf:type rdf:Property ;
    rdfs:label 'Passenger Count Boarded' ;
    rdfs:comment 'Number of passengers who boarded the outbound flight during this turnaround.' ;
    rdfs:domain ind:Turnaround ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:passengerCountDeplaned rdf:type rdf:Property ;
    rdfs:label 'Passenger Count Deplaned' ;
    rdfs:comment 'Number of passengers who deplaned from the inbound flight during this turnaround.' ;
    rdfs:domain ind:Turnaround ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rampServiceOrderNumber rdf:type rdf:Property ;
    rdfs:label 'Ramp Service Order Number' ;
    rdfs:comment 'Unique identifier for the ramp service order that defines all ground services to be performed during this turnaround.' ;
    rdfs:domain ind:Turnaround ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduledBlockInTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Block In Time' ;
    rdfs:comment 'Planned timestamp when the inbound aircraft is scheduled to arrive at the gate (OOOI - On event).' ;
    rdfs:domain ind:Turnaround ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledBlockOutTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Block Out Time' ;
    rdfs:comment 'Planned timestamp when the outbound aircraft is scheduled to push back from the gate (OOOI - Off event).' ;
    rdfs:domain ind:Turnaround ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:serviceWindowEndTime rdf:type rdf:Property ;
    rdfs:label 'Service Window End Time' ;
    rdfs:comment 'Latest timestamp by which all ground service operations must be completed to meet scheduled block-out time.' ;
    rdfs:domain ind:Turnaround ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:serviceWindowStartTime rdf:type rdf:Property ;
    rdfs:label 'Service Window Start Time' ;
    rdfs:comment 'Earliest timestamp when ground service operations can commence, typically shortly after block-in.' ;
    rdfs:domain ind:Turnaround ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:servicesCompletionTime rdf:type rdf:Property ;
    rdfs:label 'Services Completion Time' ;
    rdfs:comment 'Timestamp when all ground services were completed and aircraft was declared ready for departure.' ;
    rdfs:domain ind:Turnaround ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:servicesOrdered rdf:type rdf:Property ;
    rdfs:label 'Services Ordered' ;
    rdfs:comment 'Comma-separated list of ground services ordered for this turnaround (e.g., fueling, catering, cleaning, water service, lavatory service, GPU, air start, deicing, baggage handling, cargo loading).' ;
    rdfs:domain ind:Turnaround ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetTurnaroundTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Target Turnaround Time Minutes' ;
    rdfs:comment 'Planned duration in minutes for the complete turnaround cycle from block-in to block-out, based on aircraft type and turnaround type.' ;
    rdfs:domain ind:Turnaround ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:turnaroundStatus rdf:type rdf:Property ;
    rdfs:label 'Turnaround Status' ;
    rdfs:comment 'Current operational status of the turnaround event. Tracks lifecycle from scheduled through completion or cancellation.' ;
    rdfs:domain ind:Turnaround ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:turnaroundType rdf:type rdf:Property ;
    rdfs:label 'Turnaround Type' ;
    rdfs:comment 'Classification of turnaround based on duration and service scope. Standard (60-90 min), quick (<45 min), overnight (>8 hours), transit (international connection), maintenance (scheduled service), extended (unplanned delay).' ;
    rdfs:domain ind:Turnaround ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:turnaroundTaskId rdf:type rdf:Property ;
    rdfs:label 'Turnaround Task Id' ;
    rdfs:comment 'Unique identifier for the individual ground servicing task within a turnaround event. Primary key.' ;
    rdfs:domain ind:TurnaroundTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualEndTime rdf:type rdf:Property ;
    rdfs:label 'Actual End Time' ;
    rdfs:comment 'Actual timestamp when the ground servicing task was completed. Used for SLA compliance measurement and operational efficiency analysis.' ;
    rdfs:domain ind:TurnaroundTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualStartTime rdf:type rdf:Property ;
    rdfs:label 'Actual Start Time' ;
    rdfs:comment 'Actual timestamp when the ground servicing task commenced. Used for performance measurement and delay analysis.' ;
    rdfs:domain ind:TurnaroundTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:completionNotes rdf:type rdf:Property ;
    rdfs:label 'Completion Notes' ;
    rdfs:comment 'Free-text notes or comments recorded by the service provider upon task completion, including any exceptions, observations, or special circumstances.' ;
    rdfs:domain ind:TurnaroundTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costAmount rdf:type rdf:Property ;
    rdfs:label 'Cost Amount' ;
    rdfs:comment 'Direct cost incurred for this ground servicing task, including labor, equipment, and materials. Used for turnaround cost analysis and vendor billing.' ;
    rdfs:domain ind:TurnaroundTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gateStandPosition rdf:type rdf:Property ;
    rdfs:label 'Gate Stand Position' ;
    rdfs:comment 'Specific gate or stand position identifier where the aircraft is parked and this task is being performed.' ;
    rdfs:domain ind:TurnaroundTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gseDefectDescription rdf:type rdf:Property ;
    rdfs:label 'Gse Defect Description' ;
    rdfs:comment 'Textual description of any GSE defect, malfunction, or maintenance issue observed during task execution. Populated when defect flag is true.' ;
    rdfs:domain ind:TurnaroundTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gseDefectNotedFlag rdf:type rdf:Property ;
    rdfs:label 'Gse Defect Noted Flag' ;
    rdfs:comment 'Boolean indicator whether any equipment defect or malfunction was noted during this task. Triggers maintenance follow-up.' ;
    rdfs:domain ind:TurnaroundTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:gseDeploymentEndTime rdf:type rdf:Property ;
    rdfs:label 'Gse Deployment End Time' ;
    rdfs:comment 'Timestamp when the GSE asset was released from this task and became available for other operations. Used for GSE utilization optimization.' ;
    rdfs:domain ind:TurnaroundTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:gseDeploymentStartTime rdf:type rdf:Property ;
    rdfs:label 'Gse Deployment Start Time' ;
    rdfs:comment 'Timestamp when the GSE asset was deployed and positioned for this task. Used for GSE utilization tracking and availability management.' ;
    rdfs:domain ind:TurnaroundTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:gseFuelConsumedLiters rdf:type rdf:Property ;
    rdfs:label 'Gse Fuel Consumed Liters' ;
    rdfs:comment 'Volume of fuel consumed by the GSE asset during this task deployment, measured in liters. Used for environmental reporting and cost allocation.' ;
    rdfs:domain ind:TurnaroundTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedEndTime rdf:type rdf:Property ;
    rdfs:label 'Planned End Time' ;
    rdfs:comment 'Scheduled timestamp when the ground servicing task is planned to be completed, based on standard service times and turnaround requirements.' ;
    rdfs:domain ind:TurnaroundTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedStartTime rdf:type rdf:Property ;
    rdfs:label 'Planned Start Time' ;
    rdfs:comment 'Scheduled timestamp when the ground servicing task is planned to begin, based on the turnaround schedule and task dependencies.' ;
    rdfs:domain ind:TurnaroundTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:qualityCheckPerformedFlag rdf:type rdf:Property ;
    rdfs:label 'Quality Check Performed Flag' ;
    rdfs:comment 'Boolean indicator whether a quality inspection or verification check was performed for this task. Used for quality assurance and safety compliance.' ;
    rdfs:domain ind:TurnaroundTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualityCheckResult rdf:type rdf:Property ;
    rdfs:label 'Quality Check Result' ;
    rdfs:comment 'Result of the quality inspection or verification check, if performed. Used for quality assurance tracking and corrective action triggering.' ;
    rdfs:domain ind:TurnaroundTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityDelivered rdf:type rdf:Property ;
    rdfs:label 'Quantity Delivered' ;
    rdfs:comment 'Numeric quantity of service delivered or resource provided during this task (e.g., liters of fuel, kilograms of cargo, number of meals, gallons of water). Unit depends on task type.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:safetyIncidentFlag rdf:type rdf:Property ;
    rdfs:label 'Safety Incident Flag' ;
    rdfs:comment 'Boolean indicator whether any safety incident, near-miss, or hazard was reported during this task execution. Triggers safety investigation and SMS reporting.' ;
    rdfs:domain ind:TurnaroundTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sequenceOrder rdf:type rdf:Property ;
    rdfs:label 'Sequence Order' ;
    rdfs:comment 'Numeric order indicating the planned sequence of this task within the turnaround event. Used to coordinate dependencies and parallel operations during aircraft servicing.' ;
    rdfs:domain ind:TurnaroundTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Compliance Flag' ;
    rdfs:comment 'Boolean indicator whether the task was completed within the SLA target duration. Used for service provider performance measurement.' ;
    rdfs:domain ind:TurnaroundTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:slaTargetDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Sla Target Duration Minutes' ;
    rdfs:comment 'Contractual service level agreement target duration for this task type, measured in minutes. Used for performance benchmarking and vendor compliance.' ;
    rdfs:domain ind:TurnaroundTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:taskTypeCode rdf:type rdf:Property ;
    rdfs:label 'Task Type Code' ;
    rdfs:comment 'Code representing the type of ground servicing task being performed. Examples include fueling, catering, cleaning, water service, lavatory service, de-icing, cargo loading/unloading, passenger boarding/deplaning, pushback, ground power unit (GPU), air start unit (ASU), potable water, waste removal, cabin preparation, security check, or pre-flight inspection. [ENUM-REF-CANDIDATE: FUEL|CATER|CLEAN|WATER|LAV|DEICE|CARGO_LOAD|CARGO_UNLOAD|PAX_BOARD|PAX_DEPLANE|PUSHBACK|GPU|ASU|POTABLE|WASTE|CABIN_PREP|SECURITY|INSPECTION — 18 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TurnaroundTask ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualFlightReference rdf:type rdf:Property ;
    rdfs:label 'Actual Flight Reference' ;
    rdfs:comment 'Reference to the actual flight that operated using this slot, typically the flight leg identifier or operational flight number. Used for post-operation reconciliation and compliance tracking. Null if slot was not used.' ;
    rdfs:domain ind:Slot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualOperationDate rdf:type rdf:Property ;
    rdfs:label 'Actual Operation Date' ;
    rdfs:comment 'The specific date on which this slot was actually used for a flight operation. Populated post-operation for utilization tracking. Null if not yet operated or if slot was not used.' ;
    rdfs:domain ind:Slot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualOperationTime rdf:type rdf:Property ;
    rdfs:label 'Actual Operation Time' ;
    rdfs:comment 'The actual timestamp when the flight operation occurred (actual takeoff time for departure slots, actual landing time for arrival slots). Used to calculate variance from allocated time. Null if not yet operated.' ;
    rdfs:domain ind:Slot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:airlineDesignator rdf:type rdf:Property ;
    rdfs:label 'Airline Designator' ;
    rdfs:comment 'Two or three-character IATA airline code of the carrier to whom this slot is allocated (e.g., BA, AA, LH).' ;
    rdfs:domain ind:Slot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allocationDate rdf:type rdf:Property ;
    rdfs:label 'Allocation Date' ;
    rdfs:comment 'Date when this slot was initially allocated to the airline by the slot coordinator.' ;
    rdfs:domain ind:Slot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cdmMessageReference rdf:type rdf:Property ;
    rdfs:label 'Cdm Message Reference' ;
    rdfs:comment 'Reference identifier for Airport Collaborative Decision Making (A-CDM) messages related to this slot, used for real-time coordination between airline, airport, ATC, and ground handlers. Aligns with SITA Airport Management Platform.' ;
    rdfs:domain ind:Slot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:confirmationDate rdf:type rdf:Property ;
    rdfs:label 'Confirmation Date' ;
    rdfs:comment 'Date when the airline confirmed intention to use this slot. Null if not yet confirmed.' ;
    rdfs:domain ind:Slot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:coordinatorReference rdf:type rdf:Property ;
    rdfs:label 'Coordinator Reference' ;
    rdfs:comment 'Reference number or identifier assigned by the airport slot coordinator (e.g., Airport Coordination Limited, Flughafen-Koordinierung Deutschland) for tracking and correspondence.' ;
    rdfs:domain ind:Slot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:historicPrecedenceFlag rdf:type rdf:Property ;
    rdfs:label 'Historic Precedence Flag' ;
    rdfs:comment 'Indicates whether this slot carries historic precedence (grandfather rights) under IATA 80/20 rule, meaning the airline used the slot at least 80% of the time in the previous equivalent season and has priority for renewal.' ;
    rdfs:domain ind:Slot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:justificationCategory rdf:type rdf:Property ;
    rdfs:label 'Justification Category' ;
    rdfs:comment 'Categorized reason for non-compliance or slot misuse. Weather: meteorological conditions; ATC delay: air traffic control restrictions; Technical: aircraft maintenance or defect; Operational: crew, ground handling, or airport issues; Commercial: passenger or cargo demand changes; Other: miscellaneous.' ;
    rdfs:domain ind:Slot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonComplianceReason rdf:type rdf:Property ;
    rdfs:label 'Non Compliance Reason' ;
    rdfs:comment 'Free-text explanation for why a slot was missed or operated outside tolerance. May reference weather, Air Traffic Control (ATC) delays, technical issues, or other justifiable causes. Used for regulatory reporting and historic precedence calculations.' ;
    rdfs:domain ind:Slot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:poolCategory rdf:type rdf:Property ;
    rdfs:label 'Pool Category' ;
    rdfs:comment 'Classification of the slot pool from which this slot was allocated. New entrant: reserved for new carriers; Domestic: domestic operations; International: international operations; General: unrestricted pool. Used for regulatory compliance and fair competition monitoring.' ;
    rdfs:domain ind:Slot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Regulatory Reporting Flag' ;
    rdfs:comment 'Indicates whether this slot record must be included in regulatory compliance reports to aviation authorities (e.g., for 80/20 rule enforcement, slot pool management, or competition monitoring). True if reporting required.' ;
    rdfs:domain ind:Airport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:series rdf:type rdf:Property ;
    rdfs:label 'Series' ;
    rdfs:comment 'Indicates whether this is a regular series slot (recurring throughout the season) or an ad-hoc slot (one-time or irregular operation).' ;
    rdfs:domain ind:Slot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seriesIdentifier rdf:type rdf:Property ;
    rdfs:label 'Series Identifier' ;
    rdfs:comment 'Unique identifier linking this slot to a series of recurring slots. Populated for regular series slots; null for ad-hoc slots.' ;
    rdfs:domain ind:Slot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:swapDate rdf:type rdf:Property ;
    rdfs:label 'Swap Date' ;
    rdfs:comment 'Date when the slot swap transaction was executed and recorded with the slot coordinator. Null if no swap occurred.' ;
    rdfs:domain ind:Slot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:swapPartnerAirline rdf:type rdf:Property ;
    rdfs:label 'Swap Partner Airline' ;
    rdfs:comment 'IATA airline code of the carrier with whom this slot was swapped, if applicable. Null if no swap occurred.' ;
    rdfs:domain ind:Slot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeVarianceMinutes rdf:type rdf:Property ;
    rdfs:label 'Time Variance Minutes' ;
    rdfs:comment 'Difference in minutes between allocated slot time and actual operation time. Positive values indicate late operation, negative values indicate early operation. Used for compliance monitoring against tolerance thresholds (typically +/- 5 or 15 minutes depending on airport rules).' ;
    rdfs:domain ind:Slot ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slotUtilizationId rdf:type rdf:Property ;
    rdfs:label 'Slot Utilization Id' ;
    rdfs:comment 'Unique identifier for the slot utilization transaction record.' ;
    rdfs:domain ind:SlotUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:arrivalVarianceMinutes rdf:type rdf:Property ;
    rdfs:label 'Arrival Variance Minutes' ;
    rdfs:comment 'The difference in minutes between planned and actual arrival time, calculated as actual minus planned. Positive values indicate delay, negative values indicate early arrival.' ;
    rdfs:domain ind:SlotUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cdmMessageTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cdm Message Timestamp' ;
    rdfs:comment 'Timestamp of the Airport CDM message that confirmed the actual slot utilization, typically sourced from SITA Airport Management Platform or equivalent CDM system.' ;
    rdfs:domain ind:SlotUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:departureVarianceMinutes rdf:type rdf:Property ;
    rdfs:label 'Departure Variance Minutes' ;
    rdfs:comment 'The difference in minutes between planned and actual departure time, calculated as actual minus planned. Positive values indicate delay, negative values indicate early departure.' ;
    rdfs:domain ind:SlotUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:historicRightsProtectedFlag rdf:type rdf:Property ;
    rdfs:label 'Historic Rights Protected Flag' ;
    rdfs:comment 'Indicator of whether this slot utilization contributes to the airline\'s historic rights (grandfather rights) for future season slot allocation under the 80/20 use-it-or-lose-it rule.' ;
    rdfs:domain ind:SlotUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nonComplianceReasonCode rdf:type rdf:Property ;
    rdfs:label 'Non Compliance Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for slot non-compliance or variance, such as weather delay, technical issue, air traffic control restriction, or operational irregularity.' ;
    rdfs:domain ind:SlotUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nonComplianceReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Non Compliance Reason Description' ;
    rdfs:comment 'Detailed narrative explanation of the circumstances that led to slot non-compliance or significant variance from the allocated time.' ;
    rdfs:domain ind:SlotUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatedDate rdf:type rdf:Property ;
    rdfs:label 'Operated Date' ;
    rdfs:comment 'The calendar date on which the slot was actually utilized by the flight operation.' ;
    rdfs:domain ind:SlotUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:plannedArrivalTime rdf:type rdf:Property ;
    rdfs:label 'Planned Arrival Time' ;
    rdfs:comment 'The scheduled arrival time as allocated in the original slot assignment.' ;
    rdfs:domain ind:SlotUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:plannedDepartureTime rdf:type rdf:Property ;
    rdfs:label 'Planned Departure Time' ;
    rdfs:comment 'The scheduled departure time as allocated in the original slot assignment.' ;
    rdfs:domain ind:SlotUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:slotCoordinatorCode rdf:type rdf:Property ;
    rdfs:label 'Slot Coordinator Code' ;
    rdfs:comment 'Three-letter IATA airport code identifying the slot coordination authority responsible for this slot allocation.' ;
    rdfs:domain ind:Airport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slotReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Slot Reference Number' ;
    rdfs:comment 'External business identifier for the slot allocation as issued by the slot coordinator.' ;
    rdfs:domain ind:SlotUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slotSeriesIndicator rdf:type rdf:Property ;
    rdfs:label 'Slot Series Indicator' ;
    rdfs:comment 'Classification indicating whether this slot utilization is part of a recurring series allocation or an ad-hoc one-time slot request.' ;
    rdfs:domain ind:SlotUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:swapTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Swap Transaction Reference' ;
    rdfs:comment 'Reference to the slot swap transaction record if this slot utilization resulted from a slot exchange agreement between carriers.' ;
    rdfs:domain ind:SlotUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:utilizationRecordedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Utilization Recorded Timestamp' ;
    rdfs:comment 'System timestamp when this slot utilization record was first captured in the airport operations system.' ;
    rdfs:domain ind:SlotUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:advanceCheckinFlag rdf:type rdf:Property ;
    rdfs:label 'Advance Checkin Flag' ;
    rdfs:comment 'Indicates whether the passenger checked in more than 24 hours before scheduled departure (advance/online check-in). True if advance check-in.' ;
    rdfs:domain ind:CheckinSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:apisDataTransmittedFlag rdf:type rdf:Property ;
    rdfs:label 'Apis Data Transmitted Flag' ;
    rdfs:comment 'Indicates whether APIS data (passport, nationality, date of birth) was transmitted to destination authorities during check-in. True if APIS transmitted.' ;
    rdfs:domain ind:CheckinSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:bagsCheckedCount rdf:type rdf:Property ;
    rdfs:label 'Bags Checked Count' ;
    rdfs:comment 'Number of checked baggage pieces accepted during this check-in session.' ;
    rdfs:domain ind:CheckinSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:boardingPassBarcode rdf:type rdf:Property ;
    rdfs:label 'Boarding Pass Barcode' ;
    rdfs:comment 'Unique barcode or QR code string printed on the boarding pass. Used for boarding gate scanning. Contains PNR, flight, and passenger data encoded per IATA standards.' ;
    rdfs:domain ind:Airport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boardingPassIssuanceMethod rdf:type rdf:Property ;
    rdfs:label 'Boarding Pass Issuance Method' ;
    rdfs:comment 'Method by which the boarding pass was delivered to the passenger. Paper = printed at counter, mobile = mobile app barcode, email = emailed PDF, SMS = SMS link, kiosk_print = printed at kiosk.' ;
    rdfs:domain ind:CheckinSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkinChannel rdf:type rdf:Property ;
    rdfs:label 'Checkin Channel' ;
    rdfs:comment 'Channel through which the passenger initiated check-in. Counter = airport counter, kiosk = self-service kiosk, CUSS = Common Use Self-Service, web = online web check-in, mobile = mobile app check-in, agent_assisted = call center or remote agent.' ;
    rdfs:domain ind:CheckinSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkinEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Checkin End Timestamp' ;
    rdfs:comment 'Timestamp when the check-in session was completed and boarding pass issued. Recorded in UTC.' ;
    rdfs:domain ind:CheckinSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:checkinLanguageCode rdf:type rdf:Property ;
    rdfs:label 'Checkin Language Code' ;
    rdfs:comment 'Two-letter ISO 639-1 language code indicating the language used during the check-in session (e.g., en, es, fr).' ;
    rdfs:domain ind:CheckinSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkinSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Checkin Sequence Number' ;
    rdfs:comment 'Sequential number assigned to the passenger within the flight check-in order. Used for boarding priority and operational sequencing.' ;
    rdfs:domain ind:CheckinSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:checkinStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Checkin Start Timestamp' ;
    rdfs:comment 'Timestamp when the passenger initiated the check-in session. Recorded in UTC and converted to local airport time for operational reporting.' ;
    rdfs:domain ind:CheckinSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:checkinStatus rdf:type rdf:Property ;
    rdfs:label 'Checkin Status' ;
    rdfs:comment 'Current status of the check-in session. Completed = boarding pass issued, incomplete = session started but not finished, cancelled = passenger cancelled check-in, no_show = passenger did not complete check-in and did not board.' ;
    rdfs:domain ind:CheckinSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:excessBaggageChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Excess Baggage Charge Amount' ;
    rdfs:comment 'Total excess baggage charge collected at check-in, in the transaction currency. Null if no excess baggage.' ;
    rdfs:domain ind:Airport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:excessBaggageChargeCurrency rdf:type rdf:Property ;
    rdfs:label 'Excess Baggage Charge Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the excess baggage charge.' ;
    rdfs:domain ind:Airport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:excessBaggageFlag rdf:type rdf:Property ;
    rdfs:label 'Excess Baggage Flag' ;
    rdfs:comment 'Indicates whether the passenger checked excess baggage beyond the standard allowance. True if excess baggage charges apply.' ;
    rdfs:domain ind:CheckinSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:groupCheckinFlag rdf:type rdf:Property ;
    rdfs:label 'Group Checkin Flag' ;
    rdfs:comment 'Indicates whether this check-in is part of a group booking check-in. True if group check-in.' ;
    rdfs:domain ind:CheckinSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:infantAccompanyingFlag rdf:type rdf:Property ;
    rdfs:label 'Infant Accompanying Flag' ;
    rdfs:comment 'Indicates whether the passenger is traveling with an infant (under 2 years) on lap. True if infant accompanying.' ;
    rdfs:domain ind:CheckinSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:seatAssigned rdf:type rdf:Property ;
    rdfs:label 'Seat Assigned' ;
    rdfs:comment 'Seat number assigned to the passenger during check-in (e.g., 12A, 34F). Format: row number followed by seat letter.' ;
    rdfs:domain ind:CheckinSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standbyStatus rdf:type rdf:Property ;
    rdfs:label 'Standby Status' ;
    rdfs:comment 'Indicates whether the passenger is confirmed, on standby, or waitlisted at check-in. Confirmed = seat guaranteed, standby = awaiting seat assignment, waitlisted = not yet cleared.' ;
    rdfs:domain ind:CheckinSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:travelDocumentVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Travel Document Verified Flag' ;
    rdfs:comment 'Indicates whether the passengers travel documents (passport, visa) were verified during check-in. True if documents verified.' ;
    rdfs:domain ind:CheckinSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:upgradeProcessedFlag rdf:type rdf:Property ;
    rdfs:label 'Upgrade Processed Flag' ;
    rdfs:comment 'Indicates whether a cabin upgrade (e.g., economy to business) was processed during check-in. True if upgrade applied.' ;
    rdfs:domain ind:CheckinSession ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:boardingEventId rdf:type rdf:Property ;
    rdfs:label 'Boarding Event Id' ;
    rdfs:comment 'Unique identifier for the boarding event record. Primary key.' ;
    rdfs:domain ind:BoardingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:boardingActionTaken rdf:type rdf:Property ;
    rdfs:label 'Boarding Action Taken' ;
    rdfs:comment 'Description of any special action taken during boarding such as offload, reaccommodation, security hold, or manual verification.' ;
    rdfs:domain ind:BoardingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boardingDoorUsed rdf:type rdf:Property ;
    rdfs:label 'Boarding Door Used' ;
    rdfs:comment 'Identifier of the aircraft door or boarding method used (jetbridge door, remote stairs, bus gate).' ;
    rdfs:domain ind:BoardingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:boardingMethod rdf:type rdf:Property ;
    rdfs:label 'Boarding Method' ;
    rdfs:comment 'Method by which the boarding event was captured: automated gate reader, agent-assisted scan, manual entry, mobile device scan, or biometric verification.' ;
    rdfs:domain ind:BoardingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:carryOnBaggageCount rdf:type rdf:Property ;
    rdfs:label 'Carry On Baggage Count' ;
    rdfs:comment 'Number of carry-on baggage pieces the passenger brought to the gate.' ;
    rdfs:domain ind:BoardingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:checkedBaggageCount rdf:type rdf:Property ;
    rdfs:label 'Checked Baggage Count' ;
    rdfs:comment 'Number of checked baggage pieces associated with this passenger for this flight leg.' ;
    rdfs:domain ind:BoardingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:couponSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Coupon Sequence Number' ;
    rdfs:comment 'Sequential number of the flight coupon within the electronic ticket corresponding to this flight leg.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:gateReaderDeviceCode rdf:type rdf:Property ;
    rdfs:label 'Gate Reader Device Code' ;
    rdfs:comment 'Identifier of the automated gate reader or kiosk device that captured the boarding scan.' ;
    rdfs:domain ind:BoardingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irregularOperationFlag rdf:type rdf:Property ;
    rdfs:label 'Irregular Operation Flag' ;
    rdfs:comment 'Indicates whether this boarding event occurred during an irregular operation scenario such as delay, cancellation recovery, or diversion.' ;
    rdfs:domain ind:BoardingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:irregularOperationReason rdf:type rdf:Property ;
    rdfs:label 'Irregular Operation Reason' ;
    rdfs:comment 'Description of the irregular operation circumstance if irregular_operation_flag is true.' ;
    rdfs:domain ind:BoardingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCodesharePassenger rdf:type rdf:Property ;
    rdfs:label 'Is Codeshare Passenger' ;
    rdfs:comment 'Indicates whether the passenger booked through a codeshare partner airline.' ;
    rdfs:domain ind:BoardingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isInterlinePassenger rdf:type rdf:Property ;
    rdfs:label 'Is Interline Passenger' ;
    rdfs:comment 'Indicates whether the passenger is traveling on an interline itinerary involving multiple carriers.' ;
    rdfs:domain ind:BoardingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isStandbyPassenger rdf:type rdf:Property ;
    rdfs:label 'Is Standby Passenger' ;
    rdfs:comment 'Indicates whether the passenger was on standby status and cleared for boarding.' ;
    rdfs:domain ind:BoardingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isUpgradePassenger rdf:type rdf:Property ;
    rdfs:label 'Is Upgrade Passenger' ;
    rdfs:comment 'Indicates whether the passenger received a cabin class upgrade for this flight.' ;
    rdfs:domain ind:BoardingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rejectionReasonCode rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for boarding rejection if scan_result_status is rejected.' ;
    rdfs:domain ind:BoardingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rejectionReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Rejection Reason Description' ;
    rdfs:comment 'Human-readable description of why the boarding was rejected or flagged.' ;
    rdfs:domain ind:BoardingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scanResultStatus rdf:type rdf:Property ;
    rdfs:label 'Scan Result Status' ;
    rdfs:comment 'Outcome of the boarding pass scan indicating whether the passenger was accepted for boarding, rejected, flagged as duplicate scan, offloaded, or other status.' ;
    rdfs:domain ind:Airport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scanTimestamp rdf:type rdf:Property ;
    rdfs:label 'Scan Timestamp' ;
    rdfs:comment 'Precise date and time when the boarding pass was scanned at the gate.' ;
    rdfs:domain ind:Airport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:securityScreeningStatus rdf:type rdf:Property ;
    rdfs:label 'Security Screening Status' ;
    rdfs:comment 'Status of passenger security screening at the time of boarding.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baggageItemId rdf:type rdf:Property ;
    rdfs:label 'Baggage Item Id' ;
    rdfs:comment 'Unique system identifier for the individual checked baggage item. Primary key. Serves as the single source of truth for baggage identity within the airport domain.' ;
    rdfs:domain ind:Airport ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BaggageItem .

ind:acceptanceStationId rdf:type rdf:Property ;
    rdfs:label 'Acceptance Station Id' ;
    rdfs:comment 'Foreign key linking to airport.station. Business justification: baggage_item is accepted at a specific station. Currently stores acceptance_station_code (STRING). FK to station provides access to station details, time zone, and operational context. The acceptance_' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Station .

ind:acceptanceTimestamp rdf:type rdf:Property ;
    rdfs:label 'Acceptance Timestamp' ;
    rdfs:comment 'Date and time when the baggage item was accepted at check-in. Marks the start of airline custody and liability. Critical for baggage tracking and service level monitoring.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:bagTagNumber rdf:type rdf:Property ;
    rdfs:label 'Bag Tag Number' ;
    rdfs:comment 'IATA standard 10-digit bag tag number printed on the baggage label. Globally unique identifier used for tracking and tracing throughout the baggage journey.' ;
    rdfs:domain ind:Airport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bagType rdf:type rdf:Property ;
    rdfs:label 'Bag Type' ;
    rdfs:comment 'Classification of the baggage item based on size, content, or special handling requirements. Determines handling procedures, storage location, and applicable charges. [ENUM-REF-CANDIDATE: standard|oversized|fragile|sports_equipment|musical_instrument|live_animal|diplomatic|medical|wheelchair|infant_equipment — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Airport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentLocationStationCode rdf:type rdf:Property ;
    rdfs:label 'Current Location Station Code' ;
    rdfs:comment 'Three-letter IATA airport code of the current physical location of the baggage item. Updated at each scan point throughout the journey.' ;
    rdfs:domain ind:BaggageItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentStatus rdf:type rdf:Property ;
    rdfs:label 'Current Status' ;
    rdfs:comment 'Current lifecycle status of the baggage item in the handling process. Reflects the latest state in the baggage journey from acceptance through delivery. [ENUM-REF-CANDIDATE: accepted|loaded|in_transit|arrived|delivered|mishandled|delayed|damaged|lost — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BaggageItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declaredValueAmount rdf:type rdf:Property ;
    rdfs:label 'Declared Value Amount' ;
    rdfs:comment 'Monetary value declared by the passenger for the contents of the baggage item. Used for excess valuation coverage and liability determination in case of loss or damage.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:declaredValueCurrency rdf:type rdf:Property ;
    rdfs:label 'Declared Value Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the declared value amount. Supports multi-currency operations across international route networks.' ;
    rdfs:domain ind:BaggageItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Delivery Timestamp' ;
    rdfs:comment 'Date and time when the baggage item was delivered to the passenger or authorized recipient at the final destination. Marks the end of airline custody and liability.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:finalDestinationStationCode rdf:type rdf:Property ;
    rdfs:label 'Final Destination Station Code' ;
    rdfs:comment 'Three-letter IATA airport code of the final destination where the baggage item should be delivered to the passenger. End point for baggage routing.' ;
    rdfs:domain ind:BaggageItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:heightCm rdf:type rdf:Property ;
    rdfs:label 'Height Cm' ;
    rdfs:comment 'Height dimension of the baggage item in centimeters. Used for oversized baggage determination and ULD planning.' ;
    rdfs:domain ind:BaggageItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lastScanTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Scan Timestamp' ;
    rdfs:comment 'Date and time of the most recent scan event for this baggage item. Used for real-time tracking and service level monitoring.' ;
    rdfs:domain ind:BaggageItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lengthCm rdf:type rdf:Property ;
    rdfs:label 'Length Cm' ;
    rdfs:comment 'Length dimension of the baggage item in centimeters. Used for oversized baggage determination and ULD (Unit Load Device) planning.' ;
    rdfs:domain ind:BaggageItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mishandlingCode rdf:type rdf:Property ;
    rdfs:label 'Mishandling Code' ;
    rdfs:comment 'Classification of baggage mishandling incident if applicable. Used for service recovery, compensation determination, and quality metrics reporting.' ;
    rdfs:domain ind:BaggageItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mishandlingReportNumber rdf:type rdf:Property ;
    rdfs:label 'Mishandling Report Number' ;
    rdfs:comment 'Unique identifier of the Property Irregularity Report (PIR) or baggage claim filed for this item if mishandled. Links to the baggage claims system.' ;
    rdfs:domain ind:BaggageItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorityHandlingCode rdf:type rdf:Property ;
    rdfs:label 'Priority Handling Code' ;
    rdfs:comment 'Special handling priority assigned to the baggage item. Determines expedited processing for tight connections, premium passengers, or operational requirements.' ;
    rdfs:domain ind:BaggageItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingSequence rdf:type rdf:Property ;
    rdfs:label 'Routing Sequence' ;
    rdfs:comment 'Planned routing path for the baggage item through connecting stations. Formatted as a sequence of IATA airport codes representing the complete journey.' ;
    rdfs:domain ind:BaggageItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityScreeningTimestamp rdf:type rdf:Property ;
    rdfs:label 'Security Screening Timestamp' ;
    rdfs:comment 'Date and time when security screening was completed for this baggage item. Required for regulatory compliance and audit trail.' ;
    rdfs:domain ind:BaggageItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:uldNumber rdf:type rdf:Property ;
    rdfs:label 'Uld Number' ;
    rdfs:comment 'Identifier of the Unit Load Device (container or pallet) in which this baggage item is loaded for transport. Null if loaded as bulk baggage.' ;
    rdfs:domain ind:Airport ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightKg rdf:type rdf:Property ;
    rdfs:label 'Weight Kg' ;
    rdfs:comment 'Actual weight of the baggage item measured in kilograms at acceptance. Used for load planning, excess baggage charge calculation, and regulatory compliance.' ;
    rdfs:domain ind:BaggageItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:widthCm rdf:type rdf:Property ;
    rdfs:label 'Width Cm' ;
    rdfs:comment 'Width dimension of the baggage item in centimeters. Used for oversized baggage determination and ULD planning.' ;
    rdfs:domain ind:BaggageItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baggageScanId rdf:type rdf:Property ;
    rdfs:label 'Baggage Scan Id' ;
    rdfs:comment 'Unique identifier for each baggage scan event in the baggage handling system. Primary key for the baggage scan transaction record.' ;
    rdfs:domain ind:BaggageScan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualConnectTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Actual Connect Time Minutes' ;
    rdfs:comment 'Actual elapsed time in minutes between the inbound flight arrival scan and the outbound flight departure scan for transfer baggage. Used for connection performance analysis.' ;
    rdfs:domain ind:BaggageScan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:baggageType rdf:type rdf:Property ;
    rdfs:label 'Baggage Type' ;
    rdfs:comment 'Classification of the baggage item based on handling requirements and passenger service level. Determines handling priority and routing logic.' ;
    rdfs:domain ind:BaggageScan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cdmMessageType rdf:type rdf:Property ;
    rdfs:label 'Cdm Message Type' ;
    rdfs:comment 'Type of Airport CDM message generated by this baggage scan event for sharing with airport collaborative decision-making systems and stakeholders.' ;
    rdfs:domain ind:BaggageScan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conveyorBeltCode rdf:type rdf:Property ;
    rdfs:label 'Conveyor Belt Code' ;
    rdfs:comment 'Identifier of the specific conveyor belt or carousel within the baggage handling system where the scan occurred or where the bag was routed.' ;
    rdfs:domain ind:BaggageScan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsStatus rdf:type rdf:Property ;
    rdfs:label 'Customs Status' ;
    rdfs:comment 'Customs clearance status for international baggage items indicating whether the bag has been cleared for entry or requires inspection by customs authorities.' ;
    rdfs:domain ind:BaggageScan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionFlag rdf:type rdf:Property ;
    rdfs:label 'Exception Flag' ;
    rdfs:comment 'Boolean indicator identifying whether this scan event represents an irregular or exception condition requiring manual intervention or investigation.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:exceptionReasonCode rdf:type rdf:Property ;
    rdfs:label 'Exception Reason Code' ;
    rdfs:comment 'Standardized code describing the nature of the baggage handling exception such as misrouted, delayed, damaged, or security hold. Populated only when exception_flag is true.' ;
    rdfs:domain ind:BaggageScan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iata753ComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Iata 753 Compliance Flag' ;
    rdfs:comment 'Boolean indicator confirming whether this scan event meets IATA Resolution 753 baggage tracking requirements for mandatory scan point reporting.' ;
    rdfs:domain ind:BaggageScan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:makeupPosition rdf:type rdf:Property ;
    rdfs:label 'Makeup Position' ;
    rdfs:comment 'Specific location identifier within the baggage makeup area where bags are staged for loading onto the aircraft. Used for ground crew coordination.' ;
    rdfs:domain ind:BaggageScan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumConnectTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Minimum Connect Time Minutes' ;
    rdfs:comment 'Minimum connection time in minutes required for successful baggage transfer between the inbound and outbound flights. Used to identify at-risk connections.' ;
    rdfs:domain ind:BaggageScan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scanDataSource rdf:type rdf:Property ;
    rdfs:label 'Scan Data Source' ;
    rdfs:comment 'Type of data capture device or system that generated the baggage scan record. Used for data quality assessment and system performance monitoring.' ;
    rdfs:domain ind:BaggageScan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scanDeviceCode rdf:type rdf:Property ;
    rdfs:label 'Scan Device Code' ;
    rdfs:comment 'Unique identifier of the physical scanning device or reader that captured the bag tag. Used for device performance tracking and maintenance scheduling.' ;
    rdfs:domain ind:BaggageScan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scanPointType rdf:type rdf:Property ;
    rdfs:label 'Scan Point Type' ;
    rdfs:comment 'Classification of the baggage handling process stage where the scan occurred. Identifies the functional area within the airport baggage system.' ;
    rdfs:domain ind:BaggageScan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scanSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Scan Sequence Number' ;
    rdfs:comment 'Sequential order number of this scan event within the complete baggage journey for the specific bag tag. Enables chronological reconstruction of bag movement.' ;
    rdfs:domain ind:BaggageScan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sortationDecision rdf:type rdf:Property ;
    rdfs:label 'Sortation Decision' ;
    rdfs:comment 'Routing decision made by the baggage handling system determining the next destination for the baggage item based on flight information and system logic.' ;
    rdfs:domain ind:BaggageScan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transferConnectionFlag rdf:type rdf:Property ;
    rdfs:label 'Transfer Connection Flag' ;
    rdfs:comment 'Boolean indicator identifying whether this baggage item is part of a connecting itinerary requiring transfer between flights at this airport.' ;
    rdfs:domain ind:BaggageScan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reportStationId rdf:type rdf:Property ;
    rdfs:label 'Report Station Id' ;
    rdfs:comment 'Foreign key linking to airport.station. Business justification: baggage_irregularity is reported at a specific station. Currently stores report_station_code (STRING). FK to station provides access to station details and ground handler responsible. The report_stati' ;
    rdfs:domain ind:BaggageIrregularity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Station .

ind:bagColor rdf:type rdf:Property ;
    rdfs:label 'Bag Color' ;
    rdfs:comment 'Primary color of the mishandled bag as reported by the passenger.' ;
    rdfs:domain ind:BaggageIrregularity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bagDescription rdf:type rdf:Property ;
    rdfs:label 'Bag Description' ;
    rdfs:comment 'Detailed physical description of the mishandled bag including color, brand, size, type, and distinguishing features to aid in identification and recovery.' ;
    rdfs:domain ind:BaggageIrregularity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Closure Timestamp' ;
    rdfs:comment 'Date and time when the baggage irregularity case was officially closed, either due to successful delivery or final settlement.' ;
    rdfs:domain ind:BaggageIrregularity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:compensationAmount rdf:type rdf:Property ;
    rdfs:label 'Compensation Amount' ;
    rdfs:comment 'Actual compensation amount paid to the passenger for the baggage irregularity, including interim expenses and final settlement.' ;
    rdfs:domain ind:BaggageIrregularity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compensationCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Compensation Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the compensation amount.' ;
    rdfs:domain ind:BaggageIrregularity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contentsDescription rdf:type rdf:Property ;
    rdfs:label 'Contents Description' ;
    rdfs:comment 'Description of the bag contents as declared by the passenger, used for identification and liability assessment.' ;
    rdfs:domain ind:BaggageIrregularity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:declaredValueCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Declared Value Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the declared value amount.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveredTimestamp rdf:type rdf:Property ;
    rdfs:label 'Delivered Timestamp' ;
    rdfs:comment 'Date and time when the recovered bag was successfully delivered to the passenger or their designated location.' ;
    rdfs:domain ind:BaggageIrregularity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:forwardingInstructions rdf:type rdf:Property ;
    rdfs:label 'Forwarding Instructions' ;
    rdfs:comment 'Detailed instructions for forwarding the recovered bag to the passenger, including delivery address, contact information, and special handling requirements.' ;
    rdfs:domain ind:BaggageIrregularity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forwardingStationCode rdf:type rdf:Property ;
    rdfs:label 'Forwarding Station Code' ;
    rdfs:comment 'Three-letter IATA airport code of the station to which the recovered bag will be forwarded for delivery to the passenger.' ;
    rdfs:domain ind:BaggageIrregularity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handlingCarrierCode rdf:type rdf:Property ;
    rdfs:label 'Handling Carrier Code' ;
    rdfs:comment 'Two or three-character IATA airline code of the carrier currently handling the baggage irregularity case and recovery efforts.' ;
    rdfs:domain ind:BaggageIrregularity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interimExpenseAmount rdf:type rdf:Property ;
    rdfs:label 'Interim Expense Amount' ;
    rdfs:comment 'Amount reimbursed to passenger for interim expenses incurred due to delayed baggage (e.g., toiletries, clothing purchases).' ;
    rdfs:domain ind:BaggageIrregularity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:irregularityTypeCode rdf:type rdf:Property ;
    rdfs:label 'Irregularity Type Code' ;
    rdfs:comment 'IATA standard code classifying the type of baggage irregularity. DL=Delayed, MS=Misrouted, DF=Defaced, PL=Pilfered, DM=Damaged, RT=Retained, FD=Fraud, OV=Overage, RU=Rush, LT=Lost. [ENUM-REF-CANDIDATE: DL|MS|DF|PL|DM|RT|FD|OV|RU|LT — 10 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:BaggageIrregularity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irregularityTypeDescription rdf:type rdf:Property ;
    rdfs:label 'Irregularity Type Description' ;
    rdfs:comment 'Detailed description of the baggage irregularity type providing additional context beyond the standard code.' ;
    rdfs:domain ind:BaggageIrregularity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastKnownLocationCode rdf:type rdf:Property ;
    rdfs:label 'Last Known Location Code' ;
    rdfs:comment 'Three-letter IATA airport code of the last confirmed location where the bag was scanned or sighted in the baggage handling system.' ;
    rdfs:domain ind:BaggageIrregularity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastKnownLocationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Known Location Timestamp' ;
    rdfs:comment 'Date and time when the bag was last scanned or confirmed at the last known location.' ;
    rdfs:domain ind:BaggageIrregularity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:liabilityAmount rdf:type rdf:Property ;
    rdfs:label 'Liability Amount' ;
    rdfs:comment 'Calculated airline liability amount for the baggage irregularity based on applicable regulations and declared value.' ;
    rdfs:domain ind:BaggageIrregularity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:liabilityCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Liability Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the liability amount.' ;
    rdfs:domain ind:BaggageIrregularity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:locatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Located Timestamp' ;
    rdfs:comment 'Date and time when the mishandled bag was located and identified in the baggage handling system.' ;
    rdfs:domain ind:BaggageIrregularity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pirNumber rdf:type rdf:Property ;
    rdfs:label 'Pir Number' ;
    rdfs:comment 'Unique PIR number assigned to the baggage irregularity case. Format typically includes station code followed by sequential number. This is the externally-known business identifier for the irregularity.' ;
    rdfs:domain ind:BaggageIrregularity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recoveryStatusCode rdf:type rdf:Property ;
    rdfs:label 'Recovery Status Code' ;
    rdfs:comment 'Current status of the baggage recovery process. OP=Open/In Progress, LO=Located, FD=Found and Delivered, DL=Delivered, CL=Closed.' ;
    rdfs:domain ind:BaggageIrregularity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recoveryStatusDescription rdf:type rdf:Property ;
    rdfs:label 'Recovery Status Description' ;
    rdfs:comment 'Detailed description of the current recovery status providing additional context and updates on recovery efforts.' ;
    rdfs:domain ind:BaggageIrregularity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportTimestamp rdf:type rdf:Property ;
    rdfs:label 'Report Timestamp' ;
    rdfs:comment 'Date and time when the baggage irregularity was reported to airline staff. This is the principal business event timestamp for the irregularity lifecycle.' ;
    rdfs:domain ind:BaggageIrregularity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:responsibleCarrierCode rdf:type rdf:Property ;
    rdfs:label 'Responsible Carrier Code' ;
    rdfs:comment 'Two or three-character IATA airline code of the carrier determined to be responsible for the baggage irregularity.' ;
    rdfs:domain ind:BaggageIrregularity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:worldtracerReference rdf:type rdf:Property ;
    rdfs:label 'Worldtracer Reference' ;
    rdfs:comment 'Global baggage tracing reference number from IATA WorldTracer system used for international baggage tracking and recovery coordination across airlines.' ;
    rdfs:domain ind:BaggageIrregularity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deicingEventId rdf:type rdf:Property ;
    rdfs:label 'Deicing Event Id' ;
    rdfs:comment 'Unique identifier for the de-icing or anti-icing treatment event. Primary key.' ;
    rdfs:domain ind:DeicingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deicingLocationType rdf:type rdf:Property ;
    rdfs:label 'Deicing Location Type' ;
    rdfs:comment 'The type of location where de-icing was performed: dedicated de-icing pad, gate position, remote stand, or runway holding area.' ;
    rdfs:domain ind:DeicingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deicingVendorCode rdf:type rdf:Property ;
    rdfs:label 'Deicing Vendor Code' ;
    rdfs:comment 'Code identifying the third-party vendor or ground handling company that performed the de-icing service. Used for billing and performance tracking.' ;
    rdfs:domain ind:DeicingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:environmentalReportingFlag rdf:type rdf:Property ;
    rdfs:label 'Environmental Reporting Flag' ;
    rdfs:comment 'Indicates whether this de-icing event must be included in environmental compliance reporting (CORSIA, ISO 14001). True if glycol usage exceeds reporting thresholds.' ;
    rdfs:domain ind:DeicingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:equipmentIdentifier rdf:type rdf:Property ;
    rdfs:label 'Equipment Identifier' ;
    rdfs:comment 'Identifier for the specific de-icing truck or equipment unit used. Enables equipment maintenance correlation and utilization tracking.' ;
    rdfs:domain ind:DeicingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fluidConcentrationPrimaryPercent rdf:type rdf:Property ;
    rdfs:label 'Fluid Concentration Primary Percent' ;
    rdfs:comment 'Concentration percentage of the primary de-icing fluid mixture (glycol to water ratio). Affects freezing point and holdover time.' ;
    rdfs:domain ind:DeicingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fluidConcentrationSecondaryPercent rdf:type rdf:Property ;
    rdfs:label 'Fluid Concentration Secondary Percent' ;
    rdfs:comment 'Concentration percentage of the secondary anti-icing fluid mixture. Null if no secondary treatment was performed.' ;
    rdfs:domain ind:DeicingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fluidCostTotalAmount rdf:type rdf:Property ;
    rdfs:label 'Fluid Cost Total Amount' ;
    rdfs:comment 'Total cost of de-icing and anti-icing fluids used in this treatment event. Used for financial tracking and cost recovery.' ;
    rdfs:domain ind:DeicingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fluidTypePrimary rdf:type rdf:Property ;
    rdfs:label 'Fluid Type Primary' ;
    rdfs:comment 'The primary de-icing fluid type applied in the first treatment step. Type I is typically used for de-icing (removing contamination).' ;
    rdfs:domain ind:DeicingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fluidTypeSecondary rdf:type rdf:Property ;
    rdfs:label 'Fluid Type Secondary' ;
    rdfs:comment 'The secondary anti-icing fluid type applied in the second treatment step, if applicable. Types II, III, or IV provide longer holdover time protection.' ;
    rdfs:domain ind:DeicingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fluidVolumePrimaryLiters rdf:type rdf:Property ;
    rdfs:label 'Fluid Volume Primary Liters' ;
    rdfs:comment 'Volume of primary de-icing fluid applied, measured in liters. Used for cost tracking and environmental reporting.' ;
    rdfs:domain ind:DeicingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fluidVolumeSecondaryLiters rdf:type rdf:Property ;
    rdfs:label 'Fluid Volume Secondary Liters' ;
    rdfs:comment 'Volume of secondary anti-icing fluid applied, measured in liters. Null if no secondary treatment was performed.' ;
    rdfs:domain ind:DeicingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holdoverTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Holdover Time Minutes' ;
    rdfs:comment 'The estimated time in minutes that the anti-icing treatment will remain effective under current weather conditions. Critical for flight safety and departure timing.' ;
    rdfs:domain ind:DeicingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:inspectionPerformedBy rdf:type rdf:Property ;
    rdfs:label 'Inspection Performed By' ;
    rdfs:comment 'Identifier of the person or crew who performed the post-treatment inspection. May be pilot, ground crew, or designated inspector.' ;
    rdfs:domain ind:DeicingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outsideAirTemperatureCelsius rdf:type rdf:Property ;
    rdfs:label 'Outside Air Temperature Celsius' ;
    rdfs:comment 'The outside air temperature in degrees Celsius at the time of treatment. Critical factor in determining holdover time and fluid effectiveness.' ;
    rdfs:domain ind:DeicingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postTreatmentInspectionResult rdf:type rdf:Property ;
    rdfs:label 'Post Treatment Inspection Result' ;
    rdfs:comment 'Result of the post-treatment inspection to verify aircraft surfaces are free of contamination. Critical safety check before departure.' ;
    rdfs:domain ind:DeicingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:precipitationIntensity rdf:type rdf:Property ;
    rdfs:label 'Precipitation Intensity' ;
    rdfs:comment 'The intensity of precipitation during treatment. Combined with precipitation type to determine holdover time from FAA/Transport Canada tables.' ;
    rdfs:domain ind:DeicingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:precipitationType rdf:type rdf:Property ;
    rdfs:label 'Precipitation Type' ;
    rdfs:comment 'The type of precipitation or frozen contamination present during treatment. Affects holdover time calculation and treatment requirements. [ENUM-REF-CANDIDATE: none|light_snow|moderate_snow|heavy_snow|freezing_rain|freezing_drizzle|ice_pellets|frost|mixed — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DeicingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serviceChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Service Charge Amount' ;
    rdfs:comment 'Labor and equipment service charge for the de-icing treatment, separate from fluid costs. Used for vendor billing and cost allocation.' ;
    rdfs:domain ind:DeicingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:treatmentDurationMinutes rdf:type rdf:Property ;
    rdfs:label 'Treatment Duration Minutes' ;
    rdfs:comment 'Total duration of the de-icing treatment in minutes, calculated from start to end timestamp. Used for operational efficiency analysis.' ;
    rdfs:domain ind:DeicingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:treatmentEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Treatment End Timestamp' ;
    rdfs:comment 'The date and time when de-icing treatment was completed. Marks the start of the holdover time window.' ;
    rdfs:domain ind:DeicingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:treatmentReasonCode rdf:type rdf:Property ;
    rdfs:label 'Treatment Reason Code' ;
    rdfs:comment 'The primary reason or trigger for performing the de-icing treatment. Used for operational analysis and cost allocation. [ENUM-REF-CANDIDATE: scheduled|frost|snow|ice|freezing_rain|preventive|regulatory_requirement — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DeicingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatmentStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Treatment Start Timestamp' ;
    rdfs:comment 'The date and time when de-icing treatment began. Used to calculate holdover time expiration and turnaround impact.' ;
    rdfs:domain ind:DeicingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:treatmentStatus rdf:type rdf:Property ;
    rdfs:label 'Treatment Status' ;
    rdfs:comment 'Current status of the de-icing treatment event in its lifecycle. Tracks operational workflow state.' ;
    rdfs:domain ind:DeicingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:treatmentType rdf:type rdf:Property ;
    rdfs:label 'Treatment Type' ;
    rdfs:comment 'The type of de-icing and anti-icing fluid treatment applied. Type I is heated de-icing fluid; Types II, III, IV are thickened anti-icing fluids with varying viscosities and holdover times. [ENUM-REF-CANDIDATE: type_i_only|type_i_and_ii|type_i_and_iii|type_i_and_iv|type_ii_only|type_iii_only|type_iv_only — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:DeicingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visibilityMeters rdf:type rdf:Property ;
    rdfs:label 'Visibility Meters' ;
    rdfs:comment 'Visibility in meters at the time of treatment. Indicates severity of weather conditions.' ;
    rdfs:domain ind:DeicingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:windSpeedKnots rdf:type rdf:Property ;
    rdfs:label 'Wind Speed Knots' ;
    rdfs:comment 'Wind speed in knots at the time of treatment. High winds can reduce holdover time effectiveness.' ;
    rdfs:domain ind:DeicingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:aircraftDamageIncidentCount rdf:type rdf:Property ;
    rdfs:label 'Aircraft Damage Incident Count' ;
    rdfs:comment 'The total number of aircraft damage incidents caused by this handler during the current performance measurement period.' ;
    rdfs:domain ind:GroundHandler ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:averageBaggageDeliveryTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Average Baggage Delivery Time Minutes' ;
    rdfs:comment 'The average time in minutes from aircraft arrival to first baggage on carousel for flights handled by this provider.' ;
    rdfs:domain ind:GroundHandler ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baggageHandlingFlag rdf:type rdf:Property ;
    rdfs:label 'Baggage Handling Flag' ;
    rdfs:comment 'Indicates whether the handler provides baggage sorting, loading, unloading, and tracing services.' ;
    rdfs:domain ind:GroundHandler ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:baggageMishandlingRatePer1000 rdf:type rdf:Property ;
    rdfs:label 'Baggage Mishandling Rate Per 1000' ;
    rdfs:comment 'The number of mishandled baggage incidents per 1000 passengers handled, including delayed, damaged, and lost baggage.' ;
    rdfs:domain ind:GroundHandler ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cargoHandlingFlag rdf:type rdf:Property ;
    rdfs:label 'Cargo Handling Flag' ;
    rdfs:comment 'Indicates whether the handler provides cargo and freight handling services including loading, unloading, and warehouse operations.' ;
    rdfs:domain ind:GroundHandler ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cateringHandlingFlag rdf:type rdf:Property ;
    rdfs:label 'Catering Handling Flag' ;
    rdfs:comment 'Indicates whether the handler provides aircraft catering loading and unloading services.' ;
    rdfs:domain ind:GroundHandler ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractedStations rdf:type rdf:Property ;
    rdfs:label 'Contracted Stations' ;
    rdfs:comment 'Comma-separated list of IATA airport codes where this handler is contracted to provide services.' ;
    rdfs:domain ind:GroundHandler ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelHandlingFlag rdf:type rdf:Property ;
    rdfs:label 'Fuel Handling Flag' ;
    rdfs:comment 'Indicates whether the handler provides aircraft refueling and defueling services.' ;
    rdfs:domain ind:GroundHandler ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:handlerName rdf:type rdf:Property ;
    rdfs:label 'Handler Name' ;
    rdfs:comment 'The legal registered name of the ground handling service provider organization.' ;
    rdfs:domain ind:GroundHandler ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:handlerType rdf:type rdf:Property ;
    rdfs:label 'Handler Type' ;
    rdfs:comment 'Classification of the ground handler by ownership and operational model.' ;
    rdfs:domain ind:GroundHandler ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iataGroundHandlerCode rdf:type rdf:Property ;
    rdfs:label 'Iata Ground Handler Code' ;
    rdfs:comment 'The IATA-assigned unique code identifying this ground handling service provider globally.' ;
    rdfs:domain ind:GroundHandler ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceCoverageAmount rdf:type rdf:Property ;
    rdfs:label 'Insurance Coverage Amount' ;
    rdfs:comment 'The total liability coverage amount provided by the handler\'s insurance policy.' ;
    rdfs:domain ind:GroundHandler ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:insuranceCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Insurance Currency Code' ;
    rdfs:comment 'The three-letter ISO 4217 currency code for the insurance coverage amount.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Insurance Expiry Date' ;
    rdfs:comment 'The date when the handler\'s liability insurance policy expires and must be renewed.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:insurancePolicyNumber rdf:type rdf:Property ;
    rdfs:label 'Insurance Policy Number' ;
    rdfs:comment 'The policy number of the handler\'s liability insurance coverage as required by the ground handling agreement.' ;
    rdfs:domain ind:GroundHandler ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isagoCertificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Isago Certification Expiry Date' ;
    rdfs:comment 'The date when the handler\'s ISAGO certification expires and must be renewed.' ;
    rdfs:domain ind:GroundHandler ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:isagoCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Isago Certified Flag' ;
    rdfs:comment 'Indicates whether the handler holds current IATA Safety Audit for Ground Operations (ISAGO) certification.' ;
    rdfs:domain ind:GroundHandler ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastPerformanceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Last Performance Review Date' ;
    rdfs:comment 'The date of the most recent formal performance review conducted with this ground handler.' ;
    rdfs:domain ind:GroundHandler ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseExpiryDate rdf:type rdf:Property ;
    rdfs:label 'License Expiry Date' ;
    rdfs:comment 'The date when the ground handler\'s operating license expires and must be renewed.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:licenseIssuingAuthority rdf:type rdf:Property ;
    rdfs:label 'License Issuing Authority' ;
    rdfs:comment 'The name of the civil aviation authority or regulatory body that issued the ground handling license.' ;
    rdfs:domain ind:GroundHandler ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenseNumber rdf:type rdf:Property ;
    rdfs:label 'License Number' ;
    rdfs:comment 'The regulatory license or permit number issued by the civil aviation authority authorizing ground handling operations.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onTimeDepartureContributionPct rdf:type rdf:Property ;
    rdfs:label 'On Time Departure Contribution Pct' ;
    rdfs:comment 'The percentage of flights handled by this provider that departed on time, measuring contribution to overall On-Time Performance (OTP).' ;
    rdfs:domain ind:GroundHandler ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:passengerHandlingFlag rdf:type rdf:Property ;
    rdfs:label 'Passenger Handling Flag' ;
    rdfs:comment 'Indicates whether the handler provides passenger services including check-in, boarding, and gate operations.' ;
    rdfs:domain ind:GroundHandler ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:penaltyTriggeredFlag rdf:type rdf:Property ;
    rdfs:label 'Penalty Triggered Flag' ;
    rdfs:comment 'Indicates whether contractual penalties have been triggered due to performance failures during the current period.' ;
    rdfs:domain ind:GroundHandler ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:performanceScore rdf:type rdf:Property ;
    rdfs:label 'Performance Score' ;
    rdfs:comment 'The composite performance score (0-100) calculated from weighted Key Performance Indicators (KPIs) including on-time performance, baggage handling, safety, and SLA compliance.' ;
    rdfs:domain ind:GroundHandler ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:performanceTier rdf:type rdf:Property ;
    rdfs:label 'Performance Tier' ;
    rdfs:comment 'The current performance tier classification of the handler based on historical Service Level Agreement (SLA) compliance and quality metrics.' ;
    rdfs:domain ind:GroundHandler ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactEmail rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Email' ;
    rdfs:comment 'The email address of the primary operational contact at the ground handler.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactName rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Name' ;
    rdfs:comment 'The full name of the primary operational contact person at the ground handler for day-to-day coordination.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryContactPhone rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Phone' ;
    rdfs:comment 'The telephone number of the primary operational contact at the ground handler.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rampHandlingFlag rdf:type rdf:Property ;
    rdfs:label 'Ramp Handling Flag' ;
    rdfs:comment 'Indicates whether the handler provides ramp services including aircraft marshalling, chocking, towing, and ground power.' ;
    rdfs:domain ind:GroundHandler ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sghaAgreementReference rdf:type rdf:Property ;
    rdfs:label 'Sgha Agreement Reference' ;
    rdfs:comment 'The unique reference number of the Standard Ground Handling Agreement contract governing the relationship with this handler.' ;
    rdfs:domain ind:GroundHandler ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaBreachCount rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Count' ;
    rdfs:comment 'The total number of Service Level Agreement breaches recorded against this handler during the current measurement period.' ;
    rdfs:domain ind:GroundHandler ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cargoHandlingCapableFlag rdf:type rdf:Property ;
    rdfs:label 'Cargo Handling Capable Flag' ;
    rdfs:comment 'Indicates whether the station has facilities and capability for cargo and freight handling operations. True if capable, false otherwise.' ;
    rdfs:domain ind:Station ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cityName rdf:type rdf:Property ;
    rdfs:label 'City Name' ;
    rdfs:comment 'Name of the city where the station is located, used for route planning and passenger information.' ;
    rdfs:domain ind:Station ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedDate rdf:type rdf:Property ;
    rdfs:label 'Closed Date' ;
    rdfs:comment 'Date when the airline ceased operations at this station, if applicable. Null for active stations.' ;
    rdfs:domain ind:Station ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:customsFacilityAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Customs Facility Available Flag' ;
    rdfs:comment 'Indicates whether customs clearance facilities are available at the station for international arrivals. True if available, false otherwise.' ;
    rdfs:domain ind:Station ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dangerousGoodsCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Dangerous Goods Certified Flag' ;
    rdfs:comment 'Indicates whether the station is certified to handle dangerous goods shipments per IATA regulations. True if certified, false otherwise.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:daylightSavingObservedFlag rdf:type rdf:Property ;
    rdfs:label 'Daylight Saving Observed Flag' ;
    rdfs:comment 'Indicates whether the station location observes daylight saving time adjustments. True if DST is observed, false otherwise.' ;
    rdfs:domain ind:Station ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:elevationMeters rdf:type rdf:Property ;
    rdfs:label 'Elevation Meters' ;
    rdfs:comment 'Airport elevation above mean sea level in meters, critical for aircraft performance calculations and flight planning.' ;
    rdfs:domain ind:Station ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fuelProviderCode rdf:type rdf:Property ;
    rdfs:label 'Fuel Provider Code' ;
    rdfs:comment 'Code identifying the primary aviation fuel supplier at this station.' ;
    rdfs:domain ind:Station ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iataAirportCode rdf:type rdf:Property ;
    rdfs:label 'Iata Airport Code' ;
    rdfs:comment 'Three-letter IATA airport code identifying the airport where this station operates. Standard industry identifier for airport locations.' ;
    rdfs:domain ind:Station ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icaoAirportCode rdf:type rdf:Property ;
    rdfs:label 'Icao Airport Code' ;
    rdfs:comment 'Four-letter ICAO airport code providing globally unique airport identification used in flight planning and air traffic control.' ;
    rdfs:domain ind:Station ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:immigrationFacilityAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Immigration Facility Available Flag' ;
    rdfs:comment 'Indicates whether immigration processing facilities are available at the station for international passengers. True if available, false otherwise.' ;
    rdfs:domain ind:Station ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maintenanceCapabilityLevel rdf:type rdf:Property ;
    rdfs:label 'Maintenance Capability Level' ;
    rdfs:comment 'Level of aircraft maintenance capability available at the station. None: no maintenance. Line: routine checks and minor repairs. Base: scheduled maintenance and component replacement. Heavy: major overhaul and structural work.' ;
    rdfs:domain ind:Station ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:openedDate rdf:type rdf:Property ;
    rdfs:label 'Opened Date' ;
    rdfs:comment 'Date when the airline first began operations at this station.' ;
    rdfs:domain ind:Station ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operationalHoursDescription rdf:type rdf:Property ;
    rdfs:label 'Operational Hours Description' ;
    rdfs:comment 'Detailed description of station operating hours, including daily schedules, seasonal variations, and any restrictions.' ;
    rdfs:domain ind:Station ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationalHoursType rdf:type rdf:Property ;
    rdfs:label 'Operational Hours Type' ;
    rdfs:comment 'Classification of station operating hours. 24x7: continuous operations. Scheduled: fixed daily hours. Seasonal: varies by season or demand.' ;
    rdfs:domain ind:Station ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overnightParkingCapableFlag rdf:type rdf:Property ;
    rdfs:label 'Overnight Parking Capable Flag' ;
    rdfs:comment 'Indicates whether the station has facilities and authorization for overnight aircraft parking. True if capable, false otherwise.' ;
    rdfs:domain ind:Station ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stationName rdf:type rdf:Property ;
    rdfs:label 'Station Name' ;
    rdfs:comment 'Official name of the airline operating station, typically matching the airport name or city served.' ;
    rdfs:domain ind:Station ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeZone rdf:type rdf:Property ;
    rdfs:label 'Time Zone' ;
    rdfs:comment 'IANA time zone identifier for the station location, used for flight scheduling and operational coordination.' ;
    rdfs:domain ind:Station ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:utcOffsetHours rdf:type rdf:Property ;
    rdfs:label 'Utc Offset Hours' ;
    rdfs:comment 'Standard UTC offset in hours for the station location, excluding daylight saving time adjustments.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:crewCostCentreId rdf:type rdf:Property ;
    rdfs:label 'Crew Cost Centre Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_centre. Business justification: Crew members are assigned to cost centres for payroll allocation, CASK calculation, and crew cost attribution in airline financial reporting. Fundamental to operational cost accounting and route profi' ;
    rdfs:domain ind:Member ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCentre .

ind:employeeFfpMemberId rdf:type rdf:Property ;
    rdfs:label 'Employee Ffp Member Id' ;
    rdfs:comment 'Foreign key linking to loyalty.ffp_member. Business justification: Airlines track crew members\' loyalty program memberships for employee travel benefits, staff travel privileges, recognition programs, and discounted/complimentary award bookings. Standard HR-loyalty i' ;
    rdfs:domain ind:Member ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FfpMember .

ind:homeStationId rdf:type rdf:Property ;
    rdfs:label 'Home Station Id' ;
    rdfs:comment 'Foreign key linking to airport.station. Business justification: Crew members have a home station for domicile-based scheduling, regulatory rest requirements, commuting logistics, and operational planning. Essential for crew resource management and FAA/EASA complia' ;
    rdfs:domain ind:Member ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Station .

ind:primaryAircraftTypeId rdf:type rdf:Property ;
    rdfs:label 'Primary Aircraft Type Id' ;
    rdfs:comment 'Foreign key linking to fleet.aircraft_type. Business justification: Crew scheduling and qualification tracking require knowing each crew member\'s primary aircraft type rating. Essential for daily crew assignment validation, reserve crew callout, and regulatory complia' ;
    rdfs:domain ind:Member ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AircraftType .

ind:aimsCrewCode rdf:type rdf:Property ;
    rdfs:label 'Aims Crew Code' ;
    rdfs:comment 'External crew identifier from the AIMS Crew Management System. Used for integration and reconciliation with the source system of record.' ;
    rdfs:domain ind:Member ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crewCategory rdf:type rdf:Property ;
    rdfs:label 'Crew Category' ;
    rdfs:comment 'Primary classification of crew member role: flight deck (pilots, first officers), cabin (flight attendants, pursers), ground operations, maintenance, dispatch, or other support roles.' ;
    rdfs:domain ind:Member ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crewPosition rdf:type rdf:Property ;
    rdfs:label 'Crew Position' ;
    rdfs:comment 'Specific job title or position within the crew category (e.g., Captain, First Officer, Senior Flight Attendant, Purser, Relief Pilot).' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dateOfHire rdf:type rdf:Property ;
    rdfs:label 'Date Of Hire' ;
    rdfs:comment 'The date the crew member was originally hired by the airline, used for seniority calculations and benefit eligibility.' ;
    rdfs:domain ind:Member ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:employmentStatus rdf:type rdf:Property ;
    rdfs:label 'Employment Status' ;
    rdfs:comment 'Current employment classification indicating the crew member\'s contractual relationship with the airline.' ;
    rdfs:domain ind:Member ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:familyName rdf:type rdf:Property ;
    rdfs:label 'Family Name' ;
    rdfs:comment 'The crew member\'s legal last name or surname as it appears on official documents and travel credentials.' ;
    rdfs:domain ind:Member ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:givenName rdf:type rdf:Property ;
    rdfs:label 'Given Name' ;
    rdfs:comment 'The crew member\'s legal first name as it appears on official documents and travel credentials.' ;
    rdfs:domain ind:Member ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageProficiencyCodes rdf:type rdf:Property ;
    rdfs:label 'Language Proficiency Codes' ;
    rdfs:comment 'Comma-separated list of language codes and proficiency levels (e.g., ENG:6, SPA:4) per ICAO Language Proficiency Requirements for international operations.' ;
    rdfs:domain ind:Member ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastLineCheckDate rdf:type rdf:Property ;
    rdfs:label 'Last Line Check Date' ;
    rdfs:comment 'Date of the crew member\'s most recent line check or proficiency check conducted during actual flight operations.' ;
    rdfs:domain ind:Member ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastRecurrentTrainingDate rdf:type rdf:Property ;
    rdfs:label 'Last Recurrent Training Date' ;
    rdfs:comment 'Date of the crew member\'s most recent recurrent training completion, required annually or semi-annually per regulatory requirements.' ;
    rdfs:domain ind:Member ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:medicalCertificateClass rdf:type rdf:Property ;
    rdfs:label 'Medical Certificate Class' ;
    rdfs:comment 'Classification of the crew member\'s aviation medical certificate (Class 1 for airline transport pilots, Class 2 for commercial pilots, cabin crew medical, etc.).' ;
    rdfs:domain ind:Member ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalCertificateExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Medical Certificate Expiry Date' ;
    rdfs:comment 'Expiration date of the crew member\'s current aviation medical certificate, critical for maintaining operational legality.' ;
    rdfs:domain ind:Member ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:mobilePhoneNumber rdf:type rdf:Property ;
    rdfs:label 'Mobile Phone Number' ;
    rdfs:comment 'Primary mobile contact number for crew scheduling, irregular operations (IROP) notifications, and emergency contact.' ;
    rdfs:domain ind:Member ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextRecurrentTrainingDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Recurrent Training Due Date' ;
    rdfs:comment 'Date by which the crew member must complete their next recurrent training to maintain operational currency.' ;
    rdfs:domain ind:Member ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:passportExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Passport Expiry Date' ;
    rdfs:comment 'Expiration date of the crew member\'s passport, monitored to ensure compliance with six-month validity rules for international operations.' ;
    rdfs:domain ind:Member ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:passportNumber rdf:type rdf:Property ;
    rdfs:label 'Passport Number' ;
    rdfs:comment 'Crew member\'s passport number required for international flight operations and border crossing documentation.' ;
    rdfs:domain ind:Member ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securityClearanceExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Security Clearance Expiry Date' ;
    rdfs:comment 'Expiration date of the crew member\'s airport security clearance or background check, required for access to secure areas.' ;
    rdfs:domain ind:Member ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:seniorityNumber rdf:type rdf:Property ;
    rdfs:label 'Seniority Number' ;
    rdfs:comment 'Numeric ranking representing the crew member\'s seniority within their crew category and base, used for bidding, scheduling priority, and career progression decisions.' ;
    rdfs:domain ind:Member ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalFlightHours rdf:type rdf:Property ;
    rdfs:label 'Total Flight Hours' ;
    rdfs:comment 'Cumulative total flight hours logged by the crew member across their entire career, used for experience tracking and regulatory compliance.' ;
    rdfs:domain ind:Member ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unionMembershipFlag rdf:type rdf:Property ;
    rdfs:label 'Union Membership Flag' ;
    rdfs:comment 'Indicates whether the crew member is a member of a labor union or collective bargaining unit.' ;
    rdfs:domain ind:Member ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualificationId rdf:type rdf:Property ;
    rdfs:label 'Qualification Id' ;
    rdfs:comment 'Unique identifier for the crew qualification record. Primary key.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:licenceId rdf:type rdf:Property ;
    rdfs:label 'Licence Id' ;
    rdfs:comment 'Foreign key linking to crew.licence. Business justification: Normalize qualification to reference licence by FK. Currently qualification stores licence_number (STRING) and licence_authority (STRING) as denormalized references. The licence table is the authorita' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Licence .

ind:trainingEventId rdf:type rdf:Property ;
    rdfs:label 'Training Event Id' ;
    rdfs:comment 'Foreign key linking to crew.training_event. Business justification: A crew qualification (type rating, proficiency check result) is typically produced or validated by a specific training event (simulator check, OPC, PC). Linking qualification.training_event_id → train' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TrainingEvent .

ind:endorsementCodes rdf:type rdf:Property ;
    rdfs:label 'Endorsement Codes' ;
    rdfs:comment 'Comma-separated list of additional endorsements or restrictions on this qualification (e.g., ETOPS, CAT III, RNP AR, VFR only). Aligns with ICAO and FAA endorsement standards.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isPicQualified rdf:type rdf:Property ;
    rdfs:label 'Is Pic Qualified' ;
    rdfs:comment 'Indicates whether this qualification authorizes the crew member to act as Pilot in Command (PIC). True if PIC-qualified, False otherwise.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSicQualified rdf:type rdf:Property ;
    rdfs:label 'Is Sic Qualified' ;
    rdfs:comment 'Indicates whether this qualification authorizes the crew member to act as Second in Command (SIC). True if SIC-qualified, False otherwise.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:landingsCount rdf:type rdf:Property ;
    rdfs:label 'Landings Count' ;
    rdfs:comment 'Total number of landings performed under this qualification. Critical for recency requirements (e.g., 3 takeoffs and landings in 90 days).' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastCheckDate rdf:type rdf:Property ;
    rdfs:label 'Last Check Date' ;
    rdfs:comment 'Date of the most recent proficiency check, simulator check, or line check for this qualification. Used to track recency and currency.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastFlightDate rdf:type rdf:Property ;
    rdfs:label 'Last Flight Date' ;
    rdfs:comment 'Date of the most recent flight operated under this qualification. Used to determine recency and currency status.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:medicalClass rdf:type rdf:Property ;
    rdfs:label 'Medical Class' ;
    rdfs:comment 'Class of medical certificate required or held for this qualification: class_1 (airline transport pilot), class_2 (commercial pilot), class_3 (private pilot). Null for cabin crew qualifications.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextCheckDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Check Due Date' ;
    rdfs:comment 'Date by which the next proficiency check or recurrent training must be completed to maintain qualification currency.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:positionCode rdf:type rdf:Property ;
    rdfs:label 'Position Code' ;
    rdfs:comment 'Crew position this qualification authorizes: CA (Captain), FO (First Officer), SO (Second Officer), CP (Co-Pilot), FA (Flight Attendant), PS (Purser), LS (Lead Steward). Null for non-position qualifications.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationCategory rdf:type rdf:Property ;
    rdfs:label 'Qualification Category' ;
    rdfs:comment 'High-level category of the qualification: type_rating (aircraft type), position_authorization (Captain, FO, Purser), endorsement (ICAO/FAA licence endorsement), recurrent_training (annual recurrency), special_qualification (ETOPS, CAT III), medical_certificate (Class 1/2 medical).' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationCode rdf:type rdf:Property ;
    rdfs:label 'Qualification Code' ;
    rdfs:comment 'Standardized code representing the qualification type (e.g., B737, A320, B777, PURSER, FA). Aligns with ICAO and FAA type rating nomenclature.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationName rdf:type rdf:Property ;
    rdfs:label 'Qualification Name' ;
    rdfs:comment 'Full descriptive name of the qualification (e.g., Boeing 737-800 Type Rating, Airbus A320 Family Type Rating, Purser Qualification).' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recencyStatus rdf:type rdf:Property ;
    rdfs:label 'Recency Status' ;
    rdfs:comment 'Indicates whether the crew member meets recency requirements for this qualification: current (meets all recency rules), expiring_soon (within alert window), expired (recency lapsed), not_applicable (no recency requirement).' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restrictions rdf:type rdf:Property ;
    rdfs:label 'Restrictions' ;
    rdfs:comment 'Free-text description of any operational restrictions or limitations on this qualification (e.g., VFR only, daylight operations only, supervised operations required).' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:simulatorHours rdf:type rdf:Property ;
    rdfs:label 'Simulator Hours' ;
    rdfs:comment 'Total simulator training hours logged for this qualification. Used for tracking training investment and proficiency.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:baseCode rdf:type rdf:Property ;
    rdfs:label 'Base Code' ;
    rdfs:comment 'Three-letter IATA airport code representing the crew domicile base (e.g., JFK, LAX, ORD). This is the operational identifier used in crew scheduling and pairing construction.' ;
    rdfs:domain ind:Base ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseName rdf:type rdf:Property ;
    rdfs:label 'Base Name' ;
    rdfs:comment 'Full descriptive name of the crew base (e.g., \'New York JFK Base\', \'Los Angeles International Base\'). Human-readable identifier for business users.' ;
    rdfs:domain ind:Base ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseStatus rdf:type rdf:Property ;
    rdfs:label 'Base Status' ;
    rdfs:comment 'Current operational status of the crew base. Active = fully operational, Inactive = temporarily not staffed, Seasonal = operates during specific periods, Temporary = short-term base, Closed = permanently shut down.' ;
    rdfs:domain ind:Base ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseType rdf:type rdf:Property ;
    rdfs:label 'Base Type' ;
    rdfs:comment 'Classification of the crew base by operational role within the network (hub = major connecting base, spoke = destination base, regional = regional operations, international = international crew base, domestic = domestic-only operations, satellite = secondary base).' ;
    rdfs:domain ind:Base ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cabinCrewCapacity rdf:type rdf:Property ;
    rdfs:label 'Cabin Crew Capacity' ;
    rdfs:comment 'Authorized headcount for cabin crew (flight attendants) assigned to this base. Used for crew planning, reserve pool sizing, and capacity management.' ;
    rdfs:domain ind:Base ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:crewCategoriesServed rdf:type rdf:Property ;
    rdfs:label 'Crew Categories Served' ;
    rdfs:comment 'Indicates which crew categories are domiciled at this base (flight_deck_only = pilots only, cabin_crew_only = flight attendants only, both = pilots and cabin crew, all = all crew types including ground crew).' ;
    rdfs:domain ind:Base ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crewTrainingFacilityAvailable rdf:type rdf:Property ;
    rdfs:label 'Crew Training Facility Available' ;
    rdfs:comment 'Indicates whether crew training facilities (simulators, classrooms, recurrent training) are available at or near this base. Impacts crew recency management and type rating maintenance.' ;
    rdfs:domain ind:Base ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:currentCabinCrewCount rdf:type rdf:Property ;
    rdfs:label 'Current Cabin Crew Count' ;
    rdfs:comment 'Current actual number of cabin crew members assigned to this base. Used to calculate staffing gaps and utilization.' ;
    rdfs:domain ind:Base ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:currentFlightDeckCount rdf:type rdf:Property ;
    rdfs:label 'Current Flight Deck Count' ;
    rdfs:comment 'Current actual number of flight deck crew members assigned to this base. Used to calculate staffing gaps and utilization.' ;
    rdfs:domain ind:Base ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deadheadPositioningAllowed rdf:type rdf:Property ;
    rdfs:label 'Deadhead Positioning Allowed' ;
    rdfs:comment 'Indicates whether crew can be deadheaded (repositioned without revenue duty) to or from this base. Used in crew positioning decisions and irregular operations recovery.' ;
    rdfs:domain ind:Base ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:flightDeckCapacity rdf:type rdf:Property ;
    rdfs:label 'Flight Deck Capacity' ;
    rdfs:comment 'Authorized headcount for flight deck crew (pilots) assigned to this base. Used for crew planning, reserve pool sizing, and capacity management.' ;
    rdfs:domain ind:Base ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ftlRegulationApplicable rdf:type rdf:Property ;
    rdfs:label 'Ftl Regulation Applicable' ;
    rdfs:comment 'Specific flight time limitations and rest requirements regulation applicable to crew based at this location (FAR_117 = US FAR Part 117, EASA_FTL = EASA Flight Time Limitations, CAP_371 = UK CAA Flight Time Limitations, other = jurisdiction-specific regulations).' ;
    rdfs:domain ind:Base ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationalTimezone rdf:type rdf:Property ;
    rdfs:label 'Operational Timezone' ;
    rdfs:comment 'IANA timezone identifier for the crew base location (e.g., \'America/New_York\', \'America/Los_Angeles\'). Used for duty period calculations, rest requirement enforcement, and fatigue risk management per FAR Part 117 and EASA FTL.' ;
    rdfs:domain ind:Base ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pairingStartEndBase rdf:type rdf:Property ;
    rdfs:label 'Pairing Start End Base' ;
    rdfs:comment 'Indicates whether this base is used as a start/end point for crew pairings. True = pairings are constructed to begin and end at this base, False = crew may be positioned but pairings do not originate here.' ;
    rdfs:domain ind:Base ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:physicalAddress rdf:type rdf:Property ;
    rdfs:label 'Physical Address' ;
    rdfs:comment 'Full physical address of the crew base operations office or crew reporting location. Used for crew reporting instructions and facility management.' ;
    rdfs:domain ind:Base ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reservePoolRequired rdf:type rdf:Property ;
    rdfs:label 'Reserve Pool Required' ;
    rdfs:comment 'Indicates whether a reserve crew pool is maintained at this base for operational contingencies, irregular operations, and last-minute crew substitutions.' ;
    rdfs:domain ind:Base ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reservePoolSizeCabin rdf:type rdf:Property ;
    rdfs:label 'Reserve Pool Size Cabin' ;
    rdfs:comment 'Target number of cabin crew members to maintain in reserve status at this base. Used for reserve pool sizing and crew resource allocation.' ;
    rdfs:domain ind:Base ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reservePoolSizeFlightDeck rdf:type rdf:Property ;
    rdfs:label 'Reserve Pool Size Flight Deck' ;
    rdfs:comment 'Target number of flight deck crew members to maintain in reserve status at this base. Used for reserve pool sizing and crew resource allocation.' ;
    rdfs:domain ind:Base ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:restFacilityAvailable rdf:type rdf:Property ;
    rdfs:label 'Rest Facility Available' ;
    rdfs:comment 'Indicates whether crew rest facilities are available at this base for pre-duty rest, post-duty rest, or reserve crew standby. Critical for fatigue risk management and crew legality checks.' ;
    rdfs:domain ind:Base ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:restFacilityCapacity rdf:type rdf:Property ;
    rdfs:label 'Rest Facility Capacity' ;
    rdfs:comment 'Maximum number of crew members that can be accommodated simultaneously in the base rest facilities. Used for reserve crew planning and irregular operations (IROP) management.' ;
    rdfs:domain ind:Base ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:restFacilityType rdf:type rdf:Property ;
    rdfs:label 'Rest Facility Type' ;
    rdfs:comment 'Type of rest facility available at the base (hotel = contracted hotel rooms, crew_lounge = airport crew lounge, dedicated_facility = airline-owned rest facility, none = no rest facility).' ;
    rdfs:domain ind:Base ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pairingId rdf:type rdf:Property ;
    rdfs:label 'Pairing Id' ;
    rdfs:comment 'Unique identifier for the crew pairing (trip or rotation). Primary key.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Pairing .

ind:cost rdf:type rdf:Property ;
    rdfs:label 'Cost' ;
    rdfs:comment 'Estimated total cost of operating this pairing, including crew pay, per diem, hotel, transportation, and deadhead costs. Used by the pairing optimizer for cost minimization.' ;
    rdfs:domain ind:Pairing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deadheadSegments rdf:type rdf:Property ;
    rdfs:label 'Deadhead Segments' ;
    rdfs:comment 'Count of deadhead (non-revenue positioning) segments in this pairing where crew travel as passengers to reposition for operational duty.' ;
    rdfs:domain ind:Pairing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:endDatetime rdf:type rdf:Property ;
    rdfs:label 'End Datetime' ;
    rdfs:comment 'The scheduled date and time when the pairing ends (crew release time at base). Represents the end of the last duty period.' ;
    rdfs:domain ind:Pairing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fatigueRiskScore rdf:type rdf:Property ;
    rdfs:label 'Fatigue Risk Score' ;
    rdfs:comment 'Calculated fatigue risk score for this pairing based on duty patterns, circadian disruption, and rest opportunities. Used in Fatigue Risk Management System (FRMS). Higher scores indicate higher fatigue risk.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:hotelCost rdf:type rdf:Property ;
    rdfs:label 'Hotel Cost' ;
    rdfs:comment 'Estimated total hotel accommodation cost for all layovers in this pairing. Used for pairing cost calculation.' ;
    rdfs:domain ind:Pairing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:internationalFlag rdf:type rdf:Property ;
    rdfs:label 'International Flag' ;
    rdfs:comment 'Indicates whether this pairing includes any international (cross-border) flight legs. True if any leg crosses international boundaries, false if all legs are domestic.' ;
    rdfs:domain ind:Pairing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:legalityStatus rdf:type rdf:Property ;
    rdfs:label 'Legality Status' ;
    rdfs:comment 'Indicates whether this pairing meets all regulatory crew duty and rest requirements (legal), violates regulations (illegal), is under review (pending_review), or has an approved waiver (waiver_approved).' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxDutyPeriodHours rdf:type rdf:Property ;
    rdfs:label 'Max Duty Period Hours' ;
    rdfs:comment 'The longest single duty period (in hours) within this pairing. Used to verify compliance with FAR Part 117 and EASA FTL maximum duty limits.' ;
    rdfs:domain ind:Pairing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minRestPeriodHours rdf:type rdf:Property ;
    rdfs:label 'Min Rest Period Hours' ;
    rdfs:comment 'The shortest rest period (in hours) within this pairing. Must meet or exceed minimum rest requirements per FAR Part 117 and EASA FTL.' ;
    rdfs:domain ind:Pairing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:numberOfDutyPeriods rdf:type rdf:Property ;
    rdfs:label 'Number Of Duty Periods' ;
    rdfs:comment 'Total count of duty periods in this pairing. A duty period is a continuous block of work time from crew report to crew release, separated by rest periods.' ;
    rdfs:domain ind:Pairing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numberOfLayovers rdf:type rdf:Property ;
    rdfs:label 'Number Of Layovers' ;
    rdfs:comment 'Total count of overnight layovers (rest periods away from base) in this pairing. Each layover occurs at an overnight station.' ;
    rdfs:domain ind:Pairing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:numberOfLegs rdf:type rdf:Property ;
    rdfs:label 'Number Of Legs' ;
    rdfs:comment 'Total count of flight legs (segments) included in this pairing. Each leg is a single takeoff-to-landing flight.' ;
    rdfs:domain ind:Pairing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:optimizationRunCode rdf:type rdf:Property ;
    rdfs:label 'Optimization Run Code' ;
    rdfs:comment 'Identifier of the specific optimization run that produced this pairing. Links pairing to the batch optimization process.' ;
    rdfs:domain ind:Pairing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:optimizerVersion rdf:type rdf:Property ;
    rdfs:label 'Optimizer Version' ;
    rdfs:comment 'Version identifier of the crew pairing optimizer software that generated this pairing. Used for audit and reproducibility.' ;
    rdfs:domain ind:Pairing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overnightStations rdf:type rdf:Property ;
    rdfs:label 'Overnight Stations' ;
    rdfs:comment 'Comma-separated list of IATA airport codes where crew have overnight layovers during this pairing (e.g., \'JFK,LAX,ORD\'). Sequence reflects pairing order.' ;
    rdfs:domain ind:Pairing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pairingCode rdf:type rdf:Property ;
    rdfs:label 'Pairing Code' ;
    rdfs:comment 'Business identifier for the pairing, externally known code used in crew scheduling and operations. Typically alphanumeric format assigned by the pairing optimizer.' ;
    rdfs:domain ind:Pairing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pairingStatus rdf:type rdf:Property ;
    rdfs:label 'Pairing Status' ;
    rdfs:comment 'Current lifecycle status of the pairing: draft (under construction), published (available for assignment), assigned (crew assigned), in_progress (currently being flown), completed (finished), cancelled (no longer valid).' ;
    rdfs:domain ind:Pairing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pairingType rdf:type rdf:Property ;
    rdfs:label 'Pairing Type' ;
    rdfs:comment 'Classification of the pairing based on route characteristics: domestic (all legs within one country), international (crosses borders), mixed (combination), reserve (standby duty), training (instructional flights), or positioning (deadhead crew movement).' ;
    rdfs:domain ind:Pairing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:perDiemAmount rdf:type rdf:Property ;
    rdfs:label 'Per Diem Amount' ;
    rdfs:comment 'Total per diem allowance payable to crew for this pairing, covering meals and incidental expenses during layovers. Calculated per CBA rules.' ;
    rdfs:domain ind:Pairing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:premiumPayFlag rdf:type rdf:Property ;
    rdfs:label 'Premium Pay Flag' ;
    rdfs:comment 'Indicates whether this pairing qualifies for premium pay under CBA rules (e.g., due to red-eye flights, long duty periods, or undesirable layovers). True if premium pay applies.' ;
    rdfs:domain ind:Pairing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:publishedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Published Timestamp' ;
    rdfs:comment 'Date and time when this pairing was published and made available for crew assignment. Nullable if pairing has not yet been published.' ;
    rdfs:domain ind:Pairing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:redEyeFlag rdf:type rdf:Property ;
    rdfs:label 'Red Eye Flag' ;
    rdfs:comment 'Indicates whether this pairing includes any red-eye (overnight) flights that operate during typical sleep hours (typically 10 PM to 6 AM). True if any leg is a red-eye flight.' ;
    rdfs:domain ind:Pairing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:startDatetime rdf:type rdf:Property ;
    rdfs:label 'Start Datetime' ;
    rdfs:comment 'The scheduled date and time when the pairing begins (crew report time at base). Represents the start of the first duty period.' ;
    rdfs:domain ind:Pairing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:timeAwayFromBaseHours rdf:type rdf:Property ;
    rdfs:label 'Time Away From Base Hours' ;
    rdfs:comment 'Total elapsed time from pairing start to pairing end, representing how long crew are away from their base. Includes duty time, rest time, and layover time. Key quality-of-life metric.' ;
    rdfs:domain ind:Pairing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalBlockHours rdf:type rdf:Property ;
    rdfs:label 'Total Block Hours' ;
    rdfs:comment 'Total flight time (block hours) accumulated across all legs in this pairing, measured from gate departure (off-blocks) to gate arrival (on-blocks). Used for crew pay and legality checks.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCreditHours rdf:type rdf:Property ;
    rdfs:label 'Total Credit Hours' ;
    rdfs:comment 'Total pay credit hours for this pairing, calculated per collective bargaining agreement rules. May differ from block hours due to minimum guarantees, premiums, and duty rigs.' ;
    rdfs:domain ind:Pairing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDutyHours rdf:type rdf:Property ;
    rdfs:label 'Total Duty Hours' ;
    rdfs:comment 'Total duty time across all duty periods in this pairing, from crew report to crew release. Includes flight time, ground time, and pre/post-flight duties. Subject to FAR Part 117 and EASA FTL limits.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalRestHours rdf:type rdf:Property ;
    rdfs:label 'Total Rest Hours' ;
    rdfs:comment 'Total rest time provided across all rest periods in this pairing. Must meet minimum rest requirements per FAR Part 117 and EASA FTL.' ;
    rdfs:domain ind:Pairing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dutyPeriodId rdf:type rdf:Property ;
    rdfs:label 'Duty Period Id' ;
    rdfs:comment 'Unique identifier for the duty period. Primary key.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DutyPeriod .

ind:dutyCostCentreId rdf:type rdf:Property ;
    rdfs:label 'Duty Cost Centre Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_centre. Business justification: Duty periods drive crew cost allocation for flight-level P&L, activity-based costing, and cost centre reporting. Supports detailed operational cost analysis and variance reporting against budget.' ;
    rdfs:domain ind:DutyPeriod ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCentre .

ind:dutyStartStationId rdf:type rdf:Property ;
    rdfs:label 'Duty Start Station Id' ;
    rdfs:comment 'Foreign key linking to airport.station. Business justification: FTL compliance reporting and crew positioning require duty periods to be formally anchored to their start station. Aviation regulators and crew control systems track where each duty period originates.' ;
    rdfs:domain ind:DutyPeriod ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Station .

ind:acclimationStatus rdf:type rdf:Property ;
    rdfs:label 'Acclimation Status' ;
    rdfs:comment 'Indicates whether the crew member is acclimated to the local time zone at duty start. Acclimated means the crew member has been in the time zone for sufficient time per FAR Part 117 definitions. Affects maximum FDP limits.' ;
    rdfs:domain ind:DutyPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualFlag rdf:type rdf:Property ;
    rdfs:label 'Actual Flag' ;
    rdfs:comment 'Indicates whether this duty period was actually operated (True) or was planned but not executed (False). Used for payroll and compliance reporting.' ;
    rdfs:domain ind:DutyPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:augmentedCrewFlag rdf:type rdf:Property ;
    rdfs:label 'Augmented Crew Flag' ;
    rdfs:comment 'Indicates whether this duty period involves augmented crew (additional crew members allowing in-flight rest). True if augmented, False otherwise. Affects maximum FDP limits.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:blockHoursMinutes rdf:type rdf:Property ;
    rdfs:label 'Block Hours Minutes' ;
    rdfs:comment 'Total block time (gate departure to gate arrival) in minutes for all flight segments within this duty period. Null for non-flight duty types.' ;
    rdfs:domain ind:DutyPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dutyEndStationCode rdf:type rdf:Property ;
    rdfs:label 'Duty End Station Code' ;
    rdfs:comment 'Three-letter IATA airport code where the duty period ends (release location).' ;
    rdfs:domain ind:DutyPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dutyPeriodNumber rdf:type rdf:Property ;
    rdfs:label 'Duty Period Number' ;
    rdfs:comment 'Sequential number of this duty period within the pairing (1, 2, 3, etc.).' ;
    rdfs:domain ind:DutyPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dutyType rdf:type rdf:Property ;
    rdfs:label 'Duty Type' ;
    rdfs:comment 'Classification of the duty period: flight duty (operating flights), ground duty (administrative/ground tasks), deadhead (crew repositioning without revenue duty), training (simulator/classroom), standby (on-call at airport), or reserve (on-call at home/hotel).' ;
    rdfs:domain ind:DutyPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:easaFtlCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Easa Ftl Compliant Flag' ;
    rdfs:comment 'Indicates whether this duty period is compliant with EASA FTL regulations. True if compliant, False if violation detected.' ;
    rdfs:domain ind:DutyPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:far117CompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Far 117 Compliant Flag' ;
    rdfs:comment 'Indicates whether this duty period is compliant with FAA FAR Part 117 flight and duty time limitations. True if compliant, False if violation detected.' ;
    rdfs:domain ind:DutyPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fatigueRiskLevel rdf:type rdf:Property ;
    rdfs:label 'Fatigue Risk Level' ;
    rdfs:comment 'Categorical fatigue risk level derived from the fatigue risk score: low (acceptable), moderate (monitor), high (mitigate), critical (unacceptable).' ;
    rdfs:domain ind:DutyPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fdpElapsedTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Fdp Elapsed Time Minutes' ;
    rdfs:comment 'Total elapsed time in minutes from FDP start to FDP end. Critical for FAR Part 117 and EASA FTL maximum FDP limit checks. Null for non-flight duty types.' ;
    rdfs:domain ind:DutyPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fdpEndTime rdf:type rdf:Property ;
    rdfs:label 'Fdp End Time' ;
    rdfs:comment 'Timestamp marking the end of the flight duty period, which ends when the aircraft finally comes to rest and the engines are shut down at the last flight segment. Null for non-flight duty types.' ;
    rdfs:domain ind:DutyPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:fdpStartTime rdf:type rdf:Property ;
    rdfs:label 'Fdp Start Time' ;
    rdfs:comment 'Timestamp marking the start of the flight duty period, which begins when a crew member is required to report for duty with the intention of conducting a flight. Null for non-flight duty types.' ;
    rdfs:domain ind:DutyPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:flightSegmentsCount rdf:type rdf:Property ;
    rdfs:label 'Flight Segments Count' ;
    rdfs:comment 'Number of flight segments (takeoff and landing cycles) operated during this duty period. Used for fatigue risk assessment. Null for non-flight duty types.' ;
    rdfs:domain ind:DutyPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:legalityViolationCodes rdf:type rdf:Property ;
    rdfs:label 'Legality Violation Codes' ;
    rdfs:comment 'Comma-separated list of violation codes if the duty period is illegal (e.g., MAX_FDP_EXCEEDED, INSUFFICIENT_REST, MAX_DUTY_EXCEEDED). Null if legal.' ;
    rdfs:domain ind:DutyPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseTime rdf:type rdf:Property ;
    rdfs:label 'Release Time' ;
    rdfs:comment 'Timestamp when the crew member is released from duty. Marks the end of the duty period.' ;
    rdfs:domain ind:DutyPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:reportTime rdf:type rdf:Property ;
    rdfs:label 'Report Time' ;
    rdfs:comment 'Timestamp when the crew member is required to report for duty. Marks the start of the duty period.' ;
    rdfs:domain ind:DutyPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:restPeriodAfterMinutes rdf:type rdf:Property ;
    rdfs:label 'Rest Period After Minutes' ;
    rdfs:comment 'Duration in minutes of the rest period immediately following this duty period. Used to verify minimum rest requirements per FAR Part 117 and EASA FTL.' ;
    rdfs:domain ind:DutyPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:restPeriodBeforeMinutes rdf:type rdf:Property ;
    rdfs:label 'Rest Period Before Minutes' ;
    rdfs:comment 'Duration in minutes of the rest period immediately preceding this duty period. Used to verify minimum rest requirements per FAR Part 117 and EASA FTL.' ;
    rdfs:domain ind:DutyPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:scheduledFlag rdf:type rdf:Property ;
    rdfs:label 'Scheduled Flag' ;
    rdfs:comment 'Indicates whether this duty period was part of the original published schedule (True) or was added/modified after publication (False). Used for operational performance tracking.' ;
    rdfs:domain ind:DutyPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:splitDutyFlag rdf:type rdf:Property ;
    rdfs:label 'Split Duty Flag' ;
    rdfs:comment 'Indicates whether this duty period qualifies as split duty (duty period interrupted by a rest opportunity). True if split duty, False otherwise. Affects FDP extension calculations.' ;
    rdfs:domain ind:DutyPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:splitDutyRestMinutes rdf:type rdf:Property ;
    rdfs:label 'Split Duty Rest Minutes' ;
    rdfs:comment 'Duration in minutes of the rest opportunity during a split duty period. Null if not a split duty. Used to calculate FDP extensions.' ;
    rdfs:domain ind:DutyPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:timeZoneCrossingsCount rdf:type rdf:Property ;
    rdfs:label 'Time Zone Crossings Count' ;
    rdfs:comment 'Number of time zones crossed during this duty period. Used for fatigue risk and circadian disruption assessment.' ;
    rdfs:domain ind:DutyPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:timeZoneEnd rdf:type rdf:Property ;
    rdfs:label 'Time Zone End' ;
    rdfs:comment 'IANA time zone identifier for the duty end station (e.g., Europe/London). Used for circadian rhythm and fatigue risk calculations.' ;
    rdfs:domain ind:DutyPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeZoneStart rdf:type rdf:Property ;
    rdfs:label 'Time Zone Start' ;
    rdfs:comment 'IANA time zone identifier for the duty start station (e.g., America/New_York). Used for circadian rhythm and fatigue risk calculations.' ;
    rdfs:domain ind:DutyPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalDutyElapsedTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Total Duty Elapsed Time Minutes' ;
    rdfs:comment 'Total elapsed time in minutes from report time to release time. Used for FAR Part 117 and EASA FTL compliance calculations.' ;
    rdfs:domain ind:DutyPeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rosterId rdf:type rdf:Property ;
    rdfs:label 'Roster Id' ;
    rdfs:comment 'Unique identifier for the crew roster record. Primary key.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Roster .

ind:bidPeriodMonth rdf:type rdf:Property ;
    rdfs:label 'Bid Period Month' ;
    rdfs:comment 'The month component of the bid period for which this roster is published (1-12).' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:bidPeriodYear rdf:type rdf:Property ;
    rdfs:label 'Bid Period Year' ;
    rdfs:comment 'The year component of the bid period for which this roster is published (e.g., 2024).' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:daysOffCount rdf:type rdf:Property ;
    rdfs:label 'Days Off Count' ;
    rdfs:comment 'Total number of days off (rest days, leave days) scheduled in this roster period. Used for union compliance and crew rest verification.' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deadheadSegmentsCount rdf:type rdf:Property ;
    rdfs:label 'Deadhead Segments Count' ;
    rdfs:comment 'Number of deadhead positioning segments (crew repositioning flights without duty) included in this roster.' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:leaveDaysCount rdf:type rdf:Property ;
    rdfs:label 'Leave Days Count' ;
    rdfs:comment 'Number of approved leave days (vacation, sick leave, personal leave) included in this roster period.' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:legalityCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Legality Check Status' ;
    rdfs:comment 'Result of automated legality checks against FAR Part 117, EASA FTL, and CBA rules. Passed indicates roster is compliant; failed indicates violations; warning indicates potential issues.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalityCheckTimestamp rdf:type rdf:Property ;
    rdfs:label 'Legality Check Timestamp' ;
    rdfs:comment 'Timestamp when the most recent legality check was performed on this roster.' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:pbsAwardReference rdf:type rdf:Property ;
    rdfs:label 'Pbs Award Reference' ;
    rdfs:comment 'Reference identifier to the PBS award or bid result that generated this roster, if applicable. Empty if roster was manually constructed or assigned outside PBS.' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:publicationDate rdf:type rdf:Property ;
    rdfs:label 'Publication Date' ;
    rdfs:comment 'The date on which this roster version was officially published to the crew member.' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reserveDaysCount rdf:type rdf:Property ;
    rdfs:label 'Reserve Days Count' ;
    rdfs:comment 'Total number of days the crew member is assigned to reserve or standby duty in this roster period.' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rosterSource rdf:type rdf:Property ;
    rdfs:label 'Roster Source' ;
    rdfs:comment 'The method or system by which this roster was generated. PBS indicates Preferential Bidding System; manual indicates crew scheduler assignment; optimization indicates automated optimizer; crew_request indicates crew-initiated swap or change.' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rosterStatus rdf:type rdf:Property ;
    rdfs:label 'Roster Status' ;
    rdfs:comment 'Current lifecycle status of the roster. Draft indicates preliminary assignment; published indicates official release; revised indicates changes after publication; frozen indicates locked for payroll; cancelled indicates roster voided.' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCreditedBlockHours rdf:type rdf:Property ;
    rdfs:label 'Total Credited Block Hours' ;
    rdfs:comment 'Total block hours (gate-to-gate flight time) credited to the crew member for this roster period. Used for pay calculation and regulatory compliance.' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDutyDays rdf:type rdf:Property ;
    rdfs:label 'Total Duty Days' ;
    rdfs:comment 'Total number of days in the roster period on which the crew member has assigned duty (flight, training, standby, or other duty).' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalFlightDutyPeriods rdf:type rdf:Property ;
    rdfs:label 'Total Flight Duty Periods' ;
    rdfs:comment 'Total number of flight duty periods (FDPs) assigned in this roster. An FDP is a continuous duty period that includes one or more flight segments.' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:trainingEventsCount rdf:type rdf:Property ;
    rdfs:label 'Training Events Count' ;
    rdfs:comment 'Number of training events (simulator sessions, recurrent training, line checks) scheduled in this roster period.' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:unionComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Union Compliance Flag' ;
    rdfs:comment 'Boolean flag indicating whether this roster complies with all applicable Collective Bargaining Agreement (CBA) rules. True indicates compliance; false indicates violations.' ;
    rdfs:domain ind:Roster ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rosterActivityId rdf:type rdf:Property ;
    rdfs:label 'Roster Activity Id' ;
    rdfs:comment 'Unique identifier for the roster activity line item. Primary key.' ;
    rdfs:domain ind:RosterActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primaryRosterMemberId rdf:type rdf:Property ;
    rdfs:label 'Primary Roster Member Id' ;
    rdfs:comment 'Reference to the crew member assigned to this roster activity.' ;
    rdfs:domain ind:RosterActivity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Member .

ind:tertiaryRosterSwapReceivingCrewMemberId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Roster Swap Receiving Crew Member Id' ;
    rdfs:comment 'Reference to the crew member who accepted or was assigned to take over this activity in a swap. Null if no swap occurred.' ;
    rdfs:domain ind:RosterActivity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Member .

ind:triggeredFlightLegId rdf:type rdf:Property ;
    rdfs:label 'Triggered Flight Leg Id' ;
    rdfs:comment 'Reference to the flight leg that the standby crew member was assigned to upon activation. Null if not activated or for non-standby activities.' ;
    rdfs:domain ind:RosterActivity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FlightLeg .

ind:activityStatus rdf:type rdf:Property ;
    rdfs:label 'Activity Status' ;
    rdfs:comment 'Current lifecycle status of the roster activity.' ;
    rdfs:domain ind:RosterActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:activityType rdf:type rdf:Property ;
    rdfs:label 'Activity Type' ;
    rdfs:comment 'Type of roster activity assigned to the crew member. [ENUM-REF-CANDIDATE: pairing|training|standby|day_off|deadhead|leave|ground_duty|medical|administrative|union|vacation|sick_leave|personal_leave|jury_duty|bereavement|simulator|classroom|line_check|proficiency_check|recurrent_training|initial_training|transition_training|upgrade_training|airport_standby|home_standby|hot_standby|cold_standby|office_duty|meeting|project_work — promote to reference product]' ;
    rdfs:domain ind:RosterActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualEndDatetime rdf:type rdf:Property ;
    rdfs:label 'Actual End Datetime' ;
    rdfs:comment 'Actual end date and time when the crew member completed the activity in UTC. Null if activity has not completed or was cancelled.' ;
    rdfs:domain ind:RosterActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualStartDatetime rdf:type rdf:Property ;
    rdfs:label 'Actual Start Datetime' ;
    rdfs:comment 'Actual start date and time when the crew member commenced the activity in UTC. Null if activity has not started or was cancelled.' ;
    rdfs:domain ind:RosterActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:createdDatetime rdf:type rdf:Property ;
    rdfs:label 'Created Datetime' ;
    rdfs:comment 'Date and time when this roster activity record was first created in the system.' ;
    rdfs:domain ind:RosterActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:creditHours rdf:type rdf:Property ;
    rdfs:label 'Credit Hours' ;
    rdfs:comment 'Number of credit hours assigned to this activity for crew pay and scheduling purposes. Calculated based on block hours, duty hours, or contractual rules depending on activity type.' ;
    rdfs:domain ind:RosterActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:deadheadFlag rdf:type rdf:Property ;
    rdfs:label 'Deadhead Flag' ;
    rdfs:comment 'Indicates whether this activity involves deadhead crew repositioning (crew traveling as passengers to position for a duty assignment). True for deadhead activities; false otherwise.' ;
    rdfs:domain ind:RosterActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dutyHours rdf:type rdf:Property ;
    rdfs:label 'Duty Hours' ;
    rdfs:comment 'Total duty hours for this activity, calculated from check-in to release time for pairings, or scheduled duration for other duty activities. Used for FAR Part 117 and EASA FTL compliance.' ;
    rdfs:domain ind:RosterActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:iropRelatedFlag rdf:type rdf:Property ;
    rdfs:label 'Irop Related Flag' ;
    rdfs:comment 'Indicates whether this roster activity was created or modified as a result of irregular operations (flight delays, cancellations, crew recovery). True if IROP-related; false for normal scheduled activities.' ;
    rdfs:domain ind:RosterActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastModifiedDatetime rdf:type rdf:Property ;
    rdfs:label 'Last Modified Datetime' ;
    rdfs:comment 'Date and time when this roster activity record was last modified. Used for audit trail and roster change tracking.' ;
    rdfs:domain ind:RosterActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:leaveType rdf:type rdf:Property ;
    rdfs:label 'Leave Type' ;
    rdfs:comment 'Type of leave if activity_type is leave. Vacation is planned time off; sick is illness-related absence; personal is discretionary leave; medical is extended medical leave; bereavement is compassionate leave; jury_duty is civic duty. Null for non-leave activities.' ;
    rdfs:domain ind:RosterActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalityViolationCode rdf:type rdf:Property ;
    rdfs:label 'Legality Violation Code' ;
    rdfs:comment 'Code identifying the specific regulation or rule violated if legality_check_status is illegal or warning. Examples: FDP_EXCEEDED (flight duty period limit), REST_INSUFFICIENT (minimum rest not met), RECENCY_EXPIRED (currency requirement lapsed). Null if legal or not checked.' ;
    rdfs:domain ind:RosterActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rosterPublishDatetime rdf:type rdf:Property ;
    rdfs:label 'Roster Publish Datetime' ;
    rdfs:comment 'Date and time when the roster containing this activity was published to the crew member. Used to track roster stability and last-minute changes.' ;
    rdfs:domain ind:RosterActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledEndDatetime rdf:type rdf:Property ;
    rdfs:label 'Scheduled End Datetime' ;
    rdfs:comment 'Scheduled end date and time of the roster activity in UTC. Represents the conclusion of the duty period, training session, standby window, or leave period.' ;
    rdfs:domain ind:RosterActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledStartDatetime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Start Datetime' ;
    rdfs:comment 'Scheduled start date and time of the roster activity in UTC. Represents the beginning of the duty period, training session, standby window, or leave period.' ;
    rdfs:domain ind:RosterActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:standbyActivationDatetime rdf:type rdf:Property ;
    rdfs:label 'Standby Activation Datetime' ;
    rdfs:comment 'Date and time when the standby crew member was activated and assigned to a flight. Null if not activated or for non-standby activities.' ;
    rdfs:domain ind:RosterActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:standbyActivationStatus rdf:type rdf:Property ;
    rdfs:label 'Standby Activation Status' ;
    rdfs:comment 'Indicates whether the standby crew member was activated for a flight assignment. Not_activated means crew remained on standby; activated means crew was called out; released means standby period ended without activation. Null for non-standby activities.' ;
    rdfs:domain ind:RosterActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:standbyContactEndTime rdf:type rdf:Property ;
    rdfs:label 'Standby Contact End Time' ;
    rdfs:comment 'End of the contact window during which crew on standby must be reachable. Null for non-standby activities.' ;
    rdfs:domain ind:RosterActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:standbyContactStartTime rdf:type rdf:Property ;
    rdfs:label 'Standby Contact Start Time' ;
    rdfs:comment 'Start of the contact window during which crew on standby must be reachable. Null for non-standby activities.' ;
    rdfs:domain ind:RosterActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:standbyType rdf:type rdf:Property ;
    rdfs:label 'Standby Type' ;
    rdfs:comment 'Type of standby duty if activity_type is standby. Airport standby requires crew to be at the airport; home standby allows crew to remain at home; hot standby requires immediate availability; cold standby allows longer call-out time. Null for non-standby activities.' ;
    rdfs:domain ind:RosterActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:swapApprovalDatetime rdf:type rdf:Property ;
    rdfs:label 'Swap Approval Datetime' ;
    rdfs:comment 'Date and time when the swap was approved. Null if swap not approved or no swap occurred.' ;
    rdfs:domain ind:RosterActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:swapApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Swap Approval Status' ;
    rdfs:comment 'Approval status of the swap request. Pending indicates awaiting management approval; approved means swap is confirmed; rejected means swap was denied; cancelled means swap request was withdrawn. Null if no swap was requested.' ;
    rdfs:domain ind:RosterActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:swapRequestedFlag rdf:type rdf:Property ;
    rdfs:label 'Swap Requested Flag' ;
    rdfs:comment 'Indicates whether this activity has been requested for swap by the assigned crew member. True if swap request is pending or approved; false otherwise.' ;
    rdfs:domain ind:RosterActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:trainingType rdf:type rdf:Property ;
    rdfs:label 'Training Type' ;
    rdfs:comment 'Type of training if activity_type is training. Simulator is flight simulator session; classroom is ground school; line_check is operational proficiency check; recurrent is periodic requalification; initial is new-hire or type-rating training. Null for non-training activities. [ENUM-REF-CANDIDATE: simulator|classroom|line_check|recurrent|initial|transition|upgrade|proficiency_check|emergency_procedures|differences_training|cbt|elearning — promote to reference product]' ;
    rdfs:domain ind:RosterActivity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flightLegAssignmentId rdf:type rdf:Property ;
    rdfs:label 'Flight Leg Assignment Id' ;
    rdfs:comment 'Unique identifier for the flight leg assignment record. Primary key for the operational assignment of a crew member to a specific flight leg.' ;
    rdfs:domain ind:FlightLegAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deadheadFareClassBucketId rdf:type rdf:Property ;
    rdfs:label 'Deadhead Fare Class Bucket Id' ;
    rdfs:comment 'Foreign key linking to inventory.fare_class_bucket. Business justification: Deadhead crew are booked into specific fare class buckets (e.g., ZB crew booking class) that consume inventory. Crew travel management and revenue management must track which fare_class_bucket is cons' ;
    rdfs:domain ind:FlightLegAssignment ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FareClassBucket .

ind:actualCheckinTime rdf:type rdf:Property ;
    rdfs:label 'Actual Checkin Time' ;
    rdfs:comment 'The actual time the crew member checked in for duty, as recorded by crew tracking systems or airport operations.' ;
    rdfs:domain ind:FlightLegAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assignmentCancelledTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assignment Cancelled Timestamp' ;
    rdfs:comment 'Date and time when this assignment was cancelled, if applicable.' ;
    rdfs:domain ind:FlightLegAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assignmentCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assignment Created Timestamp' ;
    rdfs:comment 'Date and time when this assignment record was first created in the crew management system.' ;
    rdfs:domain ind:FlightLegAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:assignmentModifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Assignment Modified Timestamp' ;
    rdfs:comment 'Date and time when this assignment record was last modified.' ;
    rdfs:domain ind:FlightLegAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:crewAcknowledgementFlag rdf:type rdf:Property ;
    rdfs:label 'Crew Acknowledgement Flag' ;
    rdfs:comment 'Indicates whether the crew member has acknowledged receipt and acceptance of this assignment via crew portal or mobile app.' ;
    rdfs:domain ind:FlightLegAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crewAcknowledgementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Crew Acknowledgement Timestamp' ;
    rdfs:comment 'Date and time when the crew member acknowledged the assignment.' ;
    rdfs:domain ind:FlightLegAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:crewPositionCode rdf:type rdf:Property ;
    rdfs:label 'Crew Position Code' ;
    rdfs:comment 'The assigned crew position for this flight leg. CA=Captain, FO=First Officer, SO=Second Officer, CP=Cruise Pilot, FA=Flight Attendant, PS=Purser, LD=Lead Flight Attendant, GS=Galley Supervisor. Applicable for operating assignments. [ENUM-REF-CANDIDATE: CA|FO|SO|CP|FA|PS|LD|GS — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deadheadReason rdf:type rdf:Property ;
    rdfs:label 'Deadhead Reason' ;
    rdfs:comment 'The business reason for deadhead positioning. Applicable only when assignment_type is deadhead. Pairing_start/end=crew repositioning for duty sequence, IROP_recovery=irregular operations recovery, Training=training event travel.' ;
    rdfs:domain ind:FlightLegAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deadheadSeatNumber rdf:type rdf:Property ;
    rdfs:label 'Deadhead Seat Number' ;
    rdfs:comment 'The assigned seat number for deadhead crew travel (e.g., 12A, 23F). Applicable only for deadhead assignments.' ;
    rdfs:domain ind:FlightLegAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideApprovedBy rdf:type rdf:Property ;
    rdfs:label 'Override Approved By' ;
    rdfs:comment 'Name or identifier of the authorized person (e.g., crew scheduler, chief pilot, operations manager) who approved the override.' ;
    rdfs:domain ind:FlightLegAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideTimestamp rdf:type rdf:Property ;
    rdfs:label 'Override Timestamp' ;
    rdfs:comment 'Date and time when the override was approved.' ;
    rdfs:domain ind:FlightLegAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:ownMetalFlag rdf:type rdf:Property ;
    rdfs:label 'Own Metal Flag' ;
    rdfs:comment 'Indicates whether the deadhead travel is on the airline\'s own aircraft (true) or on another carrier via interline agreement (false). Applicable for deadhead assignments.' ;
    rdfs:domain ind:FlightLegAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualificationCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Qualification Check Status' ;
    rdfs:comment 'Result of automated qualification and legality checks for this assignment. Indicates whether crew member meets all type ratings, recency, and regulatory requirements for the assigned position and aircraft.' ;
    rdfs:domain ind:FlightLegAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reliefCrewFlag rdf:type rdf:Property ;
    rdfs:label 'Relief Crew Flag' ;
    rdfs:comment 'Indicates whether this crew member is assigned as relief crew for in-flight rest rotation on long-haul flights.' ;
    rdfs:domain ind:FlightLegAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:reserveCalloutTime rdf:type rdf:Property ;
    rdfs:label 'Reserve Callout Time' ;
    rdfs:comment 'The time the reserve crew member was called out for this assignment. Applicable only when assignment_source is reserve.' ;
    rdfs:domain ind:FlightLegAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledCheckinTime rdf:type rdf:Property ;
    rdfs:label 'Scheduled Checkin Time' ;
    rdfs:comment 'The planned time the crew member is required to check in for duty prior to the flight leg, per crew scheduling rules and regulatory requirements.' ;
    rdfs:domain ind:FlightLegAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:scheduledReportLocation rdf:type rdf:Property ;
    rdfs:label 'Scheduled Report Location' ;
    rdfs:comment 'The designated location where the crew member is scheduled to report for duty (e.g., crew room, gate, operations center).' ;
    rdfs:domain ind:FlightLegAssignment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ftlLegalityCheckId rdf:type rdf:Property ;
    rdfs:label 'Ftl Legality Check Id' ;
    rdfs:comment 'Unique identifier for the FTL legality check record. Primary key.' ;
    rdfs:domain ind:FtlLegalityCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:approvingAuthority rdf:type rdf:Property ;
    rdfs:label 'Approving Authority' ;
    rdfs:comment 'Name or identifier of the authority who approved the check result, waiver, or mitigation (e.g., Crew Control Manager, Chief Pilot, Duty Manager). Nullable for automated pass results.' ;
    rdfs:domain ind:FtlLegalityCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assessmentMethod rdf:type rdf:Property ;
    rdfs:label 'Assessment Method' ;
    rdfs:comment 'Method used for the fitness assessment: regulatory_rule (FAR Part 117, EASA FTL rule-based check) or biomathematical_model (SAFE, FAID, FRMS model-based fatigue risk assessment).' ;
    rdfs:domain ind:FtlLegalityCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkNotes rdf:type rdf:Property ;
    rdfs:label 'Check Notes' ;
    rdfs:comment 'Free-text notes or comments regarding the legality check, including rationale for waivers, mitigation details, or special circumstances. Nullable if no additional context required.' ;
    rdfs:domain ind:FtlLegalityCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:checkTrigger rdf:type rdf:Property ;
    rdfs:label 'Check Trigger' ;
    rdfs:comment 'Event or condition that triggered the legality check: pre-assignment (during rostering), pre-departure (gate check), post-duty (compliance audit), IROP extension (irregular operations duty extension request), manual audit, or scheduled review.' ;
    rdfs:domain ind:FtlLegalityCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fatigueRiskBand rdf:type rdf:Property ;
    rdfs:label 'Fatigue Risk Band' ;
    rdfs:comment 'Categorical fatigue risk band derived from the fatigue score: low, moderate, elevated, high, or critical. Nullable for regulatory rule-based checks.' ;
    rdfs:domain ind:FtlLegalityCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fatigueScore rdf:type rdf:Property ;
    rdfs:label 'Fatigue Score' ;
    rdfs:comment 'Numeric fatigue risk score generated by the biomathematical model (e.g., SAFE effectiveness score, FAID fatigue index). Nullable for regulatory rule-based checks.' ;
    rdfs:domain ind:FtlLegalityCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fdpActualHours rdf:type rdf:Property ;
    rdfs:label 'Fdp Actual Hours' ;
    rdfs:comment 'Actual or projected FDP duration in hours for the duty period being evaluated.' ;
    rdfs:domain ind:FtlLegalityCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fdpLimitHours rdf:type rdf:Property ;
    rdfs:label 'Fdp Limit Hours' ;
    rdfs:comment 'Maximum allowable FDP duration in hours per the applicable regulation, adjusted for number of sectors, time of day, and crew augmentation.' ;
    rdfs:domain ind:FtlLegalityCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fitnessResult rdf:type rdf:Property ;
    rdfs:label 'Fitness Result' ;
    rdfs:comment 'Overall fitness-to-operate result: legal (crew is legal and fit), illegal (crew exceeds FTL limits), waiver_granted (regulatory waiver issued for non-compliance), or elevated_risk_accepted (biomathematical model shows elevated risk but accepted with mitigation).' ;
    rdfs:domain ind:FtlLegalityCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:flightTime28Day rdf:type rdf:Property ;
    rdfs:label 'Flight Time 28 Day' ;
    rdfs:comment 'Cumulative flight time in hours for the crew member over the preceding 28-day rolling window at the time of check.' ;
    rdfs:domain ind:FtlLegalityCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:flightTime365Day rdf:type rdf:Property ;
    rdfs:label 'Flight Time 365 Day' ;
    rdfs:comment 'Cumulative flight time in hours for the crew member over the preceding 365-day rolling window at the time of check.' ;
    rdfs:domain ind:FtlLegalityCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mitigationApplied rdf:type rdf:Property ;
    rdfs:label 'Mitigation Applied' ;
    rdfs:comment 'Description of any mitigation measures applied to address elevated fatigue risk or legality concerns (e.g., crew augmentation, duty period reduction, additional rest, flight reassignment). Nullable if no mitigation required.' ;
    rdfs:domain ind:FtlLegalityCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Rest Compliance Status' ;
    rdfs:comment 'Status of rest period compliance: compliant (meets minimum), non_compliant (below minimum), reduced_rest_approved (approved reduced rest per regulation), or waiver_granted (regulatory waiver issued).' ;
    rdfs:domain ind:FtlLegalityCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:restPeriodActualHours rdf:type rdf:Property ;
    rdfs:label 'Rest Period Actual Hours' ;
    rdfs:comment 'Actual rest period in hours provided or projected before the next duty period.' ;
    rdfs:domain ind:FtlLegalityCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:restPeriodRequiredHours rdf:type rdf:Property ;
    rdfs:label 'Rest Period Required Hours' ;
    rdfs:comment 'Minimum rest period required in hours before the next duty period per applicable regulation.' ;
    rdfs:domain ind:FtlLegalityCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:systemSource rdf:type rdf:Property ;
    rdfs:label 'System Source' ;
    rdfs:comment 'Source system or module that generated the legality check record (e.g., AIMS Crew Management System, SAFE Model Engine, FAID Quantum, Manual Entry).' ;
    rdfs:domain ind:FtlLegalityCheck ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineTrainingFlightInventoryId rdf:type rdf:Property ;
    rdfs:label 'Line Training Flight Inventory Id' ;
    rdfs:comment 'Foreign key linking to inventory.flight_inventory. Business justification: Line training and Operating Experience (OE) events occur on revenue flights, consuming a crew seat in flight_inventory. Airlines must track which revenue flight inventory record supports each line che' ;
    rdfs:domain ind:TrainingEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FlightInventory .

ind:primaryTrainingMemberId rdf:type rdf:Property ;
    rdfs:label 'Primary Training Member Id' ;
    rdfs:comment 'Identifier of the crew member who participated in this training event.' ;
    rdfs:domain ind:TrainingEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Member .

ind:trainingAircraftId rdf:type rdf:Property ;
    rdfs:label 'Training Aircraft Id' ;
    rdfs:comment 'Foreign key linking to fleet.aircraft. Business justification: Line checks and OE (operating experience) flights require recording the specific tail number used. Regulatory authorities (FAA, EASA) require tail-specific traceability for line check records. The exi' ;
    rdfs:domain ind:TrainingEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Aircraft .

ind:trainingCostCentreId rdf:type rdf:Property ;
    rdfs:label 'Training Cost Centre Id' ;
    rdfs:comment 'Foreign key linking to finance.cost_centre. Business justification: Training events are significant cost items allocated to training cost centres for budget tracking, cost recovery, and regulatory compliance reporting. Essential for training cost management and financ' ;
    rdfs:domain ind:TrainingEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CostCentre .

ind:trainingStationId rdf:type rdf:Property ;
    rdfs:label 'Training Station Id' ;
    rdfs:comment 'Foreign key linking to airport.station. Business justification: Training events occur at stations with training facilities (simulators, classrooms). Required for training logistics planning, crew travel arrangements, and facility capacity management. Replaces deno' ;
    rdfs:domain ind:TrainingEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Station .

ind:bookingReference rdf:type rdf:Property ;
    rdfs:label 'Booking Reference' ;
    rdfs:comment 'Booking or reservation reference number for the training event, used for scheduling and resource allocation.' ;
    rdfs:domain ind:TrainingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationNumber rdf:type rdf:Property ;
    rdfs:label 'Certification Number' ;
    rdfs:comment 'Certificate or credential number issued upon successful completion of the training event.' ;
    rdfs:domain ind:TrainingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:instructorName rdf:type rdf:Property ;
    rdfs:label 'Instructor Name' ;
    rdfs:comment 'Full name of the instructor or examiner who conducted the training event.' ;
    rdfs:domain ind:TrainingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRegulatoryRequired rdf:type rdf:Property ;
    rdfs:label 'Is Regulatory Required' ;
    rdfs:comment 'Flag indicating whether this training event is mandated by regulatory authority (FAA, EASA) or is voluntary/company-initiated.' ;
    rdfs:domain ind:TrainingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:passThresholdScore rdf:type rdf:Property ;
    rdfs:label 'Pass Threshold Score' ;
    rdfs:comment 'Minimum score required to pass the training event, if applicable.' ;
    rdfs:domain ind:TrainingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:scheduledDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Date' ;
    rdfs:comment 'Originally scheduled date for the training event, which may differ from actual training_date if rescheduled.' ;
    rdfs:domain ind:TrainingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:simulatorDeviceCode rdf:type rdf:Property ;
    rdfs:label 'Simulator Device Code' ;
    rdfs:comment 'Identifier of the flight simulator or training device used for the training event. Null for non-simulator training.' ;
    rdfs:domain ind:TrainingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingCategory rdf:type rdf:Property ;
    rdfs:label 'Training Category' ;
    rdfs:comment 'Category of training event. INITIAL=First-time qualification, RECURRENT=Periodic revalidation, UPGRADE=Promotion to higher position, TRANSITION=Change to different aircraft type, REQUALIFICATION=Return after lapse, REFRESHER=Skill maintenance.' ;
    rdfs:domain ind:TrainingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingCostAmount rdf:type rdf:Property ;
    rdfs:label 'Training Cost Amount' ;
    rdfs:comment 'Total cost incurred for this training event, including instructor fees, simulator time, materials, and facility charges.' ;
    rdfs:domain ind:TrainingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingCostCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Training Cost Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the training cost amount.' ;
    rdfs:domain ind:TrainingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingDate rdf:type rdf:Property ;
    rdfs:label 'Training Date' ;
    rdfs:comment 'Date on which the training event occurred or was completed.' ;
    rdfs:domain ind:TrainingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:trainingDurationHours rdf:type rdf:Property ;
    rdfs:label 'Training Duration Hours' ;
    rdfs:comment 'Total duration of the training event in hours.' ;
    rdfs:domain ind:TrainingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Training End Timestamp' ;
    rdfs:comment 'Timestamp when the training session ended.' ;
    rdfs:domain ind:TrainingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:trainingMethod rdf:type rdf:Property ;
    rdfs:label 'Training Method' ;
    rdfs:comment 'Method by which the training was delivered. SIMULATOR=Flight simulator session, CLASSROOM=In-person classroom, CBT=Computer-Based Training, LINE=Line operational training, PRACTICAL=Hands-on practical, ONLINE=Remote online training.' ;
    rdfs:domain ind:TrainingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingResultCode rdf:type rdf:Property ;
    rdfs:label 'Training Result Code' ;
    rdfs:comment 'Outcome of the training event. PASS=Successfully completed, FAIL=Did not meet standards, INCOMPLETE=Not finished, PARTIAL=Partially completed, DEFERRED=Postponed, CANCELLED=Event cancelled.' ;
    rdfs:domain ind:TrainingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingScore rdf:type rdf:Property ;
    rdfs:label 'Training Score' ;
    rdfs:comment 'Numerical score or grade achieved in the training event, if applicable. Null for pass/fail only training.' ;
    rdfs:domain ind:TrainingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trainingStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Training Start Timestamp' ;
    rdfs:comment 'Timestamp when the training session began.' ;
    rdfs:domain ind:TrainingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:trainingStatus rdf:type rdf:Property ;
    rdfs:label 'Training Status' ;
    rdfs:comment 'Current status of the training event in its lifecycle. SCHEDULED=Planned but not started, IN_PROGRESS=Currently underway, COMPLETED=Finished, CANCELLED=Event cancelled, NO_SHOW=Crew member did not attend.' ;
    rdfs:domain ind:TrainingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingSyllabusVersion rdf:type rdf:Property ;
    rdfs:label 'Training Syllabus Version' ;
    rdfs:comment 'Version identifier of the training syllabus or curriculum used for this event.' ;
    rdfs:domain ind:TrainingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:trainingTypeCode rdf:type rdf:Property ;
    rdfs:label 'Training Type Code' ;
    rdfs:comment 'Code representing the type of training event. PC=Proficiency Check, OPC=Operator Proficiency Check, LOE=Line Operational Evaluation, EPT=Emergency Procedures Training, CRM=Crew Resource Management, ETOPS=Extended-range Twin-engine Operational Performance Standards, DG=Dangerous Goods, SEC=Security Training, GND=Ground Training, DIFF=Differences Training, RECUR=Recurrent Training. [ENUM-REF-CANDIDATE: PC|OPC|LOE|EPT|CRM|ETOPS|DG|SEC|GND|DIFF|RECUR — 11 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:TrainingEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:medicalCertificateId rdf:type rdf:Property ;
    rdfs:label 'Medical Certificate Id' ;
    rdfs:comment 'Unique identifier for the crew medical certificate record. Primary key.' ;
    rdfs:domain ind:Crew ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MedicalCertificate .

ind:certificateClass rdf:type rdf:Property ;
    rdfs:label 'Certificate Class' ;
    rdfs:comment 'ICAO medical certificate class. Class 1 for airline transport pilots and commercial pilots, Class 2 for private pilots and cabin crew, Class 3 for air traffic controllers.' ;
    rdfs:domain ind:MedicalCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateNumber rdf:type rdf:Property ;
    rdfs:label 'Certificate Number' ;
    rdfs:comment 'Unique certificate number issued by the Aviation Medical Examiner (AME) or Designated Aviation Medical Examiner (DAME). Official identifier for regulatory tracking.' ;
    rdfs:domain ind:MedicalCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateType rdf:type rdf:Property ;
    rdfs:label 'Certificate Type' ;
    rdfs:comment 'Type of medical certificate issuance. Initial for first-time, Renewal for standard periodic renewal, Revalidation for extension, Special Issuance for conditional approval with limitations or waivers.' ;
    rdfs:domain ind:MedicalCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:documentReferenceUrl rdf:type rdf:Property ;
    rdfs:label 'Document Reference Url' ;
    rdfs:comment 'URL or file path reference to the scanned or digital copy of the physical medical certificate document stored in the document management system.' ;
    rdfs:domain ind:MedicalCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:examinationDate rdf:type rdf:Property ;
    rdfs:label 'Examination Date' ;
    rdfs:comment 'Date the crew member underwent the medical examination that resulted in this certificate issuance. May differ from issue date if additional review or approval was required.' ;
    rdfs:domain ind:MedicalCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:examinationType rdf:type rdf:Property ;
    rdfs:label 'Examination Type' ;
    rdfs:comment 'Type of medical examination conducted. Standard for routine periodic examinations, Extended for comprehensive examinations with additional tests, Special for examinations required due to medical events or regulatory requests.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hearingAidRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Hearing Aid Required Flag' ;
    rdfs:comment 'Indicates whether the crew member requires a hearing aid to meet hearing standards. True if hearing aid is required, False otherwise.' ;
    rdfs:domain ind:MedicalCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:issuingAuthorityLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority License Number' ;
    rdfs:comment 'License or designation number of the Aviation Medical Examiner (AME) or Designated Aviation Medical Examiner (DAME) who issued the certificate. Used for regulatory verification.' ;
    rdfs:domain ind:MedicalCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingAuthorityName rdf:type rdf:Property ;
    rdfs:label 'Issuing Authority Name' ;
    rdfs:comment 'Name of the Aviation Medical Examiner (AME) or Designated Aviation Medical Examiner (DAME) who issued the certificate.' ;
    rdfs:domain ind:MedicalCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limitations rdf:type rdf:Property ;
    rdfs:label 'Limitations' ;
    rdfs:comment 'Any operational limitations or restrictions imposed on the crew member as a condition of the medical certificate. Examples include corrective lenses required, valid only with co-pilot, daytime operations only, or specific medical monitoring requirements.' ;
    rdfs:domain ind:MedicalCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextExaminationDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Examination Due Date' ;
    rdfs:comment 'Date by which the crew member must undergo the next medical examination to maintain continuous medical certification. Used for proactive crew scheduling and compliance planning.' ;
    rdfs:domain ind:MedicalCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:specialIssuanceFlag rdf:type rdf:Property ;
    rdfs:label 'Special Issuance Flag' ;
    rdfs:comment 'Indicates whether this certificate was issued under special issuance provisions due to a medical condition that does not meet standard requirements but has been granted a waiver or authorization. True if special issuance, False for standard issuance.' ;
    rdfs:domain ind:MedicalCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:validityStatus rdf:type rdf:Property ;
    rdfs:label 'Validity Status' ;
    rdfs:comment 'Current validity status of the medical certificate. Valid indicates the certificate is active and within its validity period. Expired indicates the certificate has passed its expiry date. Suspended or Revoked indicates regulatory action. Pending indicates awaiting final approval or special issuance decision.' ;
    rdfs:domain ind:MedicalCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:visionCorrectedFlag rdf:type rdf:Property ;
    rdfs:label 'Vision Corrected Flag' ;
    rdfs:comment 'Indicates whether the crew member requires corrective lenses (glasses or contact lenses) to meet vision standards. True if corrective lenses are required, False otherwise.' ;
    rdfs:domain ind:MedicalCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:waivers rdf:type rdf:Property ;
    rdfs:label 'Waivers' ;
    rdfs:comment 'Any medical waivers or special issuance conditions granted by the regulatory authority. Indicates exceptions to standard medical requirements with documented justification.' ;
    rdfs:domain ind:MedicalCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:languageProficiencyExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Language Proficiency Expiry Date' ;
    rdfs:comment 'The date on which the language proficiency endorsement expires and must be re-assessed. Null if no expiry (level 6 Expert has no expiry).' ;
    rdfs:domain ind:Licence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:languageProficiencyLevel rdf:type rdf:Property ;
    rdfs:label 'Language Proficiency Level' ;
    rdfs:comment 'ICAO language proficiency rating for aviation English (or other endorsed language). Scale 1-6, where 4 (Operational) is the minimum for international operations, 6 is Expert. Per ICAO Annex 1.' ;
    rdfs:domain ind:Licence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:licenceNumber rdf:type rdf:Property ;
    rdfs:label 'Licence Number' ;
    rdfs:comment 'The unique licence number issued by the regulatory authority. This is the official identifier on the physical or electronic licence document.' ;
    rdfs:domain ind:Licence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenceStatus rdf:type rdf:Property ;
    rdfs:label 'Licence Status' ;
    rdfs:comment 'Current lifecycle status of the licence: valid (active and in good standing), expired (past expiry date), suspended (temporarily invalid), revoked (permanently cancelled), pending_renewal (renewal in process), surrendered (voluntarily returned).' ;
    rdfs:domain ind:Licence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:licenceType rdf:type rdf:Property ;
    rdfs:label 'Licence Type' ;
    rdfs:comment 'The category of aviation licence. ATPL (Airline Transport Pilot Licence), CPL (Commercial Pilot Licence), MPL (Multi-crew Pilot Licence), cabin crew attestation, flight engineer, or flight navigator.' ;
    rdfs:domain ind:Licence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratingsHeld rdf:type rdf:Property ;
    rdfs:label 'Ratings Held' ;
    rdfs:comment 'Comma-separated list of ratings and endorsements held on this licence (e.g., instrument rating, multi-engine, type ratings). This is a summary field; detailed type ratings are tracked in the qualification product.' ;
    rdfs:domain ind:Licence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revocationDate rdf:type rdf:Property ;
    rdfs:label 'Revocation Date' ;
    rdfs:comment 'The date on which the licence was permanently revoked by the issuing authority. Null if the licence has never been revoked.' ;
    rdfs:domain ind:Licence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:suspensionEndDate rdf:type rdf:Property ;
    rdfs:label 'Suspension End Date' ;
    rdfs:comment 'The date on which a suspension of the licence is scheduled to end or was lifted. Null if currently suspended with no defined end date.' ;
    rdfs:domain ind:Licence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:suspensionReason rdf:type rdf:Property ;
    rdfs:label 'Suspension Reason' ;
    rdfs:comment 'Free-text description of the reason for licence suspension (e.g., medical disqualification, regulatory violation, administrative hold).' ;
    rdfs:domain ind:Licence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:suspensionStartDate rdf:type rdf:Property ;
    rdfs:label 'Suspension Start Date' ;
    rdfs:comment 'The date on which a suspension of the licence became effective. Null if the licence has never been suspended.' ;
    rdfs:domain ind:Licence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalFlightHoursAtIssue rdf:type rdf:Property ;
    rdfs:label 'Total Flight Hours At Issue' ;
    rdfs:comment 'The total flight hours logged by the crew member at the time the licence was issued. Captured for historical record and regulatory audit.' ;
    rdfs:domain ind:Licence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:absenceMemberId rdf:type rdf:Property ;
    rdfs:label 'Absence Member Id' ;
    rdfs:comment 'Identifier of the crew member who is absent. Links to the crew member master record.' ;
    rdfs:domain ind:Absence ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Member .

ind:absenceReplacementCrewMemberId rdf:type rdf:Property ;
    rdfs:label 'Absence Replacement Crew Member Id' ;
    rdfs:comment 'Identifier of the crew member assigned to replace the absent crew member. Nullable if no replacement has been assigned yet.' ;
    rdfs:domain ind:Absence ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Member .

ind:previousAbsenceId rdf:type rdf:Property ;
    rdfs:label 'Previous Absence Id' ;
    rdfs:comment 'Identifier of the previous absence record if this absence is a recurrence or continuation. Nullable if this is the first occurrence.' ;
    rdfs:domain ind:Absence ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Absence .

ind:reportingStationId rdf:type rdf:Property ;
    rdfs:label 'Reporting Station Id' ;
    rdfs:comment 'Foreign key linking to airport.station. Business justification: Absences are reported and managed at crew\'s assigned station for operational impact assessment, replacement crew sourcing, and station-level crew availability tracking. Critical for daily operations c' ;
    rdfs:domain ind:Absence ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Station .

ind:absenceStatus rdf:type rdf:Property ;
    rdfs:label 'Absence Status' ;
    rdfs:comment 'Current lifecycle status of the absence record: pending approval, approved, rejected, active (ongoing), completed, or cancelled.' ;
    rdfs:domain ind:Absence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:absenceType rdf:type rdf:Property ;
    rdfs:label 'Absence Type' ;
    rdfs:comment 'Classification of the absence reason: sick leave, maternity/paternity leave, compassionate leave, suspension, administrative leave, or unplanned absence. [ENUM-REF-CANDIDATE: sick_leave|maternity_leave|paternity_leave|compassionate_leave|suspension|administrative_leave|unplanned_absence — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Absence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:affectedDutyPeriodsCount rdf:type rdf:Property ;
    rdfs:label 'Affected Duty Periods Count' ;
    rdfs:comment 'The number of scheduled duty periods impacted by this absence, requiring roster adjustments or crew reassignments.' ;
    rdfs:domain ind:Absence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:affectedFlightLegsCount rdf:type rdf:Property ;
    rdfs:label 'Affected Flight Legs Count' ;
    rdfs:comment 'The number of individual flight legs that the absent crew member was originally scheduled to operate, now requiring coverage.' ;
    rdfs:domain ind:Absence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clearanceAuthority rdf:type rdf:Property ;
    rdfs:label 'Clearance Authority' ;
    rdfs:comment 'The name or identifier of the medical examiner, HR officer, or other authority who issued the return-to-duty clearance.' ;
    rdfs:domain ind:Absence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:collectiveAgreementReference rdf:type rdf:Property ;
    rdfs:label 'Collective Agreement Reference' ;
    rdfs:comment 'Reference to the specific clause or section of the collective bargaining agreement that governs this type of absence (e.g., sick leave policy, maternity leave entitlement).' ;
    rdfs:domain ind:Absence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payStatus rdf:type rdf:Property ;
    rdfs:label 'Pay Status' ;
    rdfs:comment 'Indicates whether the crew member receives full pay, no pay, or partial pay during the absence period, as per company policy and collective agreement.' ;
    rdfs:domain ind:Absence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonNotes rdf:type rdf:Property ;
    rdfs:label 'Reason Notes' ;
    rdfs:comment 'Free-text notes providing additional context or details about the reason for the absence. May contain sensitive personal information.' ;
    rdfs:domain ind:Absence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:replacementRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Replacement Required Flag' ;
    rdfs:comment 'Indicates whether a replacement crew member is required to cover the absent crew member\'s scheduled duties. True if replacement is needed, False otherwise.' ;
    rdfs:domain ind:Absence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:returnToDutyClearanceFlag rdf:type rdf:Property ;
    rdfs:label 'Return To Duty Clearance Flag' ;
    rdfs:comment 'Indicates whether the crew member has received medical or administrative clearance to return to duty. True if cleared, False otherwise.' ;
    rdfs:domain ind:Absence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:returnToDutyDate rdf:type rdf:Property ;
    rdfs:label 'Return To Duty Date' ;
    rdfs:comment 'The actual date when the crew member returned to active duty following the absence. Nullable if the crew member has not yet returned.' ;
    rdfs:domain ind:Absence ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:freightForwarderId rdf:type rdf:Property ;
    rdfs:label 'Freight Forwarder Id' ;
    rdfs:comment 'Foreign key linking to cargo.freight_forwarder. Business justification: AWB stores agent_name and agent_iata_code as strings. Freight_forwarder is the authoritative master with iata_cargo_agent_code. Adding freight_forwarder_id FK normalizes agent reference and allows JOI' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FreightForwarder .

ind:freightRateId rdf:type rdf:Property ;
    rdfs:label 'Freight Rate Id' ;
    rdfs:comment 'Foreign key linking to cargo.freight_rate. Business justification: An Air Waybill is issued at a specific freight rate. The AWB captures freight_charge_amount (the computed charge) but has no FK to the freight_rate master record that defines the rate structure. Addin' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FreightRate .

ind:shipperId rdf:type rdf:Property ;
    rdfs:label 'Shipper Id' ;
    rdfs:comment 'Foreign key linking to cargo.shipper. Business justification: AWB currently stores shipper_name, shipper_address, shipper_account_number as denormalized strings. Shipper is the authoritative master for shipper data. Adding shipper_id FK allows JOIN to retrieve c' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Shipper .

ind:awbStatus rdf:type rdf:Property ;
    rdfs:label 'Awb Status' ;
    rdfs:comment 'Current lifecycle status of the AWB indicating its position in the cargo handling workflow from initial booking through final delivery. [ENUM-REF-CANDIDATE: booked|accepted|manifested|departed|in_transit|arrived|delivered|cancelled — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Awb ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awbType rdf:type rdf:Property ;
    rdfs:label 'Awb Type' ;
    rdfs:comment 'Classification of the AWB: master (MAWB issued by carrier), house (HAWB issued by freight forwarder), direct (shipper to consignee), or neutral (pre-printed blank AWB).' ;
    rdfs:domain ind:Awb ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargeableWeightKg rdf:type rdf:Property ;
    rdfs:label 'Chargeable Weight Kg' ;
    rdfs:comment 'Weight used for freight charge calculation, which is the greater of gross weight or volumetric weight (volume in cubic meters × 167 for IATA standard).' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:commodityCode rdf:type rdf:Property ;
    rdfs:label 'Commodity Code' ;
    rdfs:comment 'Harmonized System (HS) code or other standardized classification code identifying the type of goods for customs and regulatory purposes.' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commodityDescription rdf:type rdf:Property ;
    rdfs:label 'Commodity Description' ;
    rdfs:comment 'Detailed description of the nature and contents of the goods being shipped, as declared by the shipper for customs and handling purposes.' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consigneeAddress rdf:type rdf:Property ;
    rdfs:label 'Consignee Address' ;
    rdfs:comment 'Complete postal address of the consignee including street, city, state/province, postal code, and country for delivery purposes.' ;
    rdfs:domain ind:Awb ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consigneeName rdf:type rdf:Property ;
    rdfs:label 'Consignee Name' ;
    rdfs:comment 'Full legal name of the party to whom the goods are being shipped and who will take delivery at destination.' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dangerousGoodsIndicator rdf:type rdf:Property ;
    rdfs:label 'Dangerous Goods Indicator' ;
    rdfs:comment 'Flag indicating whether the shipment contains dangerous goods (DG) requiring special handling and documentation per IATA DGR.' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:declaredValueForCarriage rdf:type rdf:Property ;
    rdfs:label 'Declared Value For Carriage' ;
    rdfs:comment 'Value of the goods declared by the shipper for the purpose of determining carrier liability in case of loss or damage.' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:declaredValueForCustoms rdf:type rdf:Property ;
    rdfs:label 'Declared Value For Customs' ;
    rdfs:comment 'Value of the goods declared for customs purposes, used for duty and tax calculation at destination.' ;
    rdfs:domain ind:Awb ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:executedDate rdf:type rdf:Property ;
    rdfs:label 'Executed Date' ;
    rdfs:comment 'Date when the AWB contract was executed and signed by the shipper or authorized agent.' ;
    rdfs:domain ind:Awb ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:executedLocation rdf:type rdf:Property ;
    rdfs:label 'Executed Location' ;
    rdfs:comment 'City and country where the AWB was executed and signed, establishing the jurisdiction for the contract.' ;
    rdfs:domain ind:Awb ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:freightChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Freight Charge Amount' ;
    rdfs:comment 'Total freight charges for the air transportation service, calculated based on chargeable weight and applicable rate.' ;
    rdfs:domain ind:Awb ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossWeightKg rdf:type rdf:Property ;
    rdfs:label 'Gross Weight Kg' ;
    rdfs:comment 'Total weight of the shipment including packaging, expressed in kilograms. This is the actual physical weight of all pieces combined.' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:natureOfGoods rdf:type rdf:Property ;
    rdfs:label 'Nature Of Goods' ;
    rdfs:comment 'High-level classification of the cargo type indicating special handling, regulatory, or operational requirements. [ENUM-REF-CANDIDATE: general|perishable|valuable|live_animals|dangerous_goods|human_remains|diplomatic|mail — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Awb ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberOfPieces rdf:type rdf:Property ;
    rdfs:label 'Number Of Pieces' ;
    rdfs:comment 'Total count of individual packages, cartons, or pieces comprising the shipment as declared on the AWB.' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paymentIndicator rdf:type rdf:Property ;
    rdfs:label 'Payment Indicator' ;
    rdfs:comment 'Indicates whether freight charges are prepaid (paid by shipper at origin), collect (paid by consignee at destination), or mixed (split payment).' ;
    rdfs:domain ind:Awb ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingInstructions rdf:type rdf:Property ;
    rdfs:label 'Routing Instructions' ;
    rdfs:comment 'Specific routing path and transit points for the shipment, including intermediate airports and connecting flights.' ;
    rdfs:domain ind:Awb ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Shipment Reference Number' ;
    rdfs:comment 'Customer or agent-provided reference number for tracking and internal identification purposes.' ;
    rdfs:domain ind:Awb ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialHandlingCodes rdf:type rdf:Property ;
    rdfs:label 'Special Handling Codes' ;
    rdfs:comment 'Three-letter IATA Special Handling Codes (SHC) indicating special requirements such as PER (perishable), AVI (live animals), DGR (dangerous goods), VAL (valuable cargo). Multiple codes separated by commas.' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalChargesAmount rdf:type rdf:Property ;
    rdfs:label 'Total Charges Amount' ;
    rdfs:comment 'Grand total of all charges on the AWB including freight, valuation, and other charges.' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:valuationChargeAmount rdf:type rdf:Property ;
    rdfs:label 'Valuation Charge Amount' ;
    rdfs:comment 'Additional charge for declared value coverage exceeding the standard carrier liability limit.' ;
    rdfs:domain ind:Awb ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeCubicMeters rdf:type rdf:Property ;
    rdfs:label 'Volume Cubic Meters' ;
    rdfs:comment 'Total volumetric measurement of the shipment in cubic meters, calculated from the dimensions of all pieces.' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:capacityId rdf:type rdf:Property ;
    rdfs:label 'Capacity Id' ;
    rdfs:comment 'Foreign key linking to cargo.capacity. Business justification: A cargo booking reserves space against a specific capacity record for a flight segment. cargo_booking has requested_flight_date and requested_flight_number as free-text fields but no FK to the capacit' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Capacity .

ind:primaryCargoShipperId rdf:type rdf:Property ;
    rdfs:label 'Primary Cargo Shipper Id' ;
    rdfs:comment 'Reference to the party shipping the cargo. The consignor or sender of the goods.' ;
    rdfs:domain ind:Booking ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Shipper .

ind:acceptanceDeadlineTimestamp rdf:type rdf:Property ;
    rdfs:label 'Acceptance Deadline Timestamp' ;
    rdfs:comment 'Date and time by which the physical cargo must be delivered to the origin station for acceptance. After this time, the booking may be cancelled.' ;
    rdfs:domain ind:Booking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:insuranceRequested rdf:type rdf:Property ;
    rdfs:label 'Insurance Requested' ;
    rdfs:comment 'Flag indicating whether the shipper has requested cargo insurance coverage for this booking.' ;
    rdfs:domain ind:Booking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:quotedRateAmount rdf:type rdf:Property ;
    rdfs:label 'Quoted Rate Amount' ;
    rdfs:comment 'Freight rate amount quoted to the shipper for this booking. May be per kilogram or total shipment rate.' ;
    rdfs:domain ind:Booking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Rate Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the quoted freight rate.' ;
    rdfs:domain ind:Booking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateQuoteReference rdf:type rdf:Property ;
    rdfs:label 'Rate Quote Reference' ;
    rdfs:comment 'Reference number linking this booking to a previously issued freight rate quotation. Used for rate validation and pricing.' ;
    rdfs:domain ind:Booking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestedVolumeCbm rdf:type rdf:Property ;
    rdfs:label 'Requested Volume Cbm' ;
    rdfs:comment 'Total volume of the cargo shipment requested for booking, measured in cubic meters.' ;
    rdfs:domain ind:Booking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requestedWeightKg rdf:type rdf:Property ;
    rdfs:label 'Requested Weight Kg' ;
    rdfs:comment 'Total gross weight of the cargo shipment requested for booking, measured in kilograms.' ;
    rdfs:domain ind:Booking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureControlRequired rdf:type rdf:Property ;
    rdfs:label 'Temperature Control Required' ;
    rdfs:comment 'Flag indicating whether the cargo requires temperature-controlled handling (e.g., for perishables or pharmaceuticals).' ;
    rdfs:domain ind:Booking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:temperatureRangeCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Range Celsius' ;
    rdfs:comment 'Required temperature range for temperature-controlled cargo, expressed as min-max range in Celsius (e.g., 2-8).' ;
    rdfs:domain ind:Booking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uldTypeRequested rdf:type rdf:Property ;
    rdfs:label 'Uld Type Requested' ;
    rdfs:comment 'Type of ULD (Unit Load Device) requested for the cargo, such as container or pallet type (e.g., AKE, PMC). Applicable for containerized cargo.' ;
    rdfs:domain ind:Booking ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentId rdf:type rdf:Property ;
    rdfs:label 'Shipment Id' ;
    rdfs:comment 'Unique identifier for the physical shipment record. Primary key for tracking cargo movement from acceptance to delivery.' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Shipment .

ind:currentLocationStationId rdf:type rdf:Property ;
    rdfs:label 'Current Location Station Id' ;
    rdfs:comment 'Foreign key linking to airport.station. Business justification: Shipments track current_location_code for real-time tracking. Station link provides ground handler, customs capability, operational hours, and contact details essential for exception handling and deli' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Station .

ind:manifestId rdf:type rdf:Property ;
    rdfs:label 'Manifest Id' ;
    rdfs:comment 'Reference to the flight manifest on which this shipment is loaded. Links shipment to specific flight leg for operational tracking.' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Manifest .

ind:acceptanceStationCode rdf:type rdf:Property ;
    rdfs:label 'Acceptance Station Code' ;
    rdfs:comment 'Three-letter IATA airport code where the shipment was accepted by the carrier. Origin point for physical cargo movement.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualArrivalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Actual Arrival Timestamp' ;
    rdfs:comment 'Actual date and time when the shipment physically arrived at the destination station. Recorded upon flight arrival and cargo offload.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:actualPieces rdf:type rdf:Property ;
    rdfs:label 'Actual Pieces' ;
    rdfs:comment 'Number of individual pieces or packages in the shipment as verified at acceptance. Used for piece-level tracking and reconciliation throughout the journey.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:actualWeightKg rdf:type rdf:Property ;
    rdfs:label 'Actual Weight Kg' ;
    rdfs:comment 'Gross weight of the shipment in kilograms as measured at acceptance. Used for weight and balance calculations and capacity planning.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customsClearanceTimestamp rdf:type rdf:Property ;
    rdfs:label 'Customs Clearance Timestamp' ;
    rdfs:comment 'Date and time when customs clearance was completed. Null if not yet cleared or not applicable for domestic shipments.' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:customsClearedFlag rdf:type rdf:Property ;
    rdfs:label 'Customs Cleared Flag' ;
    rdfs:comment 'Indicates whether the shipment has successfully cleared customs at the destination. Critical for international shipments and delivery release.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dangerousGoodsFlag rdf:type rdf:Property ;
    rdfs:label 'Dangerous Goods Flag' ;
    rdfs:comment 'Indicates whether the shipment contains dangerous goods requiring special handling, documentation, and regulatory compliance per IATA DGR.' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:estimatedArrivalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Estimated Arrival Timestamp' ;
    rdfs:comment 'Estimated date and time when the shipment is expected to arrive at the destination station. Updated based on flight schedules and delays.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:exceptionReason rdf:type rdf:Property ;
    rdfs:label 'Exception Reason' ;
    rdfs:comment 'Free-text description of the exception condition if exception_flag is true. Provides context for operational follow-up and customer communication.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceDeclaredValue rdf:type rdf:Property ;
    rdfs:label 'Insurance Declared Value' ;
    rdfs:comment 'Declared value of the shipment for insurance purposes. Used to calculate insurance premiums and liability limits. Business-confidential financial data.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:originStationCode rdf:type rdf:Property ;
    rdfs:label 'Origin Station Code' ;
    rdfs:comment 'Three-letter IATA airport code of the shipment origin as specified on the AWB. May differ from acceptance station for interline shipments.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:proofOfDelivery rdf:type rdf:Property ;
    rdfs:label 'Proof Of Delivery' ;
    rdfs:comment 'Name and signature of the person who received the shipment, or electronic delivery confirmation reference. Legal proof of successful delivery.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingSegments rdf:type rdf:Property ;
    rdfs:label 'Routing Segments' ;
    rdfs:comment 'Planned routing path as a sequence of station codes (e.g., JFK-FRA-DXB). Defines the intended flight segments for the shipment journey.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentStatus rdf:type rdf:Property ;
    rdfs:label 'Shipment Status' ;
    rdfs:comment 'Current lifecycle status of the physical shipment. Tracks progression from acceptance through delivery. Aligns with IATA Cargo-XML status codes. [ENUM-REF-CANDIDATE: received|built_up|loaded|in_transit|arrived|delivered|on_hold|returned — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:temperatureMaxCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Max Celsius' ;
    rdfs:comment 'Maximum allowed temperature in Celsius for temperature-controlled shipments. Null for non-temperature-sensitive cargo.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureMinCelsius rdf:type rdf:Property ;
    rdfs:label 'Temperature Min Celsius' ;
    rdfs:comment 'Minimum required temperature in Celsius for temperature-controlled shipments (e.g., perishables, pharmaceuticals). Null for non-temperature-sensitive cargo.' ;
    rdfs:domain ind:Shipment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acquisitionCostAmount rdf:type rdf:Property ;
    rdfs:label 'Acquisition Cost Amount' ;
    rdfs:comment 'Purchase or lease cost of the ULD at time of acquisition. Used for asset valuation and financial reporting.' ;
    rdfs:domain ind:Uld ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acquisitionCostCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Acquisition Cost Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the acquisition cost amount.' ;
    rdfs:domain ind:Uld ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:barcodeNumber rdf:type rdf:Property ;
    rdfs:label 'Barcode Number' ;
    rdfs:comment 'Barcode identifier printed on the ULD for manual or automated scanning during cargo handling operations.' ;
    rdfs:domain ind:Uld ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compatibleAircraftTypes rdf:type rdf:Property ;
    rdfs:label 'Compatible Aircraft Types' ;
    rdfs:comment 'Comma-separated list of aircraft type codes (e.g., B777, A350, B747F) that can accommodate this ULD type. Used for load planning and fleet compatibility.' ;
    rdfs:domain ind:Uld ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:damageDescription rdf:type rdf:Property ;
    rdfs:label 'Damage Description' ;
    rdfs:comment 'Free-text description of any damage, defects, or maintenance issues identified during inspection or operation. Used for repair planning and safety tracking.' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:damageStatus rdf:type rdf:Property ;
    rdfs:label 'Damage Status' ;
    rdfs:comment 'Current damage assessment level. None indicates no damage; minor damage allows continued use with monitoring; major damage requires repair before next use; critical damage grounds the unit immediately.' ;
    rdfs:domain ind:Uld ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inspectionIntervalDays rdf:type rdf:Property ;
    rdfs:label 'Inspection Interval Days' ;
    rdfs:comment 'Standard number of days between required inspections for this ULD type, as defined by IATA regulations and airline maintenance programs.' ;
    rdfs:domain ind:Uld ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastInspectionDate rdf:type rdf:Property ;
    rdfs:label 'Last Inspection Date' ;
    rdfs:comment 'Date of the most recent scheduled inspection or maintenance check of the ULD. Required for regulatory compliance and safety.' ;
    rdfs:domain ind:Uld ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastMovementTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Movement Timestamp' ;
    rdfs:comment 'Date and time when the ULD was last scanned or moved. Used for tracking ULD utilization and identifying stale or lost units.' ;
    rdfs:domain ind:Uld ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastRepairDate rdf:type rdf:Property ;
    rdfs:label 'Last Repair Date' ;
    rdfs:comment 'Date when the most recent repair or maintenance work was completed on this ULD. Used for maintenance history tracking.' ;
    rdfs:domain ind:Uld ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:materialType rdf:type rdf:Property ;
    rdfs:label 'Material Type' ;
    rdfs:comment 'Primary construction material of the ULD. Aluminum is most common; composite materials are lighter; steel is used for heavy-duty applications.' ;
    rdfs:domain ind:Uld ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumGrossWeightKg rdf:type rdf:Property ;
    rdfs:label 'Maximum Gross Weight Kg' ;
    rdfs:comment 'Maximum allowable total weight (tare + cargo) for this ULD type in kilograms, as specified by IATA standards and aircraft compatibility.' ;
    rdfs:domain ind:Uld ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Maximum Volume M3' ;
    rdfs:comment 'Maximum internal volume capacity of the ULD in cubic meters. Used for cargo capacity planning and load optimization.' ;
    rdfs:domain ind:Uld ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nextInspectionDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Inspection Due Date' ;
    rdfs:comment 'Date by which the next scheduled inspection must be completed. ULDs overdue for inspection should be removed from service.' ;
    rdfs:domain ind:Uld ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:ownerAirlineCode rdf:type rdf:Property ;
    rdfs:label 'Owner Airline Code' ;
    rdfs:comment 'IATA two-letter airline code of the carrier that owns this ULD asset. Part of the ULD serial number.' ;
    rdfs:domain ind:Uld ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipType rdf:type rdf:Property ;
    rdfs:label 'Ownership Type' ;
    rdfs:comment 'Indicates whether the ULD is owned by the airline, leased from a third party, or part of a shared pool arrangement.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retirementDate rdf:type rdf:Property ;
    rdfs:label 'Retirement Date' ;
    rdfs:comment 'Date when the ULD was permanently removed from service and retired from the fleet. Null for active units.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:retirementReason rdf:type rdf:Property ;
    rdfs:label 'Retirement Reason' ;
    rdfs:comment 'Explanation for why the ULD was retired (e.g., end of useful life, irreparable damage, fleet optimization, lease expiration).' ;
    rdfs:domain ind:Uld ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rfidTagNumber rdf:type rdf:Property ;
    rdfs:label 'Rfid Tag Number' ;
    rdfs:comment 'Unique identifier of the RFID tag attached to the ULD for automated tracking and scanning. Used by ULD control systems.' ;
    rdfs:domain ind:Uld ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tareWeightKg rdf:type rdf:Property ;
    rdfs:label 'Tare Weight Kg' ;
    rdfs:comment 'Empty weight of the ULD in kilograms. Used for weight and balance calculations and to determine net cargo weight.' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:temperatureControlledFlag rdf:type rdf:Property ;
    rdfs:label 'Temperature Controlled Flag' ;
    rdfs:comment 'Indicates whether this ULD is equipped with active or passive temperature control for perishable or pharmaceutical cargo. True if temperature-controlled, false otherwise.' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:typeCode rdf:type rdf:Property ;
    rdfs:label 'Type Code' ;
    rdfs:comment 'IATA three-letter ULD type code identifying the container or pallet type (e.g., AKE, LD3, LD7, LD11, PMC, PAG, AAA). Defines the physical dimensions and configuration.' ;
    rdfs:domain ind:Uld ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uldCategory rdf:type rdf:Property ;
    rdfs:label 'Uld Category' ;
    rdfs:comment 'High-level classification of the ULD: container (enclosed unit), pallet (flat platform), or igloo (pallet with contoured cover).' ;
    rdfs:domain ind:Uld ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uldMovementId rdf:type rdf:Property ;
    rdfs:label 'Uld Movement Id' ;
    rdfs:comment 'Unique identifier for each ULD movement event record. Primary key for the ULD movement transaction.' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:UldMovement .

ind:cargoManifestId rdf:type rdf:Property ;
    rdfs:label 'Cargo Manifest Id' ;
    rdfs:comment 'Foreign key linking to cargo.manifest. Business justification: ULD_movement has flight_number and flight_date (strings) to identify which flight the ULD is on. Manifest is the authoritative record for flight cargo operations. Adding cargo_manifest_id FK links ULD' ;
    rdfs:domain ind:UldMovement ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Manifest .

ind:aircraftHoldPosition rdf:type rdf:Property ;
    rdfs:label 'Aircraft Hold Position' ;
    rdfs:comment 'Specific compartment or position code within the aircraft hold where the ULD was loaded (e.g., FWD, AFT, MAIN, P1, P2). Null for non-loading events.' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:awbCount rdf:type rdf:Property ;
    rdfs:label 'Awb Count' ;
    rdfs:comment 'Number of distinct Air Waybills (AWB) consolidated within this ULD. Represents the count of separate shipments loaded into the unit.' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:damageSeverity rdf:type rdf:Property ;
    rdfs:label 'Damage Severity' ;
    rdfs:comment 'Severity classification of ULD damage. Minor = cosmetic, moderate = functional impact but usable, major = requires repair before next use, critical = ULD unsafe for service. Null if no damage.' ;
    rdfs:domain ind:UldMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discrepancyFlag rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Flag' ;
    rdfs:comment 'Indicates whether any discrepancy, irregularity, or exception was noted during this ULD movement event. True = discrepancy exists, False = normal movement.' ;
    rdfs:domain ind:UldMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discrepancyType rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Type' ;
    rdfs:comment 'Category of discrepancy or irregularity identified during the ULD movement. Damage = physical damage to ULD, missing = ULD not found, overweight = exceeds weight limits, contamination = foreign substance present, seal_broken = security seal compromised, misdirected = sent to wrong location. Null if no discrepancy.' ;
    rdfs:domain ind:UldMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:movementStatus rdf:type rdf:Property ;
    rdfs:label 'Movement Status' ;
    rdfs:comment 'Current lifecycle status of this ULD movement event. Planned = scheduled but not started, in_progress = movement underway, completed = movement finished successfully, cancelled = movement aborted, delayed = movement behind schedule, exception = irregularity occurred.' ;
    rdfs:domain ind:UldMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Recorded Timestamp' ;
    rdfs:comment 'Date and time when this ULD movement record was created in the cargo management system. May differ from event_timestamp if recorded retroactively. Follows format yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:UldMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:repairRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Repair Required Flag' ;
    rdfs:comment 'Indicates whether the ULD requires maintenance or repair before it can be returned to service. True = repair needed, False = serviceable.' ;
    rdfs:domain ind:UldMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resolutionStatus rdf:type rdf:Property ;
    rdfs:label 'Resolution Status' ;
    rdfs:comment 'Status of resolution for any discrepancy or irregularity associated with this ULD movement. Open = discrepancy reported, investigating = under review, resolved = corrective action taken, closed = case finalized. Null if no discrepancy.' ;
    rdfs:domain ind:UldMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sealIntactFlag rdf:type rdf:Property ;
    rdfs:label 'Seal Intact Flag' ;
    rdfs:comment 'Indicates whether the security seal was found intact at the time of this movement event. True = seal intact, False = seal broken or missing.' ;
    rdfs:domain ind:UldMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sealNumberPrimary rdf:type rdf:Property ;
    rdfs:label 'Seal Number Primary' ;
    rdfs:comment 'Primary security seal number applied to the ULD to ensure cargo integrity and prevent tampering. Null if ULD is not sealed.' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sealNumberSecondary rdf:type rdf:Property ;
    rdfs:label 'Seal Number Secondary' ;
    rdfs:comment 'Secondary or backup security seal number if multiple seals are applied. Null if only one seal or no seals applied.' ;
    rdfs:domain ind:UldMovement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amendedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Amended Timestamp' ;
    rdfs:comment 'Date and time when the manifest was amended post-departure to correct discrepancies or add late-loaded cargo information.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:consigneeCount rdf:type rdf:Property ;
    rdfs:label 'Consignee Count' ;
    rdfs:comment 'Total number of distinct consignees (receivers) represented across all AWBs on this manifest.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:customsDeclarationReference rdf:type rdf:Property ;
    rdfs:label 'Customs Declaration Reference' ;
    rdfs:comment 'Reference number assigned by customs authority upon submission of the manifest for clearance and regulatory compliance.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsSubmissionTimestamp rdf:type rdf:Property ;
    rdfs:label 'Customs Submission Timestamp' ;
    rdfs:comment 'Date and time when the manifest was electronically transmitted to the destination customs authority for advance cargo declaration.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:liveAnimalsIndicator rdf:type rdf:Property ;
    rdfs:label 'Live Animals Indicator' ;
    rdfs:comment 'Flag indicating whether this manifest includes any shipments of live animals requiring special care and regulatory compliance.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mailIndicator rdf:type rdf:Property ;
    rdfs:label 'Mail Indicator' ;
    rdfs:comment 'Flag indicating whether this manifest includes postal mail shipments governed by Universal Postal Union regulations.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:manifestNumber rdf:type rdf:Property ;
    rdfs:label 'Manifest Number' ;
    rdfs:comment 'Externally-known unique manifest document number assigned by the cargo system for regulatory and operational tracking.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manifestStatus rdf:type rdf:Property ;
    rdfs:label 'Manifest Status' ;
    rdfs:comment 'Current lifecycle status of the cargo manifest. Preliminary indicates draft; final indicates locked for departure; amended indicates post-departure correction; submitted indicates transmitted to customs.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operationType rdf:type rdf:Property ;
    rdfs:label 'Operation Type' ;
    rdfs:comment 'Indicates whether cargo is carried on a dedicated freighter aircraft, in the belly hold of a passenger aircraft, or on a combi (mixed passenger/cargo) configuration.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:perishablesIndicator rdf:type rdf:Property ;
    rdfs:label 'Perishables Indicator' ;
    rdfs:comment 'Flag indicating whether this manifest includes perishable cargo (e.g., fresh produce, pharmaceuticals) requiring temperature-controlled handling.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:shipperCount rdf:type rdf:Property ;
    rdfs:label 'Shipper Count' ;
    rdfs:comment 'Total number of distinct shippers (consignors) represented across all AWBs on this manifest.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalChargeableWeightKg rdf:type rdf:Property ;
    rdfs:label 'Total Chargeable Weight Kg' ;
    rdfs:comment 'Total chargeable weight in kilograms used for revenue calculation, which is the greater of actual weight or volumetric weight across all AWBs.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalDeclaredValueUsd rdf:type rdf:Property ;
    rdfs:label 'Total Declared Value Usd' ;
    rdfs:comment 'Total declared value for customs and insurance purposes across all AWBs on this manifest, expressed in US dollars.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalPieces rdf:type rdf:Property ;
    rdfs:label 'Total Pieces' ;
    rdfs:comment 'Total count of individual cargo pieces (packages, cartons, pallets) loaded on this flight across all AWBs.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalVolumeCbm rdf:type rdf:Property ;
    rdfs:label 'Total Volume Cbm' ;
    rdfs:comment 'Total volume of all cargo loaded on this flight in cubic meters, used for capacity planning and dimensional analysis.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalWeightKg rdf:type rdf:Property ;
    rdfs:label 'Total Weight Kg' ;
    rdfs:comment 'Total actual gross weight of all cargo loaded on this flight in kilograms, used for weight and balance calculations.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transitCargoIndicator rdf:type rdf:Property ;
    rdfs:label 'Transit Cargo Indicator' ;
    rdfs:comment 'Flag indicating whether this manifest includes transit cargo that will continue on a connecting flight rather than being delivered at the destination airport.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:uldCount rdf:type rdf:Property ;
    rdfs:label 'Uld Count' ;
    rdfs:comment 'Total number of Unit Load Devices (containers and pallets) loaded on this flight.' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:valuableCargoIndicator rdf:type rdf:Property ;
    rdfs:label 'Valuable Cargo Indicator' ;
    rdfs:comment 'Flag indicating whether this manifest includes high-value cargo requiring enhanced security and handling procedures.' ;
    rdfs:domain ind:Manifest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dangerousGoodsId rdf:type rdf:Property ;
    rdfs:label 'Dangerous Goods Id' ;
    rdfs:comment 'Primary key for dangerous_goods' ;
    rdfs:domain ind:DangerousGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:acceptanceCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Acceptance Certificate Number' ;
    rdfs:comment 'Reference number of the dangerous goods acceptance certificate or checklist issued upon successful acceptance inspection.' ;
    rdfs:domain ind:DangerousGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acceptanceCheckStatus rdf:type rdf:Property ;
    rdfs:label 'Acceptance Check Status' ;
    rdfs:comment 'Result of the airline\'s dangerous goods acceptance inspection: passed (accepted for carriage), failed (rejected), pending (under review), waived (exempted).' ;
    rdfs:domain ind:DangerousGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acceptanceCheckTimestamp rdf:type rdf:Property ;
    rdfs:label 'Acceptance Check Timestamp' ;
    rdfs:comment 'Date and time when the dangerous goods acceptance check was completed by airline cargo acceptance staff.' ;
    rdfs:domain ind:DangerousGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:allPackedInOneFlag rdf:type rdf:Property ;
    rdfs:label 'All Packed In One Flag' ;
    rdfs:comment 'Indicates whether all dangerous goods packages covered by this declaration are contained within a single overpack or freight container.' ;
    rdfs:domain ind:DangerousGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cargoAircraftOnlyFlag rdf:type rdf:Property ;
    rdfs:label 'Cargo Aircraft Only Flag' ;
    rdfs:comment 'Indicates whether the dangerous goods are restricted to cargo aircraft only (true) or may be carried on passenger aircraft (false).' ;
    rdfs:domain ind:DangerousGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceVerifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Compliance Verified Flag' ;
    rdfs:comment 'Indicates whether the dangerous goods declaration has been verified for full regulatory compliance with IATA DGR, ICAO Technical Instructions, and applicable national regulations.' ;
    rdfs:domain ind:DangerousGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dgClass rdf:type rdf:Property ;
    rdfs:label 'Dg Class' ;
    rdfs:comment 'Primary hazard class of the dangerous goods (1-9): 1=Explosives, 2=Gases, 3=Flammable Liquids, 4=Flammable Solids, 5=Oxidizing Substances, 6=Toxic and Infectious Substances, 7=Radioactive Material, 8=Corrosives, 9=Miscellaneous.' ;
    rdfs:domain ind:DangerousGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dgDivision rdf:type rdf:Property ;
    rdfs:label 'Dg Division' ;
    rdfs:comment 'Subdivision within the DG class providing further hazard classification (e.g., 2.1 for flammable gases, 6.2 for infectious substances). May be null for classes without divisions.' ;
    rdfs:domain ind:DangerousGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossWeightPerPackageKg rdf:type rdf:Property ;
    rdfs:label 'Gross Weight Per Package Kg' ;
    rdfs:comment 'Gross weight of each package including dangerous goods and packaging material, measured in kilograms.' ;
    rdfs:domain ind:DangerousGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netQuantityPerPackage rdf:type rdf:Property ;
    rdfs:label 'Net Quantity Per Package' ;
    rdfs:comment 'Net quantity of dangerous goods per package, excluding packaging material. Unit specified in net_quantity_unit.' ;
    rdfs:domain ind:DangerousGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netQuantityUnit rdf:type rdf:Property ;
    rdfs:label 'Net Quantity Unit' ;
    rdfs:comment 'Unit of measure for net quantity: kg (kilograms), L (liters), g (grams), mL (milliliters).' ;
    rdfs:domain ind:DangerousGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numberOfPackages rdf:type rdf:Property ;
    rdfs:label 'Number Of Packages' ;
    rdfs:comment 'Total count of packages containing dangerous goods within this declaration.' ;
    rdfs:domain ind:DangerousGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:overpackUsedFlag rdf:type rdf:Property ;
    rdfs:label 'Overpack Used Flag' ;
    rdfs:comment 'Indicates whether an overpack (single enclosure containing one or more packages) was used for this dangerous goods shipment.' ;
    rdfs:domain ind:DangerousGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:packingGroup rdf:type rdf:Property ;
    rdfs:label 'Packing Group' ;
    rdfs:comment 'Degree of danger presented by the substance: I=Great Danger, II=Medium Danger, III=Minor Danger. Not applicable to all DG classes.' ;
    rdfs:domain ind:DangerousGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:packingInstruction rdf:type rdf:Property ;
    rdfs:label 'Packing Instruction' ;
    rdfs:comment 'IATA packing instruction code specifying how the dangerous goods must be packaged for air transport (e.g., PI 965 for lithium ion batteries).' ;
    rdfs:domain ind:DangerousGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:properShippingName rdf:type rdf:Property ;
    rdfs:label 'Proper Shipping Name' ;
    rdfs:comment 'The official IATA-recognized name used to describe the dangerous goods substance or article as specified in the DGR List of Dangerous Goods.' ;
    rdfs:domain ind:DangerousGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:radioactiveCategory rdf:type rdf:Property ;
    rdfs:label 'Radioactive Category' ;
    rdfs:comment 'Category label for radioactive materials (Class 7) based on transport index and surface radiation level. Applicable only to radioactive shipments.' ;
    rdfs:domain ind:DangerousGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipperDeclarationText rdf:type rdf:Property ;
    rdfs:label 'Shipper Declaration Text' ;
    rdfs:comment 'Full text of the shipper\'s declaration certifying that the dangerous goods are properly classified, packaged, marked, labeled, and in proper condition for transport by air.' ;
    rdfs:domain ind:DangerousGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipperSignatureDate rdf:type rdf:Property ;
    rdfs:label 'Shipper Signature Date' ;
    rdfs:comment 'Date on which the shipper signed the dangerous goods declaration, certifying compliance with IATA DGR.' ;
    rdfs:domain ind:DangerousGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:specialProvisionCodes rdf:type rdf:Property ;
    rdfs:label 'Special Provision Codes' ;
    rdfs:comment 'Comma-separated list of IATA special provision codes (e.g., A1, A2) that apply additional conditions or exemptions to the shipment.' ;
    rdfs:domain ind:DangerousGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateVariationCodes rdf:type rdf:Property ;
    rdfs:label 'State Variation Codes' ;
    rdfs:comment 'Comma-separated list of country-specific variation codes indicating deviations from IATA DGR by national civil aviation authorities.' ;
    rdfs:domain ind:DangerousGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subsidiaryRiskClass rdf:type rdf:Property ;
    rdfs:label 'Subsidiary Risk Class' ;
    rdfs:comment 'Secondary hazard class if the dangerous goods present more than one hazard. May be null if no subsidiary risk exists.' ;
    rdfs:domain ind:DangerousGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalGrossWeightKg rdf:type rdf:Property ;
    rdfs:label 'Total Gross Weight Kg' ;
    rdfs:comment 'Total gross weight of all packages containing dangerous goods in this declaration, measured in kilograms.' ;
    rdfs:domain ind:DangerousGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalNetQuantity rdf:type rdf:Property ;
    rdfs:label 'Total Net Quantity' ;
    rdfs:comment 'Total net quantity of dangerous goods across all packages in this declaration. Calculated as net_quantity_per_package multiplied by number_of_packages.' ;
    rdfs:domain ind:DangerousGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transportIndex rdf:type rdf:Property ;
    rdfs:label 'Transport Index' ;
    rdfs:comment 'Single number assigned to a package, overpack, or freight container containing radioactive material to provide control over radiation exposure. Applicable only to Class 7 DG.' ;
    rdfs:domain ind:DangerousGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unNumber rdf:type rdf:Property ;
    rdfs:label 'Un Number' ;
    rdfs:comment 'Four-digit UN identification number assigned to the dangerous substance or article. Mandatory for all DG shipments per IATA DGR.' ;
    rdfs:domain ind:DangerousGoods ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dangerousGoodsApplicable rdf:type rdf:Property ;
    rdfs:label 'Dangerous Goods Applicable' ;
    rdfs:comment 'Indicates whether this rate applies to dangerous goods shipments requiring special handling and documentation per IATA DGR.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interlinePartnerCode rdf:type rdf:Property ;
    rdfs:label 'Interline Partner Code' ;
    rdfs:comment 'IATA two or three-letter airline code of the interline partner carrier for revenue proration. Applicable when rate_type is INTERLINE_PRORATE.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumCharge rdf:type rdf:Property ;
    rdfs:label 'Minimum Charge' ;
    rdfs:comment 'Minimum freight charge that applies regardless of weight. Ensures revenue floor for small shipments.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prorationMethod rdf:type rdf:Property ;
    rdfs:label 'Proration Method' ;
    rdfs:comment 'Method for dividing revenue between interline carriers. MILEAGE (proportional to distance flown), SEGMENT (per flight segment), AGREED_PERCENTAGE (pre-negotiated split), TACT_STANDARD (IATA standard proration rules).' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:prorationPercentage rdf:type rdf:Property ;
    rdfs:label 'Proration Percentage' ;
    rdfs:comment 'Percentage of total freight revenue allocated to this carrier segment in interline operations. Used when proration_method is AGREED_PERCENTAGE.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateApprovalAuthority rdf:type rdf:Property ;
    rdfs:label 'Rate Approval Authority' ;
    rdfs:comment 'Name or identifier of the authority or department that approved this freight rate (e.g., Revenue Management, Pricing Committee, IATA CSC).' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateClass rdf:type rdf:Property ;
    rdfs:label 'Rate Class' ;
    rdfs:comment 'IATA rate class indicator. M (Minimum), N (Normal/General), Q (Quantity), C (Specific Commodity), S (Surcharge), R (Reduction).' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCode rdf:type rdf:Property ;
    rdfs:label 'Rate Code' ;
    rdfs:comment 'Unique business identifier for the freight rate. Used in Mercator rating engine and TACT publications.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratePerKg rdf:type rdf:Property ;
    rdfs:label 'Rate Per Kg' ;
    rdfs:comment 'Freight charge per kilogram of cargo weight for this rate tier and route. Expressed in the currency specified in currency_code.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ratePublicationDate rdf:type rdf:Property ;
    rdfs:label 'Rate Publication Date' ;
    rdfs:comment 'Date when this rate was officially published or filed with regulatory authorities or IATA TACT.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rateSource rdf:type rdf:Property ;
    rdfs:label 'Rate Source' ;
    rdfs:comment 'Origin of the freight rate. TACT (The Air Cargo Tariff published rate), BILATERAL_AGREEMENT (negotiated carrier-to-carrier), SPOT_RATE (one-time negotiated rate), INTERLINE (multi-carrier agreement), CONTRACT (shipper contract rate), MARKET_RATE (dynamic market-based pricing).' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateStatus rdf:type rdf:Property ;
    rdfs:label 'Rate Status' ;
    rdfs:comment 'Current lifecycle status of the freight rate. ACTIVE (in use), INACTIVE (not available), PENDING (awaiting approval), EXPIRED (past effective_to_date), SUSPENDED (temporarily disabled).' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateType rdf:type rdf:Property ;
    rdfs:label 'Rate Type' ;
    rdfs:comment 'Classification of the freight rate. GCR (General Cargo Rate) applies to standard shipments, SCR (Specific Commodity Rate) applies to designated commodities, CLASS_RATE applies to rate classes, ULD_RATE applies to unit load devices, IATA_TARIFF applies to published IATA rates, SURCHARGE applies to additional charges, INTERLINE_PRORATE applies to revenue sharing between carriers. [ENUM-REF-CANDIDATE: GCR|SCR|CLASS_RATE|ULD_RATE|IATA_TARIFF|SURCHARGE|INTERLINE_PRORATE — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingRestriction rdf:type rdf:Property ;
    rdfs:label 'Routing Restriction' ;
    rdfs:comment 'Routing constraints or requirements for this rate to apply. May specify required connection points, prohibited routings, or carrier restrictions.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementReference rdf:type rdf:Property ;
    rdfs:label 'Settlement Reference' ;
    rdfs:comment 'Reference identifier for IATA Cargo Accounts Settlement Systems (CASS) or bilateral settlement agreement. Used for interline revenue reconciliation.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surchargeCalculationBasis rdf:type rdf:Property ;
    rdfs:label 'Surcharge Calculation Basis' ;
    rdfs:comment 'Method for calculating surcharge amount. PERCENTAGE (percent of base freight), FLAT_AMOUNT (fixed charge), PER_KG (per kilogram), PER_SHIPMENT (per AWB).' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surchargeType rdf:type rdf:Property ;
    rdfs:label 'Surcharge Type' ;
    rdfs:comment 'Type of surcharge if rate_type is SURCHARGE. FSC (Fuel Surcharge), SSC (Security Surcharge), HANDLING (special handling), DG (Dangerous Goods), OVERSIZE (oversized cargo), REMOTE_AREA (remote destination), CAF (Currency Adjustment Factor), NONE (not a surcharge). [ENUM-REF-CANDIDATE: FSC|SSC|HANDLING|DG|OVERSIZE|REMOTE_AREA|CAF|NONE — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:surchargeValue rdf:type rdf:Property ;
    rdfs:label 'Surcharge Value' ;
    rdfs:comment 'Numeric value for surcharge calculation. Interpretation depends on surcharge_calculation_basis (e.g., 15.5 for 15.5% or 15.5 currency units).' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:uldTypeCode rdf:type rdf:Property ;
    rdfs:label 'Uld Type Code' ;
    rdfs:comment 'IATA ULD type code if this rate applies to a specific unit load device configuration (e.g., AKE, PMC, PAG). Null for non-ULD rates.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightBreakLowerKg rdf:type rdf:Property ;
    rdfs:label 'Weight Break Lower Kg' ;
    rdfs:comment 'Lower weight threshold in kilograms for this rate tier. Rates typically decrease as shipment weight increases through defined break points.' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightBreakUpperKg rdf:type rdf:Property ;
    rdfs:label 'Weight Break Upper Kg' ;
    rdfs:comment 'Upper weight threshold in kilograms for this rate tier. Null indicates no upper limit (open-ended tier).' ;
    rdfs:domain ind:FreightRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:aircraftRegistrationId rdf:type rdf:Property ;
    rdfs:label 'Aircraft Registration Id' ;
    rdfs:comment 'Reference to the aircraft registration assigned to this flight segment.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AircraftRegistration .

ind:embargoId rdf:type rdf:Property ;
    rdfs:label 'Embargo Id' ;
    rdfs:comment 'Foreign key linking to cargo.embargo. Business justification: The capacity record has embargo_flag (BOOLEAN) and embargo_reason (STRING) indicating when a flight\'s cargo capacity is under embargo. The embargo table is the authoritative record for cargo restricti' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Embargo .

ind:aircraftConfiguration rdf:type rdf:Property ;
    rdfs:label 'Aircraft Configuration' ;
    rdfs:comment 'The operational configuration of the aircraft for this flight: passenger (belly cargo only), freighter (dedicated cargo aircraft), or combi (mixed passenger and main deck cargo).' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:allotmentDangerousGoodsKg rdf:type rdf:Property ;
    rdfs:label 'Allotment Dangerous Goods Kg' ;
    rdfs:comment 'Weight capacity in kilograms allocated to dangerous goods (DG) cargo for this flight segment, subject to IATA DGR restrictions.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allotmentExpressKg rdf:type rdf:Property ;
    rdfs:label 'Allotment Express Kg' ;
    rdfs:comment 'Weight capacity in kilograms allocated to express cargo product type for this flight segment.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allotmentGeneralKg rdf:type rdf:Property ;
    rdfs:label 'Allotment General Kg' ;
    rdfs:comment 'Weight capacity in kilograms allocated to general cargo product type for this flight segment.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allotmentLiveAnimalsKg rdf:type rdf:Property ;
    rdfs:label 'Allotment Live Animals Kg' ;
    rdfs:comment 'Weight capacity in kilograms allocated to live animals cargo for this flight segment.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allotmentPerishableKg rdf:type rdf:Property ;
    rdfs:label 'Allotment Perishable Kg' ;
    rdfs:comment 'Weight capacity in kilograms allocated to perishable cargo product type (e.g., fresh produce, pharmaceuticals) for this flight segment.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:allotmentValuableKg rdf:type rdf:Property ;
    rdfs:label 'Allotment Valuable Kg' ;
    rdfs:comment 'Weight capacity in kilograms allocated to valuable cargo (e.g., precious metals, jewelry, currency) for this flight segment.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:availableVolumeCbm rdf:type rdf:Property ;
    rdfs:label 'Available Volume Cbm' ;
    rdfs:comment 'Remaining available volume capacity in cubic meters for new bookings (total capacity minus booked volume).' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:availableWeightKg rdf:type rdf:Property ;
    rdfs:label 'Available Weight Kg' ;
    rdfs:comment 'Remaining available weight capacity in kilograms for new bookings (total capacity minus booked weight).' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bellyCargoVolumeCapacityCbm rdf:type rdf:Property ;
    rdfs:label 'Belly Cargo Volume Capacity Cbm' ;
    rdfs:comment 'Total available volume capacity in cubic meters for belly cargo compartments on this flight segment.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bellyCargoWeightCapacityKg rdf:type rdf:Property ;
    rdfs:label 'Belly Cargo Weight Capacity Kg' ;
    rdfs:comment 'Total available weight capacity in kilograms for belly cargo compartments on this flight segment.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bookedVolumeCbm rdf:type rdf:Property ;
    rdfs:label 'Booked Volume Cbm' ;
    rdfs:comment 'Total volume in cubic meters of cargo bookings confirmed for this flight segment at the time of capacity snapshot.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bookedWeightKg rdf:type rdf:Property ;
    rdfs:label 'Booked Weight Kg' ;
    rdfs:comment 'Total weight in kilograms of cargo bookings confirmed for this flight segment at the time of capacity snapshot.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:bulkCargoAllowedFlag rdf:type rdf:Property ;
    rdfs:label 'Bulk Cargo Allowed Flag' ;
    rdfs:comment 'Indicates whether loose (non-containerized) bulk cargo is accepted on this flight segment (True) or only ULD cargo is permitted (False).' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:capacityStatus rdf:type rdf:Property ;
    rdfs:label 'Capacity Status' ;
    rdfs:comment 'Current booking status of cargo capacity for this flight segment: open (accepting bookings), limited (restricted availability), closed (no capacity), waitlist (overbooked, accepting waitlist), embargoed (no new bookings allowed), cancelled (flight cancelled).' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:controlMethod rdf:type rdf:Property ;
    rdfs:label 'Control Method' ;
    rdfs:comment 'Method by which capacity allocation is managed for this flight: manual (human-controlled), automated (system-driven revenue management), or hybrid (combination of both).' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:embargoFlag rdf:type rdf:Property ;
    rdfs:label 'Embargo Flag' ;
    rdfs:comment 'Indicates whether a cargo embargo is in effect for this flight segment, preventing new bookings (True) or allowing normal operations (False).' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mainDeckVolumeCapacityCbm rdf:type rdf:Property ;
    rdfs:label 'Main Deck Volume Capacity Cbm' ;
    rdfs:comment 'Total available volume capacity in cubic meters for main deck cargo on freighter or combi aircraft. Null for passenger-only configurations.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mainDeckWeightCapacityKg rdf:type rdf:Property ;
    rdfs:label 'Main Deck Weight Capacity Kg' ;
    rdfs:comment 'Total available weight capacity in kilograms for main deck cargo on freighter or combi aircraft. Null for passenger-only configurations.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:overbookingFactorPercent rdf:type rdf:Property ;
    rdfs:label 'Overbooking Factor Percent' ;
    rdfs:comment 'Percentage by which capacity may be overbooked to account for expected no-shows and cancellations. Used in revenue management optimization.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalVolumeCapacityCbm rdf:type rdf:Property ;
    rdfs:label 'Total Volume Capacity Cbm' ;
    rdfs:comment 'Total available cargo volume capacity in cubic meters across all compartments (belly plus main deck if applicable) for this flight segment.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalWeightCapacityKg rdf:type rdf:Property ;
    rdfs:label 'Total Weight Capacity Kg' ;
    rdfs:comment 'Total available cargo weight capacity in kilograms across all compartments (belly plus main deck if applicable) for this flight segment.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:uldPositionsAvailable rdf:type rdf:Property ;
    rdfs:label 'Uld Positions Available' ;
    rdfs:comment 'Number of Unit Load Device (ULD) positions available for loading on this flight segment. Applies to containerized cargo.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:uldPositionsBooked rdf:type rdf:Property ;
    rdfs:label 'Uld Positions Booked' ;
    rdfs:comment 'Number of Unit Load Device (ULD) positions already booked for this flight segment.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:volumeUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Volume Unit Of Measure' ;
    rdfs:comment 'Unit of measure for all volume capacity fields. Standardized to cubic meters (CBM) per IATA standards.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:weightUnitOfMeasure rdf:type rdf:Property ;
    rdfs:label 'Weight Unit Of Measure' ;
    rdfs:comment 'Unit of measure for all weight capacity fields. Standardized to kilograms (KG) per IATA standards.' ;
    rdfs:domain ind:Capacity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountStatus rdf:type rdf:Property ;
    rdfs:label 'Account Status' ;
    rdfs:comment 'Current operational status of the freight forwarder account with the airline: active (operational), inactive (dormant), suspended (temporarily blocked), credit_hold (financial restriction), terminated (closed).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accreditationDate rdf:type rdf:Property ;
    rdfs:label 'Accreditation Date' ;
    rdfs:comment 'Date when the freight forwarder received IATA cargo agent accreditation.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accreditationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Accreditation Expiry Date' ;
    rdfs:comment 'Date when the current IATA accreditation expires and requires renewal.' ;
    rdfs:domain ind:FreightForwarder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:approvedCommodityTypes rdf:type rdf:Property ;
    rdfs:label 'Approved Commodity Types' ;
    rdfs:comment 'Comma-separated list of commodity types or special cargo categories the freight forwarder is approved to handle (e.g., perishables, pharmaceuticals, live_animals, valuables, dangerous_goods). [ENUM-REF-CANDIDATE: general_cargo|perishables|pharmaceuticals|live_animals|valuables|dangerous_goods|oversized|temperature_controlled|hazmat — promote to reference product]' ;
    rdfs:domain ind:FreightForwarder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bspParticipationFlag rdf:type rdf:Property ;
    rdfs:label 'Bsp Participation Flag' ;
    rdfs:comment 'Indicates whether the freight forwarder participates in IATA BSP for passenger ticket settlement (some cargo agents also handle passenger bookings). True if participating, False otherwise.' ;
    rdfs:domain ind:FreightForwarder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:businessRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Business Registration Number' ;
    rdfs:comment 'Official business or company registration number issued by the local government authority.' ;
    rdfs:domain ind:FreightForwarder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cassNumber rdf:type rdf:Property ;
    rdfs:label 'Cass Number' ;
    rdfs:comment 'Unique identifier assigned within the IATA CASS billing and settlement system for cargo transactions.' ;
    rdfs:domain ind:FreightForwarder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cassParticipationFlag rdf:type rdf:Property ;
    rdfs:label 'Cass Participation Flag' ;
    rdfs:comment 'Indicates whether the freight forwarder participates in IATA CASS for cargo billing settlement. True if participating, False otherwise.' ;
    rdfs:domain ind:FreightForwarder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:creditLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Amount' ;
    rdfs:comment 'Maximum credit exposure allowed for this freight forwarder in the airline\'s base currency. Used for credit risk management.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditLimitCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Credit Limit Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the credit limit amount.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dgCertificationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Dg Certification Expiry Date' ;
    rdfs:comment 'Expiration date of the dangerous goods handling certification.' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dgCertificationNumber rdf:type rdf:Property ;
    rdfs:label 'Dg Certification Number' ;
    rdfs:comment 'Certification number or reference for dangerous goods handling authorization.' ;
    rdfs:domain ind:Cargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dgHandlingCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Dg Handling Certified Flag' ;
    rdfs:comment 'Indicates whether the freight forwarder is certified to handle dangerous goods shipments per IATA DGR. True if certified, False otherwise.' ;
    rdfs:domain ind:FreightForwarder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:forwarderType rdf:type rdf:Property ;
    rdfs:label 'Forwarder Type' ;
    rdfs:comment 'Classification of the freight forwarder business model: direct_agent (direct cargo agent), consolidator (consolidates shipments), gsa (general sales agent), broker (intermediary), nvocc (non-vessel operating common carrier), integrated_logistics (full-service logistics provider).' ;
    rdfs:domain ind:FreightForwarder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iataAccreditationStatus rdf:type rdf:Property ;
    rdfs:label 'Iata Accreditation Status' ;
    rdfs:comment 'Current accreditation status with IATA Cargo Agency Program: accredited (full accreditation), provisional (temporary accreditation), suspended (temporarily suspended), revoked (accreditation removed), not_accredited (no IATA accreditation).' ;
    rdfs:domain ind:FreightForwarder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iataCargoAgentCode rdf:type rdf:Property ;
    rdfs:label 'Iata Cargo Agent Code' ;
    rdfs:comment 'Seven or eight-digit numeric code assigned by IATA to identify accredited cargo agents globally. Primary business identifier for cargo commercial partners.' ;
    rdfs:domain ind:FreightForwarder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTermsDays rdf:type rdf:Property ;
    rdfs:label 'Payment Terms Days' ;
    rdfs:comment 'Number of days allowed for payment after invoice date (e.g., 30 for Net 30 terms).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:stationCoverage rdf:type rdf:Property ;
    rdfs:label 'Station Coverage' ;
    rdfs:comment 'Comma-separated list of three-letter IATA airport codes where the freight forwarder has operational presence or coverage.' ;
    rdfs:domain ind:FreightForwarder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxIdentificationNumber rdf:type rdf:Property ;
    rdfs:label 'Tax Identification Number' ;
    rdfs:comment 'Tax identification number (TIN, VAT number, or equivalent) for the freight forwarder in their country of registration.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tradeName rdf:type rdf:Property ;
    rdfs:label 'Trade Name' ;
    rdfs:comment 'Operating or trade name used by the freight forwarder in commercial transactions, may differ from legal name.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:websiteUrl rdf:type rdf:Property ;
    rdfs:label 'Website Url' ;
    rdfs:comment 'Official website URL of the freight forwarder company.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blacklistReason rdf:type rdf:Property ;
    rdfs:label 'Blacklist Reason' ;
    rdfs:comment 'Reason for blacklisting the shipper if status is blacklisted. Includes security violations, payment defaults, or regulatory non-compliance. Null if not blacklisted.' ;
    rdfs:domain ind:Shipper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:commoditySpecialization rdf:type rdf:Property ;
    rdfs:label 'Commodity Specialization' ;
    rdfs:comment 'Primary commodity types or industries the shipper specializes in (e.g., pharmaceuticals, perishables, electronics, automotive, textiles). Free-text field for multiple specializations.' ;
    rdfs:domain ind:Shipper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactFax rdf:type rdf:Property ;
    rdfs:label 'Contact Fax' ;
    rdfs:comment 'Fax number for the shipper contact. May be null if fax is not used.' ;
    rdfs:domain ind:Shipper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactName rdf:type rdf:Property ;
    rdfs:label 'Contact Name' ;
    rdfs:comment 'Full name of the primary contact person at the shipper organization.' ;
    rdfs:domain ind:Shipper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditStatus rdf:type rdf:Property ;
    rdfs:label 'Credit Status' ;
    rdfs:comment 'Current credit status of the shipper for cargo services. Determines payment terms and credit limits.' ;
    rdfs:domain ind:Shipper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Customs Registration Number' ;
    rdfs:comment 'Shipper\'s registration number with the national customs authority. Required for international cargo shipments.' ;
    rdfs:domain ind:Shipper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dgShipperCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Dg Shipper Certified Flag' ;
    rdfs:comment 'Indicates whether the shipper is certified to tender dangerous goods (DG) cargo. True if certified, False otherwise.' ;
    rdfs:domain ind:Shipper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eoriNumber rdf:type rdf:Property ;
    rdfs:label 'Eori Number' ;
    rdfs:comment 'EORI number assigned by EU customs authorities for shippers operating in the European Union. Required for EU customs clearance.' ;
    rdfs:domain ind:Shipper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iataCassCode rdf:type rdf:Property ;
    rdfs:label 'Iata Cass Code' ;
    rdfs:comment 'IATA CASS code assigned to the shipper or their freight forwarder for billing and settlement purposes. Null if not enrolled in CASS.' ;
    rdfs:domain ind:Shipper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:knownShipperCertificationDate rdf:type rdf:Property ;
    rdfs:label 'Known Shipper Certification Date' ;
    rdfs:comment 'Date when the shipper was certified as a Known Shipper by the relevant aviation security authority.' ;
    rdfs:domain ind:Shipper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:knownShipperExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Known Shipper Expiry Date' ;
    rdfs:comment 'Date when the Known Shipper certification expires and requires renewal. Null if certification does not expire or is not applicable.' ;
    rdfs:domain ind:Shipper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:knownShipperStatus rdf:type rdf:Property ;
    rdfs:label 'Known Shipper Status' ;
    rdfs:comment 'IATA/ICAO security designation indicating whether the shipper has been validated and approved to tender cargo without additional security screening. Critical for aviation security compliance.' ;
    rdfs:domain ind:Shipper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastShipmentDate rdf:type rdf:Property ;
    rdfs:label 'Last Shipment Date' ;
    rdfs:comment 'Date of the most recent cargo shipment tendered by this shipper. Used for shipper activity tracking and dormancy analysis.' ;
    rdfs:domain ind:Shipper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:onboardingDate rdf:type rdf:Property ;
    rdfs:label 'Onboarding Date' ;
    rdfs:comment 'Date when the shipper was first onboarded and approved to tender cargo with the airline.' ;
    rdfs:domain ind:Shipper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:preferredCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Preferred Currency Code' ;
    rdfs:comment 'Three-letter ISO currency code representing the shipper\'s preferred currency for invoicing and rate quotations.' ;
    rdfs:domain ind:Shipper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipperName rdf:type rdf:Property ;
    rdfs:label 'Shipper Name' ;
    rdfs:comment 'Full legal name of the shipper entity tendering cargo for transport. May be individual or corporate name.' ;
    rdfs:domain ind:Shipper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipperStatus rdf:type rdf:Property ;
    rdfs:label 'Shipper Status' ;
    rdfs:comment 'Current operational status of the shipper account. Active shippers can tender cargo; inactive, suspended, or blacklisted shippers cannot.' ;
    rdfs:domain ind:Shipper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipperType rdf:type rdf:Property ;
    rdfs:label 'Shipper Type' ;
    rdfs:comment 'Classification of the shipper entity type. Distinguishes between individual shippers, corporate entities, regulated agents, freight forwarders acting as shippers, government agencies, manufacturers, and retailers. [ENUM-REF-CANDIDATE: individual|corporate|regulated_agent|freight_forwarder|government|manufacturer|retailer — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Shipper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalShipmentsCount rdf:type rdf:Property ;
    rdfs:label 'Total Shipments Count' ;
    rdfs:comment 'Cumulative count of all cargo shipments tendered by this shipper since onboarding. Used for shipper volume analysis.' ;
    rdfs:domain ind:Shipper ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:invoiceId rdf:type rdf:Property ;
    rdfs:label 'Invoice Id' ;
    rdfs:comment 'Primary key for invoice' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:billedShipperId rdf:type rdf:Property ;
    rdfs:label 'Billed Shipper Id' ;
    rdfs:comment 'Foreign key linking to cargo.shipper. Business justification: Invoice has billing_party_id (BIGINT) and billing_party_type (STRING). When billing_party_type=\'SHIPPER\', this should FK to shipper. Adding billed_shipper_id as a labeled FK (nullable, populated when ' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Shipper .

ind:invoiceBilledFreightForwarderId rdf:type rdf:Property ;
    rdfs:label 'Invoice Billed Freight Forwarder Id' ;
    rdfs:comment 'Foreign key linking to cargo.freight_forwarder. Business justification: Invoice has billing_party_id (BIGINT) and billing_party_type (STRING). When billing_party_type=\'FORWARDER\', this should FK to freight_forwarder. Adding billed_freight_forwarder_id as a labeled FK (nul' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FreightForwarder .

ind:invoiceFreightForwarderId rdf:type rdf:Property ;
    rdfs:label 'Invoice Freight Forwarder Id' ;
    rdfs:comment 'Reference to the party (freight forwarder, shipper, or consignee) being invoiced for cargo transportation charges.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:FreightForwarder .

ind:billingPartyAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Billing Party Account Number' ;
    rdfs:comment 'Customer account number or IATA CASS agent code of the billing party. Used for account reconciliation and settlement.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingPartyName rdf:type rdf:Property ;
    rdfs:label 'Billing Party Name' ;
    rdfs:comment 'Legal name of the party being billed. Captured for invoice presentation and audit trail.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:billingPartyType rdf:type rdf:Property ;
    rdfs:label 'Billing Party Type' ;
    rdfs:comment 'Type of party being billed: freight forwarder (consolidator), shipper (consignor), consignee (receiver), agent (GSA/handling agent), airline (interline partner), or broker.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cassPeriod rdf:type rdf:Property ;
    rdfs:label 'Cass Period' ;
    rdfs:comment 'IATA CASS billing period in YYYY-MM format (e.g., 2024-03). Used for settlement cycle reconciliation.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cassSettlementReference rdf:type rdf:Property ;
    rdfs:label 'Cass Settlement Reference' ;
    rdfs:comment 'IATA CASS settlement reference number for invoices processed through the CASS billing and settlement system.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsClearanceFee rdf:type rdf:Property ;
    rdfs:label 'Customs Clearance Fee' ;
    rdfs:comment 'Fee for customs clearance services provided by the airline or handling agent.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dgSurcharge rdf:type rdf:Property ;
    rdfs:label 'Dg Surcharge' ;
    rdfs:comment 'Surcharge for handling dangerous goods (DG) shipments requiring special handling, documentation, and compliance with IATA DGR.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightChargeCollect rdf:type rdf:Property ;
    rdfs:label 'Freight Charge Collect' ;
    rdfs:comment 'Total freight charges to be collected from the consignee at destination. Excludes prepaid charges.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:freightChargePrepaid rdf:type rdf:Property ;
    rdfs:label 'Freight Charge Prepaid' ;
    rdfs:comment 'Total freight charges paid by the shipper at origin. Excludes collect charges.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuelSurcharge rdf:type rdf:Property ;
    rdfs:label 'Fuel Surcharge' ;
    rdfs:comment 'Fuel surcharge applied to the shipment to offset variable fuel costs. Typically calculated as a percentage of freight charges.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:handlingFee rdf:type rdf:Property ;
    rdfs:label 'Handling Fee' ;
    rdfs:comment 'Ground handling and terminal processing fees for cargo acceptance, storage, and delivery.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceType rdf:type rdf:Property ;
    rdfs:label 'Invoice Type' ;
    rdfs:comment 'Type of invoice document: standard invoice, credit note (refund/reversal), debit note (additional charges), proforma (advance estimate), adjustment (correction), or supplementary (additional billing).' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oversizeSurcharge rdf:type rdf:Property ;
    rdfs:label 'Oversize Surcharge' ;
    rdfs:comment 'Surcharge for oversized or non-standard cargo requiring special handling or equipment.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentTerms rdf:type rdf:Property ;
    rdfs:label 'Payment Terms' ;
    rdfs:comment 'Payment terms agreed with the billing party: net_7 (7 days), net_15, net_30, net_45, net_60, due_on_receipt, prepaid, or COD (cash on delivery). [ENUM-REF-CANDIDATE: net_7|net_15|net_30|net_45|net_60|due_on_receipt|prepaid|cod — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:securitySurcharge rdf:type rdf:Property ;
    rdfs:label 'Security Surcharge' ;
    rdfs:comment 'Security surcharge for cargo screening and security compliance (TSA, EASA requirements).' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:storageFee rdf:type rdf:Property ;
    rdfs:label 'Storage Fee' ;
    rdfs:comment 'Warehouse storage fees for cargo held beyond free storage period.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:subtotalAmount rdf:type rdf:Property ;
    rdfs:label 'Subtotal Amount' ;
    rdfs:comment 'Sum of all freight charges and surcharges before taxes. Equals freight_charge_prepaid + freight_charge_collect + all surcharges.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:claimId rdf:type rdf:Property ;
    rdfs:label 'Claim Id' ;
    rdfs:comment 'Primary key for claim' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:claimStatus rdf:type rdf:Property ;
    rdfs:label 'Claim Status' ;
    rdfs:comment 'Current lifecycle status of the claim in the adjudication workflow. [ENUM-REF-CANDIDATE: draft|filed|under_investigation|pending_documents|liability_determined|approved|settled|rejected|closed — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimType rdf:type rdf:Property ;
    rdfs:label 'Claim Type' ;
    rdfs:comment 'Classification of the claim incident: loss (missing shipment), damage (physical harm to goods), delay (late delivery), pilferage (theft), shortage (partial loss), or contamination (quality degradation).' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimantAddress rdf:type rdf:Property ;
    rdfs:label 'Claimant Address' ;
    rdfs:comment 'Full mailing address of the claimant for official correspondence and settlement payment.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimantContactEmail rdf:type rdf:Property ;
    rdfs:label 'Claimant Contact Email' ;
    rdfs:comment 'Primary email address for claim correspondence and notifications.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimantContactPhone rdf:type rdf:Property ;
    rdfs:label 'Claimant Contact Phone' ;
    rdfs:comment 'Primary telephone number for claimant contact during claim investigation.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimantName rdf:type rdf:Property ;
    rdfs:label 'Claimant Name' ;
    rdfs:comment 'Full legal name of the party filing the claim (shipper, consignee, or their authorized representative).' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimantType rdf:type rdf:Property ;
    rdfs:label 'Claimant Type' ;
    rdfs:comment 'Classification of the claimant party role in the shipment transaction.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:claimedAmount rdf:type rdf:Property ;
    rdfs:label 'Claimed Amount' ;
    rdfs:comment 'Total monetary amount claimed by the claimant for loss, damage, or delay, in the claim currency.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discoveryDate rdf:type rdf:Property ;
    rdfs:label 'Discovery Date' ;
    rdfs:comment 'Date when the loss, damage, or delay was first discovered by the claimant or carrier.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:incidentDate rdf:type rdf:Property ;
    rdfs:label 'Incident Date' ;
    rdfs:comment 'Date when the incident (loss, damage, delay) is believed to have occurred, if determinable.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:insuranceClaimReference rdf:type rdf:Property ;
    rdfs:label 'Insurance Claim Reference' ;
    rdfs:comment 'Reference number of the corresponding insurance claim filed by the carrier for recovery, if applicable.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceRecoveryFlag rdf:type rdf:Property ;
    rdfs:label 'Insurance Recovery Flag' ;
    rdfs:comment 'Indicates whether the carrier pursued or intends to pursue insurance recovery for this claim.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:investigationNotes rdf:type rdf:Property ;
    rdfs:label 'Investigation Notes' ;
    rdfs:comment 'Internal notes and findings from the claim investigation process.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liabilityDetermination rdf:type rdf:Property ;
    rdfs:label 'Liability Determination' ;
    rdfs:comment 'Outcome of the liability assessment: whether the carrier is liable, not liable, partially liable, or a third party is liable.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liabilityLimitApplicable rdf:type rdf:Property ;
    rdfs:label 'Liability Limit Applicable' ;
    rdfs:comment 'Indicates whether the Montreal Convention liability limit (Special Drawing Rights per kilogram) applies to this claim.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:outcome rdf:type rdf:Property ;
    rdfs:label 'Outcome' ;
    rdfs:comment 'Final outcome of the claim adjudication process.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:shipmentPieces rdf:type rdf:Property ;
    rdfs:label 'Shipment Pieces' ;
    rdfs:comment 'Number of pieces in the shipment as declared on the AWB.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:shipmentWeightKg rdf:type rdf:Property ;
    rdfs:label 'Shipment Weight Kg' ;
    rdfs:comment 'Total weight of the shipment in kilograms as declared on the AWB.' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supportingDocumentsList rdf:type rdf:Property ;
    rdfs:label 'Supporting Documents List' ;
    rdfs:comment 'Comma-separated list or description of supporting documents submitted with the claim (e.g., commercial invoice, packing list, photos, survey report, delivery receipt).' ;
    rdfs:domain ind:Claim ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadmasterQualificationId rdf:type rdf:Property ;
    rdfs:label 'Loadmaster Qualification Id' ;
    rdfs:comment 'Foreign key linking to crew.qualification. Business justification: Regulatory audit trail: aviation authorities require proof that the crew member who signed the load sheet held a valid weight-and-balance qualification at time of signing. Linking load_plan to the spe' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Qualification .

ind:actualTakeoffWeightKg rdf:type rdf:Property ;
    rdfs:label 'Actual Takeoff Weight Kg' ;
    rdfs:comment 'Actual calculated takeoff weight for this flight including zero fuel weight plus fuel load. Must not exceed maximum takeoff weight.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:actualZeroFuelWeightKg rdf:type rdf:Property ;
    rdfs:label 'Actual Zero Fuel Weight Kg' ;
    rdfs:comment 'Actual calculated zero fuel weight for this flight including passengers, baggage, cargo, and crew. Must not exceed maximum zero fuel weight.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:aftHoldWeightKg rdf:type rdf:Property ;
    rdfs:label 'Aft Hold Weight Kg' ;
    rdfs:comment 'Weight of cargo loaded in the aft cargo hold in kilograms. Critical for center of gravity calculation.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:arrivalStation rdf:type rdf:Property ;
    rdfs:label 'Arrival Station' ;
    rdfs:comment 'Three-letter IATA airport code for the arrival station (e.g., LAX, CDG).' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bulkHoldWeightKg rdf:type rdf:Property ;
    rdfs:label 'Bulk Hold Weight Kg' ;
    rdfs:comment 'Weight of loose cargo loaded in the bulk cargo hold in kilograms. Typically used for non-containerized shipments.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cargoCenterOfGravityMacPercent rdf:type rdf:Property ;
    rdfs:label 'Cargo Center Of Gravity Mac Percent' ;
    rdfs:comment 'Cargo contribution to the aircraft center of gravity expressed as a percentage of Mean Aerodynamic Chord (MAC). Critical for flight safety and trim calculation.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cargoVolumeCubicMeters rdf:type rdf:Property ;
    rdfs:label 'Cargo Volume Cubic Meters' ;
    rdfs:comment 'Total volume of cargo loaded in cubic meters. Used for volumetric capacity utilization analysis alongside weight.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dangerousGoodsOnboardFlag rdf:type rdf:Property ;
    rdfs:label 'Dangerous Goods Onboard Flag' ;
    rdfs:comment 'Indicates whether dangerous goods (hazardous materials) are included in the cargo load. Triggers additional handling and notification requirements.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:departureStation rdf:type rdf:Property ;
    rdfs:label 'Departure Station' ;
    rdfs:comment 'Three-letter IATA airport code for the departure station (e.g., JFK, LHR). Used for station-specific cargo handling rules.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dispatchReleaseFlag rdf:type rdf:Property ;
    rdfs:label 'Dispatch Release Flag' ;
    rdfs:comment 'Indicates whether the flight dispatcher has released the flight for departure based on this load plan. True indicates dispatch approval granted.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:forwardHoldWeightKg rdf:type rdf:Property ;
    rdfs:label 'Forward Hold Weight Kg' ;
    rdfs:comment 'Weight of cargo loaded in the forward cargo hold in kilograms. Critical for center of gravity calculation.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:loadPlanStatus rdf:type rdf:Property ;
    rdfs:label 'Load Plan Status' ;
    rdfs:comment 'Current lifecycle status of the load plan. Draft indicates planning in progress; final indicates approved for dispatch; closed indicates flight departed.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadSheetReference rdf:type rdf:Property ;
    rdfs:label 'Load Sheet Reference' ;
    rdfs:comment 'Reference number of the official load sheet document generated for this flight. Links to the regulatory load and trim sheet.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loadmasterSignoffTimestamp rdf:type rdf:Property ;
    rdfs:label 'Loadmaster Signoff Timestamp' ;
    rdfs:comment 'Date and time when the loadmaster signed off on the load plan, certifying accuracy and compliance. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:maximumLandingWeightKg rdf:type rdf:Property ;
    rdfs:label 'Maximum Landing Weight Kg' ;
    rdfs:comment 'Maximum allowable landing weight for the destination airport based on aircraft structural limits and runway conditions.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumTakeoffWeightKg rdf:type rdf:Property ;
    rdfs:label 'Maximum Takeoff Weight Kg' ;
    rdfs:comment 'Maximum allowable takeoff weight for this flight based on aircraft performance, runway length, weather, and regulatory limits.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maximumZeroFuelWeightKg rdf:type rdf:Property ;
    rdfs:label 'Maximum Zero Fuel Weight Kg' ;
    rdfs:comment 'Maximum allowable weight of the aircraft without fuel for this flight, based on aircraft type and configuration. Regulatory limit for structural integrity.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:plannedLandingWeightKg rdf:type rdf:Property ;
    rdfs:label 'Planned Landing Weight Kg' ;
    rdfs:comment 'Planned landing weight at destination calculated as takeoff weight minus planned fuel burn. Must not exceed maximum landing weight.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:specialLoadFlag rdf:type rdf:Property ;
    rdfs:label 'Special Load Flag' ;
    rdfs:comment 'Indicates whether the cargo includes special loads requiring non-standard handling (e.g., live animals, human remains, valuable cargo, oversized items).' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:totalCargoWeightKg rdf:type rdf:Property ;
    rdfs:label 'Total Cargo Weight Kg' ;
    rdfs:comment 'Total weight of all cargo loaded on the flight in kilograms, including belly cargo and ULDs. Excludes passenger baggage.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:trimAdjustmentRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Trim Adjustment Required Flag' ;
    rdfs:comment 'Indicates whether trim adjustment is required due to cargo loading. True if cargo distribution requires stabilizer trim beyond normal range.' ;
    rdfs:domain ind:LoadPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:affectedRoutePattern rdf:type rdf:Property ;
    rdfs:label 'Affected Route Pattern' ;
    rdfs:comment 'Route pattern or route group affected by the embargo (e.g., \'JFK-LHR\', \'US-EU\', \'Transatlantic\'). Nullable if embargo is station-specific or commodity-specific without route constraint.' ;
    rdfs:domain ind:Embargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Effective End Timestamp' ;
    rdfs:comment 'Date and time when the embargo expires and restrictions are lifted. Nullable for indefinite embargoes. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Embargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:effectiveStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Effective Start Timestamp' ;
    rdfs:comment 'Date and time when the embargo becomes effective and restrictions begin to apply. Format: yyyy-MM-ddTHH:mm:ss.SSSXXX.' ;
    rdfs:domain ind:Embargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:embargoStatus rdf:type rdf:Property ;
    rdfs:label 'Embargo Status' ;
    rdfs:comment 'Current lifecycle status of the embargo: draft (pending approval), active (in effect), suspended (temporarily paused), expired (end date reached), or cancelled (terminated before expiry).' ;
    rdfs:domain ind:Embargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:embargoType rdf:type rdf:Property ;
    rdfs:label 'Embargo Type' ;
    rdfs:comment 'Classification of the embargo defining the nature of the restriction: station closure (airport/facility closed), commodity restriction (specific goods prohibited), weight restriction (weight limits imposed), dangerous goods restriction (DG acceptance suspended), seasonal embargo (recurring seasonal restriction), or capacity embargo (capacity allocation frozen).' ;
    rdfs:domain ind:Embargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:overrideApprovalAuthority rdf:type rdf:Property ;
    rdfs:label 'Override Approval Authority' ;
    rdfs:comment 'Role or department authorized to approve exceptions to the embargo (e.g., \'Cargo Director\', \'Station Manager\', \'Safety Officer\'). Nullable if no override is permitted.' ;
    rdfs:domain ind:Embargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeRestrictionCbm rdf:type rdf:Property ;
    rdfs:label 'Volume Restriction Cbm' ;
    rdfs:comment 'Maximum volume in cubic meters allowed under the embargo. Nullable if embargo is not volume-based.' ;
    rdfs:domain ind:Embargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:weightRestrictionKg rdf:type rdf:Property ;
    rdfs:label 'Weight Restriction Kg' ;
    rdfs:comment 'Maximum weight in kilograms allowed under the embargo. Nullable if embargo is not weight-based.' ;
    rdfs:domain ind:Embargo ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:customsEntryId rdf:type rdf:Property ;
    rdfs:label 'Customs Entry Id' ;
    rdfs:comment 'Unique identifier for the customs declaration record. Primary key for the customs entry entity.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:portOfEntryStationId rdf:type rdf:Property ;
    rdfs:label 'Port Of Entry Station Id' ;
    rdfs:comment 'Foreign key linking to airport.station. Business justification: Customs entries specify port_of_entry_code for clearance. Station link validates customs facility availability, regulatory authority, broker assignment, operating hours, and examination capability for' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Station .

ind:certificateOfOriginNumber rdf:type rdf:Property ;
    rdfs:label 'Certificate Of Origin Number' ;
    rdfs:comment 'Reference number of the certificate of origin document supporting the declared country of origin. Required for preferential duty claims.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargesCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Charges Currency Code' ;
    rdfs:comment 'Three-letter ISO currency code for all customs charges and fees. Typically the currency of the importing or exporting country.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfDestination rdf:type rdf:Property ;
    rdfs:label 'Country Of Destination' ;
    rdfs:comment 'Three-letter ISO country code indicating the final destination country for the goods. Used for export control and trade statistics.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfExport rdf:type rdf:Property ;
    rdfs:label 'Country Of Export' ;
    rdfs:comment 'Three-letter ISO country code indicating the country from which the goods were exported. May differ from country of origin for re-exports.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfOrigin rdf:type rdf:Property ;
    rdfs:label 'Country Of Origin' ;
    rdfs:comment 'Three-letter ISO country code indicating where the goods were manufactured or produced. Determines eligibility for preferential trade agreements and origin-based duties.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsBrokerLicenseNumber rdf:type rdf:Property ;
    rdfs:label 'Customs Broker License Number' ;
    rdfs:comment 'Official license or registration number of the customs broker authorized to conduct customs business in the jurisdiction.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:customsDutyAmount rdf:type rdf:Property ;
    rdfs:label 'Customs Duty Amount' ;
    rdfs:comment 'Total customs duty assessed on the imported or exported goods. Calculated based on tariff classification, value, and applicable trade agreements.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:entryNumber rdf:type rdf:Property ;
    rdfs:label 'Entry Number' ;
    rdfs:comment 'Official customs entry number assigned by the customs authority. Unique identifier for tracking the declaration through customs clearance process.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryStatus rdf:type rdf:Property ;
    rdfs:label 'Entry Status' ;
    rdfs:comment 'Current status of the customs entry in the clearance workflow. Tracks progression from initial filing through final release or other disposition. [ENUM-REF-CANDIDATE: draft|filed|under_examination|released|held|seized|cancelled — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryType rdf:type rdf:Property ;
    rdfs:label 'Entry Type' ;
    rdfs:comment 'Type of customs declaration indicating the nature of the cargo movement across borders. Determines applicable customs procedures and documentation requirements.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:examinationResult rdf:type rdf:Property ;
    rdfs:label 'Examination Result' ;
    rdfs:comment 'Outcome of the customs examination or inspection. Indicates whether the cargo passed inspection or if issues were identified.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:examinationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Examination Timestamp' ;
    rdfs:comment 'Date and time when customs examination or inspection was conducted. Null if no examination was performed.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:exporterTaxNumber rdf:type rdf:Property ;
    rdfs:label 'Exporter Tax Number' ;
    rdfs:comment 'Tax identification number or business registration number of the exporter. Required for export documentation and compliance.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:filingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Filing Timestamp' ;
    rdfs:comment 'Date and time when the customs declaration was officially filed with the customs authority. Critical for compliance with advance filing requirements.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:holdReason rdf:type rdf:Property ;
    rdfs:label 'Hold Reason' ;
    rdfs:comment 'Explanation for why the cargo is being held by customs. May include documentation issues, valuation disputes, or regulatory concerns.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hsCode rdf:type rdf:Property ;
    rdfs:label 'Hs Code' ;
    rdfs:comment 'International commodity classification code used to determine applicable duties, taxes, and regulatory requirements. Six to ten digit code from the Harmonized Commodity Description and Coding System.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:importerOfRecord rdf:type rdf:Property ;
    rdfs:label 'Importer Of Record' ;
    rdfs:comment 'Legal name of the party responsible for ensuring imported goods comply with local laws and for paying duties and taxes. Legally liable entity for the import.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:importerTaxNumber rdf:type rdf:Property ;
    rdfs:label 'Importer Tax Number' ;
    rdfs:comment 'Tax identification number or business registration number of the importer of record. Required for customs clearance and duty payment.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferentialTradeAgreement rdf:type rdf:Property ;
    rdfs:label 'Preferential Trade Agreement' ;
    rdfs:comment 'Name or code of the preferential trade agreement under which reduced duties are claimed. Examples include USMCA, EU-FTA, ASEAN agreements.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryAuthorityCode rdf:type rdf:Property ;
    rdfs:label 'Regulatory Authority Code' ;
    rdfs:comment 'Code identifying the customs or regulatory authority responsible for processing this entry. May be port-specific or national authority code.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialProgramIndicator rdf:type rdf:Property ;
    rdfs:label 'Special Program Indicator' ;
    rdfs:comment 'Code or flag indicating participation in special customs programs such as AEO (Authorized Economic Operator), C-TPAT, or bonded warehouse programs.' ;
    rdfs:domain ind:CustomsEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:baseStationId rdf:type rdf:Property ;
    rdfs:label 'Base Station Id' ;
    rdfs:comment 'Foreign key linking to airport.station. Business justification: Aircraft home base assignment drives crew rostering, maintenance scheduling, and fleet deployment planning. Essential for operational planning and cost allocation. Replaces denormalized base_station_c' ;
    rdfs:domain ind:Aircraft ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Station .

ind:lessorId rdf:type rdf:Property ;
    rdfs:label 'Lessor Id' ;
    rdfs:comment 'Foreign key linking to fleet.lessor. Business justification: aircraft has denormalized lessor_name (STRING) attribute. For leased aircraft, the lessor is a critical operational reference. The lessor product exists in fleet domain as the authoritative master. Th' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Lessor .

ind:airworthinessCategory rdf:type rdf:Property ;
    rdfs:label 'Airworthiness Category' ;
    rdfs:comment 'The category of airworthiness certificate issued. Standard = normal commercial operations; Restricted = limited operations; Limited = special purpose; Experimental = testing; Provisional = pre-certification.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apuManufacturer rdf:type rdf:Property ;
    rdfs:label 'Apu Manufacturer' ;
    rdfs:comment 'The manufacturer of the Auxiliary Power Unit installed on the aircraft (e.g., Honeywell, Pratt & Whitney, Hamilton Sundstrand).' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apuModel rdf:type rdf:Property ;
    rdfs:label 'Apu Model' ;
    rdfs:comment 'The specific model designation of the Auxiliary Power Unit installed on the aircraft.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cabinConfigurationCode rdf:type rdf:Property ;
    rdfs:label 'Cabin Configuration Code' ;
    rdfs:comment 'Internal code identifying the specific cabin layout and seat map configuration installed on this aircraft (e.g., 2-class, 3-class, high-density). Links to detailed seat map reference data.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:catIiiIlsApproved rdf:type rdf:Property ;
    rdfs:label 'Cat Iii Ils Approved' ;
    rdfs:comment 'Indicates whether the aircraft is equipped and certified for CAT III ILS precision approaches in very low visibility conditions (decision height below 100 feet or no decision height).' ;
    rdfs:domain ind:Aircraft ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificateOfAirworthinessNumber rdf:type rdf:Property ;
    rdfs:label 'Certificate Of Airworthiness Number' ;
    rdfs:comment 'The unique certificate number issued by the civil aviation authority certifying that the aircraft meets all safety and airworthiness standards for flight operations.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateOfRegistrationNumber rdf:type rdf:Property ;
    rdfs:label 'Certificate Of Registration Number' ;
    rdfs:comment 'The unique certificate number issued by the civil aviation authority proving legal registration of the aircraft.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryOfRegistration rdf:type rdf:Property ;
    rdfs:label 'Country Of Registration' ;
    rdfs:comment 'The three-letter ISO country code of the nation where the aircraft is registered (e.g., USA, GBR, DEU). Determines regulatory jurisdiction.' ;
    rdfs:domain ind:Aircraft ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryDate rdf:type rdf:Property ;
    rdfs:label 'Delivery Date' ;
    rdfs:comment 'The date the aircraft was delivered from the manufacturer to the original customer or the date it entered the current operator\'s fleet.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:etopsCertified rdf:type rdf:Property ;
    rdfs:label 'Etops Certified' ;
    rdfs:comment 'Indicates whether the aircraft holds ETOPS certification allowing extended-range operations over water or remote areas beyond single-engine diversion time limits.' ;
    rdfs:domain ind:Aircraft ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:etopsMinutesRating rdf:type rdf:Property ;
    rdfs:label 'Etops Minutes Rating' ;
    rdfs:comment 'The maximum diversion time in minutes that the aircraft is certified to fly from the nearest suitable airport under ETOPS rules (e.g., 120, 180, 207, 330 minutes). Null if not ETOPS certified.' ;
    rdfs:domain ind:Aircraft ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:melApplicable rdf:type rdf:Property ;
    rdfs:label 'Mel Applicable' ;
    rdfs:comment 'Indicates whether a Minimum Equipment List is applicable to this aircraft, allowing dispatch with certain non-critical equipment inoperative under controlled conditions.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:msn rdf:type rdf:Property ;
    rdfs:label 'Msn' ;
    rdfs:comment 'The unique serial number assigned by the aircraft manufacturer at the time of production. Permanent identifier that never changes regardless of ownership or registration.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noiseChapter rdf:type rdf:Property ;
    rdfs:label 'Noise Chapter' ;
    rdfs:comment 'The ICAO noise certification standard chapter that the aircraft meets. Chapter 4 is the most stringent current standard. Determines airport access and noise restrictions.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ownershipCategory rdf:type rdf:Property ;
    rdfs:label 'Ownership Category' ;
    rdfs:comment 'The legal and financial ownership structure of the aircraft. Owned = airline owns outright; Finance_lease = capital lease with purchase option; Operating_lease = rental without ownership transfer; Dry_lease = aircraft only; Wet_lease_in = aircraft with crew from lessor; ACMI = Aircraft Crew Maintenance Insurance lease.' ;
    rdfs:domain ind:Aircraft ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredOperator rdf:type rdf:Property ;
    rdfs:label 'Registered Operator' ;
    rdfs:comment 'The airline or operator name registered with the civil aviation authority as the entity authorized to operate this aircraft.' ;
    rdfs:domain ind:Aircraft ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeredOwner rdf:type rdf:Property ;
    rdfs:label 'Registered Owner' ;
    rdfs:comment 'The legal entity name appearing on the certificate of registration as the registered owner of the aircraft. May differ from operator for leased aircraft.' ;
    rdfs:domain ind:Aircraft ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationAuthority rdf:type rdf:Property ;
    rdfs:label 'Registration Authority' ;
    rdfs:comment 'The name of the civil aviation authority that issued the certificate of registration (e.g., FAA, EASA, CAAC, Transport Canada).' ;
    rdfs:domain ind:Aircraft ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationDate rdf:type rdf:Property ;
    rdfs:label 'Registration Date' ;
    rdfs:comment 'The date the current certificate of registration was issued by the civil aviation authority.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:registrationExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Registration Expiry Date' ;
    rdfs:comment 'The expiration date of the current certificate of registration. Aircraft must be re-registered before this date to maintain legal operating authority.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rvsmApproved rdf:type rdf:Property ;
    rdfs:label 'Rvsm Approved' ;
    rdfs:comment 'Indicates whether the aircraft is approved for RVSM operations allowing flight in airspace between FL290 and FL410 with 1,000-foot vertical separation.' ;
    rdfs:domain ind:Aircraft ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:seatingCapacityBusiness rdf:type rdf:Property ;
    rdfs:label 'Seating Capacity Business' ;
    rdfs:comment 'The number of seats in the business class cabin. Zero if aircraft does not have business class configuration.' ;
    rdfs:domain ind:Aircraft ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seatingCapacityEconomy rdf:type rdf:Property ;
    rdfs:label 'Seating Capacity Economy' ;
    rdfs:comment 'The number of seats in the economy class cabin.' ;
    rdfs:domain ind:Aircraft ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seatingCapacityFirst rdf:type rdf:Property ;
    rdfs:label 'Seating Capacity First' ;
    rdfs:comment 'The number of seats in the first class cabin. Zero if aircraft does not have first class configuration.' ;
    rdfs:domain ind:Aircraft ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seatingCapacityPremiumEconomy rdf:type rdf:Property ;
    rdfs:label 'Seating Capacity Premium Economy' ;
    rdfs:comment 'The number of seats in the premium economy cabin. Zero if aircraft does not have premium economy configuration.' ;
    rdfs:domain ind:Aircraft ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seatingCapacityTotal rdf:type rdf:Property ;
    rdfs:label 'Seating Capacity Total' ;
    rdfs:comment 'The total number of passenger seats installed on the aircraft across all cabin classes. Used for load factor and capacity planning calculations.' ;
    rdfs:domain ind:Aircraft ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tailNumber rdf:type rdf:Property ;
    rdfs:label 'Tail Number' ;
    rdfs:comment 'The official registration mark painted on the aircraft tail, serving as the globally unique identifier for the physical aircraft asset. Also known as registration mark or tail sign.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalCycles rdf:type rdf:Property ;
    rdfs:label 'Total Cycles' ;
    rdfs:comment 'Cumulative total number of flight cycles (takeoff and landing pairs) accumulated by the aircraft since delivery. Key metric for fatigue life and maintenance interval tracking.' ;
    rdfs:domain ind:Aircraft ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:aircraftFamily rdf:type rdf:Property ;
    rdfs:label 'Aircraft Family' ;
    rdfs:comment 'High-level aircraft family grouping (e.g., B737, A320, B777, A350, E190) used for fleet planning and commonality analysis.' ;
    rdfs:domain ind:AircraftType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aircraftTypeStatus rdf:type rdf:Property ;
    rdfs:label 'Aircraft Type Status' ;
    rdfs:comment 'Current lifecycle status of the aircraft type in the airline\'s context: active (currently operated), retired (formerly operated), planned (future fleet addition), reference (not operated, maintained for codeshare/interline/industry reference).' ;
    rdfs:domain ind:AircraftType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aircraftVariant rdf:type rdf:Property ;
    rdfs:label 'Aircraft Variant' ;
    rdfs:comment 'Specific aircraft variant within the family including generation and configuration details (e.g., B737-800, A320neo, B777-300ER, A350-900, E190-E2).' ;
    rdfs:domain ind:AircraftType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cargoVolumeM3 rdf:type rdf:Property ;
    rdfs:label 'Cargo Volume M3' ;
    rdfs:comment 'Total cargo hold volume in cubic meters. Used for cargo revenue planning and ULD capacity analysis.' ;
    rdfs:domain ind:AircraftType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emissionsStandard rdf:type rdf:Property ;
    rdfs:label 'Emissions Standard' ;
    rdfs:comment 'ICAO engine emissions standard (e.g., CAEP/6, CAEP/8, CAEP/10) indicating compliance level for NOx, CO, HC, and smoke. Used for CORSIA reporting and environmental compliance.' ;
    rdfs:domain ind:AircraftType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engineCount rdf:type rdf:Property ;
    rdfs:label 'Engine Count' ;
    rdfs:comment 'Number of engines installed on the aircraft type (typically 2, 3, or 4 for commercial jets; 2 for turboprops).' ;
    rdfs:domain ind:AircraftType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:engineModel rdf:type rdf:Property ;
    rdfs:label 'Engine Model' ;
    rdfs:comment 'Specific engine model and manufacturer (e.g., CFM56-7B, PW1100G-JM, GE90-115B, Trent XWB) used for maintenance planning and fuel efficiency analysis.' ;
    rdfs:domain ind:AircraftType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engineType rdf:type rdf:Property ;
    rdfs:label 'Engine Type' ;
    rdfs:comment 'Propulsion system type installed on the aircraft (turbofan for modern jets, turboprop for regional aircraft, turbojet for older jets, piston for small aircraft).' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:etopsBaselineMinutes rdf:type rdf:Property ;
    rdfs:label 'Etops Baseline Minutes' ;
    rdfs:comment 'Baseline ETOPS certification in minutes (e.g., 120, 180, 330, 370) indicating how far the aircraft can fly from the nearest suitable airport with one engine inoperative. Null for non-ETOPS or multi-engine (3+) aircraft.' ;
    rdfs:domain ind:AircraftType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:etopsCertifiedFlag rdf:type rdf:Property ;
    rdfs:label 'Etops Certified Flag' ;
    rdfs:comment 'Indicates whether this aircraft type holds ETOPS certification, enabling extended overwater and remote area operations for twin-engine aircraft.' ;
    rdfs:domain ind:Fleet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fleetEntryDate rdf:type rdf:Property ;
    rdfs:label 'Fleet Entry Date' ;
    rdfs:comment 'Date when this aircraft type first entered the airline\'s operating fleet. Null if not yet in fleet or planned only.' ;
    rdfs:domain ind:AircraftType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fleetExitDate rdf:type rdf:Property ;
    rdfs:label 'Fleet Exit Date' ;
    rdfs:comment 'Date when this aircraft type was retired from the airline\'s operating fleet. Null if still active or never operated.' ;
    rdfs:domain ind:AircraftType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:fuelCapacityLiters rdf:type rdf:Property ;
    rdfs:label 'Fuel Capacity Liters' ;
    rdfs:comment 'Total usable fuel capacity in liters. Critical for range calculation, fuel uplift planning, and operational cost analysis.' ;
    rdfs:domain ind:AircraftType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuselageLengthM rdf:type rdf:Property ;
    rdfs:label 'Fuselage Length M' ;
    rdfs:comment 'Overall length of the aircraft fuselage in meters. Impacts gate compatibility and ground handling requirements.' ;
    rdfs:domain ind:AircraftType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fuselageWidthCategory rdf:type rdf:Property ;
    rdfs:label 'Fuselage Width Category' ;
    rdfs:comment 'Classification of aircraft by fuselage width: narrowbody (single-aisle, e.g., A320, B737), widebody (twin-aisle, e.g., A350, B777), regional (smaller single-aisle, e.g., E190, CRJ).' ;
    rdfs:domain ind:AircraftType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iataTypeCode rdf:type rdf:Property ;
    rdfs:label 'Iata Type Code' ;
    rdfs:comment 'Three-character IATA aircraft type code used in reservation systems, schedules, and commercial documentation (e.g., 738 for Boeing 737-800, 32Q for Airbus A321neo).' ;
    rdfs:domain ind:AircraftType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:icaoTypeCode rdf:type rdf:Property ;
    rdfs:label 'Icao Type Code' ;
    rdfs:comment 'Four-character ICAO aircraft type designator used globally for flight planning, ATC communication, and operational documentation (e.g., B738 for Boeing 737-800, A20N for Airbus A320neo).' ;
    rdfs:domain ind:AircraftType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:inFleetFlag rdf:type rdf:Property ;
    rdfs:label 'In Fleet Flag' ;
    rdfs:comment 'Indicates whether this aircraft type is currently operated in the airline\'s fleet (true) or is a reference type for codeshare, interline, or future planning (false).' ;
    rdfs:domain ind:AircraftType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxPassengerCapacity rdf:type rdf:Property ;
    rdfs:label 'Max Passenger Capacity' ;
    rdfs:comment 'Maximum number of passenger seats that can be installed per the aircraft type certificate, regardless of airline-specific configuration. Used for regulatory compliance and emergency planning.' ;
    rdfs:domain ind:AircraftType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxRangeNm rdf:type rdf:Property ;
    rdfs:label 'Max Range Nm' ;
    rdfs:comment 'Maximum certified range in nautical miles with maximum fuel and reduced payload. Defines the aircraft\'s absolute capability for ultra-long-haul operations.' ;
    rdfs:domain ind:AircraftType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxStructuralPayloadKg rdf:type rdf:Property ;
    rdfs:label 'Max Structural Payload Kg' ;
    rdfs:comment 'Maximum weight of passengers, cargo, and baggage that can be carried, limited by structural design. Critical for load planning and revenue optimization.' ;
    rdfs:domain ind:AircraftType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mlwKg rdf:type rdf:Property ;
    rdfs:label 'Mlw Kg' ;
    rdfs:comment 'Maximum certified weight at which the aircraft is permitted to land. Determines whether fuel jettison is required in emergency return scenarios.' ;
    rdfs:domain ind:AircraftType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mtowKg rdf:type rdf:Property ;
    rdfs:label 'Mtow Kg' ;
    rdfs:comment 'Maximum certified weight at which the aircraft is permitted to take off. Determines runway length requirements, fuel capacity, and payload trade-offs.' ;
    rdfs:domain ind:AircraftType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mzfwKg rdf:type rdf:Property ;
    rdfs:label 'Mzfw Kg' ;
    rdfs:comment 'Maximum permitted weight of the aircraft and its contents (excluding usable fuel). Limits payload when fuel load is high. Critical for load planning.' ;
    rdfs:domain ind:AircraftType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:typicalBlockFuelPerHourKg rdf:type rdf:Property ;
    rdfs:label 'Typical Block Fuel Per Hour Kg' ;
    rdfs:comment 'Average fuel burn per block hour in kilograms under typical operating conditions. Used for CASK calculation, route profitability analysis, and fuel budgeting.' ;
    rdfs:domain ind:AircraftType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:typicalCruiseSpeedMach rdf:type rdf:Property ;
    rdfs:label 'Typical Cruise Speed Mach' ;
    rdfs:comment 'Typical cruise speed expressed as Mach number (e.g., 0.78, 0.82, 0.85). Used for flight planning, schedule optimization, and block time calculation.' ;
    rdfs:domain ind:AircraftType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:typicalRangeNm rdf:type rdf:Property ;
    rdfs:label 'Typical Range Nm' ;
    rdfs:comment 'Typical operational range in nautical miles with standard passenger load and reserves. Used for route network planning and aircraft assignment.' ;
    rdfs:domain ind:AircraftType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wakeTurbulenceCategory rdf:type rdf:Property ;
    rdfs:label 'Wake Turbulence Category' ;
    rdfs:comment 'ICAO wake turbulence category based on maximum takeoff weight: L (Light, <7000kg), M (Medium, 7000-136000kg), H (Heavy, >136000kg), J (Super, A380 only). Critical for ATC separation standards.' ;
    rdfs:domain ind:AircraftType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:wingspanM rdf:type rdf:Property ;
    rdfs:label 'Wingspan M' ;
    rdfs:comment 'Aircraft wingspan in meters. Determines gate compatibility, taxiway clearance requirements, and ICAO aerodrome reference code.' ;
    rdfs:domain ind:AircraftType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:businessClassSeatCount rdf:type rdf:Property ;
    rdfs:label 'Business Class Seat Count' ;
    rdfs:comment 'Number of seats in the Business Class cabin. Zero if Business Class is not offered in this configuration.' ;
    rdfs:domain ind:CabinConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:businessClassSeatPitchInches rdf:type rdf:Property ;
    rdfs:label 'Business Class Seat Pitch Inches' ;
    rdfs:comment 'Average seat pitch in Business Class, measured in inches. Null if Business Class is not offered.' ;
    rdfs:domain ind:CabinConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:businessClassSeatWidthInches rdf:type rdf:Property ;
    rdfs:label 'Business Class Seat Width Inches' ;
    rdfs:comment 'Average seat width in Business Class, measured in inches. Null if Business Class is not offered.' ;
    rdfs:domain ind:CabinConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cabinClassCount rdf:type rdf:Property ;
    rdfs:label 'Cabin Class Count' ;
    rdfs:comment 'Number of distinct cabin classes in this configuration (e.g., 1 for all-economy, 2 for business and economy, 3 for first/business/economy).' ;
    rdfs:domain ind:CabinConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:configurationCode rdf:type rdf:Property ;
    rdfs:label 'Configuration Code' ;
    rdfs:comment 'Unique business identifier for the cabin configuration version (e.g., B738-CFG-A, A320-Y180). Used for operational reference and inventory management.' ;
    rdfs:domain ind:CabinConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configurationName rdf:type rdf:Property ;
    rdfs:label 'Configuration Name' ;
    rdfs:comment 'Human-readable name or description of the cabin configuration (e.g., \'High-Density Economy\', \'Premium Three-Class\').' ;
    rdfs:domain ind:CabinConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:configurationStatus rdf:type rdf:Property ;
    rdfs:label 'Configuration Status' ;
    rdfs:comment 'Current lifecycle status of the cabin configuration. Active configurations are in operational use; planned configurations are approved but not yet installed; retired configurations are no longer in service.' ;
    rdfs:domain ind:CabinConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:doorCount rdf:type rdf:Property ;
    rdfs:label 'Door Count' ;
    rdfs:comment 'Total number of passenger entry/exit doors in this cabin configuration. Critical for emergency evacuation certification.' ;
    rdfs:domain ind:CabinConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:economySeatCount rdf:type rdf:Property ;
    rdfs:label 'Economy Seat Count' ;
    rdfs:comment 'Number of seats in the Economy (standard coach) cabin.' ;
    rdfs:domain ind:CabinConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:economySeatPitchInches rdf:type rdf:Property ;
    rdfs:label 'Economy Seat Pitch Inches' ;
    rdfs:comment 'Average seat pitch in Economy class, measured in inches.' ;
    rdfs:domain ind:CabinConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:economySeatWidthInches rdf:type rdf:Property ;
    rdfs:label 'Economy Seat Width Inches' ;
    rdfs:comment 'Average seat width in Economy class, measured in inches.' ;
    rdfs:domain ind:CabinConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:firstClassSeatCount rdf:type rdf:Property ;
    rdfs:label 'First Class Seat Count' ;
    rdfs:comment 'Number of seats in the First Class cabin. Zero if First Class is not offered in this configuration.' ;
    rdfs:domain ind:CabinConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:firstClassSeatPitchInches rdf:type rdf:Property ;
    rdfs:label 'First Class Seat Pitch Inches' ;
    rdfs:comment 'Average seat pitch (distance from one seat to the same point on the seat in front) in First Class, measured in inches. Null if First Class is not offered.' ;
    rdfs:domain ind:CabinConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:firstClassSeatWidthInches rdf:type rdf:Property ;
    rdfs:label 'First Class Seat Width Inches' ;
    rdfs:comment 'Average seat width in First Class, measured in inches. Null if First Class is not offered.' ;
    rdfs:domain ind:CabinConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:galleyCount rdf:type rdf:Property ;
    rdfs:label 'Galley Count' ;
    rdfs:comment 'Total number of galleys (food and beverage preparation areas) installed in this cabin configuration.' ;
    rdfs:domain ind:CabinConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:ifeSystemType rdf:type rdf:Property ;
    rdfs:label 'Ife System Type' ;
    rdfs:comment 'Type or model of the In-Flight Entertainment system installed (e.g., \'Panasonic eX3\', \'Thales AVANT\', \'Streaming-only\'). Null if no IFE is installed.' ;
    rdfs:domain ind:CabinConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lavatoryCount rdf:type rdf:Property ;
    rdfs:label 'Lavatory Count' ;
    rdfs:comment 'Total number of lavatories (restrooms) installed in this cabin configuration.' ;
    rdfs:domain ind:CabinConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lieFlatSeatAvailable rdf:type rdf:Property ;
    rdfs:label 'Lie Flat Seat Available' ;
    rdfs:comment 'Indicates whether this configuration includes lie-flat seats (typically in First or Business Class). True if any cabin class offers lie-flat capability.' ;
    rdfs:domain ind:CabinConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:overwingExitCount rdf:type rdf:Property ;
    rdfs:label 'Overwing Exit Count' ;
    rdfs:comment 'Number of overwing emergency exits in this cabin configuration. Used for evacuation planning and seating restrictions.' ;
    rdfs:domain ind:CabinConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:powerOutletAvailability rdf:type rdf:Property ;
    rdfs:label 'Power Outlet Availability' ;
    rdfs:comment 'Indicates the availability of power outlets (AC or USB) for passenger devices. Values: none (no power outlets), selected_seats (available in premium cabins or select rows), all_seats (available at every seat).' ;
    rdfs:domain ind:CabinConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:premiumEconomySeatCount rdf:type rdf:Property ;
    rdfs:label 'Premium Economy Seat Count' ;
    rdfs:comment 'Number of seats in the Premium Economy cabin. Zero if Premium Economy is not offered in this configuration.' ;
    rdfs:domain ind:CabinConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:premiumEconomySeatPitchInches rdf:type rdf:Property ;
    rdfs:label 'Premium Economy Seat Pitch Inches' ;
    rdfs:comment 'Average seat pitch in Premium Economy, measured in inches. Null if Premium Economy is not offered.' ;
    rdfs:domain ind:CabinConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:premiumEconomySeatWidthInches rdf:type rdf:Property ;
    rdfs:label 'Premium Economy Seat Width Inches' ;
    rdfs:comment 'Average seat width in Premium Economy, measured in inches. Null if Premium Economy is not offered.' ;
    rdfs:domain ind:CabinConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:seatMapReference rdf:type rdf:Property ;
    rdfs:label 'Seat Map Reference' ;
    rdfs:comment 'Reference identifier or URL to the detailed seat map diagram for this configuration. Used by reservation systems and passenger-facing applications.' ;
    rdfs:domain ind:CabinConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalSeatCount rdf:type rdf:Property ;
    rdfs:label 'Total Seat Count' ;
    rdfs:comment 'Total number of passenger seats installed in this cabin configuration across all classes. Critical for revenue management and Available Seat Kilometer (ASK) calculations.' ;
    rdfs:domain ind:CabinConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:wifiProvider rdf:type rdf:Property ;
    rdfs:label 'Wifi Provider' ;
    rdfs:comment 'Name of the Wi-Fi service provider (e.g., \'Gogo\', \'Viasat\', \'Panasonic Avionics\'). Null if Wi-Fi is not available.' ;
    rdfs:domain ind:CabinConfiguration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:columnLetter rdf:type rdf:Property ;
    rdfs:label 'Column Letter' ;
    rdfs:comment 'The alphabetic column identifier for the seat position within the row (A through K). Typically A and K are window seats in wide-body aircraft.' ;
    rdfs:domain ind:SeatMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deck rdf:type rdf:Property ;
    rdfs:label 'Deck' ;
    rdfs:comment 'The deck or level of the aircraft where the seat is located. Relevant for wide-body aircraft with multiple passenger decks.' ;
    rdfs:domain ind:SeatMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:galleyProximity rdf:type rdf:Property ;
    rdfs:label 'Galley Proximity' ;
    rdfs:comment 'Indicates the proximity of the seat to galley (kitchen) facilities. Proximity to galleys can impact passenger experience due to noise and crew activity.' ;
    rdfs:domain ind:SeatMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hasIfe rdf:type rdf:Property ;
    rdfs:label 'Has Ife' ;
    rdfs:comment 'Flag indicating whether the seat is equipped with an in-flight entertainment system. IFE availability is a key amenity for passenger satisfaction and ancillary revenue.' ;
    rdfs:domain ind:SeatMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ifeScreenSizeInches rdf:type rdf:Property ;
    rdfs:label 'Ife Screen Size Inches' ;
    rdfs:comment 'The diagonal screen size in inches of the in-flight entertainment display at this seat. Used for product differentiation and passenger communication.' ;
    rdfs:domain ind:SeatMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isAccessible rdf:type rdf:Property ;
    rdfs:label 'Is Accessible' ;
    rdfs:comment 'Flag indicating whether the seat is designated as accessible for passengers with disabilities or reduced mobility. Accessible seats meet regulatory requirements for space and proximity to facilities.' ;
    rdfs:domain ind:SeatMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isBassinetCapable rdf:type rdf:Property ;
    rdfs:label 'Is Bassinet Capable' ;
    rdfs:comment 'Flag indicating whether the seat position can accommodate an infant bassinet attachment. Typically available at bulkhead seats with sufficient wall space.' ;
    rdfs:domain ind:SeatMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCrewRest rdf:type rdf:Property ;
    rdfs:label 'Is Crew Rest' ;
    rdfs:comment 'Flag indicating whether the seat is designated for crew rest on long-haul flights. Crew rest seats are blocked from passenger assignment and reserved for flight crew during rest periods.' ;
    rdfs:domain ind:SeatMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isLastRow rdf:type rdf:Property ;
    rdfs:label 'Is Last Row' ;
    rdfs:comment 'Flag indicating whether the seat is in the last row of the cabin or section. Last row seats often have limited or no recline and proximity to lavatories.' ;
    rdfs:domain ind:SeatMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isOverwing rdf:type rdf:Property ;
    rdfs:label 'Is Overwing' ;
    rdfs:comment 'Flag indicating whether the seat is located over the aircraft wing, which may restrict window views. Used for passenger communication and seat selection preferences.' ;
    rdfs:domain ind:SeatMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPreferredSeat rdf:type rdf:Property ;
    rdfs:label 'Is Preferred Seat' ;
    rdfs:comment 'Flag indicating whether the seat is designated as a preferred or premium seat eligible for ancillary seat selection fees. Preferred seats typically offer enhanced comfort or location.' ;
    rdfs:domain ind:SeatMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lavatoryProximity rdf:type rdf:Property ;
    rdfs:label 'Lavatory Proximity' ;
    rdfs:comment 'Indicates the proximity of the seat to lavatory facilities. Proximity to lavatories can be a positive (convenience) or negative (noise, traffic) factor for seat selection.' ;
    rdfs:domain ind:SeatMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reclineAngleDegrees rdf:type rdf:Property ;
    rdfs:label 'Recline Angle Degrees' ;
    rdfs:comment 'The maximum recline angle of the seat in degrees from vertical. Used to communicate seat comfort specifications and differentiate premium products.' ;
    rdfs:domain ind:SeatMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reclineType rdf:type rdf:Property ;
    rdfs:label 'Recline Type' ;
    rdfs:comment 'The recline capability of the seat, ranging from no recline to full lie-flat configurations. Critical for premium cabin differentiation and passenger comfort.' ;
    rdfs:domain ind:SeatMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rowNumber rdf:type rdf:Property ;
    rdfs:label 'Row Number' ;
    rdfs:comment 'The numeric row identifier within the aircraft cabin. Used for seat assignment logic and cabin zone management.' ;
    rdfs:domain ind:SeatMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:seatDesignator rdf:type rdf:Property ;
    rdfs:label 'Seat Designator' ;
    rdfs:comment 'The unique seat identifier within the aircraft, combining row number and column letter (e.g., 12A, 34F). This is the seat label passengers see on their boarding pass.' ;
    rdfs:domain ind:SeatMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seatFeeTier rdf:type rdf:Property ;
    rdfs:label 'Seat Fee Tier' ;
    rdfs:comment 'The pricing tier for ancillary seat selection fees. Used by revenue management systems to price seat assignments and optimize ancillary revenue.' ;
    rdfs:domain ind:SeatMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:seatMapStatus rdf:type rdf:Property ;
    rdfs:label 'Seat Map Status' ;
    rdfs:comment 'The current lifecycle status of the seat map record. Indicates whether the seat configuration is currently in use, pending activation, or retired.' ;
    rdfs:domain ind:SeatMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:storageRestriction rdf:type rdf:Property ;
    rdfs:label 'Storage Restriction' ;
    rdfs:comment 'Indicates any restrictions on carry-on baggage storage at this seat location. Some seats (e.g., bulkhead, exit row) have limited under-seat or overhead storage.' ;
    rdfs:domain ind:SeatMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cancellationPenaltyUsd rdf:type rdf:Property ;
    rdfs:label 'Cancellation Penalty Usd' ;
    rdfs:comment 'Financial penalty amount in US Dollars if the order is cancelled before delivery. Defined in contract terms.' ;
    rdfs:domain ind:FleetOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Reference Number' ;
    rdfs:comment 'Legal contract or purchase agreement reference number. Links to the binding legal document governing the order terms and conditions.' ;
    rdfs:domain ind:FleetOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionDate rdf:type rdf:Property ;
    rdfs:label 'Conversion Date' ;
    rdfs:comment 'Date when an option or letter of intent was converted to a firm order. Null if order was firm from inception or has not been converted.' ;
    rdfs:domain ind:FleetOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:counterpartyType rdf:type rdf:Property ;
    rdfs:label 'Counterparty Type' ;
    rdfs:comment 'Classification of the counterparty. OEM = Original Equipment Manufacturer (Boeing, Airbus), Lessor = Aircraft leasing company, Broker = Intermediary facilitating the transaction.' ;
    rdfs:domain ind:FleetOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryWindowEndDate rdf:type rdf:Property ;
    rdfs:label 'Delivery Window End Date' ;
    rdfs:comment 'Latest contractual delivery date for aircraft in this order. Defines the end of the delivery period.' ;
    rdfs:domain ind:FleetOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deliveryWindowStartDate rdf:type rdf:Property ;
    rdfs:label 'Delivery Window Start Date' ;
    rdfs:comment 'Earliest contractual delivery date for aircraft in this order. Defines the beginning of the delivery period.' ;
    rdfs:domain ind:FleetOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:depositAmountUsd rdf:type rdf:Property ;
    rdfs:label 'Deposit Amount Usd' ;
    rdfs:comment 'Initial deposit or down payment amount paid to secure the order, in US Dollars. Typically a percentage of total order value.' ;
    rdfs:domain ind:FleetOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:financingStructure rdf:type rdf:Property ;
    rdfs:label 'Financing Structure' ;
    rdfs:comment 'Method of financing the aircraft acquisition. Cash = direct purchase, Debt Financing = loan-backed purchase, Sale-Leaseback = sell and lease back, Operating Lease = rental, Finance Lease = lease-to-own, Hybrid = combination of methods.' ;
    rdfs:domain ind:FleetOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:listPricePerUnitUsd rdf:type rdf:Property ;
    rdfs:label 'List Price Per Unit Usd' ;
    rdfs:comment 'Manufacturer\'s published list price per aircraft in US Dollars. This is the catalog price before any negotiated discounts.' ;
    rdfs:domain ind:FleetOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:negotiatedPricePerUnitUsd rdf:type rdf:Property ;
    rdfs:label 'Negotiated Price Per Unit Usd' ;
    rdfs:comment 'Actual negotiated price per aircraft in US Dollars after discounts and concessions. Highly confidential commercial terms. Null if not disclosed or still under negotiation.' ;
    rdfs:domain ind:FleetOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:optionExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Option Expiry Date' ;
    rdfs:comment 'Date by which option rights must be exercised or they expire. Applicable only for orders with option quantities. Null for firm orders.' ;
    rdfs:domain ind:FleetOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:orderType rdf:type rdf:Property ;
    rdfs:label 'Order Type' ;
    rdfs:comment 'Classification of the acquisition structure. Purchase = outright ownership, Operating Lease = rental without ownership transfer, Finance Lease = lease with ownership transfer option, Sale-Leaseback = sell owned aircraft and lease back, Wet Lease = aircraft with crew, Dry Lease = aircraft only, ACMI = Aircraft Crew Maintenance Insurance lease. [ENUM-REF-CANDIDATE: purchase|operating_lease|finance_lease|sale_leaseback|wet_lease|dry_lease|acmi — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:FleetOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:purpose rdf:type rdf:Property ;
    rdfs:label 'Purpose' ;
    rdfs:comment 'Strategic business purpose for the aircraft order. Fleet Growth = net addition to fleet size, Fleet Replacement = replacing retiring aircraft, Fleet Renewal = modernizing existing capacity, Capacity Expansion = increasing seat capacity, Route Expansion = supporting new route network.' ;
    rdfs:domain ind:FleetOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:quantityCancelled rdf:type rdf:Property ;
    rdfs:label 'Quantity Cancelled' ;
    rdfs:comment 'Number of aircraft from this order that have been cancelled or terminated before delivery.' ;
    rdfs:domain ind:FleetOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantityFirm rdf:type rdf:Property ;
    rdfs:label 'Quantity Firm' ;
    rdfs:comment 'Number of aircraft under firm binding commitment. These are contractually committed deliveries.' ;
    rdfs:domain ind:FleetOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantityLoi rdf:type rdf:Property ;
    rdfs:label 'Quantity Loi' ;
    rdfs:comment 'Number of aircraft covered by letter of intent. Non-binding preliminary agreement expressing purchase interest.' ;
    rdfs:domain ind:FleetOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:quantityOption rdf:type rdf:Property ;
    rdfs:label 'Quantity Option' ;
    rdfs:comment 'Number of aircraft under option rights. Airline has the right but not obligation to purchase at predetermined terms.' ;
    rdfs:domain ind:FleetOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalOrderValueUsd rdf:type rdf:Property ;
    rdfs:label 'Total Order Value Usd' ;
    rdfs:comment 'Total financial value of the entire order in US Dollars. Calculated as quantity times negotiated price (or list price if negotiated not available). Represents total capital commitment.' ;
    rdfs:domain ind:FleetOrder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:aircraftDeliveryId rdf:type rdf:Property ;
    rdfs:label 'Aircraft Delivery Id' ;
    rdfs:comment 'Unique identifier for the aircraft delivery event. Primary key for the aircraft delivery transaction.' ;
    rdfs:domain ind:AircraftDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:deliveryStationId rdf:type rdf:Property ;
    rdfs:label 'Delivery Station Id' ;
    rdfs:comment 'Foreign key linking to airport.station. Business justification: New aircraft acceptance logistics, delivery team deployment, and acceptance flight planning require station linkage. Fleet planning and delivery coordination depend on accurate station tracking. Repla' ;
    rdfs:domain ind:AircraftDelivery ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Station .

ind:acceptanceCertificateReference rdf:type rdf:Property ;
    rdfs:label 'Acceptance Certificate Reference' ;
    rdfs:comment 'Reference number of the formal acceptance certificate document signed by the airline and manufacturer/lessor confirming aircraft delivery and acceptance.' ;
    rdfs:domain ind:AircraftDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:airframeCyclesAtDelivery rdf:type rdf:Property ;
    rdfs:label 'Airframe Cycles At Delivery' ;
    rdfs:comment 'Total accumulated flight cycles (takeoff and landing cycles) on the airframe at the time of delivery. Zero for new aircraft, non-zero for used aircraft.' ;
    rdfs:domain ind:AircraftDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:airframeHoursAtDelivery rdf:type rdf:Property ;
    rdfs:label 'Airframe Hours At Delivery' ;
    rdfs:comment 'Total accumulated flight hours (block hours) on the airframe at the time of delivery. Zero for new aircraft, non-zero for used aircraft.' ;
    rdfs:domain ind:AircraftDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:apuSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Apu Serial Number' ;
    rdfs:comment 'Manufacturer serial number of the Auxiliary Power Unit (APU) installed on the aircraft at delivery. APU provides electrical power and pneumatic air on the ground and in-flight backup.' ;
    rdfs:domain ind:AircraftDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryCondition rdf:type rdf:Property ;
    rdfs:label 'Delivery Condition' ;
    rdfs:comment 'Condition classification of the aircraft at delivery: new from manufacturer, used from lessor, refurbished after major overhaul, or pre-owned from another operator.' ;
    rdfs:domain ind:AircraftDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryFlightNumber rdf:type rdf:Property ;
    rdfs:label 'Delivery Flight Number' ;
    rdfs:comment 'Flight number assigned to the ferry flight that delivered the aircraft from the manufacturer or lessor facility to the airline\'s base. May be a non-revenue positioning flight.' ;
    rdfs:domain ind:AircraftDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryNotes rdf:type rdf:Property ;
    rdfs:label 'Delivery Notes' ;
    rdfs:comment 'Free-text notes capturing additional details about the delivery event, including any special conditions, snags identified during acceptance inspection, or deviations from standard delivery procedures.' ;
    rdfs:domain ind:AircraftDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryNumber rdf:type rdf:Property ;
    rdfs:label 'Delivery Number' ;
    rdfs:comment 'Externally-known unique business identifier for this aircraft delivery transaction, typically assigned by the manufacturer or lessor.' ;
    rdfs:domain ind:AircraftDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deliveryStatus rdf:type rdf:Property ;
    rdfs:label 'Delivery Status' ;
    rdfs:comment 'Current lifecycle status of the aircraft delivery transaction: scheduled (planned future delivery), in transit (ferry flight underway), accepted (delivery completed and aircraft in service), rejected (delivery refused), cancelled (delivery cancelled), or deferred (delivery postponed).' ;
    rdfs:domain ind:AircraftDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engine1SerialNumber rdf:type rdf:Property ;
    rdfs:label 'Engine 1 Serial Number' ;
    rdfs:comment 'Manufacturer serial number of the engine installed in position 1 (typically left engine on twin-engine aircraft) at delivery.' ;
    rdfs:domain ind:AircraftDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engine2SerialNumber rdf:type rdf:Property ;
    rdfs:label 'Engine 2 Serial Number' ;
    rdfs:comment 'Manufacturer serial number of the engine installed in position 2 (typically right engine on twin-engine aircraft) at delivery.' ;
    rdfs:domain ind:AircraftDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engine3SerialNumber rdf:type rdf:Property ;
    rdfs:label 'Engine 3 Serial Number' ;
    rdfs:comment 'Manufacturer serial number of the engine installed in position 3 (for tri-jet or quad-jet aircraft) at delivery. Null for twin-engine aircraft.' ;
    rdfs:domain ind:AircraftDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:engine4SerialNumber rdf:type rdf:Property ;
    rdfs:label 'Engine 4 Serial Number' ;
    rdfs:comment 'Manufacturer serial number of the engine installed in position 4 (for quad-jet aircraft) at delivery. Null for twin-engine and tri-jet aircraft.' ;
    rdfs:domain ind:AircraftDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:technicalAcceptanceOutcome rdf:type rdf:Property ;
    rdfs:label 'Technical Acceptance Outcome' ;
    rdfs:comment 'Outcome of the technical acceptance inspection performed by the airline\'s engineering team: accepted (no issues), accepted with conditions (minor snags to be resolved), rejected (major defects), or deferred (inspection postponed).' ;
    rdfs:domain ind:AircraftDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:actualDeliveryDate rdf:type rdf:Property ;
    rdfs:label 'Actual Delivery Date' ;
    rdfs:comment 'Actual date when the aircraft was physically delivered to the lessee and accepted into operational service. May differ from lease start date.' ;
    rdfs:domain ind:AircraftLease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:actualReturnDate rdf:type rdf:Property ;
    rdfs:label 'Actual Return Date' ;
    rdfs:comment 'Actual date when the aircraft was returned to the lessor and removed from lessee operational control. Populated upon lease termination.' ;
    rdfs:domain ind:AircraftLease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:earlyTerminationClauseFlag rdf:type rdf:Property ;
    rdfs:label 'Early Termination Clause Flag' ;
    rdfs:comment 'Indicates whether the lease agreement includes provisions allowing early termination by either party under specified conditions.' ;
    rdfs:domain ind:AircraftLease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:earlyTerminationPenaltyUsd rdf:type rdf:Property ;
    rdfs:label 'Early Termination Penalty Usd' ;
    rdfs:comment 'Financial penalty amount in US dollars payable if the lease is terminated before the scheduled end date. Nullable if no penalty applies.' ;
    rdfs:domain ind:AircraftLease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:extensionOptionAvailableFlag rdf:type rdf:Property ;
    rdfs:label 'Extension Option Available Flag' ;
    rdfs:comment 'Indicates whether the lease agreement includes an option for the lessee to extend the lease term beyond the original end date.' ;
    rdfs:domain ind:AircraftLease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:extensionOptionDurationMonths rdf:type rdf:Property ;
    rdfs:label 'Extension Option Duration Months' ;
    rdfs:comment 'Duration in months for which the lease can be extended if the extension option is exercised. Nullable if no extension option exists.' ;
    rdfs:domain ind:AircraftLease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:governingLawJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Governing Law Jurisdiction' ;
    rdfs:comment 'Legal jurisdiction and governing law specified in the lease agreement for dispute resolution and contract interpretation (e.g., New York, England and Wales, Singapore).' ;
    rdfs:domain ind:AircraftLease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:insuranceResponsibility rdf:type rdf:Property ;
    rdfs:label 'Insurance Responsibility' ;
    rdfs:comment 'Party responsible for maintaining aircraft hull and liability insurance coverage during the lease term. Critical for ACMI vs dry lease distinction.' ;
    rdfs:domain ind:AircraftLease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaseAgreementNumber rdf:type rdf:Property ;
    rdfs:label 'Lease Agreement Number' ;
    rdfs:comment 'Externally-known unique identifier for the lease agreement as referenced in legal contracts and financial systems. Business identifier for the lease.' ;
    rdfs:domain ind:AircraftLease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaseCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Lease Currency Code' ;
    rdfs:comment 'ISO 4217 three-letter currency code for the lease agreement. While amounts are stored in USD, this captures the original contract currency for reference.' ;
    rdfs:domain ind:AircraftLease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaseExecutionDate rdf:type rdf:Property ;
    rdfs:label 'Lease Execution Date' ;
    rdfs:comment 'Date when the lease agreement was formally signed and executed by both lessor and lessee parties. Legal effective date of the contract.' ;
    rdfs:domain ind:AircraftLease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leaseStartDate rdf:type rdf:Property ;
    rdfs:label 'Lease Start Date' ;
    rdfs:comment 'Effective date when the lease agreement becomes binding and the aircraft is delivered to the lessee. Marks the beginning of rental obligations.' ;
    rdfs:domain ind:AircraftLease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maintenanceReserveRatePerCycle rdf:type rdf:Property ;
    rdfs:label 'Maintenance Reserve Rate Per Cycle' ;
    rdfs:comment 'Maintenance reserve contribution rate in US dollars per flight cycle (takeoff and landing). Applied to landing gear and other cycle-sensitive components.' ;
    rdfs:domain ind:AircraftLease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maintenanceReserveRatePerFh rdf:type rdf:Property ;
    rdfs:label 'Maintenance Reserve Rate Per Fh' ;
    rdfs:comment 'Maintenance reserve contribution rate in US dollars per flight hour. Accumulated reserves fund major maintenance events and are reconciled at lease end.' ;
    rdfs:domain ind:AircraftLease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maintenanceResponsibility rdf:type rdf:Property ;
    rdfs:label 'Maintenance Responsibility' ;
    rdfs:comment 'Party responsible for performing and funding aircraft maintenance during the lease term. Defines operational obligations under the lease type.' ;
    rdfs:domain ind:AircraftLease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monthlyRentalRateUsd rdf:type rdf:Property ;
    rdfs:label 'Monthly Rental Rate Usd' ;
    rdfs:comment 'Fixed monthly lease payment amount in US dollars payable to the lessor. Base rental rate excluding maintenance reserves and other variable charges.' ;
    rdfs:domain ind:AircraftLease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:redeliveryLocationCode rdf:type rdf:Property ;
    rdfs:label 'Redelivery Location Code' ;
    rdfs:comment 'IATA three-letter airport code specifying the contractual location where the aircraft must be returned to the lessor at lease end.' ;
    rdfs:domain ind:AircraftLease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:returnConditionMaxCycles rdf:type rdf:Property ;
    rdfs:label 'Return Condition Max Cycles' ;
    rdfs:comment 'Maximum total flight cycles allowed on the aircraft at lease return. Contractual limit for takeoff/landing cycles at redelivery.' ;
    rdfs:domain ind:AircraftLease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:returnConditionMaxFlightHours rdf:type rdf:Property ;
    rdfs:label 'Return Condition Max Flight Hours' ;
    rdfs:comment 'Maximum total flight hours allowed on the aircraft at lease return. Contractual limit defining acceptable utilization at redelivery.' ;
    rdfs:domain ind:AircraftLease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:securityDepositAmountUsd rdf:type rdf:Property ;
    rdfs:label 'Security Deposit Amount Usd' ;
    rdfs:comment 'Refundable security deposit amount in US dollars held by the lessor as collateral against lease obligations and aircraft return conditions.' ;
    rdfs:domain ind:AircraftLease ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cslsvCycles rdf:type rdf:Property ;
    rdfs:label 'Cslsv Cycles' ;
    rdfs:comment 'Flight cycles accumulated since the engine\'s last major shop visit or overhaul. Resets to zero after each shop visit. Used alongside TSLSV for shop visit planning.' ;
    rdfs:domain ind:Engine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:csnCycles rdf:type rdf:Property ;
    rdfs:label 'Csn Cycles' ;
    rdfs:comment 'Total number of flight cycles (takeoff and landing pairs) accumulated by this engine since manufacture. One cycle equals one takeoff-landing sequence. Used for fatigue life tracking.' ;
    rdfs:domain ind:Engine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:currentBookValue rdf:type rdf:Property ;
    rdfs:label 'Current Book Value' ;
    rdfs:comment 'Current depreciated book value of this engine on the airline\'s balance sheet. Updated based on depreciation schedule and any impairment charges. Null if not tracked.' ;
    rdfs:domain ind:Engine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:engineStatus rdf:type rdf:Property ;
    rdfs:label 'Engine Status' ;
    rdfs:comment 'Current operational status of the engine. Installed (on-wing), spare (serviceable spare pool), QEC (Quick Engine Change kit), shop (undergoing MRO), beyond-repair (uneconomical to repair), retired (end of service life), or AOG (Aircraft on Ground - engine causing aircraft grounding). [ENUM-REF-CANDIDATE: installed|spare|QEC|shop|beyond-repair|retired|AOG — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Engine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:esn rdf:type rdf:Property ;
    rdfs:label 'Esn' ;
    rdfs:comment 'Manufacturer-assigned unique serial number for this engine. The globally unique identifier used for tracking, MRO, and lease return. Also known as ESN in aviation industry.' ;
    rdfs:domain ind:Engine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:etopsEligible rdf:type rdf:Property ;
    rdfs:label 'Etops Eligible' ;
    rdfs:comment 'Indicates whether this engine meets ETOPS certification requirements for extended over-water or remote area operations. True if engine is ETOPS-certified and current on all ETOPS maintenance requirements.' ;
    rdfs:domain ind:Engine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastShopVisitDate rdf:type rdf:Property ;
    rdfs:label 'Last Shop Visit Date' ;
    rdfs:comment 'Date when this engine completed its most recent major shop visit or overhaul. Used to calculate TSLSV and CSLSV intervals.' ;
    rdfs:domain ind:Engine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:lastShopVisitType rdf:type rdf:Property ;
    rdfs:label 'Last Shop Visit Type' ;
    rdfs:comment 'Type of maintenance work performed during the last shop visit. Performance restoration (PR), life-limited parts replacement, hot section inspection (HSI), or full overhaul. Determines next shop visit scope.' ;
    rdfs:domain ind:Engine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leaseExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Lease Expiry Date' ;
    rdfs:comment 'Date when the current engine lease agreement expires. Critical for return condition planning and lease extension negotiations. Null if engine is owned.' ;
    rdfs:domain ind:Engine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:leaseReturnCondition rdf:type rdf:Property ;
    rdfs:label 'Lease Return Condition' ;
    rdfs:comment 'Contractual maintenance condition requirements that must be met when returning this leased engine to the lessor. Typically specifies minimum remaining hours/cycles on LLPs and maintenance status. Null if owned.' ;
    rdfs:domain ind:Engine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:llpLowestRemainingCycles rdf:type rdf:Property ;
    rdfs:label 'Llp Lowest Remaining Cycles' ;
    rdfs:comment 'Remaining cycles until mandatory retirement of the most limiting life-limited part in this engine. Critical for shop visit planning and residual value assessment.' ;
    rdfs:domain ind:Engine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:llpSummary rdf:type rdf:Property ;
    rdfs:label 'Llp Summary' ;
    rdfs:comment 'Summary of remaining cycles for critical life-limited parts (LLP) in this engine. LLPs are components with mandatory retirement life limits due to fatigue considerations. Format typically includes part numbers and remaining cycles.' ;
    rdfs:domain ind:Engine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:manufacturer rdf:type rdf:Property ;
    rdfs:label 'Manufacturer' ;
    rdfs:comment 'Name of the engine manufacturer. Major manufacturers include CFM International, GE Aviation, Rolls-Royce, Pratt & Whitney, IAE (International Aero Engines), and Engine Alliance.' ;
    rdfs:domain ind:Engine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:melItemCount rdf:type rdf:Property ;
    rdfs:label 'Mel Item Count' ;
    rdfs:comment 'Number of active MEL items currently logged against this engine. Zero indicates no MEL items. Higher counts may indicate declining engine health or deferred maintenance.' ;
    rdfs:domain ind:Engine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:model rdf:type rdf:Property ;
    rdfs:label 'Model' ;
    rdfs:comment 'Specific engine model and variant designation (e.g., CFM56-7B27, LEAP-1A26, Trent 1000, PW4000). Defines thrust rating, fuel efficiency, and maintenance program applicability.' ;
    rdfs:domain ind:Engine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mroProvider rdf:type rdf:Property ;
    rdfs:label 'Mro Provider' ;
    rdfs:comment 'Name of the MRO facility or provider currently responsible for this engine\'s maintenance, or the facility where the engine is currently undergoing shop work. May be OEM, third-party MRO, or airline in-house facility.' ;
    rdfs:domain ind:Engine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nextShopVisitDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Shop Visit Due Date' ;
    rdfs:comment 'Planned or forecast date when this engine is scheduled for its next major shop visit or overhaul. Based on maintenance program intervals and current utilization rates.' ;
    rdfs:domain ind:Engine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:position rdf:type rdf:Property ;
    rdfs:label 'Position' ;
    rdfs:comment 'Current position of the engine. For installed engines: 1, 2, 3, or 4 (left to right facing forward). For uninstalled: spare (serviceable spare pool), shop (undergoing MRO), or QEC (Quick Engine Change kit assembly). [ENUM-REF-CANDIDATE: 1|2|3|4|spare|shop|QEC — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Engine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:powerByHourContract rdf:type rdf:Property ;
    rdfs:label 'Power By Hour Contract' ;
    rdfs:comment 'Indicates whether this engine is covered under a power-by-hour (PBH) or similar pay-per-use maintenance contract with the OEM or MRO provider. True if under PBH contract.' ;
    rdfs:domain ind:Engine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:thrustRatingKn rdf:type rdf:Property ;
    rdfs:label 'Thrust Rating Kn' ;
    rdfs:comment 'Maximum certified thrust output of this engine variant measured in kilonewtons (kN). International standard unit for thrust measurement.' ;
    rdfs:domain ind:Engine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:thrustRatingLbf rdf:type rdf:Property ;
    rdfs:label 'Thrust Rating Lbf' ;
    rdfs:comment 'Maximum certified thrust output of this engine variant measured in pounds-force (lbf). Determines aircraft performance capabilities and operational limitations.' ;
    rdfs:domain ind:Engine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tslsvHours rdf:type rdf:Property ;
    rdfs:label 'Tslsv Hours' ;
    rdfs:comment 'Flight hours accumulated since the engine\'s last major shop visit or overhaul. Resets to zero after each shop visit. Used to plan next shop visit interval.' ;
    rdfs:domain ind:Engine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tsnHours rdf:type rdf:Property ;
    rdfs:label 'Tsn Hours' ;
    rdfs:comment 'Total flight hours accumulated by this engine since it was manufactured (Time Since New). Critical metric for life-limited parts tracking and residual value calculation.' ;
    rdfs:domain ind:Engine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:aircraftUtilizationId rdf:type rdf:Property ;
    rdfs:label 'Aircraft Utilization Id' ;
    rdfs:comment 'Unique identifier for each daily aircraft utilization record. Primary key for the aircraft utilization ledger.' ;
    rdfs:domain ind:AircraftUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:operatingStationId rdf:type rdf:Property ;
    rdfs:label 'Operating Station Id' ;
    rdfs:comment 'Foreign key linking to airport.station. Business justification: Daily utilization records require station context for station-level performance reporting, cost center allocation, and operational efficiency analysis. Critical for hub vs spoke utilization comparison' ;
    rdfs:domain ind:AircraftUtilization ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Station .

ind:apuHours rdf:type rdf:Property ;
    rdfs:label 'Apu Hours' ;
    rdfs:comment 'Total APU operating hours on this date. APU provides ground power and air conditioning when main engines are off. Tracked for APU maintenance intervals.' ;
    rdfs:domain ind:AircraftUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:averageDailyUtilizationHours rdf:type rdf:Property ;
    rdfs:label 'Average Daily Utilization Hours' ;
    rdfs:comment 'Rolling 30-day average daily block hours for this aircraft, calculated as of this utilization date. Used for fleet planning and lease utilization benchmarking.' ;
    rdfs:domain ind:AircraftUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:etopsSectors rdf:type rdf:Property ;
    rdfs:label 'Etops Sectors' ;
    rdfs:comment 'Number of ETOPS-certified flight sectors operated on this date. ETOPS allows twin-engine aircraft to fly routes more than 60 minutes from the nearest suitable airport.' ;
    rdfs:domain ind:AircraftUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:flightCycles rdf:type rdf:Property ;
    rdfs:label 'Flight Cycles' ;
    rdfs:comment 'Total number of flight cycles (pressurization cycles) completed on this date. One cycle equals one takeoff and landing. Critical for fatigue-sensitive component maintenance.' ;
    rdfs:domain ind:AircraftUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fuelBurnKg rdf:type rdf:Property ;
    rdfs:label 'Fuel Burn Kg' ;
    rdfs:comment 'Total fuel consumed (in kilograms) on this date across all flights. Used for CASK calculation and environmental reporting.' ;
    rdfs:domain ind:AircraftUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:groundTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Ground Time Minutes' ;
    rdfs:comment 'Total ground time (turnaround time) between flights on this date, summed across all sectors. Used for ground operations efficiency analysis.' ;
    rdfs:domain ind:AircraftUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:landings rdf:type rdf:Property ;
    rdfs:label 'Landings' ;
    rdfs:comment 'Total number of landings performed on this date. Used for landing gear and brake maintenance tracking.' ;
    rdfs:domain ind:AircraftUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:melItemsOpen rdf:type rdf:Property ;
    rdfs:label 'Mel Items Open' ;
    rdfs:comment 'Number of open MEL items (deferred defects) at the end of this utilization date. MEL allows aircraft to operate with certain non-critical systems inoperative under specific conditions.' ;
    rdfs:domain ind:AircraftUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nightFlightHours rdf:type rdf:Property ;
    rdfs:label 'Night Flight Hours' ;
    rdfs:comment 'Total flight hours operated during night hours (as defined by local aviation authority) on this date. Used for crew scheduling and fatigue management compliance.' ;
    rdfs:domain ind:AircraftUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nonRevenueBlockHours rdf:type rdf:Property ;
    rdfs:label 'Non Revenue Block Hours' ;
    rdfs:comment 'Block hours flown on non-revenue flights including ferry, positioning, maintenance test flights, and crew training.' ;
    rdfs:domain ind:AircraftUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pirepCount rdf:type rdf:Property ;
    rdfs:label 'Pirep Count' ;
    rdfs:comment 'Number of pilot-reported maintenance discrepancies logged on this date. Used for aircraft reliability trending and predictive maintenance.' ;
    rdfs:domain ind:AircraftUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revenueBlockHours rdf:type rdf:Property ;
    rdfs:label 'Revenue Block Hours' ;
    rdfs:comment 'Block hours flown on revenue-generating flights (passenger or cargo). Excludes ferry, positioning, and maintenance flights.' ;
    rdfs:domain ind:AircraftUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:sectorsFlown rdf:type rdf:Property ;
    rdfs:label 'Sectors Flown' ;
    rdfs:comment 'Total number of flight sectors (legs) operated on this date. Equivalent to number of departures.' ;
    rdfs:domain ind:AircraftUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:technicalDelayMinutes rdf:type rdf:Property ;
    rdfs:label 'Technical Delay Minutes' ;
    rdfs:comment 'Delay minutes caused by technical or maintenance issues on this date. Subset of total delay minutes, used for aircraft reliability and maintenance effectiveness analysis.' ;
    rdfs:domain ind:AircraftUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:totalAirframeHoursTsn rdf:type rdf:Property ;
    rdfs:label 'Total Airframe Hours Tsn' ;
    rdfs:comment 'Cumulative total airframe hours since the aircraft was manufactured, as of the end of this utilization date. Running total used for major maintenance checks and lease return conditions.' ;
    rdfs:domain ind:AircraftUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalCyclesCsn rdf:type rdf:Property ;
    rdfs:label 'Total Cycles Csn' ;
    rdfs:comment 'Cumulative total flight cycles since the aircraft was manufactured, as of the end of this utilization date. Running total used for fatigue-sensitive component tracking.' ;
    rdfs:domain ind:AircraftUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:utilizationDate rdf:type rdf:Property ;
    rdfs:label 'Utilization Date' ;
    rdfs:comment 'The calendar date (UTC) for which this utilization record applies. Each aircraft has one record per operational day.' ;
    rdfs:domain ind:AircraftUtilization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:authorizingStationId rdf:type rdf:Property ;
    rdfs:label 'Authorizing Station Id' ;
    rdfs:comment 'Foreign key linking to airport.station. Business justification: ETOPS authorizations often tied to specific maintenance stations with certified capabilities. Regulatory compliance audits and diversion planning require tracking which station holds ETOPS maintenance' ;
    rdfs:domain ind:EtopsAuthorization ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Station .

ind:apuEtopsComplianceFlag rdf:type rdf:Property ;
    rdfs:label 'Apu Etops Compliance Flag' ;
    rdfs:comment 'Indicates whether the APU on this aircraft meets ETOPS reliability and operational standards. True if APU is ETOPS-compliant and available for in-flight use; false otherwise.' ;
    rdfs:domain ind:EtopsAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:auditTrailReference rdf:type rdf:Property ;
    rdfs:label 'Audit Trail Reference' ;
    rdfs:comment 'Reference to the audit or inspection report that validated compliance with ETOPS requirements prior to authorization issuance. May include document ID or inspection case number.' ;
    rdfs:domain ind:EtopsAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizationStatus rdf:type rdf:Property ;
    rdfs:label 'Authorization Status' ;
    rdfs:comment 'Current lifecycle status of the ETOPS authorization. Active authorizations are valid for dispatch; suspended, expired, or revoked authorizations prohibit ETOPS operations.' ;
    rdfs:domain ind:EtopsAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cargoFireSuppressionEtopsFlag rdf:type rdf:Property ;
    rdfs:label 'Cargo Fire Suppression Etops Flag' ;
    rdfs:comment 'Indicates whether the cargo compartment fire suppression system meets ETOPS requirements for extended diversion times. True if compliant; false otherwise.' ;
    rdfs:domain ind:EtopsAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:communicationSystemEtopsFlag rdf:type rdf:Property ;
    rdfs:label 'Communication System Etops Flag' ;
    rdfs:comment 'Indicates whether the aircraft communication systems (HF, SATCOM, ACARS) meet ETOPS requirements for extended overwater operations. True if compliant; false otherwise.' ;
    rdfs:domain ind:EtopsAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:diversionTimeMinutes rdf:type rdf:Property ;
    rdfs:label 'Diversion Time Minutes' ;
    rdfs:comment 'The maximum approved diversion time in minutes that the aircraft is authorized to operate from the nearest suitable alternate airport. Common values include 120, 138, 180, 207, or 240 minutes.' ;
    rdfs:domain ind:EtopsAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:electricalSystemEtopsFlag rdf:type rdf:Property ;
    rdfs:label 'Electrical System Etops Flag' ;
    rdfs:comment 'Indicates whether the aircraft electrical power generation and distribution systems meet ETOPS redundancy standards. True if compliant; false otherwise.' ;
    rdfs:domain ind:EtopsAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:engineTypeDesignator rdf:type rdf:Property ;
    rdfs:label 'Engine Type Designator' ;
    rdfs:comment 'ICAO or manufacturer engine type designator for the engines installed on this aircraft under this ETOPS authorization (e.g., CFM56-7B, GE90-115B). ETOPS authorization is engine-type specific.' ;
    rdfs:domain ind:EtopsAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fuelSystemEtopsFlag rdf:type rdf:Property ;
    rdfs:label 'Fuel System Etops Flag' ;
    rdfs:comment 'Indicates whether the aircraft fuel system (including pumps, crossfeed, and monitoring) meets ETOPS reliability and redundancy standards. True if compliant; false otherwise.' ;
    rdfs:domain ind:EtopsAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:hydraulicSystemEtopsFlag rdf:type rdf:Property ;
    rdfs:label 'Hydraulic System Etops Flag' ;
    rdfs:comment 'Indicates whether the aircraft hydraulic systems meet ETOPS redundancy and reliability requirements. True if compliant; false otherwise.' ;
    rdfs:domain ind:EtopsAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastComplianceVerificationDate rdf:type rdf:Property ;
    rdfs:label 'Last Compliance Verification Date' ;
    rdfs:comment 'The date of the most recent compliance verification or audit confirming that the aircraft and operator continue to meet ETOPS standards. Used to track ongoing compliance.' ;
    rdfs:domain ind:EtopsAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:maintenanceProgramReference rdf:type rdf:Property ;
    rdfs:label 'Maintenance Program Reference' ;
    rdfs:comment 'Reference to the approved ETOPS maintenance program document or section number that this authorization is contingent upon. Compliance with this program is mandatory for maintaining authorization validity.' ;
    rdfs:domain ind:EtopsAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:navigationSystemEtopsFlag rdf:type rdf:Property ;
    rdfs:label 'Navigation System Etops Flag' ;
    rdfs:comment 'Indicates whether the aircraft navigation systems (FMS, GPS, INS) meet ETOPS accuracy and redundancy requirements. True if compliant; false otherwise.' ;
    rdfs:domain ind:EtopsAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextComplianceReviewDate rdf:type rdf:Property ;
    rdfs:label 'Next Compliance Review Date' ;
    rdfs:comment 'The scheduled date for the next compliance review or audit to ensure continued ETOPS authorization validity. Nullable if no periodic review is mandated.' ;
    rdfs:domain ind:EtopsAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:operatorEtopsExperienceLevel rdf:type rdf:Property ;
    rdfs:label 'Operator Etops Experience Level' ;
    rdfs:comment 'The operator\'s ETOPS experience classification at the time of this authorization. Initial operators may have more restrictive conditions; advanced operators may have fewer limitations.' ;
    rdfs:domain ind:EtopsAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:timeLimitedSystemExtensionMinutes rdf:type rdf:Property ;
    rdfs:label 'Time Limited System Extension Minutes' ;
    rdfs:comment 'For certain ETOPS authorizations, the approved extension time (in minutes) for time-limited systems (e.g., cargo fire suppression discharge time). Nullable if not applicable.' ;
    rdfs:domain ind:EtopsAuthorization ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:registeredOperatorLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Registered Operator Legal Entity Id' ;
    rdfs:comment 'Foreign key linking to finance.legal_entity. Business justification: The registered operator and owner on an aircraft registration certificate must be a legal entity for AOC compliance, insurance, and regulatory filings. registered_operator_name and registered_owner_na' ;
    rdfs:domain ind:AircraftRegistration ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:aircraftCategory rdf:type rdf:Property ;
    rdfs:label 'Aircraft Category' ;
    rdfs:comment 'The regulatory category classification of the aircraft. Transport category includes commercial passenger and cargo aircraft. General aviation includes smaller aircraft for personal or business use.' ;
    rdfs:domain ind:AircraftRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:airworthinessExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Airworthiness Expiry Date' ;
    rdfs:comment 'The date on which the current certificate of airworthiness expires. Nullable for certificates that remain valid subject to continuing airworthiness requirements.' ;
    rdfs:domain ind:AircraftRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:airworthinessIssueDate rdf:type rdf:Property ;
    rdfs:label 'Airworthiness Issue Date' ;
    rdfs:comment 'The date on which the current certificate of airworthiness was issued by the national civil aviation authority.' ;
    rdfs:domain ind:AircraftRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exportCertificateDate rdf:type rdf:Property ;
    rdfs:label 'Export Certificate Date' ;
    rdfs:comment 'The date on which the export certificate of airworthiness was issued by the exporting country civil aviation authority.' ;
    rdfs:domain ind:AircraftRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:exportCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Export Certificate Number' ;
    rdfs:comment 'The certificate number issued by the exporting country civil aviation authority when the aircraft was transferred from another jurisdiction. Required for international aircraft transfers.' ;
    rdfs:domain ind:AircraftRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nationalCaaName rdf:type rdf:Property ;
    rdfs:label 'National Caa Name' ;
    rdfs:comment 'The name of the national civil aviation authority that issued the registration. Examples: Federal Aviation Administration (FAA), European Union Aviation Safety Agency (EASA), Civil Aviation Authority (CAA).' ;
    rdfs:domain ind:AircraftRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noiseCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Noise Certificate Number' ;
    rdfs:comment 'The unique certificate number issued by the national civil aviation authority certifying that the aircraft meets noise emission standards per ICAO Annex 16. Required for commercial operations at most airports.' ;
    rdfs:domain ind:AircraftRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noiseChapterCompliance rdf:type rdf:Property ;
    rdfs:label 'Noise Chapter Compliance' ;
    rdfs:comment 'The ICAO Annex 16 noise certification chapter that the aircraft complies with. Chapter 4 is the most stringent current standard. Chapter 2 aircraft are banned from most airports.' ;
    rdfs:domain ind:AircraftRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousRegisteringCountryCode rdf:type rdf:Property ;
    rdfs:label 'Previous Registering Country Code' ;
    rdfs:comment 'The ICAO country code of the previous country of registration, if the aircraft was transferred from another jurisdiction.' ;
    rdfs:domain ind:AircraftRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:previousRegistrationMark rdf:type rdf:Property ;
    rdfs:label 'Previous Registration Mark' ;
    rdfs:comment 'The previous registration mark (tail number) assigned to this aircraft before the current registration, if applicable. Used to track aircraft that have been re-registered or transferred between jurisdictions.' ;
    rdfs:domain ind:AircraftRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registeringCountryCode rdf:type rdf:Property ;
    rdfs:label 'Registering Country Code' ;
    rdfs:comment 'The ICAO two or three-letter country code prefix indicating the country of registration. Examples: N (USA), G (UK), D (Germany), C (Canada).' ;
    rdfs:domain ind:AircraftRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationMark rdf:type rdf:Property ;
    rdfs:label 'Registration Mark' ;
    rdfs:comment 'The official registration mark (tail number) assigned by the national civil aviation authority. This is the unique identifier painted on the aircraft fuselage and tail. Also known as aircraft registration number or tail number.' ;
    rdfs:domain ind:AircraftRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationRemarks rdf:type rdf:Property ;
    rdfs:label 'Registration Remarks' ;
    rdfs:comment 'Free-text field for additional notes, comments, or special conditions related to the aircraft registration. May include restrictions, special authorizations, or historical notes.' ;
    rdfs:domain ind:AircraftRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationStatus rdf:type rdf:Property ;
    rdfs:label 'Registration Status' ;
    rdfs:comment 'The current lifecycle status of the aircraft registration. Current indicates active registration, expired indicates registration has lapsed, cancelled indicates registration has been terminated, suspended indicates temporary suspension, transferred indicates registration has been moved to another jurisdiction.' ;
    rdfs:domain ind:AircraftRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationStatusDate rdf:type rdf:Property ;
    rdfs:label 'Registration Status Date' ;
    rdfs:comment 'The date on which the current registration status became effective. Used to track when a registration was cancelled, suspended, or transferred.' ;
    rdfs:domain ind:AircraftRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:couponStatusId rdf:type rdf:Property ;
    rdfs:label 'Coupon Status Id' ;
    rdfs:comment 'Unique identifier for the coupon status record. Primary key.' ;
    rdfs:domain ind:CouponStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:previousCouponStatusId rdf:type rdf:Property ;
    rdfs:label 'Previous Coupon Status Id' ;
    rdfs:comment 'Self-referencing FK on coupon_status (previous_coupon_status_id)' ;
    rdfs:domain ind:CouponStatus ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CouponStatus .

ind:primaryCouponBookingPnrId rdf:type rdf:Property ;
    rdfs:label 'Primary Coupon Booking Pnr Id' ;
    rdfs:comment 'Reference to the booking record associated with this coupon.' ;
    rdfs:domain ind:CouponStatus ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Pnr .

ind:checkedInTimestamp rdf:type rdf:Property ;
    rdfs:label 'Checked In Timestamp' ;
    rdfs:comment 'Timestamp when the passenger checked in for the flight segment covered by this coupon.' ;
    rdfs:domain ind:CouponStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:couponStatusCode rdf:type rdf:Property ;
    rdfs:label 'Coupon Status Code' ;
    rdfs:comment 'Current lifecycle status of the coupon: O=Open for Use, F=Flown/Used, L=Lifted/Boarded, A=Airport Control, C=Checked In, V=Void, E=Exchanged, R=Refunded, I=Irregular Operations, S=Suspended, U=Unavailable, P=Printed, Z=Archived. [ENUM-REF-CANDIDATE: O|F|L|A|C|V|E|R|I|S|U|P|Z — 13 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:CouponStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:couponStatusDescription rdf:type rdf:Property ;
    rdfs:label 'Coupon Status Description' ;
    rdfs:comment 'Human-readable description of the current coupon status.' ;
    rdfs:domain ind:CouponStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeTimestamp rdf:type rdf:Property ;
    rdfs:label 'Exchange Timestamp' ;
    rdfs:comment 'Timestamp when the coupon was exchanged for a new ticket or itinerary.' ;
    rdfs:domain ind:CouponStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:flownTimestamp rdf:type rdf:Property ;
    rdfs:label 'Flown Timestamp' ;
    rdfs:comment 'The precise timestamp when the coupon was marked as flown/used, typically at gate closure or boarding completion.' ;
    rdfs:domain ind:CouponStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:previousStatusCode rdf:type rdf:Property ;
    rdfs:label 'Previous Status Code' ;
    rdfs:comment 'The coupon status code immediately prior to the current status, enabling status transition tracking.' ;
    rdfs:domain ind:CouponStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reissueIndicator rdf:type rdf:Property ;
    rdfs:label 'Reissue Indicator' ;
    rdfs:comment 'Flag indicating whether this coupon was reissued as part of a ticket exchange or voluntary change.' ;
    rdfs:domain ind:CouponStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheduledDepartureDate rdf:type rdf:Property ;
    rdfs:label 'Scheduled Departure Date' ;
    rdfs:comment 'Originally scheduled departure date for this coupon segment, in yyyy-MM-dd format.' ;
    rdfs:domain ind:CouponStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:statusChangeReasonCode rdf:type rdf:Property ;
    rdfs:label 'Status Change Reason Code' ;
    rdfs:comment 'Code indicating the reason for the status change (e.g., passenger no-show, voluntary change, involuntary reroute, schedule change).' ;
    rdfs:domain ind:CouponStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusChangeReasonText rdf:type rdf:Property ;
    rdfs:label 'Status Change Reason Text' ;
    rdfs:comment 'Free-text description providing additional context for the status change.' ;
    rdfs:domain ind:CouponStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusChangeTimestamp rdf:type rdf:Property ;
    rdfs:label 'Status Change Timestamp' ;
    rdfs:comment 'Date and time when the coupon status was last changed, in ISO 8601 format (yyyy-MM-ddTHH:mm:ss.SSSXXX).' ;
    rdfs:domain ind:CouponStatus ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:boardingSequence rdf:type rdf:Property ;
    rdfs:label 'Boarding Sequence' ;
    rdfs:comment 'Numeric boarding priority assigned to this passenger for this flight, determining boarding group and order. Lower numbers board first.' ;
    rdfs:domain ind:BookingSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:boardingTimestamp rdf:type rdf:Property ;
    rdfs:label 'Boarding Timestamp' ;
    rdfs:comment 'Date and time when the passenger\'s boarding pass was scanned at the gate and they boarded the aircraft for this flight leg. UTC timestamp.' ;
    rdfs:domain ind:BookingSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:segmentUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Segment Updated Timestamp' ;
    rdfs:comment 'Date and time when this booking segment was last modified. Updated on any change to segment details. UTC timestamp.' ;
    rdfs:domain ind:BookingSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:standbyPriority rdf:type rdf:Property ;
    rdfs:label 'Standby Priority' ;
    rdfs:comment 'Priority ranking for standby passengers on this flight segment. Lower numbers have higher priority for available seats. Null if passenger is confirmed.' ;
    rdfs:domain ind:BookingSegment ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:parentEntityLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Parent Entity Legal Entity Id' ;
    rdfs:comment 'Reference to the immediate parent legal entity in the corporate ownership hierarchy. Null if this is the ultimate parent.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:parentLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Parent Legal Entity Id' ;
    rdfs:comment 'Self-referencing FK on legal_entity (parent_legal_entity_id)' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:primaryUltimateParentEntityLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Primary Ultimate Parent Entity Legal Entity Id' ;
    rdfs:comment 'Reference to the top-level parent legal entity in the corporate ownership hierarchy. Null if this is the ultimate parent.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:accountingStandard rdf:type rdf:Property ;
    rdfs:label 'Accounting Standard' ;
    rdfs:comment 'Primary accounting framework used by the entity for financial reporting (IFRS, US GAAP, or local GAAP).' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:airOperatorCertificateNumber rdf:type rdf:Property ;
    rdfs:label 'Air Operator Certificate Number' ;
    rdfs:comment 'Certificate number issued by the civil aviation authority authorizing the entity to conduct commercial air transport operations.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aocEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Aoc Effective Date' ;
    rdfs:comment 'Date on which the Air Operator Certificate became effective and the entity was authorized to commence operations.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:aocExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Aoc Expiry Date' ;
    rdfs:comment 'Date on which the Air Operator Certificate expires and must be renewed. Null if certificate has no expiry.' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:aocIssuingAuthority rdf:type rdf:Property ;
    rdfs:label 'Aoc Issuing Authority' ;
    rdfs:comment 'Name of the civil aviation authority that issued the Air Operator Certificate (e.g., FAA, EASA, CAAC).' ;
    rdfs:domain ind:Airlines ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:consolidationMethod rdf:type rdf:Property ;
    rdfs:label 'Consolidation Method' ;
    rdfs:comment 'Accounting method used to consolidate this entity\'s financial results into group reporting.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalYearEndDay rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year End Day' ;
    rdfs:comment 'Day of month (1-31) representing the end of the entity\'s fiscal year.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fiscalYearEndMonth rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year End Month' ;
    rdfs:comment 'Month number (1-12) representing the end of the entity\'s fiscal year for financial reporting purposes.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:incorporationCountryCode rdf:type rdf:Property ;
    rdfs:label 'Incorporation Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the jurisdiction where the entity is incorporated.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incorporationJurisdiction rdf:type rdf:Property ;
    rdfs:label 'Incorporation Jurisdiction' ;
    rdfs:comment 'State, province, or sub-national jurisdiction within the incorporation country (e.g., Delaware, Ontario).' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalEntityCode rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Code' ;
    rdfs:comment 'Business-assigned unique code for the legal entity used in financial reporting and consolidation.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalEntityName rdf:type rdf:Property ;
    rdfs:label 'Legal Entity Name' ;
    rdfs:comment 'Full registered legal name of the entity as it appears in incorporation documents and regulatory filings.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:legalForm rdf:type rdf:Property ;
    rdfs:label 'Legal Form' ;
    rdfs:comment 'Type of legal structure of the entity (e.g., corporation, LLC, partnership, branch).' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:leiCode rdf:type rdf:Property ;
    rdfs:label 'Lei Code' ;
    rdfs:comment 'ISO 17442 Legal Entity Identifier, a 20-character alphanumeric code for unique identification in financial transactions and regulatory reporting.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:operatingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Operating Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of the primary country where the entity conducts business operations.' ;
    rdfs:domain ind:LegalEntity ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

