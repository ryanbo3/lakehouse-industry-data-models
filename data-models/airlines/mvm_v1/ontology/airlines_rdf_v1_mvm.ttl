ind:frequentFlyerAccrualAllowed rdf:type rdf:Property ;
    rdfs:label 'Frequent Flyer Accrual Allowed' ;
    rdfs:comment 'Indicates whether passengers can earn frequent flyer miles on the marketing carriers program for codeshare flights.' ;
    rdfs:domain ind:CodeshareAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interlineTicketingAllowed rdf:type rdf:Property ;
    rdfs:label 'Interline Ticketing Allowed' ;
    rdfs:comment 'Indicates whether interline ticketing is permitted under this codeshare agreement for multi-carrier itineraries.' ;
    rdfs:domain ind:CodeshareAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:inventoryControlParty rdf:type rdf:Property ;
    rdfs:label 'Inventory Control Party' ;
    rdfs:comment 'Designates which carrier has authority over seat inventory management and availability control.' ;
    rdfs:domain ind:CodeshareAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:liabilityAllocationModel rdf:type rdf:Property ;
    rdfs:label 'Liability Allocation Model' ;
    rdfs:comment 'Defines which carrier bears primary liability for passenger claims and operational issues under this codeshare.' ;
    rdfs:domain ind:CodeshareAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:loungeAccessReciprocity rdf:type rdf:Property ;
    rdfs:label 'Lounge Access Reciprocity' ;
    rdfs:comment 'Indicates whether marketing carrier passengers have access to operating carrier lounges under this agreement.' ;
    rdfs:domain ind:CodeshareAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:marketingCarrierSharePercentage rdf:type rdf:Property ;
    rdfs:label 'Marketing Carrier Share Percentage' ;
    rdfs:comment 'Percentage of revenue allocated to the marketing carrier when percentage-split revenue model is used.' ;
    rdfs:domain ind:CodeshareAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:operatingCarrierSharePercentage rdf:type rdf:Property ;
    rdfs:label 'Operating Carrier Share Percentage' ;
    rdfs:comment 'Percentage of revenue allocated to the operating carrier when percentage-split revenue model is used.' ;
    rdfs:domain ind:CodeshareAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:prorateMethod rdf:type rdf:Property ;
    rdfs:label 'Prorate Method' ;
    rdfs:comment 'Calculation methodology for revenue proration when prorate revenue share model is applied.' ;
    rdfs:domain ind:CodeshareAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Regulatory Approval Date' ;
    rdfs:comment 'Date when regulatory authorities approved this codeshare agreement for commercial operation.' ;
    rdfs:domain ind:CodeshareAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Renewal Notice Days' ;
    rdfs:comment 'Number of days advance notice required before expiration to trigger renewal or termination of the agreement.' ;
    rdfs:domain ind:CodeshareAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revenueShareModel rdf:type rdf:Property ;
    rdfs:label 'Revenue Share Model' ;
    rdfs:comment 'Method used to allocate revenue between operating and marketing carriers under this codeshare agreement.' ;
    rdfs:domain ind:CodeshareAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleCoordinationRequired rdf:type rdf:Property ;
    rdfs:label 'Schedule Coordination Required' ;
    rdfs:comment 'Indicates whether flight schedules must be coordinated between operating and marketing carriers under this agreement.' ;
    rdfs:domain ind:CodeshareAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:terminationNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Termination Notice Days' ;
    rdfs:comment 'Number of days advance notice required by either party to terminate the codeshare agreement.' ;
    rdfs:domain ind:CodeshareAgreement ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:iropFlightImpactId rdf:type rdf:Property ;
    rdfs:label 'Irop Flight Impact Id' ;
    rdfs:comment 'Primary key for the irop_flight_impact association' ;
    rdfs:domain ind:IropFlightImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:delayMinutesAttributed rdf:type rdf:Property ;
    rdfs:label 'Delay Minutes Attributed' ;
    rdfs:comment 'The portion of this flight leg\'s total delay minutes directly attributable to this specific IROP event. Distinct from delay_minutes on flight_leg (which is total delay from all causes). Required for regulatory reporting, passenger compensation eligibility determination, and IROP financial impact reconciliation when multiple IROP events affect the same flight.' ;
    rdfs:domain ind:IropFlightImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:flightImpactStatus rdf:type rdf:Property ;
    rdfs:label 'Flight Impact Status' ;
    rdfs:comment 'Current lifecycle state of this flight leg\'s impact within the IROP recovery workflow. Tracks OCC progress from initial impact identification through recovery completion, independent of the overall IROP event status.' ;
    rdfs:domain ind:IropFlightImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:impactSequenceNumber rdf:type rdf:Property ;
    rdfs:label 'Impact Sequence Number' ;
    rdfs:comment 'Ordinal position of this flight leg within the IROP event\'s recovery prioritization sequence. OCC planners assign sequence numbers to determine the order in which affected flights are recovered. Belongs to the association because sequence is relative to the IROP event, not an intrinsic property of the flight leg.' ;
    rdfs:domain ind:IropFlightImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:impactType rdf:type rdf:Property ;
    rdfs:label 'Impact Type' ;
    rdfs:comment 'Classification of how this IROP event affected this specific flight leg. Distinct from flight_status on flight_leg — captures the IROP-specific outcome (e.g., a flight may have been recovered without a formal cancellation but still had an IROP impact type of DELAYED).' ;
    rdfs:domain ind:IropFlightImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recoveryActionTaken rdf:type rdf:Property ;
    rdfs:label 'Recovery Action Taken' ;
    rdfs:comment 'Specific recovery action applied to this flight leg under this IROP event by OCC. Examples include aircraft swap, crew reassignment, passenger reprotection, flight merge, or delay absorption. Belongs to the association because the same IROP event may trigger different recovery actions for different affected flights.' ;
    rdfs:domain ind:IropFlightImpact ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:uldContentId rdf:type rdf:Property ;
    rdfs:label 'Uld Content Id' ;
    rdfs:comment 'Primary key for the uld_content association' ;
    rdfs:domain ind:UldContent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adIncorporationId rdf:type rdf:Property ;
    rdfs:label 'Ad Incorporation Id' ;
    rdfs:comment 'Primary key for the ad_incorporation association' ;
    rdfs:domain ind:AdIncorporation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:adComplianceStatus rdf:type rdf:Property ;
    rdfs:label 'Ad Compliance Status' ;
    rdfs:comment 'Overall compliance status of Airworthiness Directives (ADs) incorporated into this maintenance program. [Moved from program: This is a rolled-up summary of AD compliance across all incorporated ADs. The per-AD compliance status belongs at the ad_incorporation level (incorporation_status attribute), not as a single aggregate on the program. The program-level field should be derived or replaced by querying the association table.]' ;
    rdfs:domain ind:AdIncorporation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicabilityOverride rdf:type rdf:Property ;
    rdfs:label 'Applicability Override' ;
    rdfs:comment 'Operator or CAMO-specific applicability determination that narrows, clarifies, or overrides the AD\'s general applicability statement for this specific program\'s fleet effectivity (e.g., restricted to MSN range 1234-5678 within this operator\'s fleet).' ;
    rdfs:domain ind:AdIncorporation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incorporationStatus rdf:type rdf:Property ;
    rdfs:label 'Incorporation Status' ;
    rdfs:comment 'Current status of this AD\'s incorporation into the program. INCORPORATED=AD is fully embedded in the program tasks; DEFERRED=incorporation approved for later revision; NOT_APPLICABLE=CAMO has determined this AD does not apply to this program\'s effectivity; PENDING=under review.' ;
    rdfs:domain ind:Maintenance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionReference rdf:type rdf:Property ;
    rdfs:label 'Revision Reference' ;
    rdfs:comment 'The program revision identifier at which this AD was formally incorporated (e.g., Rev 12, Amendment 4). Provides traceability for regulatory audits showing when the AD entered the program.' ;
    rdfs:domain ind:AdIncorporation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sbIncorporationId rdf:type rdf:Property ;
    rdfs:label 'Sb Incorporation Id' ;
    rdfs:comment 'Primary key for the sb_incorporation association' ;
    rdfs:domain ind:SbIncorporation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:applicabilityDecision rdf:type rdf:Property ;
    rdfs:label 'Applicability Decision' ;
    rdfs:comment 'CAMO determination of whether this Service Bulletin is applicable to the aircraft effectivity covered by this maintenance program. A single SB may be applicable to one program but not another depending on MSN range, configuration, or modification state.' ;
    rdfs:domain ind:SbIncorporation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revisionIncorporated rdf:type rdf:Property ;
    rdfs:label 'Revision Incorporated' ;
    rdfs:comment 'The specific revision level of the Service Bulletin that was incorporated into this maintenance program (e.g., Rev 3, Original). Tracks which SB revision the program is aligned to, enabling traceability when the OEM issues subsequent SB revisions.' ;
    rdfs:domain ind:SbIncorporation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sbIncorporationStatus rdf:type rdf:Property ;
    rdfs:label 'Sb Incorporation Status' ;
    rdfs:comment 'Status of manufacturer Service Bulletin (SB) incorporation into this maintenance program. [Moved from program: This attribute on program is a scalar summary of overall SB incorporation status for the entire program. The per-SB incorporation status for each program-SB combination belongs in the sb_incorporation association, where it can be tracked at the individual SB level with full detail. The program-level summary field conflates what should be granular per-SB records into a single string, losing all per-SB traceability.]' ;
    rdfs:domain ind:SbIncorporation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .
