    rdfs:domain ind:BatchItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemAmount rdf:type rdf:Property ;
    rdfs:label 'Item Amount' ;
    rdfs:comment 'Monetary amount for the line item in the transaction currency.' ;
    rdfs:domain ind:BatchItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:itemCurrency rdf:type rdf:Property ;
    rdfs:label 'Item Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code of the item amount.' ;
    rdfs:domain ind:BatchItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemStatus rdf:type rdf:Property ;
    rdfs:label 'Item Status' ;
    rdfs:comment 'Current processing status of the batch line item.' ;
    rdfs:domain ind:BatchItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:itemType rdf:type rdf:Property ;
    rdfs:label 'Item Type' ;
    rdfs:comment 'Business classification of the line item (e.g., purchase, refund).' ;
    rdfs:domain ind:BatchItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkCode rdf:type rdf:Property ;
    rdfs:label 'Network Code' ;
    rdfs:comment 'Code identifying the payment network or interchange used for routing.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalTransactionReference rdf:type rdf:Property ;
    rdfs:label 'Original Transaction Reference' ;
    rdfs:comment 'Reference to the original transaction identifier when this line is a reversal or adjustment.' ;
    rdfs:domain ind:BatchItem ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalAuthorizationId rdf:type rdf:Property ;
    rdfs:label 'Original Authorization Id' ;
    rdfs:comment 'Identifier of the original authorization transaction that this capture fulfills.' ;
    rdfs:domain ind:Capture ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Authorization .

ind:captureMethod rdf:type rdf:Property ;
    rdfs:label 'Capture Method' ;
    rdfs:comment 'Method by which the capture was performed (immediate, delayed, incremental, or partial).' ;
    rdfs:domain ind:Capture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:captureNumber rdf:type rdf:Property ;
    rdfs:label 'Capture Number' ;
    rdfs:comment 'Business-facing identifier for the capture event, often used in reporting and reconciliation.' ;
    rdfs:domain ind:Capture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:captureStatus rdf:type rdf:Property ;
    rdfs:label 'Capture Status' ;
    rdfs:comment 'Current lifecycle status of the capture (e.g., pending, completed, failed, reversed, partial).' ;
    rdfs:domain ind:Capture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interchangeFee rdf:type rdf:Property ;
    rdfs:label 'Interchange Fee' ;
    rdfs:comment 'Fee paid between acquiring and issuing banks for this capture.' ;
    rdfs:domain ind:Capture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isIncremental rdf:type rdf:Property ;
    rdfs:label 'Is Incremental' ;
    rdfs:comment 'True when the capture adds to a previously captured amount (multiple captures).' ;
    rdfs:domain ind:Capture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPartialCapture rdf:type rdf:Property ;
    rdfs:label 'Is Partial Capture' ;
    rdfs:comment 'Indicates whether the capture represents a partial amount of the original authorization.' ;
    rdfs:domain ind:Capture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSettled rdf:type rdf:Property ;
    rdfs:label 'Is Settled' ;
    rdfs:comment 'True when the capture amount has been successfully settled.' ;
    rdfs:domain ind:Capture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:network rdf:type rdf:Property ;
    rdfs:label 'Network' ;
    rdfs:comment 'Payment network that processed the transaction (e.g., Visa, Mastercard).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingFee rdf:type rdf:Property ;
    rdfs:label 'Processing Fee' ;
    rdfs:comment 'Fee charged by the payment processor for handling the capture.' ;
    rdfs:domain ind:Capture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reversalAmount rdf:type rdf:Property ;
    rdfs:label 'Reversal Amount' ;
    rdfs:comment 'Amount reversed from the capture, if a reversal occurred.' ;
    rdfs:domain ind:Capture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:riskScoreAtCapture rdf:type rdf:Property ;
    rdfs:label 'Risk Score At Capture' ;
    rdfs:comment 'Fraud risk score assigned at the moment of capture.' ;
    rdfs:domain ind:Capture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tipAmount rdf:type rdf:Property ;
    rdfs:label 'Tip Amount' ;
    rdfs:comment 'Additional tip amount added to the capture, if applicable.' ;
    rdfs:domain ind:Capture ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:acquiringInstitutionCode rdf:type rdf:Property ;
    rdfs:label 'Acquiring Institution Code' ;
    rdfs:comment 'Identifier of the acquiring financial institution.' ;
    rdfs:domain ind:ClearingSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:amountFee rdf:type rdf:Property ;
    rdfs:label 'Amount Fee' ;
    rdfs:comment 'Sum of all fees applied to the transaction.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chargebackFlag rdf:type rdf:Property ;
    rdfs:label 'Chargeback Flag' ;
    rdfs:comment 'True if the transaction resulted in a chargeback.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:clearingSubmissionStatus rdf:type rdf:Property ;
    rdfs:label 'Clearing Submission Status' ;
    rdfs:comment 'Current processing state of the clearing submission.' ;
    rdfs:domain ind:ClearingSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iinNumber rdf:type rdf:Property ;
    rdfs:label 'Iin Number' ;
    rdfs:comment 'Six-digit identifier of the card issuer.' ;
    rdfs:domain ind:ClearingSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irfRateCategory rdf:type rdf:Property ;
    rdfs:label 'Irf Rate Category' ;
    rdfs:comment 'Rate tier applied for IRF calculation.' ;
    rdfs:domain ind:ClearingSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuingInstitutionCode rdf:type rdf:Property ;
    rdfs:label 'Issuing Institution Code' ;
    rdfs:comment 'Identifier of the issuing financial institution.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:pciCompliantFlag rdf:type rdf:Property ;
    rdfs:label 'Pci Compliant Flag' ;
    rdfs:comment 'True if the transaction data meets PCI compliance requirements.' ;
    rdfs:domain ind:ClearingSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sanctionCheckFlag rdf:type rdf:Property ;
    rdfs:label 'Sanction Check Flag' ;
    rdfs:comment 'True when the transaction passed sanctions screening.' ;
    rdfs:domain ind:ClearingSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:submissionReference rdf:type rdf:Property ;
    rdfs:label 'Submission Reference' ;
    rdfs:comment 'Reference assigned by the card scheme or ACH network for this clearing submission.' ;
    rdfs:domain ind:ClearingSubmission ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fxConversionId rdf:type rdf:Property ;
    rdfs:label 'Fx Conversion Id' ;
    rdfs:comment 'Unique surrogate key for each foreign exchange conversion record.' ;
    rdfs:domain ind:FxConversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sourceCurrencyId rdf:type rdf:Property ;
    rdfs:label 'Source Currency Id' ;
    rdfs:comment 'Foreign key linking to reference.currency. Business justification: FX conversion reports must reference the source currency entity to calculate rates and regulatory disclosures.' ;
    rdfs:domain ind:FxConversion ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Currency .

ind:conversionFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Conversion Fee Amount' ;
    rdfs:comment 'Fee charged for performing the foreign exchange conversion, expressed in the target currency.' ;
    rdfs:domain ind:FxConversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:conversionFeeCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Conversion Fee Currency Code' ;
    rdfs:comment 'Currency in which the conversion fee is denominated.' ;
    rdfs:domain ind:FxConversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionMethod rdf:type rdf:Property ;
    rdfs:label 'Conversion Method' ;
    rdfs:comment 'How the conversion rate was applied: automatically, manually, or overridden by an operator.' ;
    rdfs:domain ind:FxConversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionNote rdf:type rdf:Property ;
    rdfs:label 'Conversion Note' ;
    rdfs:comment 'Free-form text field for any additional remarks about the conversion.' ;
    rdfs:domain ind:FxConversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionReference rdf:type rdf:Property ;
    rdfs:label 'Conversion Reference' ;
    rdfs:comment 'Business reference code assigned to the conversion event for external tracking.' ;
    rdfs:domain ind:FxConversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:conversionStatus rdf:type rdf:Property ;
    rdfs:label 'Conversion Status' ;
    rdfs:comment 'Current lifecycle state of the conversion record.' ;
    rdfs:domain ind:FxConversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dccOptInFlag rdf:type rdf:Property ;
    rdfs:label 'Dcc Opt In Flag' ;
    rdfs:comment 'True if the cardholder opted in to Dynamic Currency Conversion; otherwise False.' ;
    rdfs:domain ind:FxConversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rateValidityEnd rdf:type rdf:Property ;
    rdfs:label 'Rate Validity End' ;
    rdfs:comment 'Date after which the quoted FX rate is no longer valid (nullable).' ;
    rdfs:domain ind:FxConversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:rateValidityStart rdf:type rdf:Property ;
    rdfs:label 'Rate Validity Start' ;
    rdfs:comment 'Date from which the quoted FX rate is considered valid.' ;
    rdfs:domain ind:FxConversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sourceAmount rdf:type rdf:Property ;
    rdfs:label 'Source Amount' ;
    rdfs:comment 'Transaction amount expressed in the source currency before conversion.' ;
    rdfs:domain ind:FxConversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetAmount rdf:type rdf:Property ;
    rdfs:label 'Target Amount' ;
    rdfs:comment 'Transaction amount expressed in the target currency after conversion.' ;
    rdfs:domain ind:FxConversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:targetCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Target Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 code of the currency after conversion.' ;
    rdfs:domain ind:FxConversion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isoMessageId rdf:type rdf:Property ;
    rdfs:label 'Iso Message Id' ;
    rdfs:comment 'Unique surrogate key for each raw ISO message record.' ;
    rdfs:domain ind:IsoMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalMessageIsoMessageId rdf:type rdf:Property ;
    rdfs:label 'Original Message Iso Message Id' ;
    rdfs:comment 'Reference to the prior ISO message (e.g., original authorization for a reversal).' ;
    rdfs:domain ind:IsoMessage ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IsoMessage .

ind:bitmap rdf:type rdf:Property ;
    rdfs:label 'Bitmap' ;
    rdfs:comment 'Hexadecimal representation of the presence map for data elements in the ISO message.' ;
    rdfs:domain ind:IsoMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:messagePayload rdf:type rdf:Property ;
    rdfs:label 'Message Payload' ;
    rdfs:comment 'Full raw message content as received (hex or base64).' ;
    rdfs:domain ind:IsoMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:messageTimestamp rdf:type rdf:Property ;
    rdfs:label 'Message Timestamp' ;
    rdfs:comment 'Date and time when the ISO message was sent or received (event time).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:panMasked rdf:type rdf:Property ;
    rdfs:label 'Pan Masked' ;
    rdfs:comment 'Card Primary Account Number with middle digits masked to protect cardholder data.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retrievalReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Retrieval Reference Number' ;
    rdfs:comment 'Identifier used to retrieve the transaction in later processing stages.' ;
    rdfs:domain ind:IsoMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sessionReference rdf:type rdf:Property ;
    rdfs:label 'Session Reference' ;
    rdfs:comment 'Identifier linking multiple messages that belong to the same processing session.' ;
    rdfs:domain ind:IsoMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:systemTraceAuditNumber rdf:type rdf:Property ;
    rdfs:label 'System Trace Audit Number' ;
    rdfs:comment 'Unique numeric identifier assigned by the originating system for traceability.' ;
    rdfs:domain ind:IsoMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transmissionDatetime rdf:type rdf:Property ;
    rdfs:label 'Transmission Datetime' ;
    rdfs:comment 'Date-time when the message was transmitted, as captured in DE7.' ;
    rdfs:domain ind:IsoMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:posEntryModeId rdf:type rdf:Property ;
    rdfs:label 'Pos Entry Mode Id' ;
    rdfs:comment 'Foreign key linking to transaction.pos_entry_mode. Business justification: Standardize entry mode by linking payment_txn to the pos_entry_mode reference table; replace the free-text entry_mode column with a foreign key.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PosEntryMode .

ind:transactionMccId rdf:type rdf:Property ;
    rdfs:label 'Transaction Mcc Id' ;
    rdfs:comment 'Foreign key linking to reference.mcc. Business justification: Transaction records need a formal link to the MCC master data for reporting and fee calculation. Adding transaction_mcc_id (FK to reference.mcc.mcc_id) replaces the loosely-typed mcc_code.' ;
    rdfs:domain ind:PaymentTxn ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Mcc .

ind:isStp rdf:type rdf:Property ;
    rdfs:label 'Is Stp' ;
    rdfs:comment 'True when the transaction was processed end-to-end without manual intervention.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isoMessageType rdf:type rdf:Property ;
    rdfs:label 'Iso Message Type' ;
    rdfs:comment 'Four-digit code identifying the message class (e.g., 0100 for authorization request).' ;
    rdfs:domain ind:PaymentTxn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:paymentTxnStatus rdf:type rdf:Property ;
    rdfs:label 'Payment Txn Status' ;
    rdfs:comment 'Current processing state of the transaction (e.g., authorized, captured, settled, declined, reversed, chargeback).' ;
    rdfs:domain ind:PaymentTxn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tokenizationFlag rdf:type rdf:Property ;
    rdfs:label 'Tokenization Flag' ;
    rdfs:comment 'True if the transaction used a tokenized payment credential instead of a clear PAN.' ;
    rdfs:domain ind:PaymentTxn ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:chargebackLiabilityRule rdf:type rdf:Property ;
    rdfs:label 'Chargeback Liability Rule' ;
    rdfs:comment 'Rule that defines which party bears chargeback liability for this entry mode.' ;
    rdfs:domain ind:PosEntryMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:credentialOnFileFlag rdf:type rdf:Property ;
    rdfs:label 'Credential On File Flag' ;
    rdfs:comment 'True when the payment credential is stored for future recurring or tokenized transactions.' ;
    rdfs:domain ind:PosEntryMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:entryModeName rdf:type rdf:Property ;
    rdfs:label 'Entry Mode Name' ;
    rdfs:comment 'Human-readable name of the entry mode (e.g., "EMV Chip Contact", "Magnetic Stripe").' ;
    rdfs:domain ind:PosEntryMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryModeType rdf:type rdf:Property ;
    rdfs:label 'Entry Mode Type' ;
    rdfs:comment 'Categorized type of entry mode used at the point of interaction.' ;
    rdfs:domain ind:PosEntryMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fallbackEligible rdf:type rdf:Property ;
    rdfs:label 'Fallback Eligible' ;
    rdfs:comment 'Indicates whether the entry mode can fall back to a lower-security method if the primary method fails.' ;
    rdfs:domain ind:PosEntryMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interchangeQualificationCode rdf:type rdf:Property ;
    rdfs:label 'Interchange Qualification Code' ;
    rdfs:comment 'Code used by acquiring networks to qualify interchange rates for this entry mode.' ;
    rdfs:domain ind:PosEntryMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:iso8583De22Code rdf:type rdf:Property ;
    rdfs:label 'Iso 8583 De22 Code' ;
    rdfs:comment 'ISO 8583 field code that identifies the point-of-service entry mode used for the transaction.' ;
    rdfs:domain ind:PosEntryMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:motoFlag rdf:type rdf:Property ;
    rdfs:label 'Moto Flag' ;
    rdfs:comment 'True if the entry mode represents a MOTO transaction (card not present, entered manually).' ;
    rdfs:domain ind:PosEntryMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:posEntryModeDescription rdf:type rdf:Property ;
    rdfs:label 'Pos Entry Mode Description' ;
    rdfs:comment 'Free-form description of the entry mode, including any special handling notes.' ;
    rdfs:domain ind:PosEntryMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:posEntryModeStatus rdf:type rdf:Property ;
    rdfs:label 'Pos Entry Mode Status' ;
    rdfs:comment 'Current lifecycle status of the entry mode definition.' ;
    rdfs:domain ind:PosEntryMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qrCodeFlag rdf:type rdf:Property ;
    rdfs:label 'Qr Code Flag' ;
    rdfs:comment 'True if the entry mode is QR code scan.' ;
    rdfs:domain ind:PosEntryMode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:riskScoreAverage rdf:type rdf:Property ;
    rdfs:label 'Risk Score Average' ;
    rdfs:comment 'Historical average fraud risk score associated with transactions using this entry mode.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reconciliationExceptionId rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Exception Id' ;
    rdfs:comment 'System-generated unique identifier for each reconciliation exception.' ;
    rdfs:domain ind:ReconciliationException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:assignedResolverEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Assigned Resolver Employee Id' ;
    rdfs:comment 'Identifier of the employee or team responsible for resolving the exception.' ;
    rdfs:domain ind:ReconciliationException ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryReconciliationInternalTransactionId rdf:type rdf:Property ;
    rdfs:label 'Primary Reconciliation Internal Transaction Id' ;
    rdfs:comment 'Identifier of the internal transaction record that participated in the reconciliation.' ;
    rdfs:domain ind:ReconciliationException ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Transaction .

ind:amountDifference rdf:type rdf:Property ;
    rdfs:label 'Amount Difference' ;
    rdfs:comment 'Numeric difference between internal and scheme transaction amounts.' ;
    rdfs:domain ind:ReconciliationException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exceptionAmount rdf:type rdf:Property ;
    rdfs:label 'Exception Amount' ;
    rdfs:comment 'Monetary value associated with the exception (e.g., mismatched amount).' ;
    rdfs:domain ind:ReconciliationException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exceptionCurrency rdf:type rdf:Property ;
    rdfs:label 'Exception Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the exception amount.' ;
    rdfs:domain ind:ReconciliationException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionDescription rdf:type rdf:Property ;
    rdfs:label 'Exception Description' ;
    rdfs:comment 'Detailed textual description of the discrepancy that caused the exception.' ;
    rdfs:domain ind:ReconciliationException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionSeverity rdf:type rdf:Property ;
    rdfs:label 'Exception Severity' ;
    rdfs:comment 'Risk severity rating assigned to the exception.' ;
    rdfs:domain ind:ReconciliationException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDuplicateFlag rdf:type rdf:Property ;
    rdfs:label 'Is Duplicate Flag' ;
    rdfs:comment 'Indicates whether the exception represents a duplicate transaction record.' ;
    rdfs:domain ind:ReconciliationException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:refundId rdf:type rdf:Property ;
    rdfs:label 'Refund Id' ;
    rdfs:comment 'System-generated unique identifier for the refund record.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cardholderEmail rdf:type rdf:Property ;
    rdfs:label 'Cardholder Email' ;
    rdfs:comment 'Primary email address of the cardholder for communication and receipt delivery.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardholderPanMasked rdf:type rdf:Property ;
    rdfs:label 'Cardholder Pan Masked' ;
    rdfs:comment 'Masked representation of the cardholder\'s PAN (first 6 and last 4 digits visible) to comply with PCI DSS.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:initiatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Initiated Timestamp' ;
    rdfs:comment 'Date-time when the merchant initiated the refund request.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isChargebackRelated rdf:type rdf:Property ;
    rdfs:label 'Is Chargeback Related' ;
    rdfs:comment 'True if the refund is linked to an ongoing chargeback case.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPartialRefund rdf:type rdf:Property ;
    rdfs:label 'Is Partial Refund' ;
    rdfs:comment 'True if the refund amount is less than the original transaction amount.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:partialRefundAmount rdf:type rdf:Property ;
    rdfs:label 'Partial Refund Amount' ;
    rdfs:comment 'Amount refunded when the refund is partial.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Processed Timestamp' ;
    rdfs:comment 'Date-time when the refund was successfully posted to the cardholder\'s account.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:processorReference rdf:type rdf:Property ;
    rdfs:label 'Processor Reference' ;
    rdfs:comment 'Reference identifier returned by the payment processor for the refund transaction.' ;
    rdfs:domain ind:Refund ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundMethod rdf:type rdf:Property ;
