    rdfs:comment 'Result of the gateway\'s initial syntactic/semantic validation.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acquirerResponseCode rdf:type rdf:Property ;
    rdfs:label 'Acquirer Response Code' ;
    rdfs:comment 'Response code returned by the acquiring bank or processor.' ;
    rdfs:domain ind:Response ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:amountCents rdf:type rdf:Property ;
    rdfs:label 'Amount Cents' ;
    rdfs:comment 'Transaction amount expressed in the smallest currency unit (e.g., cents).' ;
    rdfs:domain ind:Response ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cardType rdf:type rdf:Property ;
    rdfs:label 'Card Type' ;
    rdfs:comment 'Classification of the card (credit, debit, prepaid, commercial).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationIp rdf:type rdf:Property ;
    rdfs:label 'Destination Ip' ;
    rdfs:comment 'IP address of the merchant endpoint that received the response.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:destinationPort rdf:type rdf:Property ;
    rdfs:label 'Destination Port' ;
    rdfs:comment 'Network port on the merchant side used for the response.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:entryMode rdf:type rdf:Property ;
    rdfs:label 'Entry Mode' ;
    rdfs:comment 'Method by which card data was captured.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:finalDisposition rdf:type rdf:Property ;
    rdfs:label 'Final Disposition' ;
    rdfs:comment 'Overall outcome of the response after retries (e.g., success, failed, partial).' ;
    rdfs:domain ind:Response ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isFraudFlag rdf:type rdf:Property ;
    rdfs:label 'Is Fraud Flag' ;
    rdfs:comment 'Indicates whether the transaction was flagged as potentially fraudulent.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:message rdf:type rdf:Property ;
    rdfs:label 'Message' ;
    rdfs:comment 'Optional free-text message included in the response.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseCode rdf:type rdf:Property ;
    rdfs:label 'Response Code' ;
    rdfs:comment 'Standard response code indicating approval, decline, or error (e.g., ISO 8583 response codes).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irfRateCategoryId rdf:type rdf:Property ;
    rdfs:label 'Irf Rate Category Id' ;
    rdfs:comment 'Foreign key linking to interchange.irf_rate_category. Business justification: Routing: rules need to reference IRF rate categories to apply correct interchange rates per regulatory and scheme requirements.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IrfRateCategory .

ind:targetAcquirerAcquirerEndpointId rdf:type rdf:Property ;
    rdfs:label 'Target Acquirer Acquirer Endpoint Id' ;
    rdfs:comment 'Primary acquirer endpoint to which matching transactions are routed.' ;
    rdfs:domain ind:GatewayRoutingRule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AcquirerEndpoint .

ind:amountMax rdf:type rdf:Property ;
    rdfs:label 'Amount Max' ;
    rdfs:comment 'Upper bound of transaction amount for rule matching.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amountMin rdf:type rdf:Property ;
    rdfs:label 'Amount Min' ;
    rdfs:comment 'Lower bound of transaction amount for rule matching.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:binRangeEnd rdf:type rdf:Property ;
    rdfs:label 'Bin Range End' ;
    rdfs:comment 'Ending BIN of the rule\'s matching range.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:binRangeStart rdf:type rdf:Property ;
    rdfs:label 'Bin Range Start' ;
    rdfs:comment 'Starting BIN (Bank Identification Number) of the rule\'s matching range.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceRuleSet rdf:type rdf:Property ;
    rdfs:label 'Compliance Rule Set' ;
    rdfs:comment 'Identifier of the compliance rule set applied to transactions routed by this rule.' ;
    rdfs:domain ind:Gateway ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:externalRuleReference rdf:type rdf:Property ;
    rdfs:label 'External Rule Reference' ;
    rdfs:comment 'Identifier of the rule in an external system, if any.' ;
    rdfs:domain ind:GatewayRoutingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failoverAcquirerSequence rdf:type rdf:Property ;
    rdfs:label 'Failover Acquirer Sequence' ;
    rdfs:comment 'Comma-separated list of acquirer IDs used for failover routing.' ;
    rdfs:domain ind:GatewayRoutingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudScoreThreshold rdf:type rdf:Property ;
    rdfs:label 'Fraud Score Threshold' ;
    rdfs:comment 'Minimum fraud risk score required for the rule to be applied.' ;
    rdfs:domain ind:GatewayRoutingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:gatewayRoutingRuleDescription rdf:type rdf:Property ;
    rdfs:label 'Gateway Routing Rule Description' ;
    rdfs:comment 'Free-form description of the rule purpose and logic.' ;
    rdfs:domain ind:GatewayRoutingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gatewayRoutingRuleStatus rdf:type rdf:Property ;
    rdfs:label 'Gateway Routing Rule Status' ;
    rdfs:comment 'Current lifecycle status of the rule.' ;
    rdfs:domain ind:GatewayRoutingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isDefaultRule rdf:type rdf:Property ;
    rdfs:label 'Is Default Rule' ;
    rdfs:comment 'Indicates whether this rule serves as the fallback/default routing rule.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:loadBalancingWeight rdf:type rdf:Property ;
    rdfs:label 'Load Balancing Weight' ;
    rdfs:comment 'Relative weight for load-balancing among multiple target acquirers.' ;
    rdfs:domain ind:GatewayRoutingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:matchCriteria rdf:type rdf:Property ;
    rdfs:label 'Match Criteria' ;
    rdfs:comment 'JSON representation of complex matching conditions not covered by individual columns.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingAlgorithm rdf:type rdf:Property ;
    rdfs:label 'Routing Algorithm' ;
    rdfs:comment 'Algorithm used to select among multiple target acquirers.' ;
    rdfs:domain ind:GatewayRoutingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tokenizationRequired rdf:type rdf:Property ;
    rdfs:label 'Tokenization Required' ;
    rdfs:comment 'Indicates if the transaction must be tokenized before routing.' ;
    rdfs:domain ind:GatewayRoutingRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:ipAllowlistId rdf:type rdf:Property ;
    rdfs:label 'Ip Allowlist Id' ;
    rdfs:comment 'Unique surrogate key for each allowlist or blocklist record.' ;
    rdfs:domain ind:IpAllowlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:enforcementAction rdf:type rdf:Property ;
    rdfs:label 'Enforcement Action' ;
    rdfs:comment 'Specifies the system response: reject the request, monitor for review, or raise an alert.' ;
    rdfs:domain ind:Gateway ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicRegion rdf:type rdf:Property ;
    rdfs:label 'Geographic Region' ;
    rdfs:comment 'Region used for regulatory or risk-based routing decisions.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipAllowlistStatus rdf:type rdf:Property ;
    rdfs:label 'Ip Allowlist Status' ;
    rdfs:comment 'Indicates whether the rule is currently enforced, awaiting activation, or revoked.' ;
    rdfs:domain ind:IpAllowlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipRange rdf:type rdf:Property ;
    rdfs:label 'Ip Range' ;
    rdfs:comment 'The IPv4 address or CIDR block that the rule applies to.' ;
    rdfs:domain ind:IpAllowlist ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:listType rdf:type rdf:Property ;
    rdfs:label 'List Type' ;
    rdfs:comment 'Specifies if the IP range is permitted (allow) or denied (block) for gateway access.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apiKey rdf:type rdf:Property ;
    rdfs:label 'Api Key' ;
    rdfs:comment 'Secret API key credential used for authentication when authentication_method = api_key.' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceLastReviewDate rdf:type rdf:Property ;
    rdfs:label 'Compliance Last Review Date' ;
    rdfs:comment 'Date of the most recent compliance audit or review for this integration.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:endpointUrl rdf:type rdf:Property ;
    rdfs:label 'Endpoint Url' ;
    rdfs:comment 'Fully qualified URL of the merchant\'s API endpoint or callback address.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:gatewayRegion rdf:type rdf:Property ;
    rdfs:label 'Gateway Region' ;
    rdfs:comment 'Geographic region or data-center where the integration is hosted (e.g., us-east-1).' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:integrationCategory rdf:type rdf:Property ;
    rdfs:label 'Integration Category' ;
    rdfs:comment 'High-level business category of the integration (e.g., payment, refund).' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:integrationName rdf:type rdf:Property ;
    rdfs:label 'Integration Name' ;
    rdfs:comment 'Human-readable name given to this integration profile by the merchant or operations team.' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:integrationType rdf:type rdf:Property ;
    rdfs:label 'Integration Type' ;
    rdfs:comment 'Technical style of the integration (e.g., REST API, SOAP web service, ISO 8583 message, native SDK).' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:merchantIntegrationDescription rdf:type rdf:Property ;
    rdfs:label 'Merchant Integration Description' ;
    rdfs:comment 'Free-form description of the integration purpose, scope, or special notes.' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:merchantIntegrationStatus rdf:type rdf:Property ;
    rdfs:label 'Merchant Integration Status' ;
    rdfs:comment 'Operational status of the integration profile.' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oauthClientIdentifier rdf:type rdf:Property ;
    rdfs:label 'Oauth Client Identifier' ;
    rdfs:comment 'Client identifier issued to the merchant for OAuth-based authentication.' ;
    rdfs:domain ind:Gateway ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:oauthScopes rdf:type rdf:Property ;
    rdfs:label 'Oauth Scopes' ;
    rdfs:comment 'Comma-separated list of OAuth scopes granted to the merchant integration.' ;
    rdfs:domain ind:Gateway ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onboardingStatus rdf:type rdf:Property ;
    rdfs:label 'Onboarding Status' ;
    rdfs:comment 'Current status of the merchant\'s onboarding workflow for this integration.' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pciDssComplianceTier rdf:type rdf:Property ;
    rdfs:label 'Pci Dss Compliance Tier' ;
    rdfs:comment 'PCI DSS compliance tier assigned to the integration based on data handling scope.' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:protocolVersion rdf:type rdf:Property ;
    rdfs:label 'Protocol Version' ;
    rdfs:comment 'Version of the integration protocol or API specification used.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportContactEmail rdf:type rdf:Property ;
    rdfs:label 'Support Contact Email' ;
    rdfs:comment 'Email address of the merchant\'s technical support contact for this integration.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportContactPhone rdf:type rdf:Property ;
    rdfs:label 'Support Contact Phone' ;
    rdfs:comment 'Phone number of the merchant\'s technical support contact for this integration.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:webhookSecret rdf:type rdf:Property ;
    rdfs:label 'Webhook Secret' ;
    rdfs:comment 'Shared secret used to sign webhook payloads for integrity verification.' ;
    rdfs:domain ind:MerchantIntegration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:merchantSdkAdoptionId rdf:type rdf:Property ;
    rdfs:label 'Merchant Sdk Adoption Id' ;
    rdfs:comment 'Unique identifier for each SDK adoption record linking a merchant integration to a specific SDK version.' ;
    rdfs:domain ind:MerchantSdkAdoption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:sdkVersionId rdf:type rdf:Property ;
    rdfs:label 'Sdk Version Id' ;
    rdfs:comment 'Identifier of the SDK version being used by the merchant integration.' ;
    rdfs:domain ind:Gateway ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SdkVersion .

ind:adoptionDate rdf:type rdf:Property ;
    rdfs:label 'Adoption Date' ;
    rdfs:comment 'Date when the merchant integration first started using the SDK version.' ;
    rdfs:domain ind:Gateway ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:complianceRequired rdf:type rdf:Property ;
    rdfs:label 'Compliance Required' ;
    rdfs:comment 'True if the SDK version must meet specific regulatory or PCI DSS compliance criteria for the merchant.' ;
    rdfs:domain ind:Gateway ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:currentSdkStatus rdf:type rdf:Property ;
    rdfs:label 'Current Sdk Status' ;
    rdfs:comment 'Operational status of the SDK version as observed for the merchant integration.' ;
    rdfs:domain ind:Gateway ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:forcedUpgradeDeadline rdf:type rdf:Property ;
    rdfs:label 'Forced Upgrade Deadline' ;
    rdfs:comment 'Date by which the merchant must upgrade to a supported SDK version to remain compliant with PCI DSS or internal policies.' ;
    rdfs:domain ind:Gateway ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sdkReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Sdk Release Date' ;
    rdfs:comment 'Calendar date on which the SDK version was released to merchants.' ;
    rdfs:domain ind:Gateway ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sdkReleaseNotesUrl rdf:type rdf:Property ;
    rdfs:label 'Sdk Release Notes Url' ;
    rdfs:comment 'Web address linking to the release notes or changelog for the SDK version.' ;
    rdfs:domain ind:Gateway ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upgradeNotificationSent rdf:type rdf:Property ;
    rdfs:label 'Upgrade Notification Sent' ;
    rdfs:comment 'Indicates whether a notification to upgrade to a newer SDK version has been sent to the merchant.' ;
    rdfs:domain ind:MerchantSdkAdoption ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rateLimitBreachId rdf:type rdf:Property ;
    rdfs:label 'Rate Limit Breach Id' ;
    rdfs:comment 'System-generated unique identifier for each rate limit breach event.' ;
    rdfs:domain ind:RateLimitBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:alertSent rdf:type rdf:Property ;
    rdfs:label 'Alert Sent' ;
    rdfs:comment 'Indicates whether an operational alert was generated for the breach.' ;
    rdfs:domain ind:RateLimitBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:alertTimestamp rdf:type rdf:Property ;
    rdfs:label 'Alert Timestamp' ;
    rdfs:comment 'Timestamp when the alert for the breach was sent.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:breachDescription rdf:type rdf:Property ;
    rdfs:label 'Breach Description' ;
    rdfs:comment 'Free-form text describing the context or notes of the breach.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachDurationSeconds rdf:type rdf:Property ;
    rdfs:label 'Breach Duration Seconds' ;
    rdfs:comment 'Length of time the breach condition persisted before remediation.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:clientUserAgent rdf:type rdf:Property ;
    rdfs:label 'Client User Agent' ;
    rdfs:comment 'User-agent string of the client making the request.' ;
    rdfs:domain ind:RateLimitBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceededMetric rdf:type rdf:Property ;
    rdfs:label 'Exceeded Metric' ;
    rdfs:comment 'Metric (TPS or RPM) that exceeded the configured threshold.' ;
    rdfs:domain ind:RateLimitBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isTestEnvironment rdf:type rdf:Property ;
    rdfs:label 'Is Test Environment' ;
    rdfs:comment 'Indicates whether the request originated from a test/sandbox environment.' ;
    rdfs:domain ind:RateLimitBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:observedRpm rdf:type rdf:Property ;
    rdfs:label 'Observed Rpm' ;
    rdfs:comment 'Number of transactions per minute observed at the moment of breach.' ;
    rdfs:domain ind:RateLimitBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:observedTps rdf:type rdf:Property ;
    rdfs:label 'Observed Tps' ;
    rdfs:comment 'Number of transactions per second observed at the moment of breach.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originatingIp rdf:type rdf:Property ;
    rdfs:label 'Originating Ip' ;
    rdfs:comment 'IP address from which the request that triggered the breach originated.' ;
    rdfs:domain ind:RateLimitBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyName rdf:type rdf:Property ;
    rdfs:label 'Policy Name' ;
    rdfs:comment 'Human-readable name of the rate-limit policy applied to the source.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateLimitBreachStatus rdf:type rdf:Property ;
    rdfs:label 'Rate Limit Breach Status' ;
    rdfs:comment 'Current lifecycle status of the breach record.' ;
    rdfs:domain ind:RateLimitBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateLimitWindow rdf:type rdf:Property ;
    rdfs:label 'Rate Limit Window' ;
    rdfs:comment 'Time window granularity for the applied rate-limit policy.' ;
    rdfs:domain ind:RateLimitBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestMethod rdf:type rdf:Property ;
    rdfs:label 'Request Method' ;
    rdfs:comment 'HTTP verb used for the API call that exceeded the rate limit.' ;
    rdfs:domain ind:RateLimitBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceIdentifier rdf:type rdf:Property ;
    rdfs:label 'Source Identifier' ;
    rdfs:comment 'The actual identifier of the source that caused the breach (e.g., API key value, merchant ID, or IP address).' ;
    rdfs:domain ind:RateLimitBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceType rdf:type rdf:Property ;
    rdfs:label 'Source Type' ;
    rdfs:comment 'Category of the entity that triggered the breach (API credential, merchant identifier, or IP address).' ;
    rdfs:domain ind:RateLimitBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdRpm rdf:type rdf:Property ;
    rdfs:label 'Threshold Rpm' ;
    rdfs:comment 'Configured RPM limit for the applicable policy.' ;
    rdfs:domain ind:RateLimitBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:thresholdTps rdf:type rdf:Property ;
    rdfs:label 'Threshold Tps' ;
    rdfs:comment 'Configured TPS limit for the applicable policy.' ;
    rdfs:domain ind:RateLimitBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:burstLimit rdf:type rdf:Property ;
    rdfs:label 'Burst Limit' ;
    rdfs:comment 'Number of requests allowed in a short burst exceeding the steady-state quota.' ;
    rdfs:domain ind:RateLimitPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:consumerIdentifier rdf:type rdf:Property ;
    rdfs:label 'Consumer Identifier' ;
    rdfs:comment 'Identifier of the consumer subject to the policy (e.g., API key, MID, or IP range).' ;
    rdfs:domain ind:RateLimitPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dailyCap rdf:type rdf:Property ;
    rdfs:label 'Daily Cap' ;
    rdfs:comment 'Maximum total requests allowed in a calendar day.' ;
    rdfs:domain ind:RateLimitPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:rateLimitPolicyDescription rdf:type rdf:Property ;
    rdfs:label 'Rate Limit Policy Description' ;
    rdfs:comment 'Free-form text describing the purpose and scope of the policy.' ;
    rdfs:domain ind:RateLimitPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateLimitPolicyStatus rdf:type rdf:Property ;
    rdfs:label 'Rate Limit Policy Status' ;
    rdfs:comment 'Current lifecycle status of the policy.' ;
    rdfs:domain ind:RateLimitPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestQuotaRpm rdf:type rdf:Property ;
    rdfs:label 'Request Quota Rpm' ;
    rdfs:comment 'Maximum allowed requests per minute for the consumer.' ;
    rdfs:domain ind:RateLimitPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:requestQuotaTps rdf:type rdf:Property ;
    rdfs:label 'Request Quota Tps' ;
    rdfs:comment 'Maximum allowed requests per second for the consumer.' ;
    rdfs:domain ind:RateLimitPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:throttleResponseCode rdf:type rdf:Property ;
    rdfs:label 'Throttle Response Code' ;
    rdfs:comment 'HTTP status code returned when the consumer exceeds the quota.' ;
    rdfs:domain ind:RateLimitPolicy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierName rdf:type rdf:Property ;
    rdfs:label 'Tier Name' ;
    rdfs:comment 'Name of the service tier (e.g., Bronze, Silver, Gold) associated with the policy.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:alternativeAcquirerEndpoints rdf:type rdf:Property ;
    rdfs:label 'Alternative Acquirer Endpoints' ;
    rdfs:comment 'Comma-separated list of other eligible acquirer endpoints evaluated during routing.' ;
