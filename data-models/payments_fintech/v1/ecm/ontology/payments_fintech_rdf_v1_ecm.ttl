    rdfs:range xsd:integer .

ind:impactedPartyType rdf:type rdf:Property ;
    rdfs:label 'Impacted Party Type' ;
    rdfs:comment 'Classifies whether the breach affected a merchant, acquiring bank, partner, or other entity.' ;
    rdfs:domain ind:SlaBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCreditApplied rdf:type rdf:Property ;
    rdfs:label 'Is Credit Applied' ;
    rdfs:comment 'True if the contractual credit has been posted to the impacted party.' ;
    rdfs:domain ind:SlaBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:measuredUnit rdf:type rdf:Property ;
    rdfs:label 'Measured Unit' ;
    rdfs:comment 'Unit associated with the measured value (e.g., percent, ms).' ;
    rdfs:domain ind:SlaBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measuredValue rdf:type rdf:Property ;
    rdfs:label 'Measured Value' ;
    rdfs:comment 'Numeric value recorded for the metric while the breach was active.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:metric rdf:type rdf:Property ;
    rdfs:label 'Metric' ;
    rdfs:comment 'The specific SLA metric (e.g., availability, latency) that triggered the breach.' ;
    rdfs:domain ind:SlaBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rootCauseCategory rdf:type rdf:Property ;
    rdfs:label 'Root Cause Category' ;
    rdfs:comment 'High-level classification of why the SLA breach occurred.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaBreachDescription rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Description' ;
    rdfs:comment 'Additional narrative details about the breach, context, or observations.' ;
    rdfs:domain ind:SlaBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaBreachStatus rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Status' ;
    rdfs:comment 'Indicates whether the breach is still open, under investigation, resolved, or closed.' ;
    rdfs:domain ind:SlaBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaMeasurementId rdf:type rdf:Property ;
