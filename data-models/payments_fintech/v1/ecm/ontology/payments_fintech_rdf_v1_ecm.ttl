    rdfs:comment 'Unique surrogate key for each TPS metric record.' ;
    rdfs:domain ind:TpsMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:averageTps rdf:type rdf:Property ;
    rdfs:label 'Average Tps' ;
    rdfs:comment 'Average transactions per second across the measurement window.' ;
    rdfs:domain ind:TpsMetric ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:metricStatus rdf:type rdf:Property ;
    rdfs:label 'Metric Status' ;
    rdfs:comment 'Current status of the metric record indicating if the value is validated, estimated, or invalid.' ;
