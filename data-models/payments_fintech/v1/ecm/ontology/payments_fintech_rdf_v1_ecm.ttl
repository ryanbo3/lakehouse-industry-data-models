    rdfs:comment 'Identifier of the internal user responsible for the requirement.' ;
    rdfs:domain ind:RegulatoryReportingReq ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:applicableCurrencies rdf:type rdf:Property ;
    rdfs:label 'Applicable Currencies' ;
    rdfs:comment 'Comma-separated list of ISO 4217 currency codes to which the requirement applies. [ENUM-REF-CANDIDATE: USD|EUR|GBP|JPY|CHF|Other — promote to reference product]' ;
    rdfs:domain ind:RegulatoryReportingReq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicablePaymentTypes rdf:type rdf:Property ;
    rdfs:label 'Applicable Payment Types' ;
    rdfs:comment 'Comma-separated list of payment methods (e.g., ACH, SWIFT, Card) that fall under this requirement. [ENUM-REF-CANDIDATE: ACH|SWIFT|Card|Crypto|Other — promote to reference product]' ;
    rdfs:domain ind:RegulatoryReportingReq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeReason rdf:type rdf:Property ;
    rdfs:label 'Change Reason' ;
    rdfs:comment 'Reason for the most recent change to the requirement configuration.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceCheckRequired rdf:type rdf:Property ;
    rdfs:label 'Compliance Check Required' ;
    rdfs:comment 'Indicates whether each transaction must be validated against this requirement before processing.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contactPointEmail rdf:type rdf:Property ;
