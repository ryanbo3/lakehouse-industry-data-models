    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceIpAddress rdf:type rdf:Property ;
    rdfs:label 'Source Ip Address' ;
    rdfs:comment 'IP address of the client device that initiated the authentication.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventLogId rdf:type rdf:Property ;
    rdfs:label 'Event Log Id' ;
    rdfs:comment 'Unique immutable identifier for each gateway event log record.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EventLog .

ind:afterState rdf:type rdf:Property ;
    rdfs:label 'After State' ;
    rdfs:comment 'JSON-encoded snapshot of the entity\'s state after the event.' ;
