    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:discretionaryData rdf:type rdf:Property ;
    rdfs:label 'Discretionary Data' ;
    rdfs:comment 'Optional data field for originator-specific information.' ;
    rdfs:domain ind:AchEntry ;
