    rdfs:range xsd:string .

ind:renewalStatus rdf:type rdf:Property ;
    rdfs:label 'Renewal Status' ;
    rdfs:comment 'Lifecycle status of the renewal operation.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalSuppressionFlag rdf:type rdf:Property ;
    rdfs:label 'Renewal Suppression Flag' ;
    rdfs:comment 'True when renewal should be skipped (e.g., instrument is blocked).' ;
    rdfs:domain ind:InstrumentExpirySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalWindowEndDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Window End Date' ;
    rdfs:comment 'Latest date by which renewal must be completed.' ;
    rdfs:domain ind:InstrumentExpirySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:renewalWindowStartDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Window Start Date' ;
    rdfs:comment 'Earliest date on which renewal actions may be initiated.' ;
    rdfs:domain ind:InstrumentExpirySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:instrumentFeatureId rdf:type rdf:Property ;
    rdfs:label 'Instrument Feature Id' ;
    rdfs:comment 'Unique surrogate key for the instrument feature record.' ;
    rdfs:domain ind:InstrumentFeature ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceFlags rdf:type rdf:Property ;
    rdfs:label 'Compliance Flags' ;
