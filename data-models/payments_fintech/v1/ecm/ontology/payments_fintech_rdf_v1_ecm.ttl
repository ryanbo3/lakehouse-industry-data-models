ind:totalMatchedAmount rdf:type rdf:Property ;
    rdfs:label 'Total Matched Amount' ;
    rdfs:comment 'Aggregate monetary value of all matched transactions, expressed in settlement currency.' ;
    rdfs:domain ind:TransactionReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Total Tax Amount' ;
    rdfs:comment 'Total tax component captured in the transaction batch, if applicable.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalVarianceAmount rdf:type rdf:Property ;
    rdfs:label 'Total Variance Amount' ;
    rdfs:comment 'Sum of monetary differences between internal and scheme amounts for unmatched or partially matched transactions.' ;
    rdfs:domain ind:TransactionReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:unmatchedTransactionCount rdf:type rdf:Property ;
    rdfs:label 'Unmatched Transaction Count' ;
    rdfs:comment 'Number of transactions that did not find a counterpart in the scheme file.' ;
    rdfs:domain ind:TransactionReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transactionResponseCodeId rdf:type rdf:Property ;
    rdfs:label 'Transaction Response Code Id' ;
    rdfs:comment 'Unique surrogate identifier for each response code record.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TransactionResponseCode .

ind:declineReasonClassification rdf:type rdf:Property ;
    rdfs:label 'Decline Reason Classification' ;
    rdfs:comment 'Specific reason why a transaction was declined, aligned with internal analytics taxonomy.' ;
    rdfs:domain ind:TransactionResponseCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:numeric rdf:type rdf:Property ;
    rdfs:label 'Numeric' ;
    rdfs:comment 'Integer version of the response code for systems that store numeric values.' ;
    rdfs:domain ind:TransactionResponseCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transactionResponseCodeCategory rdf:type rdf:Property ;
    rdfs:label 'Transaction Response Code Category' ;
    rdfs:comment 'High-level grouping of the response outcome.' ;
    rdfs:domain ind:TransactionResponseCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionResponseCodeDescription rdf:type rdf:Property ;
    rdfs:label 'Transaction Response Code Description' ;
    rdfs:comment 'Full textual description of what the response code means (e.g., "Approved", "Do Not Honor").' ;
    rdfs:domain ind:TransactionResponseCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionResponseCodeStatus rdf:type rdf:Property ;
    rdfs:label 'Transaction Response Code Status' ;
    rdfs:comment 'Indicates whether the response code is currently in use.' ;
    rdfs:domain ind:TransactionResponseCode ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:txnChannelId rdf:type rdf:Property ;
    rdfs:label 'Txn Channel Id' ;
    rdfs:comment 'Unique surrogate identifier for each payment acceptance channel.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TxnChannel .

ind:authentication3ds rdf:type rdf:Property ;
    rdfs:label 'Authentication 3ds' ;
    rdfs:comment 'True if the channel supports 3-D Secure (3DS) for online card-not-present transactions.' ;
    rdfs:domain ind:TxnChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:authenticationBiometric rdf:type rdf:Property ;
    rdfs:label 'Authentication Biometric' ;
    rdfs:comment 'True if the channel supports biometric methods such as fingerprint or facial recognition.' ;
    rdfs:domain ind:TxnChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:authenticationPin rdf:type rdf:Property ;
    rdfs:label 'Authentication Pin' ;
    rdfs:comment 'True if the channel requires a Personal Identification Number (PIN) for authentication.' ;
    rdfs:domain ind:TxnChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:authenticationSignature rdf:type rdf:Property ;
    rdfs:label 'Authentication Signature' ;
    rdfs:comment 'True if the channel requires a handwritten signature for transaction approval.' ;
    rdfs:domain ind:TxnChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cardPresent rdf:type rdf:Property ;
    rdfs:label 'Card Present' ;
    rdfs:comment 'True if the channel supports card-present transactions (physical card read).' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:channelCategory rdf:type rdf:Property ;
    rdfs:label 'Channel Category' ;
    rdfs:comment 'Broad classification of the channel based on its delivery mode.' ;
    rdfs:domain ind:TxnChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:entryModeChip rdf:type rdf:Property ;
    rdfs:label 'Entry Mode Chip' ;
    rdfs:comment 'True if the channel can accept chip-based card data.' ;
    rdfs:domain ind:TxnChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:entryModeContactless rdf:type rdf:Property ;
    rdfs:label 'Entry Mode Contactless' ;
    rdfs:comment 'True if the channel supports contactless NFC transactions.' ;
    rdfs:domain ind:TxnChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:entryModeManual rdf:type rdf:Property ;
    rdfs:label 'Entry Mode Manual' ;
    rdfs:comment 'True if the channel allows manual entry of card details (e.g., key-in).' ;
    rdfs:domain ind:TxnChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:entryModeSwipe rdf:type rdf:Property ;
    rdfs:label 'Entry Mode Swipe' ;
    rdfs:comment 'True if the channel can accept magnetic-stripe swipe data.' ;
    rdfs:domain ind:TxnChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scaRequired rdf:type rdf:Property ;
    rdfs:label 'Sca Required' ;
    rdfs:comment 'True if Strong Customer Authentication is mandatory for this channel under PSD2.' ;
    rdfs:domain ind:TxnChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:txnChannelDescription rdf:type rdf:Property ;
    rdfs:label 'Txn Channel Description' ;
    rdfs:comment 'Detailed description of the payment acceptance channel, its typical use cases and any special handling.' ;
    rdfs:domain ind:TxnChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:txnChannelStatus rdf:type rdf:Property ;
    rdfs:label 'Txn Channel Status' ;
    rdfs:comment 'Current lifecycle status of the channel.' ;
    rdfs:domain ind:TxnChannel ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:txnFeeId rdf:type rdf:Property ;
    rdfs:label 'Txn Fee Id' ;
    rdfs:comment 'Unique identifier for the fee record associated with a payment transaction.' ;
    rdfs:domain ind:TxnFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:feeAmountUsd rdf:type rdf:Property ;
    rdfs:label 'Fee Amount Usd' ;
    rdfs:comment 'Fee amount converted to US Dollars for standardized reporting.' ;
    rdfs:domain ind:TxnFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feeApprovalStatus rdf:type rdf:Property ;
    rdfs:label 'Fee Approval Status' ;
    rdfs:comment 'Approval state of the fee after compliance review.' ;
    rdfs:domain ind:TxnFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeApprovalTimestamp rdf:type rdf:Property ;
    rdfs:label 'Fee Approval Timestamp' ;
    rdfs:comment 'Timestamp when the fee was approved or rejected.' ;
    rdfs:domain ind:TxnFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:feeAuditTrail rdf:type rdf:Property ;
    rdfs:label 'Fee Audit Trail' ;
    rdfs:comment 'JSON-encoded audit log capturing changes to the fee record.' ;
    rdfs:domain ind:TxnFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeCalculationBasis rdf:type rdf:Property ;
    rdfs:label 'Fee Calculation Basis' ;
    rdfs:comment 'Method used to calculate the fee.' ;
    rdfs:domain ind:TxnFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Fee Created Timestamp' ;
    rdfs:comment 'Timestamp when the fee record was created.' ;
    rdfs:domain ind:TxnFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:feeEffectiveDate rdf:type rdf:Property ;
    rdfs:label 'Fee Effective Date' ;
    rdfs:comment 'Date when the fee becomes effective.' ;
    rdfs:domain ind:TxnFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:feeExchangeRate rdf:type rdf:Property ;
    rdfs:label 'Fee Exchange Rate' ;
    rdfs:comment 'Exchange rate used to convert the fee amount to the reporting currency.' ;
    rdfs:domain ind:TxnFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feeExpirationDate rdf:type rdf:Property ;
    rdfs:label 'Fee Expiration Date' ;
    rdfs:comment 'Date when the fee ceases to be applicable (null if indefinite).' ;
    rdfs:domain ind:TxnFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:feeFlatAmount rdf:type rdf:Property ;
    rdfs:label 'Fee Flat Amount' ;
    rdfs:comment 'Fixed amount applied when the calculation basis is flat.' ;
    rdfs:domain ind:TxnFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feeJurisdictionCode rdf:type rdf:Property ;
    rdfs:label 'Fee Jurisdiction Code' ;
    rdfs:comment 'Three-letter ISO country code indicating the jurisdiction governing the fee.' ;
    rdfs:domain ind:TxnFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeRegulatoryReportingCode rdf:type rdf:Property ;
    rdfs:label 'Fee Regulatory Reporting Code' ;
    rdfs:comment 'Code used for regulatory reporting of the fee (e.g., PCI, PSD2).' ;
    rdfs:domain ind:TxnFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeResponsibleParty rdf:type rdf:Property ;
    rdfs:label 'Fee Responsible Party' ;
    rdfs:comment 'Entity responsible for paying the fee.' ;
    rdfs:domain ind:TxnFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeReversalFlag rdf:type rdf:Property ;
    rdfs:label 'Fee Reversal Flag' ;
    rdfs:comment 'Indicates whether this fee record represents a reversal.' ;
    rdfs:domain ind:TxnFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:feeRuleVersion rdf:type rdf:Property ;
    rdfs:label 'Fee Rule Version' ;
    rdfs:comment 'Version of the fee calculation rule applied.' ;
    rdfs:domain ind:TxnFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeSequence rdf:type rdf:Property ;
    rdfs:label 'Fee Sequence' ;
    rdfs:comment 'Sequential order of the fee line within the transaction fee set.' ;
    rdfs:domain ind:TxnFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:feeSettlementDate rdf:type rdf:Property ;
    rdfs:label 'Fee Settlement Date' ;
    rdfs:comment 'Date on which the fee was settled.' ;
    rdfs:domain ind:TxnFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:feeSettlementStatus rdf:type rdf:Property ;
    rdfs:label 'Fee Settlement Status' ;
    rdfs:comment 'Settlement state of the fee with respect to the financial ledger.' ;
    rdfs:domain ind:TxnFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Fee Source System' ;
    rdfs:comment 'System of record that originated the fee (e.g., gateway, settlement platform).' ;
    rdfs:domain ind:TxnFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeTaxAmount rdf:type rdf:Property ;
    rdfs:label 'Fee Tax Amount' ;
    rdfs:comment 'Tax amount applied to the fee, if taxable.' ;
    rdfs:domain ind:TxnFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feeTierDescription rdf:type rdf:Property ;
    rdfs:label 'Fee Tier Description' ;
    rdfs:comment 'Textual description of the tier applied for tiered fee calculations.' ;
    rdfs:domain ind:TxnFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeUpdatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Fee Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent update to the fee record.' ;
    rdfs:domain ind:TxnFee ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:txnLifecycleEventId rdf:type rdf:Property ;
    rdfs:label 'Txn Lifecycle Event Id' ;
    rdfs:comment 'Unique surrogate key for each immutable transaction lifecycle event record.' ;
    rdfs:domain ind:TxnLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:triggeringEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Triggering Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Operational audit: manual overrides or adjustments in transaction lifecycle must capture the responsible employee.' ;
    rdfs:domain ind:TxnLifecycleEvent ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:eventSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Event Source System' ;
    rdfs:comment 'Originating system that generated the event record.' ;
    rdfs:domain ind:TxnLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isoMessageTypeCode rdf:type rdf:Property ;
    rdfs:label 'Iso Message Type Code' ;
    rdfs:comment 'ISO 8583 or ISO 20022 message type identifier associated with the event (e.g., 0100, 0200, 0300).' ;
    rdfs:domain ind:TxnLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:priorState rdf:type rdf:Property ;
    rdfs:label 'Prior State' ;
    rdfs:comment 'State of the transaction before this event occurred. [ENUM-REF-CANDIDATE: authorized|captured|cleared|settled|reversed|voided|refunded|chargeback|disputed|pending — promote to reference product]' ;
    rdfs:domain ind:TxnLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundFlag rdf:type rdf:Property ;
    rdfs:label 'Refund Flag' ;
    rdfs:comment 'True if the event represents a refund.' ;
    rdfs:domain ind:TxnLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:voidFlag rdf:type rdf:Property ;
    rdfs:label 'Void Flag' ;
    rdfs:comment 'True if the transaction was voided before capture.' ;
    rdfs:domain ind:TxnLifecycleEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:txnLimitRuleId rdf:type rdf:Property ;
    rdfs:label 'Txn Limit Rule Id' ;
    rdfs:comment 'System-generated unique identifier for the transaction limit rule.' ;
    rdfs:domain ind:TxnLimitRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:txnTypeId rdf:type rdf:Property ;
    rdfs:label 'Txn Type Id' ;
    rdfs:comment 'Foreign key linking to transaction.txn_type. Business justification: Limit rules apply to specific transaction types; linking provides rule lookup based on type.' ;
    rdfs:domain ind:Transaction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TxnType .

ind:contactlessLimit rdf:type rdf:Property ;
    rdfs:label 'Contactless Limit' ;
    rdfs:comment 'Maximum amount allowed for contactless (tap-and-go) transactions under this rule.' ;
    rdfs:domain ind:TxnLimitRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:crossBorderLimit rdf:type rdf:Property ;
    rdfs:label 'Cross Border Limit' ;
    rdfs:comment 'Maximum amount permitted for cross-border transactions governed by this rule.' ;
    rdfs:domain ind:TxnLimitRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:instrumentType rdf:type rdf:Property ;
    rdfs:label 'Instrument Type' ;
    rdfs:comment 'Type of payment instrument to which the rule applies.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxAmountPerTransaction rdf:type rdf:Property ;
    rdfs:label 'Max Amount Per Transaction' ;
    rdfs:comment 'Upper bound on the monetary value of an individual transaction.' ;
    rdfs:domain ind:TxnLimitRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:maxTransactionsPerDay rdf:type rdf:Property ;
    rdfs:label 'Max Transactions Per Day' ;
    rdfs:comment 'Velocity limit specifying the maximum number of transactions allowed in a calendar day.' ;
    rdfs:domain ind:TxnLimitRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:maxTransactionsPerHour rdf:type rdf:Property ;
    rdfs:label 'Max Transactions Per Hour' ;
    rdfs:comment 'Velocity limit specifying the maximum number of transactions allowed in any rolling hour.' ;
    rdfs:domain ind:TxnLimitRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:regulatoryBasis rdf:type rdf:Property ;
    rdfs:label 'Regulatory Basis' ;
    rdfs:comment 'Reference to the regulatory requirement (e.g., PSD2, PCI DSS) that drives the rule.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskBasis rdf:type rdf:Property ;
    rdfs:label 'Risk Basis' ;
    rdfs:comment 'Explanation of the risk model or fraud scenario that justifies the rule.' ;
    rdfs:domain ind:TxnLimitRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tapLimit rdf:type rdf:Property ;
    rdfs:label 'Tap Limit' ;
    rdfs:comment 'Maximum amount for NFC tap transactions (often lower than standard contactless limit).' ;
    rdfs:domain ind:TxnLimitRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:txnLimitRuleDescription rdf:type rdf:Property ;
    rdfs:label 'Txn Limit Rule Description' ;
    rdfs:comment 'Free-form description of the business purpose and logic of the rule.' ;
    rdfs:domain ind:TxnLimitRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:txnLimitRuleStatus rdf:type rdf:Property ;
    rdfs:label 'Txn Limit Rule Status' ;
    rdfs:comment 'Current lifecycle status of the rule.' ;
    rdfs:domain ind:TxnLimitRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:txnRoutingDecisionId rdf:type rdf:Property ;
    rdfs:label 'Txn Routing Decision Id' ;
    rdfs:comment 'System-generated unique identifier for each routing decision record.' ;
    rdfs:domain ind:TxnRoutingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:tokenId rdf:type rdf:Property ;
    rdfs:label 'Token Id' ;
    rdfs:comment 'Identifier of the token used in place of the PAN.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Token .

ind:candidateNetworks rdf:type rdf:Property ;
    rdfs:label 'Candidate Networks' ;
    rdfs:comment 'Comma-separated list of networks evaluated during routing decision.' ;
    rdfs:domain ind:TxnRoutingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decisionReference rdf:type rdf:Property ;
    rdfs:label 'Decision Reference' ;
    rdfs:comment 'Human-readable reference code for the routing decision (e.g., RD-20231101-0001).' ;
    rdfs:domain ind:TxnRoutingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durbinComplianceApplied rdf:type rdf:Property ;
    rdfs:label 'Durbin Compliance Applied' ;
    rdfs:comment 'Flag indicating whether Durbin Amendment routing rules were enforced.' ;
    rdfs:domain ind:TxnRoutingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lcrApplied rdf:type rdf:Property ;
    rdfs:label 'Lcr Applied' ;
    rdfs:comment 'Flag indicating whether least-cost routing logic was applied.' ;
    rdfs:domain ind:TxnRoutingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:routingPath rdf:type rdf:Property ;
    rdfs:label 'Routing Path' ;
    rdfs:comment 'Serialized representation of the processing path taken (e.g., gateway → network → acquirer).' ;
    rdfs:domain ind:TxnRoutingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingReason rdf:type rdf:Property ;
    rdfs:label 'Routing Reason' ;
    rdfs:comment 'Business reason why the selected network was chosen.' ;
    rdfs:domain ind:TxnRoutingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingRuleVersion rdf:type rdf:Property ;
    rdfs:label 'Routing Rule Version' ;
    rdfs:comment 'Version identifier of the routing rule set applied to this transaction.' ;
    rdfs:domain ind:TxnRoutingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:selectedNetwork rdf:type rdf:Property ;
    rdfs:label 'Selected Network' ;
    rdfs:comment 'Payment network that was selected to process the transaction.' ;
    rdfs:domain ind:TxnRoutingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionFee rdf:type rdf:Property ;
    rdfs:label 'Transaction Fee' ;
    rdfs:comment 'Total fees applied to the transaction (e.g., interchange, network, processing).' ;
    rdfs:domain ind:TxnRoutingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:txnRoutingDecisionStatus rdf:type rdf:Property ;
    rdfs:label 'Txn Routing Decision Status' ;
    rdfs:comment 'Current processing status of the routing decision record.' ;
    rdfs:domain ind:TxnRoutingDecision ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isoProcessingCode rdf:type rdf:Property ;
    rdfs:label 'Iso Processing Code' ;
    rdfs:comment 'Standardized processing code defined by ISO 8583 / ISO 20022 that identifies the transaction function.' ;
    rdfs:domain ind:TxnType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkRuleSet rdf:type rdf:Property ;
    rdfs:label 'Network Rule Set' ;
    rdfs:comment 'Identifier of the rule set that governs routing, fees, and interchange for the transaction type.' ;
    rdfs:domain ind:TxnType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingFeeFixed rdf:type rdf:Property ;
    rdfs:label 'Processing Fee Fixed' ;
    rdfs:comment 'Flat fee amount applied to each transaction of this type.' ;
    rdfs:domain ind:TxnType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:requiresAmlCheck rdf:type rdf:Property ;
    rdfs:label 'Requires Aml Check' ;
    rdfs:comment 'True when anti-money-laundering screening must be performed for this transaction type.' ;
    rdfs:domain ind:TxnType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:riskScoreCategory rdf:type rdf:Property ;
    rdfs:label 'Risk Score Category' ;
    rdfs:comment 'Categorization used by risk models to apply appropriate scoring thresholds.' ;
    rdfs:domain ind:TxnType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementEligibilityFlag rdf:type rdf:Property ;
    rdfs:label 'Settlement Eligibility Flag' ;
    rdfs:comment 'True when transactions of this type can be settled to a financial institution.' ;
    rdfs:domain ind:TxnType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:txnTypeDescription rdf:type rdf:Property ;
    rdfs:label 'Txn Type Description' ;
    rdfs:comment 'Detailed business description of the transaction type, including typical use-cases.' ;
    rdfs:domain ind:TxnType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:txnTypeStatus rdf:type rdf:Property ;
    rdfs:label 'Txn Type Status' ;
    rdfs:comment 'Operational state indicating whether the type is in active use, retired, or awaiting approval.' ;
    rdfs:domain ind:TxnType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:achAccountId rdf:type rdf:Property ;
    rdfs:label 'Ach Account Id' ;
    rdfs:comment 'System-generated unique identifier for the ACH account record.' ;
