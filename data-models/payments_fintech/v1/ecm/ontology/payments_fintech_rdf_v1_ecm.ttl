    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:addendaRecordCount rdf:type rdf:Property ;
    rdfs:label 'Addenda Record Count' ;
    rdfs:comment 'Number of addenda records attached to this ACH entry.' ;
    rdfs:domain ind:AchEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceFlagFraud rdf:type rdf:Property ;
    rdfs:label 'Compliance Flag Fraud' ;
    rdfs:comment 'Indicates whether the entry passed fraud screening.' ;
