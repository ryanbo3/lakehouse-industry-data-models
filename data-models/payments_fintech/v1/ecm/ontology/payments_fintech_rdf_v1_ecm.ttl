    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:taxRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Tax Rate Percentage' ;
    rdfs:comment 'Applicable tax rate when fee_taxable_flag is true.' ;
    rdfs:domain ind:MerchantFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tierEndAmount rdf:type rdf:Property ;
    rdfs:label 'Tier End Amount' ;
    rdfs:comment 'Upper bound of transaction amount for a tiered fee range (exclusive).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tierRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Tier Rate Percentage' ;
    rdfs:comment 'Percentage applied within the defined tier range.' ;
    rdfs:domain ind:MerchantFeeSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tierStartAmount rdf:type rdf:Property ;
    rdfs:label 'Tier Start Amount' ;
    rdfs:comment 'Lower bound of transaction amount for a tiered fee range (inclusive).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:merchantHierarchyId rdf:type rdf:Property ;
    rdfs:label 'Merchant Hierarchy Id' ;
    rdfs:comment 'Unique system-generated identifier for each merchant hierarchy relationship record.' ;
    rdfs:domain ind:MerchantHierarchy ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:childMerchantId rdf:type rdf:Property ;
    rdfs:label 'Child Merchant Id' ;
    rdfs:comment 'Unique identifier of the merchant that is the subordinate entity in the hierarchy.' ;
    rdfs:domain ind:MerchantHierarchy ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Merchant .

ind:parentMerchantId rdf:type rdf:Property ;
    rdfs:label 'Parent Merchant Id' ;
    rdfs:comment 'Unique identifier of the merchant that acts as the parent in the relationship (e.g., PayFac, ISO, corporate parent).' ;
    rdfs:domain ind:MerchantHierarchy ;
    rdf:type owl:ObjectProperty ;
