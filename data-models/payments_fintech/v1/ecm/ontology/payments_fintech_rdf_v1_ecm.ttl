ind:attendedIndicator rdf:type rdf:Property ;
    rdfs:label 'Attended Indicator' ;
    rdfs:comment 'Specifies if the terminal is operated by a merchant employee (attended) or used by the consumer alone (unattended).' ;
    rdfs:domain ind:AcceptanceType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardPresence rdf:type rdf:Property ;
