ind:policyCode rdf:type rdf:Property ;
    rdfs:label 'Policy Code' ;
    rdfs:comment 'External business code or number used to reference the policy in contracts and communications.' ;
    rdfs:domain ind:Risk ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyDescription rdf:type rdf:Property ;
    rdfs:label 'Policy Description' ;
    rdfs:comment 'Detailed description of the policy purpose, scope and applicable merchant segments.' ;
