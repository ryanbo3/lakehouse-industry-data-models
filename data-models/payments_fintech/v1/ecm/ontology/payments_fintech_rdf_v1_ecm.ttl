    rdfs:range xsd:string .

ind:instrumentBlockStatus rdf:type rdf:Property ;
    rdfs:label 'Instrument Block Status' ;
    rdfs:comment 'Operational status of the block record.' ;
    rdfs:domain ind:InstrumentBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCardholderRequested rdf:type rdf:Property ;
    rdfs:label 'Is Cardholder Requested' ;
    rdfs:comment 'True if the block was requested directly by the cardholder (e.g., travel block).' ;
    rdfs:domain ind:InstrumentBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isComplianceTriggered rdf:type rdf:Property ;
    rdfs:label 'Is Compliance Triggered' ;
    rdfs:comment 'True if the block was generated to satisfy regulatory or AML requirements.' ;
    rdfs:domain ind:InstrumentBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFraudTriggered rdf:type rdf:Property ;
    rdfs:label 'Is Fraud Triggered' ;
    rdfs:comment 'True if the block was generated by the fraud detection engine.' ;
    rdfs:domain ind:InstrumentBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isIssuerRequested rdf:type rdf:Property ;
    rdfs:label 'Is Issuer Requested' ;
    rdfs:comment 'True if the issuing bank placed the block.' ;
    rdfs:domain ind:InstrumentBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTemporary rdf:type rdf:Property ;
    rdfs:label 'Is Temporary' ;
    rdfs:comment 'True if the block is intended to be temporary (has an end timestamp).' ;
    rdfs:domain ind:InstrumentBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:regulatoryHold rdf:type rdf:Property ;
    rdfs:label 'Regulatory Hold' ;
    rdfs:comment 'True if the block is due to a regulatory or sanctions requirement.' ;
    rdfs:domain ind:InstrumentBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:instrumentExpiryScheduleId rdf:type rdf:Property ;
    rdfs:label 'Instrument Expiry Schedule Id' ;
    rdfs:comment 'Unique surrogate identifier for each expiry schedule entry.' ;
    rdfs:domain ind:InstrumentExpirySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:instrumentExpiryScheduleStatus rdf:type rdf:Property ;
    rdfs:label 'Instrument Expiry Schedule Status' ;
    rdfs:comment 'Operational status of the expiry schedule entry.' ;
    rdfs:domain ind:InstrumentExpirySchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastRenewalAttemptTimestamp rdf:type rdf:Property ;
