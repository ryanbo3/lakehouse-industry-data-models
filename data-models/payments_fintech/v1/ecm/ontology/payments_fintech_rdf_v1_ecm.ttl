    rdfs:range xsd:string .

ind:issuanceNumber rdf:type rdf:Property ;
    rdfs:label 'Issuance Number' ;
    rdfs:comment 'Business-visible sequential number assigned to each issuance for tracking and reconciliation.' ;
    rdfs:domain ind:InstrumentIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuanceStatusDetail rdf:type rdf:Property ;
    rdfs:label 'Issuance Status Detail' ;
    rdfs:comment 'Free-form text providing additional context about the current status (e.g., reason for rejection).' ;
    rdfs:domain ind:InstrumentIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuanceTimestamp rdf:type rdf:Property ;
    rdfs:label 'Issuance Timestamp' ;
    rdfs:comment 'Exact moment the issuance event occurred in the real world.' ;
    rdfs:domain ind:InstrumentIssuance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:netCurrency rdf:type rdf:Property ;
    rdfs:label 'Net Currency' ;
    rdfs:comment 'Currency of the net amount.' ;
