    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCategory rdf:type rdf:Property ;
    rdfs:label 'Rate Category' ;
    rdfs:comment 'Business classification of the rate based on market segment.' ;
    rdfs:domain ind:FxRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratePair rdf:type rdf:Property ;
    rdfs:label 'Rate Pair' ;
    rdfs:comment 'Human-readable identifier of the currency pair, e.g., "USD_EUR".' ;
    rdfs:domain ind:FxRate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicableCountryCodes rdf:type rdf:Property ;
    rdfs:label 'Applicable Country Codes' ;
    rdfs:comment 'Comma-separated list of ISO-3166-1 alpha-3 country codes where the cycle is valid.' ;
    rdfs:domain ind:SettlementCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cutoffTime rdf:type rdf:Property ;
    rdfs:label 'Cutoff Time' ;
    rdfs:comment 'Local time of day when the cut-off for the settlement batch occurs.' ;
    rdfs:domain ind:SettlementCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cutoffTimezone rdf:type rdf:Property ;
    rdfs:label 'Cutoff Timezone' ;
    rdfs:comment 'IANA timezone identifier for the cut-off time (e.g., "America/New_York").' ;
    rdfs:domain ind:SettlementCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleCode rdf:type rdf:Property ;
    rdfs:label 'Cycle Code' ;
    rdfs:comment 'Short alphanumeric code that uniquely identifies the settlement cycle within the reference domain.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cycleName rdf:type rdf:Property ;
    rdfs:label 'Cycle Name' ;
    rdfs:comment 'Human-readable name describing the settlement cycle (e.g., "T+1 US Card Settlement").' ;
    rdfs:domain ind:SettlementCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fundingLagDays rdf:type rdf:Property ;
    rdfs:label 'Funding Lag Days' ;
    rdfs:comment 'Number of days between settlement execution and merchant funding.' ;
    rdfs:domain ind:SettlementCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isDefaultCycle rdf:type rdf:Property ;
    rdfs:label 'Is Default Cycle' ;
    rdfs:comment 'Indicates whether this cycle is the default for its payment rail and card scheme.' ;
    rdfs:domain ind:SettlementCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:processingFeePercent rdf:type rdf:Property ;
    rdfs:label 'Processing Fee Percent' ;
    rdfs:comment 'Standard processing fee expressed as a percentage of the settled amount for this cycle.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementCycleDescription rdf:type rdf:Property ;
    rdfs:label 'Settlement Cycle Description' ;
    rdfs:comment 'Free-form description providing additional context or business rules.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementCycleStatus rdf:type rdf:Property ;
    rdfs:label 'Settlement Cycle Status' ;
    rdfs:comment 'Current lifecycle status of the settlement cycle configuration.' ;
    rdfs:domain ind:SettlementCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementWindowEnd rdf:type rdf:Property ;
    rdfs:label 'Settlement Window End' ;
    rdfs:comment 'End time (HH:mm) of the daily settlement processing window.' ;
    rdfs:domain ind:SettlementCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementWindowStart rdf:type rdf:Property ;
    rdfs:label 'Settlement Window Start' ;
    rdfs:comment 'Start time (HH:mm) of the daily settlement processing window.' ;
    rdfs:domain ind:SettlementCycle ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionParentRegulatoryJurisdictionId rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Parent Regulatory Jurisdiction Id' ;
    rdfs:comment 'Identifier of the parent jurisdiction in hierarchical structures (e.g., EU as parent of member states).' ;
    rdfs:domain ind:RegulatoryJurisdiction ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RegulatoryJurisdiction .

ind:complianceContactEmail rdf:type rdf:Property ;
    rdfs:label 'Compliance Contact Email' ;
    rdfs:comment 'Email address of the compliance officer responsible for this jurisdiction.' ;
    rdfs:domain ind:RegulatoryJurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:countryIsoCode rdf:type rdf:Property ;
    rdfs:label 'Country Iso Code' ;
    rdfs:comment 'Three-letter ISO country code associated with the jurisdiction, if applicable.' ;
    rdfs:domain ind:RegulatoryJurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossBorderDataTransfer rdf:type rdf:Property ;
    rdfs:label 'Cross Border Data Transfer' ;
    rdfs:comment 'Policy governing cross-border data transfers from this jurisdiction.' ;
    rdfs:domain ind:RegulatoryJurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataResidencyRequirement rdf:type rdf:Property ;
    rdfs:label 'Data Residency Requirement' ;
    rdfs:comment 'Requirement for where data must be stored for entities operating in the jurisdiction.' ;
    rdfs:domain ind:RegulatoryJurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:financialLaw rdf:type rdf:Property ;
    rdfs:label 'Financial Law' ;
    rdfs:comment 'Key financial regulatory statutes relevant to the jurisdiction.' ;
    rdfs:domain ind:RegulatoryJurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAntiMoneyLaunderingRequired rdf:type rdf:Property ;
    rdfs:label 'Is Anti Money Laundering Required' ;
    rdfs:comment 'Indicates whether AML controls are mandatory in the jurisdiction.' ;
    rdfs:domain ind:RegulatoryJurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isCcpaApplicable rdf:type rdf:Property ;
    rdfs:label 'Is Ccpa Applicable' ;
    rdfs:comment 'True if the California Consumer Privacy Act applies to the jurisdiction.' ;
    rdfs:domain ind:RegulatoryJurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDataProtectionOfficerRequired rdf:type rdf:Property ;
    rdfs:label 'Is Data Protection Officer Required' ;
    rdfs:comment 'Indicates whether the jurisdiction mandates a Data Protection Officer under privacy law.' ;
    rdfs:domain ind:RegulatoryJurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFatfMember rdf:type rdf:Property ;
    rdfs:label 'Is Fatf Member' ;
    rdfs:comment 'Indicates whether the jurisdiction is a member of the Financial Action Task Force.' ;
    rdfs:domain ind:RegulatoryJurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFinancialReportingRequired rdf:type rdf:Property ;
    rdfs:label 'Is Financial Reporting Required' ;
    rdfs:comment 'Indicates if entities must file periodic financial reports to the regulator.' ;
    rdfs:domain ind:RegulatoryJurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isGdprApplicable rdf:type rdf:Property ;
    rdfs:label 'Is Gdpr Applicable' ;
    rdfs:comment 'True if the General Data Protection Regulation applies to the jurisdiction.' ;
    rdfs:domain ind:RegulatoryJurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPsd2Applicable rdf:type rdf:Property ;
    rdfs:label 'Is Psd2 Applicable' ;
    rdfs:comment 'True if the EU Payment Services Directive 2 applies to the jurisdiction.' ;
    rdfs:domain ind:RegulatoryJurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSarFilingRequired rdf:type rdf:Property ;
    rdfs:label 'Is Sar Filing Required' ;
    rdfs:comment 'Indicates whether Suspicious Activity Reports must be filed under local law.' ;
    rdfs:domain ind:RegulatoryJurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:jurisdictionCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Currency Code' ;
    rdfs:comment 'ISO 4217 currency code used primarily within the jurisdiction.' ;
    rdfs:domain ind:RegulatoryJurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionLanguage rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Language' ;
    rdfs:comment 'Primary language code of the jurisdiction.' ;
    rdfs:domain ind:RegulatoryJurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionName rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Name' ;
    rdfs:comment 'Full descriptive name of the jurisdiction (e.g., United Kingdom, European Union).' ;
    rdfs:domain ind:RegulatoryJurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:jurisdictionTimeZone rdf:type rdf:Property ;
    rdfs:label 'Jurisdiction Time Zone' ;
    rdfs:comment 'Primary IANA time-zone identifier for the jurisdiction.' ;
    rdfs:domain ind:RegulatoryJurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:primaryRegulator rdf:type rdf:Property ;
    rdfs:label 'Primary Regulator' ;
    rdfs:comment 'Name of the principal regulatory authority overseeing the jurisdiction (e.g., FCA, ECB).' ;
    rdfs:domain ind:RegulatoryJurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:privacyLaw rdf:type rdf:Property ;
    rdfs:label 'Privacy Law' ;
    rdfs:comment 'Primary privacy legislation applicable (e.g., GDPR, CCPA).' ;
    rdfs:domain ind:RegulatoryJurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatorType rdf:type rdf:Property ;
    rdfs:label 'Regulator Type' ;
    rdfs:comment 'Category of the regulator: supervisory agency, self-regulatory organization, or government body.' ;
    rdfs:domain ind:RegulatoryJurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryJurisdictionDescription rdf:type rdf:Property ;
    rdfs:label 'Regulatory Jurisdiction Description' ;
    rdfs:comment 'Free-form description providing additional context about the jurisdiction.' ;
    rdfs:domain ind:RegulatoryJurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryJurisdictionStatus rdf:type rdf:Property ;
    rdfs:label 'Regulatory Jurisdiction Status' ;
    rdfs:comment 'Current lifecycle status of the jurisdiction record.' ;
    rdfs:domain ind:RegulatoryJurisdiction ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bicCode rdf:type rdf:Property ;
    rdfs:label 'Bic Code' ;
