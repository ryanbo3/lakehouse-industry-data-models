    rdfs:range xsd:dateTime .

ind:lastMaintenanceTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Maintenance Timestamp' ;
    rdfs:comment 'Date and time of the most recent scheduled or unscheduled maintenance.' ;
