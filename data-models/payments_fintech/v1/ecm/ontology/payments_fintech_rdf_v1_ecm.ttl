ind:lastSeenTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Seen Timestamp' ;
    rdfs:comment 'Timestamp of the most recent observation of the device fingerprint.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:falsePositiveReviewId rdf:type rdf:Property ;
    rdfs:label 'False Positive Review Id' ;
    rdfs:comment 'Unique identifier for the false positive review record. _canonical_skip_reason: Entity does not fit standard role categories and is modeled as a custom record.' ;
    rdfs:domain ind:FalsePositiveReview ;
