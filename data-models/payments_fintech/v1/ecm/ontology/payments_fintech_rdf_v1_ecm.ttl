    rdfs:range ind:SchemeMembership .

ind:complianceObligationSummary rdf:type rdf:Property ;
    rdfs:label 'Compliance Obligation Summary' ;
    rdfs:comment 'High-level description of the key compliance obligations tied to the membership.' ;
