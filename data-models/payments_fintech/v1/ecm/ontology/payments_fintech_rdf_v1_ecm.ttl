# --- Attribute Properties ---
ind:accountHolderId rdf:type rdf:Property ;
    rdfs:label 'Account Holder Id' ;
    rdfs:comment 'Unique system-generated identifier for the account holder (golden record).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccountHolder .

ind:countryId rdf:type rdf:Property ;
    rdfs:label 'Country Id' ;
    rdfs:comment 'Foreign key linking to reference.country. Business justification: Cardholder account holder records should reference the country master for regulatory and reporting purposes. Add account_holder_country_id (FK to reference.country.country_id) and remove the duplicate' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:ecosystemPartnerId rdf:type rdf:Property ;
    rdfs:label 'Ecosystem Partner Id' ;
    rdfs:comment 'Foreign key linking to partner.ecosystem_partner. Business justification: Required for issuer settlement and regulatory reporting: each account holder must be linked to the issuing ecosystem partner that provides the account.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EcosystemPartner .

ind:accountHolderStatus rdf:type rdf:Property ;
    rdfs:label 'Account Holder Status' ;
    rdfs:comment 'Current lifecycle status of the account holder.' ;
    rdfs:domain ind:AccountHolder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountHolderType rdf:type rdf:Property ;
    rdfs:label 'Account Holder Type' ;
    rdfs:comment 'Indicates whether the holder is an individual consumer (B2C) or a corporate entity (B2B).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:avsVerified rdf:type rdf:Property ;
    rdfs:label 'Avs Verified' ;
    rdfs:comment 'Result of Address Verification System check during onboarding.' ;
    rdfs:domain ind:AccountHolder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:businessCategory rdf:type rdf:Property ;
    rdfs:label 'Business Category' ;
    rdfs:comment 'Industry classification of business account holder (e.g., retail, services).' ;
    rdfs:domain ind:AccountHolder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:city rdf:type rdf:Property ;
    rdfs:label 'City' ;
    rdfs:comment 'City of the mailing address.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:closedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Closed Timestamp' ;
    rdfs:comment 'Timestamp when the account holder was closed or deactivated, if applicable.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:corporateName rdf:type rdf:Property ;
    rdfs:label 'Corporate Name' ;
    rdfs:comment 'Legal corporate name for business account holders.' ;
    rdfs:domain ind:AccountHolder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:createdTimestamp rdf:type rdf:Property ;
    rdfs:label 'Created Timestamp' ;
    rdfs:comment 'Timestamp when the account holder record was first created in the system.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cvvLastUsedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Cvv Last Used Timestamp' ;
    rdfs:comment 'Timestamp of the most recent CVV verification event.' ;
    rdfs:domain ind:AccountHolder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:dateOfBirth rdf:type rdf:Property ;
    rdfs:label 'Date Of Birth' ;
    rdfs:comment 'Birth date of the individual account holder.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:dpan rdf:type rdf:Property ;
    rdfs:label 'Dpan' ;
    rdfs:comment 'Device Primary Account Number used for tokenized transactions.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emailAddress rdf:type rdf:Property ;
    rdfs:label 'Email Address' ;
    rdfs:comment 'Primary email address for the account holder.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:failedLoginAttempts rdf:type rdf:Property ;
    rdfs:label 'Failed Login Attempts' ;
    rdfs:comment 'Count of consecutive failed login attempts.' ;
    rdfs:domain ind:AccountHolder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:firstName rdf:type rdf:Property ;
    rdfs:label 'First Name' ;
    rdfs:comment 'Given name of the account holder.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fullName rdf:type rdf:Property ;
    rdfs:label 'Full Name' ;
    rdfs:comment 'Complete legal name of the account holder as provided during onboarding.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:incorporationDate rdf:type rdf:Property ;
    rdfs:label 'Incorporation Date' ;
    rdfs:comment 'Date when the business entity was incorporated.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:kycStatus rdf:type rdf:Property ;
    rdfs:label 'Kyc Status' ;
    rdfs:comment 'Current KYC verification status of the account holder.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:kycVerificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Kyc Verification Timestamp' ;
    rdfs:comment 'Timestamp when KYC verification was completed.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastLoginTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Login Timestamp' ;
    rdfs:comment 'Timestamp of the last successful login to the platform.' ;
    rdfs:domain ind:AccountHolder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:lastName rdf:type rdf:Property ;
    rdfs:label 'Last Name' ;
    rdfs:comment 'Family name of the account holder.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Mailing Address Line1' ;
    rdfs:comment 'First line of the mailing address.' ;
    rdfs:domain ind:AccountHolder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mailingAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Mailing Address Line2' ;
    rdfs:comment 'Second line of the mailing address.' ;
    rdfs:domain ind:AccountHolder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mccCode rdf:type rdf:Property ;
    rdfs:label 'Mcc Code' ;
    rdfs:comment 'Merchant Category Code associated with the account holder (if applicable).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:nationality rdf:type rdf:Property ;
    rdfs:label 'Nationality' ;
    rdfs:comment 'Country of citizenship or nationality of the account holder.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:onboardingChannel rdf:type rdf:Property ;
    rdfs:label 'Onboarding Channel' ;
    rdfs:comment 'Channel through which the account holder was onboarded.' ;
    rdfs:domain ind:AccountHolder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pan rdf:type rdf:Property ;
    rdfs:label 'Pan' ;
    rdfs:comment 'Primary Account Number linked to the account holder (masked for security).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:phoneNumber rdf:type rdf:Property ;
    rdfs:label 'Phone Number' ;
    rdfs:comment 'Primary contact phone number for the account holder.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:postalCode rdf:type rdf:Property ;
    rdfs:label 'Postal Code' ;
    rdfs:comment 'Postal code of the mailing address.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:preferredLanguage rdf:type rdf:Property ;
    rdfs:label 'Preferred Language' ;
    rdfs:comment 'Preferred language for communications with the account holder.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskScore rdf:type rdf:Property ;
    rdfs:label 'Risk Score' ;
    rdfs:comment 'Risk score assigned by fraud detection platform (0-100).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sanctionsScreeningStatus rdf:type rdf:Property ;
    rdfs:label 'Sanctions Screening Status' ;
    rdfs:comment 'Result of sanctions screening (e.g., OFAC).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scaCompliance rdf:type rdf:Property ;
    rdfs:label 'Sca Compliance' ;
    rdfs:comment 'Indicates if the account holder has completed Strong Customer Authentication compliance.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceOfFunds rdf:type rdf:Property ;
    rdfs:label 'Source Of Funds' ;
    rdfs:comment 'Declared source of funds for the account holder.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateProvince rdf:type rdf:Property ;
    rdfs:label 'State Province' ;
    rdfs:comment 'State or province of the mailing address.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusReason rdf:type rdf:Property ;
    rdfs:label 'Status Reason' ;
    rdfs:comment 'Reason code for the current status (e.g., fraud_suspected, compliance_hold).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:taxExempt rdf:type rdf:Property ;
    rdfs:label 'Tax Exempt' ;
    rdfs:comment 'Indicates if the account holder is tax-exempt.' ;
    rdfs:domain ind:AccountHolder ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:taxIdentifier rdf:type rdf:Property ;
    rdfs:label 'Tax Identifier' ;
    rdfs:comment 'Tax identification number (e.g., SSN, EIN, TIN) for tax reporting.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tokenizationStatus rdf:type rdf:Property ;
    rdfs:label 'Tokenization Status' ;
    rdfs:comment 'Indicates whether the PAN has been tokenized.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:updatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Updated Timestamp' ;
    rdfs:comment 'Timestamp of the most recent update to the account holder record.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:accountStatusHistoryId rdf:type rdf:Property ;
    rdfs:label 'Account Status History Id' ;
    rdfs:comment 'Unique surrogate key for each status transition record.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cardholderAccountId rdf:type rdf:Property ;
    rdfs:label 'Cardholder Account Id' ;
    rdfs:comment 'Identifier of the cardholder account whose status changed.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CardholderAccount .

ind:auditCreatedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Audit Created Timestamp' ;
    rdfs:comment 'Timestamp when this audit record was created in the system.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:correlationCode rdf:type rdf:Property ;
    rdfs:label 'Correlation Code' ;
    rdfs:comment 'Identifier to correlate this event across multiple systems.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:effectiveTimestamp rdf:type rdf:Property ;
    rdfs:label 'Effective Timestamp' ;
    rdfs:comment 'Timestamp when the new status became effective.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:eventTimestamp rdf:type rdf:Property ;
    rdfs:label 'Event Timestamp' ;
    rdfs:comment 'Date and time when the status transition event occurred.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:initiatingActor rdf:type rdf:Property ;
    rdfs:label 'Initiating Actor' ;
    rdfs:comment 'Entity that initiated the status change.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:notes rdf:type rdf:Property ;
    rdfs:label 'Notes' ;
    rdfs:comment 'Additional free-text notes about the status change.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonCode rdf:type rdf:Property ;
    rdfs:label 'Reason Code' ;
    rdfs:comment 'Standardized code indicating why the status changed.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reasonDescription rdf:type rdf:Property ;
    rdfs:label 'Reason Description' ;
    rdfs:comment 'Human readable description of the reason for status change.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reversalFlag rdf:type rdf:Property ;
    rdfs:label 'Reversal Flag' ;
    rdfs:comment 'Indicates if this record represents a reversal of a previous status change.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:sourceSystem rdf:type rdf:Property ;
    rdfs:label 'Source System' ;
    rdfs:comment 'System of record that generated the status change event.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusAfter rdf:type rdf:Property ;
    rdfs:label 'Status After' ;
    rdfs:comment 'The status of the account after the transition.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusBefore rdf:type rdf:Property ;
    rdfs:label 'Status Before' ;
    rdfs:comment 'The status of the account prior to the transition.' ;
    rdfs:domain ind:AccountStatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardholderAmlScreeningResultId rdf:type rdf:Property ;
    rdfs:label 'Cardholder Aml Screening Result Id' ;
    rdfs:comment 'Unique identifier for each AML screening result record.' ;
    rdfs:domain ind:CardholderAmlScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cardholderProfileId rdf:type rdf:Property ;
    rdfs:label 'Cardholder Cardholder Profile Id' ;
    rdfs:comment 'Unique identifier of the cardholder whose information was screened.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CardholderProfile .

ind:cardholderProfileId rdf:type rdf:Property ;
    rdfs:label 'Cardholder Profile Id' ;
    rdfs:comment 'Unique identifier of the cardholder whose information was screened.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CardholderProfile .

ind:analystReviewReference rdf:type rdf:Property ;
    rdfs:label 'Analyst Review Reference' ;
    rdfs:comment 'Unique identifier of the compliance analyst who reviewed the screening.' ;
    rdfs:domain ind:CardholderAmlScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:complianceStatus rdf:type rdf:Property ;
    rdfs:label 'Compliance Status' ;
    rdfs:comment 'Final compliance determination for the cardholder based on screening.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disposition rdf:type rdf:Property ;
    rdfs:label 'Disposition' ;
    rdfs:comment 'Outcome of the screening result after analyst review.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isAdverseMedia rdf:type rdf:Property ;
    rdfs:label 'Is Adverse Media' ;
    rdfs:comment 'True if negative media coverage was identified.' ;
    rdfs:domain ind:CardholderAmlScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPep rdf:type rdf:Property ;
    rdfs:label 'Is Pep' ;
    rdfs:comment 'True if the cardholder matches a PEP watchlist.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isSanctioned rdf:type rdf:Property ;
    rdfs:label 'Is Sanctioned' ;
    rdfs:comment 'True if the screening identified a sanctions match.' ;
    rdfs:domain ind:CardholderAmlScreeningResult ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isWatchlist rdf:type rdf:Property ;
    rdfs:label 'Is Watchlist' ;
    rdfs:comment 'True if the screening matched any watchlist entry.' ;
