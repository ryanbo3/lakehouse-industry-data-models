    rdfs:comment 'Current lifecycle status of the rule.' ;
    rdfs:domain ind:RiskRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:velocityCount rdf:type rdf:Property ;
