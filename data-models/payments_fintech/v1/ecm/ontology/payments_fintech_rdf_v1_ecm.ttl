    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:policyOwner rdf:type rdf:Property ;
    rdfs:label 'Policy Owner' ;
    rdfs:comment 'Business unit or team responsible for maintaining the policy.' ;
