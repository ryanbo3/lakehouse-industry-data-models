    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pairName rdf:type rdf:Property ;
    rdfs:label 'Pair Name' ;
    rdfs:comment 'Human-readable concatenation of base and quote currency codes.' ;
