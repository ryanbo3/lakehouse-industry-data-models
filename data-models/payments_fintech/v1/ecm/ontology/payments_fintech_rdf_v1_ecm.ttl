ind:rightToErasureRequested rdf:type rdf:Property ;
    rdfs:label 'Right To Erasure Requested' ;
    rdfs:comment 'True when the cardholder has submitted a request for data deletion.' ;
    rdfs:domain ind:CardholderProfile ;
