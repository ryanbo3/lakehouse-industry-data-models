    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eciValue rdf:type rdf:Property ;
    rdfs:label 'Eci Value' ;
    rdfs:comment 'ECI code indicating the level of authentication and liability shift.' ;
    rdfs:domain ind:Gateway3dsAuthentication ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exemptionApplied rdf:type rdf:Property ;
    rdfs:label 'Exemption Applied' ;
    rdfs:comment 'Exemption code applied to bypass full authentication (e.g., low-value, trusted-merchant).' ;
    rdfs:domain ind:Gateway3dsAuthentication ;
    rdf:type owl:DatatypeProperty ;
