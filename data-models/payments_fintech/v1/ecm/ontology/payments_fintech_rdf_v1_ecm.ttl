    rdfs:range xsd:string .

ind:sdkType rdf:type rdf:Property ;
    rdfs:label 'Sdk Type' ;
    rdfs:comment 'Classification of the SDK based on deployment model.' ;
    rdfs:domain ind:SdkVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sdkVersionStatus rdf:type rdf:Property ;
    rdfs:label 'Sdk Version Status' ;
    rdfs:comment 'Current lifecycle state of the SDK version.' ;
    rdfs:domain ind:SdkVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supportedFeatures rdf:type rdf:Property ;
    rdfs:label 'Supported Features' ;
    rdfs:comment 'Comma-separated list of major features (e.g., tokenization, 3-DS, fraud scoring) available in this SDK version.' ;
    rdfs:domain ind:SdkVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:versionCode rdf:type rdf:Property ;
    rdfs:label 'Version Code' ;
    rdfs:comment 'Canonical version code used internally and in external contracts; uniquely identifies the SDK release.' ;
    rdfs:domain ind:SdkVersion ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaBreachId rdf:type rdf:Property ;
    rdfs:label 'Sla Breach Id' ;
    rdfs:comment 'Unique surrogate key for each SLA breach event.' ;
    rdfs:domain ind:SlaBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:breachEndTimestamp rdf:type rdf:Property ;
    rdfs:label 'Breach End Timestamp' ;
    rdfs:comment 'Exact time the SLA metric returned to within the contracted threshold.' ;
    rdfs:domain ind:SlaBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:breachReference rdf:type rdf:Property ;
    rdfs:label 'Breach Reference' ;
    rdfs:comment 'Human-readable reference code assigned to the breach for tracking and communication.' ;
    rdfs:domain ind:SlaBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:breachStartTimestamp rdf:type rdf:Property ;
    rdfs:label 'Breach Start Timestamp' ;
    rdfs:comment 'Exact time the SLA metric first fell outside the contracted threshold.' ;
    rdfs:domain ind:SlaBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:contractedUnit rdf:type rdf:Property ;
    rdfs:label 'Contracted Unit' ;
    rdfs:comment 'Unit associated with the contracted SLA value.' ;
    rdfs:domain ind:SlaBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractedValue rdf:type rdf:Property ;
    rdfs:label 'Contracted Value' ;
    rdfs:comment 'The SLA-defined threshold that should not be exceeded (or must be met).' ;
    rdfs:domain ind:SlaBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditAppliedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Credit Applied Timestamp' ;
    rdfs:comment 'Date and time the credit obligation was settled.' ;
    rdfs:domain ind:SlaBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:creditCurrency rdf:type rdf:Property ;
    rdfs:label 'Credit Currency' ;
    rdfs:comment 'Three-letter currency code (e.g., USD, EUR) for the credit obligation.' ;
    rdfs:domain ind:SlaBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditObligationAmount rdf:type rdf:Property ;
    rdfs:label 'Credit Obligation Amount' ;
    rdfs:comment 'Financial credit amount the provider must remit to the impacted party as per SLA contract.' ;
    rdfs:domain ind:SlaBreach ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:impactedPartyReference rdf:type rdf:Property ;
    rdfs:label 'Impacted Party Reference' ;
    rdfs:comment 'Surrogate key referencing the party that experienced the SLA breach.' ;
