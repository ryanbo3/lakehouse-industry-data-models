    rdfs:range xsd:string .

ind:riskReviewTimestamp rdf:type rdf:Property ;
    rdfs:label 'Risk Review Timestamp' ;
    rdfs:comment 'Exact timestamp when the latest risk review was completed.' ;
    rdfs:domain ind:MerchantRiskProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:riskReviewTrigger rdf:type rdf:Property ;
    rdfs:label 'Risk Review Trigger' ;
    rdfs:comment 'Event or condition that initiated the latest risk review.' ;
    rdfs:domain ind:MerchantRiskProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskScoreExplanation rdf:type rdf:Property ;
    rdfs:label 'Risk Score Explanation' ;
    rdfs:comment 'Narrative explanation of factors influencing the risk score.' ;
    rdfs:domain ind:MerchantRiskProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskScoreSource rdf:type rdf:Property ;
    rdfs:label 'Risk Score Source' ;
    rdfs:comment 'Origin of the risk score (e.g., model, manual).' ;
    rdfs:domain ind:MerchantRiskProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskScoreVersion rdf:type rdf:Property ;
    rdfs:label 'Risk Score Version' ;
    rdfs:comment 'Version identifier of the scoring model used.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskStatus rdf:type rdf:Property ;
    rdfs:label 'Risk Status' ;
    rdfs:comment 'Current lifecycle status of the risk profile.' ;
    rdfs:domain ind:MerchantRiskProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionVolumeTier rdf:type rdf:Property ;
    rdfs:label 'Transaction Volume Tier' ;
    rdfs:comment 'Categorization of merchant based on average transaction volume.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statusHistoryId rdf:type rdf:Property ;
    rdfs:label 'Status History Id' ;
    rdfs:comment 'System-generated unique identifier for each status transition record.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:initiatingActorEmployeeId rdf:type rdf:Property ;
