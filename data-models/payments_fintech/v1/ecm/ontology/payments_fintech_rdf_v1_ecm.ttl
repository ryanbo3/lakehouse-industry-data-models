    rdfs:range ind:Currency .

ind:fraudAlertId rdf:type rdf:Property ;
    rdfs:label 'Fraud Alert Id' ;
    rdfs:comment 'Foreign key linking to fraud.fraud_alert. Business justification: Real-time monitoring dashboard shows the latest fraud alert linked to an account for risk officers.' ;
    rdfs:domain ind:PaymentsFintech ;
