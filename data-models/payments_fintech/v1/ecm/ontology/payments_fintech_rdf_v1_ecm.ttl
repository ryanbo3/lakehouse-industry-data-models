ind:reportingThresholdUnit rdf:type rdf:Property ;
    rdfs:label 'Reporting Threshold Unit' ;
    rdfs:comment 'Currency unit used for the reporting threshold.' ;
    rdfs:domain ind:RegulatoryReportingReq ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reportingType rdf:type rdf:Property ;
    rdfs:label 'Reporting Type' ;
    rdfs:comment 'Category of regulatory filing (e.g., Currency Transaction Report, Suspicious Activity Report).' ;
