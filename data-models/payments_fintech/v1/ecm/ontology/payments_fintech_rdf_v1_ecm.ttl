    rdfs:comment 'Current lifecycle status of the gpi transaction.' ;
    rdfs:domain ind:SwiftGpiTracker ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:totalFees rdf:type rdf:Property ;
    rdfs:label 'Total Fees' ;
