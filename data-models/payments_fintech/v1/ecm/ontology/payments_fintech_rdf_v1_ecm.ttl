ind:originalAmount rdf:type rdf:Property ;
    rdfs:label 'Original Amount' ;
    rdfs:comment 'Monetary amount in the origin currency before conversion.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentPurposeCode rdf:type rdf:Property ;
    rdfs:label 'Payment Purpose Code' ;
    rdfs:comment 'ISO 20022 purpose code describing the reason for the payment.' ;
