ind:walletStatus rdf:type rdf:Property ;
    rdfs:label 'Wallet Status' ;
    rdfs:comment 'Current lifecycle state of the wallet instance.' ;
    rdfs:domain ind:DigitalWallet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:walletTier rdf:type rdf:Property ;
    rdfs:label 'Wallet Tier' ;
    rdfs:comment 'Business tier of the wallet, reflecting service level and fee structure.' ;
