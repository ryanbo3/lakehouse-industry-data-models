    rdfs:comment 'Indicates whether additional supporting documents must accompany this document type.' ;
    rdfs:domain ind:KycDocumentType ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:averageTransactionVolume rdf:type rdf:Property ;
