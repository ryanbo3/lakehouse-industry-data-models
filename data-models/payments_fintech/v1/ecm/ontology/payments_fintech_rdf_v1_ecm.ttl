ind:isRestrictedMapping rdf:type rdf:Property ;
    rdfs:label 'Is Restricted Mapping' ;
    rdfs:comment 'True if the mapping is subject to additional security controls (e.g., high-value cards).' ;
    rdfs:domain ind:TokenPanMapping ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isTestMapping rdf:type rdf:Property ;
    rdfs:label 'Is Test Mapping' ;
    rdfs:comment 'True if the mapping is created for testing or sandbox environments.' ;
