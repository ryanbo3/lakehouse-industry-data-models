ind:noteStatus rdf:type rdf:Property ;
    rdfs:label 'Note Status' ;
    rdfs:comment 'Current lifecycle state of the note record.' ;
    rdfs:domain ind:Note ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:noteType rdf:type rdf:Property ;
    rdfs:label 'Note Type' ;
    rdfs:comment 'High-level classification of the note content.' ;
    rdfs:domain ind:Note ;
    rdf:type owl:DatatypeProperty ;
