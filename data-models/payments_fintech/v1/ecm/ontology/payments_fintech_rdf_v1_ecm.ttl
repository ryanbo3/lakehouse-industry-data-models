    rdfs:range xsd:string .

ind:certificateFingerprint rdf:type rdf:Property ;
    rdfs:label 'Certificate Fingerprint' ;
    rdfs:comment 'SHA-256 fingerprint of the TLS certificate presented by the requestor.' ;
