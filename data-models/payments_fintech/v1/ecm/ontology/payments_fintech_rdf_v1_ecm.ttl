    rdfs:comment 'Payment channel (e.g., online, mobile, POS) where the rule is evaluated.' ;
    rdfs:domain ind:RiskRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:concentrationLimit rdf:type rdf:Property ;
    rdfs:label 'Concentration Limit' ;
    rdfs:comment 'Limit on concentration of transactions to a single merchant or channel.' ;
