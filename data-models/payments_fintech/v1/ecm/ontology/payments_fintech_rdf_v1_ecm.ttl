ind:beforeState rdf:type rdf:Property ;
    rdfs:label 'Before State' ;
    rdfs:comment 'JSON-encoded snapshot of the entity\'s state prior to the event.' ;
    rdfs:domain ind:EventLog ;
    rdf:type owl:DatatypeProperty ;
