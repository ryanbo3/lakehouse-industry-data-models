    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:beneficiaryCustomerName rdf:type rdf:Property ;
    rdfs:label 'Beneficiary Customer Name' ;
    rdfs:comment 'Legal name of the party receiving the payment.' ;
