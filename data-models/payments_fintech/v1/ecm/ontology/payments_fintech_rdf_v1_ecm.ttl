    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:creditMovements rdf:type rdf:Property ;
    rdfs:label 'Credit Movements' ;
    rdfs:comment 'Aggregate amount of all credit transactions posted to the account on the value date.' ;
    rdfs:domain ind:NostroBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:debitMovements rdf:type rdf:Property ;
    rdfs:label 'Debit Movements' ;
    rdfs:comment 'Aggregate amount of all debit transactions posted to the account on the value date.' ;
    rdfs:domain ind:NostroBalance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holdBalance rdf:type rdf:Property ;
    rdfs:label 'Hold Balance' ;
    rdfs:comment 'Funds that are reserved or blocked and cannot be used for outgoing payments.' ;
