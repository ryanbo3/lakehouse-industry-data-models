    rdfs:comment 'Version of the message format (e.g., ISO 20022 version).' ;
    rdfs:domain ind:SwiftMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderingCustomerAccount rdf:type rdf:Property ;
    rdfs:label 'Ordering Customer Account' ;
    rdfs:comment 'IBAN of the ordering customer\'s account.' ;
    rdfs:domain ind:SwiftMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:orderingCustomerName rdf:type rdf:Property ;
    rdfs:label 'Ordering Customer Name' ;
    rdfs:comment 'Legal name of the party ordering the payment.' ;
    rdfs:domain ind:SwiftMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingEndTimestamp rdf:type rdf:Property ;
