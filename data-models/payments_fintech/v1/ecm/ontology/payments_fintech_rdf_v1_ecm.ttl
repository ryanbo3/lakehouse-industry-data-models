ind:walletVersion rdf:type rdf:Property ;
    rdfs:label 'Wallet Version' ;
    rdfs:comment 'Version identifier of the wallet software/firmware configuration.' ;
    rdfs:domain ind:DigitalWallet ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emvConfigId rdf:type rdf:Property ;
    rdfs:label 'Emv Config Id' ;
    rdfs:comment 'Unique surrogate key for each EMV configuration record.' ;
    rdfs:domain ind:EmvConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:compliancePciDssVersion rdf:type rdf:Property ;
    rdfs:label 'Compliance Pci Dss Version' ;
    rdfs:comment 'Version of the PCI DSS standard to which this configuration complies.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
