ind:invoiceId rdf:type rdf:Property ;
    rdfs:label 'Invoice Id' ;
    rdfs:comment 'Surrogate primary key uniquely identifying each partner invoice record.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:paymentRailId rdf:type rdf:Property ;
    rdfs:label 'Payment Rail Id' ;
    rdfs:comment 'Method by which settlement to the partner is performed.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentRail .

ind:reversalInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Reversal Invoice Id' ;
    rdfs:comment 'Reference to the invoice that reverses this invoice, if applicable.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Invoice .

ind:arReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Ar Reference Number' ;
    rdfs:comment 'Accounts Receivable reference number in Oracle Financials linked to this invoice.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exchangeRateToUsd rdf:type rdf:Property ;
    rdfs:label 'Exchange Rate To Usd' ;
    rdfs:comment 'Exchange rate applied to convert invoice currency to USD for reporting.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:externalInvoiceNumber rdf:type rdf:Property ;
    rdfs:label 'External Invoice Number' ;
    rdfs:comment 'Invoice number provided by the partner (if they issue a reciprocal invoice).' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceType rdf:type rdf:Property ;
    rdfs:label 'Invoice Type' ;
    rdfs:comment 'Category of fee or charge represented by the invoice.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isCreditMemo rdf:type rdf:Property ;
    rdfs:label 'Is Credit Memo' ;
    rdfs:comment 'Indicates whether this invoice is a credit memo (negative amount).' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lineItemCount rdf:type rdf:Property ;
    rdfs:label 'Line Item Count' ;
    rdfs:comment 'Number of line items included in the invoice.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:netAmountDue rdf:type rdf:Property ;
    rdfs:label 'Net Amount Due' ;
    rdfs:comment 'Net amount payable after taxes, fees, penalties, and discounts.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalQuantity rdf:type rdf:Property ;
    rdfs:label 'Total Quantity' ;
    rdfs:comment 'Aggregate quantity of units across all line items (e.g., total transaction count).' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:vatRate rdf:type rdf:Property ;
    rdfs:label 'Vat Rate' ;
    rdfs:comment 'Applicable VAT rate applied to the invoice, if tax is not exempt.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:voidReason rdf:type rdf:Property ;
    rdfs:label 'Void Reason' ;
    rdfs:comment 'Reason provided for voiding the invoice.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:voidedFlag rdf:type rdf:Property ;
    rdfs:label 'Voided Flag' ;
    rdfs:comment 'Indicates whether the invoice has been voided.' ;
    rdfs:domain ind:Invoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:performancePeriodId rdf:type rdf:Property ;
    rdfs:label 'Performance Period Id' ;
    rdfs:comment 'Primary key uniquely identifying each partner performance snapshot for a measurement period.' ;
    rdfs:domain ind:PerformancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:authorizationApprovalRate rdf:type rdf:Property ;
    rdfs:label 'Authorization Approval Rate' ;
    rdfs:comment 'Percentage of transaction authorizations that were approved for the partner (approved / total attempts).' ;
    rdfs:domain ind:PerformancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chargebackRate rdf:type rdf:Property ;
    rdfs:label 'Chargeback Rate' ;
    rdfs:comment 'Percentage of settled transactions that resulted in a chargeback during the period.' ;
    rdfs:domain ind:PerformancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Measurement Period End Date' ;
    rdfs:comment 'Last calendar date of the reporting period (inclusive).' ;
    rdfs:domain ind:PerformancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:measurementPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Measurement Period Start Date' ;
    rdfs:comment 'First calendar date of the reporting period (inclusive).' ;
    rdfs:domain ind:PerformancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:partnerTier rdf:type rdf:Property ;
    rdfs:label 'Partner Tier' ;
    rdfs:comment 'Current commercial tier classification of the partner based on volume and performance.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementTimelinessScore rdf:type rdf:Property ;
    rdfs:label 'Settlement Timeliness Score' ;
    rdfs:comment 'Score (0-100) measuring how promptly the partner\'s settlements were completed relative to SLA targets.' ;
    rdfs:domain ind:PerformancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:slaComplianceScore rdf:type rdf:Property ;
    rdfs:label 'Sla Compliance Score' ;
    rdfs:comment 'Composite score (0-100) reflecting the partner\'s adherence to agreed Service Level Agreement metrics for the period.' ;
    rdfs:domain ind:PerformancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalTpv rdf:type rdf:Property ;
    rdfs:label 'Total Tpv' ;
    rdfs:comment 'Aggregate monetary volume of all transactions processed for the partner during the period, expressed in the settlement currency.' ;
    rdfs:domain ind:PerformancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeCommitmentMetFlag rdf:type rdf:Property ;
    rdfs:label 'Volume Commitment Met Flag' ;
    rdfs:comment 'Indicates whether the partner met its contractual transaction volume commitment for the period.' ;
    rdfs:domain ind:PerformancePeriod ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:partnerProfileId rdf:type rdf:Property ;
    rdfs:label 'Partner Profile Id' ;
    rdfs:comment 'Unique surrogate key for the partner profile record.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PartnerProfile .

ind:primaryContactPartnerContactId rdf:type rdf:Property ;
    rdfs:label 'Primary Contact Partner Contact Id' ;
    rdfs:comment 'Foreign key linking to partner.partner_contact. Business justification: Replace duplicated contact details with FK to partner_contact, ensuring single source of truth for contact information.' ;
    rdfs:domain ind:PartnerProfile ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PartnerContact .

ind:annualTpvTier rdf:type rdf:Property ;
    rdfs:label 'Annual Tpv Tier' ;
    rdfs:comment 'Tier of total payment volume processed annually.' ;
    rdfs:domain ind:PartnerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apiCapabilityAuthentication rdf:type rdf:Property ;
    rdfs:label 'Api Capability Authentication' ;
    rdfs:comment 'Indicates if partner supports authentication APIs (e.g., 3-DS).' ;
    rdfs:domain ind:PartnerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:apiCapabilitySettlement rdf:type rdf:Property ;
    rdfs:label 'Api Capability Settlement' ;
    rdfs:comment 'Indicates if partner supports settlement APIs.' ;
    rdfs:domain ind:PartnerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:apiCapabilityTokenization rdf:type rdf:Property ;
    rdfs:label 'Api Capability Tokenization' ;
    rdfs:comment 'Indicates if partner supports tokenization APIs.' ;
    rdfs:domain ind:PartnerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:contractEffectiveEnd rdf:type rdf:Property ;
    rdfs:label 'Contract Effective End' ;
    rdfs:comment 'Contract end date (nullable if open-ended).' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractEffectiveStart rdf:type rdf:Property ;
    rdfs:label 'Contract Effective Start' ;
    rdfs:comment 'Contract start date.' ;
    rdfs:domain ind:Partner ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:contractNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Number' ;
    rdfs:comment 'Unique contract identifier governing the partnership.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataPrivacyCompliance rdf:type rdf:Property ;
    rdfs:label 'Data Privacy Compliance' ;
    rdfs:comment 'Applicable data privacy and security compliance frameworks.' ;
    rdfs:domain ind:PartnerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeResolutionContact rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Contact' ;
    rdfs:comment 'Contact name for dispute resolution communications.' ;
    rdfs:domain ind:PartnerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeResolutionEmail rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Email' ;
    rdfs:comment 'Email address for dispute resolution contact.' ;
    rdfs:domain ind:PartnerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:geographicFootprint rdf:type rdf:Property ;
    rdfs:label 'Geographic Footprint' ;
    rdfs:comment 'Comma-separated list of ISO 3166-1 alpha-3 country codes where the partner operates. [ENUM-REF-CANDIDATE: list of many countries — promote to reference product]' ;
    rdfs:domain ind:PartnerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersAddressLine1 rdf:type rdf:Property ;
    rdfs:label 'Headquarters Address Line1' ;
    rdfs:comment 'First line of the partner\'s headquarters street address.' ;
    rdfs:domain ind:PartnerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersAddressLine2 rdf:type rdf:Property ;
    rdfs:label 'Headquarters Address Line2' ;
    rdfs:comment 'Second line of the headquarters address (optional).' ;
    rdfs:domain ind:PartnerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersCity rdf:type rdf:Property ;
    rdfs:label 'Headquarters City' ;
    rdfs:comment 'City of the partner\'s headquarters.' ;
    rdfs:domain ind:PartnerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersCountry rdf:type rdf:Property ;
    rdfs:label 'Headquarters Country' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code of headquarters.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:headquartersState rdf:type rdf:Property ;
    rdfs:label 'Headquarters State' ;
    rdfs:comment 'State or province of the headquarters.' ;
    rdfs:domain ind:PartnerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastRiskReviewTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Risk Review Timestamp' ;
    rdfs:comment 'Timestamp of the most recent risk review for the partner.' ;
    rdfs:domain ind:PartnerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:partnerName rdf:type rdf:Property ;
    rdfs:label 'Partner Name' ;
    rdfs:comment 'Legal name of the ecosystem partner.' ;
    rdfs:domain ind:PartnerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:partnerProfileStatus rdf:type rdf:Property ;
    rdfs:label 'Partner Profile Status' ;
    rdfs:comment 'Current lifecycle status of the partner profile.' ;
    rdfs:domain ind:PartnerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueSharingPercentage rdf:type rdf:Property ;
    rdfs:label 'Revenue Sharing Percentage' ;
    rdfs:comment 'Percentage of revenue shared with the fintech per transaction.' ;
    rdfs:domain ind:PartnerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:serviceFeePercentage rdf:type rdf:Property ;
    rdfs:label 'Service Fee Percentage' ;
    rdfs:comment 'Service fee percentage charged to the partner.' ;
    rdfs:domain ind:PartnerProfile ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:partnerSettlementAccountId rdf:type rdf:Property ;
    rdfs:label 'Partner Settlement Account Id' ;
    rdfs:comment 'System-generated unique identifier for the partner settlement account record.' ;
    rdfs:domain ind:PartnerSettlementAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:accountCurrency rdf:type rdf:Property ;
    rdfs:label 'Account Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code of the settlement account.' ;
    rdfs:domain ind:PartnerSettlementAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bicSwiftCode rdf:type rdf:Property ;
    rdfs:label 'Bic Swift Code' ;
    rdfs:comment 'SWIFT/BIC code identifying the bank for international transfers.' ;
