    rdfs:range xsd:string .

ind:blockReference rdf:type rdf:Property ;
    rdfs:label 'Block Reference' ;
    rdfs:comment 'External reference number or code assigned to the block for audit and lookup.' ;
    rdfs:domain ind:InstrumentBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockType rdf:type rdf:Property ;
    rdfs:label 'Block Type' ;
    rdfs:comment 'Category indicating why the instrument is blocked.' ;
    rdfs:domain ind:InstrumentBlock ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:blockingAuthority rdf:type rdf:Property ;
