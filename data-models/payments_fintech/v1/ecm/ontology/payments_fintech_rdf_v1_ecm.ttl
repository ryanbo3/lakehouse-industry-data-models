    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:initiatingActorType rdf:type rdf:Property ;
    rdfs:label 'Initiating Actor Type' ;
    rdfs:comment 'Category of the entity that initiated the status change.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskScoreAtChange rdf:type rdf:Property ;
    rdfs:label 'Risk Score At Change' ;
    rdfs:comment 'Aggregated risk score assigned to the merchant at the moment of transition.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:statusChangeSource rdf:type rdf:Property ;
    rdfs:label 'Status Change Source' ;
    rdfs:comment 'Channel through which the status change was recorded.' ;
    rdfs:domain ind:StatusHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pciComplianceId rdf:type rdf:Property ;
    rdfs:label 'Pci Compliance Id' ;
    rdfs:comment 'Unique identifier for the PCI compliance record.' ;
    rdfs:domain ind:PciCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:aocReference rdf:type rdf:Property ;
    rdfs:label 'Aoc Reference' ;
    rdfs:comment 'Identifier or URI of the Attestation of Compliance (AOC) document submitted by the merchant.' ;
    rdfs:domain ind:PciCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assignedQsaName rdf:type rdf:Property ;
    rdfs:label 'Assigned Qsa Name' ;
    rdfs:comment 'Full name of the Qualified Security Assessor responsible for the merchant\'s assessment.' ;
    rdfs:domain ind:PciCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:asvScanDate rdf:type rdf:Property ;
    rdfs:label 'Asv Scan Date' ;
    rdfs:comment 'Date when the ASV scan was performed.' ;
    rdfs:domain ind:PciCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:asvScanStatus rdf:type rdf:Property ;
    rdfs:label 'Asv Scan Status' ;
    rdfs:comment 'Result of the Approved Scanning Vendor (ASV) vulnerability scan.' ;
    rdfs:domain ind:PciCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Compliance Fee Amount' ;
    rdfs:comment 'Monetary amount of any fee associated with compliance monitoring or certification.' ;
    rdfs:domain ind:PciCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:complianceFeeCurrency rdf:type rdf:Property ;
    rdfs:label 'Compliance Fee Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the compliance fee.' ;
    rdfs:domain ind:PciCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceLevel rdf:type rdf:Property ;
    rdfs:label 'Compliance Level' ;
    rdfs:comment 'Level of PCI DSS compliance achieved by the merchant (e.g., SAQ A, SAQ B, SAQ D, ROC).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceRecordNumber rdf:type rdf:Property ;
    rdfs:label 'Compliance Record Number' ;
    rdfs:comment 'Business-visible identifier for the compliance record, often used in reporting and audits.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceType rdf:type rdf:Property ;
    rdfs:label 'Compliance Type' ;
    rdfs:comment 'Specifies the compliance framework, fixed to PCI DSS for this product.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isWaiverApproved rdf:type rdf:Property ;
    rdfs:label 'Is Waiver Approved' ;
    rdfs:comment 'True if a waiver for non-compliance fees has been formally approved.' ;
    rdfs:domain ind:PciCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:nextAssessmentDueDate rdf:type rdf:Property ;
    rdfs:label 'Next Assessment Due Date' ;
    rdfs:comment 'Planned date for the merchant\'s next PCI DSS assessment.' ;
    rdfs:domain ind:PciCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:nonComplianceFeeWaiver rdf:type rdf:Property ;
    rdfs:label 'Non Compliance Fee Waiver' ;
    rdfs:comment 'Indicates whether the merchant has been granted a waiver for non-compliance fees.' ;
    rdfs:domain ind:PciCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:penetrationTestDate rdf:type rdf:Property ;
    rdfs:label 'Penetration Test Date' ;
    rdfs:comment 'Date when the penetration test was conducted.' ;
    rdfs:domain ind:PciCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:penetrationTestStatus rdf:type rdf:Property ;
    rdfs:label 'Penetration Test Status' ;
    rdfs:comment 'Outcome of the merchant\'s penetration testing.' ;
    rdfs:domain ind:PciCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qsaContactEmail rdf:type rdf:Property ;
    rdfs:label 'Qsa Contact Email' ;
    rdfs:comment 'Email address of the assigned QSA.' ;
    rdfs:domain ind:PciCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qsaContactPhone rdf:type rdf:Property ;
    rdfs:label 'Qsa Contact Phone' ;
    rdfs:comment 'Phone number of the assigned QSA.' ;
    rdfs:domain ind:PciCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskScoreAtAssessment rdf:type rdf:Property ;
    rdfs:label 'Risk Score At Assessment' ;
    rdfs:comment 'Numerical risk rating assigned during the PCI assessment.' ;
    rdfs:domain ind:PciCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:waiverApprovalDate rdf:type rdf:Property ;
    rdfs:label 'Waiver Approval Date' ;
    rdfs:comment 'Date the waiver was granted.' ;
    rdfs:domain ind:PciCompliance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:achTransactionFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Ach Transaction Fee Amount' ;
    rdfs:comment 'Fee charged per ACH (bank transfer) transaction processed for the merchant, expressed in the plan\'s base currency. Typically lower than card transaction fees.' ;
    rdfs:domain ind:MerchantPricingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:amexRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Amex Rate Percentage' ;
    rdfs:comment 'Separate MDR percentage applied specifically to American Express card transactions, which often have different pricing than Visa/Mastercard, expressed as a decimal.' ;
    rdfs:domain ind:MerchantPricingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currencyConversionMarkupPercentage rdf:type rdf:Property ;
    rdfs:label 'Currency Conversion Markup Percentage' ;
    rdfs:comment 'Markup percentage applied to the foreign exchange (FX) rate when Dynamic Currency Conversion (DCC) is offered to cardholders, expressed as a decimal (e.g., 0.0300 for 3.00% above spot rate).' ;
    rdfs:domain ind:MerchantPricingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:debitCardRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Debit Card Rate Percentage' ;
    rdfs:comment 'MDR percentage applied specifically to debit card transactions, typically lower than credit card rates due to Regulation II (Durbin Amendment) caps, expressed as a decimal.' ;
    rdfs:domain ind:MerchantPricingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interchangeMarkupPercentage rdf:type rdf:Property ;
    rdfs:label 'Interchange Markup Percentage' ;
    rdfs:comment 'The markup percentage added on top of the actual interchange cost in interchange-plus pricing models (e.g., 0.0050 for 0.50% above interchange). Null for non-interchange-plus models.' ;
    rdfs:domain ind:MerchantPricingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interchangePassthroughFlag rdf:type rdf:Property ;
    rdfs:label 'Interchange Passthrough Flag' ;
    rdfs:comment 'Indicates whether actual interchange fees (IRF) are passed through to the merchant at cost (true) or absorbed into a blended rate (false). True for interchange-plus and cost-plus models.' ;
    rdfs:domain ind:MerchantPricingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:internationalTransactionFeePercentage rdf:type rdf:Property ;
    rdfs:label 'International Transaction Fee Percentage' ;
    rdfs:comment 'Additional percentage fee applied to cross-border transactions where the card issuer is in a different country than the merchant, expressed as a decimal (e.g., 0.0100 for 1.00%).' ;
    rdfs:domain ind:MerchantPricingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mdrRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Mdr Rate Percentage' ;
    rdfs:comment 'The base percentage rate charged to the merchant per transaction, expressed as a decimal (e.g., 0.0275 for 2.75%). This is the primary revenue component for flat-rate and blended pricing models.' ;
    rdfs:domain ind:MerchantPricingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:merchantPricingPlanStatus rdf:type rdf:Property ;
    rdfs:label 'Merchant Pricing Plan Status' ;
    rdfs:comment 'Current lifecycle status of the pricing plan. Active plans are available for assignment; inactive plans are no longer offered but may still govern existing merchants; pending plans are under approval; suspended plans are temporarily unavailable; archived plans are historical records only.' ;
    rdfs:domain ind:MerchantPricingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:midQualifiedRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Mid Qualified Rate Percentage' ;
    rdfs:comment 'The middle MDR percentage tier in tiered pricing models, applied to transactions that partially meet qualification criteria (e.g., keyed-in transactions, rewards cards), expressed as a decimal.' ;
    rdfs:domain ind:MerchantPricingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:nonQualifiedRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Non Qualified Rate Percentage' ;
    rdfs:comment 'The highest MDR percentage tier in tiered pricing models, applied to transactions that fail qualification criteria (e.g., corporate cards, international cards, manually entered), expressed as a decimal.' ;
    rdfs:domain ind:MerchantPricingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:payfacSubMerchantEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Payfac Sub Merchant Eligible Flag' ;
    rdfs:comment 'Indicates whether this pricing plan is available for assignment to sub-merchants under a Payment Facilitator (PayFac) model. True if eligible for PayFac sub-merchants; false if only for direct merchants.' ;
    rdfs:domain ind:MerchantPricingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pciNonCompliancePenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Pci Non Compliance Penalty Amount' ;
    rdfs:comment 'Monthly penalty fee charged to merchants who fail to maintain PCI DSS compliance, expressed in the plan\'s base currency. Escalates with duration of non-compliance.' ;
    rdfs:domain ind:MerchantPricingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:planCode rdf:type rdf:Property ;
    rdfs:label 'Plan Code' ;
    rdfs:comment 'Externally-known unique business identifier for the pricing plan, used in contracts and merchant communications.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planDescription rdf:type rdf:Property ;
    rdfs:label 'Plan Description' ;
    rdfs:comment 'Detailed description of the pricing plan, including key features, target merchant segments, and value proposition.' ;
    rdfs:domain ind:MerchantPricingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:planName rdf:type rdf:Property ;
    rdfs:label 'Plan Name' ;
    rdfs:comment 'Human-readable name of the pricing plan (e.g., \'Standard Retail\', \'Enterprise Plus\', \'Startup Flat Rate\').' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualifiedRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Qualified Rate Percentage' ;
    rdfs:comment 'The lowest MDR percentage tier in tiered pricing models, applied to transactions that meet all qualification criteria (e.g., swiped consumer credit cards), expressed as a decimal.' ;
    rdfs:domain ind:MerchantPricingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:refundFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Refund Fee Amount' ;
    rdfs:comment 'Fee charged to the merchant for processing a refund or credit transaction, expressed in the plan\'s base currency. Some plans waive this fee; others charge per refund.' ;
    rdfs:domain ind:MerchantPricingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:setupFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Setup Fee Amount' ;
    rdfs:comment 'One-time fee charged when a merchant is onboarded and assigned to this pricing plan, covering account setup, KYC processing, and initial configuration, expressed in the plan\'s base currency.' ;
    rdfs:domain ind:MerchantPricingPlan ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:updatedByUser rdf:type rdf:Property ;
    rdfs:label 'Updated By User' ;
    rdfs:comment 'Identifier of the system user or administrator who last modified this pricing plan record. Used for audit trail and accountability.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardNotPresentLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Card Not Present Limit Amount' ;
    rdfs:comment 'Maximum amount allowed for card-not-present (CNP) transactions.' ;
    rdfs:domain ind:ProcessingLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:crossBorderLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Cross Border Limit Amount' ;
    rdfs:comment 'Maximum monetary value for cross-border transactions.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dailyTransactionCountLimit rdf:type rdf:Property ;
    rdfs:label 'Daily Transaction Count Limit' ;
    rdfs:comment 'Maximum number of individual transactions permitted per day.' ;
    rdfs:domain ind:ProcessingLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:dailyVolumeCapAmount rdf:type rdf:Property ;
    rdfs:label 'Daily Volume Cap Amount' ;
    rdfs:comment 'Total monetary volume limit for transactions within a calendar day.' ;
    rdfs:domain ind:ProcessingLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:limitChangeReason rdf:type rdf:Property ;
    rdfs:label 'Limit Change Reason' ;
    rdfs:comment 'Free-text description explaining why the limit was created or modified.' ;
    rdfs:domain ind:ProcessingLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limitCode rdf:type rdf:Property ;
    rdfs:label 'Limit Code' ;
    rdfs:comment 'Business code that uniquely identifies the type of limit configuration.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limitReviewDate rdf:type rdf:Property ;
    rdfs:label 'Limit Review Date' ;
    rdfs:comment 'Scheduled date for periodic review and possible adjustment of the limit.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:limitSource rdf:type rdf:Property ;
    rdfs:label 'Limit Source' ;
    rdfs:comment 'Origin of the limit configuration – whether set by underwriting, risk model, or manual policy.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:limitType rdf:type rdf:Property ;
    rdfs:label 'Limit Type' ;
    rdfs:comment 'Category of the limit, indicating which transaction dimension it governs. [ENUM-REF-CANDIDATE: single_transaction|daily_volume|monthly_tpv|transaction_count|cnp|cross_border|refund — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monthlyTpvLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Monthly Tpv Limit Amount' ;
    rdfs:comment 'Maximum cumulative transaction value allowed in a month.' ;
    rdfs:domain ind:ProcessingLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:processingLimitStatus rdf:type rdf:Property ;
    rdfs:label 'Processing Limit Status' ;
    rdfs:comment 'Current lifecycle status of the limit configuration.' ;
    rdfs:domain ind:ProcessingLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundLimitAmount rdf:type rdf:Property ;
    rdfs:label 'Refund Limit Amount' ;
    rdfs:comment 'Maximum total amount that can be refunded within the limit period.' ;
    rdfs:domain ind:ProcessingLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:riskScoreAtSet rdf:type rdf:Property ;
    rdfs:label 'Risk Score At Set' ;
    rdfs:comment 'Risk model score associated with the merchant at the time the limit was established.' ;
    rdfs:domain ind:ProcessingLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:singleTransactionMaxAmount rdf:type rdf:Property ;
    rdfs:label 'Single Transaction Max Amount' ;
    rdfs:comment 'Maximum monetary value allowed for any single transaction.' ;
    rdfs:domain ind:ProcessingLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:holdPeriodDays rdf:type rdf:Property ;
    rdfs:label 'Hold Period Days' ;
    rdfs:comment 'Number of days the reserve amount is held before release eligibility.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastReleaseDate rdf:type rdf:Property ;
    rdfs:label 'Last Release Date' ;
    rdfs:comment 'Date when the reserve was last partially or fully released.' ;
    rdfs:domain ind:MerchantReserveAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:merchantReserveAccountStatus rdf:type rdf:Property ;
    rdfs:label 'Merchant Reserve Account Status' ;
    rdfs:comment 'Current lifecycle status of the reserve account.' ;
    rdfs:domain ind:MerchantReserveAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:releaseSchedule rdf:type rdf:Property ;
    rdfs:label 'Release Schedule' ;
    rdfs:comment 'Frequency at which reserve funds are released back to the merchant.' ;
    rdfs:domain ind:MerchantReserveAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reserveAccountNumber rdf:type rdf:Property ;
    rdfs:label 'Reserve Account Number' ;
    rdfs:comment 'External reference number for the reserve account used in reporting and external communications.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reserveType rdf:type rdf:Property ;
    rdfs:label 'Reserve Type' ;
    rdfs:comment 'Classification of reserve: rolling, upfront, or capped.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schemeRegistrationId rdf:type rdf:Property ;
    rdfs:label 'Scheme Registration Id' ;
    rdfs:comment 'Unique surrogate key for each scheme registration record.' ;
    rdfs:domain ind:SchemeRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:primarySchemeAssignedMerchantId rdf:type rdf:Property ;
    rdfs:label 'Primary Scheme Assigned Merchant Id' ;
    rdfs:comment 'Identifier assigned by the card scheme to the merchant for reporting and interchange qualification.' ;
    rdfs:domain ind:SchemeRegistration ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Merchant .

ind:tertiarySchemeSponsorMerchantId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Scheme Sponsor Merchant Id' ;
    rdfs:comment 'Identifier of the sponsoring PayFac or ISO when registration_type is sponsored.' ;
    rdfs:domain ind:SchemeRegistration ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Merchant .

ind:complianceCheckDate rdf:type rdf:Property ;
    rdfs:label 'Compliance Check Date' ;
    rdfs:comment 'Date the most recent compliance verification was performed for this registration.' ;
    rdfs:domain ind:SchemeRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:programEnrollments rdf:type rdf:Property ;
    rdfs:label 'Program Enrollments' ;
    rdfs:comment 'Comma-separated list of scheme programs the merchant is enrolled in (e.g., Visa Checkout, Mastercard SecureCode).' ;
    rdfs:domain ind:SchemeRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationDate rdf:type rdf:Property ;
    rdfs:label 'Registration Date' ;
    rdfs:comment 'Date the merchant registration was initially submitted to the scheme.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:registrationFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Registration Fee Amount' ;
    rdfs:comment 'Monetary amount charged by the scheme for the registration.' ;
    rdfs:domain ind:SchemeRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:registrationFeeCurrency rdf:type rdf:Property ;
    rdfs:label 'Registration Fee Currency' ;
    rdfs:comment 'Currency of the registration fee.' ;
    rdfs:domain ind:SchemeRegistration ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:registrationType rdf:type rdf:Property ;
    rdfs:label 'Registration Type' ;
    rdfs:comment 'Indicates whether the merchant registers directly with the scheme or via a sponsor such as a PayFac.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Date' ;
    rdfs:comment 'Scheduled date for renewal of the scheme registration.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:sponsorType rdf:type rdf:Property ;
    rdfs:label 'Sponsor Type' ;
    rdfs:comment 'Classification of the sponsoring entity (PayFac, ISO, or None).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountCloseDate rdf:type rdf:Property ;
    rdfs:label 'Account Close Date' ;
    rdfs:comment 'Date when the bank account was closed or de-activated (nullable).' ;
    rdfs:domain ind:MerchantSettlementAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:accountNumberMasked rdf:type rdf:Property ;
    rdfs:label 'Account Number Masked' ;
    rdfs:comment 'Bank account number displayed with masking for security (e.g., ****1234).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:accountOpenDate rdf:type rdf:Property ;
    rdfs:label 'Account Open Date' ;
    rdfs:comment 'Date when the bank account was originally opened.' ;
    rdfs:domain ind:MerchantSettlementAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:bankBranch rdf:type rdf:Property ;
    rdfs:label 'Bank Branch' ;
    rdfs:comment 'Branch or location identifier of the bank (e.g., city or branch code).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:bicSwift rdf:type rdf:Property ;
    rdfs:label 'Bic Swift' ;
    rdfs:comment 'SWIFT code identifying the bank for international transfers.' ;
    rdfs:domain ind:MerchantSettlementAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lastVerifiedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Verified Timestamp' ;
    rdfs:comment 'Timestamp of the most recent successful verification of the account.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:merchantSettlementAccountStatus rdf:type rdf:Property ;
    rdfs:label 'Merchant Settlement Account Status' ;
    rdfs:comment 'Current lifecycle state of the settlement account.' ;
    rdfs:domain ind:MerchantSettlementAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pciCompliant rdf:type rdf:Property ;
    rdfs:label 'Pci Compliant' ;
    rdfs:comment 'True if the settlement account handling meets PCI DSS requirements.' ;
    rdfs:domain ind:MerchantSettlementAccount ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:routingNumber rdf:type rdf:Property ;
    rdfs:label 'Routing Number' ;
    rdfs:comment 'Domestic routing number used for ACH or wire transfers.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentAggregatorMerchantId rdf:type rdf:Property ;
    rdfs:label 'Parent Aggregator Merchant Id' ;
    rdfs:comment 'Identifier of the aggregator (if any) that the sub-merchant is linked to.' ;
    rdfs:domain ind:SubMerchant ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Merchant .

ind:paymentFacilitatorId rdf:type rdf:Property ;
    rdfs:label 'Payment Facilitator Id' ;
    rdfs:comment 'Identifier of the aggregator (if any) that the sub-merchant is linked to.' ;
    rdfs:domain ind:Merchant ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentFacilitator .

ind:processingStatus rdf:type rdf:Property ;
    rdfs:label 'Processing Status' ;
    rdfs:comment 'Indicates whether the sub-merchant is currently allowed to process transactions.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:riskClassification rdf:type rdf:Property ;
    rdfs:label 'Risk Classification' ;
    rdfs:comment 'Risk tier assigned to the sub-merchant based on underwriting and fraud scoring.' ;
    rdfs:domain ind:SubMerchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:state rdf:type rdf:Property ;
    rdfs:label 'State' ;
    rdfs:comment 'State or province component of the sub-merchant\'s address.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subMerchantName rdf:type rdf:Property ;
    rdfs:label 'Sub Merchant Name' ;
    rdfs:comment 'Full legal name of the sub-merchant as registered.' ;
    rdfs:domain ind:SubMerchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subMerchantStatus rdf:type rdf:Property ;
    rdfs:label 'Sub Merchant Status' ;
    rdfs:comment 'Current lifecycle status of the sub-merchant.' ;
    rdfs:domain ind:SubMerchant ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subMid rdf:type rdf:Property ;
    rdfs:label 'Sub Mid' ;
    rdfs:comment 'Unique identifier assigned to the sub-merchant by the acquiring bank.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkCertificationRecordId rdf:type rdf:Property ;
    rdfs:label 'Network Certification Record Id' ;
    rdfs:comment 'System-generated unique identifier for the certification record.' ;
    rdfs:domain ind:Network ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:NetworkCertificationRecord .

ind:certificationCode rdf:type rdf:Property ;
    rdfs:label 'Certification Code' ;
    rdfs:comment 'Internal code or identifier used to reference the certification within the platform.' ;
    rdfs:domain ind:NetworkCertificationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationName rdf:type rdf:Property ;
    rdfs:label 'Certification Name' ;
    rdfs:comment 'Human-readable name of the certification (e.g., EMV Chip Certification).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationStatus rdf:type rdf:Property ;
    rdfs:label 'Certification Status' ;
    rdfs:comment 'Current lifecycle status of the certification.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificationType rdf:type rdf:Property ;
    rdfs:label 'Certification Type' ;
    rdfs:comment 'Category of certification indicating the technology or standard being certified.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceScope rdf:type rdf:Property ;
    rdfs:label 'Compliance Scope' ;
    rdfs:comment 'Geographic or functional scope covered by the certification.' ;
    rdfs:domain ind:NetworkCertificationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isRenewal rdf:type rdf:Property ;
    rdfs:label 'Is Renewal' ;
    rdfs:comment 'Indicates whether the certification record represents a renewal of a prior certification.' ;
    rdfs:domain ind:NetworkCertificationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:resultDetails rdf:type rdf:Property ;
    rdfs:label 'Result Details' ;
    rdfs:comment 'Free-text details describing the test outcome, observations, or notes.' ;
    rdfs:domain ind:NetworkCertificationRecord ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:connectivityEventId rdf:type rdf:Property ;
    rdfs:label 'Connectivity Event Id' ;
    rdfs:comment 'Unique surrogate key for each connectivity event record.' ;
    rdfs:domain ind:ConnectivityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:certificateStatus rdf:type rdf:Property ;
    rdfs:label 'Certificate Status' ;
    rdfs:comment 'Current status of the TLS/SSL certificate used in the connection.' ;
    rdfs:domain ind:ConnectivityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durationSeconds rdf:type rdf:Property ;
    rdfs:label 'Duration Seconds' ;
    rdfs:comment 'Length of time the event lasted, measured in seconds.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:eventDescription rdf:type rdf:Property ;
    rdfs:label 'Event Description' ;
    rdfs:comment 'Free-text description providing details about the event.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkNode rdf:type rdf:Property ;
    rdfs:label 'Network Node' ;
    rdfs:comment 'Logical name or identifier of the network node where the event originated.' ;
    rdfs:domain ind:ConnectivityEvent ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emvParameterId rdf:type rdf:Property ;
    rdfs:label 'Emv Parameter Id' ;
    rdfs:comment 'Unique identifier for the EMV parameter set.' ;
    rdfs:domain ind:EmvParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:additionalTerminalCapabilities rdf:type rdf:Property ;
    rdfs:label 'Additional Terminal Capabilities' ;
    rdfs:comment 'Extended capability bitmap for the terminal.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aid rdf:type rdf:Property ;
    rdfs:label 'Aid' ;
    rdfs:comment 'Hexadecimal identifier of the EMV application as defined by the card scheme.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:aidDescription rdf:type rdf:Property ;
    rdfs:label 'Aid Description' ;
    rdfs:comment 'Human-readable description of the AID purpose.' ;
    rdfs:domain ind:EmvParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationInterchangeProfile rdf:type rdf:Property ;
    rdfs:label 'Application Interchange Profile' ;
    rdfs:comment 'Hex value defining interchange profile rules for the application.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:applicationVersionNumber rdf:type rdf:Property ;
    rdfs:label 'Application Version Number' ;
    rdfs:comment 'Version number of the EMV application on the card.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardActionCodeDefault rdf:type rdf:Property ;
    rdfs:label 'Card Action Code Default' ;
    rdfs:comment 'Hex code defined by the card issuer for default handling.' ;
    rdfs:domain ind:EmvParameter ;
