    rdfs:range xsd:string .

ind:maintenanceStatus rdf:type rdf:Property ;
    rdfs:label 'Maintenance Status' ;
    rdfs:comment 'Current maintenance state of the terminal.' ;
    rdfs:domain ind:Terminal ;
    rdf:type owl:DatatypeProperty ;
