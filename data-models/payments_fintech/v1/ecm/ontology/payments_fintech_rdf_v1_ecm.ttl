    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schemeParameterStatus rdf:type rdf:Property ;
    rdfs:label 'Scheme Parameter Status' ;
    rdfs:comment 'Current lifecycle state of the parameter record.' ;
    rdfs:domain ind:SchemeParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceBulletinDate rdf:type rdf:Property ;
    rdfs:label 'Source Bulletin Date' ;
    rdfs:comment 'Date of the network bulletin that introduced or updated the parameter.' ;
    rdfs:domain ind:SchemeParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:unitOfMeasure rdf:type rdf:Property ;
