    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:renewalFailureReason rdf:type rdf:Property ;
    rdfs:label 'Renewal Failure Reason' ;
    rdfs:comment 'Business code describing why a renewal attempt failed.' ;
