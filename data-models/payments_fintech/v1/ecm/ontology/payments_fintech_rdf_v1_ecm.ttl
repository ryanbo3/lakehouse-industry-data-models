    rdfs:comment 'Unit associated with the parameter value (e.g., USD, count, minutes).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:valueDataType rdf:type rdf:Property ;
    rdfs:label 'Value Data Type' ;
    rdfs:comment 'Data type of the parameter value indicating how it should be interpreted.' ;
    rdfs:domain ind:SchemeParameter ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:apiCredentialRotationId rdf:type rdf:Property ;
    rdfs:label 'Api Credential Rotation Id' ;
    rdfs:comment 'System-generated unique identifier for each API credential rotation event.' ;
    rdfs:domain ind:ApiCredentialRotation ;
