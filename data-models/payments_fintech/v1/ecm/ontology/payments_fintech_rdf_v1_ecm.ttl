ind:threedsConfigId rdf:type rdf:Property ;
    rdfs:label 'Threeds Config Id' ;
    rdfs:comment 'Unique surrogate key for each 3-D Secure configuration record.' ;
    rdfs:domain ind:ThreedsConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:authenticationFlow rdf:type rdf:Property ;
