ind:monthlySpendUsedAmount rdf:type rdf:Property ;
    rdfs:label 'Monthly Spend Used Amount' ;
    rdfs:comment 'Cumulative amount spent on the instrument this month, used to compare against monthly_spend_limit.' ;
    rdfs:domain ind:InstrumentLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionCountMonth rdf:type rdf:Property ;
    rdfs:label 'Transaction Count Month' ;
    rdfs:comment 'Number of transactions processed this month for the instrument.' ;
    rdfs:domain ind:InstrumentLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transactionCountToday rdf:type rdf:Property ;
    rdfs:label 'Transaction Count Today' ;
    rdfs:comment 'Number of transactions processed today for the instrument.' ;
    rdfs:domain ind:InstrumentLimit ;
