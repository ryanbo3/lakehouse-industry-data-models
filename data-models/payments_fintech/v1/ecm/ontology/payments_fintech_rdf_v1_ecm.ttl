    rdfs:comment 'Indicates whether additional authentication is required during token provisioning.' ;
    rdfs:domain ind:IssuerWalletConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:stepUpTriggerCondition rdf:type rdf:Property ;
