ind:ownerPartyReference rdf:type rdf:Property ;
    rdfs:label 'Owner Party Reference' ;
    rdfs:comment 'Identifier of the party (merchant, cardholder, or partner) that owns the credential.' ;
    rdfs:domain ind:CredentialVault ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:panTokenReference rdf:type rdf:Property ;
    rdfs:label 'Pan Token Reference' ;
    rdfs:comment 'Token that represents the Primary Account Number; actual PAN is never stored.' ;
    rdfs:domain ind:CredentialVault ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:vaultLocation rdf:type rdf:Property ;
    rdfs:label 'Vault Location' ;
    rdfs:comment 'Logical location or container identifier within the secure vault where the credential reference is stored.' ;
    rdfs:domain ind:CredentialVault ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detokenizationRequestId rdf:type rdf:Property ;
    rdfs:label 'Detokenization Request Id' ;
    rdfs:comment 'Unique system-generated identifier for each detokenization request.' ;
    rdfs:domain ind:DetokenizationRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:authorizationOutcome rdf:type rdf:Property ;
    rdfs:label 'Authorization Outcome' ;
    rdfs:comment 'Result of the authorization check for the detokenization request.' ;
    rdfs:domain ind:DetokenizationRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:complianceCheckCode rdf:type rdf:Property ;
    rdfs:label 'Compliance Check Code' ;
    rdfs:comment 'Code representing the specific compliance rule or policy evaluated for the request.' ;
    rdfs:domain ind:Terminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detokenizationRequestStatus rdf:type rdf:Property ;
    rdfs:label 'Detokenization Request Status' ;
    rdfs:comment 'Current lifecycle status of the detokenization request.' ;
    rdfs:domain ind:DetokenizationRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dpanMasked rdf:type rdf:Property ;
    rdfs:label 'Dpan Masked' ;
    rdfs:comment 'Masked representation of the DPAN (e.g., first 6 and last 4 digits visible).' ;
    rdfs:domain ind:Terminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fpanReturnedFlag rdf:type rdf:Property ;
    rdfs:label 'Fpan Returned Flag' ;
    rdfs:comment 'Indicates whether the full Primary Account Number (FPAN) was returned (true) or not (false).' ;
