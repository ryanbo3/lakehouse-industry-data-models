    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdDescription rdf:type rdf:Property ;
    rdfs:label 'Threshold Description' ;
    rdfs:comment 'Detailed description of the purpose and application of the threshold.' ;
    rdfs:domain ind:Threshold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdName rdf:type rdf:Property ;
    rdfs:label 'Threshold Name' ;
    rdfs:comment 'Human-readable name of the risk threshold.' ;
    rdfs:domain ind:Threshold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thresholdStatus rdf:type rdf:Property ;
    rdfs:label 'Threshold Status' ;
    rdfs:comment 'Current lifecycle status of the threshold configuration.' ;
    rdfs:domain ind:Threshold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:underwriterEmployeeId rdf:type rdf:Property ;
