    rdfs:comment 'Foreign key linking to product.payment_product. Business justification: Account statements, fee calculation, and regulatory reporting require linking each cardholder_account to its underlying payment_product (e.g., credit card product).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentProduct .

ind:accountNumber rdf:type rdf:Property ;
