    rdfs:range ind:Transaction .

ind:authorName rdf:type rdf:Property ;
    rdfs:label 'Author Name' ;
    rdfs:comment 'Display name of the note author.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorRole rdf:type rdf:Property ;
    rdfs:label 'Author Role' ;
    rdfs:comment 'Business role of the author at the time of note creation.' ;
    rdfs:domain ind:Note ;
    rdf:type owl:DatatypeProperty ;
