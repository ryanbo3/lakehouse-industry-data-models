    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:acceptanceTypeId rdf:type rdf:Property ;
    rdfs:label 'Acceptance Type Id' ;
    rdfs:comment 'Foreign key linking to terminal.terminal_acceptance_type. Business justification: Terminal specifies acceptance type; no redundant columns.' ;
    rdfs:domain ind:Terminal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AcceptanceType .

ind:softwareId rdf:type rdf:Property ;
    rdfs:label 'Software Id' ;
    rdfs:comment 'Foreign key linking to terminal.terminal_software. Business justification: Direct link to installed software; removes duplicated version fields.' ;
    rdfs:domain ind:Terminal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Software .

ind:terminalGlAccountId rdf:type rdf:Property ;
    rdfs:label 'Terminal Gl Account Id' ;
    rdfs:comment 'Foreign key linking to ledger.gl_account. Business justification: REQUIRED: Daily settlement report posts terminal revenue to a specific GL account; terminals need a direct GL account reference for accurate posting.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:GlAccount .

ind:connectivityType rdf:type rdf:Property ;
    rdfs:label 'Connectivity Type' ;
    rdfs:comment 'Primary network connectivity method used by the terminal.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:decommissionDate rdf:type rdf:Property ;
    rdfs:label 'Decommission Date' ;
    rdfs:comment 'Date the terminal was retired or removed from service (null if still active).' ;
    rdfs:domain ind:Terminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:deploymentDate rdf:type rdf:Property ;
    rdfs:label 'Deployment Date' ;
    rdfs:comment 'Date the terminal was first installed at a merchant location.' ;
    rdfs:domain ind:Terminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deviceCertificationBody rdf:type rdf:Property ;
    rdfs:label 'Device Certification Body' ;
    rdfs:comment 'Organization that issued the terminal\'s security or compliance certification.' ;
    rdfs:domain ind:PosTerminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emvCapable rdf:type rdf:Property ;
    rdfs:label 'Emv Capable' ;
    rdfs:comment 'Indicates whether the terminal can process EMV chip card transactions.' ;
    rdfs:domain ind:Terminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:formFactor rdf:type rdf:Property ;
    rdfs:label 'Form Factor' ;
    rdfs:comment 'Physical deployment style of the terminal.' ;
    rdfs:domain ind:Terminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:hardwareModel rdf:type rdf:Property ;
    rdfs:label 'Hardware Model' ;
    rdfs:comment 'Model name/number of the terminal hardware as defined by the OEM.' ;
