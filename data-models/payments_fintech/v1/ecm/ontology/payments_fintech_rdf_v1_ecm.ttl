    rdfs:range xsd:string .

ind:replacementParts rdf:type rdf:Property ;
    rdfs:label 'Replacement Parts' ;
    rdfs:comment 'List of parts replaced during the maintenance activity.' ;
    rdfs:domain ind:Maintenance ;
