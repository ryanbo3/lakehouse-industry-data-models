ind:currencyPairId rdf:type rdf:Property ;
    rdfs:label 'Currency Pair Id' ;
    rdfs:comment 'Foreign key linking to fx.currency_pair. Business justification: FX-specific fraud rules are defined per currency pair; the rule must reference the pair for correct applicability.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CurrencyPair .

ind:primaryFraudEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Fraud Employee Id' ;
    rdfs:comment 'Internal user responsible for the rule\'s lifecycle and maintenance.' ;
    rdfs:domain ind:Fraud ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryFraudUpdatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Fraud Updated By User Employee Id' ;
    rdfs:comment 'Internal user who performed the latest update.' ;
    rdfs:domain ind:FraudRule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:updatedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Updated By User Employee Id' ;
    rdfs:comment 'Internal user who performed the latest update.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:walletSchemeId rdf:type rdf:Property ;
    rdfs:label 'Wallet Scheme Id' ;
    rdfs:comment 'Foreign key linking to wallet.wallet_scheme. Business justification: Fraud rules are often scoped to specific card schemes; associating a rule with a wallet scheme supports rule management and regulatory reporting.' ;
    rdfs:domain ind:PaymentsFintech ;
