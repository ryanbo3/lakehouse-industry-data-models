    rdfs:range xsd:string .

ind:institutionName rdf:type rdf:Property ;
    rdfs:label 'Institution Name' ;
    rdfs:comment 'Legal name of the financial institution associated with the BIC.' ;
    rdfs:domain ind:SwiftBic ;
    rdf:type owl:DatatypeProperty ;
