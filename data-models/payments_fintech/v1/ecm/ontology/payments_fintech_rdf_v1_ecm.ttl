    rdfs:comment 'Current processing status of the SWIFT message.' ;
    rdfs:domain ind:SwiftMessage ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:messageType rdf:type rdf:Property ;
    rdfs:label 'Message Type' ;
    rdfs:comment 'Type of SWIFT message according to SWIFT or ISO 20022 standards.' ;
    rdfs:domain ind:PaymentsFintech ;
