    rdfs:comment 'Cumulative amount spent on the instrument today, used to compare against daily_spend_limit.' ;
    rdfs:domain ind:InstrumentLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:ecommerceTransactionLimit rdf:type rdf:Property ;
    rdfs:label 'Ecommerce Transaction Limit' ;
    rdfs:comment 'Maximum amount for a single online purchase transaction.' ;
    rdfs:domain ind:InstrumentLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:instrumentLimitStatus rdf:type rdf:Property ;
    rdfs:label 'Instrument Limit Status' ;
    rdfs:comment 'Current lifecycle status of the limit configuration.' ;
    rdfs:domain ind:InstrumentLimit ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internationalTransactionLimit rdf:type rdf:Property ;
