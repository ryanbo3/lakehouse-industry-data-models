    rdfs:range xsd:integer .

ind:deviceSerialNumber rdf:type rdf:Property ;
    rdfs:label 'Device Serial Number' ;
    rdfs:comment 'Manufacturer-assigned serial number of the terminal hardware.' ;
    rdfs:domain ind:Terminal ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyExpiryDate rdf:type rdf:Property ;
    rdfs:label 'Key Expiry Date' ;
