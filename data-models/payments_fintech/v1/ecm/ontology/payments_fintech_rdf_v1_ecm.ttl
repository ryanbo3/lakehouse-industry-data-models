    rdfs:comment 'Identifier of the entity (typically the merchant) that initiates the 3-DS authentication request.' ;
    rdfs:domain ind:ThreedsConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:threedsConfigDescription rdf:type rdf:Property ;
    rdfs:label 'Threeds Config Description' ;
    rdfs:comment 'Free-form text describing the purpose and scope of the configuration.' ;
    rdfs:domain ind:ThreedsConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:threedsConfigStatus rdf:type rdf:Property ;
    rdfs:label 'Threeds Config Status' ;
    rdfs:comment 'Current lifecycle state of the 3-DS configuration.' ;
    rdfs:domain ind:ThreedsConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tlsCertificateId rdf:type rdf:Property ;
    rdfs:label 'Tls Certificate Id' ;
    rdfs:comment 'Unique system-generated identifier for the TLS/SSL certificate record.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TlsCertificate .

ind:autoRenewal rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal' ;
    rdfs:comment 'Indicates whether the certificate is set to renew automatically before expiry.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:certificateProfile rdf:type rdf:Property ;
    rdfs:label 'Certificate Profile' ;
    rdfs:comment 'Level of validation performed by the CA (Extended Validation, Organization Validation, Domain Validation, Self-Signed).' ;
    rdfs:domain ind:TlsCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:certificateType rdf:type rdf:Property ;
    rdfs:label 'Certificate Type' ;
    rdfs:comment 'Classification of the certificate purpose.' ;
    rdfs:domain ind:TlsCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:compliancePciDss rdf:type rdf:Property ;
    rdfs:label 'Compliance Pci Dss' ;
    rdfs:comment 'Indicates whether the certificate meets PCI DSS requirements for encryption.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:expirationAlertSent rdf:type rdf:Property ;
    rdfs:label 'Expiration Alert Sent' ;
    rdfs:comment 'Indicates whether an expiry alert has been sent to the operations team.' ;
    rdfs:domain ind:TlsCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:fingerprintSha256 rdf:type rdf:Property ;
    rdfs:label 'Fingerprint Sha256' ;
    rdfs:comment 'Hexadecimal SHA-256 hash of the certificate, used for integrity verification.' ;
    rdfs:domain ind:TlsCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:isWildcard rdf:type rdf:Property ;
    rdfs:label 'Is Wildcard' ;
    rdfs:comment 'True if the certificate covers a wildcard domain (e.g., *.paymentsfintech.com).' ;
    rdfs:domain ind:TlsCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:keyAlgorithm rdf:type rdf:Property ;
    rdfs:label 'Key Algorithm' ;
    rdfs:comment 'Cryptographic algorithm used for the public key, e.g., RSA or ECDSA.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:keyLengthBits rdf:type rdf:Property ;
    rdfs:label 'Key Length Bits' ;
    rdfs:comment 'Size of the public key in bits, e.g., 2048, 3072, 4096.' ;
    rdfs:domain ind:TlsCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:lastCheckedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Checked Timestamp' ;
    rdfs:comment 'Timestamp of the most recent successful health-check of the certificate\'s endpoint.' ;
    rdfs:domain ind:TlsCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:locality rdf:type rdf:Property ;
    rdfs:label 'Locality' ;
    rdfs:comment 'City component of the certificate subject.' ;
    rdfs:domain ind:TlsCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organizationName rdf:type rdf:Property ;
    rdfs:label 'Organization Name' ;
    rdfs:comment 'Legal organization name extracted from the certificate subject.' ;
    rdfs:domain ind:TlsCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:organizationalUnit rdf:type rdf:Property ;
    rdfs:label 'Organizational Unit' ;
    rdfs:comment 'Organizational unit (OU) component of the certificate subject.' ;
    rdfs:domain ind:TlsCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:renewalDueDate rdf:type rdf:Property ;
    rdfs:label 'Renewal Due Date' ;
    rdfs:comment 'Date by which the certificate should be renewed to avoid service interruption.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:revocationStatus rdf:type rdf:Property ;
    rdfs:label 'Revocation Status' ;
    rdfs:comment 'Current revocation state of the certificate.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:serialNumber rdf:type rdf:Property ;
    rdfs:label 'Serial Number' ;
    rdfs:comment 'Unique serial number assigned by the issuing CA, used to identify the certificate.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:stateOrProvince rdf:type rdf:Property ;
    rdfs:label 'State Or Province' ;
    rdfs:comment 'State or province component of the certificate subject.' ;
    rdfs:domain ind:TlsCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:thumbprint rdf:type rdf:Property ;
    rdfs:label 'Thumbprint' ;
    rdfs:comment 'Legacy SHA-1 hash of the certificate, often used by older systems.' ;
    rdfs:domain ind:TlsCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tlsCertificateStatus rdf:type rdf:Property ;
    rdfs:label 'Tls Certificate Status' ;
    rdfs:comment 'Current lifecycle status of the certificate within the gateway.' ;
    rdfs:domain ind:TlsCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:usage rdf:type rdf:Property ;
    rdfs:label 'Usage' ;
    rdfs:comment 'Indicates whether the certificate is used for inbound, outbound, or both traffic.' ;
    rdfs:domain ind:TlsCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:validFrom rdf:type rdf:Property ;
    rdfs:label 'Valid From' ;
    rdfs:comment 'Date on which the certificate becomes valid.' ;
    rdfs:domain ind:TlsCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:validTo rdf:type rdf:Property ;
    rdfs:label 'Valid To' ;
    rdfs:comment 'Date on which the certificate expires and must be renewed.' ;
    rdfs:domain ind:TlsCertificate ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tokenizationRequestId rdf:type rdf:Property ;
    rdfs:label 'Tokenization Request Id' ;
    rdfs:comment 'Unique system-generated identifier for the tokenization request record.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TokenizationRequest .

ind:assuranceLevel rdf:type rdf:Property ;
    rdfs:label 'Assurance Level' ;
    rdfs:comment 'Level of confidence in the tokenization process, reflecting authentication strength.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudReason rdf:type rdf:Property ;
    rdfs:label 'Fraud Reason' ;
    rdfs:comment 'Reason or rule that triggered the fraud flag.' ;
    rdfs:domain ind:TokenizationRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:outcomeStatus rdf:type rdf:Property ;
    rdfs:label 'Outcome Status' ;
    rdfs:comment 'Result of the tokenization request: success, failure, or partial (e.g., token created but with warnings).' ;
    rdfs:domain ind:TokenizationRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:panHash rdf:type rdf:Property ;
    rdfs:label 'Pan Hash' ;
    rdfs:comment 'Cryptographic hash of the PAN; stored to avoid retaining raw PAN data.' ;
    rdfs:domain ind:TokenizationRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestChannel rdf:type rdf:Property ;
    rdfs:label 'Request Channel' ;
    rdfs:comment 'Channel through which the request was made (web, mobile app, POS, mPOS).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:requestReference rdf:type rdf:Property ;
    rdfs:label 'Request Reference' ;
    rdfs:comment 'External reference supplied by the merchant to correlate the tokenization request with their own systems.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:slaAchievedFlag rdf:type rdf:Property ;
    rdfs:label 'Sla Achieved Flag' ;
    rdfs:comment 'True if processing latency met or beat the SLA target.' ;
    rdfs:domain ind:TokenizationRequest ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tokenValue rdf:type rdf:Property ;
    rdfs:label 'Token Value' ;
    rdfs:comment 'The actual token string issued to replace the PAN; treated as PCI-sensitive data.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:webhookDeliveryId rdf:type rdf:Property ;
    rdfs:label 'Webhook Delivery Id' ;
    rdfs:comment 'System-generated unique identifier for each webhook delivery attempt.' ;
    rdfs:domain ind:WebhookDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:webhookSubscriptionId rdf:type rdf:Property ;
    rdfs:label 'Webhook Subscription Id' ;
    rdfs:comment 'Identifier of the merchant subscription that defines the webhook endpoint and event filters.' ;
    rdfs:domain ind:Gateway ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:WebhookSubscription .

ind:httpStatusCode rdf:type rdf:Property ;
    rdfs:label 'Http Status Code' ;
    rdfs:comment 'HTTP response status code returned by the merchant endpoint.' ;
    rdfs:domain ind:WebhookDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:isFinalAttempt rdf:type rdf:Property ;
    rdfs:label 'Is Final Attempt' ;
    rdfs:comment 'True if this attempt is the last allowed retry.' ;
    rdfs:domain ind:WebhookDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:maxAttempts rdf:type rdf:Property ;
    rdfs:label 'Max Attempts' ;
    rdfs:comment 'Configured maximum number of retry attempts allowed for the webhook.' ;
    rdfs:domain ind:WebhookDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:nextRetryTimestamp rdf:type rdf:Property ;
    rdfs:label 'Next Retry Timestamp' ;
    rdfs:comment 'Scheduled timestamp for the next retry attempt when the previous delivery failed.' ;
    rdfs:domain ind:WebhookDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:payloadHash rdf:type rdf:Property ;
    rdfs:label 'Payload Hash' ;
    rdfs:comment 'SHA-256 hash of the webhook payload to verify integrity.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseBodySnippet rdf:type rdf:Property ;
    rdfs:label 'Response Body Snippet' ;
    rdfs:comment 'Truncated portion of the HTTP response body for diagnostic purposes.' ;
    rdfs:domain ind:WebhookDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:responseLatencyMs rdf:type rdf:Property ;
    rdfs:label 'Response Latency Ms' ;
    rdfs:comment 'Round-trip time in milliseconds between sending the webhook and receiving the HTTP response.' ;
    rdfs:domain ind:WebhookDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:successFlag rdf:type rdf:Property ;
    rdfs:label 'Success Flag' ;
    rdfs:comment 'Indicates whether the webhook delivery was successful (true) or not (false).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:throttlingFlag rdf:type rdf:Property ;
    rdfs:label 'Throttling Flag' ;
    rdfs:comment 'Indicates whether delivery was delayed due to rate-limiting.' ;
    rdfs:domain ind:WebhookDelivery ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:authenticationSecret rdf:type rdf:Property ;
    rdfs:label 'Authentication Secret' ;
    rdfs:comment 'Secret key or token used with the selected authentication method (e.g., HMAC secret, OAuth bearer token).' ;
    rdfs:domain ind:WebhookSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:backoffStrategy rdf:type rdf:Property ;
    rdfs:label 'Backoff Strategy' ;
    rdfs:comment 'Algorithm used to calculate delay between successive retries.' ;
    rdfs:domain ind:WebhookSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:encryptionEnabled rdf:type rdf:Property ;
    rdfs:label 'Encryption Enabled' ;
    rdfs:comment 'Indicates whether the payload is encrypted at rest or in transit.' ;
    rdfs:domain ind:WebhookSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:encryptionKeyReference rdf:type rdf:Property ;
    rdfs:label 'Encryption Key Reference' ;
    rdfs:comment 'Identifier of the encryption key used to protect the payload.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:eventTypes rdf:type rdf:Property ;
    rdfs:label 'Event Types' ;
    rdfs:comment 'Comma-separated list of event identifiers (e.g., authorization.approved,capture.completed) the subscriber wishes to receive.' ;
    rdfs:domain ind:WebhookSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ipAllowlist rdf:type rdf:Property ;
    rdfs:label 'Ip Allowlist' ;
    rdfs:comment 'Comma-separated list of IP address ranges permitted to receive webhook calls.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maxRetryAttempts rdf:type rdf:Property ;
    rdfs:label 'Max Retry Attempts' ;
    rdfs:comment 'Maximum number of retry attempts before the subscription is marked failed.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:notificationEndpointType rdf:type rdf:Property ;
    rdfs:label 'Notification Endpoint Type' ;
    rdfs:comment 'Transport mechanism for the webhook (e.g., HTTP, HTTPS, message queue).' ;
    rdfs:domain ind:WebhookSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:payloadFormat rdf:type rdf:Property ;
    rdfs:label 'Payload Format' ;
    rdfs:comment 'Format of the webhook payload delivered to the target URL.' ;
    rdfs:domain ind:WebhookSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:retryBackoffSeconds rdf:type rdf:Property ;
    rdfs:label 'Retry Backoff Seconds' ;
    rdfs:comment 'Base number of seconds used in backoff calculations between retries.' ;
    rdfs:domain ind:WebhookSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:slaResponseTimeSeconds rdf:type rdf:Property ;
    rdfs:label 'Sla Response Time Seconds' ;
    rdfs:comment 'Target maximum time (in seconds) for the webhook endpoint to acknowledge a delivery.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:subscriptionCode rdf:type rdf:Property ;
    rdfs:label 'Subscription Code' ;
    rdfs:comment 'Business-facing code used to reference the subscription in external systems and documentation.' ;
    rdfs:domain ind:WebhookSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriptionName rdf:type rdf:Property ;
    rdfs:label 'Subscription Name' ;
    rdfs:comment 'Human-readable name for the webhook subscription.' ;
    rdfs:domain ind:WebhookSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:subscriptionType rdf:type rdf:Property ;
    rdfs:label 'Subscription Type' ;
    rdfs:comment 'Broad classification of the subscription purpose.' ;
    rdfs:domain ind:WebhookSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:targetUrl rdf:type rdf:Property ;
    rdfs:label 'Target Url' ;
    rdfs:comment 'Fully qualified HTTPS endpoint where event notifications are delivered.' ;
    rdfs:domain ind:WebhookSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:webhookSecretHash rdf:type rdf:Property ;
    rdfs:label 'Webhook Secret Hash' ;
    rdfs:comment 'Hash of the secret used for HMAC verification of incoming webhook calls.' ;
    rdfs:domain ind:WebhookSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:webhookSubscriptionDescription rdf:type rdf:Property ;
    rdfs:label 'Webhook Subscription Description' ;
    rdfs:comment 'Optional free-form description providing context about the subscription purpose.' ;
    rdfs:domain ind:WebhookSubscription ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acquiringPortfolioPricingId rdf:type rdf:Property ;
    rdfs:label 'Acquiring Portfolio Pricing Id' ;
    rdfs:comment 'System-generated unique identifier for each acquiring portfolio pricing record.' ;
    rdfs:domain ind:Interchange ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AcquiringPortfolioPricing .

ind:appetiteFrameworkId rdf:type rdf:Property ;
    rdfs:label 'Appetite Framework Id' ;
    rdfs:comment 'Foreign key linking to risk.risk_appetite_framework. Business justification: Portfolio pricing rules are governed by the firm’s risk appetite framework; FK provides direct reference for compliance reporting.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AppetiteFramework .

ind:durbinComplianceTierId rdf:type rdf:Property ;
    rdfs:label 'Durbin Compliance Tier Id' ;
    rdfs:comment 'Foreign key linking to interchange.durbin_compliance_tier. Business justification: acquiring_portfolio_pricing may be governed by a Durbin compliance tier; adds durbin_compliance_tier_id FK' ;
    rdfs:domain ind:Interchange ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:DurbinComplianceTier .

ind:portfolioId rdf:type rdf:Property ;
    rdfs:label 'Portfolio Id' ;
    rdfs:comment 'Identifier of the acquiring portfolio to which this pricing configuration applies.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Portfolio .

ind:programId rdf:type rdf:Property ;
    rdfs:label 'Program Id' ;
    rdfs:comment 'Foreign key linking to interchange.interchange_program. Business justification: Acquiring portfolio pricing can be associated with a specific interchange program; adds interchange_program_id FK' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Program .

ind:acquiringPortfolioPricingDescription rdf:type rdf:Property ;
    rdfs:label 'Acquiring Portfolio Pricing Description' ;
    rdfs:comment 'Free-form description of the pricing contract purpose and scope.' ;
    rdfs:domain ind:AcquiringPortfolioPricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:approvalRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Approval Required Flag' ;
    rdfs:comment 'Indicates whether changes to this pricing contract require formal approval.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:baseInterchangePassThroughFlag rdf:type rdf:Property ;
    rdfs:label 'Base Interchange Pass Through Flag' ;
    rdfs:comment 'Indicates whether the base interchange fee is passed through to the merchant without markup.' ;
    rdfs:domain ind:AcquiringPortfolioPricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:complianceReviewTimestamp rdf:type rdf:Property ;
    rdfs:label 'Compliance Review Timestamp' ;
    rdfs:comment 'Timestamp of the latest compliance review for this pricing contract.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:durbinRegulatedFlag rdf:type rdf:Property ;
    rdfs:label 'Durbin Regulated Flag' ;
    rdfs:comment 'True if the pricing is subject to the Durbin Amendment regulations.' ;
    rdfs:domain ind:Interchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isDefaultPricing rdf:type rdf:Property ;
    rdfs:label 'Is Default Pricing' ;
    rdfs:comment 'True if this pricing configuration is the default for the portfolio.' ;
    rdfs:domain ind:AcquiringPortfolioPricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isPortfolioLevel rdf:type rdf:Property ;
    rdfs:label 'Is Portfolio Level' ;
    rdfs:comment 'Indicates whether the pricing applies at the portfolio level (vs. individual merchant level).' ;
    rdfs:domain ind:AcquiringPortfolioPricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:markupBasisPoints rdf:type rdf:Property ;
    rdfs:label 'Markup Basis Points' ;
    rdfs:comment 'Number of basis points added as markup on top of the base interchange rate.' ;
    rdfs:domain ind:AcquiringPortfolioPricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:monthlyMinimumAmount rdf:type rdf:Property ;
    rdfs:label 'Monthly Minimum Amount' ;
    rdfs:comment 'Minimum monthly revenue that must be generated under the pricing contract.' ;
    rdfs:domain ind:AcquiringPortfolioPricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:perTransactionMarkupAmount rdf:type rdf:Property ;
    rdfs:label 'Per Transaction Markup Amount' ;
    rdfs:comment 'Flat amount added to each transaction as a markup.' ;
    rdfs:domain ind:AcquiringPortfolioPricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricingApplicationScope rdf:type rdf:Property ;
    rdfs:label 'Pricing Application Scope' ;
    rdfs:comment 'Scope of transactions to which this pricing configuration applies.' ;
    rdfs:domain ind:AcquiringPortfolioPricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingChangeReason rdf:type rdf:Property ;
    rdfs:label 'Pricing Change Reason' ;
    rdfs:comment 'Business reason for the most recent change to the pricing configuration.' ;
    rdfs:domain ind:AcquiringPortfolioPricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingContractCode rdf:type rdf:Property ;
    rdfs:label 'Pricing Contract Code' ;
    rdfs:comment 'Business-visible code or reference number for the pricing contract.' ;
    rdfs:domain ind:AcquiringPortfolioPricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingCurrencyConversionRate rdf:type rdf:Property ;
    rdfs:label 'Pricing Currency Conversion Rate' ;
    rdfs:comment 'Conversion rate used when pricing is expressed in a currency different from the settlement currency.' ;
    rdfs:domain ind:AcquiringPortfolioPricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricingMarginType rdf:type rdf:Property ;
    rdfs:label 'Pricing Margin Type' ;
    rdfs:comment 'Indicates whether the margin is expressed as a percentage or a fixed amount.' ;
    rdfs:domain ind:AcquiringPortfolioPricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingMarginValue rdf:type rdf:Property ;
    rdfs:label 'Pricing Margin Value' ;
    rdfs:comment 'Numeric value of the margin, interpreted according to pricing_margin_type.' ;
    rdfs:domain ind:AcquiringPortfolioPricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricingModelType rdf:type rdf:Property ;
    rdfs:label 'Pricing Model Type' ;
    rdfs:comment 'Type of pricing model applied to the portfolio (e.g., interchange-plus, flat-rate, tiered, volume-based).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Pricing Source System' ;
    rdfs:comment 'Source system that supplied the pricing configuration.' ;
    rdfs:domain ind:AcquiringPortfolioPricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeTier1MarkupBasisPoints rdf:type rdf:Property ;
    rdfs:label 'Volume Tier 1 Markup Basis Points' ;
    rdfs:comment 'Markup in basis points applied when transaction volume reaches tier 1.' ;
    rdfs:domain ind:AcquiringPortfolioPricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:volumeTier1Threshold rdf:type rdf:Property ;
    rdfs:label 'Volume Tier 1 Threshold' ;
    rdfs:comment 'Transaction count threshold for the first volume-based pricing tier.' ;
    rdfs:domain ind:AcquiringPortfolioPricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:volumeTier2MarkupBasisPoints rdf:type rdf:Property ;
    rdfs:label 'Volume Tier 2 Markup Basis Points' ;
    rdfs:comment 'Markup in basis points applied when transaction volume reaches tier 2.' ;
    rdfs:domain ind:AcquiringPortfolioPricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:volumeTier2Threshold rdf:type rdf:Property ;
    rdfs:label 'Volume Tier 2 Threshold' ;
    rdfs:comment 'Transaction count threshold for the second volume-based pricing tier.' ;
    rdfs:domain ind:AcquiringPortfolioPricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:binInterchangeRuleId rdf:type rdf:Property ;
    rdfs:label 'Bin Interchange Rule Id' ;
    rdfs:comment 'Unique surrogate primary key identifying a BIN-level interchange qualification rule record in the silver layer lakehouse. Entity role: MASTER_RESOURCE — represents a configuration/rule resource governing interchange qualification for a BIN range.' ;
    rdfs:domain ind:BinInterchangeRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supersededByRuleBinInterchangeRuleId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Rule Bin Interchange Rule Id' ;
    rdfs:comment 'Reference to the bin_interchange_rule_id of the newer rule that supersedes this record when rule_status is \'superseded\'. Enables rule lineage tracking and historical interchange qualification reconstruction.' ;
    rdfs:domain ind:BinInterchangeRule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:BinInterchangeRule .

ind:authorizationIndicator rdf:type rdf:Property ;
    rdfs:label 'Authorization Indicator' ;
    rdfs:comment 'Specifies the type of authorization associated with this interchange rule: pre-authorization (hotel/car rental), final authorization, or incremental authorization. Different authorization types may qualify for distinct interchange rates.' ;
    rdfs:domain ind:BinInterchangeRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:avsRequired rdf:type rdf:Property ;
    rdfs:label 'Avs Required' ;
    rdfs:comment 'Indicates whether Address Verification System (AVS) check is required for a transaction to qualify for this interchange rate category. AVS validation is a fraud prevention measure commonly required for card-not-present interchange qualification.' ;
    rdfs:domain ind:Interchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cardNotPresentEligible rdf:type rdf:Property ;
    rdfs:label 'Card Not Present Eligible' ;
    rdfs:comment 'Indicates whether this interchange rule applies to card-not-present (CNP) transactions, such as e-commerce, mail order, or telephone order (MOTO) transactions. CNP transactions typically carry higher interchange rates due to elevated fraud risk.' ;
    rdfs:domain ind:Interchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cardPresentEligible rdf:type rdf:Property ;
    rdfs:label 'Card Present Eligible' ;
    rdfs:comment 'Indicates whether this interchange rule applies to card-present (CP) transactions, where the physical card or device is used at a POS or mPOS terminal. Card-present transactions typically qualify for lower interchange rates than card-not-present.' ;
    rdfs:domain ind:Interchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cardProductType rdf:type rdf:Property ;
    rdfs:label 'Card Product Type' ;
    rdfs:comment 'Classification of the card product associated with this BIN range, determining the applicable interchange rate tier. Debit and prepaid cards may be subject to Durbin Amendment regulated caps; commercial and government cards follow separate interchange schedules. Serves as the primary CLASSIFICATION_OR_TYPE for this MASTER_RESOURCE entity. [ENUM-REF-CANDIDATE: debit|credit|prepaid|commercial|government|healthcare — promote to reference product]' ;
    rdfs:domain ind:Interchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactlessEligible rdf:type rdf:Property ;
    rdfs:label 'Contactless Eligible' ;
    rdfs:comment 'Indicates whether this interchange rule applies to contactless NFC (Near Field Communication) transactions, including tap-to-pay and mobile wallet payments. Contactless qualification may carry distinct interchange rates from contact chip transactions.' ;
    rdfs:domain ind:Interchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:crossBorderFlag rdf:type rdf:Property ;
    rdfs:label 'Cross Border Flag' ;
    rdfs:comment 'Indicates whether this interchange rule applies specifically to cross-border transactions where the issuing country differs from the acquiring country. Cross-border transactions typically attract higher interchange rates and additional scheme fees.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:dataQualityIndicator rdf:type rdf:Property ;
    rdfs:label 'Data Quality Indicator' ;
    rdfs:comment 'Indicates the level of transaction data (Level 1, Level 2, Level 3) required for interchange qualification under this rule. Level 2/3 data (enhanced transaction detail for B2B/commercial cards) may qualify for lower interchange rates.' ;
    rdfs:domain ind:Interchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:durbinExemptReason rdf:type rdf:Property ;
    rdfs:label 'Durbin Exempt Reason' ;
    rdfs:comment 'Reason code explaining why a BIN range is exempt from Durbin Amendment regulated interchange caps. Applicable only when durbin_regulated_flag is False. Small issuers (assets < $10B), government-administered programs, and certain prepaid products qualify for exemption.' ;
    rdfs:domain ind:Interchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emvChipRequired rdf:type rdf:Property ;
    rdfs:label 'Emv Chip Required' ;
    rdfs:comment 'Indicates whether EMV (Europay Mastercard Visa) chip processing is required for a transaction to qualify for this interchange rate category. EMV chip transactions reduce fraud liability and may qualify for preferential interchange rates.' ;
    rdfs:domain ind:Interchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:installmentEligible rdf:type rdf:Property ;
    rdfs:label 'Installment Eligible' ;
    rdfs:comment 'Indicates whether this interchange rule applies to installment payment transactions, including BNPL (Buy Now Pay Later) arrangements. Installment transactions may carry distinct interchange qualification criteria.' ;
    rdfs:domain ind:Interchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interchangeFeeCurrency rdf:type rdf:Property ;
    rdfs:label 'Interchange Fee Currency' ;
    rdfs:comment 'ISO 4217 three-letter currency code in which the interchange fixed fee is denominated (e.g., USD, EUR, GBP). Required for cross-border interchange cost calculations and multi-currency acquiring portfolios.' ;
    rdfs:domain ind:Interchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interchangeFixedFee rdf:type rdf:Property ;
    rdfs:label 'Interchange Fixed Fee' ;
    rdfs:comment 'The fixed per-transaction fee component of the interchange, expressed in the applicable currency (e.g., 0.1000 = $0.10 per transaction). Combined with interchange_rate_percent to compute total interchange cost per transaction.' ;
    rdfs:domain ind:Interchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interchangeRatePercent rdf:type rdf:Property ;
    rdfs:label 'Interchange Rate Percent' ;
    rdfs:comment 'The percentage-based component of the interchange fee applied to the transaction amount for qualifying transactions under this BIN rule (e.g., 1.6500 represents 1.65%). Used in cost-of-acceptance calculations for acquiring portfolios. Serves as the MEASUREMENT_OR_VALUE for this MASTER_RESOURCE entity.' ;
    rdfs:domain ind:Interchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mccList rdf:type rdf:Property ;
    rdfs:label 'Mcc List' ;
    rdfs:comment 'Comma-separated list of MCC (Merchant Category Code) values that are included or excluded from this interchange rule, as determined by mcc_restriction_type. For example, \'5411,5412,5499\' for grocery MCCs. Null when mcc_restriction_type is \'all\'.' ;
    rdfs:domain ind:Interchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mccRestrictionType rdf:type rdf:Property ;
    rdfs:label 'Mcc Restriction Type' ;
    rdfs:comment 'Defines how MCC (Merchant Category Code) restrictions apply to this interchange rule: \'all\' means no MCC restriction (applies to all MCCs), \'include\' means only specified MCCs qualify, \'exclude\' means specified MCCs are excluded, \'none\' means no transactions qualify regardless of MCC.' ;
    rdfs:domain ind:Interchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recurringEligible rdf:type rdf:Property ;
    rdfs:label 'Recurring Eligible' ;
    rdfs:comment 'Indicates whether this interchange rule applies to recurring or subscription-based transactions. Recurring transactions may qualify for specific interchange programs with distinct rate structures.' ;
    rdfs:domain ind:Interchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:schemeProgramCode rdf:type rdf:Property ;
    rdfs:label 'Scheme Program Code' ;
    rdfs:comment 'Card scheme-assigned program code identifying the specific interchange program under which this rule is classified (e.g., \'CPS/RETAIL\', \'EIRF\', \'MERIT III\', \'WORLD\', \'SIGNATURE\'). Used for interchange qualification matching in the transaction processing platform.' ;
    rdfs:domain ind:Interchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemRuleRef rdf:type rdf:Property ;
    rdfs:label 'Source System Rule Ref' ;
    rdfs:comment 'The native rule identifier or reference code from the originating operational system (Transaction Processing Platform or Payment Gateway) from which this BIN interchange rule was sourced. Supports data lineage and reconciliation back to the system of record.' ;
    rdfs:domain ind:BinInterchangeRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:threeDsRequired rdf:type rdf:Property ;
    rdfs:label 'Three Ds Required' ;
    rdfs:comment 'Indicates whether 3-D Secure (3DS) authentication is required for card-not-present transactions to qualify for this interchange rate. 3DS-authenticated transactions may qualify for lower interchange rates and shift fraud liability to the issuer. Relevant under PSD2 SCA requirements.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:tokenizationEligible rdf:type rdf:Property ;
    rdfs:label 'Tokenization Eligible' ;
    rdfs:comment 'Indicates whether transactions using a DPAN (Device Primary Account Number) or network token issued by a TSP (Token Service Provider) for this BIN range are eligible for this interchange rate. Tokenized transactions may qualify for distinct interchange rates.' ;
    rdfs:domain ind:Interchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transactionMaxAmount rdf:type rdf:Property ;
    rdfs:label 'Transaction Max Amount' ;
    rdfs:comment 'Maximum transaction amount (in the fee currency) eligible for this interchange rate category. Transactions exceeding this threshold may be subject to different interchange rates or require additional qualification criteria.' ;
    rdfs:domain ind:Interchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionMinAmount rdf:type rdf:Property ;
    rdfs:label 'Transaction Min Amount' ;
    rdfs:comment 'Minimum transaction amount (in the fee currency) required for a transaction to qualify for this interchange rate category. Transactions below this threshold may downgrade to a less favorable interchange tier.' ;
    rdfs:domain ind:Interchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costOfAcceptanceId rdf:type rdf:Property ;
    rdfs:label 'Cost Of Acceptance Id' ;
    rdfs:comment 'Unique identifier for the cost of acceptance record.' ;
    rdfs:domain ind:CostOfAcceptance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:msfScheduleId rdf:type rdf:Property ;
    rdfs:label 'Msf Schedule Id' ;
    rdfs:comment 'Foreign key linking to interchange.msf_schedule. Business justification: cost_of_acceptance aggregates fees for a merchant schedule; adds msf_schedule_id FK' ;
    rdfs:domain ind:Interchange ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MsfSchedule .

ind:settlementPeriodId rdf:type rdf:Property ;
    rdfs:label 'Settlement Period Id' ;
    rdfs:comment 'Reference to the settlement period during which these costs were incurred.' ;
    rdfs:domain ind:Interchange ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccountingPeriod .

ind:averageTicketSize rdf:type rdf:Property ;
    rdfs:label 'Average Ticket Size' ;
    rdfs:comment 'Average transaction amount calculated as gross transaction volume divided by transaction count.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:binRangeCount rdf:type rdf:Property ;
    rdfs:label 'Bin Range Count' ;
    rdfs:comment 'Number of distinct Bank Identification Number (BIN) or Issuer Identification Number (IIN) ranges represented in the transactions for this settlement period.' ;
    rdfs:domain ind:CostOfAcceptance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:calculationDate rdf:type rdf:Property ;
    rdfs:label 'Calculation Date' ;
    rdfs:comment 'The date on which the cost of acceptance calculation was performed.' ;
    rdfs:domain ind:CostOfAcceptance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:cardNotPresentVolume rdf:type rdf:Property ;
    rdfs:label 'Card Not Present Volume' ;
    rdfs:comment 'Total transaction volume for card-not-present (CNP) transactions processed via e-commerce, mail order, or telephone order channels.' ;
    rdfs:domain ind:CostOfAcceptance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cardPresentVolume rdf:type rdf:Property ;
    rdfs:label 'Card Present Volume' ;
    rdfs:comment 'Total transaction volume for card-present (CP) transactions processed via Point of Sale (POS) or mobile Point of Sale (mPOS) terminals.' ;
    rdfs:domain ind:CostOfAcceptance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chargebackVolume rdf:type rdf:Property ;
    rdfs:label 'Chargeback Volume' ;
    rdfs:comment 'Total transaction volume associated with chargebacks initiated during the settlement period, impacting net margin calculations.' ;
    rdfs:domain ind:CostOfAcceptance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costOfAcceptanceStatus rdf:type rdf:Property ;
    rdfs:label 'Cost Of Acceptance Status' ;
    rdfs:comment 'Current lifecycle status of the cost of acceptance record indicating its processing state.' ;
    rdfs:domain ind:CostOfAcceptance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:creditCardVolume rdf:type rdf:Property ;
    rdfs:label 'Credit Card Volume' ;
    rdfs:comment 'Total transaction volume processed using credit cards during the settlement period.' ;
    rdfs:domain ind:CostOfAcceptance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:crossBorderVolume rdf:type rdf:Property ;
    rdfs:label 'Cross Border Volume' ;
    rdfs:comment 'Total transaction volume for cross-border transactions where the issuing bank country differs from the acquiring bank country.' ;
    rdfs:domain ind:CostOfAcceptance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:debitCardVolume rdf:type rdf:Property ;
    rdfs:label 'Debit Card Volume' ;
    rdfs:comment 'Total transaction volume processed using debit cards during the settlement period.' ;
    rdfs:domain ind:CostOfAcceptance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:domesticVolume rdf:type rdf:Property ;
    rdfs:label 'Domestic Volume' ;
    rdfs:comment 'Total transaction volume for domestic transactions where the issuing bank and acquiring bank are in the same country.' ;
    rdfs:domain ind:CostOfAcceptance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:effectiveRateBps rdf:type rdf:Property ;
    rdfs:label 'Effective Rate Bps' ;
    rdfs:comment 'Effective cost of acceptance rate expressed in basis points (bps), calculated as (total cost / gross transaction volume) * 10000.' ;
    rdfs:domain ind:CostOfAcceptance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:grossTransactionVolume rdf:type rdf:Property ;
    rdfs:label 'Gross Transaction Volume' ;
    rdfs:comment 'Total Payment Volume (TPV) representing the gross value of all transactions processed during the settlement period before any fees or deductions.' ;
    rdfs:domain ind:CostOfAcceptance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interchangeQualificationTier rdf:type rdf:Property ;
    rdfs:label 'Interchange Qualification Tier' ;
    rdfs:comment 'The interchange qualification tier applied to the majority of transactions in this settlement period, determining the IRF rate structure.' ;
    rdfs:domain ind:Interchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mdrPercentage rdf:type rdf:Property ;
    rdfs:label 'Mdr Percentage' ;
    rdfs:comment 'Merchant Discount Rate (MDR) percentage applied to the merchant for this settlement period, representing the total fee as a percentage of transaction volume.' ;
    rdfs:domain ind:CostOfAcceptance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netMargin rdf:type rdf:Property ;
    rdfs:label 'Net Margin' ;
    rdfs:comment 'Net margin calculated as total MSF revenue minus total interchange cost and total scheme fees, representing the acquiring portfolio profitability.' ;
    rdfs:domain ind:CostOfAcceptance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:refundVolume rdf:type rdf:Property ;
    rdfs:label 'Refund Volume' ;
    rdfs:comment 'Total transaction volume associated with refunds processed during the settlement period.' ;
    rdfs:domain ind:CostOfAcceptance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementEndDate rdf:type rdf:Property ;
    rdfs:label 'Settlement End Date' ;
    rdfs:comment 'The end date of the settlement period covered by this cost of acceptance record.' ;
    rdfs:domain ind:CostOfAcceptance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:settlementStartDate rdf:type rdf:Property ;
    rdfs:label 'Settlement Start Date' ;
    rdfs:comment 'The start date of the settlement period covered by this cost of acceptance record.' ;
    rdfs:domain ind:CostOfAcceptance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:totalInterchangeCost rdf:type rdf:Property ;
    rdfs:label 'Total Interchange Cost' ;
    rdfs:comment 'Total Interchange Reimbursement Fee (IRF) paid to issuing banks for all transactions during the settlement period.' ;
    rdfs:domain ind:CostOfAcceptance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalMsfRevenue rdf:type rdf:Property ;
    rdfs:label 'Total Msf Revenue' ;
    rdfs:comment 'Total Merchant Service Fee (MSF) revenue collected from the merchant for payment processing services during the settlement period.' ;
    rdfs:domain ind:CostOfAcceptance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalSchemeFees rdf:type rdf:Property ;
    rdfs:label 'Total Scheme Fees' ;
    rdfs:comment 'Total assessment fees charged by card schemes (Visa, Mastercard, etc.) for network usage during the settlement period.' ;
    rdfs:domain ind:CostOfAcceptance ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:crossBorderFeeRuleId rdf:type rdf:Property ;
    rdfs:label 'Cross Border Fee Rule Id' ;
    rdfs:comment 'Unique identifier for the cross-border fee rule record. Primary key for this entity.' ;
    rdfs:domain ind:CrossBorderFeeRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supersededByRuleCrossBorderFeeRuleId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Rule Cross Border Fee Rule Id' ;
    rdfs:comment 'Reference to the cross-border fee rule that replaces this rule when it is superseded. Supports rule lineage and historical analysis.' ;
    rdfs:domain ind:CrossBorderFeeRule ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:CrossBorderFeeRule .

ind:cardPresentIndicator rdf:type rdf:Property ;
    rdfs:label 'Card Present Indicator' ;
    rdfs:comment 'Indicates whether this cross-border fee rule applies to card-present transactions (physical POS) or card-not-present transactions (e-commerce, MOTO).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossBorderAssessmentRatePercent rdf:type rdf:Property ;
    rdfs:label 'Cross Border Assessment Rate Percent' ;
    rdfs:comment 'Percentage-based cross-border assessment fee applied to the transaction amount when the issuing country differs from the acquiring country. Expressed as a decimal percentage (e.g., 1.25000 for 1.25%).' ;
    rdfs:domain ind:CrossBorderFeeRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:crossBorderFixedFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Cross Border Fixed Fee Amount' ;
    rdfs:comment 'Fixed monetary fee applied per cross-border transaction, independent of transaction amount. Used in conjunction with or as an alternative to percentage-based fees.' ;
    rdfs:domain ind:CrossBorderFeeRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:currencyConversionFeeRatePercent rdf:type rdf:Property ;
    rdfs:label 'Currency Conversion Fee Rate Percent' ;
    rdfs:comment 'Percentage-based fee applied when currency conversion occurs in a cross-border transaction. Represents the FX markup over the wholesale exchange rate.' ;
    rdfs:domain ind:CrossBorderFeeRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:dccFeeRatePercent rdf:type rdf:Property ;
    rdfs:label 'Dcc Fee Rate Percent' ;
    rdfs:comment 'Fee rate applied when Dynamic Currency Conversion is offered at the point of sale, allowing the cardholder to see the transaction amount in their home currency.' ;
    rdfs:domain ind:CrossBorderFeeRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:destinationRegionCode rdf:type rdf:Property ;
    rdfs:label 'Destination Region Code' ;
    rdfs:comment 'Regional grouping code for the destination country used for regional cross-border fee structures and compliance segmentation.' ;
    rdfs:domain ind:CrossBorderFeeRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originatingCountryCode rdf:type rdf:Property ;
    rdfs:label 'Originating Country Code' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code representing the country where the transaction originates (typically the acquiring country or merchant location country).' ;
    rdfs:domain ind:CrossBorderFeeRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originatingRegionCode rdf:type rdf:Property ;
    rdfs:label 'Originating Region Code' ;
    rdfs:comment 'Regional grouping code for the originating country (e.g., EEA, NAFTA, APAC) used for regional cross-border fee structures.' ;
    rdfs:domain ind:CrossBorderFeeRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schemeBulletinReference rdf:type rdf:Property ;
    rdfs:label 'Scheme Bulletin Reference' ;
    rdfs:comment 'Reference number or identifier of the official card scheme bulletin or publication that announced or mandated this cross-border fee rule.' ;
    rdfs:domain ind:Interchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:swiftCorrespondentFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Swift Correspondent Fee Amount' ;
    rdfs:comment 'Fixed fee component for SWIFT messaging and correspondent banking services used in cross-border settlement. Applies when international wire transfers are required for settlement.' ;
    rdfs:domain ind:CrossBorderFeeRule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:annualReviewRequired rdf:type rdf:Property ;
    rdfs:label 'Annual Review Required' ;
    rdfs:comment 'Indicates whether issuers in this compliance tier are subject to annual Federal Reserve data collection and review (e.g., the Federal Reserve\'s annual debit card survey under Regulation II). Regulated issuers above the $10 billion threshold are subject to annual reporting.' ;
    rdfs:domain ind:DurbinComplianceTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:applicableGeography rdf:type rdf:Property ;
    rdfs:label 'Applicable Geography' ;
    rdfs:comment 'ISO 3166-1 alpha-3 country code indicating the geographic jurisdiction in which this compliance tier applies. Regulation II is a US domestic regulation; this field is \'USA\' for all standard Durbin tiers but supports future multi-jurisdiction extensions.' ;
    rdfs:domain ind:DurbinComplianceTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:assetThresholdUsd rdf:type rdf:Property ;
    rdfs:label 'Asset Threshold Usd' ;
    rdfs:comment 'Consolidated asset threshold in US dollars used to determine whether an issuer is subject to Regulation II interchange caps. The Federal Reserve sets this at $10 billion; issuers at or above this threshold are regulated. Stored as the threshold value applicable to this tier.' ;
    rdfs:domain ind:DurbinComplianceTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:costOfAcceptanceImpact rdf:type rdf:Property ;
    rdfs:label 'Cost Of Acceptance Impact' ;
    rdfs:comment 'Indicates the directional impact of this compliance tier on merchant cost of acceptance (MDR/MSF). Regulated tiers with capped interchange typically reduce cost of acceptance for merchants; exempt tiers may result in higher interchange and increased merchant cost.' ;
    rdfs:domain ind:DurbinComplianceTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:dataSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Data Source System' ;
    rdfs:comment 'Name of the operational system of record from which this compliance tier record originates or is maintained (e.g., \'Risk and Compliance Management System\', \'Transaction Processing Platform\'). Supports data lineage tracking in the Databricks Lakehouse Silver Layer.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:debitCardType rdf:type rdf:Property ;
    rdfs:label 'Debit Card Type' ;
    rdfs:comment 'Type of debit card program covered by this compliance tier. Regulation II exemptions differ by card type — government-administered and certain reloadable prepaid programs are exempt from interchange caps. [ENUM-REF-CANDIDATE: consumer_debit|prepaid|government_benefit|payroll|healthcare_fsa|commercial_debit — promote to reference product]' ;
    rdfs:domain ind:DurbinComplianceTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enabledNetworkCount rdf:type rdf:Property ;
    rdfs:label 'Enabled Network Count' ;
    rdfs:comment 'Number of unaffiliated payment networks on which debit cards in this compliance tier are enabled for routing. Regulation II requires a minimum of two unaffiliated networks. Used to validate network exclusivity compliance.' ;
    rdfs:domain ind:DurbinComplianceTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fedRegulationCitation rdf:type rdf:Property ;
    rdfs:label 'Fed Regulation Citation' ;
    rdfs:comment 'Specific Federal Register or Code of Federal Regulations citation underpinning this compliance tier (e.g., \'12 CFR Part 235\', \'Federal Register Vol. 76 No. 130\'). Provides a direct regulatory audit trail for compliance and legal review.' ;
    rdfs:domain ind:DurbinComplianceTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fedReportingPeriod rdf:type rdf:Property ;
    rdfs:label 'Fed Reporting Period' ;
    rdfs:comment 'Federal Reserve reporting period to which this compliance tier applies, formatted as YYYY-H1, YYYY-H2, YYYY-Q1, etc. The Federal Reserve collects debit card interchange data annually; this field links the tier to the applicable regulatory data collection cycle.' ;
    rdfs:domain ind:DurbinComplianceTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fraudAdjustmentCapCents rdf:type rdf:Property ;
    rdfs:label 'Fraud Adjustment Cap Cents' ;
    rdfs:comment 'Maximum additional interchange allowance in US cents per transaction for fraud-prevention activities, available to eligible regulated issuers under Regulation II. Currently set at 1 cent per transaction by the Federal Reserve. Null if fraud_adjustment_eligible is false.' ;
    rdfs:domain ind:DurbinComplianceTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:fraudAdjustmentEligible rdf:type rdf:Property ;
    rdfs:label 'Fraud Adjustment Eligible' ;
    rdfs:comment 'Indicates whether issuers in this compliance tier are eligible to receive the 1-cent fraud-prevention adjustment allowance on top of the base interchange cap under Regulation II. Eligibility requires the issuer to meet the Federal Reserve\'s fraud-prevention standards annually.' ;
    rdfs:domain ind:DurbinComplianceTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interchangeCapAdValoremBps rdf:type rdf:Property ;
    rdfs:label 'Interchange Cap Ad Valorem Bps' ;
    rdfs:comment 'Ad valorem (percentage-based) component of the Regulation II interchange cap expressed in basis points of the transaction value. Under the Federal Reserve rule, regulated issuers may charge up to 0.05% (5 basis points) of the transaction amount in addition to the fixed cent cap.' ;
    rdfs:domain ind:DurbinComplianceTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interchangeCapCents rdf:type rdf:Property ;
    rdfs:label 'Interchange Cap Cents' ;
    rdfs:comment 'Maximum allowable interchange fee in US cents per debit card transaction under Regulation II for this compliance tier. For regulated issuers, the Federal Reserve base cap is 21 cents plus 0.05% of the transaction value, with an optional 1-cent fraud-adjustment allowance. This field stores the fixed per-transaction cent component of the cap.' ;
    rdfs:domain ind:DurbinComplianceTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:issuerAssetBand rdf:type rdf:Property ;
    rdfs:label 'Issuer Asset Band' ;
    rdfs:comment 'Categorical asset size band of the issuer population covered by this tier, used for segmentation and analytics. \'above_10b\' corresponds to regulated issuers under Regulation II; bands below $10 billion are exempt. Supports revenue and cost-of-acceptance analysis by issuer size.' ;
    rdfs:domain ind:DurbinComplianceTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuerClassification rdf:type rdf:Property ;
    rdfs:label 'Issuer Classification' ;
    rdfs:comment 'Classification of the issuer under Regulation II based on asset threshold and card program type. \'regulated\' applies to issuers with consolidated assets ≥ $10 billion; \'exempt\' covers small issuers below the threshold; \'government_administered\' and \'reloadable_prepaid\' reflect statutory exemptions under Regulation II Section 235.5.' ;
    rdfs:domain ind:DurbinComplianceTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:merchantRoutingChoiceEnabled rdf:type rdf:Property ;
    rdfs:label 'Merchant Routing Choice Enabled' ;
    rdfs:comment 'Indicates whether merchants are permitted to exercise least-cost routing (LCR) or preferred network routing for transactions under this compliance tier, as required by Regulation II. True = merchant routing choice is enabled and enforced; False = routing is issuer-controlled.' ;
    rdfs:domain ind:DurbinComplianceTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:networkExclusivityCompliant rdf:type rdf:Property ;
    rdfs:label 'Network Exclusivity Compliant' ;
    rdfs:comment 'Indicates whether issuers in this tier comply with the Regulation II network exclusivity prohibition, which requires that each debit card be enabled on at least two unaffiliated payment networks (e.g., Visa and a PIN debit network). True = compliant; False = non-compliant or under review.' ;
    rdfs:domain ind:DurbinComplianceTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:pinDebitRoutingRequired rdf:type rdf:Property ;
    rdfs:label 'Pin Debit Routing Required' ;
    rdfs:comment 'Indicates whether PIN-authenticated debit routing must be offered as one of the two unaffiliated network options under Regulation II network exclusivity requirements for this compliance tier. Supports routing compliance validation.' ;
    rdfs:domain ind:DurbinComplianceTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:revenueImpactClassification rdf:type rdf:Property ;
    rdfs:label 'Revenue Impact Classification' ;
    rdfs:comment 'Classifies the financial impact of this compliance tier on the acquiring or issuing portfolio. \'revenue_generating\' = tier enables interchange income above cost; \'cost_center\' = tier results in net interchange cost; \'neutral\' = break-even. Supports revenue recognition and cost-of-acceptance analysis in ERP – Oracle Financials.' ;
    rdfs:domain ind:DurbinComplianceTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:routingType rdf:type rdf:Property ;
    rdfs:label 'Routing Type' ;
    rdfs:comment 'Indicates whether this compliance tier applies to dual-message (signature debit, e.g., Visa/Mastercard), single-message (PIN debit, e.g., Interlink/STAR), or both routing architectures. Dual-message transactions are authorized and cleared separately; single-message transactions are authorized and cleared in one message per ISO 8583.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:supersededByTierCode rdf:type rdf:Property ;
    rdfs:label 'Superseded By Tier Code' ;
    rdfs:comment 'Tier code of the compliance tier record that replaced this record when it was superseded. Null if this tier is currently active or was retired without a direct successor. Enables forward-chaining of tier version history for regulatory audit trails.' ;
    rdfs:domain ind:DurbinComplianceTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierCode rdf:type rdf:Property ;
    rdfs:label 'Tier Code' ;
    rdfs:comment 'Externally-known alphanumeric code uniquely identifying this compliance tier configuration (e.g., REG_TIER_1, EXEMPT_TIER_A). Used as the business-facing identifier in regulatory filings and interchange routing tables.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierDescription rdf:type rdf:Property ;
    rdfs:label 'Tier Description' ;
    rdfs:comment 'Detailed narrative description of the compliance tier, including the regulatory basis, applicable issuer population, and interchange cap rationale. Supports audit and regulatory review.' ;
    rdfs:domain ind:DurbinComplianceTier ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tierStatus rdf:type rdf:Property ;
    rdfs:label 'Tier Status' ;
    rdfs:comment 'Current lifecycle status of this compliance tier record. \'active\' = currently in force; \'inactive\' = no longer applicable; \'pending\' = approved but not yet effective; \'superseded\' = replaced by a newer tier version; \'under_review\' = subject to Federal Reserve or internal compliance review.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionChannel rdf:type rdf:Property ;
    rdfs:label 'Transaction Channel' ;
    rdfs:comment 'Payment transaction channel to which this compliance tier\'s interchange cap and routing rules apply. Regulation II routing requirements may differ between card-present (POS/NFC) and card-not-present (e-commerce) environments.' ;
    rdfs:domain ind:Interchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:acquiringBankLegalEntityId rdf:type rdf:Property ;
    rdfs:label 'Acquiring Bank Legal Entity Id' ;
    rdfs:comment 'Foreign key linking to ledger.legal_entity. Business justification: Billing statements require linking the acquiring bank to its legal entity for settlement and regulatory reporting.' ;
    rdfs:domain ind:Interchange ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:LegalEntity .

ind:approvedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Approved By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Billing entries require employee approval for audit and reconciliation; linking to employee enables traceability in financial controls.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:issuingBankId rdf:type rdf:Property ;
    rdfs:label 'Issuing Bank Id' ;
    rdfs:comment 'Identifier of the issuing bank (cardholder\'s bank) in the interchange billing transaction.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentsFintech .

ind:schemeInvoiceId rdf:type rdf:Property ;
    rdfs:label 'Scheme Invoice Id' ;
    rdfs:comment 'Foreign key linking to interchange.scheme_invoice. Business justification: Interchange billing records are associated with a scheme invoice; adds scheme_invoice_id FK' ;
    rdfs:domain ind:Interchange ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SchemeInvoice .

ind:transactionTypeId rdf:type rdf:Property ;
    rdfs:label 'Transaction Type Id' ;
    rdfs:comment 'Foreign key linking to reference.transaction_type. Business justification: Transaction type drives billing logic for fee assessment and compliance.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:TransactionType .

ind:billingStatus rdf:type rdf:Property ;
    rdfs:label 'Billing Status' ;
    rdfs:comment 'Current lifecycle status of the interchange billing record indicating its processing state. [ENUM-REF-CANDIDATE: DRAFT|PENDING|BILLED|SETTLED|DISPUTED|ADJUSTED|CANCELLED — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Billing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardPresentFlag rdf:type rdf:Property ;
    rdfs:label 'Card Present Flag' ;
    rdfs:comment 'Indicates whether the transactions in this billing were predominantly card-present (POS) or card-not-present (CNP) transactions, affecting interchange rates.' ;
    rdfs:domain ind:Interchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cycleIdentifier rdf:type rdf:Property ;
    rdfs:label 'Cycle Identifier' ;
    rdfs:comment 'A code or identifier representing the billing cycle frequency and sequence (e.g., monthly, weekly) for this interchange billing.' ;
    rdfs:domain ind:Interchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:discrepancyAmount rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Amount' ;
    rdfs:comment 'The monetary difference identified during reconciliation between the billed amount and expected amount, if any.' ;
    rdfs:domain ind:Interchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:glPostingDate rdf:type rdf:Property ;
    rdfs:label 'Gl Posting Date' ;
    rdfs:comment 'The date on which this interchange billing transaction was posted to the General Ledger in the ERP system.' ;
    rdfs:domain ind:Interchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:grossInterchangeAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Interchange Amount' ;
    rdfs:comment 'The total gross Interchange Reimbursement Fee (IRF) amount before any deductions or adjustments for the billing period.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:periodEndDate rdf:type rdf:Property ;
    rdfs:label 'Period End Date' ;
    rdfs:comment 'The end date of the billing period for which interchange fees are calculated and billed.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:periodStartDate rdf:type rdf:Property ;
    rdfs:label 'Period Start Date' ;
    rdfs:comment 'The start date of the billing period for which interchange fees are calculated and billed.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reconciliationStatus rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Status' ;
    rdfs:comment 'Status of the reconciliation process comparing this billing record against the card scheme\'s invoice and internal transaction records.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRecognitionDate rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Date' ;
    rdfs:comment 'The accounting date on which the interchange revenue or expense is recognized in the financial statements.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:interchangeDisputeId rdf:type rdf:Property ;
    rdfs:label 'Interchange Dispute Id' ;
    rdfs:comment 'Unique identifier for the interchange dispute record. Primary key for the interchange dispute entity.' ;
    rdfs:domain ind:InterchangeDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:billingPeriodId rdf:type rdf:Property ;
    rdfs:label 'Billing Period Id' ;
    rdfs:comment 'Reference to the interchange billing period that is the subject of the dispute, if the dispute pertains to aggregated billing rather than a single transaction.' ;
    rdfs:domain ind:InterchangeDispute ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccountingPeriod .

ind:disputedTransactionId rdf:type rdf:Property ;
    rdfs:label 'Disputed Transaction Id' ;
    rdfs:comment 'Reference to the specific transaction that is the subject of the interchange dispute, if the dispute pertains to a single transaction.' ;
    rdfs:domain ind:InterchangeDispute ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Transaction .

ind:billingPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Billing Period End Date' ;
    rdfs:comment 'End date of the billing period covered by the interchange dispute, applicable when the dispute relates to aggregated billing.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:billingPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Billing Period Start Date' ;
    rdfs:comment 'Start date of the billing period covered by the interchange dispute, applicable when the dispute relates to aggregated billing.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:claimedInterchangeAmount rdf:type rdf:Property ;
    rdfs:label 'Claimed Interchange Amount' ;
    rdfs:comment 'Interchange fee amount claimed by the disputing party as the correct amount that should have been applied.' ;
    rdfs:domain ind:InterchangeDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:claimedIrfCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Claimed Irf Category Code' ;
    rdfs:comment 'The interchange rate category code that the disputing party claims should have been applied to the transaction or billing period.' ;
    rdfs:domain ind:InterchangeDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeStatus rdf:type rdf:Property ;
    rdfs:label 'Dispute Status' ;
    rdfs:comment 'Current lifecycle status of the interchange dispute in the resolution workflow.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputedAmount rdf:type rdf:Property ;
    rdfs:label 'Disputed Amount' ;
    rdfs:comment 'The difference between the claimed and scheme-reported interchange amounts, representing the financial value in dispute.' ;
    rdfs:domain ind:InterchangeDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:initiator rdf:type rdf:Property ;
    rdfs:label 'Initiator' ;
    rdfs:comment 'Identifies which party initiated the interchange dispute (acquirer, issuer, payment platform, or card scheme).' ;
    rdfs:domain ind:InterchangeDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:respondent rdf:type rdf:Property ;
    rdfs:label 'Respondent' ;
    rdfs:comment 'Identifies which party is responding to or defending against the interchange dispute.' ;
    rdfs:domain ind:InterchangeDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schemeAppliedIrfCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Scheme Applied Irf Category Code' ;
    rdfs:comment 'The interchange rate category code that was actually applied by the card scheme, which is being disputed.' ;
    rdfs:domain ind:InterchangeDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schemeReportedInterchangeAmount rdf:type rdf:Property ;
    rdfs:label 'Scheme Reported Interchange Amount' ;
    rdfs:comment 'Interchange fee amount reported or calculated by the card scheme, which is being disputed.' ;
    rdfs:domain ind:Interchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:supportingDocumentationReference rdf:type rdf:Property ;
    rdfs:label 'Supporting Documentation Reference' ;
    rdfs:comment 'Reference identifier or location of supporting documentation, evidence, or attachments related to the interchange dispute.' ;
    rdfs:domain ind:InterchangeDispute ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downgradeId rdf:type rdf:Property ;
    rdfs:label 'Downgrade Id' ;
    rdfs:comment 'Unique identifier for the interchange downgrade event.' ;
    rdfs:domain ind:Downgrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:acquirerReferenceData rdf:type rdf:Property ;
    rdfs:label 'Acquirer Reference Data' ;
    rdfs:comment 'Additional reference data provided by the acquiring bank for tracking and reconciliation purposes.' ;
    rdfs:domain ind:Downgrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Authorization Timestamp' ;
    rdfs:comment 'The precise date and time when the transaction was authorized by the issuing bank.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:avsResponseCode rdf:type rdf:Property ;
    rdfs:label 'Avs Response Code' ;
    rdfs:comment 'Code returned by the issuer indicating the result of address verification, which is often required for optimal interchange qualification.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:captureTimestamp rdf:type rdf:Property ;
    rdfs:label 'Capture Timestamp' ;
    rdfs:comment 'The precise date and time when the authorized transaction was captured for settlement.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:cardTier rdf:type rdf:Property ;
    rdfs:label 'Card Tier' ;
    rdfs:comment 'The card product tier or level (e.g., standard, rewards, premium, corporate) which influences interchange rates.' ;
    rdfs:domain ind:Downgrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cvvResponseCode rdf:type rdf:Property ;
    rdfs:label 'Cvv Response Code' ;
    rdfs:comment 'Code returned by the issuer indicating the result of CVV verification, which is often required for optimal interchange qualification in card-not-present transactions.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:detectedTimestamp rdf:type rdf:Property ;
    rdfs:label 'Detected Timestamp' ;
    rdfs:comment 'The date and time when the interchange downgrade was identified and recorded in the system.' ;
    rdfs:domain ind:Downgrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:downgradedIrfRateBps rdf:type rdf:Property ;
    rdfs:label 'Downgraded Irf Rate Bps' ;
    rdfs:comment 'The actual interchange rate in basis points applied after the downgrade, representing a higher cost to the merchant.' ;
    rdfs:domain ind:Downgrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:durbinRegulatedIndicator rdf:type rdf:Property ;
    rdfs:label 'Durbin Regulated Indicator' ;
    rdfs:comment 'Flag indicating whether the transaction is subject to Durbin Amendment interchange rate caps for regulated debit cards.' ;
    rdfs:domain ind:Interchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:emvChipTransaction rdf:type rdf:Property ;
    rdfs:label 'Emv Chip Transaction' ;
    rdfs:comment 'Flag indicating whether the transaction used EMV chip technology, which typically qualifies for lower interchange rates.' ;
    rdfs:domain ind:Downgrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:incrementalCostAmount rdf:type rdf:Property ;
    rdfs:label 'Incremental Cost Amount' ;
    rdfs:comment 'The additional interchange fee cost incurred by the merchant due to the downgrade, calculated as the rate differential applied to the transaction amount.' ;
    rdfs:domain ind:Downgrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:incrementalCostCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Incremental Cost Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the incremental cost amount.' ;
    rdfs:domain ind:Downgrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:merchantProcessingChannel rdf:type rdf:Property ;
    rdfs:label 'Merchant Processing Channel' ;
    rdfs:comment 'The channel through which the transaction was processed, affecting interchange qualification criteria.' ;
    rdfs:domain ind:Downgrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:originalIrfRateBps rdf:type rdf:Property ;
    rdfs:label 'Original Irf Rate Bps' ;
    rdfs:comment 'The optimal interchange rate in basis points that would have applied if the transaction had not been downgraded.' ;
    rdfs:domain ind:Downgrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:preventableFlag rdf:type rdf:Property ;
    rdfs:label 'Preventable Flag' ;
    rdfs:comment 'Indicates whether the downgrade could have been prevented through merchant action or system configuration changes.' ;
    rdfs:domain ind:Downgrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rateDifferentialBps rdf:type rdf:Property ;
    rdfs:label 'Rate Differential Bps' ;
    rdfs:comment 'The difference in basis points between the downgraded rate and the original qualified rate, representing the incremental cost penalty.' ;
    rdfs:domain ind:Downgrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:remediationActionRecommended rdf:type rdf:Property ;
    rdfs:label 'Remediation Action Recommended' ;
    rdfs:comment 'Suggested corrective action for the merchant to prevent future downgrades of this type, used for merchant coaching and optimization.' ;
    rdfs:domain ind:Downgrade ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementDelayDays rdf:type rdf:Property ;
    rdfs:label 'Settlement Delay Days' ;
    rdfs:comment 'Number of days between authorization and settlement, where excessive delay can trigger interchange downgrades.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:threeDsAuthenticationStatus rdf:type rdf:Property ;
    rdfs:label 'Three Ds Authentication Status' ;
    rdfs:comment 'Status of 3-D Secure authentication for the transaction, which can affect interchange qualification for e-commerce transactions.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Transaction Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the transaction amount.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardNotPresentEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Card Not Present Eligible Flag' ;
    rdfs:comment 'True if card-not-present (e-commerce) transactions are eligible.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cardPresentEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Card Present Eligible Flag' ;
    rdfs:comment 'True if card-present (in-store) transactions are eligible.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cardTypeEligibility rdf:type rdf:Property ;
    rdfs:label 'Card Type Eligibility' ;
    rdfs:comment 'Card types that qualify for the program.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryCode rdf:type rdf:Property ;
    rdfs:label 'Category Code' ;
    rdfs:comment 'Internal code categorizing the program (e.g., Utility, Merit, Purchasing).' ;
    rdfs:domain ind:Interchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossBorderEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Cross Border Eligible Flag' ;
    rdfs:comment 'True if transactions crossing national borders qualify for the program.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:eligibilityCriteriaDescription rdf:type rdf:Property ;
    rdfs:label 'Eligibility Criteria Description' ;
    rdfs:comment 'Detailed rules that determine transaction qualification for the program.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:enrollmentRequirements rdf:type rdf:Property ;
    rdfs:label 'Enrollment Requirements' ;
    rdfs:comment 'Textual description of the criteria a merchant or issuer must satisfy to enroll in the program.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fixedFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Fixed Fee Amount' ;
    rdfs:comment 'Flat fee amount charged per transaction under this program.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:installmentEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Installment Eligible Flag' ;
    rdfs:comment 'True if installment-based transactions qualify.' ;
    rdfs:domain ind:Interchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mccEligibility rdf:type rdf:Property ;
    rdfs:label 'Mcc Eligibility' ;
    rdfs:comment 'Merchant category codes (MCC) that are eligible for the program. Multiple codes may be stored as a delimited list.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programCode rdf:type rdf:Property ;
    rdfs:label 'Program Code' ;
    rdfs:comment 'External code used to identify the interchange program in scheme documentation.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:programStatus rdf:type rdf:Property ;
    rdfs:label 'Program Status' ;
    rdfs:comment 'Current lifecycle status of the interchange program.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationCriteriaCode rdf:type rdf:Property ;
    rdfs:label 'Qualification Criteria Code' ;
    rdfs:comment 'Code referencing a detailed rule set that defines qualification logic.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:ratePercentage rdf:type rdf:Property ;
    rdfs:label 'Rate Percentage' ;
    rdfs:comment 'Percentage of transaction amount charged as interchange under this program.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:rateStructureType rdf:type rdf:Property ;
    rdfs:label 'Rate Structure Type' ;
    rdfs:comment 'Indicates whether the program uses a percentage rate, a fixed fee, or a combination.' ;
    rdfs:domain ind:Program ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recurringEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Recurring Eligible Flag' ;
    rdfs:comment 'True if recurring (subscription) transactions qualify.' ;
    rdfs:domain ind:Interchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:scheme rdf:type rdf:Property ;
    rdfs:label 'Scheme' ;
    rdfs:comment 'Payment network that defines the program.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schemePublicationDate rdf:type rdf:Property ;
    rdfs:label 'Scheme Publication Date' ;
    rdfs:comment 'Date when the scheme published the program details.' ;
    rdfs:domain ind:Interchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:tierLevel rdf:type rdf:Property ;
    rdfs:label 'Tier Level' ;
    rdfs:comment 'Tier classification that determines rate structure.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:tokenizationEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Tokenization Eligible Flag' ;
    rdfs:comment 'True if tokenized card transactions are eligible under the program.' ;
    rdfs:domain ind:Interchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transactionAmountMax rdf:type rdf:Property ;
    rdfs:label 'Transaction Amount Max' ;
    rdfs:comment 'Upper bound of transaction amount for eligibility.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionAmountMin rdf:type rdf:Property ;
    rdfs:label 'Transaction Amount Min' ;
    rdfs:comment 'Lower bound of transaction amount (in program currency) for eligibility.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:settlementCycleId rdf:type rdf:Property ;
    rdfs:label 'Settlement Cycle Id' ;
    rdfs:comment 'Foreign key linking to settlement.cycle. Business justification: Enables qualification data to be associated with the settlement cycle used in interchange fee calculations and audit trails.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentsFintech .

ind:authorizationDate rdf:type rdf:Property ;
    rdfs:label 'Authorization Date' ;
    rdfs:comment 'Date on which the transaction was authorized. Time between authorization and settlement is a factor in interchange qualification.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:avsResultCode rdf:type rdf:Property ;
    rdfs:label 'Avs Result Code' ;
    rdfs:comment 'Result code from address verification system check performed during authorization. AVS match is a qualifying criterion for many card-not-present interchange categories.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactlessFlag rdf:type rdf:Property ;
    rdfs:label 'Contactless Flag' ;
    rdfs:comment 'Indicates whether the transaction was processed using contactless NFC technology (tap-to-pay). Contactless transactions may qualify for specific interchange categories.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cvvResultCode rdf:type rdf:Property ;
    rdfs:label 'Cvv Result Code' ;
    rdfs:comment 'Result code from CVV verification performed during authorization. CVV match is a qualifying criterion for card-not-present transactions to achieve optimal interchange rates.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downgradeReasonCode rdf:type rdf:Property ;
    rdfs:label 'Downgrade Reason Code' ;
    rdfs:comment 'Code indicating why the transaction was downgraded to a higher interchange rate category. Null if transaction qualified for optimal rate. Common reasons include missing AVS, non-EMV, delayed settlement, or missing Level 2/3 data.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downgradeReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Downgrade Reason Description' ;
    rdfs:comment 'Human-readable description of why the transaction was downgraded, providing detail on the specific qualification criteria that were not met.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emvChipFlag rdf:type rdf:Property ;
    rdfs:label 'Emv Chip Flag' ;
    rdfs:comment 'Indicates whether the transaction was processed using EMV chip technology. EMV transactions typically qualify for preferential interchange rates due to enhanced security.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:irfFixedAmount rdf:type rdf:Property ;
    rdfs:label 'Irf Fixed Amount' ;
    rdfs:comment 'The fixed fee component of the qualified interchange fee applied to the transaction. Expressed in the settlement currency.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:irfRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Irf Rate Percentage' ;
    rdfs:comment 'The percentage rate component of the qualified interchange fee applied to the transaction amount. Expressed as a decimal (e.g., 0.0175 for 1.75%).' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:level2DataPresentFlag rdf:type rdf:Property ;
    rdfs:label 'Level 2 Data Present Flag' ;
    rdfs:comment 'Indicates whether Level 2 enhanced data (tax amount, customer code, etc.) was provided with the transaction. Level 2 data is required for commercial card interchange optimization.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:level3DataPresentFlag rdf:type rdf:Property ;
    rdfs:label 'Level 3 Data Present Flag' ;
    rdfs:comment 'Indicates whether Level 3 line-item data (item descriptions, quantities, unit costs) was provided with the transaction. Level 3 data is required for optimal commercial and purchasing card interchange rates.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:qualificationStatus rdf:type rdf:Property ;
    rdfs:label 'Qualification Status' ;
    rdfs:comment 'Status indicating whether the transaction qualified for the optimal interchange rate, was downgraded to a higher-cost tier, is exempt from interchange, or encountered an error during qualification.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationTimestamp rdf:type rdf:Property ;
    rdfs:label 'Qualification Timestamp' ;
    rdfs:comment 'Timestamp when the interchange qualification process was executed and the IRF category was determined. Represents the business event time of qualification.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:threeDsAuthenticationFlag rdf:type rdf:Property ;
    rdfs:label 'Three Ds Authentication Flag' ;
    rdfs:comment 'Indicates whether the transaction was authenticated using 3-D Secure protocol (Verified by Visa, Mastercard SecureCode). 3DS authentication is a qualifying criterion for e-commerce interchange optimization.' ;
    rdfs:domain ind:Qualification ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:rateHistoryId rdf:type rdf:Property ;
    rdfs:label 'Rate History Id' ;
    rdfs:comment 'Unique identifier for each interchange rate history record. Primary key for the interchange rate history audit trail.' ;
    rdfs:domain ind:RateHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supersededByHistoryRateHistoryId rdf:type rdf:Property ;
    rdfs:label 'Superseded By History Rate History Id' ;
    rdfs:comment 'Reference to the interchange_rate_history_id that superseded this rate record. Null if this is the current active rate.' ;
    rdfs:domain ind:RateHistory ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RateHistory .

ind:changeReasonCode rdf:type rdf:Property ;
    rdfs:label 'Change Reason Code' ;
    rdfs:comment 'Coded reason for the interchange rate change (e.g., annual review, regulatory mandate, market adjustment).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:changeReasonDescription rdf:type rdf:Property ;
    rdfs:label 'Change Reason Description' ;
    rdfs:comment 'Detailed explanation of why the interchange rate was changed, as provided by the card scheme.' ;
    rdfs:domain ind:RateHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contactlessEligibleFlag rdf:type rdf:Property ;
    rdfs:label 'Contactless Eligible Flag' ;
    rdfs:comment 'Indicates whether contactless (NFC) transactions are eligible for this interchange rate (True) or not (False).' ;
    rdfs:domain ind:RateHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:durbinCapAmount rdf:type rdf:Property ;
    rdfs:label 'Durbin Cap Amount' ;
    rdfs:comment 'The maximum interchange fee allowed under Durbin Amendment regulations for this rate category. Null if not Durbin-regulated.' ;
    rdfs:domain ind:Interchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:emvChipRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Emv Chip Required Flag' ;
    rdfs:comment 'Indicates whether EMV chip authentication is required to qualify for this interchange rate (True) or not (False).' ;
    rdfs:domain ind:RateHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:irfCategoryName rdf:type rdf:Property ;
    rdfs:label 'Irf Category Name' ;
    rdfs:comment 'Human-readable name of the interchange category (e.g., Card Present Retail, Card Not Present E-commerce).' ;
    rdfs:domain ind:RateHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:newFixedFee rdf:type rdf:Property ;
    rdfs:label 'New Fixed Fee' ;
    rdfs:comment 'The new fixed interchange fee amount that became effective with this change. Expressed in the rate currency.' ;
    rdfs:domain ind:RateHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:newRatePercent rdf:type rdf:Property ;
    rdfs:label 'New Rate Percent' ;
    rdfs:comment 'The new interchange rate percentage that became effective with this change. Used for forward-looking rate calculations.' ;
    rdfs:domain ind:RateHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorFixedFee rdf:type rdf:Property ;
    rdfs:label 'Prior Fixed Fee' ;
    rdfs:comment 'The fixed interchange fee amount that was in effect before this change. Expressed in the rate currency.' ;
    rdfs:domain ind:RateHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:priorRatePercent rdf:type rdf:Property ;
    rdfs:label 'Prior Rate Percent' ;
    rdfs:comment 'The interchange rate percentage that was in effect before this change. Used for historical comparison and back-billing corrections.' ;
    rdfs:domain ind:RateHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:publicationDate rdf:type rdf:Property ;
    rdfs:label 'Publication Date' ;
    rdfs:comment 'The date on which the card scheme published or announced this rate change.' ;
    rdfs:domain ind:RateHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:publicationReference rdf:type rdf:Property ;
    rdfs:label 'Publication Reference' ;
    rdfs:comment 'Reference to the source publication or bulletin where this rate change was announced (e.g., Visa April 2024 Bulletin, Mastercard Q2 2024 Rate Update).' ;
    rdfs:domain ind:RateHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateCurrency rdf:type rdf:Property ;
    rdfs:label 'Rate Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the interchange rate (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:RateHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateStatus rdf:type rdf:Property ;
    rdfs:label 'Rate Status' ;
    rdfs:comment 'Current lifecycle status of this interchange rate record (active, expired, superseded by newer rate, pending future effective date).' ;
    rdfs:domain ind:Interchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:threeDsRequiredFlag rdf:type rdf:Property ;
    rdfs:label 'Three Ds Required Flag' ;
    rdfs:comment 'Indicates whether 3-D Secure authentication is required to qualify for this interchange rate (True) or not (False).' ;
    rdfs:domain ind:RateHistory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:interchangeReconciliationId rdf:type rdf:Property ;
    rdfs:label 'Interchange Reconciliation Id' ;
    rdfs:comment 'Unique identifier for the interchange reconciliation record. Primary key.' ;
    rdfs:domain ind:InterchangeReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:acquirerId rdf:type rdf:Property ;
    rdfs:label 'Acquirer Id' ;
    rdfs:comment 'Reference to the acquiring bank (merchant\'s bank) involved in the interchange transactions.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Acquirer .

ind:approvedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Approved By User Employee Id' ;
    rdfs:comment 'Reference to the supervisor or manager who approved the reconciliation results and any adjustments.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:primaryInterchangeEcosystemPartnerId rdf:type rdf:Property ;
    rdfs:label 'Primary Interchange Ecosystem Partner Id' ;
    rdfs:comment 'Reference to the acquiring bank (merchant\'s bank) involved in the interchange transactions.' ;
    rdfs:domain ind:InterchangeReconciliation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:EcosystemPartner .

ind:primaryInterchangeEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Interchange Employee Id' ;
    rdfs:comment 'Reference to the user or analyst who performed the reconciliation and investigation.' ;
    rdfs:domain ind:InterchangeReconciliation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:adjustmentReasonCode rdf:type rdf:Property ;
    rdfs:label 'Adjustment Reason Code' ;
    rdfs:comment 'Standardized code indicating the reason for any adjustment applied to this reconciliation.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:disputeFiledDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Filed Date' ;
    rdfs:comment 'The date on which a formal dispute was filed with the card scheme regarding this reconciliation variance.' ;
    rdfs:domain ind:InterchangeReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:disputeResolutionDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Resolution Date' ;
    rdfs:comment 'The date on which the scheme dispute was resolved and final settlement amounts were agreed.' ;
    rdfs:domain ind:Interchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:glAccountCode rdf:type rdf:Property ;
    rdfs:label 'Gl Account Code' ;
    rdfs:comment 'The general ledger account code to which interchange reconciliation amounts are posted.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:internalCalculatedInterchangeAmount rdf:type rdf:Property ;
    rdfs:label 'Internal Calculated Interchange Amount' ;
    rdfs:comment 'The total interchange amount calculated internally based on qualification rules and transaction data for the settlement period.' ;
    rdfs:domain ind:InterchangeReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:internalSettlementDate rdf:type rdf:Property ;
    rdfs:label 'Internal Settlement Date' ;
    rdfs:comment 'The date on which internal settlement processing was completed for this period.' ;
    rdfs:domain ind:InterchangeReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:reconciledTimestamp rdf:type rdf:Property ;
    rdfs:label 'Reconciled Timestamp' ;
    rdfs:comment 'The date and time when the reconciliation was completed and status was finalized.' ;
    rdfs:domain ind:InterchangeReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:rootCauseDescription rdf:type rdf:Property ;
    rdfs:label 'Root Cause Description' ;
    rdfs:comment 'Detailed explanation of the root cause identified for the variance, including specific transaction or rule issues.' ;
    rdfs:domain ind:InterchangeReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schemeIdentifier rdf:type rdf:Property ;
    rdfs:label 'Scheme Identifier' ;
    rdfs:comment 'The payment card scheme (network brand) for which this reconciliation is performed.' ;
    rdfs:domain ind:InterchangeReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schemeSettlementDate rdf:type rdf:Property ;
    rdfs:label 'Scheme Settlement Date' ;
    rdfs:comment 'The date on which the card scheme settled the interchange amounts.' ;
    rdfs:domain ind:InterchangeReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:settlementPeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Settlement Period End Date' ;
    rdfs:comment 'The end date of the settlement period covered by this reconciliation.' ;
    rdfs:domain ind:Interchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:settlementPeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Settlement Period Start Date' ;
    rdfs:comment 'The start date of the settlement period covered by this reconciliation.' ;
    rdfs:domain ind:Interchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transactionCountInternal rdf:type rdf:Property ;
    rdfs:label 'Transaction Count Internal' ;
    rdfs:comment 'The total number of transactions included in the internal interchange calculation for this period.' ;
    rdfs:domain ind:InterchangeReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transactionCountScheme rdf:type rdf:Property ;
    rdfs:label 'Transaction Count Scheme' ;
    rdfs:comment 'The total number of transactions reported by the card scheme for this period.' ;
    rdfs:domain ind:InterchangeReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transactionCountVariance rdf:type rdf:Property ;
    rdfs:label 'Transaction Count Variance' ;
    rdfs:comment 'The difference in transaction counts between internal records and scheme reports.' ;
    rdfs:domain ind:InterchangeReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:varianceThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Variance Threshold Amount' ;
    rdfs:comment 'The absolute monetary threshold above which variances must be investigated and resolved.' ;
    rdfs:domain ind:InterchangeReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:varianceThresholdExceededFlag rdf:type rdf:Property ;
    rdfs:label 'Variance Threshold Exceeded Flag' ;
    rdfs:comment 'Indicates whether the variance amount or percentage exceeds the acceptable tolerance threshold requiring investigation.' ;
    rdfs:domain ind:InterchangeReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:varianceThresholdPercentage rdf:type rdf:Property ;
    rdfs:label 'Variance Threshold Percentage' ;
    rdfs:comment 'The percentage threshold above which variances must be investigated and resolved.' ;
    rdfs:domain ind:InterchangeReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:authorizationTimeframeHours rdf:type rdf:Property ;
    rdfs:label 'Authorization Timeframe Hours' ;
    rdfs:comment 'The maximum number of hours between authorization and capture for transactions to qualify for this interchange rate category.' ;
    rdfs:domain ind:IrfRateCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:cardNotPresentIndicator rdf:type rdf:Property ;
    rdfs:label 'Card Not Present Indicator' ;
    rdfs:comment 'Indicates whether this interchange rate category applies to card-not-present (CNP) transactions such as e-commerce, mail order, or telephone order.' ;
    rdfs:domain ind:IrfRateCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:categoryName rdf:type rdf:Property ;
    rdfs:label 'Category Name' ;
    rdfs:comment 'The full business name of the interchange rate category as published by the card scheme (e.g., Visa CPS/Retail, Mastercard Merit III, Amex OptBlue Standard).' ;
    rdfs:domain ind:IrfRateCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:categoryType rdf:type rdf:Property ;
    rdfs:label 'Category Type' ;
    rdfs:comment 'The classification of the interchange rate category based on card product type and transaction characteristics. [ENUM-REF-CANDIDATE: standard|premium|commercial|debit|credit|prepaid|rewards|government|healthcare — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:IrfRateCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:crossBorderTransactionIndicator rdf:type rdf:Property ;
    rdfs:label 'Cross Border Transaction Indicator' ;
    rdfs:comment 'Indicates whether this interchange rate category applies to cross-border transactions where the acquiring and issuing banks are in different countries.' ;
    rdfs:domain ind:IrfRateCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:cvvRequired rdf:type rdf:Property ;
    rdfs:label 'Cvv Required' ;
    rdfs:comment 'Indicates whether Card Verification Value (CVV) validation is required to qualify for this interchange rate category.' ;
    rdfs:domain ind:IrfRateCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:domesticTransactionIndicator rdf:type rdf:Property ;
    rdfs:label 'Domestic Transaction Indicator' ;
    rdfs:comment 'Indicates whether this interchange rate category applies to domestic transactions where the acquiring and issuing banks are in the same country.' ;
    rdfs:domain ind:IrfRateCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:downgradeCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Downgrade Category Code' ;
    rdfs:comment 'The interchange rate category code to which a transaction will be downgraded if it fails to meet the qualification criteria for this category.' ;
    rdfs:domain ind:IrfRateCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:downgradeRulesDescription rdf:type rdf:Property ;
    rdfs:label 'Downgrade Rules Description' ;
    rdfs:comment 'A detailed textual description of the conditions under which a transaction will be downgraded from this interchange rate category to a lower-tier category.' ;
    rdfs:domain ind:IrfRateCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:irfRateCategoryStatus rdf:type rdf:Property ;
    rdfs:label 'Irf Rate Category Status' ;
    rdfs:comment 'The current lifecycle status of this interchange rate category within the card schemes published rate structure.' ;
    rdfs:domain ind:IrfRateCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mccRangeEnd rdf:type rdf:Property ;
    rdfs:label 'Mcc Range End' ;
    rdfs:comment 'The ending Merchant Category Code (MCC) in the range of merchant types that qualify for this interchange rate category.' ;
    rdfs:domain ind:IrfRateCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mccRangeStart rdf:type rdf:Property ;
    rdfs:label 'Mcc Range Start' ;
    rdfs:comment 'The starting Merchant Category Code (MCC) in the range of merchant types that qualify for this interchange rate category.' ;
    rdfs:domain ind:IrfRateCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:parentCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Parent Category Code' ;
    rdfs:comment 'The code of the parent or umbrella interchange rate category under which this category is nested in the schemes taxonomy.' ;
    rdfs:domain ind:IrfRateCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationCriteriaDescription rdf:type rdf:Property ;
    rdfs:label 'Qualification Criteria Description' ;
    rdfs:comment 'A detailed textual description of all the business and technical criteria that a transaction must meet to qualify for this interchange rate category.' ;
    rdfs:domain ind:IrfRateCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schemePublicationReference rdf:type rdf:Property ;
    rdfs:label 'Scheme Publication Reference' ;
    rdfs:comment 'The reference identifier or document name from the card schemes official publication where this interchange rate category is defined (e.g., Visa USA Interchange Reimbursement Fees April 2024).' ;
    rdfs:domain ind:Interchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementTimeframeDays rdf:type rdf:Property ;
    rdfs:label 'Settlement Timeframe Days' ;
    rdfs:comment 'The number of days within which transactions in this interchange rate category must be settled to qualify for the published interchange rate.' ;
    rdfs:domain ind:IrfRateCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:threeDSecureRequired rdf:type rdf:Property ;
    rdfs:label 'Three D Secure Required' ;
    rdfs:comment 'Indicates whether 3-D Secure authentication is required for card-not-present transactions to qualify for this interchange rate category.' ;
    rdfs:domain ind:IrfRateCategory ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:irfTableId rdf:type rdf:Property ;
    rdfs:label 'Irf Table Id' ;
    rdfs:comment 'Unique identifier for the interchange reimbursement fee table record.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:IrfTable .

ind:issuerCountryId rdf:type rdf:Property ;
    rdfs:label 'Issuer Country Id' ;
    rdfs:comment 'Foreign key linking to reference.country. Business justification: Regulatory reporting requires mapping issuer ISO country codes to country reference for compliance audits.' ;
    rdfs:domain ind:IrfTable ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Country .

ind:acquirerCountryCode rdf:type rdf:Property ;
    rdfs:label 'Acquirer Country Code' ;
    rdfs:comment 'Three-letter ISO 3166-1 alpha-3 country code of the acquiring bank. Used for domestic vs. cross-border interchange rate determination. Null indicates rate applies regardless of acquirer country.' ;
    rdfs:domain ind:IrfTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:authorizationMethod rdf:type rdf:Property ;
    rdfs:label 'Authorization Method' ;
    rdfs:comment 'Card authorization method required for this interchange rate (chip, contactless, magnetic stripe, manual entry, ecommerce, token). Null indicates no specific method requirement.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:binRangeHigh rdf:type rdf:Property ;
    rdfs:label 'Bin Range High' ;
    rdfs:comment 'Upper bound of the BIN/IIN range to which this interchange rate applies. Used for BIN-level interchange qualification rules. Null indicates no BIN restriction.' ;
    rdfs:domain ind:Interchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:binRangeLow rdf:type rdf:Property ;
    rdfs:label 'Bin Range Low' ;
    rdfs:comment 'Lower bound of the BIN/IIN range to which this interchange rate applies. Used for BIN-level interchange qualification rules. Null indicates no BIN restriction.' ;
    rdfs:domain ind:Interchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:cardProductTier rdf:type rdf:Property ;
    rdfs:label 'Card Product Tier' ;
    rdfs:comment 'Card product tier or brand level (e.g., Standard, Rewards, Premium, Signature, World, World Elite, Platinum, Infinite). Higher tiers typically carry higher interchange rates. [ENUM-REF-CANDIDATE: standard|rewards|premium|signature|world|world_elite|platinum|infinite — 8 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:Interchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:costOfAcceptanceCategory rdf:type rdf:Property ;
    rdfs:label 'Cost Of Acceptance Category' ;
    rdfs:comment 'Internal classification category used for cost-of-acceptance reporting and analysis (e.g., low-cost, standard, premium, high-cost). Supports merchant pricing strategy and portfolio profitability analysis.' ;
    rdfs:domain ind:IrfTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interchangeCategoryCode rdf:type rdf:Property ;
    rdfs:label 'Interchange Category Code' ;
    rdfs:comment 'Scheme-specific code identifying the interchange rate category (e.g., CPS Retail, Merit III, Core Value, Standard). This is the authoritative classification used by the card scheme.' ;
    rdfs:domain ind:IrfTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interchangeCategoryName rdf:type rdf:Property ;
    rdfs:label 'Interchange Category Name' ;
    rdfs:comment 'Human-readable name of the interchange rate category (e.g., Card Present Signature Preferred Retail, Electronic Commerce Basic).' ;
    rdfs:domain ind:IrfTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interchangeCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Interchange Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the interchange fee amounts (e.g., USD, EUR, GBP).' ;
    rdfs:domain ind:IrfTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:interchangeFixedFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Interchange Fixed Fee Amount' ;
    rdfs:comment 'Fixed per-transaction fee component of the interchange in the currency specified by interchange_currency_code (e.g., $0.10). Combined with percentage rate to calculate total IRF.' ;
    rdfs:domain ind:IrfTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interchangeRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Interchange Rate Percentage' ;
    rdfs:comment 'Percentage rate component of the interchange fee applied to the transaction amount (e.g., 1.65% stored as 0.0165). Used in cost-of-acceptance calculations.' ;
    rdfs:domain ind:IrfTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:internalRateCode rdf:type rdf:Property ;
    rdfs:label 'Internal Rate Code' ;
    rdfs:comment 'Internal company-specific code or identifier for this interchange rate, used for mapping to internal pricing and cost-of-acceptance systems. May differ from scheme category code.' ;
    rdfs:domain ind:IrfTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumTransactionAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Transaction Amount' ;
    rdfs:comment 'Maximum transaction amount for which this interchange rate applies, in the currency specified by interchange_currency_code. Null indicates no maximum.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:minimumTransactionAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Transaction Amount' ;
    rdfs:comment 'Minimum transaction amount required for this interchange rate to apply, in the currency specified by interchange_currency_code. Null indicates no minimum.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:programIdentifier rdf:type rdf:Property ;
    rdfs:label 'Program Identifier' ;
    rdfs:comment 'Scheme-specific program or initiative identifier associated with this interchange rate (e.g., Visa CPS, Mastercard Merit, Amex OptBlue). Used for program-level reporting and qualification.' ;
    rdfs:domain ind:IrfTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:qualificationCriteria rdf:type rdf:Property ;
    rdfs:label 'Qualification Criteria' ;
    rdfs:comment 'Detailed business rules and conditions that must be met for a transaction to qualify for this interchange rate (e.g., EMV chip, AVS match, settlement within 24 hours). Free-text field capturing scheme-specific requirements.' ;
    rdfs:domain ind:IrfTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateVersion rdf:type rdf:Property ;
    rdfs:label 'Rate Version' ;
    rdfs:comment 'Version identifier for this interchange rate schedule, assigned by the card scheme. Used to track rate changes over time and ensure correct rate application.' ;
    rdfs:domain ind:IrfTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recordSourceSystem rdf:type rdf:Property ;
    rdfs:label 'Record Source System' ;
    rdfs:comment 'Name or identifier of the source system from which this interchange rate data originated (e.g., Visa Rate Feed, Mastercard Portal, Manual Entry). Used for data lineage and reconciliation.' ;
    rdfs:domain ind:IrfTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:regulatoryComplianceNotes rdf:type rdf:Property ;
    rdfs:label 'Regulatory Compliance Notes' ;
    rdfs:comment 'Free-text notes documenting regulatory compliance considerations for this interchange rate (e.g., PSD2 caps, Durbin Amendment applicability, regional regulations). Used for compliance audit and legal review.' ;
    rdfs:domain ind:IrfTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementTimeframeHours rdf:type rdf:Property ;
    rdfs:label 'Settlement Timeframe Hours' ;
    rdfs:comment 'Maximum number of hours between authorization and settlement for this interchange rate to apply (e.g., 24, 48, 72). Null indicates no settlement timeframe requirement.' ;
    rdfs:domain ind:IrfTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:transactionRegion rdf:type rdf:Property ;
    rdfs:label 'Transaction Region' ;
    rdfs:comment 'Geographic scope of the transaction (domestic, intra-regional, inter-regional, cross-border). Determines applicable interchange rate tier.' ;
    rdfs:domain ind:IrfTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:issuerInterchangeIncomeId rdf:type rdf:Property ;
    rdfs:label 'Issuer Interchange Income Id' ;
    rdfs:comment 'Unique identifier for the issuer interchange income record.' ;
    rdfs:domain ind:IssuerInterchangeIncome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:issuerId rdf:type rdf:Property ;
    rdfs:label 'Issuer Id' ;
    rdfs:comment 'Identifier of the issuing bank or financial institution earning the interchange income.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Issuer .

ind:discrepancyReasonCode rdf:type rdf:Property ;
    rdfs:label 'Discrepancy Reason Code' ;
    rdfs:comment 'Code indicating the reason for any reconciliation discrepancy (e.g., timing difference, fee mismatch, transaction dispute).' ;
    rdfs:domain ind:IssuerInterchangeIncome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossInterchangeEarned rdf:type rdf:Property ;
    rdfs:label 'Gross Interchange Earned' ;
    rdfs:comment 'Total gross interchange revenue earned by the issuer before any deductions or fees.' ;
    rdfs:domain ind:IssuerInterchangeIncome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:issuerName rdf:type rdf:Property ;
    rdfs:label 'Issuer Name' ;
    rdfs:comment 'Legal name of the issuing bank or financial institution.' ;
    rdfs:domain ind:IssuerInterchangeIncome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:netInterchangeIncome rdf:type rdf:Property ;
    rdfs:label 'Net Interchange Income' ;
    rdfs:comment 'Net interchange income after all scheme fees, processing fees, and adjustments have been deducted from gross interchange.' ;
    rdfs:domain ind:IssuerInterchangeIncome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:networkAssessmentFee rdf:type rdf:Property ;
    rdfs:label 'Network Assessment Fee' ;
    rdfs:comment 'Assessment fee charged by the card network for transaction processing.' ;
    rdfs:domain ind:IssuerInterchangeIncome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:portfolioSegment rdf:type rdf:Property ;
    rdfs:label 'Portfolio Segment' ;
    rdfs:comment 'Issuer portfolio segment or business line (e.g., consumer, commercial, small business, premium).' ;
    rdfs:domain ind:IssuerInterchangeIncome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:processingFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Processing Fee Amount' ;
    rdfs:comment 'Processing fees deducted from interchange income for transaction handling and settlement services.' ;
    rdfs:domain ind:IssuerInterchangeIncome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:schemeSettlementReference rdf:type rdf:Property ;
    rdfs:label 'Scheme Settlement Reference' ;
    rdfs:comment 'Reference number provided by the card scheme for this settlement period.' ;
    rdfs:domain ind:IssuerInterchangeIncome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:settlementCycleIdentifier rdf:type rdf:Property ;
    rdfs:label 'Settlement Cycle Identifier' ;
    rdfs:comment 'Unique identifier for the settlement cycle or batch (e.g., monthly, weekly cycle code).' ;
    rdfs:domain ind:IssuerInterchangeIncome ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:transactionVolume rdf:type rdf:Property ;
    rdfs:label 'Transaction Volume' ;
    rdfs:comment 'Total monetary volume of transactions processed during the settlement period.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mccInterchangeMapId rdf:type rdf:Property ;
    rdfs:label 'Mcc Interchange Map Id' ;
    rdfs:comment 'Unique identifier for the MCC interchange mapping record. Primary key for the table.' ;
    rdfs:domain ind:MccInterchangeMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supersededByMapMccInterchangeMapId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Map Mcc Interchange Map Id' ;
    rdfs:comment 'Reference to the mcc_interchange_map_id of the newer mapping record that replaces this one. Null if this is the current active version.' ;
    rdfs:domain ind:MccInterchangeMap ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MccInterchangeMap .

ind:durbinComplianceTier rdf:type rdf:Property ;
    rdfs:label 'Durbin Compliance Tier' ;
    rdfs:comment 'Classification tier for Durbin Amendment compliance indicating whether the MCC qualifies for exemptions, small issuer treatment, or full regulation.' ;
    rdfs:domain ind:MccInterchangeMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mappingStatus rdf:type rdf:Property ;
    rdfs:label 'Mapping Status' ;
    rdfs:comment 'Current lifecycle status of the MCC interchange mapping record. Active mappings are used for transaction qualification; Superseded mappings have been replaced by newer versions.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:merchantPricingImpact rdf:type rdf:Property ;
    rdfs:label 'Merchant Pricing Impact' ;
    rdfs:comment 'Classification of the pricing impact this MCC interchange mapping has on merchant discount rate (MDR) configuration. Indicates whether the MCC qualifies for standard, reduced, premium, or penalty pricing.' ;
    rdfs:domain ind:MccInterchangeMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueRecognitionCategory rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Category' ;
    rdfs:comment 'Accounting category code used for revenue recognition and general ledger posting of interchange income associated with this MCC. Supports financial reporting and cost-of-acceptance calculations.' ;
    rdfs:domain ind:MccInterchangeMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schemeFeeTier rdf:type rdf:Property ;
    rdfs:label 'Scheme Fee Tier' ;
    rdfs:comment 'Tier or category code for scheme assessment fees applicable to this MCC. Used to determine network fees charged by the card scheme.' ;
    rdfs:domain ind:MccInterchangeMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:sourceSystemReference rdf:type rdf:Property ;
    rdfs:label 'Source System Reference' ;
    rdfs:comment 'Reference identifier or code from the source system (e.g., Transaction Processing Platform, Merchant Management System) from which this MCC interchange mapping was originally loaded or synchronized.' ;
    rdfs:domain ind:MccInterchangeMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:specialProgramEligibility rdf:type rdf:Property ;
    rdfs:label 'Special Program Eligibility' ;
    rdfs:comment 'Comma-separated list of special interchange programs or rate qualifications this MCC is eligible for (e.g., \'Supermarket Program\', \'Fuel Program\', \'Utility Program\', \'Government/Education\', \'Emerging Markets\').' ;
    rdfs:domain ind:MccInterchangeMap ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mdrConfigId rdf:type rdf:Property ;
    rdfs:label 'Mdr Config Id' ;
    rdfs:comment 'Unique identifier for the MDR configuration record. Primary key.' ;
    rdfs:domain ind:Interchange ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:MdrConfig .

ind:primaryMdrEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Primary Mdr Employee Id' ;
    rdfs:comment 'Identifier of the user who approved this MDR configuration for activation.' ;
    rdfs:domain ind:MdrConfig ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:tertiaryMdrLastModifiedByUserEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Tertiary Mdr Last Modified By User Employee Id' ;
    rdfs:comment 'Identifier of the user who last modified this MDR configuration record.' ;
    rdfs:domain ind:MdrConfig ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:blendedRatePercent rdf:type rdf:Property ;
    rdfs:label 'Blended Rate Percent' ;
    rdfs:comment 'The blended MDR percentage applied to all transactions for this merchant, expressed as a decimal (e.g., 0.0275 for 2.75%).' ;
    rdfs:domain ind:MdrConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:configurationStatus rdf:type rdf:Property ;
    rdfs:label 'Configuration Status' ;
    rdfs:comment 'Current lifecycle status of this MDR configuration record.' ;
    rdfs:domain ind:MdrConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:contractReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Contract Reference Number' ;
    rdfs:comment 'Reference number of the merchant service agreement or contract that governs this MDR configuration.' ;
    rdfs:domain ind:Interchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fixedTransactionFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Fixed Transaction Fee Amount' ;
    rdfs:comment 'Fixed per-transaction fee charged to the merchant in addition to percentage-based MDR.' ;
    rdfs:domain ind:MdrConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interchangePlusMarginPercent rdf:type rdf:Property ;
    rdfs:label 'Interchange Plus Margin Percent' ;
    rdfs:comment 'The margin percentage added on top of interchange fees for interchange-plus pricing model, expressed as a decimal.' ;
    rdfs:domain ind:MdrConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:merchantSegmentCode rdf:type rdf:Property ;
    rdfs:label 'Merchant Segment Code' ;
    rdfs:comment 'Classification code representing the merchant segment or tier (e.g., enterprise, SMB, micro-merchant) for tiered pricing strategies.' ;
    rdfs:domain ind:MdrConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monthlySubscriptionFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Monthly Subscription Fee Amount' ;
    rdfs:comment 'Fixed monthly subscription fee for subscription-based pricing models.' ;
    rdfs:domain ind:MdrConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:monthlyVolumeThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Monthly Volume Threshold Amount' ;
    rdfs:comment 'Monthly transaction volume threshold that triggers rate adjustments or tier changes for volume-based pricing.' ;
    rdfs:domain ind:MdrConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueSharePercent rdf:type rdf:Property ;
    rdfs:label 'Revenue Share Percent' ;
    rdfs:comment 'Percentage of MDR revenue shared with partners or sub-acquirers in payment facilitator or ISO arrangements, expressed as a decimal.' ;
    rdfs:domain ind:MdrConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tier1RatePercent rdf:type rdf:Property ;
    rdfs:label 'Tier 1 Rate Percent' ;
    rdfs:comment 'MDR percentage applied to transactions in tier 1 pricing band, expressed as a decimal.' ;
    rdfs:domain ind:MdrConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tier1ThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Tier 1 Threshold Amount' ;
    rdfs:comment 'Transaction amount threshold for tier 1 pricing band in tiered pricing models. Transactions below this amount use tier 1 rate.' ;
    rdfs:domain ind:MdrConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tier2RatePercent rdf:type rdf:Property ;
    rdfs:label 'Tier 2 Rate Percent' ;
    rdfs:comment 'MDR percentage applied to transactions in tier 2 pricing band, expressed as a decimal.' ;
    rdfs:domain ind:MdrConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tier2ThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Tier 2 Threshold Amount' ;
    rdfs:comment 'Transaction amount threshold for tier 2 pricing band in tiered pricing models. Transactions between tier 1 and tier 2 thresholds use tier 2 rate.' ;
    rdfs:domain ind:MdrConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:tier3RatePercent rdf:type rdf:Property ;
    rdfs:label 'Tier 3 Rate Percent' ;
    rdfs:comment 'MDR percentage applied to transactions above tier 2 threshold in tiered pricing models, expressed as a decimal.' ;
    rdfs:domain ind:MdrConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricingTierId rdf:type rdf:Property ;
    rdfs:label 'Pricing Tier Id' ;
    rdfs:comment 'Identifier for the pricing tier or program that defines the fee structure for this merchant.' ;
    rdfs:domain ind:Interchange ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PricingTier .

ind:annualFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Annual Fee Amount' ;
    rdfs:comment 'Annual membership or service fee charged to the merchant.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:avsFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Avs Fee Amount' ;
    rdfs:comment 'Fee charged per Address Verification System check performed during transaction authorization.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Batch Fee Amount' ;
    rdfs:comment 'Fee charged per batch settlement submission by the merchant.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chargebackFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Chargeback Fee Amount' ;
    rdfs:comment 'Fee charged to the merchant for each chargeback dispute processed.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:contractTermMonths rdf:type rdf:Property ;
    rdfs:label 'Contract Term Months' ;
    rdfs:comment 'Duration in months for which this fee schedule is contractually binding.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:durbinExemptFlag rdf:type rdf:Property ;
    rdfs:label 'Durbin Exempt Flag' ;
    rdfs:comment 'Indicates whether this fee schedule applies to Durbin Amendment exempt transactions (small issuer or government/reloadable prepaid cards).' ;
    rdfs:domain ind:MsfSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:earlyTerminationFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Early Termination Fee Amount' ;
    rdfs:comment 'Fee charged if the merchant terminates the agreement before the contract term expires.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interchangePassThroughFlag rdf:type rdf:Property ;
    rdfs:label 'Interchange Pass Through Flag' ;
    rdfs:comment 'Indicates whether interchange fees are passed through to the merchant at cost (true) or bundled into the service fee (false).' ;
    rdfs:domain ind:Interchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:internationalTransactionFeeAmount rdf:type rdf:Property ;
    rdfs:label 'International Transaction Fee Amount' ;
    rdfs:comment 'Additional fee charged for cross-border or international payment transactions.' ;
    rdfs:domain ind:MsfSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:monthlyAccountFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Monthly Account Fee Amount' ;
    rdfs:comment 'Fixed monthly account maintenance or service fee charged to the merchant.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:monthlyMinimumFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Monthly Minimum Fee Amount' ;
    rdfs:comment 'Minimum monthly fee that the merchant must pay regardless of transaction volume.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:msfScheduleStatus rdf:type rdf:Property ;
    rdfs:label 'Msf Schedule Status' ;
    rdfs:comment 'Current lifecycle status of the merchant service fee schedule.' ;
    rdfs:domain ind:MsfSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pciComplianceFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Pci Compliance Fee Amount' ;
    rdfs:comment 'Fee charged for PCI DSS compliance validation, scanning, or non-compliance penalties.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:perTransactionFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Per Transaction Fee Amount' ;
    rdfs:comment 'Fixed fee amount charged per transaction processed under this schedule.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:percentageRate rdf:type rdf:Property ;
    rdfs:label 'Percentage Rate' ;
    rdfs:comment 'Percentage rate applied to transaction amount as part of the merchant service fee (e.g., 2.5% represented as 0.02500).' ;
    rdfs:domain ind:MsfSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:retrievalRequestFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Retrieval Request Fee Amount' ;
    rdfs:comment 'Fee charged for processing a retrieval request (pre-chargeback inquiry) from the issuing bank.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueRecognitionMethod rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Method' ;
    rdfs:comment 'Accounting method used to recognize revenue from this fee schedule (accrual, cash, deferred, straight-line).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:scheduleType rdf:type rdf:Property ;
    rdfs:label 'Schedule Type' ;
    rdfs:comment 'Classification of the fee schedule structure (standard, custom, promotional, tiered, interchange-plus, flat-rate).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:statementFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Statement Fee Amount' ;
    rdfs:comment 'Fee charged for generating and delivering monthly or periodic account statements to the merchant.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:voiceAuthorizationFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Voice Authorization Fee Amount' ;
    rdfs:comment 'Fee charged when a merchant obtains authorization via phone rather than electronic terminal.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeTierThresholdAmount rdf:type rdf:Property ;
    rdfs:label 'Volume Tier Threshold Amount' ;
    rdfs:comment 'Monthly transaction volume threshold amount that qualifies the merchant for this fee schedule tier.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeTierThresholdCount rdf:type rdf:Property ;
    rdfs:label 'Volume Tier Threshold Count' ;
    rdfs:comment 'Monthly transaction count threshold that qualifies the merchant for this fee schedule tier.' ;
    rdfs:domain ind:MsfSchedule ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:payfacSubMerchantPricingId rdf:type rdf:Property ;
    rdfs:label 'Payfac Sub Merchant Pricing Id' ;
    rdfs:comment 'Unique identifier for the PayFac sub-merchant pricing configuration record.' ;
    rdfs:domain ind:PayfacSubMerchantPricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:payfacId rdf:type rdf:Property ;
    rdfs:label 'Payfac Id' ;
    rdfs:comment 'Identifier of the Payment Facilitator managing this sub-merchant pricing configuration.' ;
    rdfs:domain ind:PayfacSubMerchantPricing ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:PaymentFacilitator .

ind:subMerchantId rdf:type rdf:Property ;
    rdfs:label 'Sub Merchant Id' ;
    rdfs:comment 'Identifier of the sub-merchant onboarded under the PayFac master Merchant Identification Number (MID). This sub-merchant operates under the PayFac umbrella for payment processing.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SubMerchant .

ind:baseRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Base Rate Percentage' ;
    rdfs:comment 'The base percentage rate applied to transaction volume under this pricing configuration. For interchange-plus models, this represents the markup over interchange; for flat-rate models, this is the total rate charged.' ;
    rdfs:domain ind:PayfacSubMerchantPricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:batchFee rdf:type rdf:Property ;
    rdfs:label 'Batch Fee' ;
    rdfs:comment 'Fee charged per batch settlement submission. Applicable when sub-merchant submits transaction batches for clearing and settlement.' ;
    rdfs:domain ind:PayfacSubMerchantPricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:cardTypeTier rdf:type rdf:Property ;
    rdfs:label 'Card Type Tier' ;
    rdfs:comment 'Specifies which card types this pricing configuration applies to. Enables differential pricing based on card product type (debit, credit, premium, commercial).' ;
    rdfs:domain ind:PayfacSubMerchantPricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:chargebackFee rdf:type rdf:Property ;
    rdfs:label 'Chargeback Fee' ;
    rdfs:comment 'Fee charged to the sub-merchant for each chargeback dispute processed, covering administrative and operational costs of dispute management.' ;
    rdfs:domain ind:PayfacSubMerchantPricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:durbinRegulatedPricingFlag rdf:type rdf:Property ;
    rdfs:label 'Durbin Regulated Pricing Flag' ;
    rdfs:comment 'Indicates whether this pricing configuration applies Durbin Amendment regulated debit interchange rates (True) or standard rates (False). Applicable to US debit card transactions from regulated issuers.' ;
    rdfs:domain ind:PayfacSubMerchantPricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:mccRestrictionList rdf:type rdf:Property ;
    rdfs:label 'Mcc Restriction List' ;
    rdfs:comment 'Comma-separated list of Merchant Category Codes (MCC) to which this pricing applies or is restricted. Used to enforce industry-specific pricing or risk controls.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:monthlyFee rdf:type rdf:Property ;
    rdfs:label 'Monthly Fee' ;
    rdfs:comment 'Fixed monthly service fee charged to the sub-merchant for account maintenance, platform access, and support services.' ;
    rdfs:domain ind:PayfacSubMerchantPricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:monthlyMinimumFee rdf:type rdf:Property ;
    rdfs:label 'Monthly Minimum Fee' ;
    rdfs:comment 'Minimum monthly fee threshold. If calculated fees fall below this amount, the sub-merchant is charged the minimum to ensure baseline revenue.' ;
    rdfs:domain ind:PayfacSubMerchantPricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:perTransactionFee rdf:type rdf:Property ;
    rdfs:label 'Per Transaction Fee' ;
    rdfs:comment 'Fixed fee charged per transaction processed for this sub-merchant, regardless of transaction amount. Typically expressed in the settlement currency.' ;
    rdfs:domain ind:PayfacSubMerchantPricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricingAgreementReference rdf:type rdf:Property ;
    rdfs:label 'Pricing Agreement Reference' ;
    rdfs:comment 'Reference number or identifier of the legal or commercial agreement governing this pricing configuration. Links pricing to contractual terms.' ;
    rdfs:domain ind:PayfacSubMerchantPricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingConfigurationCode rdf:type rdf:Property ;
    rdfs:label 'Pricing Configuration Code' ;
    rdfs:comment 'Business-assigned code or identifier for this specific pricing configuration, used for internal reference and reporting.' ;
    rdfs:domain ind:PayfacSubMerchantPricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingModel rdf:type rdf:Property ;
    rdfs:label 'Pricing Model' ;
    rdfs:comment 'The pricing model applied to the sub-merchant. Flat rate applies a single percentage to all transactions; tiered applies different rates based on card type or volume; interchange-plus (IC-plus) passes through interchange costs plus a markup; blended combines multiple fee components into a single rate; subscription charges a fixed periodic fee; custom represents bespoke pricing arrangements.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingStatus rdf:type rdf:Property ;
    rdfs:label 'Pricing Status' ;
    rdfs:comment 'Current lifecycle status of the pricing configuration. Draft indicates pending approval; active indicates in use; suspended indicates temporarily inactive; expired indicates past effective end date; terminated indicates permanently closed.' ;
    rdfs:domain ind:PayfacSubMerchantPricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:pricingTierLevel rdf:type rdf:Property ;
    rdfs:label 'Pricing Tier Level' ;
    rdfs:comment 'Named tier or level within a tiered pricing structure (e.g., Bronze, Silver, Gold, Platinum). Used for volume-based or relationship-based pricing differentiation.' ;
    rdfs:domain ind:PayfacSubMerchantPricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:refundFee rdf:type rdf:Property ;
    rdfs:label 'Refund Fee' ;
    rdfs:comment 'Fee charged to the sub-merchant for processing refund transactions. May be waived or reduced depending on pricing tier.' ;
    rdfs:domain ind:PayfacSubMerchantPricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueSplitPercentage rdf:type rdf:Property ;
    rdfs:label 'Revenue Split Percentage' ;
    rdfs:comment 'Percentage of net revenue (after interchange and scheme fees) retained by the PayFac. The remainder is the sub-merchant net settlement. Used for internal revenue allocation and partner reporting.' ;
    rdfs:domain ind:PayfacSubMerchantPricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:riskReservePercentage rdf:type rdf:Property ;
    rdfs:label 'Risk Reserve Percentage' ;
    rdfs:comment 'Percentage of transaction volume withheld as a rolling reserve to cover potential chargebacks, refunds, or fraud losses. Released to sub-merchant after a defined holding period.' ;
    rdfs:domain ind:PayfacSubMerchantPricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:schemeFeePassThroughFlag rdf:type rdf:Property ;
    rdfs:label 'Scheme Fee Pass Through Flag' ;
    rdfs:comment 'Indicates whether card scheme fees (Visa, Mastercard network fees) are passed through to the sub-merchant (True) or included in the pricing (False).' ;
    rdfs:domain ind:PayfacSubMerchantPricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:transactionCountCap rdf:type rdf:Property ;
    rdfs:label 'Transaction Count Cap' ;
    rdfs:comment 'Maximum number of transactions allowed per month under this pricing configuration. Used for volume-based pricing tier enforcement.' ;
    rdfs:domain ind:PayfacSubMerchantPricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:volumeCapAmount rdf:type rdf:Property ;
    rdfs:label 'Volume Cap Amount' ;
    rdfs:comment 'Maximum transaction volume allowed per month under this pricing configuration. Exceeding this cap may trigger pricing tier changes or require approval.' ;
    rdfs:domain ind:PayfacSubMerchantPricing ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:pricingExceptionId rdf:type rdf:Property ;
    rdfs:label 'Pricing Exception Id' ;
    rdfs:comment 'Unique identifier for the pricing exception record. Primary key for the pricing exception entity.' ;
    rdfs:domain ind:PricingException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:autoRenewalFlag rdf:type rdf:Property ;
    rdfs:label 'Auto Renewal Flag' ;
    rdfs:comment 'Indicates whether this pricing exception automatically renews at the end of its term. True means exception continues unless terminated, false means it expires on effective_end_date.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:businessJustification rdf:type rdf:Property ;
    rdfs:label 'Business Justification' ;
    rdfs:comment 'Detailed explanation of the business rationale for granting this exception, including competitive factors, strategic value, volume commitments, or relationship considerations.' ;
    rdfs:domain ind:PricingException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionCode rdf:type rdf:Property ;
    rdfs:label 'Exception Code' ;
    rdfs:comment 'Unique business code identifying this pricing exception for reference in contracts, invoices, and reporting.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionFixedFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Exception Fixed Fee Amount' ;
    rdfs:comment 'The negotiated per-transaction fixed fee granted under this exception. May be zero for full waiver.' ;
    rdfs:domain ind:PricingException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exceptionName rdf:type rdf:Property ;
    rdfs:label 'Exception Name' ;
    rdfs:comment 'Descriptive name for the pricing exception, typically referencing the merchant, partner, or program name.' ;
    rdfs:domain ind:PricingException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionRatePercent rdf:type rdf:Property ;
    rdfs:label 'Exception Rate Percent' ;
    rdfs:comment 'The negotiated exception rate granted to the merchant, portfolio, or partner. Expressed as decimal (e.g., 0.0225 for 2.25%).' ;
    rdfs:domain ind:PricingException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:exceptionStatus rdf:type rdf:Property ;
    rdfs:label 'Exception Status' ;
    rdfs:comment 'Current lifecycle status of the pricing exception. Draft is under construction, pending_approval awaits authorization, active is in force, suspended is temporarily inactive, expired has passed end date, terminated was cancelled before expiry.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:exceptionType rdf:type rdf:Property ;
    rdfs:label 'Exception Type' ;
    rdfs:comment 'Category of pricing exception granted. MDR discount reduces merchant discount rate, MSF waiver eliminates merchant service fees, IRF adjustment modifies interchange reimbursement fee pass-through, volume incentive provides tiered pricing based on transaction volume, promotional is temporary campaign pricing, custom is bespoke arrangement.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mccScope rdf:type rdf:Property ;
    rdfs:label 'Mcc Scope' ;
    rdfs:comment 'Defines whether the exception applies to specific MCC codes, a range of MCCs, or all merchant categories.' ;
    rdfs:domain ind:PricingException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rateDiscountBps rdf:type rdf:Property ;
    rdfs:label 'Rate Discount Bps' ;
    rdfs:comment 'The discount granted expressed in basis points (1 bps = 0.01%). Calculated as (standard_rate_percent - exception_rate_percent) * 10000. Used for revenue impact analysis.' ;
    rdfs:domain ind:PricingException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:revenueImpactCurrency rdf:type rdf:Property ;
    rdfs:label 'Revenue Impact Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the revenue impact estimate.' ;
    rdfs:domain ind:PricingException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:revenueImpactEstimate rdf:type rdf:Property ;
    rdfs:label 'Revenue Impact Estimate' ;
    rdfs:comment 'Estimated annual revenue impact (reduction) of granting this exception, calculated at time of approval. Used for financial planning and exception portfolio management.' ;
    rdfs:domain ind:PricingException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardFixedFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Standard Fixed Fee Amount' ;
    rdfs:comment 'The standard per-transaction fixed fee (Merchant Service Fee component) that would normally apply before the exception.' ;
    rdfs:domain ind:PricingException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:standardRatePercent rdf:type rdf:Property ;
    rdfs:label 'Standard Rate Percent' ;
    rdfs:comment 'The standard Merchant Discount Rate (MDR) or percentage-based fee that would normally apply before the exception. Expressed as decimal (e.g., 0.0275 for 2.75%).' ;
    rdfs:domain ind:PricingException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:terminationNoticeDays rdf:type rdf:Property ;
    rdfs:label 'Termination Notice Days' ;
    rdfs:comment 'Number of days advance notice required to terminate this pricing exception, as specified in the contract.' ;
    rdfs:domain ind:PricingException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:volumeTierCurrency rdf:type rdf:Property ;
    rdfs:label 'Volume Tier Currency' ;
    rdfs:comment 'Three-letter ISO 4217 currency code for the volume tier threshold.' ;
    rdfs:domain ind:PricingException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeTierThreshold rdf:type rdf:Property ;
    rdfs:label 'Volume Tier Threshold' ;
    rdfs:comment 'Minimum monthly or annual transaction volume required to qualify for this exception. Used for volume-based incentive pricing.' ;
    rdfs:domain ind:PricingException ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueRecognitionEntryId rdf:type rdf:Property ;
    rdfs:label 'Revenue Recognition Entry Id' ;
    rdfs:comment 'Unique identifier for the revenue recognition entry. Primary key for this entity.' ;
    rdfs:domain ind:RevenueRecognitionEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalEntryRevenueRecognitionEntryId rdf:type rdf:Property ;
    rdfs:label 'Original Entry Revenue Recognition Entry Id' ;
    rdfs:comment 'Identifier of the original revenue recognition entry if this entry is an adjustment or reversal (null for original entries).' ;
    rdfs:domain ind:RevenueRecognitionEntry ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:RevenueRecognitionEntry .

ind:settlementBatchId rdf:type rdf:Property ;
    rdfs:label 'Settlement Batch Id' ;
    rdfs:comment 'Identifier of the settlement batch that generated this revenue recognition entry.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SettlementBatch .

ind:adjustmentDescription rdf:type rdf:Property ;
    rdfs:label 'Adjustment Description' ;
    rdfs:comment 'Free-text description providing additional context for any adjustment or reversal applied to this entry.' ;
    rdfs:domain ind:RevenueRecognitionEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:deferredAmount rdf:type rdf:Property ;
    rdfs:label 'Deferred Amount' ;
    rdfs:comment 'The portion of gross revenue that is deferred to future periods under revenue recognition rules.' ;
    rdfs:domain ind:RevenueRecognitionEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:erpBatchReference rdf:type rdf:Property ;
    rdfs:label 'Erp Batch Reference' ;
    rdfs:comment 'The batch identifier in the ERP system (Oracle Financials) to which this revenue recognition entry was posted.' ;
    rdfs:domain ind:RevenueRecognitionEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:grossAmount rdf:type rdf:Property ;
    rdfs:label 'Gross Amount' ;
    rdfs:comment 'The total gross revenue amount before any deferrals or adjustments.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:interchangeRateApplied rdf:type rdf:Property ;
    rdfs:label 'Interchange Rate Applied' ;
    rdfs:comment 'The effective interchange rate (as a decimal) applied to calculate the interchange income component of this entry.' ;
    rdfs:domain ind:RevenueRecognitionEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mdrRateApplied rdf:type rdf:Property ;
    rdfs:label 'Mdr Rate Applied' ;
    rdfs:comment 'The effective Merchant Discount Rate (as a decimal) applied to calculate the MSF income component of this entry.' ;
    rdfs:domain ind:RevenueRecognitionEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:netRevenueAmount rdf:type rdf:Property ;
    rdfs:label 'Net Revenue Amount' ;
    rdfs:comment 'The net revenue amount after deducting scheme fees and other pass-through costs from recognized revenue.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:postedToGlTimestamp rdf:type rdf:Property ;
    rdfs:label 'Posted To Gl Timestamp' ;
    rdfs:comment 'Timestamp when this revenue recognition entry was posted to the General Ledger system.' ;
    rdfs:domain ind:RevenueRecognitionEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:productLineCode rdf:type rdf:Property ;
    rdfs:label 'Product Line Code' ;
    rdfs:comment 'Code representing the product line or service category for which revenue is recognized (e.g., acquiring, issuing, gateway services).' ;
    rdfs:domain ind:RevenueRecognitionEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognitionDate rdf:type rdf:Property ;
    rdfs:label 'Recognition Date' ;
    rdfs:comment 'The date on which the revenue is recognized in accordance with ASC 606 revenue recognition principles.' ;
    rdfs:domain ind:RevenueRecognitionEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:recognitionStatus rdf:type rdf:Property ;
    rdfs:label 'Recognition Status' ;
    rdfs:comment 'Current status of the revenue recognition entry in the accounting workflow: pending, recognized, adjusted, reversed, or finalized.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:recognizedAmount rdf:type rdf:Property ;
    rdfs:label 'Recognized Amount' ;
    rdfs:comment 'The net revenue amount recognized in the current period (gross_amount minus deferred_amount).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueShareAmount rdf:type rdf:Property ;
    rdfs:label 'Revenue Share Amount' ;
    rdfs:comment 'The absolute revenue amount shared with the partner, calculated from recognized_amount and revenue_share_percentage.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueSharePercentage rdf:type rdf:Property ;
    rdfs:label 'Revenue Share Percentage' ;
    rdfs:comment 'The percentage of recognized revenue shared with the partner (as a decimal, e.g., 0.1500 for 15%).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:revenueType rdf:type rdf:Property ;
    rdfs:label 'Revenue Type' ;
    rdfs:comment 'Classification of the revenue type being recognized: interchange income, Merchant Service Fee (MSF) income, scheme fee pass-through, gateway fee, processing fee, or other.' ;
    rdfs:domain ind:RevenueRecognitionEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:soxControlFlag rdf:type rdf:Property ;
    rdfs:label 'Sox Control Flag' ;
    rdfs:comment 'Boolean flag indicating whether this entry has passed SOX compliance controls and internal audit checks.' ;
    rdfs:domain ind:RevenueRecognitionEntry ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:schemeFeeTableId rdf:type rdf:Property ;
    rdfs:label 'Scheme Fee Table Id' ;
    rdfs:comment 'Unique identifier for the scheme fee table record.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SchemeFeeTable .

ind:assessmentBasis rdf:type rdf:Property ;
    rdfs:label 'Assessment Basis' ;
    rdfs:comment 'Basis on which assessment fees are calculated: gross volume (total transaction value including refunds), net volume (purchases minus refunds), or transaction count.' ;
    rdfs:domain ind:SchemeFeeTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:digitalWalletIndicator rdf:type rdf:Property ;
    rdfs:label 'Digital Wallet Indicator' ;
    rdfs:comment 'Indicates whether this fee applies specifically to digital wallet or tokenized transactions (e.g., Apple Pay, Google Pay, Samsung Pay). True if digital-wallet-specific, false otherwise.' ;
    rdfs:domain ind:SchemeFeeTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:domesticInternationalIndicator rdf:type rdf:Property ;
    rdfs:label 'Domestic International Indicator' ;
    rdfs:comment 'Specifies whether the fee applies to domestic transactions (same country acquirer/issuer), international (cross-border), or both.' ;
    rdfs:domain ind:SchemeFeeTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeCode rdf:type rdf:Property ;
    rdfs:label 'Fee Code' ;
    rdfs:comment 'Scheme-assigned alphanumeric code uniquely identifying this fee within the scheme\'s fee schedule.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeFixedAmount rdf:type rdf:Property ;
    rdfs:label 'Fee Fixed Amount' ;
    rdfs:comment 'Fixed fee amount per transaction in the fee currency. Null if fee is not fixed-amount-based.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feeName rdf:type rdf:Property ;
    rdfs:label 'Fee Name' ;
    rdfs:comment 'Descriptive name of the specific fee as published by the card scheme (e.g., \'Visa Assessment Fee\', \'Mastercard Cross-Border Volume Fee\', \'Amex Digital Enablement Fee\').' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeRatePercentage rdf:type rdf:Property ;
    rdfs:label 'Fee Rate Percentage' ;
    rdfs:comment 'Percentage rate applied to transaction value, expressed as decimal (e.g., 0.00125 for 12.5 basis points). Null if fee is not percentage-based.' ;
    rdfs:domain ind:SchemeFeeTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feeRateType rdf:type rdf:Property ;
    rdfs:label 'Fee Rate Type' ;
    rdfs:comment 'Structure of the fee calculation: percentage (basis points of transaction value), fixed (flat amount per transaction), tiered (volume-based brackets), or hybrid (combination).' ;
    rdfs:domain ind:Interchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:maximumFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Maximum Fee Amount' ;
    rdfs:comment 'Maximum fee amount charged per transaction, capping percentage-based fees for high-value transactions.' ;
    rdfs:domain ind:SchemeFeeTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:mccRangeHigh rdf:type rdf:Property ;
    rdfs:label 'Mcc Range High' ;
    rdfs:comment 'Upper bound of MCC range to which this fee applies. Used for merchant-category-specific fees. Null if fee applies to all MCCs.' ;
    rdfs:domain ind:SchemeFeeTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:mccRangeLow rdf:type rdf:Property ;
    rdfs:label 'Mcc Range Low' ;
    rdfs:comment 'Lower bound of MCC range to which this fee applies. Used for merchant-category-specific fees. Null if fee applies to all MCCs.' ;
    rdfs:domain ind:SchemeFeeTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:minimumFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Minimum Fee Amount' ;
    rdfs:comment 'Minimum fee amount charged per transaction, regardless of percentage calculation. Ensures floor for low-value transactions.' ;
    rdfs:domain ind:SchemeFeeTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:threeDSecureIndicator rdf:type rdf:Property ;
    rdfs:label 'Three D Secure Indicator' ;
    rdfs:comment 'Indicates whether this fee applies to transactions authenticated via 3-D Secure protocol (3DS 1.0 or 3DS 2.0). True if 3DS-specific, false otherwise.' ;
    rdfs:domain ind:SchemeFeeTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:volumeTierLowerBound rdf:type rdf:Property ;
    rdfs:label 'Volume Tier Lower Bound' ;
    rdfs:comment 'Lower threshold of transaction volume or count for tiered fee structures. Null if fee is not volume-tiered.' ;
    rdfs:domain ind:SchemeFeeTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:volumeTierUnit rdf:type rdf:Property ;
    rdfs:label 'Volume Tier Unit' ;
    rdfs:comment 'Unit of measurement for volume tiers: transaction count (number of transactions) or transaction value (monetary volume).' ;
    rdfs:domain ind:SchemeFeeTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:volumeTierUpperBound rdf:type rdf:Property ;
    rdfs:label 'Volume Tier Upper Bound' ;
    rdfs:comment 'Upper threshold of transaction volume or count for tiered fee structures. Null for open-ended top tier.' ;
    rdfs:domain ind:SchemeFeeTable ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:chargebackProcessingFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Chargeback Processing Fee Amount' ;
    rdfs:comment 'The portion of the invoice representing fees charged by the card scheme for processing chargebacks and disputes during the billing period. Includes fees for dispute lifecycle management and arbitration services.' ;
    rdfs:domain ind:SchemeInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:compliancePenaltyAmount rdf:type rdf:Property ;
    rdfs:label 'Compliance Penalty Amount' ;
    rdfs:comment 'The portion of the invoice representing penalties or fines assessed by the card scheme for non-compliance with network rules, PCI DSS requirements, or other regulatory standards. Zero if no penalties were assessed.' ;
    rdfs:domain ind:SchemeInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:crossBorderFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Cross Border Fee Amount' ;
    rdfs:comment 'The portion of the invoice representing fees charged for cross-border or international transactions where the issuing bank and acquiring bank are in different countries or regions.' ;
    rdfs:domain ind:SchemeInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:disputeDate rdf:type rdf:Property ;
    rdfs:label 'Dispute Date' ;
    rdfs:comment 'The date on which this invoice was formally disputed with the card scheme. Null if invoice has not been disputed.' ;
    rdfs:domain ind:SchemeInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:interchangeReimbursementFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Interchange Reimbursement Fee Amount' ;
    rdfs:comment 'The portion of the invoice representing Interchange Reimbursement Fees (IRF) paid between acquiring and issuing banks through the card scheme. This is the fee paid by the acquiring bank to the issuing bank for each transaction.' ;
    rdfs:domain ind:SchemeInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:invoiceCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Invoice Currency Code' ;
    rdfs:comment 'The three-letter ISO 4217 currency code in which this scheme invoice is denominated. All monetary amounts on this invoice are expressed in this currency.' ;
    rdfs:domain ind:SchemeInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceDate rdf:type rdf:Property ;
    rdfs:label 'Invoice Date' ;
    rdfs:comment 'The date on which the card scheme issued this invoice. This is the principal business event timestamp representing when the billing statement was generated and sent.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:invoiceDocumentUrl rdf:type rdf:Property ;
    rdfs:label 'Invoice Document Url' ;
    rdfs:comment 'The URL or file path to the original invoice document (PDF or other format) provided by the card scheme. Used for audit trail and detailed line-item review.' ;
    rdfs:domain ind:SchemeInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceNumber rdf:type rdf:Property ;
    rdfs:label 'Invoice Number' ;
    rdfs:comment 'The externally-known unique invoice number assigned by the card scheme (Visa, Mastercard, Amex, Discover) for this billing statement. This is the business identifier used for reconciliation and payment reference.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:invoiceStatus rdf:type rdf:Property ;
    rdfs:label 'Invoice Status' ;
    rdfs:comment 'Current lifecycle status of the scheme invoice indicating its payment and processing state. Tracks the invoice from issuance through payment completion or dispute resolution.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:networkParticipationFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Network Participation Fee Amount' ;
    rdfs:comment 'The portion of the invoice representing fees charged for participation in the card scheme network. This is a recurring membership or access fee for being part of the payment network.' ;
    rdfs:domain ind:SchemeInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:paymentReferenceNumber rdf:type rdf:Property ;
    rdfs:label 'Payment Reference Number' ;
    rdfs:comment 'The unique reference number or transaction identifier for the payment made to settle this invoice. Used for payment reconciliation and audit trail. Null if invoice is unpaid.' ;
    rdfs:domain ind:Interchange ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:schemeServiceFeeAmount rdf:type rdf:Property ;
    rdfs:label 'Scheme Service Fee Amount' ;
    rdfs:comment 'The portion of the invoice representing fees for specific card scheme services such as tokenization, fraud prevention, dispute resolution, or other value-added services provided by the network.' ;
    rdfs:domain ind:SchemeInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:totalAmountDue rdf:type rdf:Property ;
    rdfs:label 'Total Amount Due' ;
    rdfs:comment 'The total amount payable to the card scheme for this invoice, representing the sum of all line-item fees, assessments, and charges. This is the net total amount due before any adjustments or credits.' ;
    rdfs:domain ind:SchemeInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionValue rdf:type rdf:Property ;
    rdfs:label 'Transaction Value' ;
    rdfs:comment 'The total monetary value of all transactions processed through the card scheme network during the billing period, expressed in the invoice currency. Represents the Total Payment Volume (TPV) or Gross Merchandise Value (GMV) for fee calculation purposes.' ;
    rdfs:domain ind:SchemeInvoice ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:schemeInvoiceLineId rdf:type rdf:Property ;
    rdfs:label 'Scheme Invoice Line Id' ;
    rdfs:comment 'Unique identifier for the scheme invoice line item. Primary key for this entity.' ;
    rdfs:domain ind:SchemeInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:originalInvoiceLineSchemeInvoiceLineId rdf:type rdf:Property ;
    rdfs:label 'Original Invoice Line Scheme Invoice Line Id' ;
    rdfs:comment 'Reference to the original scheme_invoice_line_id that this adjustment line is correcting. Null for original fee charges. Used to trace adjustment history and maintain audit trail for billing corrections.' ;
    rdfs:domain ind:SchemeInvoiceLine ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:SchemeInvoiceLine .

ind:adjustmentIndicator rdf:type rdf:Property ;
    rdfs:label 'Adjustment Indicator' ;
    rdfs:comment 'Indicates whether this line item represents an adjustment or correction to a previously billed fee. True for adjustments, credits, or corrections; false for original fee charges. Used to track billing accuracy and dispute resolution.' ;
    rdfs:domain ind:SchemeInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:billingCurrencyCode rdf:type rdf:Property ;
    rdfs:label 'Billing Currency Code' ;
    rdfs:comment 'Three-letter ISO 4217 currency code in which this fee is billed. All monetary amounts on this line (transaction_value_basis, fee_amount) are expressed in this currency.' ;
    rdfs:domain ind:SchemeInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeCategory rdf:type rdf:Property ;
    rdfs:label 'Fee Category' ;
    rdfs:comment 'High-level classification of the fee for reporting and cost allocation. Groups related fee types into business-meaningful categories for financial analysis and revenue recognition. [ENUM-REF-CANDIDATE: interchange|assessment|network|authorization|cross_border|chargeback|dispute|service|other — 9 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:feeRate rdf:type rdf:Property ;
    rdfs:label 'Fee Rate' ;
    rdfs:comment 'The rate applied to calculate this fee. May represent a percentage (e.g., 0.015 for 1.5%), a per-transaction amount, or a tiered rate depending on fee_rate_type. Used in conjunction with transaction_volume_basis or transaction_value_basis to compute fee_amount.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:feeTypeCode rdf:type rdf:Property ;
    rdfs:label 'Fee Type Code' ;
    rdfs:comment 'Card scheme-specific code identifying the type of fee being charged. Examples include interchange reimbursement fees (IRF), assessment fees, network fees, authorization fees, cross-border fees, and scheme service fees. Aligns with Visa and Mastercard fee code taxonomies.' ;
    rdfs:domain ind:SchemeInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:lineNumber rdf:type rdf:Property ;
    rdfs:label 'Line Number' ;
    rdfs:comment 'Sequential line number within the parent scheme invoice. Used for ordering and referencing specific line items in reconciliation and dispute processes.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:servicePeriodEndDate rdf:type rdf:Property ;
    rdfs:label 'Service Period End Date' ;
    rdfs:comment 'End date of the service period that this fee line covers. Defines the end of the transaction activity window used to calculate this fee. Used for period-based reconciliation and revenue recognition cutoff.' ;
    rdfs:domain ind:SchemeInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:servicePeriodStartDate rdf:type rdf:Property ;
    rdfs:label 'Service Period Start Date' ;
    rdfs:comment 'Start date of the service period that this fee line covers. Defines the beginning of the transaction activity window used to calculate this fee. Used for period-based reconciliation and accrual accounting.' ;
    rdfs:domain ind:SchemeInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:date .

ind:transactionValueBasis rdf:type rdf:Property ;
    rdfs:label 'Transaction Value Basis' ;
    rdfs:comment 'Total monetary value of transactions that this fee line is calculated against. Represents the dollar volume basis used for percentage-based fee calculations. Expressed in the billing currency.' ;
    rdfs:domain ind:SchemeInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:transactionVolumeBasis rdf:type rdf:Property ;
    rdfs:label 'Transaction Volume Basis' ;
    rdfs:comment 'Number of transactions or events that this fee line is calculated against. Represents the volume basis (transaction count, authorization count, or other countable unit) used to compute the fee amount.' ;
    rdfs:domain ind:SchemeInvoiceLine ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:volumeTierThresholdId rdf:type rdf:Property ;
    rdfs:label 'Volume Tier Threshold Id' ;
    rdfs:comment 'Unique identifier for the volume tier threshold configuration record.' ;
    rdfs:domain ind:VolumeTierThreshold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:supersededByTierVolumeTierThresholdId rdf:type rdf:Property ;
    rdfs:label 'Superseded By Tier Volume Tier Threshold Id' ;
    rdfs:comment 'Reference to the volume_tier_threshold_id that replaces this configuration when a new version is published. Null if this is the current active version.' ;
    rdfs:domain ind:VolumeTierThreshold ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:VolumeTierThreshold .

ind:applicableFixedFee rdf:type rdf:Property ;
    rdfs:label 'Applicable Fixed Fee' ;
    rdfs:comment 'Fixed fee amount per transaction that applies when this tier threshold is met.' ;
    rdfs:domain ind:VolumeTierThreshold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:applicableRatePercent rdf:type rdf:Property ;
    rdfs:label 'Applicable Rate Percent' ;
    rdfs:comment 'Interchange rate percentage or MDR percentage that applies when this tier threshold is met. Expressed as decimal (e.g., 0.0250 for 2.50%).' ;
    rdfs:domain ind:VolumeTierThreshold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:discountRatePercent rdf:type rdf:Property ;
    rdfs:label 'Discount Rate Percent' ;
    rdfs:comment 'Discount percentage applied to standard rates when merchant qualifies for this volume tier. Expressed as decimal (e.g., 0.0050 for 0.50% discount).' ;
    rdfs:domain ind:VolumeTierThreshold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:lowerBound rdf:type rdf:Property ;
    rdfs:label 'Lower Bound' ;
    rdfs:comment 'Minimum volume threshold value required to qualify for this tier (inclusive). Null indicates no lower limit.' ;
    rdfs:domain ind:VolumeTierThreshold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:measurementPeriod rdf:type rdf:Property ;
    rdfs:label 'Measurement Period' ;
    rdfs:comment 'Time period over which volume is measured to determine tier qualification (e.g., monthly, quarterly, annual, rolling 30 days). [ENUM-REF-CANDIDATE: daily|weekly|monthly|quarterly|annual|rolling_30_days|rolling_90_days — 7 candidates stripped; promote to reference product]' ;
    rdfs:domain ind:VolumeTierThreshold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:measurementUnit rdf:type rdf:Property ;
    rdfs:label 'Measurement Unit' ;
    rdfs:comment 'Unit of measure for the threshold bounds (count for transaction volume, currency_amount for TPV, percentage for rate-based thresholds).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:rebateAmount rdf:type rdf:Property ;
    rdfs:label 'Rebate Amount' ;
    rdfs:comment 'Fixed rebate amount provided to merchant or issuer when this volume tier is achieved during the measurement period.' ;
    rdfs:domain ind:VolumeTierThreshold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:thresholdType rdf:type rdf:Property ;
    rdfs:label 'Threshold Type' ;
    rdfs:comment 'Type of volume measurement used to determine tier qualification (transaction count, TPV amount, monthly volume, annual volume, or quarterly volume).' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:upperBound rdf:type rdf:Property ;
    rdfs:label 'Upper Bound' ;
    rdfs:comment 'Maximum volume threshold value for this tier (exclusive). Null indicates no upper limit.' ;
    rdfs:domain ind:VolumeTierThreshold ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:accountReconciliationId rdf:type rdf:Property ;
    rdfs:label 'Account Reconciliation Id' ;
    rdfs:comment 'System-generated unique identifier for the account reconciliation record.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccountReconciliation .

ind:accountingPeriodId rdf:type rdf:Property ;
    rdfs:label 'Accounting Period Id' ;
    rdfs:comment 'Foreign key linking to ledger.accounting_period. Business justification: Account reconciliation records are generated per accounting period; FK provides direct period context.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:AccountingPeriod .

ind:preparedByEmployeeId rdf:type rdf:Property ;
    rdfs:label 'Prepared By Employee Id' ;
    rdfs:comment 'Foreign key linking to workforce.employee. Business justification: Reconciliation process records the employee who prepared the reconciliation; required for internal control reports.' ;
    rdfs:domain ind:AccountReconciliation ;
    rdf:type owl:ObjectProperty ;
    rdfs:range ind:Employee .

ind:accountReconciliationStatus rdf:type rdf:Property ;
    rdfs:label 'Account Reconciliation Status' ;
    rdfs:comment 'Current lifecycle state of the reconciliation record.' ;
    rdfs:domain ind:AccountReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:adjustedBalance rdf:type rdf:Property ;
    rdfs:label 'Adjusted Balance' ;
    rdfs:comment 'Balance after applying reconciling adjustments.' ;
    rdfs:domain ind:AccountReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:agingDays rdf:type rdf:Property ;
    rdfs:label 'Aging Days' ;
    rdfs:comment 'Number of days unresolved reconciling items have been outstanding.' ;
    rdfs:domain ind:AccountReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:closedReconcilingItemsCount rdf:type rdf:Property ;
    rdfs:label 'Closed Reconciling Items Count' ;
    rdfs:comment 'Count of reconciling items that have been resolved.' ;
    rdfs:domain ind:AccountReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:fiscalPeriod rdf:type rdf:Property ;
    rdfs:label 'Fiscal Period' ;
    rdfs:comment 'Numeric period within the fiscal year (e.g., month number).' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:fiscalYear rdf:type rdf:Property ;
    rdfs:label 'Fiscal Year' ;
    rdfs:comment 'Four-digit fiscal year to which the reconciliation belongs.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:glBalanceBook rdf:type rdf:Property ;
    rdfs:label 'Gl Balance Book' ;
    rdfs:comment 'Balance of the GL account as recorded in the books for the period.' ;
    rdfs:domain ind:AccountReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:isAutoReconciled rdf:type rdf:Property ;
    rdfs:label 'Is Auto Reconciled' ;
    rdfs:comment 'Flag indicating whether the reconciliation was performed automatically by the system.' ;
    rdfs:domain ind:AccountReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isConsolidated rdf:type rdf:Property ;
    rdfs:label 'Is Consolidated' ;
    rdfs:comment 'Indicates whether the GL account is part of a consolidated reporting hierarchy.' ;
    rdfs:domain ind:Ledger ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:lastReconciledTimestamp rdf:type rdf:Property ;
    rdfs:label 'Last Reconciled Timestamp' ;
    rdfs:comment 'Timestamp of the most recent successful reconciliation run for this account/period.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:openReconcilingItemsCount rdf:type rdf:Property ;
    rdfs:label 'Open Reconciling Items Count' ;
    rdfs:comment 'Count of reconciling items that remain unresolved.' ;
    rdfs:domain ind:AccountReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:integer .

ind:reconciliationCycle rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Cycle' ;
    rdfs:comment 'Scheduled frequency of the reconciliation (e.g., monthly).' ;
    rdfs:domain ind:AccountReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationMethod rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Method' ;
    rdfs:comment 'Technique used to perform the reconciliation.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconciliationNumber rdf:type rdf:Property ;
    rdfs:label 'Reconciliation Number' ;
    rdfs:comment 'Business-visible identifier or reference number for the reconciliation run.' ;
    rdfs:domain ind:PaymentsFintech ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:reconcilingItemsTotal rdf:type rdf:Property ;
    rdfs:label 'Reconciling Items Total' ;
    rdfs:comment 'Aggregate amount of all reconciling items identified for the period.' ;
    rdfs:domain ind:AccountReconciliation ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:decimal .

ind:reviewedBy rdf:type rdf:Property ;
    rdfs:label 'Reviewed By' ;
    rdfs:comment 'Identifier of the employee who reviewed the reconciliation.' ;
    rdfs:domain ind:AccountReconciliation ;
    rdf:type owl:DatatypeProperty ;
