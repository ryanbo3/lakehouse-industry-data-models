ind:emvConfigDescription rdf:type rdf:Property ;
    rdfs:label 'Emv Config Description' ;
    rdfs:comment 'Free-form description providing additional context for the configuration.' ;
    rdfs:domain ind:EmvConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emvConfigStatus rdf:type rdf:Property ;
    rdfs:label 'Emv Config Status' ;
    rdfs:comment 'Current lifecycle status of the EMV configuration.' ;
    rdfs:domain ind:EmvConfig ;
    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:emvcoSpecVersion rdf:type rdf:Property ;
