    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:boolean .

ind:isFeeApplicable rdf:type rdf:Property ;
    rdfs:label 'Is Fee Applicable' ;
    rdfs:comment 'True if the message type may incur processing fees or interchange charges.' ;
