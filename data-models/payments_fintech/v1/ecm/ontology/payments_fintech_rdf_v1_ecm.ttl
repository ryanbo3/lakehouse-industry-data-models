    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:dateTime .

ind:isManualChange rdf:type rdf:Property ;
    rdfs:label 'Is Manual Change' ;
    rdfs:comment 'True if a human operator performed the change; false for automated system actions.' ;
