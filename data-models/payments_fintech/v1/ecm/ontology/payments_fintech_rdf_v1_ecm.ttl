    rdf:type owl:DatatypeProperty ;
    rdfs:range xsd:string .

ind:branchCode rdf:type rdf:Property ;
    rdfs:label 'Branch Code' ;
    rdfs:comment 'Three-character branch identifier (optional for 11-character BICs).' ;
