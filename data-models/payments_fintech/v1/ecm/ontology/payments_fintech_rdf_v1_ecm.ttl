ind:softwareVersionAfter rdf:type rdf:Property ;
    rdfs:label 'Software Version After' ;
    rdfs:comment 'The firmware or software version installed on the terminal after the update completes.' ;
    rdfs:domain ind:SoftwareUpdate ;
    rdf:type owl:DatatypeProperty ;
